		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。今度はオマンコで、あなたのオチンチンを感じさせてく\nださい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ええ……もう濡れてしまっています……。あなたのオチンチンが、オマンコ\nに当たっているから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんっ。後ろからおっぱいを揉んで……あっ、あはんっ！　強めにぎゅうっ\nて……気持ちよくなっちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんぅっ！　はぁっ、あぁんっ！　おっぱい揉まれながら……腰をくねらせ\nて……んっ、ふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「濡れたオマンコを……オチンチンにこすりつけてしまいます……。あっ、あ\nあ……だめぇ……どんどん濡れちゃうからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはぁ……ま、また……おねだりさせるんですね……。はぁ……はぁ……お\nねだり……オチンチンおねだりしますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どうか……オチンチンを……わたしの、いやらしいびしょ濡れオマンコにぃ\n……。ハメて……ずぼずぼ動かして……ください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オマンコだけかって……？　そんなことありません。おっぱいも、あなたの\n好きに……めちゃくちゃにしていいですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だから……いっぱいオマンコして……！　オチンチンをハメて……おっぱい\nもあなたの手で乱暴にしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　はぁああぁぁぁんっ！　き……きたぁ……！　オチンチンが…\n…ずぶって……奥までぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オマンコ、キツキツですよね……。んっ、だってこの身体を許したのは、あ\nなただけですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ずっと……指とオモチャで我慢させてきたオマンコに……あなたのオチンチ\nンがきて……ああ……だめぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オマンコが勝手に……イッちゃうぅ……っ！　あっ、ああ……あああぁぁぁ\n～～～んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ごめんなさい……。久しぶりのオチンチンで……悦びアク\nメしちゃういやらしいオマンコで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっ、ああんっ！　イッたばかりのオマンコにっ、さっそくピストンぅっ！\n　あっ、んぁっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ぶっといオチンチンっ、ずんっ、ずんって、はっ、激しく突き上げて……あ\nっ、あぁんっ、いいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そ……そうです……。昔より、ずっといやらしくなりました……。んふぅ…\n…オマンコも……おっぱいも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ひぃんっ！　乳首も大きくなっちゃいました……！　いっぱい……ここを弄\nってオナニーしたので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたの手で、勃起乳首こねくりまわされるの想像しながら、自分で……ん\nぁっ、そうです、そんなふうにいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ぎゅってして、ぐにぐにってしてぇっ！　あっ、ああっ、それ気持ちいい…\n…感じちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「本物のあなたに、ドスケベデカ乳首責められてるから余計にぃっ！　あひっ\n、ひぃいっ！　んっ、ひぃいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「腰が勝手にぃ……動いちゃいます……！　あっ、ああぁんっ！　あなたの腰\nの動きにあわせて……んっ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「奥っ、奥まで届いてる……！　オチンチンの先っぽが、わたしの子宮をトン\nトン叩いてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「それに……オマンコの中でオチンチンが膨らんで……んぁっ、オマンコをい\nっぱいにしてるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……んっ、はぁあん……！　立派なでっぱりで、中がごりごり\nぃって削られてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オチンチンがっ、出入りするたびにぃっ！　はぁっ、はぁっ、わたしのオマ\nンコ……どんどん、お汁たらしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「マン汁よだれの音……ぐちゅぐちゅさせちゃってる……。あぁんっ、そんな\nわざと音を立てるように動かないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いやらしい音、聞かせないで……んはぁっ、ああっ、だめ……自分がはした\nない女の子になったって、実感しちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「くひぃんっ！　さらに乳首っ、ぐにぐにぃって……！　ああっ、ああぁんっ\n！　おっぱいも……気持ちよくなっちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ごめんなさい……。こんな、ドスケベな身体になってしまって、ご\nめんなさいいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「デカ乳首でごめんなさい……っ、んぁっ、オマンコもこんなに汁だくで、ご\nめんなさいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「腰を自分からも動かして……オチンチンから精液ほしがってごめんなさい…\n…。ああんっ、中出しおねだりごめんなさいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁっ、反省……しますぅ……っ！　子宮で、あなたの中出し精液受け止め\nて反省しますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、だからこのまま……いっぱいわたしのオマンコ突いてぇっ、ぶっと\nいオチンチンでめちゃくちゃにしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あぁっ、あぁっ、ピストン激しくしながらっ、おっぱいも乱暴にぃっ！　気\n持ちいいのがいっぺんにきちゃって、頭が真っ白になっちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ、もうだめぇ……っ！　ああっ、ああっ、あなたも……あな\nたも一緒にぃ……！　中出し……してぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはぁあああぁぁぁああぁかっ！　ああっ、ああっ、イッくぅうううぅぅぅ\nううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「アツアツのドロドロ精液……っ！　はぁっ、はぁっ、はいってくる……子宮\nにびゅるびゅるって注がれてるのぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……この勢い……熱量……。はっきり覚えてる……あなたの精液の感じ\n……。んぁ……あははぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「とても……気持ちいい、です……。あなたに中出しされて……とても……嬉\nしい……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぅ……はぁ……腰が動いているって……？　そうですね……中出しされた\nのに、オマンコがまだ疼いていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「本当にごめんなさい……。あなたと久しぶりにエッチしたから、オマンコが\n……身体がワガママになっているみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「腰が……じっとしていられなくて……。あんっ、くねらせて……中でまだま\nだ硬いオチンチン……刺激しちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そうなんです……。もっと、あなたのオチンチンが欲しい……。精液を感じ\nたいんです……はぁ……だからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっはぁあんっ！　またっ、いっぱい突きあげてぇっ！　んっ、ああっ、オ\nチンチンで子宮口持ちあげてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしとあなたのエッチなお汁で、ぐちょぐちょのオマンコ……いっぱい締\nめますからぁっ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そうです……オマンコだけじゃなく、おっぱいも……！　いやらしいデカ乳\n首も、いじめて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、激しいのぉっ！　じゅぼじゅぼしてっ、オチンチンいっぱ\nいぃっ！　あっ、あひっ、あひぃいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさいぃ……。自分ばかり気持ちよくなっていないで、ちゃんと\nオマンコも締めますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、ぎゅって……オマンコ締めてぇ……んひっ、あなたのオ\nチンチン……もっともっと気持ちよくしますからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、あなたを感じる……！　オマンコでいっぱい、あなたの熱\nくてたくましいオチンチンを感じちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ひぃんっ！　そんな、局長って呼ばないで……。いま、こうしてエッチして\nいるわたしは局長じゃないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「局長の仕事は、こんな淫乱じゃ務まらないんです！　でも、でもぉ……ああ\nっ、だめ……いやらしくなっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああっ！　ごめんなさい……っ！　ドスケベ局長でごめんなさ\nいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ドスケベ局長イッちゃうぅうううっ！　あなたのオチンチンで、また、イか\nされちゃうのっ！　ああっ、あんっ、あんっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたもイキそうになってますね……ああっ、オチンチンが膨らんで、中で\n暴れてる……んぁっ、だっ、だして……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「またいっぱい射精して……！　わたしに精液を浴びせてくださいぃっ！　は\nぁっ、はぁっ、ああ……欲しいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ワガママオマンコで精液おねだりしてごめんなさいぃっ！　でもっ、でもぉ\n……っ！　んっひぃいいっ！　追い打ち乳首責めぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「言い訳しません……認めます……！　わたしは……園子は……オチンチンを\nイライラさせる……ドスケベ局長です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「役目は果たします……責任もって、あなたの精液受け止めますから……！　\nだから……オチンチンからいっぱい、いっぱい射精して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああっ、あはぁあああぁぁぁああぁぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でてるっ、でてるぅうううっ！　熱いのっ、また精液が中にびゅるびゅるっ\nてきて……っ！　イ……ッくぅううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ドスケベ局長イッてます……！　ああ……中出しアクメして、ごめんなさい\nぃ……んふぅ……ひぃ、ひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……とまらないぃ……。中出し、まだ……オチンチンが脈打って、精液\nをどぴゅどぴゅ吐き出してる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……。イッてるのに、オマンコが勝手にぃ……動いて、あなた\nのオチンチンから精液搾っちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だって……本当に……あなたとまたこうしてエッチできるなんて、思っても\nいなかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「子宮がたぷたぷになるくらい精液をだして……。ふふっ、いっぱい気持ちよ\nくなってもらえたみたいで……とっても嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたと釣り合うくらい、いやらしい女に成長できていたでしょうか……？\n　ンッ、返事はオチンチンがしてくれましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい、あなたが望むのなら、もっともっとエッチして大丈夫です。明日の予\n定はほぼ白紙にしているので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ですが……ごめんなさい。あまりの気持ちよさに腰が抜けてしまって、自分\nから動くのは無理そうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ああぁっ！　オチンチンが抜けて……んひぃっ！　で、でてる\n……精液ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、アツアツの精液がっ、身体にかかる……んひぃっ、ひぃい\nっ、あはぁあああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……イッちゃってます……！　あなたの精液かけられて……イ\nッてる……んひっ、ひぃいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルになった乳首を責めないで……くひんっ！　精液の匂いと乳首の刺\n激でイク……イク、イク……！　イッくぅぅううぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……少し休ませてください……。んふぅ……乳首くにくにって\nされ続けるの……どうにかなりそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「久しぶりで……興奮が収まらないから……？　んっ、もっとわたしと……エ\nッチしたいってことですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……そのようですね……。オチンチンが、まだまだ硬くて……ビクビク\nってしています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしも……したい……。あなたともっと……エッチしたいです……。おね\nだりばかりで、ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい……その見返りは、このいやらしい身体でお返ししますから……。だか\nらもっと……再会エッチを、一晩中……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふふ……安心してください……。明日からしばらく休暇をとりましたから。\nこのドスケベ局長の権限をつかって、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0904410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
