		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んりゅ……ぺろ……んふぅ……はぁ……ちゅぷっ、少しおしっこの匂いもす\nる……んちゅぷ……あぁ、私……隊長さんのおしっこ舐めてるのかな……」", "NORMAL" ]},
