		{"command":[ "SETIMAGE", "0", "still_00008103_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んぱっ、くぱっ、でもぉ……おっぱいずりゅってしてぇ……おちんちん吸い\n付くのぉ……やめられない……もっと、したい……したいのぉ……」", "NORMAL" ]},
