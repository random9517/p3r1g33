		{"command":[ "PLAYVOICE", "v2_081_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっ、うん……分かってるの……今日は、その為に来たんだから……隊長さ\nんのおちんちんを気持ちよくする為に……おっぱいご奉仕してあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「え……いつもより積極的な感じ……？　んっ、どうかな……やっぱり、顔が\n隠れてると……思い切りがよくなる気がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00008103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「本当なら……私も、もっとしてあげたいって……ずっと思ってたから……も\n、もう……そういうのは、今はいいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ……う、うん……いいよ、見て……って言う前から……ものすごく……視\n線……ビリビリ感じてた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「普段は、ちらちらって感じだけど……や、やっぱり……先端……ち、乳首が\n見えると……全然違うの、かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
