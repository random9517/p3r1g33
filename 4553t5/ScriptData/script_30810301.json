		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……すごい……中で、どんどん大きくなって来てる……熱いおち\nんちんが……おっぱいの中で膨らんで来てる……」", "NORMAL" ]},
