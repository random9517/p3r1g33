		{"command":[ "PLAYVOICE", "v2_081_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぷっ、んちゅぷぅぅ……くぽっ、んれろっ……んぁ……精液の味ぃ……ま\nだ、いっぱい残ってる……ちゅぷ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「出したばっかりだから……まだ、敏感なままで……んちゅぷっ、れろ、ぴち\nゃっ……そっとしてあげないと……らよね……えろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
