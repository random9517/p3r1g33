		{"command":[ "SETIMAGE", "0", "still_00008103_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んぱぁっ……まら、深く咥えひゃった……んっ、じゅぷっ、んりゅぅ……絶\n対……エッチだって思われてる……変態だって思われるぅ……」", "NORMAL" ]},
