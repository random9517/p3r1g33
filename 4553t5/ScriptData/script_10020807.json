{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0152" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_027" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ……まさか、ただ校外へ直進するだけの訓練が、こんなにハードなもの\nだったとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113900001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あははー……まさか進路上に常温核融合炉があるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ようやく戻ったのかい。重要施設の警備にぶち当たったぐらいで、音を上げ\nるんじゃないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「耐爆防護壁と、耐テロ用特殊部隊相手に、それは……無理……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113900001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「弱音を吐くんじゃないよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900002" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そんな根性で、『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』全国\n制覇が成るものかい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いつの間に全国制覇が目標に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いや、仰る通りだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113900002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「目標は高く遠くなければ、目の前の敵を倒すことも出来ない。それだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113900003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「よく言ったね。しかし大戸岐学園名物の、地獄の特訓はこれからが本番だよ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900004" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「大戸岐学園……名物……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふふ……嫌な予感しか、しない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113900002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0148" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "大戸岐学園名物・その一『怒根性飛蝗（どこんじょうばった）』", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「勝利のカギは足腰の鍛錬！　さあ、バッタのように跳ね回るんだよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え、ちょっと……待って。その鞭、何に使うつもり～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113900001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こうするんだよ、せいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あふんっ！？　いやん！！　はあぁぁうん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113900002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どうしてこんな、ただの拷問で感じていやがるのですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113900001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「感じてないわよ～！！　ただちょっと、変なツボに入るだけで～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113900003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやあ～ん！！　おふっ！？　うあぁぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113900004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ただのスパンキングプレイと化していやがるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113900002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大戸岐学園名物・その二『油壺魔燐万苦（あぶらつぼまりんばんく）』", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「勝利のカギは一に根性二に根性！！　さあ、貴様の根性を見せてみせな！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「うっわー……この風呂桶。並々と油が満たされちゃってるねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113900001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「肌をてかてかに輝かせるだけなら、美容としては本望である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113900001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「いやでも……うっひゃあ！？　何この感触……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113900002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「耐えるのである。ただのオイルマッサージだと思えば、油もまた涼しいもの\nである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113900002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「違う違う絶対違う！　なんか、ぬめぬめするーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113900003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大戸岐学園名物・その三『地獄極楽膳（じごくごくらくぜん）』", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「勝利のカギは精神力！！　さあ、悪魔の誘惑に耐えてごらん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え、これ、食っていいのか？　あの名店の、最高級肉まんじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ。お代わりもあるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「やった！！　へへ、戴きぃ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ただーし！！　貴様らの腰に結ばれた鎖は、肉まんにギリギリ届かぬ長さに\n結ばれている！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なっ！？　くっ、この……外せーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「耐えてごらん、と最初に言ったろう？　食べてもいい、だが食べられるとは\n言っていないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くっそぉぉぉ！！　こんな鎖、全力で引き千切れば……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「職人が材料から吟味して丹念に造り上げた至高の逸品……たとえ幹部でも、\nその鎖は破壊出来ないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んなああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これは婚活ダイエットこれは婚活ダイエットこれは婚活ダイエットこれは婚\n活ダイエットこれは婚活ダイエット……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113900004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんそれ目的変わってる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「逃げちゃ駄目だ逃げちゃ駄目だ逃げちゃ駄目だ逃げちゃ駄目だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113900005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「嫁に行くなら早くしな！　でなければ独居老人だよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それも嫌な未来予想図です！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0152" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……どうして、ダイヤナちゃんたちが、こんな、目に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113900005" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ぐうぅ……腹、減ったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900006" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そもそも、攫われたカツマが全部悪いのでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113900003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それだそれ！　くっそぉ、あいつさえちゃんとしてれば、今頃肉まん食い放\n題だったのに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113900007" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「身体は充分温まったようだね。その覇気、ぶつけるならあの人形たち相手に\nおし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900014" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、模擬戦……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113900007" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「『乱杰李威仏斗暴屡』の実戦形式さ。ここまでの特訓、その成果を見せてご\n覧！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113900015" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はい、コーチ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113900006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}