{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「こんな場所にピコさまを呼び出すなんて……ふふふっ、隊長ちゃんの考える\nことくらい、お見通しなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「エッチなこと……考えてるんでしょ？　あはっ、ピコさまみたいにカワイイ\n子にご奉仕して欲しいとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふふん、いずれ魔女王になるピコさまに、隠しごとなんてできるわけないで\nしょう？　本当、隊長ちゃんってば考え甘ーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ん～、どうしようかなー。パワーアップにもなるんだし、隊長ちゃんがどう\nしてもって言うなら、遊んであげなくもないけどぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103104" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふふっ、さっきからピコさまの胸……お尻……ふともも……すっごくエッチ\nな目で見てるの、わかってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103105" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほらほら、もう我慢できないんでしょ？　情けなくおねだりしちゃいなさい\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「おちんちん、いじめてください、ピコさま……って。あはっ、そうそう、頭\nを下げて……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「本当に言っちゃったねぇ、隊長ちゃん。カワイイ、カワイイ、最強にカワイ\nイ、ピコさまの魅力に負けちゃったんだー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「いいよ。情けない隊長ちゃんのおちんちん、特別にピコさまがしっかりいじ\nめてあげるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「でも、そんなヘンタイおちんちん、手で触りたくないしー。もちろん、お口\nなんて論外よね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103110" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「だから……ふふ、こう。足で……あはははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103111" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほらほら、見えるでしょう？　ピコさまの足で、おちんちん踏まれちゃった\nね。うわぁ、かっちかち……凄く硬ーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そんなにいじめてほしかったの？　それともぉ、ピコさまがサービスで見せ\nてあげてるおっぱいに、興奮しちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あはは、ビクンビクンっておちんちんが震えて返事してるー。うんうん、両\n方なんだねぇ。隊長ちゃんのおちんちん、素直－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ちゃんと答えてくれた素直ないい子には、お仕置き前に少しだけ褒めてあげ\nようか？　ほらほら、よしよし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「足の裏で、こうして……よしよし……よしよし……ふふっ、隊長ちゃん、息\nを切らしすぎー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はぁはぁって、凄く気持ちよさそうに喘いで……えー、ピコさまの足で軽く\n撫でられただけで、もう感じちゃってるのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんちん、ザコすぎー。あはっ、まあ、ピコさま相手じゃそ\nうなるのもしょうがないかも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、悶えてるのに、それでもエッチな目でじーっとピコさまのおっぱ\nいやアソコ見てる……視線、露骨すぎてわかっちゃうよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そんな悪いこと、もうできないようにぃ……おちんちん、本格的にいじめて\nあげようかなぁ……えいっ♪　ぎゅーっ、ぎゅーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「思いっきり体重かけてぇ、カチカチのおちんちん、踏みつぶしてぇ……あは\nはっ、凄い、すごーい！　まだ硬くなるんだぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「足の裏、押し返すみたいにおちんちんふくらんで……それに、やけどしちゃ\nいそうなくらい、熱くなってきてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「こんなに反応がいいと……面白くて、ピコさまも本気で遊びたくなっちゃう\nな。ほら、ほら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「足をゆっくり動かしてぇ……足の裏で、おちんちんをなで回すようにいじめ\nて……しこしこ、しこしこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あーあ、先っぽからお汁出てきたぁ。ヌチョヌチョで、凄く臭いお汁……ス\nンスン……本当、変な臭い……スンスン、スンスン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はふぅ、何だか、うっとりしてきちゃう。反応よすぎる、ザッコザコおちん\nちんをいじめるの、楽しい～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「うりうり、先っぽの硬いところもぉ、足の指でこちょこちょってくすぐりな\nがら……踏んづけて……えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あはっ、お汁の量、どんどん増えてきてる。どうしたの？　息も凄く荒くな\nってるしぃ……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そうだ。このヌルヌル……おちんちんに塗りたくったら、どうなっちゃうの\nかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほら……先っぽのところに、足の裏をこすりつけて……んぅ、あふれてくる\n熱いお汁、そのままおちんちん全体に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「グチュグチュって、恥ずかしい音鳴ってるよぉ？　あは……ヌルヌルして、\n動かしやすくなってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「今までより、もっと早く……激しくぅ……凄い、おちんちん、表面に血管浮\nかんできて、ちょっとこわーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ザコいくせに、ピコさまを怖がらせるとか生意気だし、もっと強くお仕置き\nしないとね。ほらほら、シコシコ、グチュグチュ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ビンッて起き上がってきそうになってるけどぉ、ダメ、許さない。もっと強\nく、グイグイ踏みつけてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「おちんちん、脈打ってる……根元から何か昇ってきてるの、足の裏で感じち\nゃう。あは……きちゃう？　いいよ……イッちゃえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、んんんんっ！　凄い……出てるっ、びゅーびゅーって、たくさん\n……ふぁああっ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「噴水みたいに、白いお汁、たーくさん出て……もう、ピコさまの身体、ドロ\nドロになっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのエッチな臭いで、染められちゃってる……あはっ、ほら、もっ\nともっとぉ、全部出しちゃえ……あはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ギュって強く踏むと、まだ出てくる。ふふっ、おちんちん、こんな風に踏み\nつけられて喜ぶ、ヘンタイ隊長ちゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「気持ちよさそうな顔……見てると、ピコさまもドキドキする……んぅ、この\n臭いのせいかもぉ……はふぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「それでぇ、こんなにたくさんお汁出したのに、隊長ちゃんのおちんちん、ど\nうしてまだ硬いままなのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あはっ、もっともっとピコさまの足でお仕置きしてもらいたいんだー。すぐ\nに気持ちよくなっちゃうおちんちんなのに、生意気－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、もっと強く……もっともっと激しくお仕置きしてあげないと反\n省しないよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほらほら、してほしいでしょ？　ふふっ、ピコさまの足の裏がくすぐったく\nなっちゃうくらい、おちんちん震えっぱなしだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「もう、足もお腹もぉ、アソコまでベトベトだし、早くお風呂に入りたいんだ\nけどなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「でも、こんな情けなく震えてるおちんちん、無視したら可哀想だもんね。優\nしいピコさまに感謝してよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「えいっ……思いっきり体重かけてぇ……すぐイッちゃうおちんちん、思い切\nり踏んじゃう……えい、えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ぎゅー……ぎゅー……どう？　ピコさまは軽いけど、それでもこんなに思い\n切り踏まれると、おちんちん、苦しいでしょー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「苦しいはずなのにぃ……どうして、さっきよりふくらんでぇ、気持ちよさそ\nうにビクビクしっぱなしなのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「カワイイ子に踏まれて喜ぶ、ザコおちんちん、これがピコさまの隊長ちゃん\nだなんてぇ、本当、笑っちゃう－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほら、悔しいなら反撃してみるぅ？　おちんちん、もっと硬くふくらませて\n、ピコさまの足、押し返してみれば？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ほらほら、さっき出したネバネバのお汁……精液のおかげで、もっ\nとグチョグチョ……エッチな音になってきちゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「足の裏とおちんちんの間に、ネバネバした精液の糸が……ふふっ、凄くエッ\nチ……んぅっ、エッチすぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「もう、部屋中、隊長ちゃんのおちんちんの臭いでいっぱいで……もう、ピコ\nさまも何だか息が荒くなってきちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ピコさまを興奮させる、悪いおちんちん、もっと強くお仕置き……んっ、え\nい……えいっ、シコシコ、グチュグチュ……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふふっ、この裏側の筋のところ、気持ちいいんでしょー？　隊長ちゃんは素\n直だから、顔とおちんちんの反応見れば、すぐわかっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほらほらぁ、カカトで押しつぶすみたいにしてぇ……根元から、先っぽへ向\nかって、ゴリゴリ……思い切り強くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
