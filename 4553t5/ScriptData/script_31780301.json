{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　帰宅早々絡んでくるなんて、悪い子たちね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「でもそんな必死に私を求めてくるのは、イヤじゃないわ。むしろ嬉しいくら\nいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……触手の先端をこんなにガチガチにして……早くシコシコして欲し\nいのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「安心して頂戴。ちゃんと貴方たちが満足するまで、いーっぱいシゴいてあげ\nるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ……！　軽く握っただけなのに、ヌルヌルした感触が手の中に\n広がっていくわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「それにいやらしい臭いもして……触ってるだけで、オマンコが疼いちゃう…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、んんっ……！　上下にシゴくと、臭いとヌルヌルがさらに濃く\nなって……！　あっ、はあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「先端からエッチなお汁も出てきてるわね……粘液と一緒にぐちゅぐちゅして\n、もっと滑りをよくしてあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふっ、くっ、んふっ……！　粘液でヌルヌルになった手でシコシコされるの\n、たまらないみたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　触手たちが激しく暴れて、さらに絡みついてくるわっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「それにシゴいてる触手もひときわ大きくヒクついて……！　そんなに跳ねた\nら、シコシコしにくいじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「こんなに暴れるなんて……手でシゴくくらいじゃ、満足できないって言いた\nいのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「もう……しょうがないわね。なら今日は特別に、お口でも奉仕してあげるわ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「明日は収録があるから、あんまり喉に負担をかけたくないけど……触手たち\nが望んでるなら、仕方ないもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「しっかりと奥まで咥え込んであげるから、さっきみたいに暴れたりしちゃダ\nメよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ぐちゅるっ……！　じゅ、ちゅぷっ……！　れりゅ、ぢゅぴっ……\nちゅ、ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ずぷっ、れろぉ……！　んっ……しょっぱくへ、しゅごくエッチな味がすり\nゅわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルひた感じが口いっぱひに広がっへ……んんっ……！　ずっひょ舐め\nていひゃくなる感じよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ずっ、ちゅぷっ……！　にちゃ、ぬりゅうぅ……！　んっ、んぐっ……！　\n触手汁も濃くて美味ひいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「こうひて手でシコシコひながりゃ舌でペロペロすりゅと……いっぱい奥かり\nゃ溢れてくりゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「まだ先走りの汁にゃのに、喉にねっひょりと絡みちゅいて……んぐっ、ちゅ\nぱっ……！　本当にたまりゃないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぞっ……！　ぴちゃ、ぐちゅるっ……！　にちゅ、ぐちゅ……ぴ\nちゃ、れずりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んむううぅ……！？　口の中れ触手がグニグニ動いてりゅ……！　そんらに\n激しくビクビクひたら、歯に当たっひゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「貴方たちが傷つくひょこなんれ見たくないの……気持ちいいにょは分かるけ\nど、少し自重ひてね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ぐぷっ、ちゅぶっ、じゅぞぞっ……！　ぷちゅ、れりゅ、にちゃ……！　ず\nずっ、ぢゅ……じゅぱっ、ずちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「舐めりぇば舐めりゅほど……触手汁に合わへて、硬さも増ひていくわね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルひて柔りゃかいにょに……先端だけはガチガチに勃起ひたみたいに\n硬くなっへ……んっ、ちゅぱあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「こんにゃに硬いと、シコシコすりゅ手も自然と速くなっひゃうっ……！　れ\nろっ、ぴちゃ、ちゅちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ぴちゃ、ぷちゅるっ……！　先走りにょエッチな汁も……ひゃっき\nより濃くなってきてりゅわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「そりぇに触手たちの動きや拘束も強くなっへ……！　そりょそりょ、イキそ\nうらのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……別に言葉にゃんかにひなくても、貴方たちのことなりゃ何でもわ\nかるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ほりゃ……我慢せずに、いつでも出していいわよ……！　こにょまま、私の\n口に触手汁を出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「いっぱいびゅーびゅーひて、気持ひよくなって……！　んちゅ、じゅぴっ、\nちゅぷうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「にぢゅ、ずりゅっ！　じゅぽっ、ぢゅぢゅ！　れじゅ、ぢゅぢゅるっ、ずっ\n……じゅぞぞっ、ぴちゃ、ぷちゅ、ぐちゅるうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ！　触手たひが一斉に震えてっ……！　あっ、くりゅっ……\n！　触手汁くりゅうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んむううぅ……！？　触手の先端かりゃ、濃いミルクがどぴゅどぴゅ出へり\nゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ビクビク脈を打ちながりゃ、エッチな汁を私の口の中にまき散らひてりゅわ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ドロドロの濃厚な汁が直接喉の奥に流りぇこんで……！　んぐっ、じゅるる\nっ！　ちゅぱっ、じゅぷぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「口の中を触手まみりぇにしゃれるの、凄く感じちゃうっ……！　ほりゃ、\nもっと出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「私の口を孕ませりゅくらい、いっぱい種付け汁をびゅーびゅーひてっ……！\n　んむっ、んんっ……！　んじゅうううぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……いっぱい出ひたわね……私の口の中、貴方たちにょエッチな汁で\nドロドロにひぇるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ……こくっ、ごくんっ……！　そりぇに味も臭いも、頭がクラ\nクラするくりゃい濃厚らわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……あんっ……！　こんらに出した後にゃのに、まだ触手たちが\nうごめいてりゅわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「そうよね……１回出ひたくりゃいじゃ、満足すりゅわけないわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「まぁいいわ。貴方たちが満足すりゅまで、もっと触手をシコシコしながら、\n口で舐めまわしてあげりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　ぐちゅ、ちゅぷっ、ずっ……ぐぶっ、ぢゅぱっ、じゅぱっ\n……！　にちゃ、ちゅるっ……じゅ、ぢゅぶうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「触手汁を出しゅ前よりも硬くなってりゅ気がするわ……そんらに私の手と口\nが気持ひいいにょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「なりゃ、もっと気持ひよくなりぇるようにひてあげりゅ……ぢゅぢゅ、じゅ\nぱっ、ずぷっ、ちゅぱあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「触手の先端を舌でペロペロひながりゃ……思いっきり吸い付いて……んぶっ\n、ぢゅうううぅ……！　ぐっ、んむっ、じゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……相変わりゃず先端は敏感にゃのね……ぢゅぱっ、ぺろっ、ぷちゃ\n……！　れろっ、れりゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ぐぶっ……！　先っぽらけじゃなくて、ちゃんと根本の方も刺激ひ\nてあげりゅわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「口の中で触手を舐めまわひながりゃ、根本の方を思いっきり掴んでシコシコ\nひて……！　ぶちゅ、じゅぱっ……ぢゅぐっ、んじゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　シゴけばシゴくほりょ、ひゃっき出した触手汁の残り汁が\nどんどん出てくりゅわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「全部出ひてよかったにょに、まらこんなに溜め込んでりゅなんて……悪い子\nね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「興奮ひてまた私を襲わなにゃいように、今度は溜め込んでりゅ汁を全部吐き\n出させてあげりゅわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、じゅじゅ……！　れろっ、ちゅちゅ、じゅぱっ、ぐちゅるっ……！\n　にちゃ、れろっ、れりゅ……！　じゅぷっ、ぢゅぷぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅぶっ……！　ぐちゃ、ぶちゅるっ……！　んっ、んむうぅ……！\n？　まひゃ触手たちがビクビク震えてりゅわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「まひゃ触手汁をびゅーびゅー吐き出ひたいにょね……！　いいわよ……ひゃ\nっきと同じように、思いっきり出しなひゃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
