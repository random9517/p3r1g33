		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おかしいじゃないか……だって、いつもはそんな感じに甘えて来たりはしな\nいだろ……？　突然……こんな、あっ……ちょ、ちょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ずっと後ろ姿に……ムラムラしてた……バ、バカ言うんじゃないよ……あた\nしとあんたは……その親子なんだからさ……そういうことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ……だ、ダメだよ……あぁっ、そんな……んっ、脱がさないで……あぁ\nっ、待って……ダメだって言ってるのに……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「が、我慢出来ないなんて……こ、こらっ……あっ、待って……あぁっ、何で\nそんなに手際よくっ……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こ、これは……あっ……チ、チ〇ポ……入り口のところに……あ、当てられ\nてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……あふっ、待って……ダメだよ……そんな、考え直して……あぁっ\n、入り口……擦らないで……そ、その気になんて……なってない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、濡れてる訳じゃっ……違うんだよ……期待してっ……こうなってる訳\nじゃっ……あぁっ……ほ、本当に……それはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁっ……は、入って来るっ……あぁっ、息子のチ〇ポが……オ、\nオマ〇コの中に……入って来ちゃってるぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……！　んっ……くぅぅ……そんな……ダメだよ……あぁっ、\nみっちり……埋め込まれるなんてぇ……んぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぬ、抜いて……抜くのよっ……今なら、許してあげるから……取り返しがつ\nかなくなる前に……はぁんっ、あひっ、あっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ダメっ……！　も、もうピストンが始まっちゃうなんてっ……あっ\n、あぉっ、あっ、おぉぉっ、そこぉっ、あぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ダメだって……ばぁっ、あぁっ、おっぱいっ……そんな窓に押し付けてっ、\nあぁっ、こんな所っ、誰かに見られたらっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁっ、あぁんっ……！　違うっ、よ、悦んでなんかっ……これは\nっ、濡れてるとかじゃっ、なくてっ……自然になってっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んひぁっ！　あぁぁぁっ……チ〇ポっ、突きまくらないでっ！　くぅぅっ、\nあっ、そんなにっ、激しくされるとっ、あたしっ、あたしはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あぁっ……腰くだけになっちゃうっ……そんな、息子のチ〇\nポを……こんなに咥えこんじゃうのっ……いやらしいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、またおっぱいっ……ぎゅうってされたらっ……あっ、あぁっ……ダ\nメ……ミルクがっ、母乳が出ちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ち、違うっ……嬉しいからじゃなくてっ……！　あっ、それはっ……母乳の\n薬のせいでっ……はひっ、あっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ダメ……出るっ、あっ、あぁぁぁぁっ、母乳出しながらっ……ひっ、イッ…\n…イクっ、あぁっ、すぐイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……あっ、あぁっ、出ちゃった……んっ、こんな搾ってもいないの\nに……ミルク出すなんて……恥ずかしい……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　ま……待って……あっ、今……ちょっとイッて、中……あっ\n、感じやすくなってるから……動かすのは……あっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……チ〇ポの先がっ……奥に……届いてぇっ……あっ、はぁぁ\nっ……やだっ……力……抜けるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ……そ、そこっ、そこはぁっ、弱いからっ……あぁっ、弱点っ……そん\nなっ、集中的にするなんてっ、い、意地悪なことぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……んんっ、あくぅっ、上手い……いつの間に……こんなっ、あぁ\nっ、女を……ダメにする技を……身につけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……パツンパツンって……そんな激しく打ち付けるのはぁっ……あ\nっ、あはぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、ダメ……こんな息子のチ〇ポがいいなんてっ……あぁっ、そんな\nママ失格なことっ……で、でもぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……気持ちいいのが……広がっていくぅっ……あぁっ、か、かき回さ\nれてっ……あぁっ、はっ、あぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うくぅっ……あぁっ、大きい……そんな……ま、まだ膨らむって言うのかい\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んくっ、はぁんっ！　あっ、またピストンっ……激しくぅっ、あっ、あぁっ\n……くぅっ、気持ちいいっ……ダメ……そんなことっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
