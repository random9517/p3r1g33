		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁっ……どうしたんだい……急に抱きついて来たりして……何か\nあったのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204101" ]},
