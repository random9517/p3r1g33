		{"command":[ "PLAYVOICE", "v2_003_1204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふぁ……はぁぁぁ……んっ、あぁ……なんてことを……近親相姦で中に出\nすなんて……んっ……ぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんな許されないことなのに……あたしは……こんなに気持ちよくなって…\n…あぁ……どうしたらいいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あふっ……とにかく……終わったんだろう……？　あっ、な\nのに……んっ、まだ……チ〇ポが抜けない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、まだ……したりないなんて……そんな……ことっ、あっ……んんっ、ゆ\n、ゆっくり動かすなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あたしも……欲しがってる……？　バ、バカ言うんじゃないよ……そん\nな、あっ……こ、ことは……んっ、あぁっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅ……んっ、でも、するなら……し、してもいいからぁ……続けて……チ\n〇ポ動かして……いいから……あっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「えっ……あ、あたしがおねだりしたらっ……？　っくぅっ……こ、ここまで\nしておいてっ、あたしにわざわざ言わせるなんてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ……んっ、でもっ……これぇっ、あっ、あふぁっ……今更……やめら\nれる訳ぇ……あっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ……するっ、おねだりするからぁっ……あぁっ、してっ……近親セッ\nクスっ……後ろからケダモノみたいにっ、組み伏せてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もっと……あたしのオマ〇コ……突いてぇっ……息子チ〇ポでっ……いっぱ\nしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁんっ！　あぁっ、そうっ、こ、これぇっ……あぁっ、チ〇ポがっ…\n…気持ちいいとこっ、いっぱい擦ってくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そ、そう……もうっ、あたしの好きな場所……全部知られちゃってるのにぃ\nっ……抵抗なんて……出来るわけないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんな太いチ〇ポ……味わっちまったらっ……あっ、もう身体がっ……オマ\n〇コがっ……全部、その形にさせられるぅっ、んぁっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ……また母乳が出るっ……びゅびゅって搾られてぇっ……止まらなく\nなるぅっ……あっ、んぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、あっ、んくぅっ……！　ま、また……奥にぃっ……あぁぁぁっ…\n…気持ちいいっ……もう、どうしようもないのっ……これぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、あたしが……あんたをっ……導いてやらなきゃいけないの\nにっ……あっ、あぁっ、あたしの方が……躾けられてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このっ、太いチ〇ポにっ……気持ちいいことっ、教え込まれてぇっ……あぁ\nっ、もうっ、こんなのっ、我慢なんて……出来るわけぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「我慢しないでっ……いいっ？　そんな……ことっ、言われたらっ……あぁっ\n、流されちまうからぁっ……！」", "NORMAL" ]},
