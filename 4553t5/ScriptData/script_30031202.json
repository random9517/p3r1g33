		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、まさかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなっ……ああっ、中に出すのはっ……ああっ、幾らなんでもっ、それだ\nけはっ……あっ、あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ダメっ……また来るっ！　チ〇ポっ……すごすぎてぇっ！　ひっ……あひぃ\nっ、オ、オマ〇コ……熱くなるぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ……！　あぁぁっ……中にっ……出てる……そんな……息子の\n精液……中に出されるなんてぇ……は、あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅぅっ……イ、イクッ……！　はぁぁっ……母乳が……漏れちゃうっ…\n…あぁぁっ……おっぱいが出ちゃってるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
