		{"command":[ "PLAYVOICE", "v2_003_1204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……そ、それでいいなんてっ……だってっ……あんたは……息\n子でっ……あたしはママなのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あくぅっ……！　でもっ……あぁっ、チ〇ポっ……すごすぎてっ……何もっ\n、分からないっ……！」", "NORMAL" ]},
