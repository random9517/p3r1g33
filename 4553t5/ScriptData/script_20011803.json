{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0033" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「…………静かですね。敵が暴れた様子は見られませんが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550008" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "報告のあった現場に、氷華が駆けつける。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが夜の広場には、押し付けがましい夜闇の静けさだけが漂っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……誤報でしょうか？　いや、まさかそんなはずは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550009" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その時、突然木々がざわめき、周囲から高笑いが聞こえ始めた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「わははははははははは……よくぞ参られたでござるっす！　マスク・ザ・ブ\nルー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_020021550002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……何者！？　姿を見せなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550010" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ここであったが百年目でござるですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_020021550002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「我古来闘者！　悪魔不動！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_020021550002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550011" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "油断なく、周囲を窺う氷華だが、夜闇の中にまぎれているのだろう……相変わ\nらず敵の姿はない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「声はすれども姿は見えず！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_020021550002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「闇に紛れて善を討つ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_020021550002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ドーモ、マスク・ザ・ブルー＝サン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_153_020021550002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「華のクノイチ隊、只今見参！！　せーの…………とう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_020021550002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……随分芝居がかった登場ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550012" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すると突然、奇妙な装束を身にまとった女性が氷華を取り囲むように突然現れ\nた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00014902_01", "0", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00015002_01", "0", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00015102_01", "0", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなた達が、ニンジャ？　それにしては随分奇妙だけど……それに私のこと\nに随分詳しいようね……？　事情を知るなら生かして返せません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550013" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "油断なく、剣呑な雰囲気を立ち込めさせながら、氷華が半身に構えた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その様子を見て、ニンジャ達もスッと各々の構えを見せる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00014902_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00015002_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00015102_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「『華のクノイチ隊』と言いましたね？　いいでしょう……事情は、ぶちのめ\nしてから伺うことにします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550014" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「そんなこと言っていいんですか？　痛い目見るのはそっちですよ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_020021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＦ" ]},
		{"command":[ "SETTEXT", "「マスク・ザ・ブルー……カナラズ、コロスベシ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_153_020021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00015302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「そのお命、頂戴つかまつりますわぁ……お覚悟を！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_020021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00015202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "７人は息のあった様子で、一斉に氷華へ向かって飛びかかった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが、氷華は慌てず騒がず見栄を切ると――", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「とぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550015" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "気合いと共に真上にジャンプした。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}