{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ほ、本当にするの……？　わ、私たちにはまだ早いと思うのだけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「い、いえ……別にあなたとエッチなことをしたくないという意味ではないの\n。ただ、心の準備というか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もうはしたない姿を何度も見てるから大丈夫……？　ふふっ……それもそう\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00015901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「わかったわ。それじゃあ、いっぱい気持ちよくして頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あなたのたくましいオチンチンで、私のオマンコを犯して……私があなたの\nモノだっていうことを、証明して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はああぁ……これが私の膣内に入ってくるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もう何度もあなたのモノを見てきたけど、オマンコに挿れると思うと……や\nっぱり、緊張するわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　ちょ、ちょっと……そんなに、擦りつけられたら……あ\nはあぁ！　んくっ、ふああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「クリトリスとおっぱいが同時に刺激されて……あっ、ああぁん……！　ダメ\n……これ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「オマンコから、エッチなお汁が溢れて……あっ、んくああぁ……ふあぁ、ひ\nああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「オチンチンと絡んで……ぐちゅぐちゅって、いやらしい音が鳴ってるわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、くっ……あっ、んはああぁ……！　お、オチンチンが\n膨らんでるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「私の膣内に挿れたいのね……いいわよ。私もあなたのオチンチンが欲しくて\n、たまらないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……くっ、ああぁ……！　それじゃあ、挿れるわね……んっ、くっ……\nあっ、はあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「奥まで、一気に挿れるわね……ふっくっ、あああぁ……！　んあっ、あっ、\nあああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「お、オチンチン入ってるぅ……！　硬くて、熱いオチンチンが……私の、奥\nの奥までぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「大きすぎて、オマンコがあなたの形になりそうだわ……はぁ、あああぁ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……これで私は、あなたのモノになったのね……嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「でも、まだ終わりじゃないわよね……次は私の子宮に、あなたの精液を流し\n込んで頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの部屋まであなたのモノだって、私の身体に刻み込んで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ああああっ！？　そ、そんな急に動かないで……！　挿れたばっかりで、敏\n感なのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ぐっ、あっ、ふうううぅ！？　そんなに、激しく……あっ、ああっ、はああ\nぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「亀頭がオマンコをかきわけて、ズンズンって奥の方まで届いてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「すっ、すごいわ……勃起オチンチンが、容赦なく私を犯してぇ……あっぐっ\n、んきゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「エッチなお汁も、エッチな声も、止まらなくてぇ！　ダメ、ダメええぇ……\n私のはしたない音、聞かないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ、ひっ、きゃうううぅ！？　そこ、弱いのぉ！　浅いところ\nをそんなに擦られると、変になっちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ひうううぅ！？　お、奥の方もダメええぇ！　子宮口をグリグリされると、\n感じすぎちゃううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　おっぱいも責めるなんてぇ！　こんなの、すぐにイッ\nちゃいそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「きゃうぅ！？　い、今、オチンチンがお腹の中でビクンって跳ねてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチン、全身で感じちゃうぅ！　まるで全身がオマンコになっ\nたみたいだわ……あっ、ああっ、ふあああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「パンパンって打ち付けるたびに、あなたのモノもビクビクって震えて……！\n　あっ、ひいぃん……！　わ、私もう限界だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ……んんんっ！　あ、あなたのオチンチンも、限界なの……！？　オチ\nンチンがすごく膨らんで、小刻みに震えてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「い、いいわよ……好きなだけ、私の膣内で出して頂戴……！　子宮の中まで\n濃厚な精液で、満たして頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あああっ！　あぁんっ、あっ、はああぁんっ！　わ、私もイクから……いっ\n、一緒に、イッてええぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああぁ、あああんっ！　イクっ、イクっ！　あなたのザーメン\n、いっぱい出してえぇ！　あっ、くああっ！　ふああああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふああああぁ～～～！？　あっ、熱いっ！　子宮の奥まで、熱いザーメン\nいっぱい感じるうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「どぴゅどぴゅって、いっぱい出てるぅ！　オマンコ感じちゃう！　ザーメン\nで、エッチなお汁でイッちゃううううぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんんっ～～～！　ま、まだ出るのぉ！？　そんな……もう子宮が満たされ\nてるのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ああああぁ……もう、身体の隅々まで、マーキングされちゃったわ……暫く\n精液のニオイがとれなさそうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あなたと繋がれて、あなたのモノにされて……ふふっ。女として、こんなに\n幸せなことはないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……まだ勃起したままなのね。まだ私を犯したいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……あんなに激しく私を求めたばっかりなのに、しょうがないわね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「いいわよ……私のオマンコで、もっと気持ちよくなって……私も、もっとあ\nなたを感じたいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、あああぁ……いろんなエッチなお汁がまざって、子宮の奥ま\nでドロドロになってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「これなら、さっきよりもスムーズに動けそうね……んっ、あっ、はああああ\nぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んひいいぃ！？　さ、さっきと同じぐらい……い、いえ、さっきよりも硬く\nなって……んあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「オマンコを締めれば締めるほど、硬く勃起してるのがわかるううぅ！　こん\nなの、我慢できなくなっちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あひっ、ひいいぃん！　またカリ首がオマンコのお肉を削ってるううぅ！　\n擦れすぎて、すりへっちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、んほおおぉ！　本当にこのオチンチンすごいいぃ！　さっき\nから私の子宮口、開きっぱなしなのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さっき出された精液がズンズンって、奥まで運ばれてるのぉ！　これ、絶対\nに孕んでるわぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　んっ、ひいいいぃ！　オチンチンから離れられなくなる\nぅ！　オチンチン大好きな、変態女になっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんん～～～っ！　か、軽くイクぐらい、感じてえぇ！　ダメっ、これ以上\nは、本当にダメえええぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「おかしくなるからぁ！　私のオマンコ、本当にダメになっちゃうからあああ\nぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あああっ、んひいいぃっ！　それ以上突かれたら、入っちゃ\nうぅ！　亀頭が子宮口の奥まで、入っちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ダメっ、ダメえええぇ！　これ以上感じたら、気持ちよくなったら、戻れな\nくなるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あなたに依存して、毎日エッチなことしたくなる、オマンコ奴隷になっちゃ\nうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あああっ！　ま、またビクビクって……！　さっきよりも、激しく動いてる\nぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「また、出るのね！？　ドロッドロのエッチなミルク、いっぱい私に染み込ま\nせるのね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふあああっ、あっ、ひいいいいぃん！　きて！　いっぱい、出して！　真っ\n白な精液、たくさん出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んああああぁ！　イクっ、イクっ！　いっ、イクうううううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ひいいいいいぃ～～～！？　あっ、熱いの！　熱湯みたいなザーメン、子宮\nに全部出されてるのおおおぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「孕むううぅ！　こんなの、絶対に孕んじゃうううぅ！　ボテ腹の妊婦さんに\nなっちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ……あっああぁ……！　くっ、ふぐううぅ……！　はぁ、はぁ……全身\n、トロけちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はああぁ……あっ、あああぁ……！　ま、まだ、オマンコの膣内で跳ねて…\n…！　ビクビクって、動いてえぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……こんなに出すなんて……子宮の中まで綺麗にマーキングされたら\n、もう離れられないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ずっとあなたの傍で……一人の女として、生きたいとすら思っちゃうわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「こんなこと言うと……重たい女って、思われちゃうかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……オチンチンが、また跳ねて……ふふっ。もしかして、今のが\n返事なの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ありがとう……すごく嬉しいわ。これからも、たくさんエッチなことしまし\nょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それから、一緒に赤ちゃんも育てて……ふふっ。なんてね。さすがにそれは\n、まだ気が早いわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぶっ！？　お、オチンチンが抜けて……きゃああぁっ！　あっ、熱い精液\nが、身体にいいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_22" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぐううう～～～っ！　は、鼻の奥にまで、ザーメンのニオイが……！　ほ\n、本当に全身犯されるみたいでええぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_24" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「肌にまで染み込んで……あひいいいぃ！　す、すごいぃ……！　全身マーキ\nングされちゃったわぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……このニオイ、しばらく取れないかも……でも、あなたを感じ\nられて、すごく嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_25" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「四六時中、あなたのザーメン臭に包まれるなんて……想像しただけ、イッち\nゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……別にイヤじゃないわよ。むしろ、あなたに包まれているとすら思\nえて、発情しちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「でも、これだと任務に支障が出ちゃうわね……どうしようかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「えっ……産休や育児休暇を取ればいい？　ふふっ。もう赤ちゃんが出来たこ\nとを考えてるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「嬉しいわ……あなたとの赤ちゃんなら、喜んで産んであげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「だから……これからもよろしくね……アナタ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0104410" ]},
		{"command":[ "SETIMAGE", "0", "still_00015901_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
