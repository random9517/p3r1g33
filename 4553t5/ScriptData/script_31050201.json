{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「それじゃ……隊長さん……そこに、座って下さいね。水着……下げちゃいま\nすから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ……すごい……もう、こんなに大きくなってる……私のおっぱい……そ\nんなに楽しみだったんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うぅ……改まってじっと見つめられたら……恥ずかしい、です……その……\n先っぽが見えちゃってるのは全然訳が違って来るんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふ……でも……ちょっと……そういう、のが……あっ……気持ちいい\n感じになっちゃうような……気もしたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「だから……その、おすそ分けと言いますか……私の……お、おっぱいで……\n隊長さんの……オチンチン……気持ちよくします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「どういう風に……ですか。で、ですから、こうして……おっぱいで挟んで…\n…んっ……谷間でオチンチン……扱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「とにかくっ、パ、パイズリっ……ですっ。私の大きいおっぱいでっ……隊長\nさんのオチンチン……シコシコしますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うぅっ……自分で口にすると、ものすごく恥ずかしいです……こんないやら\nしいことしちゃうんだって……ドキドキして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「で、でも……隊長さんは……そういうエッチな私がいいんですよね？　だっ\nたら、が、頑張りますからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「え、えいっ……おちんちん……サンドしましたっ……んくぅぅ……あぁ、す\nごく熱くなってる感じです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ここから……んっ、どうしよう……まず、ぎゅうっと……強く……押し付け\nてあげて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「それから、んっ、はっ、ぁんっ……上下に……あっ、動かして……あっ、あ\nげますっ……は、ひぁっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「手慣れてるなんて……そんなことっ、こんなこと……他の誰にもしたり……\nしませんからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「隊長さんにだけっ……特別の……特別なんですよっ？　んっ、その辺……ち\nゃんと、あっ、わかって……ますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……それなら……いいんです。確かに……あっ、私は……見られ\nると、ドキドキ……興奮して……言葉責めにも弱くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「自分でもエッチな……いやらしい子だって分かってますけど……でもっ、そ\nれは……隊長さんだからっ……なんですよっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ、そうじゃなかったら、こんな……おっぱい見せて……あっ、オチンチ\nン……ずりずりって……するなんて……絶対出来ませんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はぁっ、あぁ……皮の……継ぎ目の所……あっ、ぐちゅって擦\nれるの……んんっ、くすぐったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ちょっとだけ……引っかかる感じ……しますか？　えと……それなら、んっ\n、ぺろ……れろ……えろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「その、少しだけ濡らしましたから……これなら、大丈夫ですよね？　んっ、\nはっ、んふっ、はぁっ……あんっ、はぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「やっぱり、いい感じです……オチンチンと……おっぱいが……ちょうどよく\n滑って、さっきより……んっ、気持ち……いいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ、いえっ、今のは……隊長さんが気持ちよくなれるかなって意味で……\nその、私が……気持ちいいっていう意味じゃ……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「やんっ、い、いたずらしちゃダメです……乳首……あふっ、し、しこってな\nんか……んくぅんっ……はっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「指であっ、コリコリするのは……反則ですっ……そんなに、されたらっ……\n今……敏感になってるのっ……分かっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……感じて……るのはっ、お互い様ですっ……隊長さんだって…\n…んっ、オチンチン……震えてるじゃないですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「これだけ、おっぱいを押し付けてたら……嫌でも分かります……んんっ、パ\nイズリする度に……ちゃんと反応してるの……分かってますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「それに……んっ、ほら……亀頭から……ちょっとじわっと出てきてるの……\nこれって、カウパーですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「私……もう、何も知らない子じゃありません。隊長さんの状態だって、ちゃ\nんと……把握してるんですから……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ほらぁ……ここぉっ、ぎゅってしながら……動かしたら……んっ、あふっ、\n弱いんです、よね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あふっ……あぁ、おっぱいが汗ばんで来ちゃう……あっ、ダメ\nですよ、匂いなんて嗅いじゃ……デリカシーですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ち、違いますっ、フリじゃありませんっ！　あぁんっ、そんな鼻を前に出さ\nないでっ、あんっ、はっ、あぁっ、汗臭くなんかないですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んんっ、こうなったら……もう、先に……出してもらうまでですっ……精液\n……出しちゃえば……全部……上書きされるんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、あんっ、はっ、あんっ……お、おっぱいが……潰れてっ、\nあんっ、形……いやらしくなってるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でも、もう少しっ……あんっ、オチンチンビクビクしてるっ、ほ、ほらっ、\nいいんですよっ、私の……お、おっぱいマンコにっ……出して下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「熱い精液っ……ぴゅって出してっ……はぁんっ、おっぱいの中っ……ドロド\nロにして下さいっ、あっ、はぁんっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　あっ、出ましたっ……精液っ……あぁっ、谷間に……ドロっと\nしたのっ……流れ込んで来ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……やだ、すごい量……前より、ずっと多くないですか、これ……思\nってたより、溢れて来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「上手く出来てたから……そ、そう言われると……まぁ、悪い気はしませんね\n……ん……ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……収まって来ました……んっ、はぁ……おっぱい……精液まみれです\n……本当に遠慮なく出すんですね……隊長さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「い、いえ、私がそうして欲しかったのは確かなので……はい、射精してくれ\nて……よかったです……えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「えっと……このまま続き？　な、何ですか……今出したばっかりで、すぐそ\nういうこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「どうせするつもりだった……そ、それは……まぁ、そういう気分でなくもな\nかったですけど、露骨に言われると私が変態みたいじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「う……でも、違うのかって言われたら……違わない気も……も、もういいで\nすっ、パイズリっ……続きしますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……さっきみたいに、しっかり中にうずめて、今度は……前後に\n、んっ、しょっ……んんっ、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「うぁっ……出された精液がヌルってして……感触が変わってきてます……は\nぁぁ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「それに男の人のにおい……んんっ、はぁ……吸い込んだら……んぅっ、おっ\nぱいが……むずむずして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「えっ……乳首……立ってる……？　そ、そんなのっ……見なくていいですか\nらっ、もうっ、恥ずかしいことばっかりぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んんっ……でも……本当です……私、いつの間に……あぁ……すごく、感じ\nやすくなっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　胸板に……乳首が擦れてっ……あっ、はぁぁ……動かすと……あ\nんっ、き、はひっ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁっ、ご奉仕のつもりなのに……私の方が、良くなっちゃうなん\nて……そんなこと……あっ、ダメです……んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「えっ、二人で感じる方が……いい……ですか？　はい、隊長が……そう仰る\nなら……んっ、く……んふっ、続けてします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「おっぱい……はぁ、熱いです……オチンチンの熱さが移って……精液と汗が\n混ざり合って……んふっ、息が乱れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……陽射しのせいですか……？　体がぽかぽかして……んっ、火照って\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「よく、考えたら……こんな貸し切りでも……開けた場所で……私……すごい\nことしちゃってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でも、んっ、ドキドキするほど……体が止まらなくなって……はんっ、あぁ\nっ……オチンチン、もっとしたくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ、いやらしい子でごめんなさい……あぁ、でも……おっぱい気持ちいい\nっ……パイズリで……私……すごく、感じて……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あぁっ……隊長さんもオチンチン……待ちきれなくなってます\nかっ？　さっきからずっとビクビクが強くなって……あっ、乳首擦れてぇっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、ヌルヌルのオチンチンが、精液出したがってますっ、また\n……掛けて下さいっ……んっ、あっ、はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はいっ、このまま……また、おっぱいマンコの中でもっ、顔でもっ……どこ\nでもいいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「溜まった欲望……全部吐き出してっ……パイズリでっ……もう一回っ……び\nゅくびゅく出して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ……はいっ、大丈夫ですっ、おっぱいマンコ……また……中出しでっ…\n…あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁぁぁぁっ……あっ……またいっぱい出てるっ……オチンチンか\nら、びゅくびゅくっ……精液……出てますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……隊長さんの、すごく元気……んっ、私のパイズリでこんなに射精\nしてくれてるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あぁ……胸の下に垂れて来て……あっ、足の方にまでトロトロになっちゃい\nました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んく……でも、それもちょっとだけ嬉しいです。隊長さんの匂いで……全身\n染められちゃうってことですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ふふ……今頃気がついたんですか？　私……結構、そういう風に支配されち\nゃう感じ……嫌いじゃないみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そうじゃなかったら、こんな風に……おっぱい使って、オチンチンにご奉仕\nなんて……恥ずかしくて出来ませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「その、恥ずかしいのは今も恥ずかしくて……体が燃えちゃいそうな位なんで\nすけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でも、隊長さんになら……いいかなって……私、もうそんな気持ちになっち\nゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ま、また次ですか？　そうですね、はい……隊長さんがお望みでしたら……\n喜んで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あっ……顔にっ……は、はいっ、掛けて下さいっ……顔面シャワー……いっ\nぱい……浴びせてっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁっ……あぷっ……！　んぁっ、顔に……出てますっ、んぁっ、ふ\nっ……すごいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……ねばねばしてる……頬と……口に……べとっとして……ちゅぱ\nっ、んふっ……れろ……りゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あ……自然に舐めちゃってました……ちゅぷっ……大丈夫です。もう、この\n味……慣れてますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「それに、隊長さん……飲んであげたら嬉しいんですよね？　私……喜んで欲\nしいですから……ぺろっ……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00010502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……すごい匂い……私、すっかり隊長さんにマーキングされちゃ\nいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「でも、ちょっと嬉しいって思う自分もいて……な、何言ってるんだろ、私…\n…ただ、正直……本当に思うんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「今も……顔から火が出るほど恥ずかしくて、ただ、そういうのも全部含めて\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「隊長さんになら……いいかなって……私、もうそんな気持ちになっちゃいま\nした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「ま、また次ですか？　そうですね、はい……隊長さんがお望みでしたら……\n喜んで……♪」", "NORMAL" ]},
