{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "097_0103101" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おい。オマエ、オレのことバカにしてんだろ。そうなんだろ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103102" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「『何が？』じゃねえよ！　何がニンジュツの修行だよ！　なんなんだよ、オ\nマエのそのカッコはよ！　下半身丸出しでよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103103" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なにぃ？　そういうオレもおっぱい丸出しだと！？　うるせえ！　オマエが\nやらせたんだろうが！　どう考えてもこれ、修行じゃねえだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103104" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ？　『ニンジュツではないけど、これでパワーアップできるこ\nとは間違いない』？　はぁ？　何言ってやがんだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103105" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったくオマエは、またそういう　またそういう嘘を――え？　な、なに！？\n　『ホクシィはこれで強くなった』だとぉ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103106" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「て、て、てめえ！　ホクシィともこんなことしてやがったのか！？　いった\nい何考えて――い、いや、それどころじゃねえ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103107" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おら！　オマエの粗末なモノ、もっとこっちに突き出しやがれ！　やってや\nらあ！　ホクシィなんかより、オレのほうがすげえってとこ見せてやらあ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103108" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「……で、どうすりゃすげえことになるんだ。なに？　オマエをイカせてみせ\nろって？　おう。お安い御用だぜ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103109" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなもん、アレだ。オレの胸で挟み込んでだな。ぷに、ぷに、ぷに、ぷに\nっ……と」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103110" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なに？　口がお留守だあ？　うっせえ！　わかってんだよ、んなこたあ！　\n……あむっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103111" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……んん……！　んんんん……！　く、くそ、無駄にでけえから舐めづ\nれえな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103112" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ええい、上からグチャグチャ言うな！　わかってんだよ！　もっとこう……\n思い切ってくわえて……んんんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103113" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちゅっ……ちゅっ……ちゅっ……。それから……舌を……ぺろ……れろ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103114" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あむ……はむっ……むむっ……ちゅっ……ちゅるっ……む、胸もか？　う、\nうるせえ、わかってるってんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103115" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ふに……むに……むに……ぺろっ……ちゅっ……れろっ……れろっ……あ！\n　てめえ、なに腰動かしてんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103116" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なにぃ？　オレが上手すぎて？　気持ちいいからつい腰が動いた？　ったく\n。しょうがねえなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103117" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それに？　オレの胸が柔らかくてあったかくてふにふにしてて、もう最高？\n　ふ、ふふん！　わかってんじゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103118" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おっしゃ！　オマエの粗末なジュニア、オレ様の胸と口で昇天させてやらあ\n！　ふんっ！　ふんっ！　はぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103119" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほれほれほれほれぇ！　うぉおおおおおー！　ラビットパワァー！　イッケ\nえ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103120" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「え？　もっと優しく？　かつ、やらしく？　ねっとりしっとりと？　ったく\nめんどくせえなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103121" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちゅっ……ちゅっつ……ちゅっ……じゅっるるっ……ちゅっ……れろん、れ\nろ……こんな……感じか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103122" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「胸の方も……？　しょうがねえなあ……ほら……こんなかんじか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103123" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「胸で上下に……おら……ほれ……こんな感じか？　こうやってこすりながら\n……あむっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103124" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんっ……ちゅっ……ぺろっ……。ふにふに……こすこす……むにむに……\nおお？　なんだなんだぁ？　こりゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103125" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへへ、ただでさえ赤くてギンギンに膨れ上がってたモノが、もっと真っ赤\nでガチガチになってきちまったぜえ？　なんだよ、気持ちいいのかあ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103126" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへへ、そうかそうか。気持ちいいか。どうだ、オレ様のすごさがわかった\nか。わかったら言ってみな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103127" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「『ウタマロさま、ユーアーグレイテスト！　気持ちいいので、もう出させて\nください！　プリーズ』ってな！　あははははは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103128" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あははははは！　言ったか！　言っちゃったか！　お願いしちゃったか！　\nよしよし、しょうがねえなあ！　今、イカせてやっかんな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103129" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「奥までくわえこんで……んんんっ！　んっ！　ちゅっ！ ちゅるるるっ……\nじゅるっ、ぺろっ、れろ、れろっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103130" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「べろべろ、れろ、じゅるるる……ん？　なんら？　イキそうなのか?　へへ\nへへ、いいぜ、好きなだけぶちまけちまい――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103131" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんんっ！？　んんっ！　んんんんんーっ！？　い、いきなり出てるぅっ！\n　んんっ！　んんんっ！　んあああああああーっ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103132" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「けほっ……！　けほっ、こほっ！　ば、バカ野郎！　出してもいいとは言っ\nたけど、こんなにいっぱい、しかもいきなり出すヤツがあるかよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103133" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「しかしよ……ざまあねえな。こんなにだらしなく、いっぱい出しちまってよ\n？　に、してもすっげえ量だな、これ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103134" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「量だけじゃなく、臭いもすげえし……おまけにめっちゃくちゃ濃厚で粘つく\nんだな、精液って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103135" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんだよ。これ……マジやらしい……はぁあ……なんかこう、またムズムズ\nしてきちまいそうだな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103136" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく……いくらオレの口とおっぱいが気持ちいいからってよ。きったねえ\nもんを、こんなにだらしなくぶちまけてんじゃねえよ。へへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103137" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ま、そんだけオレ様のワザマエがすごかったってことだよな！　ホクシィな\nんざ目じゃねえぜ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103138" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お！？　な、なんだよ！　急に頭なんか撫でてきやがって！　なんだよ、そ\nの上から目線！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103139" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく、ホントにしょうがねえな。オマエはよ……。でもまあ……なんだ。\nほら、オマエも頭出せよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103140" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレもオマエの頭なでてやるって言ってんだよ！　ほら、さっさと出せって\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103201" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「――って！　バカ野郎！　だれがそこの頭を突き出せって言ったよ！　ウサ\nギにカメの頭を出してどうすんだよ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103202" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「っていうか……今、あんだけ出したばっかりだってのに、どうしてもう、こ\nんなになっちまってんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103203" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「え？　一回じゃおさまらない？　もう一回、気持ちよくしてほしい？　『お\n願いします、ウタマロ様』だと？　しょうがねえなあ。このドスケべ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103204" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「どれ……さっそくこすってやるぜ。ほれ……ほれ……むに……むに……こす\n……こす……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103205" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おら、気持ちいいか？　気持ちよかったら気持ちいいって言ってみろ？　腰\n、動かしたっていいんだぜ？　へへへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103206" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「わかってるわかってるって。口でもしてほしいってんだろ？　そう焦るなっ\nて……ほらよ。あむっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103207" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……んん……ちゅっ……ぺろ……れろっ……ちゅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103208" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「うわぁ……やっぱりすげえな、精液の臭い……それから味がよ。鼻にツーン\n、とくるぜ……へへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103209" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく。何喰ったらこんなくっせえ精液が出るようになるんだあ？　ちった\nあ恥ずかしいと思わねえのかよ、こんな汚くて臭いもん出しちゃってよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103210" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「うおっ！？　急にまた、一段と硬くでっかくなったなぁ？　なんだなんだ？\n　そんなにオレのおっぱい、気持ちいいのか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103211" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「え？　臭くて汚いモノを出してしまった恥ずかしさのあまり、逆に興奮した\nって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103212" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「わはははははは！　なに言ってんだよこの変態！　ったく、はずかしいヤツ\nだなあ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103213" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そんな恥ずかしいモノには、きっちりお仕置きしてやらないとな。あむっ…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103214" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぺろ…ぺろ……れろ……れろっ……んんっ、んっ……ちゅるっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103215" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぷはぁ……そうだ。胸もだな。ほれ……すりすり……ぷにぷに……むにゅむ\nにゅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103216" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぷにぷに……すりすり……れろっ……れろれろ……じゅるるっ……ちゅっ…\n…ぺろん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103217" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぺろ……れろ……お？　なんか、ピクピクしてきたぜ？　限界近いんじゃね\nえか？　へへへへ……じゅるつ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103218" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「じゅるるる……すりすり……れろ、れろ……おうおう、こんなにガチガチに\nしやがって。ホントにエロ恥ずかしい野郎だな。へへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103219" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちゅっ……じゅるっ……じゅるるるっ……どうだ？　もう限界か？　そろそ\nろいきそうなんだろ？　いいんだぜ、イッちっまっても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103220" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほらほら、またぶちまけてみろよ……臭い……精液をさ……ん、んんっ、ん\nっ……ぺろ、れろ、れろ……じゅるるるる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "097_0103301" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！？　んぐっ！　んんんんんん～～っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103302" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……くっ……んんんんんっ！　ごほっ！　ごほっ！　くぅうう……！　\n２回目だってのに、こんなに出しやがって……！　こほん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103303" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「え？　尿道に残ってるのも吸い出してほしい？　『お願いします、強くて美\nしいウタマロ様』？　へへ……しょうがねえなあ。ちゅるっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103304" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちゅっ……んんっ……んんっ……おっしゃ！　全部飲んだぜ！　どうだ！　\nこんなん、ホクシィにはできねえだろ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103305" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あいつはいい子ブリッコだからな！　こんな臭くって汚ねえもん、一滴も残\nさずに飲み切るなんて、絶対にできっこねえよな！　わはははははは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103306" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ま、やっぱりアレだ。このオレが、スクールガール・ミュータント・ニンジ\nャ・ラビッツのリーダーにふさわしいってことだよな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103307" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そういうわけだ、隊長！　今後も、なんかあったらまず、オレに頼っていい\nぜ！　あ、あとな、それから――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103308" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こういうことしたくなったら、まずオレに声をかけろよ？　ホクシィじゃな\nくな？　気が向いたら、その……相手してやっからよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103309" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「わかったか？　よしよし、いい子だ！　頭だせ。なでてやっから」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103310" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だから！　出すのはカメの頭じゃねえっての！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]}, 
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "097_0103401" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ん！？　どうした？　いきなり腰を引いて――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103402" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ノォオオオオオッ！　ガッデム！　なんじゃこりゃ！　てめえ！　人の顔に\nなにぶっかけてやがるっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_10" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103403" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「うああ……！　な、なんてことしやがるんだ、この野郎！　顔も胸もベトベ\nトじゃねえか！　しかも、このひでえ臭い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103404" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああ、もう……！　そうだよ、この臭いだよ……鼻にツン、とくるこの刺激\n……！　はああ……もう、興奮するぜ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103405" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それに、このベトベトした濃厚な感触……はあああ……これが今、オレの顔\nにべっとりと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103406" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なにが『よく似合う』だ、この変態！　機嫌とってごまかそうったって……\nえ？　今のオレ、最高にセクシーだって？　ホクシィよりずっと！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103407" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そ、そうか？　ま、まあ、そこまで正直に言われちゃあなあ？　オレだって\n、そう悪い気はしねえけどなあ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103408" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「で、でもな！　今度からは、ぶっかけるまえに一声かけろよ！　いきなりぶ\nっかけんじゃねえぞ！　わかったな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103409" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「え？　またぶっかけさせてくれるのかって？　ま、まあ……嫌いってわけで\nもねえしな、こういうの」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0103410" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「まあ、なんだ、オマエが隊長としてちゃんと仕事してたら、また相手してや\nってもいいぜ！　な！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
