{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0199" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "時間帝国の追手を倒した俺たちは、秘宝を求めて洞窟のさらに奥へと進んだ。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それにしても、この惑星に隠された秘宝とは、いったいどれほどの価値がある\nのだろうか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "金銀財宝なら、間違いなく大金持ちになれるよな？　隊長として安月給でコキ\n使われることもなくなる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "遊んで暮らしても貯金できるくらいの財宝だったら……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……だとしたら、他の奴らに渡すわけにはいかないよな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつらを出し抜いて、俺が宝を独占できないか……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、カツマ。さっきから早足だな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういう姫様こそ、どうしたんですか？　どんな罠があるかわからないのに\n、競歩です……あだっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "なにかに引っかかって転んでしまった。こんなことをしたのは……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0199" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おいおい、よそ見してたらつまずいちまうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115550001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、お前その手に持ってるのはなんだ？　それで俺の脚をひっかけただろう\n！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「エファナティカ！　足元にヘビ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぎゃあああぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ウソだよ～、お先に～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「せ、セレーナあんた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おまえたち、そんなに急ぐな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カチッ！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだ？　またなにかの罠が起動して……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「きゃぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたつきみ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしじゃないよ！　カツマさん、服！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115550002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の服……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんじゃこりゃぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "強制脱衣の罠だ！　全裸になってしまう！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……って、エロトラップダンジョンの罠に男がひっかかってどうすんだよ！　\nだれもよろこばねぇだろうが！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やはり罠が……。みんな、慎重に進むべき……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「つまり、この罠をつかえば、他の連中を足止めできる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「姫様、それであたしらを出し抜こうとしていませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なにをいってる？　私が言っているのは、追手の時間帝国のことだぞ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なるほどね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カチッ！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい……今なに押した？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「壁にあったボタンを押したら、秘密の通路とか出てくるかもしれないだろ～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、あからさまにあやしいラッコ模様のスイッチじゃなかったか！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なっ、なんだいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115550005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わわわっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115550003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレーナが押したスイッチに反応して、壁からピンク色の蒸気が噴き出してき\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の本能がこれはヤバいと告げている。アナザーたちを包んでいく蒸気を、口\n元を覆って吸わないようにした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "蒸気が止んだとき、俺が目にした光景は……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0204" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんか変だ……どう見てもアナザー・ルナテミスが色っぽい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この狂魔元帥……すけべすぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115550004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんだか頭がクラクラする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115550004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「セレーナ……あんたちょっと見ない間に、いい女になったねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115550006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……よせやぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだ、セレーナたちになにが起こっているんだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なんか変な気分……発散しちゃいたいわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115550002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もう我慢できないっ！　相撲しようぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115550007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「なるほどそうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115550005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あいつらなにをやってんだ？　というか、セレーナは自爆しているような……\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、そんなことより秘宝だ秘宝！　誰にも渡さな……って、カグヤとまりあ\nは！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0199" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマとの結婚資金カツマとの結婚資金カツマとの結婚資金……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カグヤさん！　抜け駆けは許しません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115550001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カグヤのやつ、思いつめすぎて思ってることが口から出てるじゃねーか！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが、いくらカグヤでも秘宝は渡せねぇ。秘宝は俺の……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まてぇ！　貴様らぁっ！　秘宝は私のものだぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カチッ！　カチッ！　カチッ！　カチッ！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさか姫様、このダンジョンのトラップを全部踏み抜いて追いかけてきている\nのか！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様！　罠を作動させたらひっかかるのが、エロトラップダンジョン攻略の\nマナーですよ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「知るかぁっ！　そんな罠は貴様がかかっていればいいんだ、私は秘宝を手に\n入れるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115550005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
