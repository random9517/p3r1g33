{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「な……なんてこと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030001" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "薬を飲んだ俺の身体は、元の姿に戻っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それだけじゃない。なんか、こう、身体の奥底から力がみなぎってくるような\n感じもする。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっと鳳雛、あの薬のせいだよね？　ヤバいもんだったんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうかも。でも、彼は元の姿に戻れてるみたいだよ？　あの魔術師も成長化\n薬って言ってたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっと、あんた！　説明しなよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あの成長薬は、私の魔術を応用したもので、飲んだ子を一時的に急成長させ\nるのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030002" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんは、それを飲んで元の姿に戻ったどころか、そこから１０年く\nらい経験を積んだ状態になってるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ということは、ここにいるご主人は、いまから１０年後のご主人ということ\nに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それって……どうなるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「１０年後のカツマなんて想像できやしないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なるほど、今の俺は１０年後の俺の力を前借している状態になっているのか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マキ・アーリスター……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「なに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030004" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「外へ行こう。ここに居たら、こどもたちまで巻き込んでしまう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そ、そうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだい、やけにクールぶっちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「嫌な予感がするなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここなら邪魔が入らないな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「待っててね。私がキュートな姿に戻してあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030006" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺が勝って、俺たちのことを元の姿に戻してもらうぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだったよ！　あたちたちのこと、ちゃんと元の姿に戻してもらわないと\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんな子どもの姿じゃ不自由すぎるからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「もう、いうこと聞かない子は、とびっきりのお仕置きをしちゃうわよ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030007" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「望むところだ。お仕置きなら俺の得意技でもあるからな。さあ、かかってき\nな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マキが杖を掲げ、呪文を唱える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "魔力がフェニックスの形となって、俺に向かって飛んでくる！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いくぞ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺も自慢の獲物を抜いて、マキの攻撃に向かって目にもとまらぬ早撃ちを……\nって。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まて、まてまて！　俺のただの鉛弾が、こんなデカいフェニックスに通用する\nとでも！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の攻撃をものともせず突き進んでくるぞ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおおおぉぉぉっ！！　俺は！　１０年経って！　パワーアップしているは\nず……！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐわぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "せめて相殺してやろうと撃ちまくったが、現実は非常である。俺は１０年経っ\nてもろくに成長していないようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち……くしょぉ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「勝負あったわね。さあ、あなたのこともちゃぁんとキュートな姿に戻してあ\nげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030008" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そして、お友達と一緒に、マキママと仲良く暮らすのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マキはまた大技の構えをとる。このままではやられる……と、思ったとき、俺\nの視界に一人のこどもが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こんなところに迷い込んだ幼女！？　いや、あの顔つきはまさか……鳳雛か！\n？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええい、こうなったら！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は立ち上がり、なぜか幼女の姿になっている鳳雛のところへ向かう。そして\nひょいと抱き上げた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やい、マキ・アーリスター！　これを見ろ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「なに……って、あ、あなたなにしているの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030010" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はははっ、下手なことをしてみろ！　この子の命がどうなっても知らないぞ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "迷い込んでいた子供を人質にとる！　相手は子供が大好き。きっと平常心でい\nられなくなるはずだ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「な……ななな……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛？" ]},
		{"command":[ "SETTEXT", "「ま、ままー。助けてー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あ、あなた、それでもインクレディブル・スクワッドの隊長なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030012" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせぇ！　俺はもともと悪の組織の人間だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さあ、この子の命が惜しければ、俺たちの要求に従ってもらおうか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そ……そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030013" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえに選択肢はないぞ！　ほれほれほれ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛？" ]},
		{"command":[ "SETTEXT", "「あーん、いたいよー。怖いよまま―」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「くぅ……っ！　なんて卑怯な手を使うの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030014" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだねぇ。こんなやり方はあたちもどうかと思うよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえらどっちの味方だよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛？" ]},
		{"command":[ "SETTEXT", "「僕も、ただ相手の気を引こうと変装しただけなのに。まさかこんなテンプレ\n悪役ムーブをされるとは思わなかったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛？" ]},
		{"command":[ "SETTEXT", "「たちゅけてままー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、これ以上この子が悲しむ様子を見たくなければ、俺たちを元の姿\nに戻すんだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030015" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほれほれ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛？" ]},
		{"command":[ "SETTEXT", "「あーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023030008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「やめてっ！　それ以上幼女をいじめないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030016" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「わ……わかったわ……。あなたのいう通り、みんなを元の姿に戻すわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030017" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、それでいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待っておくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030018" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうせなら、元の姿よりちょっとだけ若い姿に戻れないかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023030010" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それは……難しいわねぇ。あなた達から奪った時間を同じだけ戻すんだし…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023030019" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
