		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「さて……集中練習が終わって、君だけが居残り……どうして、そうなったか\n分かっているか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704101" ]},
		{"command":[ "SETCHARA", "0", "char_00004907_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだな……どうも、今日の練習に身が入っていないようだったからな。そ\nの原因を取り除いてやらねばなるまい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まあ、おおよその見当はついている。つまり……こういうことだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00004907_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……何を驚いた顔をしている。君が、私の身体を舐め回すように見てい\nたことは分かっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そして、私がどんな思いで練習に臨んでいたかも……君は何となく分かって\nいた筈だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだ……君が私をそうさせたのだぞ？　皆に指導をしている間も、どうに\nも君のチンポが気になって仕方がなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ほら……なんだ、このチンポは？　もう、ビンビンに勃起して反り返ってい\nるじゃないか。この状態は見逃せんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「なに……？　私のこの状態を見たら絶対にそうなる？　ふふ……光栄だな。\n君を興奮させてしまったわけだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ならば、その責任は取らなくてはな……あぁ、もう我慢できない……んっ、\nチンポ……ハメるぞ……オマンコを落としていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁぁぁぁぉっ……おっふ……おぉっ、チンポ……ずぶずぶ……\n入っていくぅぅ……あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704110" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……もう、トロトロに濡れているだろう？　指導中も、マン汁が滲みで\nて……平静を装うのが大変だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、もうごまかす必要もない。んっ、今日は私がしっかりと腰を振って、\n勃起チンポにご奉仕するからな……はっ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ、くふっ、おっ、ほっ、あぉっ……ふ、太い……あぉぉっ、オ\nマンコ……広がる……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ、これだ……この感触を待っていた……んっ、チンポが内側から膨れ上\nがっていく……この感じだ……くぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704114" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「腰を落とす度に……あぉっ、膣壁に、心地いい痺れが広がっていく……んっ\n、勝手にピストン……してしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んふぁ……見えているか……？　あぁ、君のチンポをぱっくりと咥えこんで\nいるオマンコが……丸見えだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「繋がっているところがいやらしいな……あぁ、隙間からよだれがどんどん溢\nれ出して……はんっ、ぐちゃぐちゃになっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、あひっ、んふっ……目線が……あちこち、忙しいな……この揺\nれる乳房……おっぱいも気になって仕方ないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……少し不格好に垂れて……恥ずかしいが、君の目が楽しめるなら……\n喜んで、おっぱいも揺らしてみせよう……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あぁっ、いやらしい……こんなガニ股になって……おっぱい\nもオマンコも……全部丸出しでへこへこと腰を振って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704120" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「年甲斐もなく……あぁっ、チンポに夢中になって……ほぉぅっ……！　だが\nっ、気持ちがいいっ……気持ちいいんだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ、君が……名器だとっ……反応が極上だとっ……事あるごとに褒めて\nくれるからっ……私も、どんどんその気になって勘違いしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだ……このチンポの虜になって……恥ずかしいことでも、なんでもして\nしまう、浅ましい女になっているんだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぉぉっ、ここっ、おぉっ……チンポのカリがっ、土手のところに……あ、\n当たるぅっ、くぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704124" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「おっ、ふっ、あぁっ、グリグリ……押し付ける度にっ……ケダモノのような\n声が出てしまうっ、あぉぉっ、そこぉぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁっ、ふっ、あぁっ……どうだっ？　君のチンポ……感じてくれているか\nっ？　私のオマンコ……ユルユルになっていないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704126" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こんな年増女のっ……あぁっ、拙い腰使いでっ……あぁっ、興奮してくれて\nいるかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ドスケベ女……あぁっ、そ、そうだ……私の本性は……チンポが大好きなっ\n……いやらしいメスっ……！　ドスケベなんだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「表では、厳しい長官っ……鬼のコーチなどと恐れられているかも知れないが\nっ……君のチンポの前に完全屈服する……いやらしい女だっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ、そうでなければ……こんなっ、貪るようにチンポをかき回す真似な\nどできないっ、あっ、おぉっ、ほぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「な、何度でも言うっ……このチンポがいいっ、チンポが好きだっ、あぁぉっ\n、チンポ気持ちいいっ、オマンコ感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、は、恥ずかしいっ……恥ずかしいに決まってるっ！　こんな姿\n……他の誰にも見せられないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704132" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「君だからっ……君にだから見せるんだっ……あぁっ、ぐちょぐちょの中が…\n…かき混ぜられてぇっ……イ、イキたくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、だが……まだだ……君もっ、そろそろ……イキたくなって\nるだろうっ？　このチンポの震え方……もう分かっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、もちろんっ……離さないぞっ……最初の一発は中出しに決ま\nっているからな……一番奥で出すんだっ……いいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁっ、チンポが震えてるっ……私も、もう待ちきれないっ\n！　あぁっ、来るっ、あっ、ふぁっ、あぁぁぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はひっ……あぁっ、来たっ……！　あっ、出てるっ……生精液っ……ドピュ\nドピュされてぇっ、おほぉぉぉぉぉぉぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、おぉぉぉぉ……おふぁ……イ、イッたぁ……あぁ……子宮まで届けら\nれた精液……最高だ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、しばらくこの感触に浸りたい……はぁぁ、埋まったチンポを\n……じっくりと中で味わう……たまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっふ、あぁ、やっと射精が止まった。本当にいっぱい出してくれたな……\n感謝するぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704140" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んふぅ……さて……一段落したとはいえ……チンポは、まだまだ元気そうだ\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「どうだ？　このまま終わりにするか……それとも……あっ、おぉっ！　んふ\nっ……突き上げっ、来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……直接チンポで返事をしてくるとは、やはり君だな……んっ、いいだ\nろう……私も、まだ身体の疼きが収まりきらずにいるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「中出しされてドロドロになったオマンコで申し訳ないが……はっ、んんっ…\n…引き続き……私のご奉仕ピストンを味わって欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふっ、んんっ、あふっ、あっ、んむぅっ、あっ、おっ……おぉっ……あぁ…\n…今、イッたばかりで……感度が……くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704205" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふっ、大丈夫だ……ゆっくり、慣らしていく……もっともっと二人で深み\nに嵌っていきたいんだ……おっ……ほぉぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ようやく、チンポのサイズには慣れてきた……オマンコのヒダが……しっか\nりと全体に絡みついて……いい感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……うねっているな……はぁぁ……熱い幹が、ぐいぐいと……表\n面をなぞってくる……んむぅっ、くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704208" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ……この感じ……んっ、君の方からも……チンポ……突き上げて……\nくっ、んぅぅぅ……ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、おっ、くぅぅ……私も負けていられないっ、んっ、ただ腰を振るだけ\nでなく……しっかりオマンコを締め付けていかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んくぅっ……！　はぁんっ、どうだ……？　あぁ……んふっ、また目がギラ\nギラしている……おっぱいが気になるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704211" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、そんなに気になるなら……後で、直接吸ってもいいぞ……？　はっ、\nんっ、ふっ……私がイッた後になるが……あっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ、あぉっ、またっ……突き上げられるぅっ！　あぉぉっ、そんなにや\nる気を出すなんて……んふっ、女冥利に尽きるなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704213" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いいぞ……もう、すぐにイッてもいいっ……また、続ければいいだけだから\nなっ……はぁんっ、もっとオマンコするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あぁっ、いいっ、このチンポピストンっ！　あぁっ、やればや\nるほどっ……ジンジン……するぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……！　んんっ……締め付けるだけで気持ちいいっ、あぁっ、ま\nた、チンポが震えているっ……次の射精が近いんだなっ？」", "NORMAL" ]},
