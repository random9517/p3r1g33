		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、今度は……君の好きなようにしていいからなっ……また、中出しして\nもいいっ……私にぶっかけてマーキングしてもいいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「とにかくっ、君の逞しくて太いチンポでっ、私をメスにして欲しいっ！　あ\nぁっ、もうっ、止まらないっ、イクまでっ……このままっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、あぉぉぉっ、私もっ、もう限界だっ……このままメスイキするっ！　\n君と一緒にっ、最高のアクメを迎えたいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだっ、ズボズボチンポ突き上げてぇっ！　あぉぉぉっ、イクっ！　んひ\nぃぃぃぃっ、イグぅぅぅぅぅぅっっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あへぁぁぁぁぁっ……！　なかぁっ……あっ、またっ……中に出されてぇっ\n、は、ひぃぃぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「うぁぁ……チンポが膨らんで……射精してるっ……オマンコ、いっぱいにさ\nせてっ……まだ、出続けてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぉぉぉぉぉ……あぁぁ……メスイキ……気持ちよすぎるぅ……まだ、射精\n……止まらない……あへぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んんっ、後もう少しだけ……？　分かった……さ、最後の締\nめ付けで……んんっ、あっ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふっ、出てきた……奥に残っていた分……これで……全部出し終わった…\n…それでいいんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704305" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……もう、腰に力が入らない……チンポを抜くのも、もう少し待ってく\nれ……はふぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「すまない……しばらくの間、このチンポに支配された余韻に浸っていたい…\n…それだけ、素晴らしい瞬間だったということだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが……こんなに直接出されてしまったら、本当に妊娠してしまったかも知\nれないな……私もすっかり流されてしまったが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もし、そうなったとしたら……私も、その覚悟はできている。君にも責任を\n取ってもらうことになるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……そう緊張するな。その時はその時……その前に、また楽しめる時が\nあれば、またしよう……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はひぁぁぁぁぁぁっ！　あっ……精液……飛んでっ……んんっ、おっぱいっ\n……顔まで……浴びせられてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……噴水みたいに溢れて……おふっ……止まらない……こんなに出\nして……肌に……染み込むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁぁ……このにおい……たまらない……ずっとメスイキしたまま……はぁ\nぁ……気持ちいいの……続いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……精液が熱い……身体が火照っているのに……おっぱいが\nやけどしそうな……変な感覚だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もう、射精も終わりか……？　あぁ……本当にたっぷり出したな……お疲れ\nさまと言わせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704405" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、本当に全身がドロドロだ……中も外も……私の全てが君の精液\nで満たされてしまった……満足だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「普段の練習も、これだけ身を入れてくれれば助かるんだがな……ふふっ、冗\n談だ。わざわざ付き合わせて悪かったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こんなことならいつでも歓迎する？　ほう、そこまで言うからには、きっち\nりと先のことまで考えているということだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「婚姻届なら、もう準備はできているぞ。諸々の手続きも全て手配していいが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0704409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……冗談だ。いや、全くの冗談でもないがな……君との身体の相性も悪\nくない……また、そのうちよろしく頼むよ」", "NORMAL" ]},
