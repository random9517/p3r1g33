{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はーい、みんな静かにー。日直ー、号令よろしくー」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はーい！　きりーつ！　れーい！　ちゃくせーき！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んじゃ、出席取るぞー。大江山夜日楽ー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はい。あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　委員長、どした？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「今日はカツマ先生がホームルームをやるんですか？　お姉ちゃ――じゃなく\nて、大江山先生は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113020002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。大江山先生は、事務関係の用事があって遅れるそうだ。そんなわけで\n、ホームルームは副担任の俺が代わることになった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　まりあ、どうかしたか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「い、いえ！　なんでもないんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010113020002" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか？　それじゃ続けるぞ。えーと、次は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "といった具合に、俺は淡々と学生たちの名前を呼び、出席を取り続ける。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルルーナ・フォンブラウン・ムーンランド」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マーガレット・ロート」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はい！　はい！　はーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつも言ってるけど『はい』は一回でいいからなー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "きょうはこんな具合に、平和な学園生活が続くのかな……と、思ったその時だ\nった。突然、校内放送でサイレンが鳴り響く。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「来た！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113020002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はぁ……また来ちゃったか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "各人それぞれの反応を示しつつ、俺も学生たちも放送に注意を向ける。そして\n、サイレンに続いて流れてきたのは――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "学園長" ]},
		{"command":[ "SETTEXT", "「特別授業です。地球防衛科の学生と教職員は、ただちに校庭に集合してくだ\nさい。繰り返します。特別授業です。地球防衛科の――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113020001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "という、学園長からの指示だ。俺は出席簿を机に置き、学生たちに呼びかける\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、みんな。準備して校庭に出るぞ！　お約束はわかってるな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は、はい！　『押さない』『駆けない』『しゃべらない』『急げ！』、『お\n・か・し・い』ですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113020003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あーあ、めんどいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113020002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、校庭では――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うぉおおおおおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。修羅姫殿が交戦中ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よーし！　待ってろ、いま行くぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あらあら、カツマちゃんたちも来たのね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしらも加勢するよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちが変身して校庭に出ると、職員室にいたエファナティカたちも飛び出し\nてきたところだった。合流して戦闘に加わる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん、遅くなってごめんなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こら！　『お姉ちゃん』と呼ぶな！　いまの私は修羅姫だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113020002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「明日楽先生！　援護します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020113020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だから修羅姫だと……あああ、もういい！　とにかくみんな戦闘に加われ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113020003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、ちょっと待て桃花！　おまえまだ変身してないのか！？　準備しろっ\nて言っただろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……はあ。これ、ほんと嫌なんだけど……仕方ないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113020003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "吉備桃花はそう言って、地面に向けて手をかざす。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いざ、バッケンッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113020004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "彼女の目の前の地面が爆ぜ、一本の刀が突き出してくる。桃花はその柄を両手\nでしっかりと握ると――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしにこの剣を……抜かせるなああああああぁぁっっっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113020005" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0106" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "刀を引き抜き、空へと掲げる。そして――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「バッケンローダー、いざ参る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010113020001" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0107" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}