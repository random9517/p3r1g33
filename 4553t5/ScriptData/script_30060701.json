		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「い、いったいなんなんですか？　わたしのこと、呼び出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703101" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ええっ！？　ほ、奉仕ですか！？　奉仕って、いったいなにをすれば……っ\nて、ひっ、オチンチンっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「な、なにを見せてるんですか！　セクハラっ、セクハラですっ！　あっ、あ\nうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こ、これに奉仕して、パワーアップできる……？　み、未来はそういうのが\n、当たり前なんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703104" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「まあ、確かにこのままよりは……。わたしも、多少はみなさんの役に立ちた\nいって、思いますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「だからって、オチンチンに奉仕するのは……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……ひゃうぅっ！？　なっ、いきなり胸に、オチンチンを突っ込まないでく\nださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あ……ああ……。オチンチン……おっぱいに、挟まっちゃってる……うぅ…\n…すっごい熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「な、なんですか……。そりゃあ、これがパイズリってことくらい、知ってい\nますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「このあと、どうすればいいのかも、わかりますけど……。でも……わたしな\nんかで気持ちよくなれますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「と、とにかく動かしてみろ、ですか。わ、わかりましたよ……。んっ、んぅ\n……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、く……ふぅ……。直接肌に触れているわけじゃないのに……\n熱が……おっぱいに伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それにこうして……んっ、おっぱいで、ぎゅってするたびに……はぁ、はぁ\n……オチンチンが、ビクンって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「これが……男の人の……。んっ、んんぅ……。オチンチン……ああ……なん\nだか、変な感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「外側は、ぷにっとしているのに……でも、中はとっても硬くて……。それに\n、臭いも……すごくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「お、おっぱいの動きが止まってる？　わかりました……もっと、動かします\n、よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んんっ、んふぅ……はぁ、ああ……。おっぱいの間から、ンッ、オチンチン\nが、顔を……出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こんな……ンッ、オチンチンって、大きいものなんですか……？　んっ、ん\nふぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「勃起して……ビクビクして……。それに、真っ赤になってる先っぽが、パク\nパクって、していて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それに……ンッ、あなたの腰まで、なんだか震えている、ような……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わ、わたしのパイズリで……気持ちよく、なっているってことですか……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「で、でも……。気持ち悪くないですか？　こ、こんな……バカみたいにでか\nいおっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「よく、他の職員からからかわれたり、馬鹿にされたりしていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ひゃうぅっ！？　い、いきなり大きな声を出さないでください！　そんなこ\nとないって、言ってくれるのは嬉しいですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ！　あなたは、大きいおっぱいの方が、好き、なんですか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「大きいのが好きって言っても、限度があるでしょう？　こんな、牛みたいな\n大きさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　だ、だから大きな声を出さないでくださいってば！　そ、それ\nでも……わたしのおっぱいが、好きなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ううぅ……普段ならこんなの、絶対セクハラなのに……。あなたに、おっぱ\nいを褒められるの……嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「は、はいっ！　さっきよりも、おっぱい押し付けて……んっ、オチンチン、\nおっぱいで、しごいて……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「先っぽから、ああっ、ヌルヌルしたのが溢れて……はぁ、はぁ、おっぱいの\n間が……ベトベト……んっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチン……すごく、感じて……ああ、あなたも、わたしのおっ\nぱいで、興奮してくれてますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、すっごく、腰を動かして……アアッ、わたしのおっぱいに、オチンチ\nンを擦りつけるみたいに……あっ、ンン……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「射精……こ、このまま、射精しちゃうんですか……！？　お、おっぱいに、\nあんっ、精液……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「そ、それは……んっ、あっ、ああっ、ま、待ってください……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んんっ、んぁあっ！　待ってって言ったのにっ、いきなり射精っ！　ああっ\n、びゅるびゅるって、オチンチンからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「精液、すっごいたくさん……。はぁ、はぁ、こんなにドロドロ、ネバネバし\nたものが……ああぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「制服……汚されちゃいました……。ううぅ……そんなに、わたしのパイズリ\n気持ちよかったんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「オチンチン、おっぱいでしごいただけで、こんなにたくさん精液出ちゃうも\nのなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「若いころからおっぱいマンコだったんだなって、な、なんですかその言い方\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコだなんて……おっぱいオバケって呼ばれた方がまだマシです\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んひっ！？　ちょ、ちょっと待ってください。あれで、おしまいじゃないん\nですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、まだまだオチンチンがこんなに硬い……。ンッ、も、もっとわたし\nのおっぱい使わせろって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んくっ、んっ、ああ……っ！　さっき、射精されて、ぐちょぐちょのおっぱ\nい……オチンチンでかき混ぜられてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、もっと、締めろって……？　んぅっ、こ、こう……ですか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、さっきよりも、おっぱいにオチンチンが密着しちゃっているの、感\nじちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「お、おっぱい……んっ、熱くて、硬い……ガチガチのオチンチンが……出入\nりしちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああ……おっぱい、こんなことに使われてるのに……なんだか、胸が……高\n鳴ってる、ような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「精液まみれの、ドロドロオチンチン……い、一生懸命、おっぱいの中を擦っ\nてて……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「オチンチンから……はぁ、はぁ……目が、離せない……んぅ……ふぅ……あ\nっ、んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わ、わたしのおっぱいが……んぁっ、あなたのオチンチンのこと……気持ち\nよく、できてるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、もっと……んっ、こうして……ああっ、おっぱいで、ぎゅうって……\nすれば、いいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「精液まみれの、んっ、おっぱいを……上下に……んっ、んんっ、動かして…\n…はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んひゃっ！　おっぱいの中で、オチンチンがまた……おっきく……んっ、あ\nあっ、さっき射精したのに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「また、気持ちよくなって……オチンチン、射精しちゃいそうになっているん\nですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わ、わたしのおっぱいに向かって……んっ、ああっ、セックスするみたいに\n、腰を打ちつけて……あっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱい……んっ、ほ、本当に、オマンコみたいに使われちゃって\nる……！　あっ、ああっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「おっぱい……オマンコ……ああ、本当に、おっぱいマンコにされちゃってる\nのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それなのに、胸が……ンッ、すっごくドキドキしちゃって……ああっ、あな\nたのオチンチン、気持ちよくなってくれるの、嬉しくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、いい、です……。んっ、このまま、わたしのおっぱいマンコ\n使って……イッてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱい好きに使って、好きに、射精してくださいぃいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ああぁっ！　あはぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ま、また……おっぱいの中に……ンッ、たっくさん精液が、びゅくびゅくっ\nて……んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「お、オチンチン……ビクビクしながら……。ま、またぁ……精液……あふれ\nちゃうくらいに注いでるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「また……たくさん射精しましたね……。二回目なのに、こんなに濃くて、ネ\nバネバしてるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「そんなに……気持ちよかったんですか、わたしのおっぱいマンコ……うぅ、\n今になって急に恥ずかしくなってきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「な、なんですか……。気持ちよかった……？　なら……まあ、こうしてあな\nたに付き合ってよかったって思えます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それにしても……なんでまだ、おっぱいの中のオチンチンは硬いままなんで\nすか……？　二回も射精したのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ま、まだまだできるって！？　男の人って、そんなに何回もできるもんなん\nですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「えっ、わ、わたしのおっぱいマンコがエロすぎるからって、ちょ、直球で言\nわないでくださいっ！　恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ま、まあ……。あなたがそういうなら、最後までお付き合いしてもいいです\n……よ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ！　ちょっと……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「な、なんですか……ああ……こんどは……顔にぃ……。んっ、ドロドロの、\n精液が……いっぱいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああ……んぅ……。口にまで、ンッ、はいっちゃったかも……んっ、んふぅ\n……ネバネバが……あうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こんな……あぅ……二回目なんですよね……？　それなのに、すっごく濃い\n臭いの、精液でぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わたしの顔……ンッ、まっしろに……されちゃったら……はぁ、はぁ……臭\nい……肌についちゃうじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こ、これだけ精液を搾れるおっぱいしてるんだから自信を持て……って、そ\nれって励ましてるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ま、まあ……その……。射精中のあなたの顔は、とっても気持ちよさそうで\n……見ていて、イヤじゃありませんでしたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「その……だからですね……もっと、あなたのそういう顔を見せて欲しいなっ\nて、思うんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、だから……うぅ……また……こうして……呼んでくれると、嬉しい\n……わけでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「そ、そしたら、あなたが気に入ってくれたおっぱいで奉仕するので……。こ\nれからも、よろしくおねがいします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0703410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}