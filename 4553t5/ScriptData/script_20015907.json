
{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ご苦労だったな、みんな。今日も大活躍だったではないか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「はい、ありがとうございます、ルナテミスさん」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「私達も、ようやくこちらでの戦いにも慣れてきた感じがしますね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そうだな……最初に来た時は、少し身体が重かったように思えたが、今は調\n子よく感じるな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤもですか？　私も似たような感じです。とても、動きやすくなった\nと言うか……身体が軽く感じます」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ここって、ご飯も美味しいですしね！　アリーヤ先輩は、それで調子がいい\nんじゃないですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「む……まぁ、美味いものが多いのは認めるが、それが体調にまで関係あるか\nは……はっ……！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……今日はこの世界でも戦士たちに圧倒的な支持を得ているこいつ……\nカツ丼だ。さあ食え」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「くぅっ……これは、もう見た目から既に危険な雰囲気が……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、最近すっかりアリーヤにメシ食わせるのハマってますよね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなに食べさせがいのある奴は中々いないからな。ほぉら、ふわふわの卵\nでとじられたカツだぞぉー」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「むぐっ、んふぅっ、はぁぁ……美味い……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……にしても、今日の戦闘も何だかすごい騒ぎだったな。もう戦いが始まる\n前から、雰囲気が違うというか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「皆のヴァルキリー特務隊への期待感が高まっているんだろうな。敵の連中も\nやり辛そうだったぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「私達も少し戸惑う位なのですが……こちらの民の方々も、とても良くして下\nさっていて……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい、これ程までに私達のことを受け入れて下さるなんて……本当にありが\nたいと思います」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「急遽作ったヴァルキリーグッズも、今は飛ぶように売れているからな。タペ\nストリーも、アクスタも何でもござれだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちゃっかり商売してたんすね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「しかし……もぐ……何となく居着いているが、本来は我々は異邦の者である\nことを忘れてはならんと思うぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全部食べてからでいいですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「わ、分かっている。んぐっ……とにかく、例の裂け目はどうなったのだ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「確か……あの後、裂け目は一旦塞がるような動きを見せたんだよな？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「科学班は周期的なものかも知れないってことを言ってましたね。また、その\nうち広がるかも知れないって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「行き来をするなら、裂け目を通じてなんでしょうけど、現状では難しいとい\nうことだと聞きました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、焦って状況が変わるわけでもない。調査は続行しているし、状況が改\n善するまでは、うちにいればいい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「申し訳ありません、ご迷惑をお掛けして……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、迷惑なんてとんでもない。こっちこそ、かなり助かってますし気\nにしないで下さいよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、めったにない機会だしな。今しかできないことを楽しむといい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「あっ、それならスクルドは、遊園地っていうのに行ってみたいかも！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「私は……プールというのですか？　海のように泳げるところがあるそうなの\nで、そこに行ってみたいかも……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……いいじゃないか。プールがついている遊園地……連れて行ってやる\nぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「ほ、本当ですかっ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「プールに行くなら水着も用意しないとだな。とりあえず、言っておけばワン\nチャン実装もあるかも知れん」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何のアピールをしてるんですかね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「水着……！　レイアお姉様にはどんなのが似合うでしょうか……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「わ、私はそんなに泳ぎが得意というわけではないですから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「泳がなくても大丈夫です！　水着姿のお姉様を見たいだけですから！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「欲望がダダ漏れ過ぎる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そう言えば、本場の海の家も悪くないが、プール周りのフードコートもかな\nり行けるぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「スクルド知ってる！　あーいうところの、ラーメンとか焼きそばが美味しい\nって！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「……む……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「スクルド、それは少し違うな。実はアレは美味しい訳ではない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「えっ、違うの？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、結果としては美味いんだが、実際のところは材料もチープで、特別絶\n品というわけでもない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だが、泳ぎ疲れた身体に、仲間たちとダベりながら、少しのびた麺をすする\nとな……これがメチャクチャ美味いんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「な、何だかよく分かんないけど、おいしそう！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「……ごく……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……気になるか、アリーヤ。ならば、次のオススメは……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「い、いや、大丈夫だ！　と言うか、私はそこまで食い意地は張ってないから\nな！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ふふっ、でも、こんな楽しいお話ができるなんて……何だか夢見たいですね\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「そうですね……こんな平和な日々が、ミッドガルドでも当たり前になればい\nいんですけど……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お前たち、大変だっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたんですか？　血相を変えて」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「裂け目に……異変が起こっている……！　急いで来てくれ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}