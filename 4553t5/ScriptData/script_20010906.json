{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0050" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "某日。クラッドたちのアジト。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「今回は我だけで出撃する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021210001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「えー、私もいくー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021210001" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「トタンは傷が癒えていないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021210002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「いやいや、ちょっと装甲がへっこんだだけじゃん。こんなのかすり傷だって\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021210002" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「それに、クラッドがゲームしている間にすっかり治ったよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021210003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「だめだ。トタンはステイホーム」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021210003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ぶー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021210004" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "1", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「それでは、行ってくるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021210004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……で、だ。なんで俺たちはこいつらと一緒に買い物に出かけてるんだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00001201_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まあまあ。二人とも女の子だし、どこの世界にいてもオシャレしたいんじゃ\nない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "暗黒界はまだこの世界を狙っている。鈴と葉金は、この世界にしばらくとどま\nることになりそうだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というわけで、当面の生活に必要なものを買いそろえることになったのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「鈴ちゃんと葉金ちゃん、一緒に暮らすことにしたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ええ、ルームシェアをしようかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「そういうこと。まあ、元の世界でも寮で相部屋だったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「そうですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「へー、なんだかうらやましいなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たち、完全に蚊帳の外だな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、ご主人は荷物持ちとして呼ばれましたからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021210001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう思うならお前もちょっとは手伝え。荷物を持て」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「それにしても、異世界ってあんまし元の世界と変わんねー感じだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210002" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「そうですわね。この世界の襲来者（インベーダー）と戦っている組織の方々\nが、少々オーバーテクノロジーな感じでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「それ以外は本当……ほら、見てみろよ葉金」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　男の人が居る前で下着を指さしますか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210004" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「お前、こういうデザイン好きだよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「大声でそういうことを言わないでください。まったく、今は二人っきりのシ\nョッピングではないんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210005" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "4", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なーんか普通に買い物を楽しんでるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「世界を救う変身ヒロインも、普段は普通の女の子ですからなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021210002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つきみが言うならそういうもんなのか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……というか、すっかり忘れていたが、暗黒界の狙いとか聞いてないぞ！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえば、前回そんな引きで終わったような。なにぶん、一週間も前のこ\nとですからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021210003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、鈴、葉金。結局あの暗黒界の連中はなにがしたいんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ああ？　わからん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210005" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わかりませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「よくわかんねーけど、街をめちゃくちゃにする悪いやつは許せねぇ。ぶっと\nばす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210006" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「人々の安全を脅かすのなら、放ってはおけませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210007" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、こいつら大丈夫なのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はい。えっ、襲来者（インベーダー）！？　こんなときに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「なんだ、襲来者（インベーダー）って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210007" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えっと、私たちの世界にやってきてる悪いやつのことだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "つきみは画像を見せた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「へえ、面白そうなやつと戦ってるじゃねーか。アタシたちも連れてけよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210008" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えっ！？　いいのかな、そんなこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「鈴、あまり異世界の問題に首を突っ込むのはやめた方がいいですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210008" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「いいだろ？　それに、街をめちゃくちゃにするやつは暗黒界じゃなくても許\nせねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210009" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「まったく。貴女になにかあったら、ブリキ２に変身できなくなるんです。そ\nしたら、クラッドたちとも戦えない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「なんだよ。葉金はブリキ２に変身するためにアタシと一緒にいるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210010" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "0", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「そういうわけではありません！　ただ、わたくしはわたくしたちの目的を果\nたすべきだと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210010" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「とにかく、どの世界にいようとアタシは悪いやつを放っておけないね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210011" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「もう、勝手にしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021210011" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "1", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ああ、そうさせてもらうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021210012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ああっ、鈴ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210008" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鈴が襲来者（インベーダー）の現れたという現場へと向かってしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　ケンカか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「青春でございますな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021210004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いやいや、大変だよ！　だって、鈴ちゃん一人じゃ変身できないんだよ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210009" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「というか、場所もわかってないんじゃない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだな！　じゃあ、俺は鈴を探しつつ現場へ向かうから、つきみは葉\n金を連れて本部の部隊と合流してくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「う、うん。わかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021210011" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "鈴は騒ぎのする方へと向かっていたらしい。カツマがついたころにはすでに襲\n来者（インベーダー）と戦闘していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったく、単独で敵の中に突っ込むなんて無茶にもほどがある……」", "NORMAL" ]},
