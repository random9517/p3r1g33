{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えと……もう少しだけ、下に……はい、大体そのくらいで大丈夫です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「申し訳ありません、お手を煩わせて……私に出来ることを一生懸命考えたら\n、この、発育を活かすしかないと……そう思いまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「一応、事前に出来る限りの予習はして参りましたが……至らぬ所は色々ある\nと思います……！　そ、それでも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「少しでも、私の、お、おっぱいで……気持ちよくなって頂けるように……オ\nチンポを……扱かせて、パイズリさせて頂きますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「よ、よろしいですか？　はい、では……ぎゅっと……挟みます……んっ……\nんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……よい、しょっと……あの、出来れば……その、最初はじっとして頂\nけると……え、えいっ……えいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……何とか、捕まえられたみたいです……あぁ……やっぱりオチンポ熱\nい……とくんとくんって脈打って……本当に逞しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「まずは……んっ、しっかり挟んで……ぎゅっと包み込んで行きますね……ん\nんっ、くぅ……んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……まさか、自分のおっぱいを、こんな形で動かす日が来るなんて……\n改めて考えると……とても、は、恥ずかしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも……んっ、貴方の力強さを……んっ、こんなに間近で感じられる……そ\nれだけでも、とても幸せです……あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ここから、動かして行きます……右のおっぱいと……左のおっぱいを交互に\n……んっ、ふっ、んくっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……そ、そうでした。確か……唾液で滑りやすくさせると……より、気\n持ちいいと聞きました……ん、えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これで、先程よりも……んっ……よくなるのでは……んっ、ないかと……は\nぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……本当です……たった少し、滑りやすくなるだけで……さっきと感触が\n全然……っ……違って来ます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「より、オチンポの……形がはっきり……分かるような、んんっ、おっぱいの\nお肉と重なり合って……はっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、は、はしたない声を出して申し訳ありません。慣れない感\n覚の刺激で……あっ、んくっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ですが、んっ、このオチンポの震え……私のおっぱいで……感じて頂けてい\nるということでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……よ、よかった……はい、この調子で続けて参ります。んっ……はっ、\nんんっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……凄い、オチンポが前より膨らんで……はぁっ、んっ、あっ……くぅ\n……熱い……汗が出てしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「それも……潤滑油に……そ、そういうことなんですね……はい、ずりゅずり\nゅっ……オチンポ扱き続けます……いやらしいパイズリ、頑張りますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、あぁっ……はい、私のおっぱいも……感じています……オ\nチンポと擦れて……気持ちいいですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、ち、乳首も使うん、ですか……？　あぁ、今、そんなことしたら……\nでも、お望みでしたら……んっ、ひぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、今の凄い……身体にピリッと来て……もっと押し付けて……この、コ\nリコリ……んっ、オチンポに当たるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あっ、あぁんっ……手が止まっちゃう……駄目、私ばっか\nり感じてたら……オチンポが一番大切なんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、んしょっ、すみません、おっぱい……続けますから……んっふっ、あ\nっ……はぁっ、うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……何でしょうか……そんなに、じっと……顔とおっぱいを……み、見つ\nめられたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぅ……わ、私の感じてる表情で……興奮……うぅっ、は、恥ずかしい……\n！　駄目です……そんな、お許し下さい……恥ずかし、過ぎます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、興奮して頂けるなら……私……はっ、んんっ、あっ、あぁ…\n…頑張りますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もっと、大きく動かして……あぁっ、やだ……自分のおっぱいが、こんなに\n潰れてっ、形が……い、いやらしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……自分にこんなはしたない一面があったなんて……どうか、軽蔑なさ\nらないで下さい……貴方にだけなんですから……こんな、こと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、貴方になら……どんな姿でも見せてしまえる……私がおっぱい感じて\n……乱れた表情になっても……貴方になら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、オチンポ……どうですか？　この感じ……あっ、んっ、そ\nろそろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい……分かります。先程よりも、ずっと震えが大きくなって……射精した\nがってるってこと、ですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「出来れば……最初は……んっ、このまま、おっぱいの中に出して下さい……\n貴方の精液……身体の中心で感じたいんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、あぁ……はいっ、扱きますっ……沢山シコシコしてっ、中出\nしして……頂きますっ、はんっ、あっ、あんっ、あっ、あぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　あっ……あったかいのっ……びゅるって出ましたっ……んんん\nっ、ねっとりして、ます……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ、私のおっぱいが……オ、オマンコになったんですね……ヌル\nヌルの精液……元気いっぱいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……あ……なんと言うか、変わった味がします……す、すみません\n、お行儀悪くて……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、後でお掃除とかしないといけませんから、この味にも慣れておかない\nとですよね……んっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、収まりましたか。至らない所も多かったでしょうが、射精して頂けて\n……嬉しく思います……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっ……？　良かったから……このまま、もう一回……は、はい！　もちろ\nん、させて頂きますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっと……どうしましょう……普通に続けていいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、そうですね……出して頂いた精液をもっとおっぱい全体に伸ばすよう\nな感じですね……は……んんっ、あっ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……んくっ、すごく滑ります……ベトベトだけど……あぁ、よく馴染ん\nで……はっ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「精液……こんなに出てたんですね……なのに、オチンポ……前より反り返っ\nているような……こ、興奮されているんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は、はい……もちろん、私も……とても、ドキドキして……興奮と言うか…\n…半分、発情しているような感じです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あんっ……今、乳首を弄られたら……はふっ、んんっ……本当に、感じすぎ\nて……んぁっ、あぁっ、パイズリがおろそかに……あ、ひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、ちゃんと……乳首も使いますから……悪戯は許して下さい……ん、あ\nふっ、はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え……貴方も腰を、ですか……は、はい……分かりました。それは、もちろ\nん好きになさって下さい……あっ、ひぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……そ、そんなに激しく動かすものなんですね……あっ、あぁっ、おっ\nぱいの中で……オチンポが跳ね回って……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ……これ、本当に……オチンポで犯されてるみたいな……んっ、はぅ\nんっ、あぁっ、おっぱいが……熱いですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁっ……されるばかりでは……いけませんっ……私も……しっか\nりパイズリご奉仕をっ、あふっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「くぅん……あぁ……身体が火照って……オチンポと一つになっていく感じが\n……あっ、堪らないですっ……んひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「こうして、ぎゅっとおっぱいをくっつけてっ……ヌルヌルを絡ませてっ……\nち、乳首っ……こすってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303214" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_06" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んくぅんっ……あぁっ、にちゃにちゃって……いやらしい音ぉっ……興奮し\nちゃいますっ……あっ、貴方の方は……どうですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「いいですかっ？　んんっ、私のご奉仕で……いっぱい感じて頂けてますかっ\n？　あぁっ、嬉しいですっ、私もっ……感じ過ぎるっ、位ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、はぁんっ、あぁっ……おっぱいいいっ……このままされた\nらっ、おっぱいでイっちゃいますっ……はっ、ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ……オチンポも、出そうですかっ？　はいっ、あぉっ、もう少しですよ\nねっ……んんっ、あっ……ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私もっ……おっぱいイキますからっ、一緒にっ……びゅくって出したいとこ\nろにいっぱい出して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「オチンポずりゅずりゅしてっ、また気持ちよくなってっ……熱いの射精なさ\nってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はいっ、またおっぱいにお願いしますっ……栄養がたっぷり詰まった……濃\n厚な精液っ……いやらしい谷間にいっぱい下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁんっ！　出てますっ、また熱いのっ……どぴゅって……おっぱい\nにっ……出てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……さっきと同じくらい……いえ、もっといっぱい……んんっ、あぁ…\n…おっぱいが精液漬けにされていきますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……もっと下さい……いっぱい搾り出してしまいますか\nらぁ……んっ、こうしてぎゅってしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふっ……！　んんっ……ほら、残ってました……完全にスッキリしてしま\nいましょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はふ……終わり、ましたか？　はい、お疲れさまでした……オチンポの先に\nついてる分も、おっぱいになすりつけて下さい……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「後で……改めてお清めしますから……今は、ここに……んっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「全部出して下さいましたか……？　はい、ありがとうございます……ふふっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「すみません、自分がこんなに大胆なことが出来るなんて思わなくて、つい…\n…おかしくなってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、今日思い切ることが出来て……自分に自信が持てた気がします。気が\n早いですけど……また、機会があればぜひ……ご奉仕させて下さいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……今度は顔にっ……？　はいっ、お願いしますっ……また、い\nっぱい精液掛けてっ……ミルクでドロドロにして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　んんっ……はぁぁっ……お顔に出てる……あぁっ、濃い\nのが……ドロって……すごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あふぁ……マーキングされちゃいます……貴方の精液が……私の顔にも……\n身体にも全部……染み込んでいくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……あぁ……濃い……喉に絡みついて……んくっ、すぐに飲み込\nめない位……は……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「お願いします……ちゃんと最後まで出し切って下さい……奥に残っている分\nも、しっかり……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ……今の発射で……出し切りましたか……？　ありがとうございます…\n…お疲れさまでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……顔がぬるぬるします……ちゅぷっ、でも……これで、貴方のものに\nされたって……そんな実感が湧いてきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうでしたか？　その、本当に慣れないもので、上手く出来たかどうかは…\n…どうしても、不安で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「よかった……！　満足して頂けたなら、本当にそれに勝る喜びはありません\n。はい、とても……嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000113_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これで、自分にも自信が持てた気がします。気が早いですけど……また、機\n会があればぜひ……ご奉仕させて下さいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}