		{"command":[ "PLAYVOICE", "129_0103110" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「やれやれ、男ってのはどうしてだか知らないが、おっぱいが好きなんだねえ\n……」", "NORMAL" ]},
