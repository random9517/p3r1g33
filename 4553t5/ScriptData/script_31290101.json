		{"command":[ "PLAYVOICE", "129_0103111" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「それで……どうだい？　こんなもんだと思うんだがね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103112" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「何だって、経験はないのかって？　いいや、ないよ。必要だとも思ってなか\nったし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103113" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「好きだと言われることはあったけどね、そういう男は勝手に死んでいった。\nアンタは死ぬんじゃないよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103114" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「パイズリだっけ？　フェラチオ、合わせてパイズリフェラ、ふふん。これぐ\nらい、いくらでもやってやるからさ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103115" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「へえ、オチンポがビクビクと跳ねてるじゃないか……気持ちイイのかい？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103116" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アンタが悦んでくれるのがアタシゃ嬉しいのさ。こうかい、これでいいのか\nい？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103117" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ちゃんと咥えて……ああ、こうかね。ちゅっ……ちゅる、ちゅぱ、ちゅ、ん\nふっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103118" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アンタ、オチンポちゃんと洗ってるのかい？　ああ、ちゃんと風呂には入っ\nてる。それにしてもすごい匂いだよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103119" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「オスの香りだ……んふふ、アタシも興奮してきた。ちゅるる、ちゅむ、おっ\nぱいを寄せて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103120" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「挟んで、オチンポをしごいて、んっ、んん！？　ちょっと、イタズラするん\nじゃないよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103121" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「乳首を弄るなんて……んぁっ！？　ば、バカだね。アタシだって気持ち良く\nなるよ……オンナなんだからね」", "NORMAL" ]},
