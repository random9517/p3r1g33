		{"command":[ "PLAYVOICE", "129_0103124" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「口と手がお留守だって？　言うじゃないか。んちゅ、じゅるる、じゅむ……\nんふぅ、もっと奥まで咥える……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103125" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アタシを試すようなことを言って、後悔するんじゃないよ？　あむっ……ぢ\nゅむむむ！　じゅるる～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103126" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「じゅっぽ！　じゅぽっ……んふぅぅ！　けふぉ！　えほっ！　ど……どんな\nもんだい。根元まで咥えてやったよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103127" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「もっとして欲しい？　ワガママな坊やだねえ……でも、いいよ。素直にお願\nいされちゃあ……アタシも応えるしかないね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103128" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「おっぱいでしごく手も休めず……んうぅ！　あ、あぁっ……あぁん、乳首を\n弄られ、ながらぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103129" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「あむぅ、ぢゅむむ……んっ、んうぅぅ～～～！！　じゅっぽ、じゅぽっ！　\nぢゅむみゅぅ……んふぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_06" ]},
