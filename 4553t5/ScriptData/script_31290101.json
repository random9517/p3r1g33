		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103123" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「何だって、アタシにも気持ち良くなって欲しい？　だ、だからって……んん\nぅ、はぅ、ああぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012901_01_04" ]},
