		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「性欲を発散したいからアタシにやれって、そういうことかい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103103" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「面白いじゃないか。アタシを風俗嬢扱いしたのは、アンタが初めてだよ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103104" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「それで？　どうしろっていうんだい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103105" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ほう……胸で？　アンタのオチンポを挟んでしごけっていうんだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103106" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「しかもそのまま口で咥えて、スペルマを口で受け止めろと……ハハハ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103107" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アンタじゃなけりゃ、胸ぐらを掴んで吊し上げてるところだけどねえ……ふ\nふっ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103108" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アタシは知ってる。アンタは冗談を言うような男じゃない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "129_0103109" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「性欲をもてあましてるんだね、いいさ……付き合ってやるよ」", "NORMAL" ]},
