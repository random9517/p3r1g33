		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "おじさん" ]},
		{"command":[ "SETTEXT", "「えーっと……おう。丁度だな。それじゃ、１回だけ回してくれ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ハズレ以外ならなんでもいいから、当たって欲しいなぁ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「金色……？　これ……ひょっとして……！？」", "NORMAL" ]},
