		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「は～い……おじさん。福引させてもらうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "おじさん" ]},
