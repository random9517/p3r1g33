		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "おじさん" ]},
		{"command":[ "SETTEXT", "「これが旅行券と宿泊先のホテルのチケットだ。三人分あるから、お嬢ちゃん\nたちで行くといい」", "NORMAL" ]},
