		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……もういいです。どうせハズレでしょうし、さっさと終わらせて家に\n帰るですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540008" ]},
