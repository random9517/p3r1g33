		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人曰く、勝負は時の運です。時には馬鹿勝ちするぜ！　って意味です。こ\nの現実を受け入れましょう」", "NORMAL" ]},
