		{"command":[ "PLAYVOICE", "008_0203101" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぅぅ……れろ……んっ、ちゅぷ……なぜ驚いているのでしょうか\n……？　ンっ、ちゅぱ……ちゅ、ちゅむ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203102" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「だって……パワーアップに必要なのでしょう？　ふぅ……ン、ぢゅっ……当\n然、心得ています……ちゅ、ちゅく……はぁ、んっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203103" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「はい？　べつに、口で奉仕するのが好きなわけではありません……当たり前\nです……こんなこと、好き好んでやるはずがありません……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203104" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「私は……ンっ……仕方なく、やっているだけですので……ちゅぷ、ちゅぅ…\n…んっ、勘違いなさらないように……んっはぁ……ちゅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203105" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んっ……それにこの体勢に深い意味はありません……こうした方が、舐めや\nすいだけですので……んっ、ちゅく、ちゅうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203106" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「そのわりには丁寧な舌使い？　なにをバカなことを……手抜きをして長引く\nより……早く終わらせたいだけです……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203107" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「ですから、隊長も……変に我慢せず、出そうになったら……んっ……すぐに\n出してください……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203108" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「もっと強くですか？　わかりました……んっ、あぁっ……ちゅっ、ちゅうっ\n……はっ……れろっ……んぢゅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203109" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「美味しそうにしゃぶれって……注文が多いですね……いえ、隊長がおっしゃ\nるなら……心がけます……はぁ、んふっ……ちゅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203110" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「どうですか……こんな感じで、いいでしょうか……？　ちゅぷっ、ちゅるっ\n……んっ、ンっちゅっ、ちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203111" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「わかりづらいと言われても……困ります……はっ、あぁ……んっ……ちゅぷ\n……これ以上、どうしろと……あむっ、んっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203112" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「くっ……それは、そうですが……今からですか？　承知、しました……んっ\n、お、おい……しい……です……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203113" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「隊長の、おちんぽ……んっ、れろっ……美味しいです……ちゅ、ちゅうっ…\n…はぁ、ああっ……おいひぃ、です……うぅん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203114" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……本当に趣味が悪い、です……こんなことをさせて……ええ、\n余計な一言でしたね……申し訳ありません……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203115" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「ちゅむっ……でも、隊長のおちんぽ……我慢汁が、こんなに溢れてきて……\n匂いもキツくて、ますます熱くなってますよ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203116" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「はい、わかっております……ちゃんと、このおつゆも舐めて差し上げます…\n…れろっ……ちゅ、ちゅく……れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203117" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「いちいち味がどうかと聞かれても……もちろん、美味しい……ですよ……隊\n長のものですから……はっあぁ……ふぅ……ンンっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203118" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んっ、んぢゅっ……あぁ、カリがパンパンに腫れて……舐めても舐めても…\n…我慢汁が止まりません……ちゅっ……ぢゅうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203119" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「本当にイヤらしい、おちんぽですね……ドクドクと脈打って……んふっ……\n威圧的で、見ているだけで変な気分になります……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203120" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「こんなものを……舐めさせて……ちゅっ、じゅるっ……はぁっ……興奮する\nなんて……変態すぎます……ちゅぶっ、ぢゅ、ぢゅるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203121" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「いえ、いちいち気持ちいいとか……仰らなくても結構です……それより、早\nく……出してください……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203122" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「もっとカリの周りを……？　この出っ張ってる部分ですね？　こう、ですか\n……ちゅ、ちゅうっ……はぁ、れろぉ……んっぶぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203123" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「れろ、れろぉっ……んあっ……チンポが、また大きくなってます……ん、ん\nぶっ……ちゅぷ、ちゅぶっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203124" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んはぁ……なんですか……先ほどから情けない顔をして……これが、そんな\nに気持ちいいのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203125" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「ええ、大丈夫ですよ……ちゃんと隊長がイクまで……舐めますから……んぁ\n……れろっ……ちゅぷっ……ンっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203126" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んぶっ……さっきから、苦い汁が……どんどん溢れてきて……んちゅ、くち\nゅっ……あぁ、舌が痺れてきましたぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203127" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「我慢汁を飲んで欲しい？　それはいいですが……んくっ……精子も、早く…\n…お願いします……ちゅ、ちゅぶっ……ずずっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203128" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「まだですか？　早くイッてください……んっ……くちゅ、ちゅぱ……んっ、\nちゅうっ……ちろちろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203129" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んぢゅっ……もう少しですか？　はい、承知しました……ち\nゅっ、ちゅうっ……んっ、ふっ……ちゅ、れろっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203130" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んっぶっ……れろぉ……んっ、んんっ……そんなに、腰をビクつかせて……\nイキそうなんですね……ちゅう、ちゅうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203131" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「わかりましたから……ちゅ、ちゅぷ……出して、ください……ええ、わたし\nの顔にでもなんでも……はっ、んぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203132" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んんんっ……はっ、んっ、ンンっ……れろっ……ちゅ、ぢゅうっ……ちゅぅ\n、ちゅぶっ、ぢゅぶぶっ……ん、あっはっ……あっああぁあぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203133" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁぁっ！　ああっ……はっ、いやっ……んっ、んんんっ……くっ\n、ま、まて……んん、あぐぅっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000802_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203134" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「な、なんですか……この量は……それにクサいっ……匂いが、キツすぎて…\n…どうにかなりそうです……くっ、くううううっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203135" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ……出していいとは言いましたが……こんなに顔に、かかるな\nんて……聞いてない、です……うっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203136" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「熱い……ですし……ネバネバしてて、気持ち悪いです……こんなの顔にかけ\nられて……嬉しいはずが、ないでしょう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203137" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「はい？　私の奉仕がよかった証拠ですか……パワーアップ間違いなし……と\nいうのは……まあ、素直に喜んでおきます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203138" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「ふぅ……とにかく無事に終わって安心しました……なんですか、そんな嬉し\nそうな顔をして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203139" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「はい？　また……ですか……？　ええ、まあ……必要な行為ですからね……\nもちろん拒否することはありません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0203140" ]},
		{"command":[ "SETNAME", "ピースムーン カグヤ配下" ]},
		{"command":[ "SETTEXT", "「ただし！　楽しみにしてるとか、期待しているとかではありませんので、そ\nこらへんは勘違いしないでください……」", "NORMAL" ]},
