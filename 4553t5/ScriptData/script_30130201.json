{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "013_0203101" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「それで……私をこんなところに呼び出して、一体、何の用事なの？　もしか\nして……また、Ｈなことをする気？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203102" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……え？　今回は仲を深めるためのただのスキンシップなの？　Ｈなことじ\nゃなくて？　……本当に？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203103" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うーん、怪しいなぁ……そう言っていつもＨなことばっかりするんだから…\n…こないだだってあんなこと……はぅ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203104" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……って、そうじゃなくって。とにかくあなたの言うことは全然信用できな\nいってこと！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203105" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんからも、あなたのＨなところには気をつけなさいって、普段から\n口を酸っぱく言われてるし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203106" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……そりゃあ、私だって女の子だから、Ｈなことに興味がないわけじゃない\nけど……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203107" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「今の私は、正義の戦士『シルバスター』だから……チビっこたちが見てるし\n、ヒーローはそんなことしちゃいけないんだけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203108" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うぅ、でも、そっか……みんなの平和を守るためには、強くならないといけ\nないんだよね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203109" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「今は二人っきりだし……それに、あなただったら……むしろちょっと嬉しい\nって言うか……ううん！　なんでもないよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203110" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「しょうがないから、その仲良くなるためのスキンシップ？　っていうのをし\nてあげる！　それで……私はどうすればいいの？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203111" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「えっと、オチンチンの上からおっぱいを乗っけるみたいに押しつけて……ん\nしょ、と……こんな感じでいいの？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203112" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ていうか、やっぱりＨなことだったね……まぁ、もちろんわかってたけどね\n。まったくもう、あなたはしょうがないなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203113" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「でも、オチンチン重たくない？　私のおっぱいってけっこうおっきいみたい\nだから……え？　これが気持ちいいの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203114" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んっ……わ、ほんとだ……おっぱいの下でオチンチンがどんどん固くなって\n、びくんびくんて、んふぁ、熱くなってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203115" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こういうのが気持ちいいのかぁ……男の人って変なのが好きなんだなぁ……\nそれとも、あなただから？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203116" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「とにかく、このオチンチンがＨなのがいけないんだ。えいっ、えいっ！　悪\nいオチンチンは懲らしめてあげなくっちゃね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203117" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「おっぱいをぎゅうぎゅうに押し付けて、悪者オチンチンを押しつぶしてあげ\nる、うりうり～、どうだどうだ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203118" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、びくびくしてる！　気持ちいいんだ？　えっへへ～。じゃあ、こういう\nのはどう？　オチンチンの裏側をおっぱいで、す～りす～り……", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203119" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「どう、気持ちいい……って、聞くまでもなさそうだね。ものすごくＨな顔し\nてるもん。んもう、満足そうにしちゃってぇ……んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203120" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、オチンチン固くてゴツゴツしてるから、あんっ、でっぱりにお\nっぱいが擦れて、んふっ、私もちょっと気持ちよくなっちゃう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203121" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、そうだ。それならこういうのはどうかな？　オチンチンをおっぱいで両\n側からむぎゅっ～て挟んじゃって……えいっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203122" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「おっぱいでむにゅむにゅ揉みながら、んしょ、んしょ、オチンチンを上下に\nずりずり、擦ってあげるね、ん、ふ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203123" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こういうのパイズリって言うんだよね？　ん、んんっ、前に雑誌で読んだこ\nとあるんだ～、気持ちいいでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203124" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いつもＨなことばっかり考えてる悪いオチンチンは、ん、ふぅ、ヒーローの\nおっぱいで成敗しちゃうんだから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203125" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んっふふ～、両方からおっぱいに押しつぶされて、オチンチンぴくぴくして\nるよ？　どうだ、参ったか～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203126" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、先っぽから透明なお汁が出てきたよ。これって気持ちいいと出るんだよ\nね？　オチンチンをむぎゅむぎゅすると、とろとろあふれてくるよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203127" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ヒーローおっぱいに攻められて、悪者オチンチンが泣いちゃってるんだねぇ\n～、ほらほら～、もっといっぱいシゴいちゃうぞぉ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203128" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「えいっ、えいっ、オチンチンをおっぱいにすっぽり包みこまれて、ずりずり\n～ってしごかれて、もうたまらなくなっちゃってるんでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203129" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「オチンチンの先っぽがパンパンにふくれあがってるよ……んっ、ふぅ……Ｈ\nなミルクをびゅーびゅーって、出したがってる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203130" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ほらほら、イッちゃえ～！　ヒーロおっぱいにオチンチンしごかれて、イヤ\nらしいザーメンミルクを射精しちゃえ～！　えいっ、えーーーいっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203131" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　わ、すごぉい、おっぱいの間で精液が出てる……びゅう、びゅ\nうって……すごい勢いだよぉ……それに、あんっ、熱い……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203132" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「濃くてドロドロしたザーメンが、おちんちんの先っぽからどぴゅどぴゅって\n……あぁん、どんどんあふれてきてるよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203133" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、あっ……オチンチンがびくびくするたんびに、割れ目からエッチなミル\nクがびゅくびゅくって、んあぁ、すごぉい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203134" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いいよ、おっぱいでオチンチンぎゅうぎゅうしごいて……んっ、あ、あっ…\n…最後の一滴まで出させてあげる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203135" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁ、またいっぱい……びゅるびゅる出てる……悪者オチンチンからイヤら\nしいミルクがどんどん出てくるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203136" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「わぁ、こんなに出したんだ……あぁ、すごぉい……おっぱいの間、あなたの\nＨなザーメンでドロドロになっちゃったよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203137" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「プルプルのゼリーみたいな精液がおっぱいの間にべっとりへばりついて……\nやぁん、ぜんぜん落ちないよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203138" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「それに匂いもすごい……青臭くてイヤらしい匂いがして……頭がくらくらし\nてくる……変な気分になっちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203139" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「熱々の精液をおっぱいの間にたくさん注ぎ込まれて……んあぁ……私の身体\nまで、なんだか熱くなってきちゃったみたい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203140" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「こんなにおっぱいに出されたら、匂いが染み付いてとれなくなっちゃいそう\n……ヒーローがこんなＨな匂いさせちゃダメなのにぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203201" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ……オチンチン、まだ固いままなんだね……もしかして、まだ出し足りな\nいの？　……んもう、オチンチンで返事をしないの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203202" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いっつもダメダメなのに、こういうところばっかり男らしくて、元気なんだ\nから……まぁそういうところも、わたしはキライじゃないんだけどね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203203" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ううん、なんでもないよ！　そんなに私のおっぱいが気持ちよかったの？　\nもう、しょうがないなぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203204" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いいよ。じゃあ、またシてあげる。もう出ない～ってなるくらい、徹底的に\nオチンチンを搾り取って、こらしめてあげるんだから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203205" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたの精液でヌルヌルになったおっぱいを押し付けて……んっ、オチンチ\nンをずりずり、擦ってあげるね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203206" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ん、あぁ……ぬちゅぬちゅって、イヤらしい音が鳴ってるね……んふぅ……\nさっきよりもすべりがよくなって、いっぱい擦れちゃう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203207" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あんっ、オチンチンの凸凹がおっぱいに擦れて……あふぅ、私まで気持ちよ\nくなってきちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203208" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「やんっ！　あっ、あっ……もう、勝手に腰を動かしちゃダメだよぉ……あん\nっ、固くなった亀頭でぐりぐり……んふぅっ、乳首をほじくらないでぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203209" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、そんなに乳首ばっかりいじられたら……あぁんっ、背筋がぞ\nくぞく震えてきちゃう、んふぁぁ、Ｈな声がでちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203210" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ガチガチに固くなった雁首がずりゅずりゅ、あんっ、あっ、あっ、乳首のと\nころを行ったり来たりして、ぷりぷり引っ掻いてるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203211" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……んもう、コレ以上はダ～メ！　そういう悪いオチンポはお仕置きだよ！\n　またおっぱいに挟んで、本気で気持ちよくしちゃうんだからっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203212" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ほらほら、精液でドロドロになったおっぱいで、オチンポをむぎゅ～って挟\nみ込んで、ぬちゃぬちゃシゴイてあげる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203213" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「むぎゅっておっぱいに包みこまれながら、その中をオチンポが出たり入った\nり……んっ、ふぅ……どう、気持ちいいでしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203214" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「精液でヌルヌルだから、んっ、んふぅ、さっきよりも強く挟んで、んんっ、\n激しくシゴいてあげるね……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203215" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ずちゅ、ずちゅって、おっぱいの中をオチンポが出たり入ったりして、んふ\nぅ、溜まった精液がぐちゅぐちゅかき回されて、泡立っちゃってるね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203216" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んふぁ、すごくＨな音……それに、匂いもまた濃くなって……あふぅ、イヤ\nらしい気分になってきちゃう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203217" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ガチガチの勃起オチンポがおっぱいの中をにゅこにゅこ、んぁ、ぁ、行った\nり来たりして、あんっ、たくさんの凸凹で、ずりずり擦られちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203218" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んふぅ、オチンポでおっぱいをずりずりされると、あぁんっ、背筋がぞくぞ\nくして、身体が熱くなってきちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203219" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたも、すごく気持ちよさそうな顔……あぁん、かわいくてキュンキュン\nてしちゃう……もっと気持ちよくしてあげたくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203220" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いいよ、またイッて……！　ヒーローおっぱいにオチンポずりゅずりゅシゴ\nかれて、Ｈでイヤらしいザーメン、いっぱい出してぇ……っ！！」", "NORMAL" ]},
