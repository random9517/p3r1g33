		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「どくんどくんって、エッチなお汁がどんどんあふれてきて……やぁんっ、お\nっぱいの間からこぼれてきちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203303" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「おっぱいでシゴいててあげるから、んっ、んふぁっ、オチンチンびくんびく\nんて、もっといっぱいザーメン出してぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203304" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あんっ、あんっ、またいっぱい出てきたぁ、どぷっ、どぷって、\nどんどん出してっ、タマタマが空っぽになるまで、射精してっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203305" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「私のおっぱいで気持ちよくなってぇ、んっ、んふぅっ、エッチなミルクを思\nいっきり出して、おっぱいの中を精液まみれにしてぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203306" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ふあぁぁ、すごぉい、おっぱいのところがザーメンでもっとベタベタになっ\nちゃったぁ……本当に肌に染み付いて、匂いが取れなくなっちゃうよぉ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001302_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203307" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
