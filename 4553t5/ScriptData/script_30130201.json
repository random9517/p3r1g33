		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203310" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「私のおっぱいにイヤらしいザーメンをたっぷりと中出ししてぇ……あなたの\n精液をどぴゅどぴゅ、いっぱい注ぎ込んでぇ……」", "NORMAL" ]},
