		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203308" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「んあぁ、オチンポまだまだ固くて、おっきいよぉ……もっと出したいの……\n？　んふふっ、いいよ……もっといっぱい、してあげるね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0203309" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
