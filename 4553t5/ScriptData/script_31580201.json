{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「来たよ、ご主人、何か用事？　……え、魔力の残量はどうかって？　うーん\n、さっきまで色々新しい魔法を試してたから、ちょっと減ってるかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――確かに魔力補充は必要だし、その為にはご主人の精液を体内に備え付け\nられた魔力生成機関に取り込むのが手っ取り早いシステムになってるけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……ご主人、その下半身のふくらみは何かな？　魔力補充なんて建前で、た\nだ単に私としたいだけだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まぁ、いいけどね――安心して、嫌じゃないよ。このパーツのお陰かな？　\n今の私はご主人に素直に甘えたいって思えるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに、ちょっと新しい知識も仕入れてね。折角だからご主人、ちょっと付\nき合ってよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015802_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんぅ……そう、そうやって後ろからご主人のおちんちんを私の股の間に挟\nんで……んっ……もう少し、おまんこに押し当てて、そう……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、素股って言うんだよね？　色々調べてたら気になっちゃって、一度ご\n主人としてみたいなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、大丈夫、効率は落ちるけど、肌に付いた精液からでも魔力補填は出\n来る様になってるから。魔力の減り具合的に、素股を試すチャンスかなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ……もう少しお尻を突きだした方がやりやすいかな……？　んふっ、\nんっ……ふふっ、ご主人のおちんちん、ぴくぴくしちゃってるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それで、どうかな？　私の太腿の感触は？　もう少し締め付けた方がいいと\nかあったら、遠慮なくいってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ほ、褒められるのは嬉しいけど、そこまでテンション上げられると恥ず\nかしいってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、実はこのパーツを選んだ時にね？　ご主人に喜んでもらえたらって\n、肌触りにまでこだわったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、こうして両側からぎゅっ、て挟み込んであげると……んんっ……ご主\n人のおちんちんが、どんどん私の太ももに埋もれて沈み込んでいく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふとももを擦り合わせる様にすりすり、ぐりぐり……どうかな、ご主人。ク\nララの太ももおまんこは、気に入ってもらえた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　ご、ご主人、そんないきなり腰を振り始めて、あっ、んんん\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、悦んでもらえたみたいで嬉しいよ。あっ、んんっ……いいよ、腰を\n振るのはご主人に任せるから、私の太ももおまんこを好きに使って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、んふぅんっ……！　これ、知識としては知ってたけど、ご主人\nのカリ首の所が、布越しに何度も割れ目を擦り上げてっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「勃起おちんちんがっ、あっ、んあぁんっ……！　私の太ももおまんこを、ぐ\nちゅぐちゅって、かき混ぜる様に犯してっ、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、気が付いた？　ご主人が好きそうなえっちな言葉も、いっぱい\n調べてきたんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「人間の男性は下品な言葉を囁くと興奮するんでしょ？　いいでしょ、私の太\nももおまんこ、ご主人のおちんちんビクビクしちゃうでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ！　ふふっ、ご主人って、やっぱり結構単純だよね。そー\nゆーところも大好き。んっ、んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「言ったじゃん、このウィッチパーツのお陰で今の私は素直なの。ご主人が大\n好きで、甘えたくて……いっぱい色んなえっちを試してほしいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　またおちんちんがビクンってして、ふあぁんっ！　いいよご\n主人、好きなように腰を振りまくっていいからね、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、おちんちんの先っぽから我慢汁だらだらだね。肌から染み込んで…\n…ああぁんっ、ご主人からもらう魔力、気持ち良いよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、私ももっと太ももをぎゅーって締め付けるから……んあぁんっ！　\nそう、その括れの部分でおまんこもっとぐりぐりして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　あっ、んふぅんっ！　皮を巻き込んで、おちんちんぐちゅぐ\nちゅってえっちな音しちゃってる、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「今の私の太ももおまんこは、ご主人専用のオナホールなんだ、んんっ！　な\nんか、そう思うと、全身のパーツが熱くなってっ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああっ、エラー来たっ、えっちなノイズが走って、んふぅんっ！　こ、これ\n、ご主人に愛されてる証みたいで、好きなのっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、こうして見下ろすと、まるで私の股間からおちんちんが生えてるみ\nたいだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぴくぴくしちゃって、本当にかわいい……ほーら、いい子いい子、おちんち\nんの先っぽなでなで……ふふっ、いい反応」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これも調べてきたよ。ここだよね、こうして亀頭の付け根の所を裏側から指\n先でぐりぐり、もう片手で亀頭を優しくなーでなで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！？　ご、ご主人、その角度すごいっ！　割れ目におちんちんの\n先っぽがぐりぐり食い込んでっ、ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――わ、分かってるよ、ご主人出そうなんだよね。おちんちんの血管が浮き\n上がって、先っぽもパクパクし始めちゃってるもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私もこのままノイズに身を任せるからっ、んんんっ！　ご主人、一緒にイこ\nう？　私にご主人の魔力をぶっかけて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　きた、ご主人の立派なおちんちんが激しくてっ、ふあぁんっ\n！　出して、私の太ももおまんこに中出ししてっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ……！　出てるっ、ご主人の熱い精子が、私の肌に触れてっ、\nんんふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ご主人の精液で、私の魔力が満たされていくよ。んんんっ……不思\n議な感覚……お腹の奥が満たされるような気がして……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……射精、終わっちゃったかな？　どうだった、私の太ももおまんこは\n……って、この精液の量を見れば、聞くまでもないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人ってば、とっても必死に腰を振ってくれてたもんね。――ふふっ、照\nれないでよ、私は嬉しかったんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あ、待ってご主人、まだ腰を引こうとしないで！　……調べたから知ってる\nよ、素股プレイはここからが本番、でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こうやって、太ももとおんちんちんに、さっき出した精液を塗り込んで、っ\nと……ふふっ、でーきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「精液で、ぐちょぐちょになった、クララの太ももおまんこはいかがかな、ご\n主人？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あはぁんっ！　こ、これ、すごい滑りだねっ、あぁんっ！　さ、さっきとは\n比べ物にならないほど、おちんちんがにゅるにゅる滑って、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに、まだまだこういうのもあるよ？　――ふふっ、どうしたのかな、そ\nんなに焦った声出しちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――そう、これは性欲増大の魔法。ウィッチパーツのお陰でこんなことも出\n来ちゃうんだ。折角だもん、使えるものは全部使わないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　そ、そうだよご主人、遠慮なんていらないんだから！　私はご\n主人の所有物、太ももおまんこを壊すつもりで腰を振っていいからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　そう、そこっ、もっとおまんこにも食い込むぐらいに\n来てっ、あっ、んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ま、またおちんちんの先っぽも撫でてあげる。ヌルヌルの精液をいっぱい指\nに絡めて、ぐちょぐちょって……んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふぅんっ……！？　あっ、ふあぁんっ……！？　ご、ご主人、ちょ、ちょ\nっと、その耳元で囁くの、やめてっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「嫌じゃない、嫌じゃないん、だけどっ、んふぅんっ……！　このパーツの耳\n、ちょっと敏感過ぎてっ、あっ、ああぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――へ、変な魔法をかけてくれたお返し？　わ、分かるよご主人、今絶対む\nかつくニヤニヤ顔してるでしょ！　あふぅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「い、いいよ、そっちがその気なら……えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、すごいでしょ？　太ももの内部を駆動させておちんちんに軽い振動\nを与えてるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私は貴方のロボット。魔法だけじゃない、機械の身体全てを使ってご主人を\n満足させてあげるんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んぁんんっ！　――うん、だから、一緒に、今度も一緒にいこうねご主人！\n　いっぱい気持ち良くしてあげるから、いっぱい気持ち良くしてね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　あひゃぁんっ！　来てる、またエラーとノイズが増え\nてっ、んふぅんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人、ここだよね！　亀頭の裏側を指先でぐりぐりしてっ、浮き上が\nった血管をツーってくすぐる様に撫でてっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「イキそうなの、分かるからっ……ご主人も、腰をいっぱい振って！　また敏\n感な耳も弄ってっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああ、やっぱり射精直前のビクビク震えるおちんちんかわいいなぁ……んあ\nぁん！　私の太ももおまんこで、いっぱいいっぱいシコシコして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んふぅんっ！　わ、私もイクからご主人も一緒に！　どこに出してく\nれてもいいからっ、ご主人の精液で私をドロドロに汚して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あんんんぅぅっ～～！　また太ももおまんこに、あついのきてっ……んあぁ\nぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んくぅぅんんっ～～！　わ、私もイッてる、ご主人の精液で太ももお\nまんこドロドロにしてっ、あっ、んふぅぅんんっ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もっともっと、締め付けるからっ……好きなだけ出してっ！　全部出し切る\nまで私を使ってね、ご主人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　ふふっ、やっぱりこうして見下ろすと、私が射精してる様にも\n見えるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ビクンビクンって何度も跳ねて、必死に精液を吐き出してる……ご主人のお\nちんちん、かわいいなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……そろそろ終わりかな？　ふふっ、見てよご主人、私の下半身、ご主人の\n精液で大変なことになっちゃってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、何で謝ってるのさご主人。魔力補填を持ち掛けてきたのはそっちだ\nけど、素股がいいってお願いしたのは私だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……実はね、まだまだ試してみたいえっちがたくさんあるんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「何度も言ってるじゃん、ウィッチパーツのお陰で今の私は素直にご主人に甘\nえられるんだ。素直で従順な、貴方だけの魔女」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だから……ね？　これからも私の知らないえっちな知識を、たくさん教えて\nくれたら嬉しいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んはぁんんっ～～！！　す、すごい勢いっ、ご主人の精液が、おっぱいにま\nで飛んできてっ……んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「全身が熱いっ……ご、ご主人の精液が触れたところから、どんどん魔力が染\nみ込んできてっ……あっ、ふあぁぁんんっ～～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「すごいっ、すごいよご主人っ！　あっ、あぁんっ！　まだまだ出して、私の\n全身をドロドロにする勢いで、もっとっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んぁんんっ……！　ご主人好き、大好きっ……！　素直に大\n好きって言えるのが嬉しいよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……流石にもう打ち止め、かな？　ふふっ、ご主人見てよ私の身体、顔\nにまで届きそうな勢いの射精だったよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私の太ももおまんこはどうだった？　素股えっち、存分に楽しんんでもらえ\nた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――うん、私もとっても気持ち良かったよ。魔力補填も完璧、全身に魔力が\n漲るみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……ねぇ、ご主人、次の魔力補填の時はどんなえっちをしよっか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「言ったでしょ、折角の機会だもん。このパーツでしかできないことを、ご主\n人と楽しみたいなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私は貴方だけの魔女。お望みとあらば、どんなえっちな魔法でもマスターし\nといてあげる……なーんてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}