{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「コンテスト会場はこの先みたいねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540018" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「賞品ってどんなのが貰えるんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540019" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「賞品を貰うためには、優勝するか最優秀賞を取らないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540022" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そんなの、ボクたちが力を合わせれば楽勝だよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540020" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「とは言え、これは紅組と白組に分かれて戦うチーム戦……。あたしたちが全\n員一緒のチームになるとは限らないっぽいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540019" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「例えバラバラになっても、恨みっこなしですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540023" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや。若苗三姉妹の序殿、破殿、急殿ではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あっ、いつもカツマさんと一緒に居る犬……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540021" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「犬じゃなくて、ジュンジローさんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540024" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほほほほほ。名前を憶えていただけているとは、大変光栄ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「どうしてジュンジローさんがここに居るの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540022" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ、それはですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて、着替えも終わったし、みんなのところに戻って遊ぶとするか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、ご主人。丁度いいところに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　どうした……って、序に破。それに急じゃないか。こんなとこでなに\nしてんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、カツマさん。こんにちはです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540025" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「こんなところで会うなんて奇遇ですねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540020" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、俺は商店街の福引で特賞が当たってな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「偶然だね～。実はボクたちも特賞が当たって、ここに遊びに来たんだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540023" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たちも？　っていうか、特賞ってこんなにぽんぽん当たるもんなのか…\n…？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「日頃の行いがいいからかもしれませんねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540021" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それにしても、お三方だけで旅行とは中々大胆なことをしますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「本当はお母さんたちも来る予定だったんだけど……仕事でこれなくなっちゃ\nって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540024" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「旅行券の期日もあるし、もったいないから私たちだけで来たんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540026" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だったら俺たちと合流するか？　色々あって、幹部連中もここに居るからさ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「それは嬉しいですけど……いいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540022" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいもなにも、俺一人じゃ面倒な事になりそうだからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こんないたいけな少女たちを皆様の生贄に差し出すとは……さすがはご主人\n。悪党の鏡ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人聞きの悪い言い方をするんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えっ……私たち、どこかに売られたりするですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540027" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなことするわけねぇだろ！　いいから、早く来てくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「それから私たちは、インクレディブル・スクワッドやニンジャラビッツの\n皆さんと合流して、コンテストに出ることになりましたです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540028" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}