{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0168" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "炎に包まれたまま消えていくデッドシャーク。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "呼び出されたサメたちは統率する者がいなくなったからか、散り散りに逃げ\nていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ようやく終わった……のか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まあ、あれを食らえばいくらサメとはいえタダじゃすまないでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「あんだけ痛い目見れば、もうアタイの縄張りを荒らすこともないだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも、犠牲がでちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうだ。スーザンはサメに呑みこまれたままだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「あのでっかいサメだよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スーザンを飲みこんだサメが逃げようとしたところで、マリッサが回り込む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「てめぇ……こっから無事に逃げられると思ってんのかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113810003" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "睨みをきかすマリッサにたじろぐサメ。次の瞬間、ビクンビクンと悶え始めた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113810004" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "「ええい……ふざけやがって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113810001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ずんっ！　とサメの腹からチェーンソーが生えた！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ええぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こ、これはいったいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁーっ、はぁーっ！　こんなところで、私が死ぬわけないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「い、生きていたのね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、なんで生きてるんだよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "fALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「どうだ！　腹の中でチェーンソーを思いっきりぶん回してやった！　回転数\n１．２１ジゴワットだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113810003" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "サメの腹をかっさばいて、血まみれのスーザンが無事に生還した。なんで無事\nなのかはまるでわからん。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんなんだよその単位は！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えっと、その単位はかの有名な映画に出てきたもので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「このサメ……食べられないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「時空の穴から出てきたサメだろ？　なに食って生活してるのかわかったもん\nじゃないぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113810005" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うーん、それもそっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お前ら、サメにひどい目に合わされたのによく食べようって気になるな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやぁ、無事全員が生還できてよかったですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「えっと、ありがとうございました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_070113810001" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ダイヤナちゃんが本気を出せばこれくらい朝飯前なんだからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その本気を普段から出して欲しいものだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、なにか言った～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いーえ、なーんでも。ところで、そろそろ俺のことを降ろしてくれないか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ずっと柱に括りつけられたままなのだが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「結局一晩中、サメと追いかけっこしてたんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「大きな戦いのあとに浴びる朝日は最高だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113810004" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113810004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああ、まったくだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113810006" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お前ら聞いてるか？　俺のことを降ろして！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、いつも通りですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ちくしょう！　またこういうオチか！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……まあ、今回はこんなものですかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113810003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}