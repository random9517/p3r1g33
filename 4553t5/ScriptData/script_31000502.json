{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ハハッ♪　やっと二人きりになれたな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まったく……クリスマスだからといって、おまえに群がる女達の数、数、数\n……！　忌々しい。どうせ奴らの目的も私と同じだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、おまえに開発された肉体の解放……。つまりは子作りセックス\n、生本番交尾の希望……。今更嫌とは言わせんぞ？　……それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「誰よりも早く、おまえを食らい尽くすのは私だ。光栄だろう？　最高の女と\n寝られるんだから、さっさと感動して下半身から歓喜の涙を流すがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「クフ……♪　フフフフ……♪　いつまたがっても、飽きることのない良い身\n体だ。最近ますます美味しそうになった。私は目の前に餌をぶら下げられ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504105" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これでも随分と我慢してやったんだぞ。すぐさま、おまえの喉元に食らいつ\nき、隆起したペニスを咥えこんで腰を振りたかったところを……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……あっ♪　夜ごとに一人で慰め、て……♪　このペニスを想像し、感度を\n高めに高めていたんだ。ゆえに、もう……限界というやつだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「挿入させてもらうとしよう……♪　ふぅ、ふぅ、ふぅ……♪　なんというペ\nニスの照り、そしてこの硬度。入れる前からアソコが喜んでしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あッ……♪　焦らず、に……。じっくりとペニスに膣口をこすりつけてマー\nキング、して……♪　はぁっ、ぁっ……あっ……ぁっ、あ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえのモノの形……。くぅっ……♪　重さ、規格外の大きさをしっかり粘\n膜に記憶させてから……一気に腹の中にいただくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふ、くぅうううう……っ♪　チンポぉおお……！　このチンポ、いいぞ……\nいいぞ！　私が求め、狩った最高のペニス……深く突き刺さってくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んにゃぁああ……！　狩猟本能でゾクゾクしてしまう……！　んっ……ふぅ\nう♪　下腹が膨らむほどに肥大した、巨大なペニス……美味すぎる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「欲情した身体に、膣内に……火照った子宮に突き刺さる太い牡器官！　くふ\nぅうう♪　これだ、これ！　これが欲しかったのだぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あぁ、あぁ、はぁ、はぁ、はぁあっ……ああ♪　モジモジと腰\nが勝手に動き出す……おまえのチンポを味わいたくて本能が疼く♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえは本当に、下半身だけは最高だな……っ！　ああ、動くんじゃない。\n私は私のやりたいようにヤる……。お前はただの生贄だ……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「たっぷり気持ち良くしてやるから、おまえは横に寝っ転がっていろ……。あ\nっ……♪　くぅう♪　痺れる……この摩擦、極上すぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ほら、よーく見ていろ……？　私がおまえのペニスをぐっぷり咥えこみ\n、卑猥な動きでピストンするのを……。はぁ♪　あっ、ぁっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「胸を揺らし……。っく……♪　おまえの情欲をかきたてて、ただでさえ硬い\nペニスを……限界以上にはりつめさせ、て、使い倒す……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ウィンウィンの関係だろう……？　ハハハッ……！　ああ、そうか……自由\nに腰を振れなくて辛いか？　苦しいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それは知らん。だが、そうだな……。せっかくおまえの生意気な乳首が目の\n前にあるのだ。それを、特別にいじめてやってもいい。……わかるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「キュウキュウとペニスに絡んで、締めつけてくる肉厚なオマンコ……。そし\nて、ニンジャの超絶技巧でおまえの乳首を愛撫する私の手……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これが、ダークニンジャの……。ダークサンタ・マスターの房中術だ。二つ\nの性的な刺激に、悶え、喘ぎ、翻弄されろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　はぁっ、はぁ、はぁあ……♪　男のくせに、いやらしい乳首\nをしているじゃないか……。ずっと摘まんでほしかったのだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「親指と人差し指で……つまんで、押し潰して……クニクニクニ……♪　くり\nくりくり、クニクニ……。フフッ、嗜虐心をそそるその表情……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なんだ？　女の子になって私に責められたい願望でもあったか？　変態だな\n……。男でここまで感度のいい乳首をもっていると、大変だろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504125" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ピンと勃起して、私の指先に甘えてくるぞ……。おお、よしよしよし。こう\nか？　こうして優しく撫でまわすのがいいのか？　それとも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ギュウッ、とこうやって引っ張るのがいいか？　どっちだ？　……あっ♪　\nま、またチンポが返事をしたぞ……。なるほど……。はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「乳首をもてあそび、いじることでおまえのチンポが喜ぶなら、私にとっても\n一挙両得……。今日はこのまま、おまえのチンポをアソコでねぶる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……んッ……♪　あぁ……！　ああっ……ああ……！　太いチンポでオマン\nコを蹂躙させ、思う存分デカい亀頭で粘膜を刺激する……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あッ♪　はぁっ、はぁ、こ、これはキクぅ……！　キくっ……！　子宮から\n脳天に太い快楽がのぼってきて……ああっ、いいぞ、いいぞ……イイっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この私を、ダークサンタマスターを夢中にする悪いチンポは粛正するぅう…\n…♪　あぁ……！　こうか、こうかっ、こうしてほしいのかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……んぁああッ……♪　そうか、そうか……！　オマンコにしゃぶりつくさ\nれるのが好きなのだな……！　このマゾチンポ、ドＭチンポ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のドＳオマンコに服従しろっ……！　あっ♪　あっ♪　私の好きなところ\nを、都合のいいところを掻き回せ……。ああっ、そうだ、そこだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「奥のっ……し、子宮の入り口をえぐれっ……！　ンふぅうっ……♪　あぁ、\n上手いじゃないか……！　そのまま……そのまま、……あぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の膣内のヒダヒダを、蠢く肉壁を感じ取れ♪　んん……そうだろう？　す\nぐにも射精したくなってきただろう？　この中に汁を撒き散らしたいよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「その願い、叶えてやる……。遠慮するな、今日の私はダークサンタ……！　\nあっ♪　おまえの精子を搾りにきたんだ……出せ……！　イけっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アハハハッ……♪　アハ、ハハハハッ♪　出た出た……！　搾り取ってやっ\nたぞ！　どうだ？　女に主導権を完全に握られてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「大事な精子を根こそぎ搾り上げられた気分はぁ！　あははっ、ドプドプと腹\nの中で音が聞こえるぞ、んん？　いいのか？　ここに出しきって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「他の女達が、おまえに抱かれたくて仕方ないであろう今日に！　私との愛の\nないセックスで子種を全て吐き出していいのか？　あはは、もう遅いか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のヌルヌルオマンコに♪　っふ……♪　ビュクビュク情けなく種付けさせ\nられて……ああっ♪　熱い精液を吸い上げられ、て……♪　はあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「貪り尽くされるのがおまえにはお似合いのクリスマスだ……。ああっ……、\nあぁ……あぁ、ああ……！　おい、もう射精は終わりか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「足り、ない……！　こんな量では足りない……！　私の子宮はまだまだおま\nえの白濁を飲み干したがっている……！　ほら出せ、もっと出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「身体の水分が枯れ果てるまで射精しろっ……！　んん！？　休憩？　誰がさ\nせるかっ……！　おまえがこれくらいで終わらないことはわかっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「キツぅくオマンコで締めつけて……、出したばかりの過敏なペニスをシゴき\nたててやる、から♪　早く復活させろ……。遅いぞ、待ちきれん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「早く♪　早く、早く、最初の硬さに戻せ……！　……ん……？　おっ？　あ\nあ、そうだ……！　おまえはペニスしか取り柄がないのだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「素直にペニ、スを差し出して、私を……私の膣内粘膜を満足させろっ……！\n　はぁ、はぁ、はぁ……はぁあ♪　おぉッ？　こ、これは……いいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「中出しされた精液、が……。はぁっ♪　ヌチョヌチョとオマンコに塗り広げ\nられ……。ヒダヒダがほぐされる、おまえの種の色になる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁ、あぁ、動きやすくなって一石二鳥でもある……！　これは…\n…たまらんな、はぁっ♪　ますます腰を振りやすくなった……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……んん？　嫌そうな反応をしているくせに、ペニスが復活してきたぞ？　\nおまえはマゾというやつなのか？　身体と心は別々ということか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010005_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「フフフ、ハハハ……♪　いいぞ、いいぞぉ……♪　あっ♪　抗いようもなく\n、私のオマンコの中が気持ちいいのだな？　なんと可愛いやつだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そら……また乳首を攻めてやる、から存分に感じろ……♪　ンンっ……！　\nだが、次は多少もたせろ、すぐにイクな……私を楽しませろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あ～～～～♪　これはキく……！　あっ、あっ！　単純に腰を上\n下前後させる、だけで……無限に快楽が生み出されていく……ぅ♪」", "NORMAL" ]},
