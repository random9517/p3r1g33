{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「すみませんっ、わ、私……何だかボーっとしちゃったみたいで……ご迷惑を\nお掛けしちゃいました……よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920001" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、全然気にしなくていい。あれは顧問がアレ過ぎただけだ。大事になら\nなくてよかった。いやマジでな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あはは……あんまりよく覚えていないんですけど……私、ギターのセンスは\nなかったみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920002" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「センスはともかく……軽音部はやめといた方がいいかもな。おっ、ここは…\n…？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "生徒Ａ" ]},
		{"command":[ "SETTEXT", "「ワンツー、ワンツー、ゴーゴー、レッツゴー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "生徒Ｂ" ]},
		{"command":[ "SETTEXT", "「フレーフレー！　大戸岐！　ファイトー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "元気のいい声を上げながら、キレのいいダンス練習が行われている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おー、やっぱチアガールってのは華やかだな……って、真ん中にいるのは…\n…」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ヘイヘイヘーイ！　もっとキレーに足あげるっ♪　ちゃんと出来ないヤツは\n、やり直しだからっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920001" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "生徒Ｃ" ]},
		{"command":[ "SETTEXT", "「は、はいっ！　ワンツー、ワンツー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「まーまーいー感じにできてるしっ♪　我のやり方っ……よーく真似するコト\nっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920002" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "生徒Ａ" ]},
		{"command":[ "SETTEXT", "「はい、コーチ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今度はファンタズマかよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「学園長の人脈も大概偏っておりますなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "中心でダンス指導していたのは、何故か次元旅団のファンタズマだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "相変わらず偉そうな態度全開だが、その動きはキレがよく、生徒達もしっかり\nと従っているようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そいじゃ、てきとーに休憩ね♪　んー？　あららー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920003" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダンスが一段落したところで、ファンタズマの方が俺たちに気がついた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　誰かと思えば、モブざぁこのカツマじゃないの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920004" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「相変わらず失礼な奴だな。お前も臨時顧問してるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「とーぜん♪　このガッコのボスに、どーしてもって頼まれたから、仕方なく\nやってんの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その割には、めちゃくちゃノリノリだったよな……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「それでー？　パッとしないモブちゃんが何しに来たワケ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920006" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺が用事がある訳じゃない。この子にちょっと見学させて貰えないか\nなって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ、あの……よろしく……お願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920004" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ほーん？　なかなかい～カラダしてるじゃないの♪　じゃあ、ちょっと踊っ\nてみよっか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920007" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「えっ、い、いきなりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920005" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「思いついたらすぐやるのがベストだし♪　ほれ、さっさとしなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920008" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、えとっ、は、はいっ……えっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920006" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あっという間にうららはグループの中に放り込まれていった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「最初だから我がすぐ隣でサポートしてあげるし♪　だから、言う通りにしと\nこっか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920009" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は、はい……あの、でも……私、スカートで……そのあまり大きな動きは…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920007" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「細かいことはどーでもいいし♪　パンツもスコートも大して変わりゃしない\nから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920010" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「さ、さすがに、それが一緒ってことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920008" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「大丈夫♪　そんだけいいパイオツしてたら、目が行くのはそっち側♪　チョ\nロ男子の視線も独り占めできるし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920011" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ひ、独り占めなんて……そ、そんなの……は、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920009" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっひひー♪　とにかくカラダ動かしたら気になんなくなるし♪　じゃ、ミ\nュージックスタート♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920012" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "有無を言わせないまま、また音楽が始まり、うららは流されるまま動きを合わ\nせようとする。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ピッタリ合わなくていいから、しっかり追いかけなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920013" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、は、はいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920010" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はーい、ワンツー、ワンツー♪　くるっと回って、ぴょーんって跳ねる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920014" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「くるっと……回って……ぴょんって……跳ねるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920011" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おー、はじめてにしちゃ悪くないし♪　つづけてジャーンプ♪　ぴょん、ぴ\nょん、ぴょーん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920015" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ぴょんっ、ぴょんっ、ぴょー……きゃあっ！　スカートがっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920012" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「なーに動き止めてんの～？　こーだし、ぴょーんっと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920016" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あのっ、でもっ……これ、めくれちゃいますっ……そ、それに胸も……あっ\n、窮屈で……は、はち切れそうで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920013" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなの気にしてたらチアなんてやってらんないしっ♪　ほれほれ、飛べ♪\n　飛べ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920017" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あうっ、はうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920014" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "飛び上がる度に胸がゆさゆさと揺れ動き、スカートも捲れて、うららは恥ずか\nしさにうずくまる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「どした、どしたー♪　こうやって飛ぶの、ほれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920018" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は、はひぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920015" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ファンタズマのやつ、うららが恥ずかしがるのを分かってて、ニヤニヤしなが\nらジャンプ連発させてやがる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "全くけしからん……止めてやらなきゃならん……の、だが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ほら、あのザコ警備員の顔見てみ♪　めっちゃガン見してるでしょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920019" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「えっ……警備員さん……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920016" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あのドスケベ視線♪　マジで分かりやすいなんてレベルじゃないし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920020" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いやっ、違うぞっ！？　別に、俺はそんなやましい気持ちはっ……全然\n見てなんか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「見てないなんてマジ嘘だし♪　ほれ、せっかくだからもっとサービスしたり\nして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ひゃあんっ！　だ、だめですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920017" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっふふー、可愛い反応しちゃって♪　ウチの部活に来たら、もっと可愛が\nってあげるから♪　うりうり♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010022920022" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁんっ、だめっ……ですぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010022920018" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本来ならば止めなくてはならないのだろうが、うららの口からこぼれる悩まし\nい喘ぎに、俺は目を奪われてしまっていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}