		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オチンチンも一緒にイッてください……！　また、精液ぃ……どぴゅどぴゅ\nって……だしてぇ……！」", "NORMAL" ]},
