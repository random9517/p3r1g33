		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ここは……懐かしいですね。あなたにとっては最近かもしれませんが、わた\nしにとってはもう何年も前のことなんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903101" ]},
