		{"command":[ "SETTEXT", "「んぁああっ！　あっ、ああぁあああぁぁああぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でてる……また、でて……でて……ああぁ……っ！　ドロドロの精液ぃ……\nおっぱいマンコに中出しぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いいっ、イッてるっ！　おっぱいで……イッてしまってます……！　あっ、\nああ……っ！　んっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……まだでてる……。オチンチンがおっぱいの間で暴れまわっ\nて……射精してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どんどん……谷間が……精液で満たされていく……。アツアツの精液ぃ……\nんふぅ……はぁ……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ど……どうでした……？　わたしのパイズリ……。あなたのこと、気持ちよ\nくできたでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「精液の量を見て判断しろ、ですか……。こんなにたくさん……それって、気\n持ちよかったということでいいんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうやらあなたも気持ちよくなっていただけたようですね。とても\n嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ええ……あなたが望むのなら、また明日にでも、こうやってご奉仕させてい\nただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こうしてあなたといられる時間……。わたしは一人の女の子に戻れるような\n気がしますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ああっ！　いっぱい……精液ぃっ！　はぁっ、ああぁああ\nぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「すごい……ネバネバの精液が……飛び出して……んっ、いっぱいかかって…\n…ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だめぇ……肌がドロドロに覆われて……イク……！　イッちゃう……あっ、\nああ……また、イッちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ！　口にも入ってしまいました……んっ、そうですね…\n…この味……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「懐かしい……あなたの精液の味……んっ、はぁ……とっても美味しいです…\n…んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どうですか？　あなたも懐かしいと思いませんか？　このわたしの精液まみ\nれの顔……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたにたくさん精液をかけられたこと……。わたしにとっては、懐かしい\n思い出です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ですがこうして再会しましたから、またあなたの精液でドロドロにしてもら\nえるようになりますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたのねっとりとした精液の感触……わたしの肌に染みついてしまってい\nるんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふふ……これからもご奉仕させてください。離れていた時間の埋め合わせを\n、これからさせていただきますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903410" ]},
