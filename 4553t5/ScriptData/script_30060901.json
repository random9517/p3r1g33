		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オチンチン……感じて……だめぇ……っ！　ご奉仕しているに……わたしま\nでイキそうになってます……んっ、ああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……イキます……おっぱいマンコ、イッちゃいます……！　あっ、ああ\nっ、あなたも……一緒にぃ……！」", "NORMAL" ]},
