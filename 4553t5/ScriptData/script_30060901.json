		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あのときはあなたに言われるままに奉仕しましたが、今日はわたしの方から\n、あなたにご奉仕させてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「なにをするか、ですか……。そうですね、せっかくこうやって再会したんで\nすから、あなたが最初にやらせたこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「パイズリ……なんていかがでしょうか？　あなたは好きだって言ってくれま\nしたね、わたしのこのおおきなおっぱい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「楽にしてくださいね。はぁ……そうです、このオチンチン……。おっぱいが\n火傷しそうなくらい熱いの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000609_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そしてとっても硬く……いきり勃って……。すんすん……匂いも……あのと\nきの記憶がよみがえってきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「おっぱい動かしますね……んふっ、いっぱい気持ちよくなってください……\nはぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ガッチガチの勃起オチンチン……んふぅ……わたしのおっぱいで……たっぷ\nりしごいてあげますから……ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ん……はぁ……。相変わらず暴れん坊のオチンチンですね……ンッ、おっぱ\nいの間で、ビクビクして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「気持ちいい……ですか……？　はぁ、はぁ、上手にパイズリ……できている\nでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「おっぱいで……オチンチンをぎゅっぎゅっとして……。ごしごし……って、\nしごいて……んっ、はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どんどん大きくなっていくあなたのオチンチン……感じる……。はぁ……は\nぁ……んぁ……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そ……そうですね……。ンッ、おっぱいの感度は……前よりも上がってしま\nっている……かもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「大きさも……昔より、大きくなりました……んっ、なんでかって……その…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「理由をいうのは恥ずかしいのですが……ンッ、あうぅ……その顔……わたし\nに言わせようとしていますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「は……白状します……。元の次元に帰ってからも……あなたのオチンチンが\n忘れられなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だから……毎晩のようにオナニーをしてしまって……あなたのオチンチンに\n奉仕する妄想で……何度も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そうしているうちに、おっぱいは大きくなるし……感度も上がってしまって\n……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「今もこうして……あなたの、本物のオチンチンに……妄想ではなく現実に奉\n仕出来ていると思うと……たまらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんっ！　わ、わたしの恥ずかしい告白で……さらにオチンチンが大きくな\nっちゃいましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい……わかっています……。はぁ……はぁ……。このオチンチンに……ご\n奉仕しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「やわらかいおっぱいで……オチンチンを包み込んで……。いっぱい……気持\nちよくします……んぅ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オチンチンに……おっぱいこすれて……ンッ、ああ……わたしも感じてしま\nいます……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁ……そうです……おっぱいマンコです……！　あなたに処女を捧げた\nおっぱいマンコ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いっぱい感じてください……わたしのいやらしいおっぱいで……たくさん気\n持ちよくなってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　ああっ、ああ……っ！　オチンチン……先っぽがパンパンに膨\nれてますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「先走りが……ンッ、ヌルヌルになって……おっぱいマンコが濡れて……いや\nらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「射精してしまいそうですか……？　あんっ、そうですよね……もうこんなに\nオチンチンが震えてますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あのときのように……ネバネバで、ドロドロの精液を……たくさん射精しち\nゃってください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁ……んっ、ああっ、わたしのおっぱいマンコは、準備できているので\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いつでもあなたに……精液、だされてもいいので……！　んっ、はぁっ、あ\nあ……っ！　もう……イキそう……ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ど、どうぞっ！　お手伝いします！　おっぱいをもっと激しくうごかして、\nオチンチンしごいて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンが、気持ちよく射精できるように、んっ、根元から……\n搾るようにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああっ、だして……精液っ、だ、だして……だしてください\n……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　んっ、はぁっ、あはぁああぁぁっ！　で……でてる……精液ぃ\n……ああんっ、おっぱいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……すっごく熱い……。んふぅ……はぁ、はぁ……それに……この青臭\nい匂いも……ああ……久しぶり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふふ……前より……たくさん射精させることができたでしょうか……？　わ\nたしのご奉仕は……いかがでしたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……悦んでもらえてうれしいです……！　今日まで、いろいろ知識をつ\nけてきてよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「知識だけあっても、その通りにできなかったらどうしようって、心のどこか\nでずっと不安だったんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でも、あなたは……いつもわたしの不安を消し飛ばしてくれる……。前から\n、そうでしたもんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんっ！　まだまだおっぱいの間で、オチンチンが硬いままですね……。ふ\nふっ、相変わらず、とってもエッチ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい。お任せください。あなたのオチンチンが満足するまで、おっぱいでご\n奉仕いたしますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、あんっ！　さっき射精された精液が……ヌルヌルして……ン\nッ、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000609_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「精液をローション代わりにして……もっと、おっぱい……密着させて……ん\nふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オチンチン……すごく感じます……！　ああっ、もっとおっぱいの圧力を高\nめて……挟んでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、動かして……あっ、んくっ、いやらしい音が……あんっ、精液が泡立\nって……ぐちゅぐちゅって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はあんっ、ああっ、もっともっと……いっぱい感じて……！　わたしのおっ\nぱいマンコ……味わってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、ああっ、はぁんっ！　精液でベトベトになったおっぱい……\nあんっ、擦れて……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「まだこんなに硬い……ガチガチの……あなたのオチンチン……！　あっ、あ\nはぁ……気持ちいいの……感じるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、そんな……。いやらしい顔になっているだなんて……言わない\nで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だって……本当にうれしいんだもの……。あんっ、こうしてあなたに再会し\nて……ご奉仕できるのが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だから……興奮して……いやらしい顔になって……。おっぱい……自分でこ\nね回しながら……ご奉仕しちゃうんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……またオチンチンがビクビクしてきましたね……。先っぽも\nパクパクしてきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「まだまだ残っている精液を……また……わたしに向かって放ってください…\n…お願いします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、もっと激しく？　わかりました……ラストスパート、おっ\nぱいマンコでお手伝いしますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0903215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、あっ、ああっ、こうですか？　おっぱい……こうやって上\n下に……ぐにぐにって……あはぁんっ！」", "NORMAL" ]},
