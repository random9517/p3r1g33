		{"command":[ "PLAYVOICE", "v2_156_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「この体勢っ……体位っ！　精液がオマンコの中をかけのぼってき、て……刺\n激が強すぎるぅうう♪　アッ♪　あっあっあぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「だ……駄目だ、頭がクラクラして……！　あっ♪　あっあっ♪　隊長っ……\n私の身体、支えていてくれ……！　胸を強く握って、掴んで……あーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
