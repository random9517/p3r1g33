		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ……。こ……これでいいのか……？　うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あ、あっ！　お、起こしてしまったか……？　すまない……。このところ、\nどうにも夜になると……身体の疼きが止まらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「しかし、そんなことをおまえに相談するのも恥ずかしいし、申し訳がないか\nら……。その、なんだ。寝ている間に少しだけ身体を貸してもらえないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「……ん？　夜這い……？　あっ！　こ、こっちの世界ではこれを夜這いと言\nうのか！？　……いや、待て、私は抱いてもらおうなんて思っていなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あくまでほんの少し、おまえの身体を使わせてもらえたらと……。……う…\n…。そ、そうかもしれない。これは夜這い……だったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　うぁっ、あっ、ああっ！？　な、なんだ！　いきなり私を脱が\nして！　う……後ろから抱きしめるだと！？　わ、あ、あ、あ、あああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「そ……そうか。おまえも私としたいと思ってくれていたのか。それなら……\nうん。悪くない。二人で互いに欲求を解消し合おう。うん、そうしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「フフ……っ。私が今夜来るのが前もってわかっていたかのようにギンギンじ\nゃないか……。おまえも性欲をもてあましていたのか？　……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「これは疲れマラ？　へぇ……そうなのか。また１つ、おまえには教えられて\nしまったな。おまえはいつも賢くて、知識が豊富だ……。尊敬しているよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「セックスも上手いし……。っ、あ、な、なんでもない。今の言葉は忘れてく\nれっ！　え……えっと。まずは胸を揉んで欲しい。ああ、強く……そうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「揉み回すようにして……。んっ……ふぅっ、ふぅ……！　や、やっぱりまた\n上手くなっている……！　あ、愛撫が……前戯が細やかで……はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404111" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「肌という肌がざわめいて、おまえの指を……手を求めているのが感じられる\n……。それに……背中におまえの鼓動がつたわってきて、心地……いい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえの視線がわからないから、次にどこをどう触られるか想像して……濡\nれてしまう。あっ……んん……たくさん触ってくれ……待ちきれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「っふっ……んっ……。そ、そこ……うう……♪　へそや、腰や……脚ぃ……\n太ももも撫でてくれ。優しく……いやらしく……。……あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「それから……アソコも、くちゅくちゅかきまわしながら……。胸をいじりま\nわしてほしい……。んっ……あっ……うまいっ……あっ♪　そのまま……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「わ……私の感度が上昇し続けているのがわかるだろう？　アソコも大洪水に\nなってきて……愛液が次々に滴りおちていく……。も、もういいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえの愛撫と前戯は最高だった。だから……だから、後は本番を頼む。し\n、したいんだ。ずっと一日中したかった……セックス。セックス……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえに、おまえのたくましいオチンポを入れてほしい……♪　はぁ、はぁ\n、私のオマンコは切なくて、も、もう、さっきから大変なんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「だから……。この野太いチンポを、一気にずぶぅううううって突き刺して欲\nしいっ……。そら、腰を浮かせて……私から挿入するぞ？　い、いいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「入れ……るぅ、オチンポ入れるぅ……♪　挿入っ……挿入するっ♪　んふぁ\nあ……♪　これっ、素股でヌルヌルするだけでもすさまじい威力だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ……こんなにスゴいのが、今から……オマンコに入る、挿入されるぅ…\n…！　入る、入って……♪　ッあああああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「は……ぁっ♪　ああああっ……ああっ♪　いきなりッ……いきなり深くキタ\nぁ……！　奥にっ、奥に突き刺さって……！　ああぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404122" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「そう、だったのか……！　あっ♪　おまえも……私の中に、オマンコの中に\nチンポを入れたくて昂ってくれていたんだな……！　い、いいぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃに動かしてくれっ……はぁああっ……♪　あぁっ、す、すごい\n……！　下から、ガンガンチンポで突き上げられ、て、……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404124" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「尻も胸もっ……いいや全身がチンポに押し上げられて、揺れてっ……も、も\nう身体の中がチンポでいっぱいだっ……チンポ、チンポ……ひゅごいぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「チンポに身体を支えられてっ……貫かれて、グチョグチョにされて……！　\nもっ……♪　こんな、こんな快感……すごすぎる……強すぎる……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ……んぅううう～～～♪　ま、待て……待て待て♪　わ、私も協力、す\nる……っ。おまえだけに動かしてもらうのは、申し訳ない……いくぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ……♪　こうやってっ……こうやって腰を回して……あぁっ♪　オマン\nコ、マンコ締めながら……ひねって、出来るだけチンポに絡み付けて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404128" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「はふぅううっ……♪　ううううう～～～♪　ゾクゾクするっ、これっ……チ\nンポが気持ちいいところに当たって……動けば動くほどっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「天井無しでどんっどん快感が大きく深くなって、くぅううう……！　あぁっ\n、あぁ、お、おまえの、おまえのモノもすごく太くて……んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私、たち……ッ。身体の相性がいいのかもしれない、なっ……。だって、だ\nって……オマンコとオチンポ両方がこんなに悦んで、る……すごいぞぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「少しも離れたくないって、ぴったりくっついて……！　絡んで、交わって…\n…！　あああっ、たまらない、もっと、もっともっと続けてくれ……ぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んふっ！？　な……なんだ？　今、腹の中がノックされて……！　あっ♪　\nこ、これは……おまえのチンポが跳ねた、のか……脈打って……あぁうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ッ……こ、これ以上チンポがデカく、硬くなったら……腹が破裂してしまう\nっ……♪　い、一度っ、一度精子を出して小さくしてくれっ……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「い……いいか、ら♪　私の中に出していいから……！　あっ！　あっ、この\nまま……このまま射精を……！　３、２、１……い、今だぁあっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んあああっ……！　ああっ、あぁあ～～～っ！　あ、あたたかい……熱いぃ\n……っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
