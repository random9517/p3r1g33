		{"command":[ "SETTEXT", "「あっ！　ひぃっ、ああっ、あぁああっ……！　ズッチョズッチョマンコを突\nきながら……あぁああっ！　乳首っ、乳首いじめて……感じさせてくれぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「っんんん……！　んんんぅ……、ふぅうう～～～～っ♪　い、いいっ……イ\nイッ、気持ち……いい♪　オマンコ、オマンコ疼いておかしくなるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「チンポが好きすぎて……あぅうっ！　か、硬いの欲しくて、つい締めつけて\n……あっ♪　あっ♪　そのせいで、摩擦が強くなってきて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404210" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「キツい膣内でチンポ、チンポをじっくり感じ取って……しまっている……！\n　はぁああっ♪　おまえは、おまえはどうだ……っ？　このヒダヒダぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえの精液とっ……あんっ♪　あぁっ♪　私の愛液でヌルヌルになったこ\nの貢壺の具合、は、悪くないか……？　あっ♪　いいか？　感じるかぁっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404212" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁああ……っ♪　はぁああっ、ああっ、あっ♪　あっぁっあっ……\n！　気持ち、いい……気持ちいいっ♪　あ～～～っ、イ、く……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえは私をこんなに気持ち良くしてくれる♪　本当にっ……本当に、おま\nえのところに来て良かった、もう、もうどこにも行きたくないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえのいない場所など意味がない……！　どこにも行かないぃ……！　ん\nぐぅうっ♪　でも、イ、……イくっ、おまえにはイカされてしま……うぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「何度も！　何度もマンコの奥を突かれて、えぐられて……！　ああああっ、\nもう、もう好きにしてくれ、なんでもするっ、なんでもするからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あっあぁっ……！　中に……中に無責任射精していいか、\nだって……？　いいっ、いいよっ……中でも外でもどこでもいつでもぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404217" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえ、の出したいように出してほしい……！　あぁっ、射精っ……射精さ\nれると、私も、私も気持ちがいいから……いいよ、出してくれ、出せぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私の欲望をいつも受け止めてくれるおまえのモノなら……！　あっ、チンポ\nでも、精液でもいくらでも受け入れてやる……！　それに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえにっ、興奮してもらうのが好きなんだ……！　あっ、あっ、興奮した\n証……精液っ、精液を私に出してくれ……！　たくさん、たくさんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっぅっふっ♪　んくふぅうううううう～～～～～♪　あうっ！　あうっ、\nあうぅううぅ～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「脳っ、から大量に脳汁が噴き出すくらい……気持ち、いい……！　ああああ\nあ……！　中出しっ、中出しが好きだ……好きっ、好き……うううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あぁ……ドクドクとおまえの子種が膣内に注入されていくのがわかる……。\n私の中の女が、悦んでいるのがわか……る。し、幸せだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「だ……大好きなお前とこんなに激しく密着して、他の誰にも触れさせない場\n所で深く、ぴったりと繋がれるなんて……本当に素晴らしいことだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ♪　子宮口、が開かれて中に精液が流れ込んで……♪　ど、どんな勢い\nの射精をしているんだ、信じられない……嬉しい。うっ♪　うぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「う……うまく孕ませてくれ……。受精、受精したい……♪　私はおまえの子\nを産むために、こちらの世界に来たんだと思い知らされたい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「っ……あはっ……♪　はぁああっ、あぁ……！　大量に精液を注ぎ込まれて\n……私の子宮はもうパンパンだ。これ以上はこぼれかねないほど入っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ……♪　おまえを夜這いして、本当に良かった……。身体の火照りが消\nえただけじゃない……。その、心まで満たしてもらえたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404308" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえには、感謝してもしきれないな……。私は与えてもらってばかりで…\n…。って！　大事な話をしている時にチンポをヒクつかせるなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ゆ……油断していたから、うっかり感じてしまっただろう！　ば……ばか…\n…。ま、まあ次も……夜這いを許してくれるなら、許してやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ……ああっ♪　あはぁあああっ、あああ……！　あッ♪　ぷぅっ……ん\nぷっ、ぷぅっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あぁ……うぁああ……♪　そう、か……おまえは私に種汁をぶちまけたかっ\nたんだ、な……いいぞ、もっと、もっとかけてくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっあっ……熱い……。すごい臭いぃ……。ドロドロの精液が容赦\nなく私めがけて……っ。こんなに興奮する事は他にない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あふっ……！　作り立ての……っ、絞りたての新鮮な精液、精液ぃ……！　\nトロトロのミルク、んぅっ……こんな勢いで食らったら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「イッ……♪　イッてしまう、私は精子をぶっかけられてイク、悪い襲来者だ\nぁ……！　あぁっ、あっあっあっ、イく……！　あ～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「は、ぁ、あ、ぁ、ああああ……♪　はふぅうう……♪　せっかく……おまえ\nが、私を新しい姿に変えてくれた、のに……ダメだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404406" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「おまえのチンポから溢れ出した精液に、私はドス汚れた劣情を思い出して…\n…。何？　私は前とは違う……？　どうしてだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「こんなに精子に興奮してしまったのに……。……セックスで我を忘れるのは\n、悪いことじゃない？　精液浴びてトロ顔になってしまってもか？　うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「そうか……だったら、これからも……。はぁ、はぁ……おまえを夜這いして\n、こうして精子を奪い取ってしまってもいいんだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「そ……その時のことを妄想するだけで……私は、私はぁ……♪　あああ、私\nをこんな風にした責任……一生をかけてとってもらうから、覚悟するんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
