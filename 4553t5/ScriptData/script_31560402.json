		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「こんな快感んんんっ♪　たえっ……耐えられるかばかぁあああ……♪♪　あ\nふっ！　ああっ、あ～～～～っ♪　あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「精子っ……精子、精子のぼってくるぅ……！　あーっ！　おかしく、おかし\nくなるぅううう！　はぁっ♪　はぁ、はぁ、はぁあああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「すま、ない……。うう……。あまりに気持ち良くて、ぼーっとしてしまって\nいた……。精液で、私の全てが満たされていくようで……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「やっぱり……やっぱり、この格好でするのが好きだぁ……。すごく安心する\n、おまえに何もかもを委ね、任せているようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「……ンッ！？　な、なんだ？　今……中で何かが動いたような……。ぁ……\n、え？　チ、チンポがもう復活して……？　う、嘘だろうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404203" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
