		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……そ……そうか。まだ出来るのか……。それなら……。はぁ、はぁ\n、あと少し……したい。ねだってしまってもいいだろうか……？」", "NORMAL" ]},
