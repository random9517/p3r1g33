		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あぁ……、あっ、あっ……！　こ、応えてくれるんだな……っ\n。あ、ありがとう……すごく、すごく気持ち、いい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んふっ……！　ふぅううっ……ううっ♪　あっ♪　せ、精液で満たされた膣\n内を……チンポが動き回ると、ヌチョヌチョして気持ち良すぎる……ぅっ」", "NORMAL" ]},
