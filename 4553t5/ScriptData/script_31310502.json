		{"command":[ "PLAYVOICE", "v2_131_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そうですか……あなたも、気持ちよかったなら……嬉しい、です……んっ、\nふぅ……これだけ、出せば……そうでしょうけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えぇ……私ですか……？　もう……野暮ですね……聞かなくてもわかってま\nすよね……？　確かに直接聞きたいって、言いましたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「うぅ、まあ……はい……気持ちよかったですよ……私だって……でも、だか\nらって、出しすぎですよ……もうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「好き放題に中に出してましたけど、妊娠したらどうするんですか……？　責\n任、取ってくれるんですか？　ふふっ、冗談ですよ」", "NORMAL" ]},
