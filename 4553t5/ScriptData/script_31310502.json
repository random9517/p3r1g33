		{"command":[ "PLAYVOICE", "v2_131_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あんっ……んふぅ、はっ……さっきより、もっと多いぃ……んふ\nぅ……はぁ、はぁ……はっはっ、はーっ、あぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
