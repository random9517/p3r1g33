		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「くっ、ンぅうっ……そうやって、お尻に……擦りつけるだけで……なにを…\n…して……ううっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504102" ]},
