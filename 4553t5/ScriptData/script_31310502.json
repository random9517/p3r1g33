		{"command":[ "SETIMAGE", "0", "still_00013105_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わかって、ます……頑張りますから……そう言う、あなたは、どうなんです\nか……き、気持ちいい……ですか？」", "NORMAL" ]},
