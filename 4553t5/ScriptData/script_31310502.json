		{"command":[ "PLAYVOICE", "v2_131_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ま、まだ、出て……るっ……ふぅ……ひゃうっ……いい、\nですよ……好きなだけ……出して、ください……」", "NORMAL" ]},
