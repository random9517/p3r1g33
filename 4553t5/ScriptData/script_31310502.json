		{"command":[ "PLAYVOICE", "v2_131_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そうです、ギンギンに勃起した……おちんちん……私の、アソコ……ああ、\nもうっ……おまんこ、です……おまんこに欲しい……」", "NORMAL" ]},
