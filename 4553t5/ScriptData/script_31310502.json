		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃあっ！　あっ、あひぃい……んっ、ンンぅぅっ！　あついぃ……んっ、\nンンっ！　お、お尻っ……かかって……ひぃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はっ、ひぃっ！　あぁんっ！　すごい、飛んでくる……あはぁ……はっ、あ\nんっ……あんっ……あひぃんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、熱い……せーし、熱いっ……ひぃ、ひうっ……お尻、が……ドロドロに\nなってくぅ……んあぁあ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
