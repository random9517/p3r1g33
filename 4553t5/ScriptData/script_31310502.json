		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあっ……あぁ、あっ……やっぱり……私を恥ずかしがらせようとしてぇ…\n…んんっ……そういうの、いいですってば」", "NORMAL" ]},
