{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「しかしよくぞ我等の計画書を手に入れたものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てめーの部下がな、疲れからか不幸にも計画書をバイトのグループチャット\nにアップしたからだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「コンプライアンスぅー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「悪の組織がコンプラ叫んでんじゃねーっすよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「確かにごもっともだが、もはや我々は止めれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010022820002" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「ああ、全メニュー食い尽くしてくれる！　お前ら、その間足止めしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010022820002" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「これ別に手当出ます？……あ、作戦漏洩の罰帳消しと引き換え？　あ、はい\n分かりましたガンバっしゃーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「させると思うか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00016002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「てめーらのせいで、やりたくもねーバイトをさせられたからなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_020022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00020602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「残業マシマシ効果でさすがに鬱憤が溜まってるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_020022820002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ、全員殲滅しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820002" ]},
		{"command":[ "SETCHARA", "0", "char_00016002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおいおい、店の中でフランカ達と襲来者達が大立ち回り始めたぞ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "たかが食欲のためにファミレス一つ潰す気か！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「おー、面白いことになってるっすね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022820002" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なってねーよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ちなみにあいつらをぶちのめせばドリンクフリーっすか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022820003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなんねーよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「きゃ～怖いわぁカツマさぁん、んふふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010022820001" ]},
		{"command":[ "SETCHARA", "0", "char_00018203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おわ、お前はこんな時に抱き着いてくるんじゃねー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んもぅ、私の愛を受け取って♪　ほらほらぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010022820002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「そこイチャイチャするな！　愛など粘膜が作る幻想だってばっちゃが言って\nいたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010022820003" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どこから取り出してんのか分からねーけど、重火器やら鈍器やらナイフやらフ\nォークやらが襲い掛かってくる！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そしてここのファミレスは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010022820003" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「手ごろな価格で上質な食材を揃え、なおかつメニューも豊富、まだまだ食べ\n尽くさなければならない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010022820004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ンだあいつ！　食欲だけで立ち向かってきてるってのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_020022820003" ]},
		{"command":[ "SETCHARA", "0", "char_00020602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「厄介な……！　ならば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820003" ]},
		{"command":[ "SETCHARA", "0", "char_00016002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「姐さんが無線機を取り出した！　これで勝つる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_020022820004" ]},
		{"command":[ "SETCHARA", "0", "char_00020602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何にだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「応答せよ。こちらフランカ、応答せよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820004" ]},
		{"command":[ "SETCHARA", "0", "char_00016002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「こちらライオットだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022820001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「こちらの連絡を忘れたのかと思っていたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「とんでもない。待ってたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022820002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「『当初の作戦通り』だ。ライオット、アレを使う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「アレならオンラインだ。ぶちかましてやれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022820003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "――いやだから何を？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう聞き返す暇もなく、無線越しにスイッチの押される音がする。……今回初\n期から思っていたが、嫌な予感というのは大概的中するもんだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「衛星からの超超高度距離照射ビーム、果たして逃げられるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010022820007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
