{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「人間の分際で、王である我にセクハラをするとは……どうやら、命が惜しく\nないようであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「今この場で、天罰をくだしてやるのである……ん？　なんであるか。その手\nに持っている機械は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それは我の新パーツ……！　おかしいのである！　それはドクターが持って\nいるはずなのである！　何故そなたが持っているのであるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「まさか人質……いや、機械質とでも言いたいのであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ……！　わかったのである……そなたの言う通り、我の恥ずかしい過去\nを話してやろう。だからそのパーツを返すのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　いくら我が機械の身体だからといって、どうして自分自身\nの生殖器を見せつけられねばならないのであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002001_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そもそも、王である我をこんな格好で拘束するなど、不敬にもほどがあるの\nである！　今すぐ解放するのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こらっ！　なぜ無視をするのだ！？　我の声が聞こえないのであるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「えっ……？　ど、どうしてチンポを取り出すのだ……！？　まさか、この状\n態でオマンコに挿れる気なのであるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そ、それだけはやめるのだ！　今なら我への不敬も許してやるのである！　\nだからチンポをオマンコに近づけるでないのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ！　ど、どうしてであるか……！？　チンポを見ていると、\nオマンコが熱くなってくるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、あうぅ……！　ワレメからエッチな汁が……愛液が溢れてくるので\nあるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「卑猥な恰好で拘束されて、チンポとオマンコを見せつけられているというの\nに……気分が高揚してくるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「思考回路がショート寸前なのだ……！　あっ、んはあぁ……！　チンポが欲\nしいと思うだなんて……エラーに決まっているのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！　オマンコの入り口にチンポがあてがわれているのである\n……！　カタくて太いチンポが、入ってくるのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んくうううぅ……！　オマンコの肉が無理やりチンポで広げられながら、奥\nまで犯されているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんなにも酷いことをされているのに、子宮が反応しているのである……！\n　感じてしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ……！　チンポの先端が、奥に当たっているのである……！\n　王である我の子宮口と、口づけをするなどありえないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こ、これは不敬どころの話ではない！　王に対する反逆である！　い、今す\nぐチンポを抜くのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「やっ……あっ、あっ！　ゆ、ゆっくりと腰を引くでない！　やめるのである\n……！　こんな状態でピストンされたら、ダメなのであるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぐううぅ！　オマンコがグリグリ抉られていくのであるっ！　太い\nカリで、ヒダが擦られるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああっ！　んひっ、ぐっ、あふううぅ！　や、やめるのだ！　今すぐその\n激しいピストンを止めるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひいいいいぃ……！？　い、勢いよくオマンコの奥をチンポで突きさすな\nど……！　おっ、おほおおおぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「た、確かにピストンを止めろとは言ったが……！　無理やり奥を突けという\n意味ではないのである……！　チンポを抜けという意味であるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、んひいぃ……！？　オマンコの奥をグリグリするのもダメで\nあるぅ！　感じすぎて、子宮の入り口が開いてしまうのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だ、だが……我は機械である……！　いくら子宮口が開き、精液を注がれよ\nうと……妊娠することはないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「今のうちに、好きなだけ快楽に身を委ねておくといい……！　解放されたら\n、すぐにでも抹殺して……な、なんであるか、その不気味な笑い声は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ドクターから受胎できるようになるドリンクを貰い、我に飲ませておいただ\nと……！？　そ、そんなバカな話、あるわけないのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが、もしそれが本当だとしたら……我の子宮に精液が出されたら……に、\n妊娠してしまうのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひっ、あふっ……！　あはああぁん……！？　な、なぜであるか……！？　\n妊娠した姿を想像したら、オマンコが疼いてしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「勝手にチンポを締め上げて、グニグニと蠢いているのである……！　こんな\nの、我の意思ではないのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！　んぐっ、はひいいぃ！？　この状態で、そんなに動かれ\nたら……あっ、ああぁん！　か、感じてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぅ、んっ、んっ、んんんっ……！　チンポが震えているのだ……！　チン\nポの奥から、ザーメンがせり上がってきているのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、あひいいいぃ！　お、お願いだから、イカないで欲しいのであ\nる！　射精しないで欲しいのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イあああぁぁぁっ！　イクなと言っているであろう！　だ、出すでないっ！\n　我の子宮に、ザーメンを注ぎ込むでないぃ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んやああああああっ！　んぐっ、ぐっ、あああああああ～～～～＾っ！　で\n、出ているのであるうううううぅ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「熟成されたドロドロザーメンが、我の子宮に流し込まれでいるのであるぅ！\n　やっ、あああっ！　膣内出し、気持ちいいのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが、こんなことあってはらなぬのであるぅ！　膣内出しされ、受胎させら\nれている瞬間を見せつけられるなど……んっ、んぐうううぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あああぁあぁん！　早く抜くのであるっ！　このままでは、本当に赤\nちゃんを孕んでしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、ああっ！　だ、ダメであるっ！　イキたくないのに、イッてしまう\nのであるぅ！　あっ、あはっ！　んはああぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ……あぐっ……！　これで、満足したであろう……？　早くその粗末な\nチンポを、我のオマンコから抜くのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んむっ、うううぅ……！　抜かぬというのなら、我の方から抜いて…\n…んっ、ああっ！　あっ、はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「拘束されているせいで、上手く身体が動かぬ……！　身悶えするだけでは、\nチンポを抜くどころか、余計に感じてしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひっ……！？　ど、どうしてまたチンポが大きくなっていくのであるか…\n…！？　ま、まさか……また我を犯すというのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「や、やめるのである！　もうこれ以上は無理であるぅ！　こんな状態でオマ\nンコをほじられたら、本当に思考回路がショートして……あはあああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっ、おぐっ、んおおぉ……！？　さっきよりも奥までチンポが入ってきて\nいるのであるぅ！　子宮が直接、チンポで犯されているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「やっ、あああっ！　我のことを射精するための道具としか思っていないよう\nな腰使いなのに……！　オマンコが悦んでいるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ひっ……あっ、おほおおおおぉん！？　げ、下品な声が止まらぬっ\n！　王である我の威厳が、崩れるような声が出てしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もしこんな声をスレーブたちに聞かれたら、我は終わりである！　た、頼む\nから、もう許して欲しいのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うぎっ、ひぎいいいぃ！？　ピストンがもっと激しくなっているのであるぅ\n！　ど、どうしてなのだ！？　我になんの恨みがあるというのだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「う、恨みなんてない……？　ただ我のことが気に入ったから、犯すだと……\n！？　そのような理屈、通るワケが……んひいいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！　うああああぁ！　そ、それダメであるっ！　オマンコを\nグリグリしながら突くの、感じすぎるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「チンポの傘が、我のオマンコを削っているのである！　ゴリゴリ擦られるた\nびに、電気系統がエラーを発するのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、ぐほおぉぉぉん！？　エラー音が止まらないのであるっ！　\n我のオマンコから聞こえる卑猥な音と、エラーの音が全身に響くのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はあっ、ああっ、あっ、んひぃぃぃ！　身体がオーバーヒートしてしまうの\nである……！　このままでは、本当に壊れてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「な、なに！？　精液を冷却水の代わりにして、火照った身体を冷ましてやる\nだと！？　ば、バカなことを言うでない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「精液が冷却水の代わりになど、なるワケないのである！　熱くなった身体が\n、さらに熱くなるだけなのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それを今から試してやるだと……！？　やっ、やめるのだ！　もう精液など\n欲しくないのである……あっ、あっ！　んああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オマンコの奥で、チンポがビクビクと暴れているのである……！　あっ、や\nっ、ああああぁ！　またザーメンを注がれるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ひぎっ、うぐうううぅぅぅ！　あっ、あっ！　くるのであるっ！　\n熱いザーメン、出されるのであるうううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぎいいいぃぃぃっ！？　あっ、ひぐっ、んくうううぅぅぅぅぅんっ！？　\nまた子宮に注がれているのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ、くひいぃぃぃん！？　やっ、あぁぁぁ！　ダメである！　本\n当に赤ちゃんが出来てしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんな変態みたいな恰好で受胎するなど、王としてあってはらならぬという\nのに……！　し、子宮が悦んでいるのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「やあああぁ！　ダメであるっ！　イキたくないのに、気持ちよくてイッてし\nまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふぎゅっ、あっ、んふうううぅ！　イクッ！　イクのであるっ！　子宮をザ\nーメンで犯されながら、イッてしまうのであるぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あひっ……んんっ……！　こんな快感、知らないのである……今ま\nで、味わったことがないのであるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これが……人間の生殖行為……セックスというものであるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そして……オマンコの奥に感じる、温かな感覚……これが、母になるという\nことであるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふふふっ……まさか人間の感覚を知ることになるとは……我の演算回路でも\n、予想できなかったのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「よければ……もっとオマンコにザーメンを注いで欲しいのである……もっと\n人間の感覚を、味わわせて欲しいのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おほおおおおぉぉぉぉぉ！？　おっ、チンポが抜けて……うぐううううぅぅ\nぅ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あぶっ、ぐっ、んぶうううぅ！？　ど、どうして我の顔にザーメンをかける\nのであるか！？　うぎゅっ、あっ、熱いのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オーバーヒートしているのに、こんなに熱い精液をかけられたら……余計に\nオーバーヒートしてしまうのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぎっ、あああっ！　エラー音が止まらないのであるっ！　不快なはずなの\nに、身体は気持ちいいのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あひっ、おっ、んぐおおおおぉ！？　もうダメであるっ！　回路が、こ、壊\nれ……あっ、あああっ……！　ひあああああぁ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ……ああぁ……顔も……オマンコも……ザーメンでドロドロになってい\nるのであるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「熱暴走も……と、止まらないのである……身体がずっとおかしくて、小さな\n絶頂を繰り返しているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「早急にメンテナンスをしなければ……本当に壊れてしまうのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「た、頼む……我をここから出して……早く、ドクターのもとへ連れて行って\n欲しいのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00002001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんも、ちゃんと産むのである……だから……早く我を、ここから……\n出して……あっ、あああぁ……んっ、くはああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
