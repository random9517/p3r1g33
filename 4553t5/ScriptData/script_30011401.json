	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……っく……くそっ……このような不覚を取るとは……私もヤキが回った\nものだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん……ここまで来たら、私は逃げも隠れもしない。貴様の好きなようにす\nればいい……うっ、くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「遠慮なくチンポを押し付けてくれる……私に何をさせるつもりだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「分かっているだろうと……？　ああ、そうだな……貴様のような下衆の考え\nることなど、決まりきっているからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうせチンポを舐めろと言うんだろう……？　所詮、その程度の……何……\nお、おねだりするのは私だと……？　ど、どういう意味だっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私から言えと言うのかっ……！　くっ、貴様……調子に乗ってっ……うくっ\n……しないと、私のアーマーを奪うだとっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「この卑怯者めっ……い、いや、待て……分かった……言う通りにする……そ\nの、私に……貴様のチンポを舐めさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「言葉遣い……わ、分かった……お願い、します……どうか、卑しい私に……\nあ、貴方の……立派なチンポを……舐めさせて……下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、れろ……ちゅぷ……んっ、える……れる……れろ……んっ\n、れろぉ……れろ、れろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくっ……あぁ……臭い……キツいにおいが……鼻に広がって……洗ってい\nるのか……このチンポ……んっ、えろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私が……綺麗にするっ……んくっ、そういう企みか……んっ、えろっ……れ\nろ……この、汚れを……唾液で……溶かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……はぁ……んっ、舌を擦り付けて……舐めとっていく…\n…ぴちゃ……れろ……ちゅぷぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くそっ……この屈辱は、必ずいつか倍に……いや、それ以上にして返してや\nる……覚えて、んちゅぷっ、いるがいい……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁ……れろっ、何を馬鹿な……このような仕打ちを、喜んでする訳が……\nれろ……ないだろうっ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「誰が、好きこのんで……不潔な貴様のチンポなど……れろ……んっ、舐める\nわけが……はぁ……んっ、れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「この辺も汚れている……ちゅぷっ……ぴちゃ……あぁ……んっちゅ、何故、\n私が……こんな真似を……れろ、んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅぱ……どうだ……もう、十分綺麗になっただろう……まだ\n、何かさせる気か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここからは……チンポを気持ちよくさせるように舐めろ……だとっ……どこ\nまでも調子に乗って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れるっ……んっ……ぴちゃ、こういう……ことか……んちゅぷっ、ぴちゃ…\n…んぁっ……はぁっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ……んむっ……れろっ、えろっ……あぁ……ここに舌を押し付けて……ん\nっ、割れ目に合わせて……舐めあげていく……ぴちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……れるぅ……れろぉっ、んっ、えろっ、れるっ……んれりゅっ、\nりゅぷっ……りゅぱっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んむっ、今のが気持ち、いいのか……んっ、れろっ……もっとしろ\nと……んっ、れろ……れる……んりゅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぱっ、んんっ……入り口が震えている……ちゅぷっ……汁が\n滲んで……ふん、分かりやすいチンポだ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま、あっさり出してしまうんだろう……？　いいぞ、さっさと出して\n……んんっ、ふぶっ……むぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「きひゃまっ……らりをっ……おぶっ！　むぐぅっ！　んぐっ、ふぉんらっ…\n…奥にチンポっ……うぐっ、ふぐぅ、おぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んむっ、じゅぷっ……りゅぶっ……んぐぅっ……！　おぶっ！　あ、手をっ\n……離せっ……むぐぅっ、無理矢理にっ……ふるなろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぐぅっ、おぷっ、あぶっ、くるひぃっ……んんっ、息がっ……むぐぅっ…\n…れきないっ、じゅぽっ、んふっ、は、鼻を使うっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ、んぶっ……んぷあっ、りゅぷっ……むぐぅっ……たひかにっ\n、呼吸は……れきる、がっ……んふぅっ、こんらのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「口に……いっぱいっ、入り切らなひっ……んじゅるぅっ、ぐぽっ、じゅぱっ\n、ちゅぷっ、んりゅぷっ……んじゅるっ、んふぅぅっ、むぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「腰を……そんらにっ、振られたらっ……むぐぅっ、あぶっ、くるひぃっ……\nんぐっ、らめらっ、チンポ……そんらにぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んぶっ……！　むぐっ、じゅるるっ……んぐっ、んふぅっ……わらひ\nのっ……口をなんらと思って……んぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと強く吸い付けっ……？　貴様……ろこまでっ……んぐっ、くそっ……\nんじゅるっ、んじゅぅぅっ、これでっ、ろうらっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ……あぷっ、チンポがっ……震えてっ……じゅぷっ、んじゅるるっ\n……！　まさかっ……貴様っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もう出るっ……！？　んぐっ、は、離せっ……このまま出す気じゃっ…\n…むぐっ、んんっ！　おぶっ、は、激しいっ……むぐぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やめろっ、らすなっ……あぐっ……口にそのままらんてっ……ふぐっ、むぐ\nっ……んんんんんんんんーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぶぅぅぅぅぅっ！　おぷっ……まへっ……んっ、ふぐうっ……んっ、むぐ\nっ、んんんんんーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんて量らっ……んぐっ、こくっ……んんっ、ふぐっ、離へっ……んんっ、\nごくっ、んぐっ、んふぁっ、むぐっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、こぼひたら……また……酷いことを……んんっ、うくっ、こくっ、んっ\n……んくっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぷぁっ……はぁっ、はぁっ、はぁっ……けふっ、けほっ、けほけほっ……\n！　本当に……遠慮なく出してくれたな……窒息するかと思った……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せ、精液の味だと……？　ふざけるなっ……こんなものが美味い筈がないだ\nろうっ……調子に乗るなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなもの……れろっ、ぺろ……んちゅ……生臭いだけで……何も美味くは\n……ないっ……んっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、今……先端を舐めたのは……どうせ、貴様が後始末を要求すると思った\nから……先に済ませてしまっただけだっ……勘違いするんじゃないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……くっ、まだ終わりじゃない……だと……貴様というやつは……これ\nだけでは飽き足らず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、分かった……すればいいんだろうっ……だから、そんな風にチンポを…\n…頬に当てるなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「全く……んっ、えろっ……ぴちゃ……んちゅ……ちゅぱ……んちゅぷ……れ\nろ……あぁ……また精液の味が……んっ、舌に……広がる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……んりゅ……何故、私がこのような真似を……あぁ……んちゅぷっ、\nぴちゃ……んっ、れろ……はぁ……んむっ、ちゅぷっ、えるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「先端をそんなに震わせて……んちゅぷっ……そんなに、私の舌が……気持ち\nいいというのか……んちゅぷ、れろ、れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「別に……んっ、嬉しくなど……ないっ……ただ、早くイクなら……すぐ終わ\nってくれるから……ありがたい、だけだ……んちゅ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「断じて……咥えたいなどと……はぁんむっ、くぽっ、りゅぷっ、んふぅぅっ\n、おもっへらど……らいっ……じゅぽぉっ、んちゅぷぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……自然に、深く咥えてひまった……んっ、りゅぷっ、じゅぽっ、くぽ\nっ、んぷっ、りゅぷっ、んちゅぷぅぅっ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなチンポに夢中になるなど……あってはならないことなのにぃ……じゅ\nぱっ、ちゅぷっ、りゅぷっ、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んむぅっ……あぶっ、んふぅっ……じゅるるるっ……はぁんむ、ちゅるっ…\n…口の中で……唾液が溢れて来てしまう……りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ……違う……美味しいと思ってる訳じゃらいっ……あぁっ、れ\nも……んちゅるっ……舌が勝手に……チンポに吸い付いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅぅっ……味わっちゃう……んちゅっ、れるっ、ちゅるるうぅっ…\n…この濃い味が……癖になるぅ……ちゅぷっ、んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ……ちゅぱっ……んぷぁっ、あぁ……また先走りがチンポに……浮\nいてる……んちゅるっ、またこの味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
