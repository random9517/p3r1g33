{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　服を剥かれて全裸にされて、身動きが取れないように手足を拘\n束されて……中々お似合いの格好ですよ、下僕♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「実は下僕を虐めるいい方法を思いついちゃいまして……ちょっと闇討ち、さ\nせていただきました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――何をするつもりも何も、この状況ならやることは一つでしょ？　下僕の\nおちんちんだって、期待してるじゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「オリジナル風にいうと『メンテナンス』で『ご奉仕』ですよ♪　ただ、それ\nを受けるのもするのも、下僕の仕事ですけどね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、余計な口を叩いてる暇はありませんよ？　んんっ……あっという間\nに下僕のおちんちんが私のオマンコに飲み込まれちゃいましたねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「一応私のボディもオリジナルとほぼ同等なモノになっています。中の感触も\n、中々悪くはないでしょう？　あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――はい、それじゃあ始めましょうか♪　人間である下僕は、機械である私\nに奉仕するため、必死に腰をヘコヘコと振ってくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「なに呆けてるんですか？　さぁ早く腰を振ってくださいな。ご奉仕、できま\nすよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「言ったでしょう、下僕のことを虐めてあげると。今日の下僕は私の道具。た\nだただ腰を振って、私を満足させる生体機械になればいいんですっ、よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃはは♪　驚きました？　挿入したおちんちん、苦しいでしょう？　この\nままオマンコで圧迫して、おちんちん潰すこともできちゃうんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「それが嫌なら……ね、いくらお馬鹿な下僕でも、どうすればいいか、分かり\nますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んふぅんっ……！　そうです、やればできるじゃないですか！　んっ\n、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちん、奥のところ、ずんずんって突いてっ、んふぅんっ！　少し上手\nいのが、憎らしいですねぇ、んふんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――私が何をしたいか分からないけど、ただエッチするだけなら余裕だ、で\nすか？　にゃふふ、分かってませんねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「身体を仰向けに手足を拘束されて、動かせるのは腰だけ……ねぇ、下僕はそ\nんな無理な体勢で、いつまで腰を突き上げ続けれますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「私を満足させることができなくなった時点で、下僕のおちんちんは、ぎゅっ\n、ぐちゃ♪　ですからね♪　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あらあら？　早速腰の動きが鈍ってきてますよ？　んんっ、その情けない腰\n振りが本気ってことでいいんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んはぁんっ！　さすがに、まだ大丈夫ですか……んふっ……角度をつ\nけてオマンコを突く余裕もあるのは、腹立たしいですねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ああ、でも……にゃふふ♪　人間に――憎らしい下僕に奉仕させるというの\nは、思った以上に悪くないかもしれません、んあぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ！　腰を跳ねさせるしかないから、体の芯に響くように、お\nちんちんがガンガン突きこまれて、あっ、んにゃんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――わ、私の声はどうでもいいんです！　そーゆーところが憎らしいんです\nよ！　んふっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ぐっ……生意気を言うような下僕は……こうです！　んんっ！　にゃふふ♪\n　どうですか、おちんちんに直接流し込まれる微弱電流の刺激は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、そうです、おちんちんを虐められたくなかったら、もっと必死に\n腰を振るんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あぁあ、んあぁんっ……！　ま、まだスピードを上げる余裕がありますか！\n　んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んやぁんっ！　一突きごとに、快感によるエラーが出てっ、んにゃぁ\nんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これは、想像よりはるかにいいかも……あっ、ふあぁんっ……！　歯を\n食いしばって必死に腰を振る姿も、みじめで素敵ですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、少しだけご褒美です……あぁんっ……！　おちんちんを絞り上げ\nるように、オマンコな内部機構をうねうねってしてあげます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「キツキツで少し苦しいぐらいの締め付けですけど、痛くはないでしょう？　\nにゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　んんっ、んにゃぁんっ！　おちんちん、どんどん大き\nくなって、一番奥をぐりぐり抉ってっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――出したい、ですか？　このまま私の中に、精液をぶちまけたいですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、いいですよ、別に。特別に許可して上げます♪　そのままヘコヘ\nコ情けなく腰を振って、私のオマンコに膣内出ししちゃっていいですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んやぁんんっ！　あっ、んふぅんっ！　こ、これもおまけです、気持ちいい\nぐらいの微弱の電流を、プレゼントして上げます！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふふ♪　オマンコの中でおちんちんが面白いほどに暴れまわってます\nね！　ああ、なんて情けない喘ぎ声……とっても素敵♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――そんなに大声で叫ばなくともわかってます。いいからそのまま膣内に出\nしちゃってくださいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、んあぁんっ……！　先端のかさが膨らんで、一気に熱が駆け上がっ\nてきて……！　んにゃ、んふぅんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅんんっ！　こ、この精液の勢いは、少し想定外かもっ……ああっ\n、んふぅうんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「な、内部機関が熱暴走を起こしちゃいそう……！　あっ、んあぁんんっ……\n！　下僕の分際で、分かってはいても、少し腹立たしいですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ですが……にゃふ、にゃふふふ♪　何腰の動きを止めようとしてるんですか\n？　本番はここから、ですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「誰が一回で終わりと言ったんです？　私が満足するまで奉仕させる……下僕\nを虐めるに決まってるじゃないですか、にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、とっととおちんちんを固くして、腰を跳ね上げてくださいよ！　もた\nもたするようなら、下僕のおちんちん、壊しちゃいますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、あぁんっ……そうそう、物分かりがいい下僕は嫌いじゃあり\nません、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ですが……少し動きが温いですねぇ。んんっ……なんですか、もしかして、\nわざと手を抜いて私に虐められたいとか思ってます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――そうですね、腰を振るリズムをとってあげましょう。少しでもずれたら\n……分かってますよね？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「はーい、いち、に、いち、に♪　みっともなく腰をヘコヘコさせて、ドロド\nロオマンコを突き上げましょうね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「いち、に、いち、に♪　んあぁんっ♪　そうそう、やればできるなら私の手\nを煩わせないでくださいよ。いち、に、いち、に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふ♪　そう、その必死な姿が見たかったんです！　あっ、\nんあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「下僕の惨めで情けなく喘ぐ姿を見るだけで、参照データが存在しないエラー\nが止まらなくなって……あぁんっ、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「これがオリジナルが言う愛情……？　いえ違います、これは憎悪！　下僕の\nことを虐めるのが愉しくて仕方ないの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「必死にご奉仕する下僕にご褒美もあげちゃいます！　オマンコの内部機構を\n常に稼働させてっ……んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちん全体をぎゅっぎゅ、ぎゅっぎゅって！　うごめくオマンコで何度\nも何度も絞り上げてあげます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ！　に、人間でいう子宮にあたる部分も振動させてあげる\nからっ、必死に奥を突けば突くほど、下僕も気持ちよくなれれますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あひゃぁんっ！　あっ、ふあぁん！　そ、そう、その貪るような動きを待っ\nてたの！　オマンコの奥の奥までかき回すおちんちんの動き、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふふ♪　息を荒げて、涎を垂らして……ああ、もっと虐め\nたい、下僕のこと、もっとぐちゃぐちゃになるまで壊したい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あひゃぁんぅ！　あっ、んふんんっ！　下僕のみっともない姿を見てるだけ\nで、本格的にエラーが止まらなくなってっ、にゃふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「下僕もまた出したいんですよね？　分かりますよ、私の玩具のことならなん\nだって、手に取るように分かります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あっあっ、ふあぁんんっ……！　いいですよ、おねだりするのであれば、下\n僕の好きなタイミングで、好きな場所に出すのを許可してあげます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、間髪入れずに機械である私におねだりとは、下僕には人間と\nしてのプライドはないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「でも、約束は約束です！　あっ、んふぅんっ！　こ、このまま私に奉仕して\n、思う存分精液をぶちまけちゃってくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！？　あひっ、あっ、んにゃぁんんっ！　最後、はげしっ、ふあ\nぁんんっ！　オマンコの奥っ、抉ってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「下僕にイかされるなんて、屈辱、ですけどっ、ふあぁんんっ！　あ、あああ\n、ノイズが走ってっ、あひっ、イク、イクイクッ、イっクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んふぅぅんんっ～～っ！！　オマンコの奥に精液を叩きつけられてっ、にゃ\n、あぁんんっ！　ノイズの嵐がっ、止まらない、んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　もう体力の限界のはずなのに、射精中も必死にへこへこ腰をふ\nる下僕、素敵ぃ……ああぁ、ああぁああんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「まったく、生意気なおちんちんですね～、あっ、んふぅんっ……オマンコか\nら溢れそうなほど、出しちゃってくれて……んっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ……素敵……貴方は私の玩具、私だけの玩具……！　こんなことされち\nゃうと、今すぐ壊したくなっちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふ♪　冗談ですよ、冗談♪　まだまだ虐めたりないですも\nの。そんな簡単に壊しちゃったらもったいないじゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……さすがにもう打ち止めですか。にゃふふ、ほ～ら、最後にオマンコ\nの中をぎゅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「情けなくていい悲鳴を聞かせてくれますね～。――本当にこのまま虐め壊し\nちゃおうかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――なんだ、まだそんな反抗的な目で文句を言えるんですね。にゃふふ♪　\nまだまだ遊べそうなようで何よりです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「今度はどんなことをして下僕のことを虐めてあげましょうか？　身体だけで\nなく心までぐちゃぐちゃにするのもいいかもしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「だから……逃げようなんて思わないでくださいね？　私だけの玩具……にゃ\nふ、にゃふふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁあんんっ～～！　おちんちんが抜けて、にゃふうんっ！　下僕の精液\n、ぶっかけられて、イっちゃうっ、んにゃぁんんっ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015705_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「確かに許可を出したのは私ですが、あっ、んあぁんっ……！　全身をドロド\nロにされるのは、中々に不愉快で、腹立たしいものですね……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「まぁでも……にゃふふ♪　そのおちんちんをヒクつかせて射精する惨めな姿\nに免じて、許してあげちゃいましょうか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　なんですか、その馬鹿みたいなおちんちんの跳ね方。ビクンビ\nクンって暴れまわって……にゃふふ、みっともないですねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あら、あらあら？　おちんちん馬鹿にされて反応しちゃってませんか？　や\nっぱり下僕の性癖ってそーなんですねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ……やっぱり私の玩具は虐め甲斐があって素敵です……いつか壊す日が\n来ることを想像するだけで、んあぁんっ！　また、ノイズが走って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃぁぁんっ……！　あっ、んふぅんっ……！　にゃふ、にゃふふふふ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「――息が整った途端、中々反抗的な目をみせてくれるじゃないですか。でも\n、そうじゃないと面白くありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「これからもたくさん嬲って、虐めて、泣かせて……ほどほどに壊しぬいてあ\nげますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、よろしくお願いしますね？　私の可愛い可愛い、憎らしい玩具の\n『ご主人様』？　にゃふ、にゃふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
