		{"command":[ "FADEIN", "NORMAL" ]},	
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふひゃあっ！　あっ、んんっ……！　出てるっ……！　また、新しいのビュ\nビュってしてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503401" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ……！　んんっ、おっぱいっ……そんな、ギュってしたらっ、ヤムもっ\n、あっ、またミルク出ちゃうしっ……はひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……ヤバ……パパのミルクと……ヤムのミルクが入り混じって\n……うぁ……めっちゃドロドロになってきてるぅ……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくぅ……不覚ぅ……ヤムもこんな気持ちよくさせられちゃうなんてぇ……\nあっ、こら……おっぱい引っ掻くなしっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503404" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ……はふぅ……んっ、全部……出した？　よしよし、ちょっと生意気だ\nったケド、いっぱい出せてえらかったねぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503405" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「でも、結局パパってば、子どもでも、チンポはバッキバキのままで、よっぽ\nどスケベだったんだなーって分かったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503406" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そんなことより、早く戻せ？　あー、まぁ、一日くらいしたら、一応戻ると\n思うよ？　たしかそんな感じだった気がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まー、じたばたしても仕方ないしさっ。待ってる間ヒマなら、またヤムのお\nっぱいでも飲んどく？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、なーに、チンポビクってさせてんの？　今のだけで、何かまた新し\nいこと期待しちゃってたり？」", "NORMAL" ]},
