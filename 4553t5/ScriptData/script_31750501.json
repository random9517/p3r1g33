{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「にひひひ……パパ……ずいぶんと、かーわいいカッコになったじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「で……なーんか面白いこと言ってたよね？　ヤムがオトナになっても、そん\nなにおっきくなってないって……どう？　今、どんな感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ベツに何もしてないよー？　ちょーっと飲み物にマキモドールを混ぜただけ\n。そしたら、こんな小さいパパになっちゃうなんてねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「これでも、まーだヤムのこと、成長してないって笑える？　笑えないよねぇ\nー、ごめんなさいしちゃう？　にひっ、さー、どうしよっかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503104" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあ、もうバカにしないってことでぇ……ヤムのおっぱい飲んだら許して\nあげなくもないけどー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ……なーんて、パパに選択肢なんてないんだけど。ほーら、ヤムの\nおっぱいだよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ……そうそう、チュウチュウ吸って……どう、これでもヤムは子ども\nって言えるかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さて……こっちはどうなってるのかなーっと。ふふぅーん、なるほどねぇ…\n…んふふっ、可愛くなってもチンポは結構おっきいままじゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「可愛い顔して、こんな凶悪チンポ持ってるなんて……これは、ヤムがしっか\nりお仕置きしてあげないとダメみたいねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、よい……しょっと……ふふっ、こーいう時に尻尾って便利でしょ\n？　ぎゅっと巻き付けちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さーて、チンポの感度はどんなモノかな～？　うりうり……ぐりぐり……く\nにくに～、どれくらいの加減がいいのかなっと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、教えて……？　ヤムにさ……どんな風にチンポ気持ちよくしてほしー\nの？　もっと、ぎゅーっと強くして欲しい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それとも、こうして……先っぽをさわさわーって……優しく撫でて欲しいか\nな？　それともどっちもしちゃうのがいいかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、チンポがびくんびくんしちゃってる。これって、全部して欲しいっ\nてことだよねぇ。さっすがパパってばやーらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いいよ、その代わり……パパもヤムのおっぱい……思いっきりちゅーってし\nよ？　ほら……遠慮しなくていーんだから……んっ、ふっ、そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、どう……ヤムのおっぱい美味しい？　んっ、待ってね……もうちょ\nっとしたら、ちゃんとミルクも出る感じだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパがちゃんとチュウって吸ってくれたら出るし……んっく、もうちょっと\n強く……ねっ。はぁんっ、そう……そんな感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はい、ヤムもお返し……チンポをよしよしして……きゅんってしてあげる。\nあはっ、今、ビクってしたでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ごまかそうとしてもダーメ。ぜーんぶ、ヤムの尻尾に伝わっちゃってるんだ\nから。ほぉら、またチンポをむぎゅーって擦ってあげちゃうよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もうお汁、浮いてきてるじゃん……どれどれ、ちょっと味見しちゃおっかな\n……ちゅぷっ、れろっ、んふぅー、なるほどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「小さくなっても、パパのチンポ汁の濃さは全然変わんないって感じ？　や、\n若くなったからもっと青臭いのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あららー、恥ずかしがってる？　パパってば、意外にそーいうとこ気にした\nりするのかな～？　可愛いじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いーよぉ、今日はヤムおねーさんが、パパをしーっかり躾けてあげるから♪\n　ほら、そろそろ、ヤムのミルクも出ちゃうからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、んふっ……あふっ、あんっ……！　おっぱい……出てきたぁ……\nふふっ、お待たせぇ……いーっぱい召し上がれっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どぉ？　ヤムのおっぱい美味しい？　ふふ……一回出たら、後はどんどん出\nてくるから、いっぱい飲んでいいからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……んんっ、飲みながらチンポもシコシコしちゃおうねー。後は弱そう\nなトコも一緒にくすぐったげよっか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「例えば、このわき腹とか……つんってっ、あははっ、くすぐったかった？　\nめちゃくちゃビクンってなってんのかーわいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ごめんごめん、ほら、もうちょっと大丈夫なトコにするし。この……太もも\nとかさ、後は……首筋のトコとか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ね、落ち着く感じするでしょ？　チンポに集中しすぎないぐらいの感じでぇ\n……さわさわーって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それで、また時々チンポをむぎゅーって……どう？　ヤムの尻尾コキ……気\n持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっふふー、こくこく頷いちゃって、かーわいいんだから。いーよ、そんな\n顔されたら、もっとしてあげちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーら、しこしこ……むにゅむにゅ～。あー、チンポがまたビクって震えが\n強くなってきたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくっ……！　おっぱいもチュウってされて……気持ちせり上がってきてる\n……あっ、くんっ、んくんっ……はふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ……いーよ……ほら、出しちゃうでしょ？　チンポがもう出したいー\nって、尻尾の中でビクビクしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパの射精……いっぱい見せて♪　情けない顔して、気持ちい～の出すトコ\n……全部、オープンにしちゃおっ、えいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはっ……！　あふっ、出た出たっ……気持ちいいの、いっぱい出てるねっ\n。チンポから一生懸命射精してるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503136" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、ちっちゃくなってもすごい量……絶倫パパはこうじゃないとね…\n…んー、ちゅぷっ、うん、おいし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふっ、ヤムもミルクがぴゅって出てきちゃったし……おっぱい吸うの上手\nだったねぇー、よしよし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、先っぽジンジンする……危うくヤムもイカされちゃうとこだ\nったわ……危ない危ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、チンポ収まったね。いっぱい出せてえらかったねぇ、いい子いい子し\nてあげるからねー、パーパっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さて……これで終わりかなーって思ったんだけどぉ。どうも、このチンポく\nんは、それじゃ物足りないって感じだねぇー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「にひひっ、いいよー、パパ。素直になっちゃお？　まだまだ、チンポシコシ\nコして欲しいんじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503202" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それじゃあ……言わなきゃいけないことってあったでしょ？　ねっ、パーパ\n。さあ……このチンポ……どうなりたいのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はーい、ちゃんとおねだり言えましたー。それじゃ、パパのチンポ……もっ\nとしてあげちゃうからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……出したばっかりだから、まだまだすっごく敏感になってる。ちょっ\nと触るだけでも、ピーンとしちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「は……ふっ、そういう敏感なチンポをイジメちゃうのが、また楽しかったり\nして……どう？　こすこす……くちゅくちゅ……いい感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まだまだ、ヤムの尻尾責めは、もっとすごいからね？　チンポの先から付け\n根のとこまで、じーんわり感じさせたげるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それに……今度はこっちもしてあげよっか……んふふっ、可愛くぷらぷらし\nてる……キ・ン・タ・マ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あははっ、今……ドキってした？　チンポがぴょこんって跳ねちゃってるの\n、可愛すぎでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーら、大丈夫。ちゃんとよしよししてあげるから。やっぱりちっちゃいパ\nパの方が可愛いかもなんて……んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……！　くぅぅ……また乳首……不意打ちでしてくるなんて生意気じゃ\nない……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ……！　反対側も……指でっ、あっ、コリコリって……やらっ、あっ\n、またミルク出ちゃうっ……ひぁっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なるほどね……可愛くなっても、基本のスケベはやっぱりパパのまんまだし\n……そーいうことならっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503213" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、どぉ？　ヤムの尻尾がまたぎゅーっとチンポに巻き付いて……ずり\nずり皮がめくれてくるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅってお汁の混ざるエッチな音……いーっぱいさせちゃってるね\nっ。ほれほれ、こーいうのがいいんでショ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「手加減してたら、また生意気なことされちゃうかもだし……ここはしっかり\nチンポに分からせてあげないと……ねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、また……先走り……じわじわ出てる……さあ、もう我慢したっ\nてムダだし……いっぱい出しちゃうしかないよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「きゃふっ！　んんっ……くっ、ヤムも……マジでイキそっ……だけどっ！　\n先にイッたり、しないしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503218" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んぁっ……あくっ……んんんっ……！　もう限界なのは分かっ\nてるしっ……あと、もう少しだけっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらっ……チンポッ……さっさとイッちゃえっ！　ぎゅーってっ……んぁぁ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃはっ！　また出てきたっ……パパのせーえきっ、まだまだ濃いのっ……\nドロっと出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503301" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……気持ちいい？　いーよぉ、もっとシコシコしたげるから……奥にあ\nるの……全部出しちゃおっか……ふふっ、そうそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503302" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「蕩けた顔しちゃってぇ……ちっちゃいパパのそーいう顔見てると……なんだ\nかゾクゾクしてきちゃうし……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーら、もう残しちゃダメだからね？　ヤムがぜーんぶピュッピュさせたげ\nるから……出し切っちゃお……ねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ふは……たくさん出せたねー。ふふっ、いーこいーこ。ヤムおねーさ\nんの言うコト、全部聞けてえらかったねぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503305" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「にしても……ちっちゃくなっても、チンポのすごさは何も変わってないのヤ\nバすぎでしょ。ふふっ、まーだビクビクしてるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ん？　これがいつ戻るか？　あー、そうだねぇ……うん、丸一日ぐらいたっ\nたら元に戻るんじゃない？　多分……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「や、だいじょぶだいじょぶ、ちゃんと戻るからさー。どうせ慌てたって、効\n果が早く終わるとかないんだし、落ち着いてさー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503308" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「何なら、今しかできないコトとか、もっとしちゃってもいいんじゃない？　\nん？　どーいうことかって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっふふー、分かってるクセにぃ……それとも、直接教えたげた方がよかっ\nたり？　いいよ、ヤムは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0503310" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_01_15" ]},
		{"command":[ "WAITINPUT" ]},
