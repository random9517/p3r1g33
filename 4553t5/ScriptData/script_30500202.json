		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フフ……ようやく私の正義をあなたに刻み込む日がやってきたようですね。\n私がこの日をどれだけ待ちわびていたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「鈍感なあなたには知るよしもないでしょう。でも、いいのです。あなたのよ\nうな愚鈍な男には……口で言うより、身体に叩きこむ方が早い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「さ、お脱ぎなさい。そしてすぐにでも繋がりましょう……。はぁ、はぁ……\n。え？　私が楽しそう、ですか？　当然でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「先ほど言ったではありませんか。この日をまちわびていた、と……。毎日毎\n晩、あなたを想って一人、肉体を慰め続けてきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……もう逃がしません。私はこうなるとしつこい女なのです。私に目をつけ\nられたこと……感謝しつつも恐怖してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ん……。はぁっ、はぁ、はぁ……。いつ見ても、逞しく強靭なペニスですね\n……。これで何人もの女を泣かせてきたのでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はたして私はどうでしょうか……。んん、早く……早く確かめてみないと…\n…。フフ、見えますか？　私のアソコ……もう濡れているんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたのモノを見て、期待して……潤んでしまっている……。ああ、いけな\nいペニスですね、女を狂わせる魔性のペニス……罰が必要です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……抵抗しなくていいのですか？　このままでは私の中に、膣内\nに入ってしまいますよ……？　ほら……拒むのなら早くしないと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……そうですか。であれば容赦はしません。遠慮なくご馳走になるとしまし\nょう……。挿入しますよ、よーく見ていなさい……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ッぁっ……♪　ああ……す、すごい……ぃ……♪　なんという肉厚な……ァ\n……ああ……♪　カリ高で、反り返っていて……んああああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んぉおお、こ、れは……ああ♪　悪の波動、を感じるペニス、です……ああ\n、悪い、悪いペニス、女をおかしくする洗脳兵器……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私が成敗してあげなくちゃあ……。んあっ……あっあっ……おぁふぅう♪　\nなんということ……ちょうどいいところにひっかか、る……んんぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ああ、ダメ、だめ、だめ……！　私の肉ヒダを強引にかきわけて……んんぁ\nあああ♪　ズッシリと重いペニスが、……ぁ♪　出入りして……おおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こんなのっ、こんなの堕ちてしまうぅ♪　あっうっ、うううぅ♪　馬鹿みた\nいにデカくて硬いだけのバカチンポぉお……気持ち良すぎますぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んっ……あはっ……♪　あっ……あっあっ……！　わかりますか……？　私\nの熱くてヌルヌルした蜜壺で……あなたのモノが愛撫されているのが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私にはよくわかりますよ……。はぁっ……あなたのペニスの大きさ、太さ…\n…はぁあ♪　そのでこぼことした形、すら……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「粘膜に伝わってきて……たまりません。私の中の雌が呼び覚まされる感覚…\n…この極上の快感、何事にも代えがたい唯一のもの……んん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こらっ、何を惚けているのです！　気持ちがいいのはお互いさま……だから\nといって、快楽を人任せにしてはいけません！　動きなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「まったく……。せっかくあなたを見直したというのに……愚図なところは変\nわらないのですから……。って、あっ……♪　そう、そうですよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そう、やってぇ……女の弱点を！　粘膜を無理やりに犯すんです！　あっ！\n　あっあぁっ！　腰を揺らし、て……貪るように……んんんっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「生意気なメスをねじふせるように、傲慢に腰を振りなさい……！　っ……は\nぁっ、はぁ、はぁ、はぁ……フフ……物覚えは悪くありません、ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そう、それが私を悦ばせる方法……。んふ……、そのまま……そのままぁっ\n、ピストンを続けなさい……止めることなく……んぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フフ、フフフ……♪　なかなかやりますね……、ですが、あっ♪　主導権は\nこちらにあることをお忘れなく……んっ、んっ、いきますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私の腰使い……あああっ、乱れた吐息、甘い嬌声にうねる膣ヒダ……。今だ\nけは全て、あなたのものなのです。せいぜい使いこなすのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……と、余裕ぶっているわりに膣内の余裕がない……？　な、何を言ってい\nるのです……私はいつも通り、あっ！　冷静で……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あ、はぁっ、はぁあっ……♪　私が話している時に、あっ、下から突くのは\nやめ……。あっ！　そ、そこ……そこは……ああ！　ああっあっあっあぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ゆ……油断しすぎました……。んっ……あ、あなたのような相手に軽くイか\nされるだなんて……。こちらも本気で臨まねばなりませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それ……それ……！　フフフ……！　他の女とは感触が違うでしょう？　熱\nいのに冷たくて……はぁっ、蠢くのに吸い付いてきて……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたは私の思うがままにペニスを勃起させ、動かし、情けなく精を吐き出\nせばいいのです……。そぉれ……！　どんどん締め付けていきますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んっ、んんん……ああああ♪　あっ♪　それで反撃のつもりですか？　はぁ\nっ……あぁんんっ……いいでしょう……勝負ですね、んっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「どちらが先に果てるか……真剣勝負です。あっ……！　私、の……正義の味\n方おまんこと！　あな、たのガチガチになったおちんぽ、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「一騎打ちっ……一騎打ち、で……！　はぁあああああっ……♪　肉と肉とを\nぶつけあって……。あふ……！　んんんぅっ……んんんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……っあっ！　あっあっあっ！　……フフ……どうやら、二人同時に達して\nしまうようですね……。あっ、いいですか、イキますよ、イキ、ますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「っあっ！　あっああああああっああっ……！　出し、て、出して出して……\nそのまま！　絶頂している私に中出ししなさいっ、ああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ッん～～～～っ……！　なんという凄まじい濁流の、勢い……っ。蜜壺から\n逆流しそうな、ほど……ああ……出てる、出ています、精液が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「っぅうう……！　ああ……これ、これは……ああ……。熱い……いえ、あた\nたかい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「これがあなたのぬくもりなのですね……。……い、いえっ、別に……！　情\nにほだされたわけではありませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたとする性交渉は悪くありません。そ、そうですね……。一日に一度ほ\nどなら、いつでもお付き合いしてさしあげようかと思案する程度、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「つまり何を言いたいかというと……。も、もう少しこのまま繋がっていたい\n……ということです。い……言わせないでください……。もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……それで？　まだこの忌まわしいペニスは、まだまだ満足していないよう\nにお見受けいたしますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もちろん、私のアソコも、まだまだあなたを受け止め足りないと申しており\nます……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「で、いかがいたします？　私は必要ですか？　それとも不要ですか？　はぁ\n……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「え？　そっちが身体を動かしている、ですって？　それが、どうかいたしま\nしたか？　ふぅ……んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こうして大きく膨らんだ状態を、利用しない手はありません、からね……は\nぁ、ふぅ……少しでも、私の膣の味を、覚え込ませて、おかねば……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……出したて精液が、中で掻き混ぜられて……ん\n、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「精液が、泡立ってる……アソコの奥で、ネットリと塗り伸ばされていく……\nはぁ、ふぅ……んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぅ……勝負はまだ続いている、ですって？　くぅ……精液を注ぎ込まれた\n状態から開始するだなんて……卑劣な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……まあ、ちょうどいい、ハンデです……私の正義は、ん、あ\nぁあん……邪悪なチンポにみすみす破れたりは……あ、あぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、あひぃ……中で、チンポが暴れてる……あっ、ぐぅ、ひや……はぁ\n……あぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いえ、まだイッて、ません……マスクはせずとも、私はマスク・ザ・ブルー\n……この程度でギブアップはしません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、ううぁ、はぁ、はぁ……膣内が、捩れてる……チンポに中身が持っ\nていかれ、ちゃうぅ……ぐぅ、ひぁぁ、ふぐっ、ひゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ま、負ける、ものかぁ……ぐぅ、ううぅあ、はぁ、はぁ……\nあぁぁん……腰が、止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「チンポを、膣が勝手に締め付けていく……あ、ああ……マンコが、正義を貫\nこうとしてる……はぁ、はぁ……ひぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「おのれぇ……ん、ああん、はぁ、はぁ……あ、あなたも腰を使いなさい！　\n人任せにするなと、さっきも、んぐぅ、言ったでしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「お互いの力を拮抗させてこそ、はぁ、はぁ……戦いを通じて、ぐっ、んはぁ\n……成長できるというもの……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「さあ、お互いの力を称え合いましょう……はぁ、ふぅ……あなたの悪チンポ\nと私の正義マンコ……今度こそ、どちらが上が、ハッキリさせるのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あああ……イキ、そう……はぁ、はぁ……ですが、ぐっ、うう\n……負ける、ものか……はぁ、ぐぅ、あぁぁあん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「だ、駄目っ……負ける……そんな、はぁ、はぁ……この、私が、正義が……\nオマンコが、もう……んんっ、ひゃうぅ！　ひぐぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ひっ、やっ、駄目ぇ……今イッてるのに……精液が……あ、ああ……悪の汚\n物が、私に……きゃうぅ、ひやぁぁぁぁあん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んはぁぁ！！？　はぁ……はぁぁあん……ま、また、中にっ！　ぐぅ、うあ\nぁ……勝利の、種付けされちゃってるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んひぅ、はへぇぇ……す、すごい……さっきよりも、たっぷり出されてる…\n…はぁ、はぁ……はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「オマンコの中、白濁液が駆け巡って……あっ、あひぃ……あああ……ザーメ\nンが、絶頂マンコ、いっぱいにされてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ひぐぅ！　ひゃうぅぅ！？　イクのが、と、と、とまりませんっ！　くぅ…\n…ひぐぅ……負けてる……私、チンポ負けしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はー……はひぃぃ……あ、温かい……また、あなたのぬくもりが、お腹の中\nに染み渡っていく……はー……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「くぅ……こ、こんなことで、私の優位に立てただなんて、思わない、ことで\nすね……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ですが、んん、ふぅ……こうして、しのぎを削ることは……やはり悪くあり\nませんね……はー……あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「溢れてる……繋がったところから、いっぱい滴ってる……ああ、さっき出さ\nれたネットリ精液……んふぅ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「これで、ようやくペニスも、力を失いつつあるようですね……はぁ……ふぅ\n……危なかった……これ以上は流石に続けられませんでしたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「続きは、また日を改めましょう……今日は一歩、及びませんでしたが……必\nずあなたの邪悪を調伏してみせますからね……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ひやぁぁぁ！！？　あ、あああ……はぁ……はぁ……い、いきなり、チンポ\nを抜かないでぇぇ……あぁぁああん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「引っこ抜かれた刺激で、ま、またイッちゃ……あへぇぇ……駄目ぇ、駄目駄\n目ぇ……オマンコ、パックリと口を開けちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はー……はー……オマンコの中に空気が、入ってくるぅ……あああ……正義\nのオマンコの奥から……ドロドロが溢れてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ううぁ、あぁあ……精液、熱い……出したて精液が、肌に染み込んで……ぐ\nぅ、ふぅ……オマンコからも、どんどん滴って……ひうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ず、随分、出してくれましたね……正義を汚辱して、喜んで\nいるのでしょう？　はぁ……はぁ……酷い人ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ん、あぁあん……駄目ぇ……精液の匂いで、イッちゃいそう……はー……は\nー……はへぇ……ああ、呼吸するだけで、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……今日は、随分してやられましたね……途中までは互角だと\n、思っていたのに……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あ、ああ……精液が、肌の表面を滑り降りて……はぁぁん……ゾクゾクしち\nゃうぅ……ん、んん、ひふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぅ……一度イクと、止まりませんね……はぁ、ふぅ……邪悪なチンポの、\n邪悪な精液……恐ろしい威力、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「次こそは……必ず、悪に打ち勝ってみせます……ですから、ちゃんと私を呼\nびなさい。絶対に、逃しませんからね……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0204410" ]},
