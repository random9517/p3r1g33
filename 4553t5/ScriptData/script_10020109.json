		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うひゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ……！　ルナテミス様が、いつもにも増して強い……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010113090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃまあ、勉強させられすぎてテンパっちゃってるからなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私は！　私の頭は！　腐ったミカンじゃなぁーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ！　逃げた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああ～ん！　もう！　なんでこんなことになっちゃうのよぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まったくだ……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう思いながら、俺たちは学園内に逃げたルナテミスを追う。するとそこには\n――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おい！　貴様らいったいなにをやっている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113090001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん、大丈夫ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113090001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うるさいよ！　あんたたちには関係ないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「関係ないことがあるか！　今、ルナテミスを逃がしたら勝負にならないぞ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113090002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「わかってるよ！　だから捕まえて、勉強の続きをするんじゃないか！　邪魔\nするんじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ！　待て、貴様ら！　行くぞ夜叉！　こちらが先にルナテミスを捕まえる\nぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113090003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「どうして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113090002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あの子はまだ活用表を覚えていない！　先に捕まえて、覚えさせるんだよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113090004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうはいくかい！　こっちは練習問題の途中なんだよ！　ダイヤナ！　行く\nよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「む！　先にこっちとやり合う気か！？　いいだろう！　行くぞ夜叉！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113090005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁあああ……めんどくさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ほんとに……お姉ちゃんったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113090003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
