{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0154" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、またまりあ時空が動き出した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まりあ時空？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクがつけた仮称だけどね。『古時計と一体化し、その力を身に着けたまり\nあが作り上げた願望の世界』って名前だと長いだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「たしかに。それで、まりあ時空ではなにが起こっているの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115730002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「まりあ時空では、主であるまりあの戦闘力が数倍に跳ね上がっている。そし\nてまりあ自身もいろんな能力を身に着けているんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「侵入すれば、すぐに見つかる。見つかったらルナテミスたちみたいにすぐに\n弾きだされる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうすればいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115730003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「弾きだされずに侵入できるような、時空のワレメみたいなところが見つかれ\nばいいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わかった。見つけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115730004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「簡単に言ってくれるね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730006" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「見つけて！　今すぐに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115730005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「わかった、わかったから！　落ち着いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730007" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふぅ……。こんなに想われているカツマくんが、うらやましいような、うら\nやましくないような……複雑な気分だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115730008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "まりあは屋上から飛び降りた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "姿は見えなくなったが、きっと校庭にいるはずだ。俺は急いでそこへ向かう。\nすると、校庭にはたしかにつきみたちがいた！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ、ここにはいないのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「むだだっちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なっ、なんだ！？　ビリビリしてるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「帯電しているみたいだね……どういうわけだかしらないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんは渡さないっちゃ……。それに、あなたたちにカツマさんを見つ\nけることは不可能だっちゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115730002" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いったいどういうことだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、姫様、アナザー！　俺はここだ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにを言ってるんだ、カツマを見つけ出す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115730002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「そうだよ、お姉ちゃん！　一緒に本部に帰ろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115730002" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおい、こいつら、俺が見えていないのか？　たしかにこんな校庭の隅じゃ\n気づかないか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "よし……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「邪魔するヤツは、許さないっちゃーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115730003" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスたちの前に飛びだしてやろうとしたところで、まりあがルナテミス\nたちと戦いはじめた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}