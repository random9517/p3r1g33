{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「通信が繋がっている間に、カツマからの返信を逆探知しておいた！　発信源\nはこちらだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こっちには、何があるの？　だんだん、装飾が豪華になってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おそらく玉座の間だ。だとするとカツマが危ない！　急げ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、無事でいて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「エファ……！　どうか、おまえたちも無事でいてくれ……！　すまない、こ\nんなときに手を貸せなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あのとき母上様は、皆を救うために犠牲になったというのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それなのに、わたしはなんの役にも立っていない！　それでいいのか！？　\n私は……私はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ルナ。いいんじゃよ、それでいい。悩むべき時は大いに悩み、迷うがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そのことが、いつかきっと役に立つ日が来る。それは意外と……もう、目の\n前に迫っているかもしれぬぞ？　ふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うわああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Мサムライ" ]},
		{"command":[ "SETTEXT", "「アイエエエエエエエ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「ふふふふ、どうしたのかしら？　お前たちの実力はその程度？　ふふふふふ\nふ……あーっはっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＳＭＮＲ" ]},
		{"command":[ "SETTEXT", "「うわあああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00009701_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00009801_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00009901_01", "3", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いかん……！　実力が違いすぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんてこった！　みんながルナテミス・ダークひとりに翻弄されてる……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんな！　しっかりするんだ！　くそっ！　俺も……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「やめておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にか俺の背後にまわっていた刻の女王が、こちらの肩に手をかける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前のその力――エンブレム・シンテシスは、あのような役立たずどものた\nめにあるのではない。もっと、有意義な使い方があるはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なにを言ってやがる……くそっ！　体が……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうなってんだ……！？　体がピクリとも動かねえ……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あんな奴らは放っておけ。おもちゃ代わりに、ルナテミス・ダークにくれて\nやるがよい。そしてカツマ、お前は……私の元に来るのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふざけんな……！　誰が、お前なんかと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうか……？　もちろんただで、とは言わぬぞ。お前が一番知りたかったこ\nとを教えてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺の知りたかったこと……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうだ。お前の母親のことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺が物心つく前にいなくなったおふくろのことを……こいつが知ってるっての\nか？　まさか！　そんなことあるわけない。ハッタリだ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや……待てよ！？　おふくろがいなくなった理由に、こいつが関わってると\nしたら！？　それどころか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさか、お前が俺のおふくろを殺したって言うんじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「殺した……？　私が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580006" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0168" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうではない。私がお前の母なのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんだって！？　う、嘘だ……嘘だ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私が、お前の母だ。我が子よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなの嘘だ……嘘だああああああーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}