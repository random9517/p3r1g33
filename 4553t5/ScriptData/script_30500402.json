{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。すみません、隊長。気をつけてはいたのですが、作戦中\nにエネルギーが切れてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「基地まで運んでいただきありがとうございます。ですが……なぜこの部屋な\nのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「しかも、あなたの膝の上に座らされるなんて。え？　いまからエネルギーチ\nャージを行う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「な、なぜペニスを露出させているのですか！？　まさかチャージの方法とい\nうのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404104" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……そうですね。いまはすぐにでも回復し、戦線に復帰しなければ。では、\n隊長お願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404105" ]},
		{"command":[ "SETCHARA", "0", "char_00005004_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ん……っ！？　ま、待ってください。隊長、いまペニスをあてているのは、\n私の肛門ではありませんか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「膣ではないのですか？　それに、肛門に挿入するだなんて、は、初めてで…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そもそも、本当に肛門への挿入でエネルギーをチャージできるのですか？\nチャージできるなら、肛門である必要など……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こ、こっちの方が効率がいい？　そういうことなら、仕方ない……のでしょ\nうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ただ……繰り返しになりますが、お尻は初めてなので……。優しく、お願い\nします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んっくぅうううぅぅぅっ！！　おっ、おひっ、おひりにずぶっと、隊長のお\nちんぽがぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、熱いおちんぽが……お尻に、お尻……んっ、ああ……焼ける\nっ、こんな感触、知らない……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そんなっ。お尻に挿入されただけで、絶頂したなど……。んっ、そんなこと\n、ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こんな……。んはぁ……んっ、んくぅ……。お尻を、無理やり広げられるよ\nうな感覚が……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「気持ちいい、はずが……。はぁ……はぁ……。んんっ、あっ、んくぅ……っ\n！　んふぅ……はふぅ……?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ゆっくりと、腰をゆすられて……んぁっ、おちんぽが、お尻の中をゆっくり\nほぐして……くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽが、ぐりぐりと、中を……。んっ、んんっ、あっ、んはっ、\nああ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「お尻を、おちんぽでほじられて、気持ちよくなんて……。はぁ、はぁ……ん\nっ、んくぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こ、肛門への刺激に慣れてきたんじゃないかって？　このような刺激に、慣\nれるはずが……んふぅっ、あっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「お尻の穴が、勝手に……っ。んっ、んんっ、動いて、あなたのおちんぽを咥\nえて……あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「おちんぽが、お尻をひろげる動きから、下から突き上げるうごきにぃっ！\nんっ、ああっ、待ってください、それっ、あはぁんっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「お尻の中を、おちんぽがっ、んぁっ、ああぁっ！　こすれて、んっ、ああっ\n、硬いのがぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それ、だめ、ゴリゴリと……んぉっ、おおっ！　おちんぽ、おっ、おお……\nっ、んっ、んふぅうっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404123" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「おぉ、お尻が熱いっ！　ジンジンと、疼くぅ……っ！　んぁあっ、ああっ、\nはぁっ、はぁあんっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「か、感じてっ、お尻でっ、おっ、おひりぃっ?　んくっ、ふぅっ、おっ、お\n尻の中、おちんぽで蹂躙されてぇっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「正義の味方が、お尻の穴をおちんぽに犯され、か、感じまくるなんて……。\nあ、あってはならない……のにぃ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「激しくずぼずぼ、お尻に、ピストン……っ！　こんなの、耐えられない……\n腰が勝手に、動いてしまいます……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くはっ、ああぁっ！　中で、オチンポ膨らんでぇ……っ！　ますます大きな\nおちんぽが、熱いおちんぽが、お尻っ、出たり、入ったりぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああっ、気持ちいい……っ！　お尻っ、お尻で、あなたのおちんぽを感じて\nっ、気持ちよくなってしまってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あっ、あぁあっ！　ますます激しく、お尻を、犯して……んくっ\n、溶けるっ、お尻溶けるぅっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「おっ、おお……んっ、おぉ……っ！　お尻なのに、オマンコみたいに感じて\n……んぐっ、最初は苦しいだけだったのに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「嬉しそうに、あなたのおちんぽを咥えてしまっています……！　んぁあっ、\n大きなおちんぽを、全部、のみこんでしまって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404132" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「中を、くねらせて、おちんぽを射精させようとしてしまって……っ！　んぁ\nあっ、あなたも……イキそうになってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「パンパンになったおちんぽが、お尻で暴れて……っ！　あっ、ああっ、イク\nのですね、お尻に……射精……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「私も、イキます。正義の味方なのに、お尻を犯されてイッてしまいます……\n！　あなたに、中出しされながら……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　あっ、あああぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　イ……ッ、くぅうううぅぅぅ～～～～っ！！　熱い精\n液がっ、注がれるっ！　どぴゅどぴゅたっぷり、お尻にぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……お尻で……イッてしまいました……。隊長の熱い精液で…\n…お尻の中……いっぱいに、されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404138" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「なんて、快感……。頭の中が真っ白になって……ほかのことなど忘れてしま\nいそうになるほどの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さて……もうエネルギーは十分チャージされましたね。隊長のいう通り、こ\nちらの方が効率が良かったようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それでは戦線に……って、なんですか隊長……んぁあっ?　も、もう十分で\nす。これ以上、する必要は……あぁんっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「イッたばかりのお尻に、ま、まだガチガチのおちんぽが……あはぁっ?　こ\nすれて、んっ、声が……あぁっ、あぁんっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404202" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そんな、またずぽずぽ、お尻ぃ……んっ、おおぉっ?　さっきより激しく犯\nして、るっ、んっ、んくぅうっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「私のお尻が、そんなに気持ちいいと……んっ！　だから何度も突き上げを、\nお尻に……ぃひぃいいっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、お尻をおちんぽにめちゃくちゃにされて、また、気持ちよく\nなってしまう……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「エネルギーは、充填されているはずなのに。お尻犯されて、感じて、身体か\nら力が抜けてしまいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くふっ、んっ、あはぁんっ?　ずんずんと、下からぁっ！　お腹の中を揺さ\nぶるような突きあげっ、んっ、んくぅんっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404207" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「極太のおちんぽに、お尻、おひっ、突かれて、かきまぜられてぇっ！　んっ\n、あっ、あっ、あっ、ああ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「この衣装に相応しい、ケツ穴でよがる変態ヒーローだなんて、言わないでく\nださい……んぁっ、はぁあっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「だって、気持ちいいんです。お尻を、おちんぽで犯されるのが、気持ちよす\nぎるのが悪いんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたのおちんぽが狂わせる。私は正義のヒーローなのに、お尻の穴の快楽\nに溺れてしまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んひぃっ?　はぁっ、ああっ、もっともっとぉっ?　あなたの熱いおちんぽ\nで、お尻の穴、溶かしてぇっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404212" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああっ、もっと下品に？　淫らに？　んっ、お尻の穴ではなく、け、ケツ穴\n……ケツマンコぉ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「正義のケツマンコを、あなたのおちんぽでほじくり犯して！　また、たくさ\nんエネルギーを、射精してくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んぉおっ、おおぉおっ！　おちんぽ膨らんで、ケツマンコいっぱいになるぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んぉっ、おおっ、んふっ、ほぉおおっ！　おひっ、ひぃいっ、熱いおちんぽ\nが暴れまわって、ンッ、ひっ、かひぃいぃんっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「いっ、いっ、イクイク……ッ！　イクッ、ああっ、イかされるっ！　ケツマ\nンコ、イクッ、イッてしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404217" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああっ、締めますっ！　あなたのおちんぽがたくさん気持ちよくなるよう、\n正義のケツ穴しっかり締めますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「たくさん射精して、ケツ穴で感じまくる正義のヒーローに、思いっきり精液\nを放ってくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　ピストンの速度が上がるっ、んぁっ、おちんぽ膨らんで\n、精液こみ上げてくるの感じる……！　わ、私もぉ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んぃいっ！　イクッ、イッくぅうううぅぅぅうううう～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んはぁあっ、ああぁっ、熱いっ！　また熱くて、大量の精液がケツマンコに\n中出しされて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁっ、溢れるっ！　ケツ穴締めないと、溢れてきそう……んひぃいっ?　\nお尻の壁に、精液が染みるぅ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、おちんぽがビクンと震え、何度も精液の塊を、まだ、射精し\n続けてます……んっ、んくぅっ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404304" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ケツ穴……精液で満たされて……。はぁ……はぁ……。まだ、イッてる……\nお尻が、ヒクヒクし続けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたのおちんぽを、きゅうきゅうと搾りつづけて、しまっています……。\nんくぅ……自分の意志ではなく、お尻が勝手に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああ……はやく、戻らないといけないのに……。あまりに気持ちよすぎて、\nまだ身体に力が入りません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んんっ！　な、なんですか！？　私が動けないことをいいことに、も、もっ\nとお尻を犯すつもりですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404308" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁんっ?　私のお尻を、この機会にとことん開発してやるですって！？　\n抵抗できないからって、調子に乗るのは結構ですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「私がケツ穴狂いのドスケベヒーロ―になってしまったら、ちゃんと責任を取\nってくださいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404310" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁ～～～～っ?　いっ、イクッ、イッく……！　\nイクッ、イクッ、イッ……くぅうううぅぅぅ～～～～っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁあっ、くはぁあっ、凄い勢いで精液が噴きあがって……！　わたしの身\n体に、ぼたぼた、降り注ぐ……んぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああ……っ。ドロドロの精液を、肌で感じて……。その熱と重みで、イク…\n…！　なんども、イかされて、しまいます……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ん……ああ……。お尻が……。ンッ、力が……入らなく、なってしまって…\n…。んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404404" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「先ほど中出しされた精液が、逆流して……くるぅ……。んくぅ、だめ……肛\n門が、締まらないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「んひぃいっ?　ああ、溢れる精液を押し戻すように、またおちんぽをケツマ\nンコにぃ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「おちんぽで栓をされてしまったら、お尻があなたのおちんぽの形になって、\n戻らなくなる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ケツ穴も、開きっぱなしになってしまったら……どうしてくれるんですか…\n…んぁあっ、あはぁ……っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0404408" ]},
		{"command":[ "SETIMAGE", "0", "still_00005004_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「また、ぐりぐり……んぁあっ、ケツマンコほじられっ、んへっ?　あ、ああ\n、頭の中が、真っ白にぃ……っ?」", "NORMAL" ]},
