{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「隊長、私をわざわざ呼び出して、どのような用件だ？　次の戦いについて…\n…ではなさそうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「パワーアップ……？　ああ、もちろん、必要だ。私は黒衣の死神として、よ\nり多くの悪を滅ぼすことしか考えていないのだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「……隊長のモノを、胸で挟めだと？　……正気か？　それのどこがパワーア\nップに関係あると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「いや……最近のことを振り返ると、一概にそれをでたらめだと否定できない\n。くっ、しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「……いいだろう。私は悪との戦いに身も心もすべて捧げて生きている。今さ\nら、その程度のことに臆することなどない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「だが、死神と呼ばれる女を相手に、お前は興奮できるのか？　……いや、聞\nくまでもないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「まったく、何だ、その股間のモノは……うっ、ビクビクと震わせる必要はな\nいだろう！　……驚かせるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「仕方ないだろう、初めて見るのだからな、そのようなもの。……それなら、\nもっと間近で見て慣れろ……だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103108" ]},
		{"command":[ "SETCHARA", "0", "char_00011001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「わかった。より多くの悪を滅ぼすための力、必ず手に入れてみせる……その\nためなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「それにしても……本当に奇妙な形をしているものだな。色も異様に赤黒く、\nそれにこの形……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103110" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……んっ、臭いも強烈だ。鼻の奥までツンと染みるような……アン\nモニアのような、生もののような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「クンクン……あぁ、そんなに不快とは感じない。不思議だ……むしろ、もう\n少し嗅いでみたくなるような……クンクン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁんっ……さて、これを胸で挟めばいいのだな？　んっ、あぁ、多少熱い\nが、問題ない。それくらい……んぅっ、はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「もう少し力を入れて、胸を寄せろ……？　ああ、お前がそういうのなら、構\nわないが……こうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ふぁっ……あぁ、急にふくらんで、またビクッと大きく震えたぞ。大丈夫な\nのか、これは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「気持ちがいい証……？　大きなおっぱいがふわふわで最高？　そういうもの\nなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「こんな胸、戦いでは邪魔でしょうがないだけなのだが……隊長に褒められる\nと、悪い気持ちではない……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ぎゅっと、もっと強く……んっ、どうだ？　潰れた胸の谷間に、お前のモノ\nが完全に埋まったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「このまま胸をこねるように動かす？　ああ、ほら、どうだ？　こんな風に、\n大きく揺らして……はぁ、はふっ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「凄いな、私が胸を動かせば動かすほど、それに応えてお前のモノも大きくな\nっていく……んっ、痙攣も激しく……はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「先から透明の汁が垂れて、臭いも強くなってきた。くぅっ、はぁ、この臭い\n……んっ、はぁうっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「嗅いでいるだけで、胸の奥が……お腹の奥がジンッと熱く疼いて、不思議な\n気持ちに……くふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「これがパワーアップに繋がる感覚なのだろうか。わからないが……もっと味\nわってみたいと思ってしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んっ、これの先から垂れてくる透明の液体を、胸の谷間に塗りたくるように\n動かせと？　そうすれば、スムーズに動ける……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「……先走りのチンポ汁……と呼ぶのか。くっ……んっ、妙に恥ずかしい呼び\n方だが、そう呼べという命令なら……はぁんっ、あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「先走りチンポ汁、私の胸に……はぁんぅっ、あぁ、おっぱい……おっぱいマ\nンコに塗りたくってっ、くっ、はんんっ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「くぅっ、恥ずかしい言葉を口にすればするほど、胸の……お腹の疼きも強く\nなる。頭も、真っ白に……ふぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「胸、おっぱいを揺らすと、グチュグチュと卑猥な音が大きく鳴って、お前の\nモノ……チンポがますます大きく……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁふっ、あぁ、隊長……気持ちがいいのか？　息が随分と荒くなってきて\nいる。……そうか、私のおっぱい……気持ちがいいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「なぜだ、そう言われるだけで、胸が弾んでしまう。こんな気持ち、今まで味\nわったことがない。不思議な……はふっ、はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あぁ、胸っ、チンポと擦れるだけで、くすぐったくて、熱くて、気持ちが\nいい……私もっ、ひぃっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「乳首……先っぽも尖ってっ、はふぅっ、あぁっ、少し刺激されるだけで、痺\nれるような……はふっ、いぃっ……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んぅっ、チンポの汁、どんどん溢れて、濃くなっている。私の胸が、隊長の\nチンポ汁の臭いで染まっていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「先っぽの穴が開いている。何か、出そうな……んふっ、あぁ、くる、私も何\nかがお腹の奥からこみ上げてくるようなっ、ふぁああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んくううっ、ひゃうっ、ああっ、何だ、これは……熱いっ、んぅっ、熱い汁\nが顔にっ、おっぱいにっ、あくぅっ、んんー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁ、んんぅっ、あぁ、止まらない……もうドロドロに染まって……ひぃっ\n、あああっ、熱い……身体がぁ、あんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、や、やっと……止まった……はふっ、あぁ、凄い量じゃないか。\nこれ……はぁっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ヨーグルトのように真っ白でドロドロの液体……精液……これが男の精液…\n…はふっ、隊長の精液で、顔も胸も染められている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、これで強くなれたのか、私は……？　わからないが……決して不\n快な感覚ではない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ、隊長がそういうなら……また、こういう特訓に付き合おう。まったく\n、こんな死神相手に……物好きな男だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「おい、隊長？　なにをしている？　特訓は終わったのではないのか？　なに\n？　まだ満足していない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「つまりそれは、私のパワーアップに満足していないということか？　わかる\nのか？　どの程度パワーアップしているか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「つべこべ言わずに、もういちど胸でチンポを擦れだと？　仕方ないな……強\nくなるためなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「それに……まあ、この感覚は、私としても不快ではないからな。んっ……ん\nんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ああ……硬い……隊長のチンポは、相変わらず硬いな……それに、熱く、脈\n打っている……はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「こうして、胸を動かすと、隊長の硬いものが擦れて……はぁ……はぁ……\nんっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「なんだか、またお腹の奥がむずむずしてきた……なるほど……またパワーが\n湧いてきた、ということなのだな……んんんっ……！　んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ひゃぁん！　な、なにをする！　突然乳首に触るな……ああぁんっ！　あ、\nあ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「な、なんだこの感覚は！　まるで、乳首の先から電気が流れたような……ビ\nリビリと痺れるようなこの感覚……ひゃうん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「これが……第二段階の特訓だと？　この刺激に耐えてこそ、より強いパワー\nを得ることができると……な、なるほど……はぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああっ！　んんんんっ……くぅうっ！　こ、これはなかなかの刺\n激だ……！　だが、これに耐えてこそ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んんんんっ！　これに耐えて、隊長に精液を出させてこそ、特\n訓の効果が……はぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、ん、ん、んんんっ！　はぁあああ……あんっ！　んっ！　胸で……挟ん\nで……こね上げ……んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あん！　こ、これはどうしたことだ……！　乳首だけでなく、隊長\nのチンポを挟んでいる谷間にも……はぁああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「谷間にも、電気が走る……！　お腹のむずむずが、さらに強まって……あ、\nあ、あああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「と、止まらない！　胸を動かす手が……隊長のチンポを擦る動きが、止め\nられない！　あ、あ、ああああっ……はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「すごい！　すごいぞ！　これが、私の新たなパワー……ぁあああん！　あ、\nあ、あ、はぁあああん！　んんんっ！　くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「隊長のチンポも、ピクピクしているぞ！　出るのか？　精子が出るのか？　\nいいだろう、出せ！　早く出すんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「わかっている、擦ればいいのだろう！　はぁああ……っ！　あ、あ、あああ\nん！　あんっ！　はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あああ……熱いっ！　チンポが、まるで焼けるように胸の間で熱く脈打って\n……！　んんんんっ！　はぁああ……っ！　ぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああああっ！　んぁああああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、あ、あっ！　出ている……っ！　出ているぞ！　隊長の、熱くドロドロ\nとしたものが……！　精子が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁっ……ああああ……胸の間が、熱い……！　それに、また顔に\nも飛んできて……はぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「ま、まだ……出るのか……っ！？　男の精液というものは、こんなにたくさ\nん……出るものなのか！？　んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……こほっ！　けほっ！　なんという匂いだ……！　思わず、\nむせてしまう……！　こほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ、んあ、はぁああ……やっと勢いが弱まって……。あ、あ、あああ……も\nう、終わりか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「それにしても……二回合わせて、こんなに出たのか。私はもう、胸も顔もベ\nトベトだ……ああぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「だが、これで私はより強くなれたのだな……？　いまひとつよくわからんが\n、とりあえず礼を言っておこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「……なに？　私がその気なら、もっと強くなれる特訓があるだと？　それは\n本当か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「うむ……わかった、次の機会にな。楽しみにしているぞ、隊長、もっと気持\nちのいい……いや、効果のある特訓をな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「あ！？　な、なにをする！？　突然腰を引いて……あ！　んあああああああ\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「せ、精子が……！　精子が噴き出して顔に……！　んんんんんっ！　はぁ…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「熱い精子が、顔に、胸に降り注ぐ……っ！　んはぁ……っ、ああああ……ん\nんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「い、いったいこれはどういうことなんだ……？　なぜ、急に顔にかけたりす\nるのだ……顔だけではない、胸も、腹までベトベトではないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「はぁあああ……全身に、生臭い刺激臭が……！　これは……すごい匂いだ…\n…はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「なに？　二度目は、精液を広範囲に浴びせたほうが効果が出る？　それで、\nこんな出し方をしたというのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00011001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「なるほど、そう言われてみると、このべたつき具合……いやらしくもあるが\n……パワーを秘めているような気もする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「だが、これで私はより強くなれた、と思っていいのだな？　いまいち実感は\nないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「なに？　疑わずに、粘り強く、何度でもこの特訓を繰り返すというのか。そ\nれによって、さらに効果が上がると？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクセリオン" ]},
		{"command":[ "SETTEXT", "「なるほど、それも一理あるかもしれん。それでは隊長。次の特訓を、楽しみ\nにしているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_110_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
	{"command":[ "EXIT" ]}
	]
