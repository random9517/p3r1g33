		{"command":[ "PLAYVOICE", "046_0104408" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「……身体にかけられるのが嫌とは言わぬが……。少々無礼であることは間違\nいあるまい……」", "NORMAL" ]},
