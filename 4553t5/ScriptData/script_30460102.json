		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あーっ！　ああああっ！　身体に精液をかけるじゃとぉ……っ！？　ああっ\n……ああっ、いやじゃ、いやじゃ、いやじゃあ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104403" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「膣内が寂しいままっ、あっ♪　ひっかけられた精液のぬくもりで果てるのは\n嫌……いや、なのに……ああああっ！　余韻だけで、あーっ♪」", "NORMAL" ]},
