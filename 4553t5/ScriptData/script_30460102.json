		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104216" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「わらわの誰にも見せぬ、誰も知らぬ秘所を……！　ぶっといチンポ挿入して\nおるピンクのおまんこを、あっ、見ながら抽送せよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104217" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ！　ああっ、ああそうじゃっ！　そこ、じゃ……そこっ、わ\nらわのおまんこ、そこじゃ、もっと突けっ、ああ、もっともっとっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104218" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「おまんこのヒダヒダをぉおお……あああっ！　その凶暴な男根でえぐれっ！\n　その太い肉茎で攻めよっ！　っああああっ、ああ、気持ちがいいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104219" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ……ああ……ああああ……！　ああ、隊長どの、隊長どの……\n！　またわらわ果てるっ、わらわ達するっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104220" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたも……そなたも共にゆくのじゃああっ！　わらわのっ、ああ、わらわ\nの処女膣内に、この穴にそなたの精を注ぎ果てよ！　あああああ！」", "NORMAL" ]},
