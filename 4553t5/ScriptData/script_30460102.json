		{"command":[ "PLAYVOICE", "046_0104210" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「わらわの肉穴に男根をからめとられている様を……じっくりその目で観察し\nながら……あっ♪　あっ♪　この腰振りを、淫らな舞を鑑賞せよ♪」", "NORMAL" ]},
