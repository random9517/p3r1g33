		{"command":[ "PLAYVOICE", "046_0104122" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「見かけ以上に豪胆なヤツじゃ……。あっ♪　デコボコが、わらわの中を……\n粘膜をぐちゅぐちゅこすって……んああああっ♪」", "NORMAL" ]},
