		{"command":[ "PLAYVOICE", "046_0104302" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ああ、あああああっ！　ああ、熱い精液が……隊長どのの樹液がわらわを犯\nしておるっ♪　わらわの処女を真白く染めてぇえええ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104303" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ああーっ、良いっ！　良いっ、良いぃいい♪　こんなにっ、こんなに激しい\n濁流を注がれながら果てられれば本望というものぉおおお♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104304" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「あーーーーっ！　ああああっ！　ゆくっ！　ゆくぅううっ！　膣内射精され\nながらゆくぅっ！　イくぅっ、イクぅうううううう♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104305" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「んあああああああっ！　あああああああ！！　これっ、これじゃあっ、これ\nっ……これでわらわとそなたは結ばれた……ぁあああ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104306" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「もう、もう永遠に離してなどやらぬっ……そなたはわらわのもの……。そし\nて、わらわも、わらわもまたそなたのものに……んーーーー♪」", "NORMAL" ]},
