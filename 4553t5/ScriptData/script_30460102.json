		{"command":[ "PLAYVOICE", "046_0104134" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ゆくっ！　ゆく、ゆくぅっ、達してしまうぅうっ……！　と、あっ！？　そ\n、そなたっ！　そなたは良いのじゃ、まだ出すでないっ」", "NORMAL" ]},
