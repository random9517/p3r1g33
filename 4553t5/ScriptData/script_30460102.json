		{"command":[ "PLAYVOICE", "046_0104208" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「これをのぉ？　あ、ふ……♪　こうして、尻っ、尻を左右に振るっとっ……\n！　ほら、ニチュニチュいやらしい水音が、して……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104209" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ヒダヒダが肉茎にまとわりついておるのが見えるっ、じゃろう……んんん♪\n　離れたくないと、貪欲にすがりついておるのが……あああ♪」", "NORMAL" ]},
