		{"command":[ "PLAYVOICE", "046_0104405" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「そなたの男根を求め、うねって哀しく泣いておるのがぁああ……っ。ああ、\nなのに、なのに……ううう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104406" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「や、やめろ……やめるのじゃ……。ああ……！　そなたの精液を感じながら\n、一人で達するわらわを見るなぁああ……んんんんっ！」", "NORMAL" ]},
