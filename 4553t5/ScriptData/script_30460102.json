		{"command":[ "PLAYVOICE", "046_0104404" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「っああ……ああああ……。そなたには人の心がないのかっ……！　見ておれ\nばわかったじゃろうっ……今もわらわのここが、膣口が……！」", "NORMAL" ]},
