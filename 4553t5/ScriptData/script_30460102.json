		{"command":[ "PLAYVOICE", "046_0104407" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「…………。うう……膣ヒダが、健気にヒクヒクと疼いておる……。そなたの\n精を欲しがって、切ない切ないと呻いておる……」", "NORMAL" ]},
