		{"command":[ "PLAYVOICE", "046_0104120" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「膣奥から溢れ出てくる愛液、で……ぇ♪　ヌルヌルにして、キツキツのこの\n肉穴で……んんんっ！　思いっきり搾り取ってやる……あああ♪」", "NORMAL" ]},
