		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「んあーーーーっ！　アアアアアアッ！　来いっ、来い、来いっ、あああ、も\nっとじゃ、もっと出せっ、もっとじゃああああっ！」", "NORMAL" ]},
