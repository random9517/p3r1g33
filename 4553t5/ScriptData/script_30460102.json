		{"command":[ "PLAYVOICE", "046_0104118" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「わらわを必要以上に気持ちよくするでないっ！　わらわ、が……そなたを一\n方的に搾取して、……んん♪　感じるさまを見たいのじゃからな♪」", "NORMAL" ]},
