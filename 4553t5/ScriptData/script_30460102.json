		{"command":[ "PLAYVOICE", "046_0104307" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「ここ、まで……ここまで気持ちがよいなら、もっとはように寝込みを襲って\nおくのじゃったぁああ……♪　こん、なの……こんにゃのおお♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104308" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「今までの価値観、がひっくり返るほどの快楽ぅうう♪　ああああ、隊長どの\nの膣内射精、好きじゃ……わらわの新しい大好物じゃあ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "046_0104309" ]},
		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「んあっ♪　あっあっあっあっ♪　ひゅごいぞぉおお♪　ゆきたいだけゆける\nっ、イキ、たいだけ……あああっ、達するっ♪　ひゅごいっ♪」", "NORMAL" ]},
