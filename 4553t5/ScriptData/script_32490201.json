		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「出したくなりまひたら……いつれも出してくらはいませっ……！　お口の中\nれもお顔でも……！　どうぞ、お好きなとこりょに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様の精液なりゃ悦んでお受けいたひまふわっ……！　ですかりゃ、ど\nうか遠慮なさらずっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んちゅ、じゅるるっ、んむうぅ……！　オチンチンがまた激ひく暴れてまふ\nわっ……！　どうぞ……！　射精してくらはいませっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んぐっ……！？　じゅっ、じゅるるっ……！　また熱い精液が、私のお口の\n中にっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あぶっ、ちゅぱっ……！　１回目と同じくらいの勢いれ、喉の奥にまで流れ\n込んできまふわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ごくっ……んぐっ、こくんっ……！　はぁ、んっ……んちゅ……！　出され\nた精液は、全部飲み込ませていたらきまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「れすからカツマ様は欲望の赴くままに、お好きならけ射精してくらはいませ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ずちゅ、じゅぞっ……！　れりゅ、ぷちゅ！　にちゅ、ぐちゅ！　じゅぞっ\n、じゅるるっ……んぢゅるぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ、くちゅるっ……！　こくっ……くちゅ、ごくんっ……！　\nたくさん出まひたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私のご奉仕でこんらにも出していただけるなんて……とても嬉しいですわ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「えっ……もっとお口れご奉仕をして欲しいのれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「い、イヤなんてことありませんわっ……！　カツマ様に悦んでいただけりゅ\nのれしたら、何でもいたしまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ちゅくっ……そりぇでは、改めてご奉仕をさせていたらきまふね……んっ、\nちゅぱっ……！　くちゅ、ちゅ……んちゅるぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁっ！　カツマ様の精液が顔にびゅるびゅるかけられてますわぁ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こんなにも濃い香りのするザーメンをかけられるだなんて……これでは、ま\nるでマーキングですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私がカツマ様のモノだと示すみたいになっておりますっ……！　ああっ！　\nなんて素敵なことでしょうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様っ！　どうぞお好きなだけマーキングしてくださいませっ！　私を\nカツマ様の色で染めてくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　さらに顔にびゅーびゅー精子が飛び散っておりますわっ！　\n私、とっても幸せですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あふっ……たくさん、お出しになられましたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オチンチンの大きさだけでなく、射精の勢いもたくましいだなんて……改め\nて、カツマ様に惚れてしまいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「えっ……？　顔にこんなにも精液をかけられて、不愉快ではないのかですか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！　不愉快だなんてまったく思いませんわっ！　むしろ、心地\nいいくらいですのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「カツマ様の専用機になれたという感じがして、とても嬉しいのです……カツ\nマ様。これからも、末永くよろしくお願いいたしますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203410" ]},
