		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「心だけではなく、身体での繋がりも欲しくなりまして……だ、ダメでしょう\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「まあ……！　カツマ様も私と同じ想いでいてくださったのですね……！　と\nても嬉しいですわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「それでは、早速オチンチンを味わわせていただきますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「無理しなくていいだなんて……大丈夫ですわ。カツマ様へのご奉仕は私の悦\nびですから……んっ、んむっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅ……じゅぷ、れろっ、ぷちゅ……！　んっ、ぐちゅ……ぴち\nゃ、にちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「じゅずっ、ぢゅぢゅ……！　こりぇが、カツマ様のオチンチンの味なのれふ\nね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「硬くひぇ、太くひぇ……とても男らしい臭いと味がひまふっ……！　にちゅ\n、ぐちゅ……！　ちゅ、ぐぷっ、じゅぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ちゅちゅ……！　咥えていりゅだけで、さりゃに愛しさがこ\nみ上げてきまふわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　もっひょ奥まれ咥えひゃへていたらきまふね……！　んっ、\nぐぽっ……！　ちゅ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ぢゅぱっ、じゅぴっ……！　にちゅ、ずりゅりゅっ……！　ぐちゅ、れろっ\n、ぴちゃ、ぷちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ぐっ、うぐっ……！　んむぅ……！　咥えしゅぎると……喉の奥にオチンチ\nンが引っかかってひまいまふね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私のお口れはここまでが限界みたいれふわ……！　申し訳ありまひぇん……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「代わりと言っては何れふが、咥えたままいっぱいオチンチンを舐めひゃせて\nいたらきまふので……んちゅ、ぺろっ、ちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅちゅ、ぐちゅるっ……！　れりゅ、ぴちゃ、にちゅ……！　ぐぽ\nっ、じゅぽっ……ぐぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オチンチンの先端かりゃ……ネバネバしたお汁が溢りぇ出てきまひたね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こりぇが我慢汁……カツマ様が感じてくりぇているという証拠ですのね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私のつたないフェラチオでこんらにも感じていただけりゅなんて、光栄れふ\nわっ……！　ずぐっ、ちゅ、じゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あむっ、んむっ……！　んっ、ちゅぱっ……！　亀頭や段になっていりゅと\nころを舐めりゅと、強くオチンチンが反応しまふわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「……な、なりゅほど……今舐めていりゅあたりは、性感帯なのれふね……で\nは、そちりゃを重点的に舐めしゃせていただきまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ぐぽっ……！　ちゅ、んじゅるっ……！　れりゅ、ぴちゃ、ちゅぢ\nゅうぅ……！　ぷちゅ、ずずっ、んじゅ、ぢゅぷるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「皮の隙間にも舌を入りぇて欲しいんれふの……？　ええ、勿論構いまへんわ\nよ……ぐちゅ、れろぉ……！　ずっ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、ぐちゅ、ちゅぽっ……！　れりゅ、んちゅ……！　んっ……確か皮に\nょ隙間に舌をねじ込んれ……撫でりゅように舌を動かひて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「お掃除をすりゅように、いっぱいペロペロひながりゃ吸い付くと……気持ひ\nいいのれしたわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「れりゅ、ぐずっ、ずっ、にちゅるっ……！　れろれろっ……ぴちゃ、ちゅち\nゅ……！　んじゅ、じゅぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んぷっ、ぢゅぽっ……！　えっと……ダウンロードひた知識れふと、男の人\nはこの裏スジというとこりょも気持ちいいんれひたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「オチンチンにょ先端に向かって、這うように舌を動かひて……ぴちゃ、ちゅ\n……れろぉ……！　くちゅ、じゅ、じゅぴぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ちゅぐっ、にちゅるっ……！　最後にオチンチンの先端を舌先でホ\nジりゅようにすりぇば……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あぶっ、んぐうぅ……！　刺激すりぇばすりゅほど、オチンチンがお口の中\nで暴れていきまふわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ネバネバのお汁もぴゅっぴゅっと跳ねて……！　んぐっ、んっ……！　喉に\nょ奥に流れこんれきまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こんらにもお口で感じてくれりゅなんて、嬉しいれふわっ……！　ずぽっ、\nぢゅ、にちゃ、ちゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私のこひょはお気になしゃらず、もっと感じてくらはいませ……！　いっぱ\nいオチンチンをビクビクしゃせて……！　ずずっ、ちゅ、じゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ！　んむっ！　れじゅ、ぐちゅるっ！　じゅぽっ、ぢゅぷっ！　ぴちゃ\n、んちゅ！　ずっ、じゅぱっ、にちゅ、ぐちゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「いつれも……お好きにゃタイミングれ出ひて構いませんのれっ……！　私の\nお口に、精子をびゅーびゅー吐き出ひてくらはい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ！　んんっ！　オチンチンがまた大きく跳ねてまふわっ……！　じ\nゅ、じゅるっ！　にちゅ、ぐちゅ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うぶっ！？　んっ、んむうぅぅっ！？　カツマ様の精液がひっぱいお口に流\nりぇ込んれきまふわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ドロドロひた感触が、お口の中だけれなく、喉の奥にまれ届いて……んぐ\nっ、じゅるっ、ぐちゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「れすが、せっかくカツマ様が出ひていたらいた精子れすもの……！　全部飲\nまなけりぇば、失礼というものでふわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んぐっ……じゅぞっ、じゅるるっ……！　ごくっ、ごくんっ……！　ちゅぱ\nっ、じゅぞぞっ……んじゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あぶっ、んちゅるっ……！　喉に絡みついへきまふわっ……！　とても濃い\n精液れふのね……！　んぐっ、こくっ……ごっくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……！　いっぱい出まひたね……私のお口がカツマ様\nの精液でベトベトになってひまいまひたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですが、愛する方の子種で穢されりゅというのは、とても心地の良いものれ\nふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ……今しがたあれらけ出ひたのに、まらオチンチンが硬いままです\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「大きいままれは大変れしょうし……もしよろしければ、もう１度私のお口で\nご奉仕させていたらけませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「遠慮ひないでくらはいませ……これは私がしたくてひてることれふから……\nでは、改めてご奉仕をしゃせていたらきまふね……んっ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅるっ……！　ずちゅ、にちゃ、ぴちゅるぅ……！　れろれろっ、\nんじゅ……じゅぞっ、ぢゅぢゅ……ずりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぱっ……！　オチンチンの奥に……うっすりゃと精液が残ってい\nまふわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こちりゃも全部吸い取りゃへていたらきまふわね……ずぞぞっ……！　ちゅ\n、じゅるっ……！　んっ、ちゅぱっ、れりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んぐっ……んんっ……！　濃い味と臭いが……お口の中に広がっていきまふ\nわ……！　はぁ……もっと舐めひゃくなってきまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、ちゅぷるっ……！　今度は先端だけれなく、オチンチンの根本の\n方も舐めしゃせていたらきまふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ぷちゅ、んちゅ……！　んっ、ふっ……！　精液が混ざっていりゅのもあり\nゅとは思いまふが……根本の方は特に臭いが濃いれふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そりぇにこんらにも血管が浮き出て……んっ、ちゅぱっ……！　硬さと荒々\nしさが凄く伝わってきまふわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ……強く吸い付きながりゃ、根本から先端に舌をゆっくり這わせて……\n裏スジと亀頭をペロペロ舐めまふと……んっ、んちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ……やはり敏感なとこりょを重点的に刺激すりゅと、オチンチンが\n強く反応ひまふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「感じていりゅカツマ様の姿……とても愛おひいですわっ……！　ずちゅ、に\nちゅるっ……！　ぐちゅ、ぺろっ、ぴちゃ、ちゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024902_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ！　じゅぞっ、にちゅ、ぐちゅるっ！　んっ、んんっ！　ちゅぱ\nっ、ちゅっ！　れりゅ、じゅぞっ、ぐちゅるぅ！」", "NORMAL" ]},
