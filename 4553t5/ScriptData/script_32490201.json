		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「亀頭のあたりを重点的に舐めりゅと……オチンチンの反応がどんどん強くな\nっていきまふわっ……！」", "NORMAL" ]},
