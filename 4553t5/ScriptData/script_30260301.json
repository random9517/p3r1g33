{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「こんな場所に、突然呼び出してすみません……。なかなか、二人きりになれ\nるタイミングがなかったものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふふ……そんなに硬くならなくても大丈夫ですよ。今日はお説教をするつも\nりはありません。貴方を褒めようと思って呼んだんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……さ、ベッドに寝そべって仰向けになってくださいね。何をするのか？　\nそれは準備が出来てからのお楽しみです。……ん、こんなものかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ママが貴方に、今してあげられる最大のご褒美……♪　それは、貴方の大好\nきなオッパイを好きなだけ吸って、舐めて、触ってもらいながら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002603_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「私が、凝り固まったおちんちんを良い子良い子してあげることです。えぇ？\n　叱られる、怒られると思って怯えていたのですか……？　まさか、そんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「私が怒るのは悪い事をした子だけですよ……。リラックスして。今は、私の\n手のひらに、胸に集中して癒されてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「すり、すり、すり……。ぎゅううう……♪　優しく、優しくおちんちんを握\nりしめて……。ゆっくりゆっくり上下に手を動かしていきますね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「くすぐったい？　あら……じゃあもうちょっと強めにおちんちんに触るわね\n……。んっ……んっ……これくらいかしら？　もっと素早く？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「うふふふ……気持ちよさそうな顔になってきましたねぇ？　今だけは、嫌な\nことは何もかも忘れてしまいなさい。快楽だけに身を委ねるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そう。そうやって、オッパイに顔をうずめて……赤ちゃんみたいにちゅー、\nちゅーって吸っていいのよ？　身体中から余計な力を抜いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ママのオッパイは柔らかいなぁ、あったかいなぁ……って陶酔していると…\n…。ん……おちんちんもだんだん気持ち良くなってきますよ……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふに、ふに、ふにってオッパイを押し付けてあげるから……。ぴちゃぴちゃ\n舐めて……？　あっ……そんな感じよ……歯はたてちゃだめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちん、ビーンって上を向いていて素敵だわ。たくさん刺激して\nあげる……。しゅに、しゅに、しゅに……くに、くに、くに、くに……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　包皮が手と一緒に動くのが面白いですね？　外側はなめらか\nなのに……中の芯は硬くて……。はぁ、はぁ、存在を主張している……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あ、貴方のココは……オチンポは、男らしく手のひらに食い込んでくるわ。\nはぁっ……ゆ、油断したら、手首がゾクゾクしちゃいそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「出来るだけ大きな動きで……貴方の股間の一番気持ち良い場所を探りながら\n……。シコ♪　シコ、シコ♪　シコ、シコ、シコ……ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「いやだわ……♪　なんだかおままごとをして遊んでいるようで、だんだん楽\nしくなってきちゃった……。しこ、しこしこ♪　しこ、しこ、しこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ……太くて硬くて……立派ねぇ……♪　なんだか見ているだけで……。\nんっ、ふぅ……私まで落ち着かなくなってきちゃうわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ん？　ずうっと棒の部分を刺激していたら慣れてしまう……？　確かに、そ\nうかもしれませんね。では、こういうところはいかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふふふ、そう……亀頭♪　手のひら全体でゴシゴシするのに加えて……、指\n脇でおちんちんの先っちょをクニクニ撫でたりつまんだり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「こういう刺激も交えると、飽きがこなくていいでしょう？　これ……やっぱ\nり貴方は喜んでくれるって思っていたわ。気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「これって女の身体にはない部分だから、いじりまわすのが楽しくて仕方ない\nわ……。あ、でも、もしかしたら……クリトリスと同じものなのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だとしたら……。ごくっ……そこをこんな風にクニクニクリクリされたら、\nとんでもない快楽よね。男の子の弱点を今、責めてるだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ……すごく昂ってきてしまうわ……♪　んっ……！　あ\nらっ？　ご、ごめんなさい！　つい前のめりになっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「オッパイでお顔を潰してしまっていたわね。息が出来なかったでしょう？　\nごめんなさい……。気をつけながら……。ああ、そうです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「亀頭、肉竿、おタマタマ、亀頭、肉竿、おタマタマって……手のひらを往復\nさせながら三点責めにしていくのもいいわね？　うふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「感じる場所ぜーんぶ、ママの器用な手をまとわりつかせて……♪　こう♪　\nこうよ……♪　オチンポ全体をこの指の支配下に置いてしまうの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「亀頭をくにくにくに、オチンポをぐにぐにぐに……♪　股間をさわさわさわ\n、おタマタマをふにふにふに……。ふふふふ、うふふ、フフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「どこが一番す～き？　ねえ、教えて欲しいわぁ……♪　エッチな場所、ママ\nにどこまでも触られて……ビクビクしちゃって本当に可愛いわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ……、んっ、ふぅっ……♪　ふぅっ、ふぅ、ふう……♪　やっぱり一番\nは棒の部分かしら？　でも、先端もピクピクずーっと悦んでいる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ♪　あぁ……♪　ああああ♪　可愛いわ……可愛いわよ、たくさん感じ\nてね……♪　ママのおててでオチンポマッサージよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「シコ、シコシコ♪　シコ、シコシコ……♪　うふっ、感じるところを触ると\n、ママのオッパイをはむって甘噛みしちゃうのね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「力が入ってしまうのですか？　面白いわ……♪　シコシコシコ♪　シコシコ\nシコ……♪　え？　精液がビュルっと出ちゃいそう？　まぁ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んん……大丈夫よ。ママを信頼して……♪　ママはどんな貴方のことも受け\n止めてあげますから。頭をからっぽにして、気持ち良く射精して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あんっ♪　いいですよ……、ぴゅっぴゅっぴゅっ……♪　ぴゅっぴゅっぴゅ\n……♪　うふふ、しーしー上手に出来ていますねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ……ずうっと、精液を身体の中に溜めこんで我慢していたのですね……\n。噴水のように次々に手の中に精が飛び込んできます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ♪　手首や指の間にまで……。なんて健康的で、元気な精子な\nんでしょう。とても良い色よ、真っ白で粘り気も濃くて素敵です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「これは赤ちゃんを、生命を生み出す大切な体液なのですから……濃いにこし\nたことはないでしょう。ああ♪　そんなにブルブル震えて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「無防備でとても可愛らしいですね……♪　ふふ……全部です。全部出し切っ\nて……。はい、お疲れ様でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「この臭い……。良質な精を、大量に放ったことがすぐにわかる濃密な臭いで\nす。上手にぴゅっぴゅしてくれて、ママはとっても嬉しい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あら……どうしたんですか？　たくさん出してスッキリしたでしょうに……\nまぁた、おちんちんが大きくなってきましたよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「なぁんて、焦らすのは少し意地悪だったでしょうか……。んん？　なあに？\n　もっとしてほしいんですか？　おちんちん、クリクリして欲しいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だったらちゃんとそのお口で言ってくれないとわかりませんよ。……私にど\nうして欲しいんですか？　はっきり言ってくれないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「このまま、おちんちんを綺麗に拭いて、シコシコ終わりにしちゃいますから\nね……♪　うん……。このままもーっと苛めてほしいのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「わかりました。精液でヌルヌルするかもしれませんけれど……ローションが\nわりということで、あまり気にしないでくださいね。いきますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「まずは上手にピュッピュしてくれた先端ね……。亀さんの頭をなーでなで、\nくーりくり……ふふふ♪　まだ刺激に対して過敏な状態かしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ここ。この先端が膨らんでいるところ。そして……段差のあるカリ首。ここ\nがね、おまんこをこすると女の人はみーんな気持ち良くなっちゃうのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴方のコレ……かっこいい形でママ、だーいすき……♪　見ているだけでう\nっとりしちゃう……♪　女を夢中にさせる悪いオチンポの形ねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁっ……クリクリクリ♪　くりくりくり……♪　うふ、先走りのお汁がま\nた滲み出してきた……。気持ちいいの？　もっとするわね。くりくりくり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あらあら……。いつまでも、亀さんと遊んでいるばかりじゃ切ないかしら。\nんっ……蒸れ蒸れの肉竿も……私の手のひらで包みこんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「シコ、シコシコ♪　シコ、シコシコ……ふふふふ♪　こぉら……ママにばっ\nかりおちんちんいじらせているんじゃだめですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ほら……オッパイも舐めないと。ママも気持ち良くなりたいわぁ……？　ん\nっ……。そう……そうやって、舌で、ぺろぺろ舐めまわして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　あぁああ……♪　ちゅぱちゅぱ音をたてて、吸って……。あ\nっ♪　甘噛み、したり……乳首をぉ♪　舌先で転がした、り……ぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ンン……♪　良い子、良い子ですねぇ……♪　ママ、とってもおっぱいが気\n持ちいい♪　気持ち良すぎてぷるぷる震えちゃう……とても上手よ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁっ、はぁ……♪　お、お互いに、お互いの気持ち良い\nところを攻め合って……んふぅっ♪　これが相手を思いやる心……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あっ♪　ぁっ、あっ……！　あぁん……！　そうよ、強く吸ってぇ……あっ\n♪　あっ、か、感じすぎて手が止まってしまい、そう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「こんなことじゃあ駄目よね……♪　ママ、頑張ってシコシコ、シコシコする\nからぁ……ああっ！　貴方の射精……サポートしてみせるから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だから……っ、あぁん♪　おタマタマから尿道、亀頭の先っちょまで精液っ\n……絞り上げるわねっ……！　あっ♪　あぁ、優しく……優しくぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「母の愛情のように……！　んっぁっ、愛を♪　こめてシゴき続けるの……。\nシコ、シコシコ♪　シコシコ……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だめ……！　マ、ママもイキそう……！　一緒にイく？　ふふふっ……いい\nわよ、今度は一緒に……いっしょ♪　にぃいいっ♪　ああぁあんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「やっ……♪　あッぁっ、熱ぅい……！　お顔！？　お顔にまでピュッピュか\nかってるっ……すごい飛距離よ……あぁっ、こんな、こんなにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「いやだぁ……お顔全体がパックされちゃった……♪　まだまだこれだけの量\nを隠していたのね……苦しかったでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「え？　一度出してから、これだけまた貯めた……？　あらっ……本当に、貴\n方のオチンポは優秀ね。ママ、すっごく驚いちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んッ……。そうよね、おててに出すだけじゃあ物足りないわよね……。いい\nのよ、好きなだけママのお顔に出しなさい……浴びてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だって私は……貴方のことを愛しているのだもの。ふふっ……♪　あんっ…\n…無償の愛で、貴方の欲望を受け止める聖母……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「サンタクロースのつもりだったのに、すぐママになっちゃってごめんなさい\nねぇ……。どう？　まだ出るかしら？　ええ、あとちょっと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ぴゅっ、ぴゅっ……♪　ふふふ……。貴方の臭い、すごいわ……。男の子の\n臭い……。これ、私の手と胸に興奮して出してくれたんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そう思うと、愛しくて愛しくてたまらないの……。ぺろっ……。ンン……苦\nくて、プリュプリュで……実の詰まった精子をよく出せました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「えらいえらい……♪　貴方は私の自慢の息子よ。……あっ♪　本物の息子で\nはないけれど……。いつもそういう気持ちでいるってこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「私はいつだって、貴方の味方で、貴方のママだから……。いい子にしていた\nら、ピュッピュのお手伝いしてあげますからね。頑張るのよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ！？　あらっ……！　胸！？　お胸にビュッビュ、精液をひっかけて…\n…。あっ♪　いやよ、私……達しちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あぁんっ、ああああっ……！　ペロペロされて感度の上がった\nオッパイに、こんな……！　ドロッドロの熱いほとばしり……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「やぁあん♪　ぶつけちゃだめ、貴方の興奮を感じ取っちゃう……♪　だめっ\n、だめ、だめ……！　ああ、イクッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ……！！　……ん、んもぉ……！　ママがおちんちんに\nイタズラしたから仕返しのつもりかしら？　悪い子っ、わるい子！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ママ、うっかり……貴方のおちんちんを握りながら達してしまったじゃない\n……。今日は一方的にご奉仕してあげるつもりだったのに、情けないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00002603_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ママをお口だけで気持ち良くしちゃうなんて……貴方ったら天才かもしれな\nいわ……。将来が不安になっちゃう。女の人を泣かせちゃあダメよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……え？　ご奉仕する私に、何かプレゼントをしたかった？　……あら……\n♪　あらあらあら、まあまあまあ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それがこれ？　お口で乳首ちゅぱちゅぱと、この大量の白濁液がプレゼント\n？　……エッチで悪い子だけれど……そう。気持ちは嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ママ、してあげるつもりで貴方にたくさんもらっちゃったわね♪　……ふふ\nふ、二度目なのにこんなに出して……。気持ち良かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ママにもとびきり素敵なプレゼントをくれてありがとう……♪　あ、動かな\nいでね。綺麗に拭いてあげまちゅからね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0303410" ]},
