{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "112_0103101" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ふへー？　隊長ちゃんが切羽詰まった声出してたから、大急ぎで来たのにぃ\n……んぅー……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103102" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「こんなことさせる為に呼んだのかー。んもぅ、急いで損しちゃったよー。ま\nったくもー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103103" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「はいはい、折角来たからやりますよー？　……で、どうすればいいのさ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103104" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ほぉほぉ、隊長ちゃんのオチンチンを……アンナの太腿に挟む、と……。隊\n長ちゃんは、何を言っておるのかね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103105" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「んー？　これがパワーアップの手段だとぉー？　信じられるかーい！　……\nえ？　本当の本当に本当なの？　はー、そっか。そうなのかー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103106" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「じゃあ仕方ないねー。パワーアップは大事だよ。敵はほら、むっちゃ強いし\nねー。分かった分かった。アンナも協力してあげよう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103107" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「……とは言ったものの……アンナ、結構エッチなことしちゃってない？　…\n…いやー、こんなことになるとは……ＥＤＯ恐ろしいなぁー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103108" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「まぁ、隊長ちゃんのお望みなら何でもやっちゃうけどさ……。それくらいの\n覚悟は、アンナだって決めてんの……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103109" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ただ……隊長ちゃん。アンナがこんなことしたのは……絶対にぜーったいに\n内緒だかんね？　しーっだぞ？　約束！　ほら、指切りしてー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103110" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「じゃあやっちゃうかー。ちょっと待ってね、タイツ脱ぐか……え？　脱がな\nくていいの？　それがルールなのかな？　わ、分かったよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103111" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「えっと……んん……挟んでるだけじゃ……駄目なんでしょ？　これを……ほ\nぉ、太腿を動かして刺激するのか。りょうかーい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103112" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「よいしょ……よいしょ……ふぅん……あん、これ滑って……はぁ、やりにく\nいなぁ……。ん？　これがいいの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103113" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「確かに、タイツはすっべすべだもんねー。触ったら気持ちいいかー。ねぇね\nぇあのさー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103114" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「折角なら隊長ちゃんに、気持ち良ーくなってほしいからさ……アンナ、下手\nだったらちゃんと言ってね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103115" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「んん……それにしても、熱いなぁ……。え？　部屋じゃないよ。その……隊\n長ちゃんの、オチンチンのことだよ……もぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103116" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「それになんだか……これ、どんどん硬くなってきてないー？　……んん？　\nへーぇ、これが気持ちがよくなってる証拠なのかぁー」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103117" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「男の人の身体の仕組みはよく分からないなぁー。アンナは女の子だからさぁ\nー？　ひゃひゃひゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103118" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「んー？　アンナは別に気持ち良くはないよ。むしろ太腿くすぐったくて、ム\nズムズしちゃってる。でもさ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103119" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんが気持ちいいって顔になると、アンナの心はきゅんってするよ？\n　これは気持ちがいいってことなのかもね、ひゃひゃひゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103120" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「んんっ……なんか、んー？　オチンチンが、ますます熱くなってきたぞ？　\nどうした？　どうしたんだー？　……あやや？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103121" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「た、隊長ちゃん！　オチンチンが汗かいてる？　アンナのタイツ、染みにな\nってるよぉ。タオルで拭こうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103122" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「へ？　汗じゃないの？　……じゃあ、おしっこ？　おおぅ、違うのね？　じ\nゃあ何なんだよー？　不思議な液体がアンナのタイツを濡らしているぞー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103123" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「え？　……我慢汁って、言うの？　へーぇ、そんな名前なのね。覚えたぞ！\n　アンナ、賢くなっちゃったー。我慢かぁー。我慢、我慢……ほほぉー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103124" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ってことは、隊長ちゃん……我慢、してんの？　我慢は身体によくないぞー\n？　我慢するなするなー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103125" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「およ？　オチンチンの形が……何だろ？　さっきよりも……んん？　血管が\n浮き上がってる。それに、あ……ああぁん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103126" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「太腿の中で、隊長ちゃんのオチンチンが……はぁぁ……ビクビクってしてる\nぅ。ひゃぁん……く、くすぐったいってぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103127" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ふひゃぁん！　オチンチン、太腿こちょこちょしないでぇー。あはぁ……こ\n、これ……変な感じになっちゃうじゃん、まったくもー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103128" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「こうなったら仕返しだ！　隊長ちゃんのオチンチンめー、覚悟しなさい！　\nえいっ……えいっ……ああぁん、硬ぁい。何だよぉー！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103129" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「これじゃあ、オチンチンに負けちゃう！　アンナの柔らか太腿じゃあ、相手\nにならねーのかぁ？　このやろぉー！　えいっ！　えいっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103130" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……隊長ちゃんのオチンチン、何だか……くぅん、変な臭いす\nるぅ。もぉ、これもタイツに着いちゃうじゃん。困るよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103131" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、終わったらこれ……一緒に洗ってよぉ？　頼むよー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103132" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ん？　もう限界……？　あぁ、さっき我慢してるって言ってたもんね？　い\nいよ、我慢せずに……んん？　我慢しないと、どうなるんだ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103133" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「た、隊長ちゃん？　ど、どした……？　太腿の中でオチンチンがビックンビ\nックン震えてるよ？　え？　え？　これ何……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103134" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「う、うわぁぁぁあぁぁぁー！　が、我慢汁がいっぱい出てきたよぉー？　ふ\nぇ？　これ……違うの？　えっと……何？　精液……？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103135" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとぉ……！　隊長ちゃん、こんなにいっぱい出てくるとか聞い\nてないぞぉー！　それに、すごい臭い……うひぃー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103136" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「タイツだけじゃなくて、制服にも精液飛んじゃってるじゃないかー！　もぉ\n、どうしてくれるんだよー？　クリーニング代を要求する！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103137" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「もう、べっとべとで……すっご、顔にまでかかったぞ。……ペロッ、うひゃ\nぁ、舐めちゃった！　うへぇ、苦くて不味いよぉー。ぐぬぬぬ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103138" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、お口直しして！　ほら、まだ食堂開いてるからぁ……何か甘い\n物食べに行こう？　勿論隊長ちゃんのおごりだかんねー？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103139" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「あぁ、この汚れちゃった格好だと外出れないか。ふむー、じゃあ……隊長ち\nゃんの私服、貸してよぉ？　駄目？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "112_0103140" ]},
		{"command":[ "SETNAME", "アンナ" ]},
		{"command":[ "SETTEXT", "「えへへー、ありがと！　じゃあこっそり取ってきて？　アンナここで待って\nるから。よろしくぅー」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011201_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}