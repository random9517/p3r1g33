{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0195" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……あれ、ここどこだ……？　ってなんで椅子に縛られてるんだ俺！？」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「気がつかれましたか、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー？　お前の仕業……でもないな。なんでお前、繋がれてるんだ\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて……私はご主人と一緒にＥＤＯのお使いを終えて歩いていたら急に意識\nがなくなりましたので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺もそうだ……ということは、これは敵の仕業か？　そもそも、ここはどこ\nだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ここはｓｕｃｃｕＢｉ(サキュビ)のオフィスです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰だ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「初めまして、カツマさん。株式会社－ｓｕｃｃｕＢｉ－の社長、貴梨果・サ\nルガタナスです。そしてこちらは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310002" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「秘書兼従業員の魅白・エリゴールです。以後お見知りおきを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310001" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……で、なんで俺は縛られてるんだ？　一応そこの犬もだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人の心遣いに、感涙が止まりませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「えっと……暴れられると困るから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310003" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで疑問形なんだよ。ていうか、そもそもどうやって俺たちをここに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私と魅白はサキュバスなので……チラシを配る振りをして、カツマさんの手\nに触れて精気をぎゅっと絞りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310004" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういえば、気絶する前に美人からチラシを受け取ろうとしたような……ジ\nュンジローはその間なにをやってたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんは、撫でる振りをして私が精気を絞りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310002" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はっは、女性の手を拒まないのは私のモットーですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つまり二人ともハニトラに引っかかったというわけか……で、なにが目的だ\n？　言っておくが、俺たちを人質にしてもＥＤＯは容赦なく攻撃してくるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやいや、ご主人様、いくら姫様たちといえど、それはさすがに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、俺たちが囚われてたとして、姫様とかエファナティカが攻撃をためら\nうと思うか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……可愛いマスコット犬たる私だけならワンチャン……犬だけに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ねえよ。そしてうまくもねえ。で、もう一回聞くが、なにが目的なんだ？　\n敵に渡せる情報もねえぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「えーと……カツマさん、あなたには私たちはどう見えていますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310005" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうって……まあ、美人だなとは思うけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「美人で、スタイルもよく、顔も好みなのでできればいい仲になりたいと仰っ\nてます。縛りプレイもそれはそれでアリと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「黙れ駄犬。いや否定はしないけどよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ならよかった。ええと、まず私たちは敵ではありません。強引な手段を取っ\nてしまったのは社長としてお詫びします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310006" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「カツマさんも、ジュンジローさんも、今拘束を解きますので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310003" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「？？　なにがしたいんだお前ら……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「その……先ほども言いましたが、私たちは株式会社－ｓｕｃｃｕＢｉ－を経\n営しております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310007" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「モットーは『クライアントにクリティカルなアサインを』です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310004" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう……それで？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私の趣味は映画鑑賞で、こう見えてコーヒーが苦手なんです。ですから、映\n画を見ながらホットミルクを飲むのが好きです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310008" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私は読書ですね。貴梨果と一緒で仕事も好きですが、休みの日に本を読みな\nがらゆっくりと紅茶を飲む……そんな時間も幸せを感じます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310005" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、これなんの時間だ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「サキュバス的にそういうプレイなのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「今後の展望としては、従業員を増やしつつ、全体の和を大切にする。そんな\nアットホームな会社を目指しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310009" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私としては会社の処理キャパシティを管理しつつ、できればゆるキャラなど\nを作ってアピールもしていきたいと思っています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310006" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310010" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310007" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやこれで終わるなよ！！　なんなんだお前ら！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「その……カツマさんはＥＤＯで組織を成り立たせるために奔走しているとお\n聞きしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310011" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「その能力をもって様々な組織の集合体……いわば正義のアライアンスである\nＥＤＯのリスクヘッジを行っているとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310008" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？　えー……あー……まあ……そう、かな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆さんにこきつかわれているだけとも言いますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっせえ。誰も雑用をやりたがらないんだから仕方ねえだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「つまり、カツマさんなくてはＥＤＯは成らず。あなたの存在がＥＤＯの核」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310012" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと……さすがにそれは言い過ぎのような」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「謙遜することはないと思います。古来よりそういった人間が組織におけるキ\nーパーソンとなっているのは確か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310009" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「そうです。劉邦における蕭何、孔明における楊儀、ＥＤＯにおけるカツマさ\nん。私はそう見ています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310013" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで例えが中国の戦国時代なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「最近その辺りの映画をたくさん見ましたので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310014" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「ともあれ、その類い希な力をもって、私たちを助けて欲しいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310010" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助けるって……どういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「お願いします。万策尽きて、もはやあなたしか頼れる人はいないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310015" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっ……ちょっ、そんな抱きつかれたら胸が……うはっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「どうか、どうか私たちのメンターになってほしいのです。カツマさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310011" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おお、こっちからも……んっ、柔らけえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ……ご主人は美女のおっぱい押しつけ攻撃には弱いのです。クリティカ\nルなアサインですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023310010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっせえ。微妙に間違った使い方してんじゃねえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「カツマさん……お願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023310016" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「私からも……カツマさんのノウハウが必要なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023310012" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うはは、最高……じゃない、そうじゃなくて、問題点を全く聞いてないんだ\nって」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

