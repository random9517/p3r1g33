		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一体、何が起こったらあんな風になるんだ？　これ、向かい側が少し見えて\nないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、あれを見ろ……！」", "NORMAL" ]},
