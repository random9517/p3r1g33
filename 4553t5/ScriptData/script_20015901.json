		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ジェスタ、格好の話はよい。事情も分かっておらぬ客人に、説明をするのが\n先であろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800011" ]},
