		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うぇー、振ってきたのはそっちなのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800018" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "4", "CENTER", "-400" ]},
