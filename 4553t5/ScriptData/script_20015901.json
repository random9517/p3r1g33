		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「えぇー？　いきなりソレは……って言うか、いかがわしいカッコって、人の\nコト言えないんじゃ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800016" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「何ぃ……！？　私の格好の何がいかがわしいというのだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800003" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "5", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「やー、そんだけ出すトコ出しといたら、ぶっちゃけ痴女もビックリって言う\nか。十分過ぎるかなって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800017" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「貴様……死にたいようだな？」", "NORMAL" ]},
