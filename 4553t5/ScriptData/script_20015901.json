		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ふん……随分と勝手な真似をしてくれるな。そんな貴様らに都合のいいよう\nに、私たちが言うことを聞くとでも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800006" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「突然呼びつけた非礼は詫びよう。じゃが、余はお主らを使役するために呼び\n出した訳ではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800013" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「……と言いますと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800005" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「我らは、共闘相手を探している。もし、お主らが我々に力を貸してくれるな\nらば、その逆も然り。我々の力をお主たちに貸そう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800014" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "6", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「つまり、それは取引……ということですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800006" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そそっ、科学の粋を結集させた武器とか、道具とか、後は人材も含めて共同\n戦線を張んないかってハナシ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800021" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "6", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「科学……よくは分かりませんが、私たちがまだ見知らぬ技術が用いられたも\nのがあるということですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800007" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "0", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うむ。ジェスタ、軽く何か見せてやるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800015" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んー、そうっすねー。そんじゃ、ちょっとボクの作ったやつで、こんなのと\nか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800022" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETIMAGE", "1", "sbg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "SETTEXT", "「っ……！？　何だっ、急に周囲がっ……貴様ら一体何を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800007" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "0", "CENTER", "400" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] }, 
		{"command":[ "FADEOUTCHARA", "3", "NORMAL" ] }, 
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「落ち着いて下さい、フェンリル。どうやら、これは目眩ましの一種のようで\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "DISPIMAGE","1", "FALSE" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETTEXT", "「おっ、一瞬で理解できるなんてやるぅ！　そう、これは周囲をブラックアウ\nトさせて視界を奪うアイテムってヤツ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800023" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「これやると、素材いらずでパッと真っ暗な状況を演出できるから楽チンなワ\nケ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800024" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「素材……？　何の話だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800008" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "4", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ま～、こっちの話。細かいことはい～から」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800025" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「直接的なモノも、おいおい見せることにしよう。１度共に戦場に出て、我々\nの力を見極めてから判断してくれてよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800016" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ] },
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「なるほど……確かに、面白いかも知れませんわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800009" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ] },
		{"command":[ "DISPCHARA", "3", "FALSE" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「おいフレイア、勝手に話を進めるな。私は反対だぞ、こんな胡散臭い奴らと\n手を組むなど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800009" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "7", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ] },
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「全面的に信用しろというつもりはありません。ですが、検討する余地は十分\nあると思いますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800010" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「どういうことだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800010" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「まず、この未知の技術は、私たちの戦いに新たな局面をもたらす可能性が高\nいです。それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800011" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「こうしたものに特に目のない方にお心当たりがありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800012" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「……！　それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800011" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「この次元のものを、あの方に献上すれば……私たちも沢山可愛がって貰える\nかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800013" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ま、まあ……別に私はあいつが喜ぶかはどうでもいいが……確かに戦力の底\n上げにはなるかも知れんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800012" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "2", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あら……フェンリル様は、あの方の寵愛は必要ないと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800014" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「なっ、バ、バカ者っ！　今はそんな話をしている場合ではないということだ\nっ！　全く貴様という奴は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800013" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "5", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ふふ……では、フェンリル様も、お話に賛同することには問題ありませんか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800015" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ひとまずは様子見だ。妙な真似をしたら、すぐにでもあいつらの首を刎ねて\nやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800014" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なんか、メチャクチャ物騒なことを言ってる気がしますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800026" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "4", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ] },
		{"command":[ "DISPCHARA", "2", "TRUE" ] },
		{"command":[ "DISPCHARA", "0", "FALSE" ] },
		{"command":[ "DISPCHARA", "3", "FALSE" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よい、それ位の気骨がなければ戦力にはなるまい。ジェスタよ、なかなかよ\nい仕事をしたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800017" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「え、えへへ、あ、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800027" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……面白くなりそうじゃ。ＥＤＯの連中が、泡を吹くところが今から楽\nしみじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800018" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
