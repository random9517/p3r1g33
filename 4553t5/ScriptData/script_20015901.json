		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっとと、そうでした。ボクとしたことが、ついついうっかり、てへ」", "NORMAL" ]},
