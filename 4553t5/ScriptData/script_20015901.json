		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「な……何だっ、一体何が起こったのだっ！？　天界の連中の罠かっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800001" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「いえ……奇妙ですね。先程までの戦場とは空気が違います……周囲の景色も\n異なるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023800002" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "0", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00000310_01", "6", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう、１人だけを呼び出すのかと思ったら、２人もいるとはな。思いもよら\nぬ収穫ではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800009" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふ～む……一応成功したって感じですかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800014" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて、それはこれから分かることじゃ。ジェスタ、話をしてみよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800010" ]},
