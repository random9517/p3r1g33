		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……これは一体何だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「よくぞ聞いて下さいました！　何を隠そう、これは別次元との扉を開き、強\n力な戦士たちを召喚する機械！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800002" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「名付けて、次元チェンジャーチェンバーくんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800003" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チェン……バー、チェン……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チェンジャーチェンバーくんです！　分かりにくかったらチェンジャーくん\nでもいいですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800004" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "0", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……それで、それが別次元の戦士を召喚するとな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いえす！　このチェンジャーくんの優秀なところは、その強い指向性にあり\nま～す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800005" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「例え召喚が成功しても、必ずしもボク達と同じような思想や理念を共有でき\nるとは限りませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800006" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "4", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「このチェンジャーくんは、我らが時間帝国に協力してくれそうな奴らを上手\nく探して、更にはそれ以外のやつは召喚中に弾き出すんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800007" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "0", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……選別する機能がついておるということか。中々興味深いが……弾き\n出すというのは、どうなるのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まー、また途中で次元の裂け目にポイしちゃう感じなんで、運が良ければ元\nに戻るか、あるいはどっかに強制漂流ですかね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800008" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「次元の裂け目に落とされてしまうとな。それは、中々に恐ろしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「後は、開いた次元をそのままにしとくって機能もついてますけど、それはそ\nれとして。いかがします？　やっちゃいます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800009" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「許す。始めるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023800006" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「りょっ！　それじゃあ、さっそく～スイッチオン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023800010" ]},
		{"command":[ "SETCHARA", "1", "char_00023101_01", "8", "CENTER", "400" ]},
