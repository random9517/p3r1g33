		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「む……何だ、貴様らは。何とも見慣れぬいかがわしい格好をして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023800002" ]},
		{"command":[ "SETCHARA", "3", "char_00028401_01", "7", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "2", "char_00023101_01", "8", "CENTER", "-400" ]},
