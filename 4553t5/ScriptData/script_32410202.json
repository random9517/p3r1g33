		{"command":[ "SETTEXT", "「はあぁ、か、顔が……いや、身体中が火照って、おるわ……あぁ、あっ、\nあんっ……はぁ、あ、熱い……ちんぽも、熱いぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「な、中、擦れてぇ、おるぅ……ひっ、ひんっ！　はぁあ、くっ……くひっ…\n…も、もぉ……妾ぁ……い、いくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「だめじゃ、なにも考えられぬ……んううっ！　お、おぬしの……ちんぽで…\n…くひっ、いいっ！　ちんぽで、いっぱいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、あん、あぁんっ！　くひぃっ！　も、もう……だめじゃ……わ、妾…\n…立っておれぬ……ひぐっ、ひっ、ひぃいぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「頼むから、一緒に……！　い、いっしょ……いって……はぁぁっ、あっんっ\n……！　はぁんっ！　おぬしも、果てて……！　あっああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「は、孕んでも……よい……おぬしの赤子なら、孕んでもいいから……この\nまま、中に……はっ、はんっ……中に出すのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　で、出る？　出るのか？　いいぞ、は、早く……出して\nっ……熱くて、濃い……子種汁を……たくさん、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「い、いくぅぅ……！　おぬしも、いっしょにぃ……い、しょ……じゃなきゃ\n、いやじゃ……い、いあっ……あっ、あっあっ！　あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁぁぁぁ～～～っ！　あっ、あんっ！　またっ……出てっ……出てお\nるぅっ！　あっ、くぅうっ……んはあぁぁぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ……んううっ！　おく、うぅ……でてぇ……あっ、あはぁ……\nあっ、はっあっ……うっ、んうぅぅ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あ、あはぁぁ……熱い……んんっ……！　さっきも、出したのに……よくも\nまあ……これほど、吐き出せる……ものじゃな……んんうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あ、あふぅっ……んっ……よかったぞ……よすぎて、完全\nに気をやってしまったわ……はぁあ……あ、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ち、ちと待つのじゃ……はーっ……はあっ……激しすぎて、くたくたじゃ…\n…違う、歳ではない……！　おぬしが好き勝手するからじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まったく、こんなに出しおって……ふう～……腹が、温かい……なんだか、\n幸せな気分じゃのう……おぬしはどうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうか……おぬしも、よかったか……まあ、これだけ出せば満足じゃろうな\n……しかも二回も連続でじゃ……おかげで溢れてきておるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こんなに出したら、本当に孕んでしまうぞ？　くふふっ……どうするのじゃ\n？　赤子ができたら、娶ってもらわねばならんのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なにを驚いておるのじゃ。そもそもこんな好き勝手されたのじゃ、もうお嫁\nにはいけぬ……よよよ……責任取ってもらわねばのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「安心せよ。妾は床上手じゃからな。おぬしもすっかり妾の虜じゃろう？　\n夫婦になって毎日まぐわう……それもよいとは思わぬか？　ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひ、あああぁぁっ！　なか、擦れてぇ……ひっひいっ！　あっ、ああっ！　\n抜けっ……抜けてぇ……ひいっ！　ひゃぁぁぁぁぁ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　あっ、あぁっ！　こ、これっ……なにを、して……ひうっ……\n！　んんううっ！　あ、あつうっ……熱いぃぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「どうして、抜いて……おるのじゃぁ……馬鹿者ぉ……ひゃうっ……んっ！　\nくっ……か、身体に、かかって……くひっ！　んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁ……く、くさいぞ……んんっ……はぁあ……は、鼻が\n曲がりそうじゃ……まったくぅ……んはぁ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「う、嬉しそうな顔をしおって……はぁ、ふうっ……んっ……これで、全部\nか？　溜まってたの、全部出し切ったか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ……妾も、気持ちよかったぞ……よかったが……こんなに汚されてしま\nうとは……後片づけも大変なのじゃぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それに……これだけ塗りたくられたら、おぬしの匂いが取れなくなりそう\nじゃ……きっと誰かと会ったら気づかれてしまうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾とまぐわっておったこと……みなに知られてしまうのう。まあ妾はよい\nぞ。おぬしと妾が、いい仲なのは事実じゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうじゃろう？　いっそ妾を嫁にもらってはどうじゃ？　ふふっ、妾は本気\nじゃぞ。こうやって毎日まぐわおうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「今すぐではなくともよい。しかし、これだけ身体を重ね合うておるのじゃ…\n…きっと妾が欲しくて堪らなくなるじゃろうな」", "NORMAL" ]},
