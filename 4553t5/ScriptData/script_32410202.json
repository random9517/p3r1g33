		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんじゃ藪から棒に……おなごを誘うにしても、もう少し気の利いたこと\nくらい言えぬのか？　まったくおぬしときたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほう……妾を食いたくて仕方ない、と……？　そんな無粋な誘い方があるか\n……まあ、そういう必死な姿、妾は嫌いではないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「年下男がけもののように迫ってくるというのは、よくある話じゃ。それを\n優しく包んでやるのが、姉女房の器量というものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああ、言葉のあやじゃ、そう気にするな。しかし、もはや女房のようなもの\nではないか？　のう、そうは思わぬか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00024102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「とにかくお姉さんであることは間違いないからのう……うむ、妾に任せて\nおけ。ほれ、まぐわいたいなら……早くこっちへこい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんじゃ、もう反り返っておるではないか……相変わらず禍々しい形をした\nちんぽじゃ……んんっ……見ているだけで、身体が火照ってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024102_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「う、うむ……股座はとっくに濡れておる。気遣いは無用じゃ、早くそれを…\n…ここに……ほれ、焦らすでない……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くふぅぅぅっ！　はっ、あっ……あっ！　だ、大丈夫じゃ……んんっ！　\nほれ、奥まで……一気に……はうっ、んっんぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ぜ、ぜんぶ……か？　全部、挿入ったか……？　あ、あぁ……おぬしのちん\nぽは大きい、からのう……挿入れるだけで一苦労じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしのせいで、妾のおまんこが……このちんぽの形になってしまいそう\nじゃ……隙間なく、密着しておるじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああ、挿入れただけで、気持ちいい、のう……妾も同じじゃ……んっ、どう\nした？　動かぬのか……？　好きにしてよいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「心配するな、激しくしてよいぞ。うむ……おぬしのちんぽで、妾をただの\n牝にするがよい……ほれ、ほれ～ひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ……！　くっ、ううっ……なんじゃ、その腰使いは、あぁ…\n…あ、浅い所を……あぁ、抜けてしまうぞ……んんうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁあ、あっ、これ……あっ、あっ……しつこい、ぞ……そこは、んあっ！\n　う、上……を擦る、なぁぁぁ……あんっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んふぅっ！　お、おぬしの、ちんぽ……出っ張った、とこが……当たって…\n…ひぃんっ！　こしゃく、なぁ……ひゃぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くっ、楽しそうな顔をしおってぇ……そんな余裕でいられるのも、今のうち\nじゃぞ……すぐ、果ててしまう……に決まっておる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ！　これっ……そこは、んっ、そこばかり……するのはやめよ\n……もっと、んっはっ……ふ、普通にぃ……んあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「じゃから……お、奥まで……こう……ええい、まどろっこしいわ……！　\nもっと強く、奥まで突いてこぬか！　いいも悪いもあるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほう、楽しみじゃのう……そこまで言うなら、おぬしの好きにやってみよ…\n…んっ！　んん！？　あっ、あはっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　んっ！　そ、そぉ……じゃ……ひぃっ、ひいいっ！　あひっ、\nあっあんっ！　い、いいっ……気持ち、いい……ぞっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁあ、あっ、あふっ……そ、その調子じゃ……ひぃんっ！　あっ、あっ…\n…あっ！　あっ……んっ、はぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃぁ、あんっ……はぁ、はあっ……は、果てて、おらぬ……ちと、気を\nやりそうになっただけで……はぁんっ……まだ、じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾を侮るなと、言うておろうが……おぬしのちんぽ……いくらでも、受け\n止めてやるわ……んんっ！　ひゃっ、あんっ！　あひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「お、おぬしも……気持ちいい、じゃろう？　妾のおまんこ……堪らぬであ\nろう？　な？　そうじゃろう？　んんっ……そう、そ、おぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ！　くっ、うぅっ……はっ、はっ……お、奥……突いて、こい\n……ひっ、ひぃんっ！　どうじゃ……出そうに、なったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まだ、しばらく……かかりそうなのか？　んんっ……そ、それはよいが……\n身体は、んっ……もつのか？　こんな激しく動いて……はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「若いと言っても、限度が……あっ、あるっ……あっあっ……ひぃんっ！　\nあひっ！　妾となら、いくらでも……できるぅ？　んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それは嬉しいが……あっひっ、ひぃんっ！　ひんっ！　こ、腰が、浮くっ…\n…腰が、とろけてしまう……うぅん、んっ、んひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あぁ、あひぃっ！　わ、妾だって、まだ……あぁっ、あひぃいいっ！　はっ\n、ああっ……た、達して、なぃ……ちがう、のじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひぃ、ひいっ！　あはぁ……き、気持ちよすぎるっ……なんじゃ、これは…\n…おぬしに突かれる、たび……すご、い……いいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「いつもより、もっと……感じるのじゃ、おぬしのちんぽを……んっ……身体\n中が、ちんぽで貫かれておる……くっ、ひいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「も、もうっ……い、くっ……いき、そうじゃ……んっ、あっ……違うと、\n言うておるじゃろう……今、やっと果てそうになっておるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「強がって、など……な、ひぃいっ！　ひっ！　ひぃいっ！　ああっ、激しい\nっ……！　んはぁぁあっ！　つ、強すぎるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾だけ、果ててしまうっ……！　これ、こぉれぇ……一緒、い、一緒がよい\nのじゃ……わら、わ……だけ……嫌じゃ、んっ！　はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「だ、出して……おくれ……！　中に、出して……んっ、んんっ！　そうっ…\n…あっ、あっ、あっ！　あああっ！　はぁぁぁぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ！　はひっ、ひぃっああっ！　あっああっ……出て、るっ…\n…くひぃいっ……！　あふっ……あっ、あはぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あぁ……あっ、ああぁ……まだ……どくん、どくんと……ちんぽが、妾の中\nで、跳ねて……おる……子種汁を吐き出して、おるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……は、あぁ、あはぁ……たっぷり、出して……んぅ……そうじゃ\n……よい……んぅ、ふうっ……気持ちよかったじゃろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾も、よかったぞ……おぬしも夢中で、腰を振っておったしのう……身体の\n相性がよいのじゃろうな……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「な、なに……？　もっとか？　うむ……求められるのは嬉しいが……ちと\n休憩せぬか？　待てぬのか？　ち、ちと……待て……ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「は、あぁんっ！　元気が、よすぎる……ひっ、ひぃいっ！　妾が、それだけ\nいい女……というのは……嬉しいが……あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！　ば、馬鹿者ぉ……こ、これしきのことで……妾が、へばるわけ\nなかろう……んひぃい、ひっ、ひぃあっ！　あひぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あ、あへぇ……だ、だめじゃと……言うて、おる……さすがの妾も、果てた\nばかりで……疲れておるのじゃ……あぁ……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「好きに動いて、よいとは……言うたが……少しは年長者を、労わらぬかぁ…\n…お、ぬしぃ……はぁ！　はぁあ、あっ……ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんじゃ、急に……可愛い、可愛いなど言いおって……ひゃうっ、んんっ…\n…ちんぽ、くぅんっ……お、奥、当たっておるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひぃあぁっ！　また、ちんぽが大きくなって、おるぅ……ひぃいっ、ひゃい\nぃっ！　な、中から、押し広げられてぇ……はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なに？　妾の方が、締めつけ……強く、なっておるのか？　くっ、ふぅう…\n…自分では、よくわからぬ……あっ、あぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「さっきから、感じすぎて……股座辺りの感覚が、ないのじゃ……んんっ……\n腰からとろけてしまいそうなのじゃ……んっ、はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、あっはぁっ！　い、いいっ……気持ちいい、が……妾だけ、ひい\nひい言わされてぇ……ひゃんっ！　お、おぬしは、どうなのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、んっ……いい？　いいのか？　妾とまぐわって……おぬしも\n感じて、おるのじゃな？　あぁ……嬉しい、ぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「嬉しいに決まっておる……せっかく、こうして身体を重ね合っておるのじゃ\nからな……あ、あふっ……一緒に、楽しまねば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　な、なんじゃ……そんなに顔を、覗き込んできて……照れるで\nはないかぁ……あんっ、あっ、くうっ……あんっ……！」", "NORMAL" ]},
