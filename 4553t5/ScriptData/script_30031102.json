{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……はぁっ、はぁ、はぁ、はぁ……。随分と激しい試合展開だったねぇ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104101" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ん？　あんた、あたしの試合を見に来てたのかい。ちょうど良かった……今\n、呼び出そうと思ってたとこなんだ。こっちに来なよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「人気のない場所に引きずり込んで何をするつもりか、だって？　そんなこと\n、決まってるだろ。試合で火照った身体を発散させてやるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……あたしの役に立てるなら光栄だろ？　そら、ズボンを下ろしな……。フ\nフ、もう期待してチ○ポがパンパンになってるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしの試合を見て、勃起するなんて……あんたも相当なヘンタイだね。で\nも、都合がいいのは助かるよ。そのままジッと待ってなよ……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000311_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　汗まみれになった身体に、風が気持ちいいねぇ……♪　そし\nて目の前には、あたしの好きにできるチ○ポがある。最高じゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あははっ……。健気に上を向いてるよ。あたしの中に入りたいんだろ？　も\nう我慢できないってのが伝わってくるよ。カウパーだって出てるしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも……こういうご馳走はねぇ。焦らしに焦らして、いっちばん美味しいと\nころでいただくのがエファナティカ流ってやつさ。よーく見ときな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしの、特別おいしそうなヌルヌルオマ○コを……。ぁっ♪　こうしてチ\n○ポにこすりつけて……。ん、ふ……♪　愛液を塗りたくってさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ぁ……ぁ、あ……♪　じっくり下準備、していくのさ。……ハハ\nッ、必死で腰を浮かせてもダメだよ。既にあんたはあたしの管理下だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしがきまぐれに中に招き入れない限り……。ギリギリの快楽に襲われな\nがら、射精は出来ない地獄の苦しみを体験してもらうよ……♪　んッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……ん、ふ……。ふぅっ……ふ、ぅ……はぁっ♪　はぁっ……は、ぁ……♪\n　ん……。ぁ……あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「とんっでもなく太い肉竿……。それに、エグいカリ高のチ○ポ……♪　そう\nだよ、これが……これが欲しかったんだ。まさに勝利の美酒ってやつさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ん、……改めて見ると長くて逞しい、なかなかのチ○ポだよ。ほら、わかる\nだろう？　あたしの入り口から腹の奥まで届きそうなくらいある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「これをズップリ奥の奥まで入れて動かしたら、最高に気持ちがいいんだろう\nねぇ……。ん……。聞こえるかい？　粘膜と粘膜が触れ合って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ヌチュ、クチュ、って卑猥な水音がしてるよ。フフ……あたしも試合後で昂\nっているからね、本音で言えばすぐにハメてやりたいところだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こ、の……っ。マ○ズリもなかなか気持ちがいい……。んッ……！　チ○ポ\nの先っちょがクリにぶつかって……。あっ、すごく感じるし……。ンッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あと少し腰を落とせば入っちまうって状態で……。んぁああっ♪　こうして\nニュルニュルアソコをなすりつけてんのも、なかなか……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……何より、あんたのそのじれったそうな顔♪　おあずけくらって泣き出し\nそうになってる、犬みたいな顔が最大のご馳走ってもんさ……。はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「入れたいかい？　あたしの中は最高だよ？　名器がうねうね絡みついて、チ\n○ポをみっちりと締めつける……。熱くて濡れてて……ンフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「鍛え上げられた膣内が、あんたが射精するまでチ○ポを搾り上げるんだ。悲\n鳴をあげても、やめてなんかやらないよ？　……っふぅっ、ふううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アハ……♪　想像だけで唾飲んで、チ○ポ硬くしてんじゃないよ♪　えぇ？\n　焦らさないで早く入れさせてくれ？　さて、どうしようかねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「生かすも殺すもあたし次第って状況で、こうやってニチニチオマ○コをなす\nりつけてるってシチュエーションも……ゾクゾクしていいよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……んん？　どうしても？　どうしてもしたいのかい？　おかしくなりそう\n？　それはまだダメだよ。おかしくなるのはここからさ……入れるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っあ～～～～っ♪　あぁ～～～～♪　入れちゃった……♪　あんたが懇願す\nるもんだから、優しいあたしはオチ○ポマ○コに入れてあげちゃった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも、さぁ♪　そんなにうまい事ばかりの話はないよ……？　っ、ぁっ♪　\n膣内に入れてあげたって、簡単には射精は許可しない……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしが腰を揺すってさ♪　あんたのチ○ポでオナニーするのをその目でよ\nーく見てな♪　あたしが満足するまで出すんじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っあああああ……♪　あぁっ、ああああ……♪　ぶっといチ○ポ、えっぐい\n角度であたしの中をえぐってくるチ○ポ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「腹の中に、一本太い杭を打たれたみたいだよっ♪　あっ♪　あっ、あっ♪　\nコイツが身体を支えてくれるから、無茶苦茶な動きもしやすくなった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉら♪　ズップズップ出し入れしてやるよ♪　チ○、ポぉ♪　チ○ポであ\nたしん中、突いて突いて突きまくるんだよっ！　ンンンンっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはぁああ♪　ちょうどいいデカさかと思ったら、まーだあたしのオマ○コ\nを拡張する気だね……♪　元気いっぱいで助かるよ♪　あっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んん～～～～♪　スポーツの後はコレだねぇ～～～♪　身体に溜まったモヤ\nモヤが♪　熱が、スッキリ浄化されてくよ、あ～っ！　ん、ん、ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「気持ちも♪　心も満足して……んぁっ♪　チ○ポ一本で幸せになれちまう♪\n　ンふっ……♪　んんっ♪　いつもヘタレのあんたの特技ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「セックスだけは、ホンット一流だね♪　あ♪　あっ♪　チ○ポ♪　カリ高チ\n○ポ♪　ずっちょずちょ音たててオマ○コをほじくってるっ、あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁ？　もう射精が我慢できないぃ？　チッ……！　それならとっとと一\n発出して、すぐに復活させるんだよ、いいね！　そら出しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁああああふっ♪　躊躇のない膣内射精ぃいいっ……♪　サカりのついた\nオスのケダモノに、生で種付けされる感覚……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはっ、アハハハっ！　よっぽど出したくて仕方なかったみたいだね！　と\nてつもない勢いで……ンンンンッ♪　精液ほとばしってるじゃないかぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅううっ♪　んふっ♪　ああ……あああっ♪　あッ、んんんあぁああ…\n…！　子宮口にべったり精液がはりついて……ンンンンッ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ナマイキにも、あたしに受精させようって魂胆だね……！　あぁッ♪　あぁ\n……！　悔しいけど、これ、は……これは感じるうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「イクっ♪　イクイクイクぅうっ♪　無敵のエファナティカ様を、強制的にイ\nカせるなんて……やっぱりあんたが一番スゴいよ！　ッ、イっくぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふ～～～～～♪　はぁ、はぁ、はぁ、はぁっ♪　あ～あ♪　もっともーっ\nと長持ちさせるつもりだったのに、あたしの名器じゃ無理だったかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さっき約束した通り、このまま抜かずの二発目キメてもらうから覚悟しなよ\n？　まさか、萎えたなんて言わないよね？　……上等だ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この最強のオマ○コの中にいて、一回の射精で萎えたりしたらチョンギるか\nらね。気合い入れて勃たせてなよ……。って、心配はいらないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの……。うっ♪　デカマラ、もうビキビキに復活してるじゃないか…\n…。スケベなやつだね、こっからはお仕置きが必要かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ♪　あっ、あっあっ♪　あたしの超高速腰振りにどこまでついてこられ\nるのか……試してあげる！　あっ♪　あっ♪　スピードあげてくよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら♪　ほら♪　最近、下半身を主に鍛えてるんだ♪　すっごいだろぉ……\n？　尻を揺らしながら……腰をくねらせて……。んぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ○ポのありとあらゆるところを締めつけて、快感だけを送り続けるのさ…\n…♪　んあはっ♪　気の弱いヤツなら廃人確定のピストンさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたは耐えられるよねぇ……？　あっ……♪　あたしのこの名器、このオ\nマ○コにだって負けないで抗える……そうだよねぇ？　アハ、アハハハ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そぉら……いっぱい締めてあげるよ♪　ンッ……わかるだろう？　ぎゅぅっ\n、ぎゅぅうってチ○ポが締めつけられて……あっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……おや？　どうしたんだい、腰が逃げてるよ。フフフ……♪　もっと深く\n、ふかぁく交わろうじゃないか……♪　あっ♪　あっ、ぁっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あは……♪　はぁっ、はぁっは……っ♪　ああ……♪　いいよっ、いいねぇ\n……♪　この、一番奥にねじこまれる太いチ○ポ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「子宮口に突き刺さる、コレがあたしの女を刺激して、陶酔させてくれるんだ\nよ……♪　あっあっ♪　試合の後はやっぱりコレだよ……♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やりたい放題に尻を揺すって、チ○ポを貪り尽くす……♪　あっ……ああ…\n…♪　って、あんた自分も腰を動かそうとしているのかい？　ハハ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「下手に抵抗したって無駄だよ！　あんたが私のピストンに勝てるわけ……っ\nて、んふっ！？　あっ……！　な、なんだいその動きっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んあっ！？　や、やるじゃないか……今のは良かったよ……！　あぁっ♪　\nそうさ、そこだよ……そこ……！　あっ、あっあっあっあぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅうううっ♪　絶頂、が、止まらないよ……！　あんたのチ○ポ、いい\nとこにばっかこすれて……あっあっあっ、イキっぱなしに、なるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁあ……イ、く……！　あんたもイキたいって？　それは……、あっ♪　\nまた別のハナシだろ……今はあたしが愉しむ時間だよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……いいチ○ポだ♪　イ……く、イク……っ♪　ああああああ♪　……\nなんだいっ、一番いいところで……！　……んんっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「一緒にイキたいぃ……？　ふぅーん、言うじゃないか……♪　あたしはまだ\nまだイケそうだから……あんたも勝手にイケばいいだろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはぁ……♪　射精寸前の男の顔ってバカみたいで好きさぁあ♪　根性入れ\nて出すんだよ！　いいね！　めいっぱいきばりな、……イキなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉら……ほぉら……っ、いつまでも強情はっているんじゃないよ♪　あた\nしの子宮は準備が出来てるんだ、音をたてて飲み干してやるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……っうぅううんんんっ♪　あぁっ……ヤバいね、ちょっとイキすぎて……\n手加減してあげられそうにないよ、ラストスパートキメるよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっぁっあっあっ♪　イケっ、イけっ……♪　んんんっ♪　あたし\nもイくよ……ぶっといのでイくっ……あぁああああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あはははは……♪　ヤれば出来るじゃないかぁああっ♪　いい感\nじだよっ……！　あんたの中出し、あたしによく馴染むぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104304" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ねぇ……自分でもわかるだろう？　いつもよりたくさん精子漏らしちまって\nること……♪　異常なくらい発射し続けてるってこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんた、もう終わりだよ……っ、アハハッ♪　私の身体無しじゃあ生きられ\nなくなっちまうねっ……！　はぁ、はぁ、なんて顔してるんだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「最高の女に種付けしてるんだ……しっかり堪能しなっ……！　あっ……あぁ\n……！　子宮口でブチュブチュ精液が踊っているよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの底力はすごいねぇ……！　感心するよ……！　は、ぁ……♪　はぁ\nああ……ああ……♪　ごちそうさま……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「人間がみーんなあんたくらいスゴかったら、いたぶりがいがあって愛おしい\nのに……♪　まぁ、当分はあんただけで満足しておいてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはっ、アハハハっ！　まだ出てるよ……♪　ねえ、このまま出し過ぎて死\nんじゃったら……それって最高の終わりなのかもね、あはははっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「な～んて……あたしがただ、お優しく射精させてやるオンナだとは思ってな\nいよねぇ……それっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アハハハッ♪　ぬるぅううってチ○ポがオマ○コから抜けちゃったねぇ？　\nあはっ、どうだい？　辛いかい？　苦しいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしをさんざん絶頂させておいて、中出しまで許したら……あんたは調子\nに乗るだろう？　だから、マ○ズリで情けなくイかせてやるよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んん……♪　少しの刺激でも破裂寸前のチ○ポ、をねぇ……♪　亀頭をこう\nしてオマ○コでこすってやるとぉ……♪　ほらほらほらほらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アハハハハ！　出た出たっ！　汚い噴水みたいに精子がビュッて飛び出した\nよ♪　どうだいっ……これで自分の立場がわかったろうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104405" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしの身体に無駄打ちした精液……。あ～あ、この濃さなら着床確実だっ\nたかもしれないのにねぇ……って、なんだい。ニヤニヤして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「何？　自分がイキすぎて耐えきれなくなったから抜いたんだろうって？　精\n液をかけられた姿がエロくて興奮する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っく……！　な、なんだって……！？　べ、別にあんたを喜ばせるために浴\nびたんじゃ……！　あっ！　み、見るな！　いやらしい目で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちが……違う……。あたしは、あんたに恥をかかせるために……！　イキす\nぎておかしくなりそうだったからじゃ……。……う、うるさいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたのチ○ポとセックスが上手いのは、あたしが一番わかってる！　……\n今日のことを、誰かに言いふらしたら承知しないからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
