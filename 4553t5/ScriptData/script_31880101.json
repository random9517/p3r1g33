{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。遅くなってしまってすみません。突然呼び出しだなんて…\n…味方に何かありましたか？　すぐにでも出撃出来ます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00018801_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「えっ……出撃ではないのですか？　もっと個人的なこと？　詳しくお聞かせ\n願えますか？　……はい。パイズリ？　パイズリとは、あ、あの……胸で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00018801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ええ、一応……知識では……。って、おかしなことを言わせないでください\n！　け、経験はありませんが……それが何か？　『今からしてほしい』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「えっ、えええええっ！？　ぁ……嫌とかではないのですが。きゅ、急に言わ\nれたものでびっくりして……。パイズリ……そ、そう、ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「つまり夜のお相手ですね？　……わか、りました……。でも、部下たちには\n言わないでくださいね？　私が胸で奉仕しただなんてこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00018801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「それに、初回でうまく出来るかは保証できませんので……。している最中に\n、ご要望があれば遠慮なくおっしゃってください。……脱ぎますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んっ……男の人に……、は、肌を、胸をさらすだなんて恥ずかしい……。ど\n、どうですか？　私の胸……大きすぎて変ではありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『見るだけで癒されるどっしりおっぱいだ』……ふふふ、どっしりだなんて\n。でも、確かに重たいですよ？　潰されそうなら言ってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んっ……は、ぁ……。あぁ、そうだ……。隊長さんの大切なところ……私の\n胸で押し潰さないように……。こういう形で挟むのはいかがでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「私、が胸を手で支えて……。谷間にその、差し込んでいただく形で……。そ\nうすれば、柔らかさだけを楽しめるかと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「え？　何を胸に差し入れるべきか言って欲しい？　も、もう……。今日の隊\n長さんは、私にすごく甘えてきますね。え……と……。それ、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長さんの……。ペ、ペニス……。……もっと下品に？　うぅ……私を困ら\nせないでください。おちんちん……。もっと！？　や、やだぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽ……を挟ませてください……。だってそれがパイズリですよね？　\n隊長さんのおちんぽを、私のずっしりみっちりおっぱいにお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……あっ！　す、すごいっ……！　隊長さんのおちんぽっ……！　こんなに\n大きくて太いなんて！　それに、私の胸なんかより何倍も重いっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽって、肉の塊だからって……ここまで凶悪な大きさになるものなん\nですか？　だ……だって……これ、赤ちゃんを作る部分でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長さんのは……おっぱいの隙間ならともかく、ア、アソコには巨大すぎる\n気がして……。あっ……、やんっ……捕まえるのも大変です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「想像よりずっと……暴れん坊さんで困ってしまいます……。待って……私の\nおっぱいの中じゃイヤ？　じーっとしていて、怖いことなんてしないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「うん……うん、いい子ね。今からパイズリして、たくさんよしよししてあげ\nるから……もう逃げちゃダメよ？　って、な、何笑っているんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽくんに私が話しかけるから？　だ、だって……。生き物みたいに、\n反応するから……。なんだか可愛く思えて……。でも、そうですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「パ、パイズリに集中した方が……この子にとってもいいですよね。喜ばせる\nなら、胸で……。お乳で気持ち良くしてあげないと。男の子だし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　はぁっ、はぁ、はぁ……。えぇと……胸のお肉で……たぷ、\nたぷ、たぷ、たぷって揺らしてあげると落ち着くのかしら……？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『せっかくだだ余りになるくらい乳肉があるんだから、チンポに絡みつかせ\nてこすりつけろ』……まぁ！　そんなの思い付きもしませんでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あっ……。こ、こう、かしら……。ンッ……♪　デコボコしていて、硬くて\n……難しいです。私の胸が滑って……あんっ、そ、それに……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「一所懸命まとわりつかせても……この子♪　おちんぽくんが元気すぎて……\nあんっ、う、内側から弾き飛ばされそう……。頑張って抑えないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「っぁ……こう……？　こう、かな……？　ぎゅぅっとおっぱい全部で抱きし\nめるみたいにして……こする。こする？　んっ……上半身を動かして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あっんっ、んっ、んっ……♪　揺らし、ながら……んっ♪　おっぱいと、お\nちんぽくんとを馴染ませて……仲良しにして……こする。こす、る……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んっ♪　んんっ……そう。これがいいのね……♪　ん、は、ぁ……♪　隊長\nさん……。やっぱり、私はこの子が愛おしいです……。んんっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「私がすることに、敏感に反応して……。あっ♪　おっぱいの谷間でピクピク\nして……♪　すごくなついたフェレットちゃんみたい……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「私のおっぱいが好き、好き、って頭をおっぱいにこすりつけてくるんですよ\n……♪　可愛い……。よちよちよち♪　よーちよちよち……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「好きなだけ甘えていいのよ……。おっぱい、どこにも逃げたりちませんから\nねぇ……♪　ほぉら、ゆっさゆっさゆっさ♪　ぷる、ぷる、ぷる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……ンッ……！？　どうしたんでしょう。なんだか今、胸の中でヌルッとし\nたものが……。あっ！　おちんぽくんの先っちょから何か……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「カウパー……というんですか、これ……。『気持ちいいと滲み出してくる』\n……？　ふふっ……そーぉ♪　気持ちいいんだったらいいのよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「もっと、もっと気持ち良くなってね。私、不勉強でカウパーのことはわから\nなかったけど……んっ、あなたが気持ちいい証なら、嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「いっぱいなすりつけていいからね……。はぁっ、はぁ、はぁ……。おっぱい\n汚していいんだからね……♪　うん♪　うん、大丈夫よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「カウパーのヌルヌルで……私の胸もオイルマッサージされてるみたい。はぁ\nっ……。ふふふ……可愛い、かわいい……よし、よし、よし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「私のおっぱいにたっぷり甘えて……癒されて……♪　今だけは、どれだけワ\nガママになってもいいのよ……。んっ……ん、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「もっと強い方がいいかしら？　ふふ……。ぐいぐい迫られるのは嫌いかしら\n？　ほら……ほら、私のおっぱいに埋もれて、溺れちゃいなさい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ん……ん、ん……っ。はぁっ、はぁ、はぁあ……♪　ぁっ……あぁ……♪　\nそう、おっぱい全体にまとわりついて♪　柔らかいのがわかるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「うん、うん……。おっぱいヌチュヌチュして気持ちいいねぇ♪　私も気持ち\nいいよ♪　……っん？　なんだか、カウパーの量が増えて……んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「え？　『出るからそのまま』？　出る……って、カウパー以外の何、が……\nって、あっ！？　も、もしかして……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んっ！？　ンンンッ……！　や、やっぱりっ……！　今度は白いお汁、真っ\n白なお汁……あっ！　あっ、胸の中にすっごく出てる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ふぁあっ……頭がクラクラするくらい濃い臭い……。胸も服もベトベトにな\nってしまいました……。んっ、あ、でも、気にしないでください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「こっちのお汁は、出しきってしまわないとおちんぽがスッキリできないんで\nすよね……？　私は平気ですから……出すのに集中してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ふぅっ♪　んんっ……ふぅう……、んっ♪　わぁ……。とてつもない量……\n。カウパーとは勢いが違って、ドピュドピュ発射されていました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「これ、は……あの。間違っていたらごめんなさい。精液というもの……です\nよね。ええ。カウパーと合わせて言うなら、ザ、ザーメン、というか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「はい。パイズリをするとこんな風に飛び出すというのは聞いたことがありま\nしたが……本物を見たら、怖気づくほど激しくて……びっくりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ふふ……だって見てください。私の胸、結構大きくて深いのに……あらゆる\nところがドロッドロ……。やっぱりこんなの、アソコじゃ受け止めきれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ど……どうして赤ちゃんを作るだけなのに、こんな爆発的な量がほとばしっ\nてしまうんでしょう。それとも、隊長さんが特別多いのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『今度試してみるか』……って、も、もうっ！　私のこと、からかわないで\nください！　パイズリだって恐る恐るしましたのに……！　あ、そうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……気持ち良くなれたかな？　おちんぽくん……。って、あら……？　やだ\n、どうしたの？　また、胸の奥でムクムクって……あっ！？　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『私が優しいから』？　『笑顔で射精を見守ってくれたから』？　……精液\nのドロドロが、胸の体温であたたまって心地いいから？　あら……そんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「また大きくなっちゃったんですね……。しょうがない子……♪　でも、いい\nですよ。このまま……再び包みこんで、パイズリし続けてあげますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んぅ……んんっ……。あ……♪　せ、精液が胸から溢れそう……。だめ……\n。こぼさないように、このまま……上手に……。ん、ん、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「っはぁああああ……♪　これ……なんだかさっきよりも、危険なカンジ、で\nす……♪　胸でおちんぽを摩擦すると、精液の臭いが際立って香って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「目の前がぽーっとするのに……。ずりゅん、ぬりゅんって、おちんぽくんが\n滑って大きく動く、から……♪　いやぁっ、私もすごく気持ちいい♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、あっ、あはっ……♪　あぁっ、あぁ……！　や、だ……あっ♪\n　感じているところ、見られるの……は、恥ずかしい、見ないで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んんんっ……だめ、だめぇ……止まらない♪　おちんぽくんが、胸の色んな\nところこする、から……精液のヌルヌルなすりつけるからぁ♪　っあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「くぅううううう……！　た、隊長さ、ん……！　本当に見ないでください、\nわ、私……乳首まで硬くしてしまって、本当に恥ずかしいんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ、んっ、んんぅ♪　『恥ずかしがっているのを見ると興奮す\nる』？　あっ、いやぁ……！　だめです、そんな不健全なパイズリっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「気持ち良くするためにしてる、のに♪　おちんぽで私が気持ち良くなるなん\nて♪　んっ……んん、ごめんなさい、ごめんなさい、気持ちいいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んぁあああああああっ♪　あぁっ！　あぁあああああんっ……んんんぅっ♪\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……！　ご、ごめんなさい……あぁ、私、私、胸で達して……！　\nおちんぽくんに精液、また出してもらいながら感じてしまい、ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あぁ……！　私がイッたのがわかるんでしょうか……。私の胸が……ち、乳\n首が感じるたびに、おちんぽくんもお汁をぴゅぅっ、ぴゅうって出して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「まるで本当のエッチを体験しているみたいです……。私のおっぱいは、この\n子とエッチをするためにあったみたい。あっ、あっまだ？　まだ出るの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ええ、もちろん大丈夫よ……。だから今回こそ、最後までちゃんと綺麗にぴ\nゅっぴゅしましょうね。私も胸で絞り出してあげるから……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「上手に出しきれるかな？　ぴゅっ、ぴゅっ♪　ぴゅっピュッ……♪　んんん\nっ……。とってもうまく照準をつけられたね、えらいね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……これで全部出た……みたいですね。あぁ……湯気がたってますよ。それ\nが鼻先をかすめて……。んん、この臭い、こびりついちゃいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「でも……私のおっぱいを、気に入ってくれた……ということですよね？　だ\nったら、頑張ったかいがありました。私も感じてしまいましたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……ふふ、なんだか、おっぱいのお肉が柔らかくなったみたい。見てくださ\nい、こねたてのおモチみたいにてろんと伸びて……ゆるんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽくんが精液を出すたびに、胸が柔らかくなっていったら……。すぐ\nに、もっといやらしいおっぱいになってしまいそうですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あッ……♪　ああああっ、んんぁあああっ……あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あ！　ご、ごめんなさい！　私っ……自分ばかりが感じてしまって、隊長さ\nんのおちんぽくんが抜けてしまいました……。え、大丈夫？　きゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んぁ……あぁ、あはぁああっ……♪　顔……？　私の顔に精液をかけたくて\n引き抜いた、のですか……？　っぁっ♪　んぷっ、ぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「も、もちろん、かけていただくのはかまいませんが……。良かった。私のお\nっぱいが滑って抜けてしまったかと思っていましたから。んっ、ンン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長さんがそうしたかったのなら……ほっとしました。……はい。好きなだ\nけ……、思う存分かけてください。っんゥっ♪　うぅ♪　熱い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「胸にかけてもらった時もあたたかくて気持ち良かったですけど……。顔だと\n、更に熱さがしっかり感じ取れます……。生々しい感触も……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ん……。ふぁ……♪　あぁ、顔から顎、首から胸に垂れ落ちていく、隊長さ\nんの熱い雫……。そしてなにより、その満足そうなお顔……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「私の胸が役に立てたようで本当に嬉しいです。パイズリの経験がありません\nでしたから……。気持ち良くなってもらえるか少し不安で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「でも、これだけ色の濃い、ねっとりとした精液を出してくれたのなら……良\nかったんだってうぬぼれても……いいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ふふ、顔も、胸も……隊長さんにマーキングされてしまいました。これでも\nう、私の腰から上は……隊長さんのものですね。なぁんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
