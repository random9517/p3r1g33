{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おーい、隊長。また電話鳴ってるよ。電話出なさいよ、隊長ー？　どこ行っ\nたんだ隊長ー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00004999_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そういえば、さっきから姿が見えない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「変ですね、さっきまでそこで始末書を書いていたのに。他にも、目を通して\nほしい書類があるのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうね、ついさっきまで確かにそこに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「部屋にいるのかも？　ちょっと呼びに行ってくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114850002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待って私も！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114850002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、それなら私も行こう。下僕のサボり根性を叩きなおしてやらなくては\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様が行くのなら、あたしも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「面白そー！　わたしたちも行くぞー！　気分転換ってやつだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「って、全員どさくさに紛れてサボる気満々かよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114850002" ]},
		{"command":[ "SETCHARA", "0", "char_00004999_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114850002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうしちゃったんだろうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0178" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「待って！　ここに書き置きが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114850003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「書き置き？　カツマさんの！？　なんて書いてあるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114850003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「『疲れました。探さないでください。いいか、探すな！　探すなよ！　絶対\n探すんじゃないぞ！』……だって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114850004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なに……？　これ。どう見ても、探してほしいようにしか見えないんだけど\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114850001" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0179" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「絶対そうだよね、この書き方は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114850002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「探さないと！　カツマが助けを求めてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114850005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、探しに行こう。このまま放っておくわけにもいくまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114850001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でも、カツマさんいったいどこへ行ったんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114850003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだなぁ……あ！　もしかしたら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114850003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0148" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「カツマさんですか？　いえ、今日はこちらには来ていませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114850004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ハズレでしたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「それにしても、あなたたちがこんなに心配しているのに勝手にいなくなって\nしまうとは。困った隊長ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114850002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「わかりました、今日はもう授業はありませんし、捜索をお手伝いしましょう\n。その代わりにルルーナさん。あなたは帰りなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114850003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え！？　ど、どうしてですの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114850002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……決まっているでしょう。週明けに小テストがあるんですよ！　帰ってお\n勉強しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020114850004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひっ！　ひいいいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114850003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あははは……ルルーナちゃん、やぶへびだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114850005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「っていうかぁ、ディアナちゃんたちもそろそろ帰りたいしぃ……カツマちゃ\nん探しは、輝夜ちゃんたちに任せていいかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうですね。わたしもルルーナ様のお勉強を見なければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060114850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いやぁあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114850004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「大丈夫。私たちに任せて。今度こそ、カツマの行先がわかった気がする……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114850006" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうね、私も。カツマさんがこんなとき、絶対に行きそうなところといえば\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114850004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜＆まりあ" ]},
		{"command":[ "SETTEXT", "「あそこしか、ない！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}