		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もう一度だけ聞きますけど、これって……やっぱり強くなる為の秘\n密特訓じゃないんです……よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00013102_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……ですよね。はぁ、私におちんちんしごいて欲しいだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203102" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「い、言っておきますけど……私、こういうことしたことないですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203103" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「男の人と付き合ったこともないし……だから、うまくできなくても許して下\nさいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203104" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え……？　太陽の石に学習させて、性格を一時的に上書きできる魔石が手に\n入ったんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00013102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そんなものをどこから……う、うん。ちょっと怖いですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203106" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたが喜んでくれるなら、私……。使いますね……？　んっ、んん……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203107" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……ふふん、この身体はしっくり馴染むな。どうした、素っ頓狂な顔をして\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203108" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「お前が望んだことだろう？　ただデカいだけのオチンポをおっ立てて、ほら\n……こうして欲しいんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203109" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふん、ちょっと触ってやっただけでビクビクと動かしちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203110" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほら。どうして欲しいのか言ってみな？　へ～ぇ。オチンポをしごいて欲し\nいねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203111" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「バカみたいに硬くしてさぁ、ゴシゴシしごかれてみっともないったらありゃ\nしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203112" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ？　舐めて欲しいだぁ？　そういう馬鹿げたことは……寝てからいいな\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はははっ！　ぎゅっと握られて痛がるかと思えば、気持ちいいだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゃあ、痛いぐらい握り締めたまましごいてやるよ……それが望みだろう？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203115" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「舐めて欲しいって言ってたよな、ほら……ここはどうだい？　ちゅる、ちゅ\nるりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふっ、バキバキにオチンポ硬くしてさぁ、乳首を舐められて感じてるなん\nてメスみたいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203117" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほぉーら、ちゅる！　ちゅぷぷ！　ちゅうぅぅ～～～っ！！　ちゅ！　ちゅ\nぱ！　ちゅっ！　ちゅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203118" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふふっ♪　オチンポが腹打ちしそうなぐらい勃起してるよ？　そんなに乳\n首をイジメて欲しいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ？　何を期待してんだい？　して欲しいなら、口にしなきゃ分かんない\nだろ……えぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203120" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ははははっ！！　しょうがないねぇ、じゃあ……望み通り乳首をしゃぶられ\nて、メスみたいに感じちゃいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203121" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅる！　ちゅぱ！　ちゅっ！　ちゅぅ……！！　ちゅっ、ちゅ、ちゅるる\n～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もう一方の乳首も寂しそうだねぇ……ほぉ～ら、くりくりって……あははっ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203123" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ビクビクってカラダごと震わせてさぁ、オチンポの先から我慢汁を垂らして\nるよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203124" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あんた、このまま乳首だけでイケちゃうんじゃないの？　そしたら完全にメ\nスだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203125" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「乳首もオチンポも服従して、メスイキしちゃいたいんだね……？　しょうが\nない子だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203126" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あんたの臭くて汚い精液、あたしの手で搾り取ってやるよ……んぅ～～！　\nちゅぷぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅる！　ちゅぱ！　ちゅっ、ちゅぅぅ……ちゅ！　ちゅっ、んふぅ、ココ\nもしっかり責めてやんないとね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203128" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほらぁ、ほらぁ……！！　尿道をほじられて浅ましくイッちゃいな……！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203129" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅるりゅ、ちゅる、れろれろ、ちゅぱ……ちゅうぅ！！　ちゅっ！　ちゅ\nぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203130" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅるる、んふぅ……イクのかい？　イク前に宣言しな……！！　そう、も\nっと大きな声で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203131" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「れろれろ、んふぁ……よく言えました、ちゅぷ！　ちゅぷぷ！　んんっ……\nこれは、んあああぁぁっ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203132" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……あぁ、なんて量を出すんだい……あたしの手だけじゃなく、胸も顔も、\n髪の毛まで……ベトベトだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふ、臭くて最高にいやらしい匂い……ちゅる、ちゅっ……ごっ、くん……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「濃厚ミルク一番搾りだねぇ……あっ。そろそろ魔石の時間が切れ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ！　はあぁ！　はぁっ！　な、何ですか今のは……！！　私、カラダの\n制御ができなかったんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「うぅ、それにカラダ中が精液でベトベトになってますし……えっ？　気持ち\n良かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203137" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もっといっぱいして欲しかった？　つ、次はこの魔石でって……いやあぁ～\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203138" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もぅ！　どこからそんなもの手に入れたんですか！　しません、しませんか\nらね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203139" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「で、でも……今の、もう一回しろって言うなら……今度は私がしてあげます\n。それじゃダメ……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「私で、いいんですね？　ありがとうございます。それじゃ、はじめますね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203201" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え、えと、さっきは確か、オチンポをぎゅっと握ってましたね。こ、これぐ\nらいで……いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　さっきはもっと強かったけど、これはこれでいい？　わかりました。\nうわ……すっごく硬い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203203" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「お、男の人ってみんな、一回終わっちゃっても、こんな風に硬いままなんで\nすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203204" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　それは人による？　そんなことより早くこすって欲しいんですか？　\nわ、わかりました……それじゃ、はじめますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203205" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「よっ……と……こ、こう……ですか？　こうやって、しこ、しこ、しこ、っ\nて……手を上下に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203206" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「上手ですか？　ありがとうございます。まだ、なんとなくさっきの感覚が手\nに残ってて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_　131_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「その感覚で、乳首も舐めてほしい、ですか？　わかりました……ぺろっ……\nちゅっ……ちゅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「な、なんだか変な感じですね。私に乳首を舐められて、あなたが悶えてるな\nんて……ちゅっ……ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203209" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい？　もっと激しく、ですね？　舌の動きも、手の動きも。わかりました\n。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅるるっ、じゅるっ、ちゅぱっ、ちゅっ……こう、ですか？　こ\nれでいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わかりました。この調子で、がんばります……じゅるるるっ、ちゅっ、ちゅ\nるっ、ちゅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203212" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、なんだか、オチンポがますます熱く、硬くなってきて……ちゅるるっ…\n…気持ちいいんですね。嬉しいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あれ……なんだか、先っぽからヌルヌルの汁が……これは、たしか、我慢汁\n……でしたよね？　出そうなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203214" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もう少し、ですか？　それでは、がんばります！　ちゅっ、ちゅるるるる、\nじゅるるるっ、ちゅぱ、ちゅぱ……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「どうですか？　気持ちいい……ですか？　ちゅっ、ちゅっ、じゅるるるるる\n……じゅぅうううっ……ちゅううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203216" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゅるっ……なんだか、オチンポが……ちゅるるっ……ピクピクしてきまし\nたね、さっきも……じゅるっ……そうでしたけど。これって、たしか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、やっぱり。もう出そうなんですか？　え？　もっと、速くしごくんです\nか？　舐めるほうも激しく？　わかりました！　ちゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ……じゅるっ……な、なんだか、オチンポのピクピクが激しく\nなってきました……え？　もうすぐ限界ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203219" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わ、わかりましたっ！　がんばりますっ！　じゅるっ、ちゅっ、べろっ、じ\nゅるるるるるっ……ちゅっ！　ちゅぅううううう～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203220" ]},
		{"command":[ "WAITINPUT" ]},
