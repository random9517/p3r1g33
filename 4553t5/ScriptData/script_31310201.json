		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「で、出ましたね……隊長さんの……精液。あの、これ、二回目ですよね？　\nそれなのにすごい量……うわっ！　まだ出てる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「最後まで絞って欲しい、ですか？　こ、こうですか？　こうやって、根元の\nほうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「うわ……まだ大きい。もしかして、隊長さんまだ満足してないんですか？　\nすごいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203304" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　今日のところはもういい？　そうですか。ちょっと安心しました。だ\nって私もう、全身あなたの精液を浴びてしまって、ベトベトで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それに……こほっ！　けほっ！　こほん！　匂いもすごいですね……うっか\nり大きく息を吸うとむせちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「でも、これが隊長さんの分身の匂い……ということは、私、いま、全身に隊\n長さんを浴びちゃったことになるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203307" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「今、私の身体にあなたがしみ込んでる……そう思うと、なんだかドキドキし\nてきちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え！？　ええっ！　こ、今度は、私の中に出すって……そ、それはつまり…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え、えと、それはちょっと、まだ、考えさせてください、心の準備が必要だ\nと思うので……ふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ！？　わっ！　きゃっ！　うわぁああああああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わっ！　わっ！　わわっ！　ちょっと！？　なんでこんなに出てくるんです\nかっ！？　これ、二回目で……うわっぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「う、うわぁ……びっくりして手を放したら、すっごい勢いで精液が噴き出し\nて……あたりじゅう、精液でベトベトですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00013102_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　手で受け止めてれば、そこまでまき散らさなかった？　もう……それ\nなら早く言ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203404" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それにしても、ホントにすごい量……男の人の精液って、こんなにたくさん\n出るものなんですね。知りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203405" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　あなたのは特別？　そうなんですか……これじゃ、あなたと結婚した\nらたくさん子供ができちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203406" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ！　ち、違いますからね！　そういうことじゃないですから！　別に、あ\nなたとの子供が欲しいっていうわけじゃないですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203407" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「い、いえ、あなたがどうしても、っていうなら考えないこともないですけど\n、今すぐっていうわけじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　それじゃまずは、カラダの相性を確かめてみようって？　もう！　あ\nなたはすぐそういうこと言う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そういうことは……その……また今度にしましょう！　もっとその……覚悟\nを決めてからです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
