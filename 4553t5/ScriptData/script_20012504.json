{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私を、呼んだか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010021990001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……お前は！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「サメ絶対殺すウーマンこと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そう、スーザン・コーマー。サメあるところに私あり。現状は……説明され\nるまでもないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000001" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「見つけたぞサメ女！！　この辺りを張っていればまた出てくると思っていた\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000002" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエル……カエル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000001" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その、コテージにいたらいきなりあいつが襲ってきたんだが……それはそれ\nとしてスーザン、なんか姿変わってないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああ。恥ずかしながら私はあいつに敗れた。だからSKC財団の力を借りて\n、サメ撃退スーツをパワーアップした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000003" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そして今日がその初陣にしてリベンジ！！　サメは、絶対、殺す！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000004" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエレェェェェッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000002" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「サメ許すまじ！！　喰らえ、サメ撃退スプレー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000005" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000003" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「水棲生物にスプレーって効果あるのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000001" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、でも嫌がってるぞあれ。どんな成分なのかはわからんが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アウウウウウッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000004" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ、サメ怪人が海へ。自力で水を出す陸より海のほうが本場でしょうから、\nこれはまずいのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふ……問題はない。アンチサメ爆雷、投射！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000006" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわ、すげえ。海が爆発してるぞ。大丈夫なのかこれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まるでダイナマイト漁のごとく。水中の怪人はひとたまりもありますまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「禁止されているけどなそれ。とにかく、有効そうではあるが。巻き込まれて\nる人や魚がいなくてよかったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あ、でも水中から水の銃弾が彼女を襲ってるわ。まるでテッポウウオみたい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000002" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「サメなのにテッポウウオ……もう何がなんだかわからんな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかしながら妙ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ？　なにがだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「スーザン殿との戦いを見るに、あの怪人は攻撃方法が多彩な様子。であるの\nに、我々にはなにやら呟くだけで攻撃はしなかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かに……なあ、ラー・サイアム、俺たちが来る前、なにかあいつにされた\nと思うようなことはあったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そう言われれば……床が濡れていたことはあったけど、それ以外は別になに\nも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000003" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんか事情があるってことか？　ジュンジロー、怪人派遣組合からなん\nか新しい派遣の話とか聞いてたか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえ。寡聞にして書類も話も見聞きしておりませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それにあの怪人、ちょっと普通とは違う気がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000004" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「なんというか、私の魔導への対抗、その仕組みが変わってる気がして。術式\nの通りが違う、って言えば分かるかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「要するに、今まで私が出会ったことのない感触だったのよ。別物……って言\nったらいいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000006" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つまり、一般的なものとは系統が別の怪人ってことか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「少なくとも派遣組合の怪人ではないと思うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000007" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まだまだ、まだ終わらない！！　サメ爆殺酸素ボンベを喰らえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000007" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ウアアアアアアアアアッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000005" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それに……あの反撃も明確な殺意はないような気がしますな。スーザン殿が\n攻撃してくるから防衛しているだけのように思えます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん、となると……これ、早まったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ははははっ！！　どうしたどうした！！　自慢のサメ肌が型なしだな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000008" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「グ……アッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000006" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「新型スーツだけあって、スーザンが優勢だな。だけど、今の考察が当たって\nるならちょっとまずい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「私の術で止めてみる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000008" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一発で止まるならいいが、スーザンはサメ退治を止められるとちょっと我を\n忘れるところがあるからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あのスーツの耐久力が高かった場合、危険だ。俺とラー・サイアムとジュン\nジローでやって止まるかどうかかもしれん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、私は海の中だと無力ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだった……水中に強いやつが一人いればいいんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「怯えろ！！　竦め！！　逃げ惑え！！　生まれた意味も分からずに朽ちてい\nけ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000009" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエル……カエルウウウウウウウウッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010022000007" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべえな、悠長なことを言ってられねえ。とにかく一度止めないと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「援護するわ。ジュンジローは可能ならあのサメを砂浜へ誘導して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010022000009" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「承りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022000009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、それじゃあ行くぞ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「何やってんだテメエえええええええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010022000001" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000010" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はっ、案の定罪のないサメをいじめてやがったな！！　アタイの勘が当たっ\nたぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010022000002" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょうどよかった。話を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「お前は……忌々しいサメ女！！　また私の邪魔をするのかっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000011" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「当然だ！！　サメを虐げるやつをアタイは許さねえ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010022000003" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「見たところ、お前もスーツを新しくしたみてえだが、アタイだって新しい力\nを手に入れた！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010022000004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「行け、ゴーストシャーク！！　あの女を喰いちぎれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010022000005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ぐっ！！　この力……なるほど！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000012" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「話を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「だが私とてこのスーツの全てを出したわけではない。ちょうどいい、あのサ\nメよりも、お前にスーツの力をぶつけてやろう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010022000013" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「上等だ！！　今日こそテメエをぶちのめして、今まで殺した全てのサメに謝\nらせてやる！！」", "NORMAL" ]},
