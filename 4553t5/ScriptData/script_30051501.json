{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっ……どうやら、戦いも一段落したみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「全く次から次へと湧いて……懲りない連中でした。ひたすら動き回って……\nかなり汗をかいてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方も汗だくじゃないですか。この程度の相手に手こずるようではこの先困\nりますよ？　んっ……ふっ……すぅぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これは……少し特別な訓練をした方がいいかも知れません……ほら、こちら\nに来て下さい……いいから、早く！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さあ、オチンチンを出して下さい。理由は……何だっていいでしょうっ、ん\nっ、さっさと出すんですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なんですか、これは。渋ったような様子を見せて、しっかりと勃起してるじ\nゃないですか。これからされることに興奮しましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、すぅぅぅ……んふぅぅ……はぁっ……あぁっ、なんて汗臭さですか。\nそれにアンモニア臭もします……不潔な臭いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くんくんっ、すぅぅっ……はぁぁっ……あぁ……こんな状態を放っておくな\nんて……どういうつもりなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……これは、厳しい指導が必要かも知れませんね。このような不潔な\nオチンチンを放っておいた指導をしなくては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふぐぅ……んっ、あぁ……んっ、まずはにおいの度合いを確かめなくてはな\nりません。じっとしていて下さいね……んんっ、すぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……むわっと広がるこの発酵臭……んんっ、クセが強くて……鼻の奥\nを刺すような刺激が……くぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふぐっ！　な、何を勝手にオチンチンを押し付けてますかっ。まさかウチの\n鼻を気持ちよくする道具かなにかと勘違いしてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅぅっ……屈辱的ですね……すぅぅぅっ……んはぁっ……ふぐっ、\n鼻の穴に押し込もうとするかのように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「言っておきますが……ウチの鼻はそこまで大きくありませんからね？　んっ\n、どう頑張っても……鼻で擦るのがせいぜいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「は、鼻コキ……んっ、よくもそんな図々しいことを……平然と言えたもので\nす……んぁふっ……はぁっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これは、しっかりと指導しなくてはなりません……んっ、ふっ、ふぐっ、ん\nふぅぅっ……んむっ、あっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それにしても……なんですか、このオチンチン……さっきより、もっと大き\nくさせて……期待してるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どこまでも節操のない、欲望まみれのオチンチンです……そんなオチンチン\nは……こうして……ぎゅっと……してあげますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……ほら……根元の弱点を抑え込まれると……とても不安になる\nでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「この無防備なキンタマも……ぐぐって……ふふっ、ウチの手のひらの中に収\nまっちゃいましたね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どうですか？　もっとコリコリって、中心の部分をほぐして欲しいんじゃな\nいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「駄目ですよ、しっかりおねだりしないと。自分の口で、どうして欲しいか言\nうんです。オチンチンをぎゅってして下さいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふふっ……あっさり言っちゃうんですねぇ。本当に欲望に正直ないやらしい\n人です……いいですよ、いっぱい扱いてあげますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はっ、あっ、んっ、あぁっ……ほら……オチンチン……皮がめ\nくれて……ぐちゅりと音がしてますよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちょっとしただけで、こんなに発情して……恥ずかしくないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……亀頭のところ……じわってお汁滲んで来て……ますます興奮して\nるのが伝わって来ますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「すぅぅぅぅっ……くんくんっ、んはぁ……オスのフェロモンも……一層強く\nなって来てます……んふぅぅぅっ……んはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……けしからん……けしからんです……こんな、欲望まみれのエッチな\nにおい……放っておけませんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もっとシコシコしたら……あぁ……オチンチン……先走りが止まらなくなっ\nてます……ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、全く……こんな路地裏なんかで、すっかりその気になって……\nだんだん射精したくなって来てるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いいですよ……下手にやせ我慢なんかされても迷惑です。浅ましい欲望……\nさっさと吐き出してしまうですよ……んっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほぉら……キンタマも、たっぷりマッサージしてあげます。んふふっ、腰が\n砕けそうになって……情けない顔をしてますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、ふっ……我慢は毒ですよ……スッキリしたいでしょう？　さ\nあ、オチンチン……観念しなさいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンチン……ビクビク震えてっ、もう出そうですっ、んふっ、射\n精……するっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんんんんんーっ！　はぷっ……！　出てっ……キツいのがっ……顔にっ、\nべったりぃっ……ふぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ……んぷっ、あぁっ……本当に遠慮なく出しまくってくれてますね…\n…また一段と強烈なにおいが……ふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「よ、よろこんでなんか……あぁ……ダメです……このにおいは……ウチをダ\nメにする……危険なにおいなんですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んちゅぷっ、ちゅぱっ……んふっ、れろっ……舌が勝手にぃ……\nれろ、ぺろ……えろ……舐めちゃいまひゅうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁ……はぁ、ふはぁ……はぁ……あぁ……んっちゅ……ちゅぱ……止ま\nってしまいました……射精終わりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、ドロドロの精液ぃ……んっ、たっぷり溢れてしまい\nました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも、ちゅぷっ、んっ……まだまだオチンチンはビキビキのままです……物\n足りないって分かってるようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それに、ウチにこれだけぶっ掛けてくれたんです……ウチとしても……この\nまま終わる気はありませんよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ドロドロのオチンチン……まず、先っぽに残った精液を味わわせてもらいま\nしょう……あぁんむ……むぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふっ、くぽっ、りゅぷっ……んじゅっ、んじゅぅぅぅっ……なんれすかっ\n……この濃いのは……んぐっ、んじゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「口の中に広がる感じ……すごいれふ……んちゅっ、ちゅぷっ……くぷぅっ…\n…あぁ……んむっ、じゅるっ、れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ひとしきり吸い出しましたよ……このまま、オチンチン……しゃぶりますか\nらね……んじゅっ、ちゅぱっ、ぴちゃ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……気持ちいいれふか？　そうれしょうとも……ウチが舐めてあげ\nてるんれふからね……貴重なご奉仕タイムれふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くびれのとこ……んっ、カリ……皮の継ぎ目……んっ、浮き上がってる血管\n……どこも、敏感になってまひゅね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぷぅっ、んちゅっ……んんっ、顔を動かしまひゅよ……んりゅっ、ぐぷ\nっ、じゅぽっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……んぷっ、太い……おっきい……頬張るのがやっとで……んっ、全然\n余裕がありまへん……んふぅぅっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ……でも……オチンチンが……んちゅぷっ、喜んでいるのは分か\nりまふ……んちゅぱっ、れる……れらぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、んれる……本当にスキモノなオチンチン……んちゅぷぅ……\nあぁ……しっかり指導しなくては……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……んちゅっ……新しい汁が滲んで来ました……それだけ気持ちよくな\nってるってことですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほら、ちゃんと言うんです……オチンチンをペロペロされて興奮して……感\nじてますって……さあ、言うですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふふ……それでいいです。正直なご褒美に、この鈴口の弱いところ……い\nっぱいしてあげますよ……ぴちゃ、んちゅっ、ちゅぷぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほら、ビクビクが強くなってます……腰が引けてますよ？　でも、逃しませ\nんからね……ちゅぷっ、んちゅうぅぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くんっ……くんくんっ……精液のにおいが強くなって来ました……ウチには\n分かります……また射精したくなってますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅっ……我慢なんて許しませんよ？　欲望は全部……そのまま開放\nさせなきゃですからねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅるっ……んちゅっ、さあ……もう限界なのはバレバレれふっ……無駄な\n抵抗はやめて、ビュクビュク出しちゃいなさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅぱっ……口の中でもっ……顔にでもっ……貴方の欲望っ……\n全部……ぶちまけるですっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふぐっ……！　んんっ、ふごい量のっ……せーえきっ……でてっ、まひゅう\nぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「むぐっ、こくっ、んぐっ……んんっ、んっく……んふぁ……あぷっ、飲みき\nれなっ……口から……こぼれっ……んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「けふっ、こほっ、こほっ……んぐっ、だ、大丈夫です。ちょっと軽くむせた\nだけで……大したことはありませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、落ち着きました……まだ、ちょっと出そうですね……吸い上\nげてしまいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅうぅぅぅぅぅっ……んふっ……貪欲……？　違います……こ\nれは指導であり、当然の権利ですから……んちゅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こくっ、んくっ、こくんっ……んふっ……ふはぁっ……全部飲み切りました\nよ……んっ、ちゅぷ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「独特の臭み……クセも強いのに、どうしても舌が伸びてしまいますね……ん\nっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えろ……れろ……んっ、ふはっ……これで指導は終わりです。これからも、\nオチンチンの状態には気をつけておくように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「清潔にしていた方がいいのか……？　そんなの……当然でしょう。ですが…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もし、貴方が不潔にしていたら、またすぐに指導しますからね？　そのこと\nを、しっかり覚えているように……いいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　思いっきり顔にっ……ふぐっ……んんっ、出てっ……ますぅぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぷぁっ……んぐっ、はぁぁ……また、精液のにおい……いっぱいに広がっ\nてぇ……んふぁぁ……鼻がおかしくなりますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「すぅぅ……んんっ、もっとです……はぁぁ、このウチをおかしくさせるフェ\nロモンをもっと吸い込んでぇ……んすぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……目がとろんとしてる……？　んんっ……余計なお世話です…\n…このにおいを嗅いだらおかしくなるのは当然ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000515_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ……ぴちゃ……ちゅぷっ、んっ……味も確かめなくては……んふぅ……\nぴちゃ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぐ……あぁ、絶対に美味しくないです……エグみも生臭さも最低です……\n最低なのに……ちゅぷ……ちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ずっと舌が止まらないれふ……全部……精液……舐め取らないと……気が済\nみません、ぴちゃ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、ふはっ……はぁ、はぁ……んっ、ふぅ……気がついたら、殆\nど舐めてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも、これで綺麗になりました。いいですか、常にオチンチンは清潔にして\nないとダメですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もし、貴方が不潔にしていたら、またすぐに指導しますからね？　そのこと\nを、しっかり覚えているように……いいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
