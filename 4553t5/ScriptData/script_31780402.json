{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もう……今日はお尻の穴でしたいだなんて、一体どこでそんなことを覚えて\nくるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「でも不快な気持ちは一切ないわね。むしろ貴方たちの本能的な考え方に、改\nめて惚れこんじゃいそうだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああんっ……！　私のアナルを犯せると思って、触手たちがさらに絡みつい\nてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんなに拘束されたら、まったく身動きが取れないわっ……！　触手の好き\n勝手にされて、一方的に嬲られちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　触手たちに無理やり犯されるだなんて……そんなの、最高す\nぎるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あはあぁ……！　とりあえずお尻の中は綺麗にしてきたから、\nいつでも挿れていいわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ほらっ……私のアナルがいやらしくヒクついてるの、わかるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「早くそのぶっとい触手を挿れて欲しくて疼いてるの……オマンコと同じくら\nい、お尻の穴がウズウズしてるのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方のヌルヌルした汁があるから、前戯なんていらないわ……だから一思い\nにアナルに触手を突き挿れて頂戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ！　触手が肛門にあたってるっ……！　あっ、あっ……！　来\nるっ……アナルに触手が入ってくるぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おほおおおおぉぉぉ！？　ぶっといヌルヌル触手、アナルに入ってる\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「肛門が無理やり広げられてるわっ……！　くっ、苦しいけど……これ、すっ\nごく気持ちいいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ！？　おほっ、んほぉ！？　どんどん奥まで入ってくるぅ！　\n私の腸内をえぐりながら、どんどん奥に来てっ…んひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ずりゅずりゅ動いてくるたびに、アナルがめくれちゃうっ！　あああっ！　\nもっとお尻を広げてあげないと、気が狂いそうになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひっ……おっ、あっ……！？　あっ、あはあぁ……！　凄い……奥の奥ま\nで触手が入ってるのがわかるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おヘソの下あたりにまで異物が入ってる感じがしてる……こんな……苦しい\nのに、気持ちいいだなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　んひいいいぃ！？　触手がズルズル動き始めてるわっ……！　い\n、いいわよ……！　遠慮しないで、思いっきり動きなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おほっ！？　おっ、んほおおおぉ！？　ぶっとい触手がお尻の中でずちゅず\nちゅ動いてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルした汁のおかげで滑りがよくて、最初からピストンが激しいのぉ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「肛門が引っ張られるたびに排泄してるような感覚が続いて……！　あっ、あ\nあっ！　粗相をしてる感じがするわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「背徳的な行為をしてるって思うと、いつも以上に感じちゃうわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんんっ！　もっとぉ！　もっとホジホジしてぇ！　私のアナル、ダメにな\nるまでいっぱい使いつぶして頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ！　くっ、あっ！？　ひぎっ、んひいいいぃ！？　触手のヒダ\nで腸内をかき回されてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「デコボコした感触がお尻の中いっぱいに広がってるわっ！　あっ！　あっ！\n　感じるっ！　アナル感じるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お尻が気持ちいいから、オマンコも感じちゃうのぉ！　エッチな汁が２つの\n穴から同時に溢れちゃってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触ってないのにクリトリスも乳首も勃起して……！　あっ、んっ！　あぁん\nっ！　アナルセックス最高よぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私のアナルを壊してもいいから、もっと感じさせてっ！　いつも以上に激し\nくズポズポしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おふっ、ぐっ、おおおぉ……！？　凄く長いストロークでアナルをズンズン\nされてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「これ、絶対に触手が直腸にも届いてるっ！　お腹の中をぐちゃぐちゃにされ\nる感じがして、たまらないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぐぐっ、あっ、んひっ！？　おっ、んおっ……おおおぉ……！？　くっ、来\nるっ……！　凄く気持ちいいのが、オマンコのすぐそこまで来てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アナルで感じてるのにオマンコがイクだなんてっ……！　あああっ！　でも\nこの凄いの、止めらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　あっ、あひぃっ！？　アナルに入ってる触手もビクビク動いて\n……！　触手汁出したいって疼いてるの感じるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いいわよっ！　このまま私のお尻に出して頂戴っ！　貴方の触手汁でアナル\nを満たしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私もイクからっ……！　あっ、あっ！　んんっ！　アナルで感じて、オマン\nコイクのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あひっ、ふっ、あっ！　イクッ！　イクぅ！　ケツ穴犯されながらイクぅぅ\nぅぅぅ～～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふおおおおおぉ！？　おっ、おっほおおおおおぉぉぉ！？　お尻の中にどぴ\nゅどぴゅ触手汁が出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「熱いのがお腹の中に溜まっていくのを感じるわっ！　んっ、あっ！　ああっ\n！　気持ちいいっ！　幸せな感じがこみ上げてくるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いっぱい出されてお腹が膨らみそうなくらい苦しいのに、イクの止めらない\nのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「イクッ！　またイクぅ！　アナルヒクつかせながら、オマンコイッちゃうう\nううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ！　ひっ、あああぁ！？　くっ、うぐっ、んんっ！　イクッ！　\nイクッ！　イクぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おおぉ……！　こんなに身体を震わせながらイッたのは、初めてかも\nしれないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手にアナルを弄られるのがこんなに素敵だなんて……想像していた何倍も\n素敵だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「この快感を１回で終わらせるなんてもったいないわ……貴方ももっと私を犯\nしたいわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お尻の中が触手汁でいっぱいになってるから、さっきよりも滑りがいいわよ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ほらっ……遠慮しないで動きなさいっ……！　私のアナルを好きなだけズポ\nズポ犯して、もっと触手汁をびゅーびゅー出しなさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひっぎいいいぃ！？　またいきなり激しく触手が動いて……おほっ！？　お\nっ、おっ！？　んおおおぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アナルをズルズルされるたびに、出しちゃいけないような声が出ちゃうぅ！\n　こんな下品でエッチな声、歌手である私が出しちゃいけないのにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「でも気持ちよすぎて、声が止まらないのぉ！　アナルを思いっきりズポズポ\nされると、勝手に喘いじゃうのほぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おぐっ、ぐぐっ……あっ、あひいいいぃ！？　触手が腸内から子宮の裏側を\n刺激してるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アナルを犯されるのにオマンコをトントンされてるみたいで……！　あっ！\n　あんんっ！　こんなの味わったことないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「肛門が擦れる快感と子宮を叩かれる快感が重なって、オマンコとアナルから\nエッチな汁が止まらないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！　あっ、あひっ！？　この快感を知ったら、もう普通のセックスだ\nと満足できなくなっちゃうわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アナルとオマンコを同時に攻められないと、イケない身体になっちゃうっ！\n　私の身体、おかしくされちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああっ！　ダメなのに、もっとして欲しいって思っちゃうぅ！　いっぱいケ\nツ穴をホジホジして、弄んで頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お尻の形も肛門のサイズも、全部触手の形に変えていいからっ！　最後まで\n思いっきり感じさせてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おふっ、んっ、うぐぐっ！？　くっ、あああっ！　触手がもっと大きくなっ\nて、アナルを限界まで広げてくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああああっ！　またイカされちゃうっ！　アナルダメにされながら、はした\nなくイッちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ひぐっ！？　あ、貴方たちもイキたいんでしょ！？　私のこと\nは気にしなくていいから、好きにイキなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「我慢せずに触手汁をびゅーびゅー出してっ！　私の身体を触手汁塗れにして\nぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ！　イクッ！　アナル拡張されながら、イッちゃうのほおお\nおおぉぉぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっほおおおおおぉぉぉぉぉ～～～～～！？　またお尻の奥に触手汁出され\nてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「しかも今度は子宮の裏側めがけて思いっきり出されてるわっ！　こんなの、\n種付けされてるみたいじゃないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「アナルに入ってるから絶対妊娠なんてしないのに、受精しちゃってる感覚が\nするのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ、ひぎぃ！？　オマンコ感じるっ！　アナルも感じちゃうぅ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎてイクの止まらないわっ！　あっ！　イクッ！　またイクッ！\n　腸壁越しに種付けされながら、イクぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んふっ……ふっ、あっ……おっ、おほぉ……！　凄い快感だったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こうして無理やりアナルを犯されるの、クセになっちゃいそうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　触手がまたお尻の中で動いてる……！　貴方もアナルセック\nスが気に入ったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……まだまだ犯し足りないって言わんばかりに、触手がビクビク跳ね\nまわってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いいわよ……貴方たちの気が済むまで、好きなだけアナルを犯しつくして頂\n戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あひっ！？　ひっ、んひいいいぃぃぃ！？　触手が一気にお尻から抜けてい\nくぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉ！？　んほぉぉぉっ！？　こ、肛門が思いっきりめくられた\n状態で触手汁を浴びせてくるだなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「しかもこの強烈な臭い……！　あっ！　あっ！　とっても濃くて臭いのに、\n嗅いでるだけで感じちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あはああぁっ！　もっとかけてぇ！　私のアナルだけじゃなくて、身体も真\nっ白にしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「熱くて濃い触手ミルクびゅーびゅーしてっ！　いやらしい汁に塗れさせて、\nベトベトにして頂戴っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ、んんっ……ふふっ……アナルも身体も触手汁塗れね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00017804_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こうやって貴方たちの色に染め上げられるのは、本当にたまらないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「でも、今日はまだ染め上げてない部分があるのよね……ほら、このエッチな\n汁を垂れ流してるところ……オマンコよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お尻の中にあれだけ出したんだから、こっちにも出したいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　そうよ……！　もう準備はできてるから、このままオマンコ\nもいっぱい犯して尽くして頂戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
