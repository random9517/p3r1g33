{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「隊長さん？　次の任務の資料なんだけど……。って、あら……？　うたたね\nしながらお休み中だった？　まあまあ、無防備な格好でひっくり返って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00024601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……見つけたのが私だったからよかったものの……。貴方ね？　他の子にこ\nんな姿を見られたら、襲われていたかもしれないのよ？　ほら、起きて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「目が覚めた？　ええ、そうよ。メアフォルマ。メアです。やめなさい、甘え\nないで。……なによ？　眠くて起き上がれない？　もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「じゃあ一発、ぎょっとしてたちどころに目が覚めるようなことをしてあげま\nしょうか。フフフッ……♪　目を閉じて。まだ開けちゃだめよ。いいわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「じゃっじゃぁ～ん……♪　え？　何のつもりかって？　さっきも言ったじゃ\nない。ぼさっとしてたら襲われるわよって。だから襲ってあげてるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024601_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方ねぇ……？　私の身体を開発するだけ開発して、さんざん欲求不満にさ\nせておいて……のんべんだらりと優雅に休憩してるんじゃないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「仕事をするか、しっかり寝るか。……じゃなきゃ、こうして私の相手をする\nのが筋でしょ？　ねえ。さんざん我慢をしながら仕事してあげてたのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「それなのに、この体たらく……。暇にしているなら、いいわよね？　私の性\n欲……しっかり解消してもらおうじゃない。抵抗は許さないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「それに……。ほら……♪　うふふふっ……。私にこうしてのしかかられてい\nるだけで、期待してオチンコがしっかり勃起しているじゃない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「したいんでしょ？　したいのよね？　貴方も……。なら、お互いに利害一致\nということで……フフッ。させてもらっちゃうわね、エ・ッ・チ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「はいはい、暴れないで～……。おとなしくジッとしてるのよ？　おねーさん\nねぇ……今日はずぅーっとムラムラしっぱなしだったの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こーんな美味しそうな肉棒見せつけられて……はいそうですかって退くわけ\nないでしょう？　んふっ……ふふ、すごく硬い……気持ちよさそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「これを自分の中に……。アソコにずっぷりねじこまれたら、絶対頭がトロ\nットロになるまで感じちゃうわ。挿入しただけでイッちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……♪　ほんと美味しそう……。うん♪　ガチガチで、太\nくて、硬くてデカくて……見てるだけで唾が出ちゃう。はぁ、はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「いいわよね？　逆レイプ……されちゃってもいいのよね？　なら……。オチ\nンコを手で支えてぇ……私の濡れたアソコの入口にあてがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「チンコの形を堪能するみたいに、ゆーっくり腰を落として……挿入しちゃう\nの。いくわよぉ……？　は、ぁ……♪　あぁあああ、あぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ッあぁああああああああぁ……！　キたわぁあっ！　キ、たぁああぁ……っ\n♪　ウフフフッ、ずっぷりオチンコ、オマンコに入れちゃったぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あっあっ、これっ……ヤバい……ぃっ♪　あっ♪　なに？　す\nっごいデカい……っ。アソコの中がパンパンになっちゃった……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「えぇっ？　想定より遥かに巨大で……、んふぁっ♪　密度すっごい……！　\nなにこれぇ♪　ディルドなんかとぜんっぜん違う……リアルすぎるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……ん？　大人のオモチャ？　貴方が私にたくさんプレゼントしてくれたじ\nゃない。もちろん、最初は貴方自身のオチンコで処女を喪失したかったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「使ってなんかいないわよ？　ただ……いつも、ディルドを触って、撫で回し\nながら想像して濡らしてたの。きっと貴方のも、こんな形で感触なんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「実際に入れたらどんな感じなのかなぁって……。それがどう！？　あっ♪　\n張り型なんか目じゃないでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ硬くて、芯が通ってて……っ！　私の柔らかいところ、濡れた\n粘膜をミチミチに一突きしちゃってくれてるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ♪　生々しい、硬いお肉の感触ぅう……！　そして、先端……\n！　先端が膨らんでて、太くて中にひっかかって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「動かす前からわかっちゃう♪　こんなの気持ち良くないわけないじゃないぃ\n……！　もうやだぁ♪　やだっ……知っちゃいけない禁断の快楽よぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こんな危険で、いやらしいオチンコをおまんこに入れて……襲って感じてる\nとか！　女の子達に知られたら生きていけないっ……困る！　なのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「勝手に腰が動いちゃう……！　あっ……！　あっあっあっ！　ぬりゅりゅっ\n、ぬぷぷぷっ、て水音がしてる……っ！　粘膜の擦れ合う音ぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私のおまんこ、貴方のチンポを包み込んで……離さないって言ってるぅ……\n！　ああああ♪　動いちゃお……♪　貴方のこと犯しちゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「いくわよっ……！　あっ♪　……ヌチョヌチョになったオマンコで、貴方…\n…のっ、貴方の逞しいのをヌプヌプこすってあげる……ぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あはぁああ……ッ♪　あぁ、あぁあ……！　き、もちいい……ッ！　えええ\nえぇっ？　セックスっ……私の理解を超えて気持ち良すぎ、るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あぁあああっ……！　あぁ～～～っ、あっあっあっあっ♪　ど、童貞クンみ\nたいにヘコヘコピストンするのが止まらない、やめられないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　はぁああっ、あぁっ、あぁああんっ！　オチンポ……ぉ！　オチ\nンポ入れたり出したり入れたりぃっ！　ゆっくり抜いて……入れたりぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ふ、ぁ、あぁああぁん……！　脳汁ドパドパ出てきちゃう！　ねえっ……貴\n方もわかる？　私の……肉ヒダ……うねってるのわかる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私っ……私、貴方を思って一人でしていた時に気付いたのよ……！　私の中\n……おまんこの中、濡れたヒダヒダがすごくまとわりついてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あっ♪　ぷちゅぷちゅって蠢いて……これって結構な名器なんじゃないかっ\nて。そう、間違ってもいないでしょう？　オチンポの反応凄くいいもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「生き物みたいに肉棒に絡みついて、むしゃぶり尽くしてきて……チンポのど\nんな反応も見逃さない、捕まえてねぶりつくす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……ね？　吸い出すみたいに動いてるでしょ……？　精液を絞り取ることに\n特化しているの……♪　ふふ、出したくなってきたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「いいの、よ……？　フフッ……私も欲しいわ！　一度経験してみたかったの\n……！　膣内に注ぎ込まれる熱い樹液の感触……興奮しちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ねえ？　ねえちょうだい？　ちょうだぁい……？　私のおまんこに精液、出\n来るだけたっぷり出して……♪　ねぇ～、まだぁ？　早くしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……そうだ、私ももうすぐイけそうだから……一緒にイキましょうか？　待\nってね……。ぁ……あ、イクわよ……？　あっ、イクっ……今、今ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んっんんんんん～ッ♪　んふんんんんん～♪　あっ！？　こうくるの！？　\nこんな、風に……あっ！　やだっ♪　精液のぼってくる、すごいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「いいわっ……いいわよ……♪　はぁっ……熱い……♪　あッ……ドクドク脈\n打って……。そんなに膣内射精って気持ちいいのね？　うらやましい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んんんぅ……っ！　中で反り返って、何度も何度も痙攣して……。これが、\nこれが膣内射精なのね……！　こんなの想定できるわけない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「オマンコの一番奥を狙い撃つこの粘液のしつっこさ……♪　あぁああ、陶酔\nしちゃう……本当に、本当に心地いいわ……最高よ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ずぅっとずーっとこのまま浸っていたい……。ん？　何かしら？　気持ち良\nく射精したからもう抜きたいの？　まさかでしょ、嫌よ。離さないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「せっかく念願の挿入と膣内射精を経験出来たのよ？　当然、このまま抜かず\nの二回目をするに決まっているじゃない。もったいないわねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「嫌よ。私が満足するまで、このオチンポは私のもの……。フフフッ、いいじ\nゃない。減るものじゃないんだし……あと少し私に貸してね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「その代わり……。あぁんっ♪　明日足腰が立たなくなるまで絞ってあげる♪\n　んぁあっ……ふぁあんっ♪　あぁ……気持ちいいところだけ絞ってあげる！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あぁ～っ……、あぁっ……あぁ……！　これ、すごい……すごいわ、ずっぽ\nりハマってる……っ！　私のあそこもオチンポを握って離さないし……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「お互いを求めて協力しあってる、子作りしようとしてる……！　あんっ、そ\nうだわ……精液っ、中に入ったままなのにこんなことしていたら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「赤ちゃん、赤ちゃんできちゃうわ……！　でき、ちゃう……できちゃうのに\n全然抜きたくない……っ！　絶対危ない、だめなのにやめたくないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あなたも……あなたもそうよね？　私と一緒で、快感に弱いの……！　精液\nのヌルヌルに愛液のネトネトが絡んで……どんどん快感が増していって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ふくれ、あがってぇ……♪　セックスやめられないのよね？　っくぅうう…\n…っ！　絶対危ないのにぃ……そう思うとなおさら続けたくなるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方のオチンポは私をおかしくさせるのよ、魔法がかかったみたいに……っ\n、おまんこ魅了してっ、離れられなくしちゃうの……とんでもないわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あ……♪　あっ……あぁ、当たるぅ……！　奥にゴツゴツ当たって、理性、\n理性消えちゃう……消されちゃう、本能だけのケモノになりそうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「っふふ……♪　でもいいかな、エッチの時くらい２人でバカになってもいい\nよね……♪　んっ、こすって……おまんこの中こすってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「深く突き上げて……、やぁああん♪　そこっ……そこよっ！　そこが感じる\nの……！　突き上げて、えぐって、……そうっ、そう、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「イっちゃう……！　あはぁああっ♪　完全にスイッチ、スイッチ入っちゃっ\nたぁ♪　オチンポにスイッチ押されちゃって……イクの止まらない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あひぁあっ♪　ひぃいっ……あぁあぁっ♪　んぁ……！　イってるの、わか\nる……？　うん、そうよ……オチンポぐちゅぐちゅ絞り上げてるのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方も……もう一度私の中で、膣内で絶頂して……！　射精、射精してよっ\n……！　もう一回、精液感じながら果てたいのぉ！　お願いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「っあぁあああッ、これよぉ……！　これっ……貴方とっても射精が上手ねッ\n……！　私、私ゾッコンになっちゃいそうっ……染みるわぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「そのまま……そのままありったけ注いでっ……いいから！　赤ちゃんできて\nもかまわないからっ……一番奥、そこ、そこに注ぐの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あぁあああ～～～っ♪　腰がガクガクになっちゃう……っ。すっごい勢い…\n…！　なんでよぉ、さっき出して二回目の膣内射精なのにぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イクぅ……イくっ！　オチンポミルクばしゃばしゃ子宮に\nかかってて……！　だ、め♪　これっ……着床確実！　受精してるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んんんんんん～～～っ！　無限にイケちゃうぅ……！　最高の男、見つけち\nゃったぁ……♪　一生離してあげられなくなっちゃったじゃないぃい～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方はっ……貴方は私の、メアの物になりなさい！　いいわねっ……！　あ\n～～～っ！　量……多すぎなのよ、でも、それが……良いのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ふぅうううう……♪　凄いわ、おまんこの中が精液にまみれて……♪　真っ\n白よ、貴方の男らしさ、嫌と言うほど注ぎ込まれて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「満足よ、隊長さん……♪　フフフ、こんなにいじりがいがあって、襲うのが\n楽しい男なんて一生出会えない……。決めたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「これからも、私は貴方を何度だって襲って、犯して、身勝手に精液を奪って\nあげる……♪　栄誉なことでしょ？　怯えたってだーめ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「エスティマちゃんたちにはバレないように……大人と大人のお付き合いをし\nてもらうわね。しっかり覚悟をきめておくように……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あっ！？　そ、そう来るの！？　完全に油断してたじゃないっ……あッ！？\n　一番いいところでオチンコ抜くなんて衝撃的ぃ……！　やぁだぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「やっ……！　やぁんっ……あぁっ！？　あっ……！　もぉ～～～っ！　精液\n、私の身体にかかって……あっ！　おあずけなんてダメぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「それっ……！　それ、膣内射精用の精液でしょう！？　それなのに……んっ\n！　こんな風に使って……！　私の不意を突くなんて……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あ、あったかい……ヌルヌルするぅ……！　んもぉ……！　これはこれで、\n確かに気持ちいいわよっ……でもね！　私の指示と違うじゃないぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「反逆よぉおっ……！　あああっ……！　……なんですって？　不意を突かれ\nた私が嬉しそう……？　よく気付いたわね……そうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方が反骨心たっぷりに、私を裏切って精液をぶっかけてきたことに……驚\nきつつもゾクゾクしてることは否定しないわ。すごい胆力じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方って……。んっ、私が想像していたよりもずっと奥が知れない面白い人\nなのかもしれないって思ったわ。この粘り気、この臭い……フフフッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こんな臭い体液を、私にぶちまける男なんてこの世のどこにも存在しないわ\nよ……。見直したわ。豪快なところ、あるじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私……もっともっと貴方を知り尽くしたくなってきちゃった。貴方を無邪気\nに慕うエスティマちゃん達には申し訳ないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「独占、考えちゃってもいいかしら……？　まずは、そうね……。この精液を\n一緒に洗うところから……なんていうのはどうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}