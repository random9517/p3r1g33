{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ふぅっ……。どうしはったんですか？　急に、こないなところに呼び出して\n……。うちがちょうど、ギターの練習終わったとこで良かったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00019802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……夜に、人気のない部屋で二人きり……。もしかして、これ、いけないお\n誘いと違います？　……いえ、まったく嫌じゃないですよ。むしろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00019802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「やっと、うちを使ってくれはるんやな～って嬉しいくらいです♪　さ♪　今\n日もお疲れでしょ。うちとベッドに座りましょう。ほら、遠慮せず……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00019802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そぉれ……♪　あら？　何驚いてはりますのん？　あんさん、今日ずぅーっ\nと、うちの足……見てたじゃないですか。ふふふ、気付いてましたから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019802_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もしかして足で……してほしいんやないかなぁって、思ってたんですけど…\n…。んふふ、そうですよね、当たりですよねぇ。いいんですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちも……ちょうどあんさんと、濃密に触れ合いたいって思ってたとこでし\nたから。まあ、それが足で……っていうのは少々驚きましたけど。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うち。見た目だけは抜群にエエってよく言われますから。清楚っぽいロング\n髪の女子、それもバンド女子のムレムレの靴下に興奮するのもわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……あは♪　チンポが期待でバッキバキやないですか……♪　すごぉい……\nコレは、とんでもないスケベはんですね。そんなに待ちきれないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「きゃっ♪　んもぉ、暴れんといてくださいな♪　大丈夫です……。うちの足\nはどこにも逃げたりしまへんえ？　こうやって……ギュッとチンポ掴んで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぜーったいに離しません♪　むぎゅ、ぎゅむ、って足裏でチンポ踏みしめら\nれるのってどうです？　気持ちええですか？　もしそうなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こう、やって♪　両足でゴシゴシシゴくのはどうでっしゃろ……♪　っん…\n…♪　やぁだ、硬い……。おっきいです……それに太くて……うふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「なんちゅう逞しい肉棒でしょ……♪　こんな立派なモノ、そそり勃たせても\nろたらうちも、本気出さへんわけにいきませんやん……困るわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……足コキって、まーったく経験あれへんのですけど。あんさんはどないな\n風にされたいんどす？　むぎゅーっと強く踏みしめられたいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「それとも……こうやって、小刻みにギュゥ、ギュム、ムギュ、って刺激され\nるのんがええですか？　ああ、ややわあ。足がもっとたくさんあったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「一度にぜーんぶしてさしあげられるのに……。残念ながら二本しかありませ\nんから。交互に色々やってみますね。フフフ、まずは丁寧に根元から」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「精液を生み出して、たっぷり睾丸に溜めてもらえるように……この付け根。\nここからよーくほぐしていきますね。……ん……。ん、んッ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あ……♪　すっごい巨根……♪　あんっ♪　そうやった、スゴいチンポっち\nゅうんは、もう根元からブリブリに太くて弾力が凄まじいんやね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こ、れ……♪　こんな力強いチンポ、足の指で必死に押しても弾かれるくら\nいの最強のチンポ……。こんなん見てたら、こっちも興奮してしまいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「っぁっ……♪　あっ、ぁっ……♪　そ、そないにJK姿のうちの靴下……。\n蒸れて湿ったクサぁい靴下がお好きですか……。んっ、本当に熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんさんの股間、ビクン、ビクンって脈打っとって……♪　これ、もしかし\nて血の巡りが良ぉなって、痙攣してはりますのん？　あぁ、そんな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んんっ！　んん……！　ぐりっ、ぐりっ、て結構強めに踏んどるし、キツめ\nに挟んどりますけど……全然負けてへん。むしろ弾力が増してくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「なんてチンポやの……♪　こ、こんなん、足ならまだしもアソコに……女の\n子の大事なトコロに入れるようなパーツやあらへん。つ、強すぎるわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　あ、あかん♪　あんまりカッコ良すぎて、このままシゴいと\nったらうちの方が感じてまいそう♪　つ、次は亀頭を攻めさせてもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そぉれ、ぐりぐりぐり～♪　んふふっ♪　こっちやったら、うちが負けるこ\nとあらへんでしょ。男の人の弱点やもん♪　……って、あっ♪　やぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「えっ……♪　あぁ、もうこないにカウパーで濡らしてはったんですね……♪\n　足の指がにゅるんとなってびっくりしてしまいました。……へぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そやの……♪　隊長さぁんは、チンポをちょーっと足で踏み踏みナデナデさ\nれるだけでこないにおかしくなってしまうんやねぇ……。かわいらし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そんならたっくさん足コキ♪　してさしあげんと……♪　……んふ♪　ふぅ\nっ……♪　ンッ……んっ、んんっ、んー……♪　あはっ♪　太ぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「勃起の角度もさすがやけど、肉笠がエグいくらいに広がっとって……。色も\nやらしい特級チンポで、素晴らしいですねぇ♪　……はぁ、はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「足で触ると、生々しい感触がしっかり伝わってきて……照れてまいます♪　\n肉竿は熱した鉄の棒のように硬くて、それなのに先っちょはやわくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「どんだけシゴいても、飽きるっちゅうことがありません……。んぁっ♪　う\nちの足、強弱つけてシコシコすると……反応も変わって楽しいですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「可能なら永遠にこうしていたいくらいです……♪　はぁ、はぁ……あんさん\nも、すぅ～っごく気持ちいいんですね♪　腰が浮いてきてますえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっん♪　うちの動きに合わせて、腰……揺らしてますのん？　あぁ……♪\n　いややわ、いやらし……♪　んんっ、もっとカクカクしていいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちも♪　気合を入れて踏ましてもらいます♪　……そぉれ♪　亀頭をぐる\nぐる足の裏で撫で回して……ずりゅっ♪　ぐりゅっ♪　と踏みしめて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ♪　女の子にこないなことさせて興奮して、チンポビキビキにし\nとるあんさんを見ながら……。うちも、うちも濡らしてまうぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　はぁ♪　あっぁっ……♪　ここですか？　ここがええの？　ふふふ\nっ♪　感じてるお顔、もっとうちに見せてぇな……♪　はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「足コキ。どんどん早くしてったら……隊長さぁん、一体どうなってしまうん\nやろ？　見てみたいわぁ……♪　……ほら。ほら、ほら、ほら、ほら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、ええの？　こういうのがええの？　あぁ……♪　元からおっ\nきなチンポが膨らんできとる、もう限界やね……♪　出して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あんさんがうちの足に精子、びゅぅ～って発射するとこ、見たいんよ♪　ね\nえ……♪　出して♪　射精して……♪　ほらっ、今や……イッてっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ッんんんんっ♪　半端ない勢いで、尿道口から精液が溢れ出してくるぅ……\n♪　ああああっ♪　すっご♪　ホントに足だけでイッてしもたん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっあぁんっ♪　花火打ち上げてるみたいに、びゅーっ！　びゅーって精液\nが♪　重力無視して飛び散っとるぅ♪　冗談みたいや……熱いぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちの……足にぎょうさんかけはって……♪　あッ♪　靴下臭くなってしま\nうわぁ……♪　もうコレ履かれへん、精液の臭いこびりついてるぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっ……ふ……♪　見て？　この、ドロッドロで濁った精液……。よっぽど\n溜まっとったんやろか。うちの指示通りびゅっびゅしてくれてありがと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「でも……。なんでやろなぁ？　精液撒き散らして、足にもかけて。満足して\nるはずのチンポはん……出した後なのに、まだカチコチの勃起状態やん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もしかして……。一発じゃ足りへんの？　ふふふっ、なんて貪欲なワルいチ\nンポなんやろ。そんなにうちの足気に入った？　このまま続けて欲しいん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……あは♪　射精したばっかりの敏感なチンポ。ベトベトになったJK靴下\nでズリズリされると気持ちええんや？　へぇ～、これはヘンタイさんやわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そんだけ卑猥なヘンタイ隊長さぁんやったら、どんだけチンポにひどいこと\nされても平気そうやね？　例えば……んっ♪　もっと早く……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「高速で、うちの足にシゴかれても。むしろそれがええんよね？　……あっ♪\n　やだ、本当に感じとる♪　えぇえ♪　早く、強くされるのが好きなん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん、ふ♪　んんっ……♪　あっ♪　あっ♪　反応すごぉ……♪　うちがチン\nポいじめるたびに、射精の時以上にビクッビクッて震えてるやない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もっと？　もっとしてええの？　これ、くらい……？　もっと？　んふふふ\n♪　うちの足のスピードと、チンポの耐久力とで勝負やね……んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こうやろ？　こうやってぇ……♪　たまにねじられたり、ヒネられたり♪　\nチンポむちゃくちゃにされんのがええんよね♪　ヘンタイ♪　っぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「またビクビクッてなった♪　靴下のサリサリした感触と、自分の精液のヌル\nヌルした感触と……二つの感触をいっぺんに味わえて、幸せなチンポやね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっ♪　休む暇なんか与えへんよ♪　チンポにどんどん摩擦熱発生させて…\n…♪　っはぁっ♪　はぁ、シコシコゴシゴシし続けたるぅ♪　あぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「いややわ♪　うちもなんだか身体が熱ぅなってきた……♪　あっ♪　ますま\nす靴下が……足の裏が蒸れてまう♪　ごめんなぁ、隊長さぁん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「チンポ、うちの足で臭くなってしまうわぁ……♪　あっ♪　で、でも♪　う\nちの匂いで♪　マーキングできる……あんさんのチンポ臭くできる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「それが嬉しくてたまらへんの……♪　だから足コキ、絶対にやめへん……っ\n♪　はぁっ、はぁ……♪　気持ちええ？　うちの足好きぃ？　はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちは隊長さぁんのチンポだーい好きやぁ……♪　だからぁ……♪　あえて\n速度を落とさずに♪　チンポに厳しく刺激与え続けるよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そぉれ、ごしごしごし♪　ぐりぐりぐり♪　シーコシコ♪　シーコシコ……\n♪　あぁああ♪　チンポ喜んでるっ、腫れて膨らんでるぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「またイクん？　うちの足にイジワルされて、チンポからびゅーびゅー精子出\nしてしまうん？　こんなムレムレのベトベトな足でイジられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「気持ち良くなってイクなんて、隊長さぁんはヘンタイやね♪　精液溜まって\nつらい？　苦しい？　……そしたら、解放してあげんとな？　いくで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちの足の動きに合わせてビューしてな……♪　５……、４、３、２，１…\n…今や♪　靴下コキで情けなく精子発射して♪　かけてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　すさまじ……っ♪　あっ！　あっぁっ！　こんなの暴発やん\n……！　思ったより大量に出てる……♪　あっ、飛び出すぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　こう、やろか……っ♪　尿道口を足で押さえて……って\n、あっ！？　やっ♪　う、ウソや♪　うちの足の力より勢い強いなんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あーっ♪　んあああっ♪　また足がドロドロになってくぅうう……っ♪　ん\nぁんんっ♪　あんっ♪　射精するたびうちの足につたわる振動っ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「だ、出しすぎやわ……っ！　あっ♪　すっごいぃい♪　足コキで二回もこな\nいな量撒き散らすやなんて……っ♪　とんでもないヘンタイやわぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　うちと一緒……♪　隊長さぁんのチンポ、足でコキコキし\nて興奮して……軽くイッとるうちと同じ♪　ヘンタイカップル爆誕やん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ええよ♪　ええよ……♪　うちの靴下に染みこむくらい出してぇな♪　……\nあっ♪　精液のシミ、二度と落ちへんくらいビュッビュしてぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……あ……♪　や、やっと止まったぁ……♪　一体、何十回精液吐き出して\nんのぉおお……♪　永遠に続くかと思ってドギマギしたわぁ……良かった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こ……これでうち……。あんさんの欲求を発散させられたんやろか？　え？\n　まだチンポに何滴か残ってるから足で絞って？　……んもぉおお～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こう？　……あっ♪　出たわ出たわ♪　……ふぅ～……♪　今日は隊長さぁ\nんの、とんでもない……ヒミツの性癖に付き合わされてしもた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「このこと、誰にも言われたくなかったら……。次はオマンコに出してぇな？\n　はぁ……♪　すっご♪　ベッドも足もネトネトすぎるわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ッんんんんっ！？　んぁっ！？　あぁんっ！？　あッ♪　ちゃ、ちゃうよ！\n？　かけてって言うたけど♪　足に、足にで身体やなくて……ぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ああああああっ♪　も、もぉ……♪　どんだけヤンチャやのぉお……♪　う\nちの身体、精子でベチョベチョになってもうてるぅ……♪　あっ♪　あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「暴発してまうくらい良かったん……？　ッきゃんっ♪　足コキでここまで精\n子飛ばすとか、よっぽど足でして欲しかったんですねぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「面白いくらいにビュッ、ビュッ！　って飛んでくるぅ……♪　あぁああ……\n♪　イタズラっ子やね……♪　あぁっ♪　気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もう、こうなってもぉたらしゃあないから……♪　好きなだけ、好きなとこ\nに出してください♪　はい、ぴゅっぴゅっぴゅっ♪　ぴゅるるるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00019802_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ん～～～～♪　うちの足も、身体も、あんさんの精子でクサクサになってし\nまいましたぁ……♪　こ、これで満足できましたぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「は～～～～♪　我ながら、足で……とはいえ、ええ仕事しましたわぁ……♪\n　隊長さぁんにも満足いただけたみたいで、なんや自信つきましたよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……それにしても……。これだけ射精してまうってことは……うちの足コキ\nが、めちゃくちゃ気持ち良かったってことでええですか？　ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「自分でも気付いていなかった才能、見つけてもろて幸せやわ。でも……そや\nねぇ、強いていうなら。うちも、あんさんに気持ち良くしてほしい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「やから、今度は……隊長さぁんが頑張ってな♪　今から楽しみにしとるから\n……♪　そうやって、お互いにずーっと気持ち良くなりましょねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
