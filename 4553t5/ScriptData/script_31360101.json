		{"command":[ "PLAYVOICE", "136_0103101" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ねえ、こんなことして何になるの？　おっぱいでオチンポ挟んで……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103102" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「気持ちイイからして欲しい？　そうなんだ？　わたし、こういうのしたこと\nないから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103103" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「うん。処女っていうの？　エッチしたことない。必要じゃなかったし。しろ\nとも言われなかったから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103104" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「なんだかさ、今まで会った人は、何故かわたしを恐れてたの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103105" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「でも、あなたにはそういうのがない。ずけずけ心の中に入ってきて……好き\nにさせちゃうの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103106" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「わたしはあなたのこと好きだから、おっぱいも見せるし、何だってしてあげ\nるよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103107" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「うん……オチンポ舐めればいいの？　ぱくって咥えて、ぴちゃぴちゃって\nしゃぶればいいんだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103108" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あむっ……ちゅぱ、ちゅっ、ちゅるる、ちゅっ、ちゅ……んぅ、何だかビク\nビク動いてしゃぶりにくいよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103109" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「気持ちイイから動いちゃう？　そうなんだ……へぇ、じゃあこれでイイんだ\nね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103110" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「はむ……ちゅ、ちゅるる、んっ、んうぅ、ちゅうぅ、ちゅっ……ちゅうぅん\n、ふあぁん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103111" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「うーん、あなたの顔みてると本当に気持ち良さそう……わたしもこういうの\nして欲しい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103112" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「え？　おっぱいを動かして、オチンポしごくの？　こうかなあ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103113" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「思ったよりもおっぱいが大きい？　そうなんだ……わたしは他人のことよく\n分かんないや」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103114" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あなたが喜んでくれるなら、いいことなんだね。おっぱいでしごいて……ん\nうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103115" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ぱくっと咥えてしゃぶる。ちゅるる、ちゅむむ……んうぅ、ちゅむ、ちゅむ\nむ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103116" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「もっと奥まで咥えるの？　いいよ。咥えられるだけやってみるね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103117" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「じゅむ……じゅむむむ、んんぅぅぅ～～～っ！！？　けふぉ！　けほっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103118" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「え？　今のが気持ちイイの？　じゃあやるよ。ちょっとむせただけ……\n大丈夫」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103119" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「しゃせーしたいんでしょ？　見たことないけど、白くてネバネバしたのがオ\nチンポがビュルビュルって出ちゃうんだよね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103120" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「いいよ……わたしの口に出して。え？　うん……飲んであげる。あなたのを\n飲み干してあげる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103121" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「えっ、あ……ちょっと。おっぱい揉んでどうしたの、あっ、あああ……やぅ\nぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103122" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んっんんん……！　乳首ぃ、触ってると凄い気持ち良くなる……の、ふあぁ\n、はぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103123" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「突然でビックリしたって……？　みんな気持ちイイものじゃないの？　わた\nし、乳首とオマンコは弱いよ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103124" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ああっ、だからつままれると……んん～～～っ！！？　あああぁ……！！　\nはぁ！　はぁぁ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103125" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「う、うん。軽くイッちゃった……頭の中が真っ白になったの。おっぱい責め\nられながらしゃぶるの？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103126" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「わたしにも気持ち良くなって欲しいからって？　じゃあ……いっしょにイッ\nちゃおう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103127" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あなたのそういうところ、好き。だーーーいすき。あむっ……ぢゅむむ、\nじゅぷぷぷ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103128" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「えふぉっ、んふぅ……大丈夫、喉でオチンポの先ぃ、ぎゅっぎゅってしごい\nたげる……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103129" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「おっぱいも動かして、オチンポしごいちゃうもん……ぢゅぷ！　ぢゅぷぷ！\n　んんぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103130" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「じゅぷぷ！　じゅるる、じゅむ！　んんぅ！　じゅぷ！　じゅっぷ、じゅぷ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103131" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んふあぁ……オチンポがビクビクって震えて……あぅぅぅんっ！？　乳首ぃ\n……あああぁ～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103132" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「イクの？　イッちゃうの？　わたしもイクから……！　い、いっしょにイこ\nう……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103133" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ぢゅむ！　ぢゅぷぷ、ぢゅるっ……んふぅぅ！　んっんっ！　んうぅ～！　\nあうぅ、んあぁぁん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103134" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ひゃぅっ！？　んあああぁ～～っ！！　あああああ～～～～～！！！！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
