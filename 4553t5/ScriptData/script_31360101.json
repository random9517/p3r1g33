        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103135" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んひゅうぅ……熱くて、すごい量……ネバネバで、んあぁ、ごくっ……ごき\nゅっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103136" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んあぁ、はぁっ、ちゅばば、ぢゅるる、ごくっ。ごっ……くん、ふあぁーっ\n、はぁー、はあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103137" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「すごく気持ち良かった……よ？　あなたも……？　なら、良かった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103138" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「わたしなら、いつでもオチンポしゃぶってあげるから……言ったらいいと思\nう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0103139" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「でもその代わり、わたしが一緒に居たいって言う時は、一緒にいるんだよ？\n」", "NORMAL" ]},
