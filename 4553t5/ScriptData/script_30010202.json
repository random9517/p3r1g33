		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっひぃいいいいいいんっ！！　あひっ、あっ、あぁっ、んひぃいいっ！　\nオマンコ、あちゅいぃっ！　精液、どぷどぷ、いっぱい出てるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204302" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ひぃっ！　オチンポの先っぽから、ザーメンっ、んほぉっ！\n　オマンコの奥っ、子宮の入り口に、かかっちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204303" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、もう、らめぇっ！　オマンコ入らないぃっ、もう、いっぱいだ\nからぁっ！　ひぅううっ、オマンコ、ぱんぱんっ、はれつしちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204304" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぴゅっ！？　んきゅうううゅっ！？　し、しきゅうっ、せーしっ、オマン\nコから、ナカに……んぴゅうっ！？　入って、きちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204305" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぴぃっ！　らめっ、じゅせいしちゃうっ、はらまされちゃうっ！　あっあ\nっあっ！？　イくっ、たねづけされながら、イくっ、イくうううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_11" ]},
		{"command":[ "PLAYVOICE", "001_0204306" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ、はぁ、はぁっ……くうぅぅ、奴隷オチンポにイかされてしまったぁ……\n私がご主人様なのにぃ、今日は私がするはずだったのにぃ、おのれぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204307" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぅぅっ、オマンコのナカで、ザーメンが動いてる……ひあぅっ、あ、あぁ\n！　お尻の方からも、漏れて……あひんっ、ダメぇ、見ないでぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_10" ]},
		{"command":[ "PLAYVOICE", "001_0204308" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅぅっ、どれだけザーメンを出したというのだ……ナカがたぷたぷだぞ、\nまったく……んんっ、お腹の奥が精液で熱くて、重くて……んんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204309" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、こんなに出されたら、本当に妊娠してしまうぞ……？　いいの\nか……？　その時はきちんと、責任はとってもらうからな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204310" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、これでお前の身も心も、私のモノになったということだ。浮気は\n許さないぞ？　もしシたら、お仕置きが待ってるからな。分かったか！？」", "NORMAL" ]},
