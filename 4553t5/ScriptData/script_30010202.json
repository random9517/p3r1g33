		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、あっ、ドロドロの精液が、どぷどぷ、降り注いでぇ、んふあ\nあっ、マーキングされちゃてるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204404" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、臭くて、汚い、奴隷オチンポで、んふうぅっ、匂い付けされて\nるぅっ、あっ、あっ、ダメぇぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204405" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ベタベタの精液、熱くて、臭くてぇっ、んくぅぅっ、あぁっ、またクる、キ\nちゃうっ、ザーメンのニオイでイっちゃうっ、あ、イく、イくっっ……！！」", "NORMAL" ]},
