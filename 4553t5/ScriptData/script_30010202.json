{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "001_0204101" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、もうこんなに大きくしているのか……オチンポがカチカチではないか\n……早く私のオマンコに挿れたくてたまらないのか？　可愛い奴め……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204102" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、まだだぞ……そら、私のオマンコを押し付けてやる。んんっ、オマン\nコの割れ目にオチンポの裏筋を食い込ませて、前後に擦ってやる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_02" ]},
		{"command":[ "PLAYVOICE", "001_0204103" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁっ……どうだ、たまらないか？　オチンポがビクビクと震えてい\nるぞ？　もっと擦ってやろう、んっ、んふぅっ……気持ちいいか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204104" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、こらっ、待て！　勝手に挿れようとするんじゃない……あぁんっ、\n亀頭がオマンコの入り口に当たって……って、ダメだ、待て、ステイだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_01" ]},
		{"command":[ "PLAYVOICE", "001_0204105" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ、まったく、チンポ癖の悪いバカ犬め……ご主人様の命令はきち\nんと聞け。でないと今日は、挿れさせてやらないからな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204106" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、情けない顔をするな、そんなに私のオマンコに挿れたいのか？　オ\nチンポもこんなに固くして……んっ、もう待ちきれないのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_02" ]},
		{"command":[ "PLAYVOICE", "001_0204107" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ、分かるか……んっ、私のオマンコもこんなに濡れてるぞ……んふぅ\nっ、お前のチンポと擦れて、ああっ、イヤらしい音を立てている……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204108" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前以外の男は触れたこともない、キツキツでトロトロのオマンコに、んん\nっ、今からお前のオチンポが入って、ニュポニュポ、シゴかれるんだぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204109" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「挿れたいか……？　なら、きちんとおねだりをするんだ……んぁぁっ、ご主\n人様のオマンコに奴隷オチンポを挿れさせてくださいって、言ってみろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_01" ]},
		{"command":[ "PLAYVOICE", "001_0204110" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　ふぅ、ふぅっ……仕方ないな、挿れさせてやろう……\nほら、オチンポの先がオマンコの入り口に当たって……ん、んんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_06" ]},
		{"command":[ "PLAYVOICE", "001_0204111" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あふぅぅっ……！　あぁぁっ……入ってくるぅっ……！　カチカチに固くて\n、大っきくてぇ……あぁんっ、奴隷オチンポが、私のナカにぃっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204112" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あっ、あぁっ、オマンコのお肉を、ぶりゅぶりゅってかき分けなが\nら、奥までぇっ……んふぁっ！？　先っぽが、子宮口に当たって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_04" ]},
		{"command":[ "PLAYVOICE", "001_0204113" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ、どうだ……根本まで入ったか……？　ぐ、ぐっぽりだと……！\n？　よ、余計なことは言わなくていい！　あと、あんまり見るな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204114" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ！　こら、勝手にオチンポを動かすんじゃない！　んふあっ、オチン\nポがナカでビクビク、跳ね回って……くっ、わかってる、そう急かすなっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204115" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今、動いてやる……んふぅぅっ、いいか、今日は私がするからな……あふぅ\nっ、お前はそのままだぞ……んんっ……これは命令だからな……いいな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_05" ]},
		{"command":[ "PLAYVOICE", "001_0204116" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あふううっ……！　オチンポが、抜けて……あっ、あっ、あっ\n！　ぷりぷりって、カリ首っ、オマンコのナカ、引っ掻いてっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204117" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あふぅぅっ……！　あぁぁっ、亀頭が、オマンコの入り口に、引っかかって\n、んんぅっ……いいか、また腰をおろすぞ……あぁあぁぁああっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204118" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「すごいぃっ……！　カチカチのオチンポが、また、オマンコのナカ、ずにゅ\nにゅうってぇ……！　あっ、あっ、あっ、ダメだ、腰が止まらないっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204119" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、あんっ！　くふぅううっ、見るなぁっ、後ろから、オマン\nコずぽずぽぉっ、あひぃっ、オチンポが入ってるとこ、見るなぁっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_04" ]},
		{"command":[ "PLAYVOICE", "001_0204120" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　オマンコ、イイッ、気持ちいいっ……！　お前は……？　ああ\nぁっ！　どうだ……ちゃんと私のオマンコ、んふぅぅっ、気持ちいいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204121" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふあぁっ、あっ、あっ、それなら、もっと激しくしてやるっ……私のオマン\nコでぇ、んふぅぅっ！　もっと、オチンポ、気持ちよくなれ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_05" ]},
		{"command":[ "PLAYVOICE", "001_0204122" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふあぁっ！　あっ、あぁっ！　すごいぃっ！　あぁぁっ！　オチンポっ、\nオマンコのナカでっ、あふぅぅっ！　奥まで、行ったり、来たりっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204123" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ！　ぐちゅぐちゅっ、ふあぅっ！　オマンコのナカ、かき\nまわしてるぅっ！　あぁっ！　いっぱい、エッチな音しちゃってるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204124" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁっ、あっ、あっ、どうだ、んふあぁっ！　オマンコ、気持ちいいか、\nあっ、あふぅぅっ！　気持ちいいと言え、あひぃいんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_04" ]},
		{"command":[ "PLAYVOICE", "001_0204125" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぅううっ！？　オチンポ、オマンコのナカでふくらんで、あぁんっ！　\nイきそうなのか？　あっ、あっ、私のオマンコで、オチンポ射精するのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_05" ]},
		{"command":[ "PLAYVOICE", "001_0204126" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメだっ！　あっ、あんっ！　まだ、まだだぞ、あふぅっ、ちゃんとおねだ\nりしろっ！　んひぃっ、勝手にイったら、許さんからなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204127" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ご主人様のオマンコで、んふぅっ、奴隷チンポをイかせて、汚らしいザーメ\nンを、、あっ、あっ、ナカ出しさせて下さいと、言え……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_06" ]},
		{"command":[ "PLAYVOICE", "001_0204128" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、もうっ、あひぅぅっ！　言えっ、早くっ、言うんだっ、んふあ\nっ！　あっ、あぁっ！　おねだりしろっ、はやく、はやくぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204129" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あはぁんっ！　あっ、あぁっ！　いい、いいぞ、早く出せっ……あっ、あっ\n、私のナカにいっぱい、んひぅっ、お前のザーメンを、射精しろぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204130" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃんっ、ひあっ、あっ、あぁっ！　ダメだっ、私も、イくっ！　ああっ\n、私のオマンコに、いっぱい、んはぁっ、精液、ナカ出ししてぇっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_02_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0204131" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひあぁああああっ！　あぁんっ、熱いィッ！　あぁあっ、あっ、出てるぅっ\n、ふああっ！　オマンコのナカに、ザーメン、いっぱいぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204132" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　ドロドロの、精液、あふぅっ！　オマンコの奥に、ドプド\nプぅっ、、あぁんっ！　当たっちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204133" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あっ、あっ、あっ……オマンコのナカに、奴隷ザーメン、どぴゅど\nぴゅ……あぁんっ、ネバネバの精子がこびりついてるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204134" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……！　まだ、出てるぅっ……ひぅぅっ、そんなに出されたら\n、赤ちゃんできちゃうっ……奴隷オチンポに、孕まされちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204135" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、気持ちいいっ、ザーメン、いいっ……！　あっ、あっ、またイくっ\n、イっちゃうっ、オマンコにナカ出しされて、イっちゃうっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_08" ]},
		{"command":[ "PLAYVOICE", "001_0204136" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁっ……あぁ、すごいぃ……オマンコのナカに、精液、いっ\nぱいぃ……あはぁぅぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204137" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「熱くて、じんじんして……ふあぁ……奴隷の臭いザーメンが、オマンコの奥\nまで染み込んでるぅ……ニオイが取れなくなっちゃいそうだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204138" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはあぁっ……ネバネバの精子が、オマンコにこびりついて、んんぅっ、赤\nちゃんができてしまうぞ……あぁっ、奴隷チンポに孕まされてしまう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_07" ]},
		{"command":[ "PLAYVOICE", "001_0204139" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……まったく、こんなに大量に出すなんて……そんなに私のオマ\nンコが気持ちよかったのか？　しかたのない奴め……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204140" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これは、特別に……そう、特別に、ご主人様のオマンコを使わせてやったん\nだからな？　感謝するんだぞ？　ほら、きちんとお礼の言葉を言え……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204201" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あんっ……なんだ、オチンポがまだ固いままではないか……んあぁっ\n、もっと私のオマンコで気持ちよくなりたいのか？　ワガママな奴隷め……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204202" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかたない、それならこのまま続けてやろう……んふぁっ、あっ、あぁっ…\n…むしろ今日は、あぁんっ、私が満足するまで、終わらないからな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204203" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のオマンコで……んふぁっ、あっ、あっ……お前のオチンポを犯しぬいて\n……あふぅっ、んっ、んふぅっ、徹底的に、搾り取ってやるぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204204" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あっ、あひぅっ、どうだ、嬉しいか……？　あぁんっ、あっ、あふ\nぅんっ、嬉しいと言え、あぁんっ、あんっ、ほら、言ってみろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204205" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これで、どうだ……あふうっ！　んふぁっ、あっ、あぁっ、ご主人様のオチ\nンポで、貴様の奴隷オチンポを、あはぁんっ、激しくシゴいてやる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204206" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それ、こうしてナカを締め付けると、あひうっ……！　んっ、んんっ、オマ\nンコとオチンポが密着して、あぁんっ、気持ちいい、だろっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204207" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら、ほらっ、あっ、あぁっ、あんっ、もっとオチンポ、気持ちよくなれ、\nんひぅっ、そら、そらっ、私のオマンコに、夢中にさせてやる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204208" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あっ、私のオマンコなしに生きられない身体にしてやる、あ\nぁんっ、他の女のことなど考えられなくなるくらい、私に夢中になれっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204209" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これはどうだ……んふぁああっ、腰を回しながら、ずぽずぽぉっ、んひぅう\nうっ！　オチンポぐるぐるかき回されて、あはぁあんっ、いい、だろ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204210" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、このっ、だらしないオチンポめっ！　あんっ、あぁんっ！\n　浮気症の、ダメチンポ！　こうしてやるっ、あんっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_09" ]},
		{"command":[ "PLAYVOICE", "001_0204211" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいいいんっ！？　あっ、あへっ、なにっ……？　下から、オチンポ、\nズンって……んほぉおおっ！？　こら、やめ、えへぇええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204212" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメだ、今日は私がする番だから……あひぃんっ！　お前は、動くんじゃ…\n…ぁおぉんっ！　オチンポ、やめっ……ぇひいいっ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204213" ]},
