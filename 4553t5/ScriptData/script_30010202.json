		{"command":[ "PLAYVOICE", "001_0204409" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅぅっ、まったく、お前という奴は……んんっ、ちっとも私の言うことを\n、聞いてくれないのだからな……ふぅぅ、ちょっとだけ、傷ついたぞ……」", "NORMAL" ]},
