		{"command":[ "PLAYVOICE", "001_0204214" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あへっ、あへぇっ！　やめろっ、オチンポ、やめっ、あはぁあんっ！　あひ\nぃいっ！　やめて、おねがいっ、いひぃいいんっ！　言うことを聞いてぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204215" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今日はダメなのぉっ、あひぃっ、私がオチンポを、夢中にさせる日なのぉっ\n！　オチンポ、ズンズン、気持ちよすぎるからぁっ！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_02_09" ]},
		{"command":[ "PLAYVOICE", "001_0204216" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃっ、あひぃんっ！　私が、ご主人様なのにぃっ、んひぃんっ！　せっ\nかく頑張ってぇ、あぁんっ！　こんな、恥ずかしい格好、してたのにぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204217" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、やぁあっ、オチンポ、太くなってるっ、あひぃいっ！　ダメぇ\n、今、射精しないでぇっ！　オマンコに、止めをさされちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204218" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あへっ、今、しゃせーされたらっ、あぁんっ！　熱くてネバネバの\nせーし、オマンコにどぴゅどぴゅされたら、ホントに堕ちちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204219" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あへぇっ！　もう、らめぇっ！　奴隷オチンポ、気持ちよすぎるぅっ！　堕\nちちゃうっ、このオチンポなしに、生きられない身体にされちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0204220" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、もうイくっ、イっちゃうっ、オマンコずんずんされて、イか\nされちゃうっ！　奴隷オチンポに堕とされちゃうっ、イっくううううっ！！」", "NORMAL" ]},
