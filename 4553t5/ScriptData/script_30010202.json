		{"command":[ "PLAYVOICE", "001_0204402" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ！　ああっ、あぁんっ！　アツアツのザーメンシャワーっ、しゅごいっ\n！　んふぁあっ！　身体中にかかってるぅっ！」", "NORMAL" ]},
