{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0176" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「時間稼ぎは終わりだ！　引き揚げるぞ！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "隊長らしき襲来者（インベーダー）の号令で、敵部隊はワームホールを開くと\nその中に飛び込んでいく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ！　ずるい！　あいつら、ワームホールを自由に開けるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うらやましがってる場合じゃない！　戦艦がビームを発射した！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわああああああ！　もうダメだ母上さまぁあああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや待て！　あれは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "巨大な宇宙戦艦から伸びたビームは列車を捕え、戦艦の方へと引き寄せていく\n。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こ、これは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんたちを、捕まえようとしてるってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、なんだ。そういうことか……！　驚かせるんじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くそっ！　やっぱりあいつら、こっちをなめてやがんな！　だったら、あの\n宇宙船の中に引き込まれたところで大暴れして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのとき、宇宙空間を二筋の閃光が走ったかと思うと、巨大戦艦の一部で爆発\nが起きた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「いまのなに！？　アナザー、なんかした！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや、私はなにも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「牽引ビーム、消失！　亜空間通信を受信！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040114430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「通信だと！？　っていうかメカジュンジロー、そこにいたのかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「私も気づかなかったよ……って、そんなことは後でいいから！　通信をつな\nいで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114430002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「了解！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040114430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「こちら、次元海賊団アルデバラン。Ｇ・ルナリアムのみんな、聞こえてるか\nい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様はたしか……アルフィルクか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そう。いつだったか居酒屋・正義（まさよし）で会ったね。そのよしみで、\nというわけではないけど、救援に来たぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当か！？　それは助かる！　今にも捕まりそうだったんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ははは、そのようだね。ちょっと待ってな。いまから敵艦隊を片付けてやる\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、敵はかなりの戦力だぞ？　一隻だけで大丈夫なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「なめてもらっちゃ困るね。こっちは宇宙海賊だよ。数ばかりの正規軍艦隊な\nんか、石のタヌキみたいなもんさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「それに、一隻だけじゃない。わたしたち、トレミー海賊団もいる。どこの宇\n宙でも、わたしたちが組めば最強」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114430001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そういうわけで、この場はアタシたちに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「はーっはっはっはっは！　会いたかったぞ！　Ｇ・ルナリアムの諸君！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114430001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「その声はベルガマスク！？　なぜそんなところに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114430005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「宇宙の海は私の海、私の果てしない憧れさ！　この世に出番がある限り、\nベルガマスクは――あ、ちょっと待て！　マイク横取りするな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114430002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「いま忙しいんだから、あんたは少しおとなしくしてな！　勝手に乗り込んで\nきたくせに、態度でかいんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「せめて名乗りぐらい、最後までさせてくれぇ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114430003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「うるさいっての！　あー……すまないね。とにかく、あんたたちはアタシら\nが護衛する！　ここからが海賊の――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「海賊の戦い方の、見せどころ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114430002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「って！　あんたまでアタシのセリフとるんじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114430008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「これも海賊のやり方。ふふふふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114430003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なんか、向こうも大変みたいねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、助けに来てくれたのはありがたい。海賊戦法、しかと見せてもらおう\nじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}