		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス＆夜叉" ]},
		{"command":[ "SETTEXT", "「月面鬼面フラッシュシュート！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001701_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ああっ、受け止められた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「最初より威力が落ちているようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それから試合は動かない。ただ体力を消耗していくだけだ。大技を連発してい\nたルナテミスたちは徐々に不利になる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
