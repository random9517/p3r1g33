		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "解説も急に出てきたベルガマスクもよくわからんが、なんだか凄いことが起\nきそうなのは伝わってくる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
