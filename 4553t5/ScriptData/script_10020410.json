		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「特訓は厳しいし、めちゃくちゃだし、身体はボロボロになるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113650008" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すぐ怒鳴るし、威圧感も凄いし、口答えを許さないし……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113650009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
