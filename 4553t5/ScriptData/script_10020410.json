		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ベルガマスク様より受け継いだ、技と心のすべてをここにぶつける！」", "NORMAL" ]},
