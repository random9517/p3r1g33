		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "襲来者のボールを受け止めたルナテミスが膝をついた。", "NORMAL" ]},
