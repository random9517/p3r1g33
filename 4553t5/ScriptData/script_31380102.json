{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はあああぁ……今日も大変な一日だったな。全身汗びっしょりだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「っていうか、お前はいつまで付いて来るんだ？　ここ、あたしの部屋だぞ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あたしの汗のニオイが気になって仕方ないって……お、お前、なにそんな変\n態みたいなこと言って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待て……こっちに来るな！　な、なにをする気だ……！？　\nお、おい！　人の話を聞け！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00013801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「まっ、待て……！　少し落ち着け……きゃあああああぁ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……あっ、あはああぁ……！？　お、お前……こんなことして、\nタダですむと思ってんのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひいいぃ！？　ひ、チンポをマンコに擦りつけるなぁ！　く、クリトリスが\n擦れて……全身、感じて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「マンコが湿ってきて、ぐちゅぐちゅって変な音が……なんでこんなに気持ち\nいいんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「べ、別に濡れてなんかいない！　これはマン汁じゃなくて……そ、そう！　\nこれは汗だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「だからもうチンポ擦りつけるなっ！　汗まみれで、お前も気持ちわるいだろ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「蒸れていいニオイがするって……そ、そんなわけあるか！　こんなの、クサ\nイだけだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「だ、ダメだ……！　ほ、本当にマンコが濡れてきて……感じすぎて、チンポ\n欲しがってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「子宮の奥まで犯して欲しいって……あたしの本能が訴えてきて……あはああ\nぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んくううぅ……！　な、なにマンコにチンポの先端当ててやがる！？　ほ、\n本当にやめろ！　こんな状態で挿れられたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「いっ、挿れるな……！　ダメ……！　ダメだって……あっ、あああああぁ…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んひいいいいぃ～～～！　あぐっ、ひっ、ふああぁ……ぶっといチンポ……\nんぐっ、あ、あたしのマンコに入ってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ガチガチの勃起チンポが、マンコえぐってぇ！　一気に子宮口まで届いてる\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「こんなの、マンコがチンポの形を覚えちまう……！　そ、そうなる前に抜か\nないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はひいいぃ！？　い、今、ビクンってチンポが跳ねて……！　それに反応し\nて、あたしのマンコもぎゅっって締まって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んぐううぅ……！　やっ、やめ……！　う、動くな……！　ギチギチのキツ\nマン状態で動かれたら、あたし絶対に感じすぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んひいいいぃっ！？　あっあっ、くあああぁ！？　マンコがずりずり擦られ\nてるうぅ！？　カリがあたしのマンコの肉、削ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あっ、はぐううぅ！　チンポ挿れられて感じまくってるぅ！　あ\nたしのマンコ、悦んで……おほおぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「やめっ、チンポ動かすなぁ！　奥の方、執拗にトントンって突かれて……！\n　何度も赤ちゃんの部屋叩かれてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んんんんっ～～～！　そ、そうやってグリグリするのもダメだっ！　これ以\n上、押しつけないでくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「お前の我慢汁、子宮の奥に注がれてるのわかる……！　あたしのマンコが、\n勝手にチンポの先端に吸い付いてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あああっ、んああっ！　ゆっくり引き抜かれると、マンコが\n引っ張られる感じが……あはああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あ、あたしのマンコが、お前のチンポを離したくないって言ってるみたいだ\n……！　そんなこと、全然思ってないのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「頭ではチンポを否定しても、身体がお前の勃起チンポを求めてる……！　こ\n、こんなのおかしい……！　こんなの、あたしじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んぐうううぅっ！？ひぐっ、あっ、ああううぅ……！　ち、チンポに負ける\nなんて……！　あたしが女だって、マンコに教え込まれるなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……い、イヤだ……！　あたしが負けるなんて……んっ、あっ、\nくううぅ！　しかも、お前のチンポに屈するなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あ、あたしは負けない……！　あたしがイク前に……あっ、ひっ、あああっ\n！　お、お前がイケば、チンポに屈したことにならないんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「もっとマンコ締め付けてやる……！　それで、さっさとイキやがれ！　無様\nにザーメンを吐き出して、あたしを犯したことを後悔しろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んぎいぃ……！？　あああぁ……！　チンポが何度もビクビクしてる……！\n　亀頭がなんか膨らんで、マンコの膣内を抉ってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「いっ、イクんだな……！？　はっ、ははっ！　ざ、ざまぁみろ！　あたしを\nチンポで負かそうなんて、百年はやいんだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あぁ、あひっ、んんんっ！　ほらっ、出せっ！　あたしの膣内に、敗北ザー\nメンたくさん注ぎやがれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んはああああぁ～～～～っ！！？　あっ、熱いの出てるううぅ！　子宮にこ\nってりザーメン、びゅるびゅる出てるううううぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひゃううううぅ！　き、気持ちいいっ！　精液を赤ちゃん部屋に注がれるの\n、気持ちよすぎるうううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「これっ、ダメ……！　やっぱり、あたしもいっ、イク……イクうううううぅ\n～～～～～！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、ひああぁ……！　ザーメンで……膣内出しで、イキまくって\n……はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「で、でも……先にイッたのは、お前だ……！　ざ、ざまぁ見ろ……！　あた\nしは負けてない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひっ！？　ち、チンポがまたあたしの膣内で暴れてる……！？　な、ななな\nっ……なんで……！？　あんだけ精子出したのに……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ま、まだ出せるだって……！？　マンコが屈するまで、あたしを犯すって…\n…そ、そんなことされたら、あたし……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んはあああぁ！？　あっ、あぁんっ、んひあああぁっ！　よ、容赦なく犯さ\nれてるぅ！　さっきよりも激しいピストンで、子宮押し潰されてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「こんなの狂うっ！　頭の中、全部気持ちいいことで塗りつぶされるっ！　チ\nンポに負けるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「子宮が疼きまくって、卵子が精子求めてる……！　さっき出された精液じゃ\n物足りないって言ってるみたいで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あひっ！　んっ、ひっ、はひいいいぃ！　マンコの肉がうごめいて、チンポ\nに奉仕してるっ！　あたしのマンコ、とっくに屈してるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んふううぅっ！？　おっ、おおおぉ！？　ダメだっ！　もっ、抜いて……チ\nンポ抜いてえええぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ！　抜けって言っただろぉ！　なんで奥の方グリグリするんだ\nあああぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひぎいいぃ！？　あ、足をこれ以上持ち上げるなぁ！　そんなことされたら\n、チンポ突きやすくなるだろぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ぐっ、あぐううぅ！　だ、だから、動くなって！　クソっ！　こうなったら\n、マンコを思い切り締め付けて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あひぃいいいいぃ～～～！？　お、おまっ……マンコ締め付けているときに\n動くとか反則……ああああぁあっん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ダメっ！　ダメえええええぇ！！　もうあたしの意思でマンコ締め付けられ\nない！　お前の動きに合わせて、勝手にマンコが締め付けてるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「負けっ！　負けだからっ！　あたしの負けでいいからぁ！　だからもう、マ\nンコほじるなっ！　子宮口叩くなぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「おほおおおぉっ！？　チンポ凄すぎるぅ！　勃起しっぱなしのたくましいチ\nンポが、何度もマンコ擦ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「イッ！　イクっ！　こんなの、強制的にイカされるうぅ！　イヤだっ！　犯\nされてイクなんて、イヤだあああぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あ～～～っ！　あああぁ～～～っ！　イヤなのに、マンコ悦んでるぅ！　う\nごめいて、このチンポが好きって言ってるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「だ、出されるっ！　屈した子宮に、トドメさされるっ！　精液出されて、孕\nんじゃうううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひいいいぃ！？　チンポ抜きたいのに、抜けないぃ！！　マンコのヒダが、\nチンポをがっちりホールドしてるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、んああああっ！　イクッ！　イグうううぅ！　チンポで強制イ\nキすりゅうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「んああああああぁ～～～～～っ！　イクッ！　イクッ！　イックううううう\nぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「おほおおおおぉ～～～！？　さっきよりも粘り気のあるザーメン、あたしの\n子宮に注がれてるううううぅ～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_19" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「子宮が悦んで、ザーメン啜ってるのわかるぅ！　ダメだ！　も、もう入らな\nいから！　子宮パンパンだからあああぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひあああぁ～～～っ！　マンコが悦ぶたびに、イッてるうううぅ！　何回も\nイキ重ねてるうぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あっ……あああぁ……！　は、早く……精子をかき出さないと……ほ、本当\nに赤ちゃんできちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひっ、あぐっ、んっ、んんっ……か、身体に力が入らない……！　お、おい\n……！　とりあえず、チンポを抜け……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あああぁ……チンポが引き抜かれる……！　でも、引き抜かれたくないって\n、マンコがチンポ咥えこんでる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「もっと締め付けを緩めろって……あ、あたしは力を抜いてるんだ……！　で\nも、マンコが勝手に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「離れたくないなら、もっと犯すって……！？　ちょ、ちょっと待て……！　\nあ、あたしはもう無理……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「やっ……やめっ……そ、そんな……！　今、抜けかけのチンポをマンコに突\nき入れられたら……！　だ、ダメ……！　ダメ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「うああああぁ～～～～～！　も、もうやめてくれええええぇ～～～～～～！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ひあああぁん！？　マンコからチンポが抜けて……はひっ、あぁっ、あっ！\n　んああっ、せ、精液が身体にいいいぃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_24" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「ザーメンが身体に塗りたくられてるっ！　こ、こんなの、子宮の外から出さ\nれてるみたいで……んはああああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「あっ、熱っ！　火傷するぅ！　あたしの肌、精子で焼かれちゃううううぅ～\n～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はあぁ……あっ、ああぁ……ドロドロのミルクが、肌の上で踊ってるぅ……\nこんなに付けられたら、取れなくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……ぬるぬるで、ぐちゃぐちゃで……イカみたいなニオイ\nが、拡がって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「に、ニオイだけで……また、イッ、イク……！　ひっ、あっ、あああぁ……\nんひいいいぃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「もう、許してくれ……！　ザーメンの味はわかったから……もうこれ以上、\n敗北を味わわせないでくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「うううぅ……酷いニオイがする……！　あたしの汗と精子のニオイが混じっ\nて、エッチなニオイが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「好きな時に、何度でもこのニオイを嗅がせてやるって……？　そ、そんなこと\n言われたら……もっと欲しくなるだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "薬師丸泉" ]},
		{"command":[ "SETTEXT", "「もう一回するって……ちょ、ちょっと待て……！　もっ、もう無理だから…\n…！　あっ、あああああぁ～～～～～……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_0104410" ]},
		{"command":[ "SETIMAGE", "0", "still_00013801_02_23" ]},
