{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、痛ってぇええええええええ！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつもの雑なワームホールによる転送を経て、辿り着いた時間城。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これで大したことない用だったらマジでキレるぞ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とはいえ、刻の女王の姿はまったく見当たりませんなぁ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022950001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「急に呼んどいて本人不在とか、一体どういうつもりなんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間帝国の大広間は、いつ来てもひんやりと涼しい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「用がないなら帰りたいんだが」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺がその場で困惑していると、後ろから足音が聞こえてきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……おや？　そこにいるのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950001" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお！？　クロートー。ついさっき夢で見た顔だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「今はあなたに用はありませんわ。何をしにここにいらっしゃったのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルナテミス・ダーク……。ああ、いや、俺のことはほっといてくれていいぞ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「とはいえ、ウロウロされると気になる。何か企んでいるんじゃないだろうな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022950001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザーニャンコ先生までいるのか。となれば、もしかして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ドーモ、隊長サン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤのアナザー！？いやダークか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「私とは近いうちに会う事になるだろう……本編でな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本編ってなんだ……？　でも、夢で見た４人がどうしてこんなところに……\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うろたえる俺の真後ろから、にゅっ、と白い腕が伸びてきて抱きしめられた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「やあ、久しぶり。隊長くん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっ！？　ジェスタ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……キミがどんないやらしい夢を見ていたかはわからないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「彼女たちは刻の女王に招集されてここにいるんだ。ま、つまりキミと同じだ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか、この城に来れば当然お前もいるか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふふ。そりゃあもう。……会いたくなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや。別にそういう意味じゃないが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクは会いたかったけど」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……んっ！？　んん！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「モテモテですな～、ご主人。羨ましいですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022950002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「犬くん。キミにも会いたかったよ。基本、ここに来てくれる人は歓迎するこ\nとに決めてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……撫でさせて？　よしよしよし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うはぁああ～♪　極楽のごとき手つきですなあ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022950003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「チッ、デレデレしやがって。駄犬め……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「私たちは、どうしたら人気投票の表彰台に上がれるか……を真剣に議論して\nいたところだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950003" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「お前からも、何かアドバイスがあれば遠慮なく言うがいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人気投票？　ってなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「この世界で定期的に行われる、人気者を決める投票だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022950002" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へー。そんなもんがあるんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「しかし、ワタクシたちの順位はかんばしくなく……。その……あまり高いと\nは言えなかったのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか。１位は誰だったんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「１位になったのは刻の女王だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022950002" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だから、彼女に人気の秘訣を聞こうとここに集まったのだが……。秘訣など\n特にないと言われてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「話し合う場所は貸してやるから、好きなだけ語り合えと言われてここに集ま\nっていたわけですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022950003" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほーん。しかし、秘訣……。人気の秘訣、なあ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「刻の女王に思い当たるところがないのなら、他の上位者に問うしかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950005" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「そう思って探してはみたものの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そいつらとも特に繋がりがあるわけじゃないし……ヤツらがどこにいるかも\n定かじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022950003" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「１人１人捕まえるのも大変ですし、完全に手詰まりになってしまった、とい\nう状況です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022950004" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「カツマ。貴方なら、人気のある者たちとも面識があるだろう。彼女らに勝て\nる方法は思いつかないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人にも人気と言える人気などありませんゆえ。何の参考にもなりゃしま\nせん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022950004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー、お前なぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……そうか。貴方を、女王に無理に呼んでもらったのはワタクシなのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950005" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「無駄足を踏ませてしまってすまなかったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950006" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しゅんとするクロートーと、他３人。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だからといって名案が思いつくわけもなく、困っていた俺にジェスタが助け舟\nを出してくれた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「この話、結構長い議論になりそうだし……。こんなとこで話しているのは不\n毛じゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「で、ではどうすればいいというのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022950005" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「４人とも、頭がカタいところがあるからさ～。そーだね、こーゆーのは……\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950009" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お酒を飲みながらフワッと決めるっていうのはどうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022950010" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「お酒……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950007" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おおおおおお酒っ！！　お酒！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022950004" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「……お酒、ですか……。それで何かが思いつくとは思えませんけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022950006" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「でも、ここにいても進展は望めない。だから私はそれでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022950007" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お酒☆　お酒☆　お酒お酒～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022950005" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……この人数で酒が飲めるところって言ったらアレだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ほう。何か心当たりがあるのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022950008" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。知り合いがやってる居酒屋なんだが、あそこでなら多少騒いでも問題\nないはずだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうと決まればすぐにゴーですぞ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022950005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
