{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふう……。突然呼び出して何を言うかと思えば。浴衣を着て体験した一番い\nやらしい体験を話せ、ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00001603_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「本来ならば絶対に口にはしないことですが。今日は任務でミスをしましたか\nら……特別に。あなただけにお話しましょう。誰にも言わないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あれは……何年前のことだったかしら。夏の暑い日。祭りに出かけていた私\nは、強引に迫られて木の下に追いやられました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001603_02_01" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ま、待ちなさい……！　焦らないで……！　多少戯れるだけならかまわない\nけれど……最後までするのは無理よ！　ひ、人が来るでしょうっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「急に浴衣を着て祭りに出向こうだなんて、あなたが言い出したのはおかしい\nと思っていたけれど……。そうなのね、これを狙っていたってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「だ、めよ……。したい気持ちはわかるけど……。私にも立場というものがあ\nりますから……。そ、そうよ。別の場所でなら……って、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「む……胸元に手を差し込まないで。あっ♪　揉まないで……！　お尻を撫で\nないでください！　っんっ、わからずやね！　いけないことなのよ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ……ちょ、ちょっと何をしてる、のぉ……っ！　あっ♪　私のオマンコ\nにオチンチンをなすりつけて……くちゅくちゅ動かして……いやっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_02" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「入口、だけを刺激するなんて……！　あっあっ、ひ、卑怯じゃないの……っ\n！　ええ、そうよ、今ここでするのは危険すぎると私は思っているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「で、も……！　こんな風にオチンチンをオマンコにくっつけてマンズリして\nいるのだったら、……はぁっ♪　普通にしているのとかわりないじゃないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「やっ♪　あっ、ぁっ、あっ……♪　粘膜に直に感じる熱い粘膜ぅ……！　は\nっ、あっ、あっ……！？　どうして？　今日のソレ、すごく硬いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ねえっ……や、めて……♪　ああっ！　そんな風にしたらこっちだって感じ\nてしまうからっ……あっ、愛液が溢れ出して……おかしくなりそうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「な、んですって……？　入れて欲しかったらおねだりをしろ、と？　この私\nに？　恥も外聞も投げ捨ててオチンチンを求めて媚びろと……！？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そ……そんなの私のプライドが許さないわ……。って、いやぁっ♪　入口グ\nチグチしないでっ、わかったわ、わかったからもう許して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ほ……欲しい、わ……。もう、私のオマンコ……こんなに濡れてトロトロに\n潤っているの……。こ、ここに、この穴にあなたのオチンチン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「逞しいオチンチンを入れてちょうだい……！　い、いいから！　誰に見られ\nてしまってもいいから……どうしてもそれが欲しいの、欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「い……入れて、ほしい……！　ああっ……もう我慢できませんっ！　お願い\nですから私の濡れたオマンコにそのオチンチンを入れてよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_01" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁあっ！？　ああッ……！　あああっ……！　オチンチン、オマンコの奥\nまでもぐりこんできて……ああっ！　貪欲で素敵っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_04" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ヌルヌルの粘膜を味わうみたい、に……！　んあああっ、前後に動いて……\nんぅっ！　す、すごいっ……！　オチンチンすごいぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「これっ……これよ、これが欲し、かったの……！　あああっ……！　き、も\nちいい……気持ちいいわ、いつもより感じてる……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「たっぷりおあずけを食らったせい……？　奥の奥まで愛液で満たされたオマ\nンコが、オチンチンを味わいつくそうと本気で蠢いてるわ……！　はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_03" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたも気持ちいい……？　ええ、わたしのオマンコ……うねってオチンチ\nンを歓迎しているでしょう？　だってずっと待たされていたんだもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「っんんんんっ！？　ちょっと……！　いきなり乱暴に突かない、でぇ……っ\n！　後ろからだと、あなたの顔がよく見えないのよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_04" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「それなのに、そんなに全力で貫かれたら……あぁっ！？　次の動きが予想で\nきなくてこわ、いぃ……！　あっ！　あっ……♪　刺さるのよぉ……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あ……ッ♪　あぁああっ……！　一番奥をひっかくカリ首ぃ……！　だめ…\n…いけないわ、まだお祭りもやっていて……あはぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「だ、誰か人が来るかもしれないのよ？　なのにこんなに大きな水音たてて…\n…あっ！　めちゃくちゃにオマンコとオチンチンを混ぜ合わせ、て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_03" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「互いの下半身を粘液でヌルヌルにしながらセックスするなんて……！　すご\nい背徳感だわ、ひ、控え目に言って……興奮しちゃう……！　でも、でも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「大人として、教員としては良くないことだわ……！　あ、あなたは何も失う\nものがないからいいかもしれないけど……って、んぅううううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「急に子宮を突き上げて……何！？　えっ？　な、中出しがしたい？　ひ、ぅ\n……っ、そ、それは……い、いいわけがないでしょう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_04" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「避妊具もつけずに繋がっているんだからっ……！　はぁあっ♪　子どもが…\n…、あっ♪　赤ちゃんが出来てしまうわ、絶対にだめぇえ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あんっ、んんっ、あぁんんっ！　む、無理やり腰を打ち付けて\n、亀頭で子宮口をこじあけようとしたってだめ……だめよ、んんんぐっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「だめって言ってるのに……ッ！　そんなに奥をグチュグチュ突かれたら、…\n…あっ♪　快感に頭がかすんで……あひぃっ！　許可したくなるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「中出し……、あっ！　出来ちゃう、赤ちゃんできちゃうわ、妊娠しちゃうの\nにぃいっ……！　あっ！　中出し……してほしい、このまま精子欲しいわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_05" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「オチンチン……オマンコに叩きつけながら出して♪　はぁっ……ああっ、あ\nぁ……！　たくさん絞るからっ……オマンコでオチンチン締めつけるから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「こうっ？　こうやって……あぁ♪　下腹に力をこめて……あなたの精液を強\n制的に絞り上げるのっ、どうかしら……ザーメンあがってきた！？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁああああああっ♪　んあああああっ、あああああ～っ！　私の子宮が、\n真っ白に染まっていく……濁液でいっぱいになっていくぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_08" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んあ……あっ、あぁ……中に、オマンコの中にたっぷり出されてしまった…\n…ぁっ♪　あぁああっ、絶対妊娠するっ……今受精してるぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「でもっ……！　子宮にかかる精液が……得能ザーメンが気持ち良すぎて、こ\nらえられないぃ……！　本能が中出しを、膣内射精を喜んでるぅう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああっ！？　ああっ、ああっ……イグッ……イグぅうっ！　ひぅっ！　ドク\nドク入ってくる……！　子宮の中に精液流れ込んできて……止まらない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「絶頂しますっ……！　あぁあああ……っ！　んぐぅっ！　あううっ……！　\n野外でしっかり種付けされて……私、私絶頂していますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あはぁあああ……♪　はーっ、はーっ……はぁあああ……♪　め、目の前が\nチカチカするわ……。外での危険な中出しは、スリルが違うわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_07" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「してはいけないと思えば思うほど……オマンコが反応して、どうしてもオチ\nンチンを抜いて欲しくなくなってしまって……。反省だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……それで……あなた。こ、ここからは一体どうするつもりなの？　本来な\nら、すぐにでも離れて精液の処理をすべきだけれど……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_06" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなたのコレ……オチンチン、出す前と全然変わらないくらい……いいえ、\nそれよりも硬く強く勃起してる。そう。やっぱりこのまま続けたいのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「もう……こんなに中に出されてしまったら、今更拒んでも仕方ないわ……。\nそれに、何より私がやめたくない。もっともっと続けたいのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「素早く……激しくすればそんなに時間はかからないでしょう？　んっ……し\nましょう、このまま……。あっ♪　私も協力するわ、お尻を揺すって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ♪　あなたのオチンチンが感じやすくなるようにっ、敏感にオマンコの\n粘膜を感じられるようにぃ……！　こうやって、努力して……んあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふ、不思議……だわ、射精した直後にここまで力強いセックスが出来る、な\nんてぇ……っ！　この服に、浴衣に欲情しているの？　それとも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私としているところを誰かに見て欲しいの？　気付いてほしくて……あっ！\n　そんなにぐりぐり腰を打ち付けてくるの？　いやらしい人……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……ん！？　ね、ねぇ……、今そこの茂みがガサガサと音をたてなかった？\n　か、勘違いなんかじゃないわよ……誰か来るわ、……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「や、だ……♪　人の気配を感じただけで、オマンコが……疼いて、熱くなっ\nて……。これじゃあ私が露出狂の変質者みたいじゃないの……っ、んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_07" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「抜かなきゃ……オチンチンを抜いて、オマンコと胸を隠さなきゃ……。それ\n、なのに……あぁっ！　どうして私は腰をくねらせて……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……んぅっ！！　あ、あなたもあなたよ！　まったく気にせずにズプズプピ\nストンし続けて……！　っあっ！　い、いいのね？　見られてしまっても？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私は……あっ、……んっ、わ、私も……いいわ。どうなっても……っ！　す\n、全てを失ってしまってもいいからもっとして……突いてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んはぁあああっ♪　はぁああっ、あぁあんっ！　あんっ♪　あんっ……あぁ\nんっ♪　もうだめ、声……漏れちゃう、抑えきれないわ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_09" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私のこと……めちゃくちゃに掻き回して！　あっ♪　肉ヒダを割り開くみた\nいに……ぃっ、オチンチンの形をオマンコに記憶させるみたい、にっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「誰かに見られたら言い訳出来ないくらいっ……！　抱いて、犯して……！　\nあッ、ああ……いいのっ、イイっ、オマンコめくれて気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んッ、またイキそうになっているの？　まだ？　あっ……♪　それじゃあ私\nの方が先にイカされてしまうかもしれないのね……っ、はぁっはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そうなのっ……！　さっきから、ずっと絶頂の寸前で……あああっ、今にも\nトんでしまいそう……！　子宮が、甘く痺れて……脚が震えて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ねえ……もう一つおねだりすることが叶うのなら……！　一緒に、一緒にイ\nッてもらえないかしらっ……あなたと一緒にイキたいのよっ、お願いぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「……んぐぅううんんっ！！　い、やぁあ……っ♪　一番奥、めちゃくちゃに\n突き上げられて……！　出そうなの！？　一緒にイッてくれるのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あぁんんっ！　激しすぎるピストン……っ！　この腰使い、加速するスピー\nド……あはぁっ！　精液溜まりきったのね、今にも飛び出しそうなのね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私も……私も腰を揺らすわ……っ。あっ、はぁっ♪　はぁあんっ、あぁんっ\n……！　二人のリズムを合わせて……あぁっ！　い、今の感じよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　い、いいからっ、中に出していいからっ……！　いいえ、中出\nし以外ありえないわ……っ！　絶対に一番奥で出して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私の卵子にしっかりかかるように……狙い撃ちして！　ザーメンびゅるびゅ\nる出してちょうだいっ……！　ほら、ほらキツく締め上げてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ッぁああああっ……！　キタわ、キてるぅううっ……！　二発目の精液……\nザーメンどぴゅどぴゅ……！　はぁああっ、気持ちいぃいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304306" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_11" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ♪　一度目の分が逆流して中から溢れ出してくる……！　それで\nもいいの、何度でも注ぎ込んで、子宮でゴクゴク飲み干してあげるから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んんんんッ……♪　限界を超えてザーメンを注がれる喜び……っ♪　いけな\nいとわかってるのに……夢中になって絞り取ってしまうの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「フフフ……♪　性豪のあなたでもさすがに精液が枯れ果てたかしら？　……\n気にしていた人の気配も、無事に通過していって消えたみたいだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_10" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「たまにはこんな風に、スリリングなイベントを過ごすのも悪くない、のかも\nね。あなたは良かった？　私はすっ……ごく良かったわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「えっ……！？　私の浴衣……それに胸や顔にかけたい……？　そ、それは想\n定していなかった台詞、ね……っ。あっ、か……構わないと言いたいけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「浴衣が汚れてしまうから……って、んぁんんッ！？　や、やめてぇ♪　強く\n突き上げないでっ……なし崩しに許しちゃう、あっ、許可出しちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　オチンチンっ……オマンコの奥にねじこまれると……快感が止\nめられないの、自分の腰も動かしちゃう……あ、あ、あ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「わ……わかったわぁっ♪　好きにしていいからっ……顔でも胸でも、どこに\nだって出していいからイカせてぇっ！　あなたのザーメン浴びさせてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はぁっ……ああ、熱い……っ♪　すごい勢いで次々に溢れ出す精液……！　\nんんっ♪　そんなに満足したの……っ？　嬉しいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304405" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_13" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あ、ぷ……！　とてつもない量のザーメンシャワーね……っ！　あンッ……\n♪　だめ……こんな強いオスの臭い……あなたのザーメンの香り……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「射精しているあなたを見ていると、私っ……私もイクぅっ……！　あ、あぁ\nあああ……ッ！　気持ちいいっ……ドロドロしたものが降り注いで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んっ♪　メガネにもたっぷりかかってしまったわ……♪　はぁっ……♪　レ\nンズごしに見つめる精液のぬめり……なんて、なんて卑猥なの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あぁもう……ここまで汚れてしまったら、何食わぬ顔で帰るというわけには\nいかなさそうね。まったく、とんでもないことをしでかしてしまったけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0304409" ]},
		{"command":[ "SETIMAGE", "0", "still_00001603_02_12" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「日頃のストレスが消えていい気分だわ。フフフ……♪　たまにはハメを外し\nてみるのもいいのかもね。い、いつもというわけにはいかないけれど……」", "NORMAL" ]},
