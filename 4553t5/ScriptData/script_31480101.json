		{"command":[ "PLAYVOICE", "148_0103101" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「えっと……これで、本当に強くなるっすよね？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103102" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「何だか騙されてる気がしてならないっすけど……でも、えっと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103103" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんとなら、たとえ騙されてたっていいっす。こういう関係になるの、\nイヤじゃないっすから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103104" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「え、えっ？　どういう関係か、って……そんなことウチの口から言わせない\nで欲しいっすよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103105" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「言って欲しいっすか？　ううう……何だか今日は意地悪な気がするっす」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103106" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「その、え……エッチなことをする間柄、っす。その……ウチは隊長さんのこ\nと、けっこう……え、えっと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103107" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「気に入ってるっすよ。ウチみたいな子が独占していい人じゃないってことは\n分かってるっす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103108" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「でも、今だけは……あなただけのアーミィで居たいっす。だから……して欲\nしいこと、一生懸命するっす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103109" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はっ、あぁ、こ……これでいいっすか？　ウチ、胸がないから挟む\nなんてできないと思ってたっすけど……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103110" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「あなたの……えっと、お、オチンチン大きいから案外……挟めるもんっすね\n……はあぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103111" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「え？　どうして顔を赤くしてるっすかって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103112" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「うぅ……いまさらっすけど、すごいエッチなことしちゃってるって自覚した\nっすよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103113" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱいでオチンチン挟んで、ごし……ごしって、はあぁ、こんな風に……\nしごいてるだなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103114" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「その、気持ち良くなってるっすか？　こんな小さなおっぱいでも……あっ、\nあぁ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103115" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「ビクビクって跳ねてるっす……オチンチン。感じてくれてるっすね……んっ\n、んんぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103116" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁぁ、はぁっ、ウチ……こんなことするの初めてっす。だから……あぁ、\nそのっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103117" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「間近で男の人の射精見るの初めてっす……！　た、隊長さんに喜んで貰える\nなら……どこにでもかけて欲しいっす」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103118" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「胸に……か、顔にも、っすか？　分かったっす……いっぱいかけて欲しいっ\nす、んっ……んんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103119" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱい揉んで、ウチも興奮してきちゃったっすよ……！　はあぁ、んんっ\n、んあぁ、はっ……はっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103120" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「えっ？　あ……あぁ！　オチンチンが大きく跳ねて……！？　出るっすか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103121" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「びゅっびゅってたくさん出ちゃうっすか？　うぅ……ちょっと怖いっすけど\n、出して欲しいっす……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103122" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「あ、あなたの精液たっぷり受け止めてみせるっす……さ、さあ来るっす……\nんんぅ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103123" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「あっ……あああ、んんっ！　あっ…………！！　きゃううぅっ！！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_05" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103124" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ！　はあぁ！　こ、これがスペルマ……んふああぁっ。あ、あぁん……\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103125" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱいにかかって、ベトベトっす……んふぅぅ、ドロドロにされちゃった\nっす……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103126" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「顔も、髪の毛も、たくさん出しすぎっすよぉ……はあぁ、あぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103127" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「えっ、え……？　う、ウチが可愛いからいっぱい出ちゃった……っすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103128" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「も、もぅ！　こんな時に冗談はやめるっす！　その……本気にしちゃったら\nどうするっすか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103129" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「ウソじゃない……？　とっても気持ち良かった……？　う、うぅっ、嬉しい\nっす……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103130" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「今度はザーメンを舐めてごっくんして欲しい？　わ、分かったっす……ぴち\nゃ、ちゅるる」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103131" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「んあぁ、ネバネバしてて、とっても濃くて、なかなか飲み込めないっす……\nんちゅ、ちゅるる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103132" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅううぅ、んふぅ、ちゅっ……ちゅるる。ごくっ……！　ごっ\n……くん……んふぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103133" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「すごいにおいっす……んあぁ、ますます興奮してきちゃうっす……ウチ、お\n口の中もあなたに支配されたんだって……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103134" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「えっ？　ええ……！？　ちょ、そ、それは……うぅ、分かったっす。答える\nっすよ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103135" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「あなたの言う通り、パイズリしててウチ興奮して……はうぅ、恥ずかしいけ\nど、濡れてるっす……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103136" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「い、今ならあなたの大きすぎるオチンチン受け入れられるかもしれないっす\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103137" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「え？　ま、まさか本気っすか？　でもウチ、初めてで……こんな大きいのい\nきなり入らな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103138" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「ひゃん！？　あぁ……ほ、本気っすね。分かったっす。その……こんなウチ\nで良ければ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103139" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「あ、あなたが満足するまで、好きなだけ可愛がって欲しいっす。んんぅ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "148_0103140" ]},
		{"command":[ "SETNAME", "戦闘員Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さん、大好きっす……あなたの手で、オンナにして欲しい……あ、ああ\nぁぁ～～！！」", "NORMAL" ]},
