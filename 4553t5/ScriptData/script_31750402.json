		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふ……びっくりした？　今日は最初からぱんつ……はいてなかったし…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパに特別じゅぎょー？　してもらおうかなーって……ほら、どう……？　\nヤムのオマンコ……どうなってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あたり……もう、パパとしたいって……ぬるんってしてるから……準備もう\n出来てるってコト……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「にひひっ……パパのチンポ……しっかり大きくなってるし……♪　ほら、し\nたいんだよね？　して……パパぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ここ……オマンコにぴとってくっつけて……そのまま、んっ……奥まで……\nズブって来てぇ……あっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁふっ……入って来る……んひぁ……オマンコ、くぱって広げて\nっ……パパのチンポっ……めり込むぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「くぅんっ……うんっ、奥まで……ちゃんと突っ込んでぇ……はっ、ひぃっ…\n…ずりゅって……んくぅっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふっ、全部食べちゃった……んふふぅ……パパのチンポ……コチコチにな\nりすぎ……そんなにヤムとしたかったんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えっへへー……とぼけなくていいし。ヤムはシたかったよ？　パパチンポ…\n…んっ、すっごく気持ちいーし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「一番奥まで届いたから……ね、動いちゃお……ヤムのヌルヌルオマンコ……\nいっぱいかき回して……はっ、ぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、そぉっ、それっ、あっ……最初は、ゆっくりねっ……んっ、ふっ、く\nふっ、んん……まずオマンコに慣れさせてあげるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ずりずりっ、ぐりぐりっ……んふぅっ、いい音……してきたぁ……ぐちゅだ\nって……エローい……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そうだよ……んっ、ヤムのオマンコがさせてる音ぉ……ちょい恥ずいケド…\n…でも、やっぱ気持ちいいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふっ、んふぅっ……パパのチンポがビクビクするのっ……よく分かるから…\n…あっ、遠慮しないで……もっと動かしていいからねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あぁっ、そこぉっ……いい、感じぃっ……チンポの熱いの\nっ、いっぱい届いてくるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくぅ……パパの先っぽが、カリカリって引っかかってる……あぁっ、それ\n好きぃっ……もっとカリカリしてぇっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、うんっ……気持ちいいっ……！　ふひぁっ……今、チンポが当たって\nるとこぉっ、特にっ……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁんっ……パパにやらしい顔……見せてるぅ……だって、気持ちいいんだ\nし……仕方ないよねぇっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁっ、んちゅぷっ……うんっ、キスするぅ……んふっ、もっとヤムのコト\n……トロトロにさせてぇ……りゅぷっ、れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ、はぁ……んっ、パパのツバ……甘いし……んふっ、ヤムのも飲\nんでぇ……んちゅぷ……れろ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ……もっとくっつきたい……ちゃんと抱っこしてよね、パパぁ…\n…カラダ支えてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、そぉ……しっかりくっつくの……あったかいし……ドキドキするの伝\nわるし……パパ……チラチラおっぱい見てるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムのちっこいのでも、見ちゃうんだから……マジ、パパってヘンタイだよ\nね……ひぁぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ、怒った？　んっ、だって……ホントじゃん……ヤムとしちゃうのだ\nって……割とスレスレっていうか……アウトだし？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ……違うしっ、やめてってことじゃないからっ……そういうのだから…\n…ドキドキするってコトっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパと一緒にイケナイことするのっ、ゾクゾクして気持ちいーからぁっ、だ\nからもっといっぱいオマンコしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あぅんっ、あんっ、はっ、あんっ、パパのチンポっ……さっきより、もっと\nいいトコっ……当たるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ、くんっ、はぅんっ、めっちゃ張り切ってるしっ……んっ、ヤムもパ\nパのこと……よくしたげるからねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらぁっ、んふふっ、どぉ？　今のキュンってするの、いいでしょ？　パパ\nの顔でバレバレだし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、もっとしたげるからっ、あんっ、これっ……ヤムも気持ちよく\nなってっ……あっ、ヘンになるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……ウズウズするぅ……オマンコ……痺れてっ、あっ、そろ\nそろ……イキそっ……かもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっふっ……パパも……？　んふぅっ……いーよ、いっぱい出しちゃおっ…\n…もち、中出しだからね？　オマンコ中出しぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そぉっ、そのままっ……グリグリしてっ、あぁっ、出してっ……パパのせー\nえきっ……びゅくびゅくしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんんんんんぅぅぅぅんっ！　あぁっ……出てるっ！　いっぱいっ、オマン\nコ！　せーえきっ、来たぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ……中……熱くなるぅ……はひっ、あぁっ、イクっ……イッてるっ、\nオマンコ……ずっとジンジンするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁ……イッたぁ……パパのチンポ……すごかったぁ……あふっ、んん\nっ……んくぅぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……ふ……ヤムの体液のお陰で、今日もめちゃくちゃいっぱい出たし…\n…お腹、いっぱいになっちゃったカモ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えっ……ううん、別にもう終わりって意味じゃないし……パパのチンポ……\nまだ、本気出しきってないでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムも、もっとしたいカモ……ね、オマンコ……もっと気持ちよくして……\nんっ、パパの本気見せてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくぁっ！　あっ、はぅんっ、そうっ……この位のペースで……んっ、チン\nポ……ずりゅってされるのっ、あはっ、好きぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふっ、んくっ……オマンコのざらっとしてるトコ……ちょうど突かれてぇ\nっ……はぁんっ、オマンコ喜んじゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃっ、んふっ、くふんっ……奥にぃ、こんこんって……届いて来るぅ……\nうくぅっ、ヤムだって……パパにするんだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ、んくぅっ……！　ほらぁ……チンポにしゃぶりついてるオマンコっ\n……いいでしょっ？　んぅっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いっぱい中出しされてっ……ヌルヌルになってるからっ……こんなに激しく\n擦れてもっ……きゅうって締め付けてもっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、ほぉら……パパの顔がだらしなくなってる……んふぅっ、カリが引\nっかかる時とかっ、ゆるゆるだしっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁっ、あふっ、お互い様……？　別に……ヤムは、そんなに顔に出てない\nでしょ……？　えっ……ぐずぐず……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ウソ……そんなことっ……はひぁっ、あっ、あぁっ、あぅんっ！　ある……\nカモっ……パパの本気チンポっ……また、ぐりってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはぅっ、あっ、オマンコっ……めくれるっ、あひっ、ひぃっ！　ホ、ホン\nトだ……あっ、顔……ゆるゆるになってるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくぅぅっ！　あぁっ、はぁんっ、ふぐっ、おくぅっ……しびれてぇっ……\nはひっ、チンポっ……すごすぎぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……ちゅぷっ、い、今……キスされたらぁっ、あふぁっ、トロけた\n顔……見せひゃうの……んふぅっ、じゅるいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017504_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、イヤじゃない……んりゅぷっ、ちょっと恥ずいだけぇっ……あ\nぁんむっ、りゅぷっ、きもひぃぃの……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ、らめ……ヤム……もっ、ダメかもっ……イキそっ、オマン\nコっ……トロけるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパもっ、あっ、もうすぐっ？　はぁっ、んふっ……ヤムもっ……あとちょ\nっとだけガマンするからっ……一緒にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁんっ！　らめっ、そんなにチンポっ……グリグリされ\nるのっ、止まらなくなるからっ、あひっ！」", "NORMAL" ]},
