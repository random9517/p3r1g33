		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ、あふっ、オマンコ飲みきれないの……イクっ……！　はぁぁんっ、\nまたイクのっ、んひっ……ずっとイッてるぅぅぅ……！」", "NORMAL" ]},
