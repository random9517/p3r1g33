		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふはぁ……はぁ……んっ、あ……止まってる……これで、全部出たの……？\n　ヤムのおかげで、すごい量になっちゃったね……」", "NORMAL" ]},
