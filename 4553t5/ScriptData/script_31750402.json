		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なかっ……熱い……オマンコが……ずっとよろこんでるのぉ……しあわせぇ\nぇ……はふぁぁ……ちょうだい……パパの、もっとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　あぁっ……せーえき出されたままピストン……きてるぅっ……\nふぁぁ、これすごっ、イクっ……またイクのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
