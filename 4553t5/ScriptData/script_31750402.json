		{"command":[ "PLAYVOICE", "v2_175_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「制服にもついちゃったし……んふ……拭いてそのままガッコ行ったら、みん\nな気づいちゃうかな？」", "NORMAL" ]},
