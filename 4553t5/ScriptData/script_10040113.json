		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ下僕！　私と合体するのが不満だとでもいうのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス……あまり大きな声でそういうことを言うな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんでだ？　合体のなにが――あっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違うぞっ！　違うんだからなっ！　私は別にカツマ――下僕とエロいことを\nしたいとかアナザーとしたらちょっと気持ちいいかもとか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなことあんまり考えたりしてないんだからなっ！　違うんだからなっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミスっ！　それ以上なにも言うなっ！　墓穴を掘る一方だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほ、掘る！？　掘るだとっ！　お、おまえの方こそそういうこというな！　\nこのムッツリアナザーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116510005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……２人ともそういう話はもうちょっと物陰でだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「カツマ隊長……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116510002" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう、昴。どうにか敵は追っ払ったぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「そうね。あの……ありがとう。危ないところを助けに来てくれて……やっぱ\nり君がいないと……このチームは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116510003" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　あ、いやぁ……別にそんな……俺はただ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれ！？　昴！　怪我してないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「怪我？　ああ、左手のこれ？　別にたいしたことないわ。ちょっとした擦り\n傷だし。あとで絆創膏でも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116510004" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「絆創膏なら持ってるよ。ちょっと手を出せ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「なんでそんなものを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116510005" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでって、この仕事じゃ生傷はつきものだからな。絆創膏ぐらいは俺が持\nち歩いてないと……ほら、手を出せって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「う、うん……ありがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116510006" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあなんだね。やっぱりこのチームはカツマがいないとねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうだなあ、カツマ抜きじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケン・ローダー" ]},
		{"command":[ "SETTEXT", "「たしかに、カツマさんがいないと回らないとこあるしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116510001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　お、おいおい！？　みんなどうしちゃったんだ！？　いきなり俺をほ\nめ出して！　おだてたって、なんにも出ないぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "STOPBGM" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「え……？　なに言ってんだい、あんた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんか、勘違いしてんじゃないか……？」", "NORMAL" ]},
