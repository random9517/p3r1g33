{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「誰が何と言おうとヒロインの座は渡しません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私だって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113440001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしもここまで来たら絶対にヒロインになる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113440001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら落ち着けって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつらが俺の言うことを聞かないのは百も承知だが、一応教師としてはこの\n状況を放置しておけないわけで……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0130" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「どうしたのですか？　騒々しいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「が、学園長っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113440001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな教室の騒ぎを聞きつけて、今度は学園長の古賀道子がやってきてしまっ\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「大江山先生、どうしてこうなったのか説明をお願いできますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「それはですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113440002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "明日楽が一通り説明する。顔色一つ変えずに聞いている学園長がなんとも不気\n味だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「なるほど。わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それでは、全員ヒロインということで。それなら公平ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そ、それはどういう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113440003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「全員を物語のヒロインにしてしまえば、このような争いもなくなるでしょう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440005" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんて力技だよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「なにか問題でも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいえなにもっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目が合ったとたんに本能的なヤバさを感じた。逆らわない方がいいと直感が告\nげた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ですが、そうすると脚本は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113440004" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それは、大江山先生が新たに書きましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440007" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113440005" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「生徒のために動くのが教師というものです。園長室なら空いていますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440008" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「じっくり生徒たちのための脚本を執筆しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「物語の結末は大江山先生が決めるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待って。全員ヒロインっていうけど、私は、ヒロインとかど\nうでもいいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113440001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういえば、桃花はこのヒロイン役争いに立候補していなかったな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あら、そうですか。では、吉備さんはヒロインのライバルですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440011" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「どっちにしても目立つ役じゃないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113440002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそもそんな役は台本になかったはずだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうやら、学園長のなかでは代わりの脚本が組みあがっているようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それでは行きますよ、大江山先生」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440012" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「は、はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113440006" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「台本のことは私たちに任せてください。ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440013" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0130" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「し、ず、か、に。学問にはげんでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113440014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "全員" ]},
		{"command":[ "SETTEXT", "「はいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113440002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "残される俺たち。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれだけ騒がしかった教室が一気に静まり返るなんて……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああいう人を怒らせてはいけないということですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113440002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それからは、いつも通りの一日を過ごした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}