{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "014_0103101" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ、あの……本当に、するんですか……？　その……エ、Ｈなことをして強\nくなれるなんて……やっぱり信じられなくて……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103102" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……いえ、そうですよね。つきみをこれ以上、危険な目には合わせられない\nから……どんなことをしてでも、私が強くならないと……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103103" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも……あなたはいいんですか？　その……私とそんなことをしてしまって\nも……私みたいなのと、その……え、Ｈなことを……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103104" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひぇっ！？　な、何を言ってるんですか……！？　わ、私なんて、そんな…\n…全然可愛くないです！　だって、つきみより胸も小さいし……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103105" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オ、オチン……っ！？　な、ななな、何てモノを見せるんですか！？　……\nえ？　それって、もしかして……私で、興奮してくれてるんですか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103106" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……わかりました。私、頑張ります……っ！　だから、その……え、Ｈなご\n奉仕の仕方……教えてください……っ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103107" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オ、オチンチンをおっぱいで挟んで……んっ……こうですか……？　一応、\n挟めてるとは思うんですけど……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103108" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……本当ですか？　よかった。つきみほどじゃないですけど、私だって少し\nはおっぱいあるんですよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103109" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それにしても……んっ……オチンチン、おっきくて、固くて……本当に、私\nで興奮してくれてるんですね……嬉しい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103110" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……あ、ごめんなさい。ええと、挟んだまま、上下にシゴくんですよね？　\nあとは、さきの方の……亀頭を舌で舐めながら……んっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103111" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れろ、れろっ、でっぱりの……雁首に舌をからめたり、れるれるっ、裏筋の\nところも舌で、ぺろっ、ぺろっ……どうです、ちゃんとできてますか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103112" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、れろれろっ……一生懸命、オチンチンにご奉仕しますから……れるれ\nるっ、れるぅっ……たくさん気持ちよくなってくださいね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103113" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んっ……あれ、なんだか先の方から、透明なお汁が出てきてま\nすけど……先走り汁、ですか？　あの、これも舐めていいんですよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103114" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ん……れろっ、れろれろぉっ……んあぁ、すごくＨな味がします……んちゅ\nうっ、ちゅっ、ちゅううっ……頭がぼうっとしてきちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103115" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れろれろぉっ……オチンチンがもっとおっきくなってきました……れろれろ\nぉっ、熱くて、ゴツゴツしてて、すごくＨですぅ……ちゅぱちゅぱっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103116" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もし、こんなものをアソコに挿れてしまったらぁ、れろぉっ、れろれろっ、\nれろぉっ、どうなっちゃうのぉっ、れろれろぉっ……ひぁあんっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103117" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「な、なに……っ！？　んあっあっあっ、私のアソコ、いじられちゃってるぅ\nっ……！？　あぁっあぁぁんっ、指でいっぱい、触られてるぅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103118" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁっ、やぁぁんっ！　ち、ちがいますぅ、オチンチン舐めて興奮な\nんてしてませんっ、あぁぁんっ！　そんな変態なんかじゃ……あひぃんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103119" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああああんっ、指を入れちゃダメですっ、入り口のところぬぽぬぽ出し入れ\nされたらぁっ、あふうううんっ！　気持ちよくなっちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103120" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひゃあんっ！？　アソコ、ぺろぺろぉっ！？　あひぃいいいんっ！　汚いで\nすからっ、そんなところ舐めないでくださいぃぃっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103121" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひぃぃんっ！？　ソコっ、ダメですぅっ、クリトリス、ダメェっ！　ひぃっ\n、ひぃいんっ！　ペロペロされたら、腰がビリビリしちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103122" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいいっ！　吸うのもダメぇっ！　クリトリス、取れちゃうぅぅっ\n！　ぃひいいいんっ！　おかしくなっちゃいますからぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103123" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひぎぃっ！？　ご、ごめんなさい、私もオチンチンを気持ちよくしますから\nっ、激しくしないでぇっ、ちゅぱちゅぱっ、じゅぷぷっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103124" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふぁあああんっ！　にゅるにゅるの舌が、オマンコのナカに入ってきてる\nぅっ、んふうううんっ！　れりゅりゅっ、じゅぷぷっ、じゅるるるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103125" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゅるるる……んぎゅうううううんっ！　ひぎぃっ！　クリトリス、指でつ\nまんじゃ駄目ぇっ！　ぐりぐりっ、スイッチじゃないのぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103126" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぉひぃいいいんっ！　ぜんぶ同時なんてダメぇっ、んひっ、ぃひいっ！　あ\nひぁああああっ！　おかしくなっちゃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103127" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいっ！　あっあっあっあっ！　なんか来るっ！　おっきいのがき\nちゃいますぅっ！　んぶっ、んじゅるるるっ、んぶぅうううっ！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103128" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んじゅるるるっ、オチンチンおしゃぶりしながらぁっ、あひぃいいいんっ、\nオマンコペロペロされて、あぁあああんっ、おかしくなっちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103129" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れりゅ、れりゅりゅりゅっ、オチンチンのさきっぽが風船みたいにパンパン\nになってるぅ、びくびくしてますぅっ、んじゅるるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103130" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「精液、出ちゃうんですかぁ、わかりました、お口で受け止めますからぁ、は\nぽっ、じゅりゅりゅりゅっ、じゅりゅっ、じゅるるるるっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103131" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んじゅるるるっ、んぶぁっ、あっあっあっ、私ももうダメですぅっ、イクっ\n、イっちゃいますっ！　んぶっんぶっんぶっ……んッグぅううううっ！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103132" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぶうううぅっ！？　んぶっ、んぐぅっ……！　んぶぶっ、んぐふっ……ご\nきゅっ……んぐっふ……ごきゅっ、ごきゅっ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001401_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103133" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ごきゅっ、ごきゅっ……んぶっ！？　けほっ、けほっ……ご、ごめんなさい\n……少し、こぼしてしまいました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103134" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「言われたとおりに、飲もうと思ったんですけど、んんぅっ、すごく濃くて、\nどろどろしてて、喉にからんでしまいましたぁ……げふぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103135" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……すごい臭いです……お口から胃の中まで、全部精液の臭いになっ\nちゃいましたぁ……頭がぼうっとして、くらくらしますぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103136" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あぁぁっ……身体がまた熱くなっちゃぅっ……あっああんっ……\nアソコがじんじん、熱いのぉっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103137" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ひゃああううっ！？　んあぁぁっ、あっあっ、もうダメですからっ！　あぁ\nあああんっ、舐めないでくださいっ、指でいじるのも駄目ぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103138" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、おかしくなっちゃいますぅっ！　あはぁああああんっ！　ま\nた気持ちよくなっちゃいますぅっ！　ひあぁあああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103139" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、わかりました、またオチンポおしゃぶりしますからぁっ！　\nパイズリフェラで、オチンポ気持ちよくしますぅっ！　だからやめてぇっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "014_0103140" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぁおっ、あっあっ、あひぃいいいいんっ！　癖になっちゃいますぅっ！　エ\nッチなことにハマっちゃうからぁっ！　もう許してぇ……っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}