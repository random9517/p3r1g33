{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "050_0103101" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……私をお呼びになりましたね。隊長。……こんな夜更けに……何事でしょ\nうか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103102" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「戦力拡充のためのパワーアップイベント……？　私を強化するための方法が\n見つかった……？　……それは本当ですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103103" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「え……？　ここで今、隊長の男性器を手で慰め……射精に至らしめる……？\n　そうすれば隊のシンクロ率が上がり……互いの呼吸を合わせられる……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103104" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……さすがにそれは……。ですが、今夜は特に用事もありません。万に一つ\nもステータスが上がる可能性があるのならば……わかりました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103105" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長に手コキをさせていただきます。ですが……マスクとスーツは脱ぎませ\nんよ。それでも構わないのであれば……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103106" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「と、条件を出している私に……そこできっぱりと『いい』と言ってしまえる\nのですね……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103107" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「驚きました。隊長に……こんなおかしな趣味があるなんて。ですが、それも\n利用させていただきます。素顔を晒さずパワーアップが可能なら」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103108" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それはマスカレードとしても必要な行為……。では、男根をこちらに。……\nえ？　肉棒を見たことがあるのか、ですか？　……それは秘密です」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103109" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「仮面のヒロインは神秘的でなくては……。ですがわかりますよ。隊長のコレ\nが、パンパンに張りつめて昂っていることは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103110" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ん……。初めはゆっくりと……優しく、肉竿を握らせていただきます。\nしゅっ……しゅっ、しゅっ……しゅっ……しゅっ、しゅっ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005001_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103111" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふ……スーツの素材が独特の感触でしょう？　ツルツルしていて……。生\n肌にはない不思議な触感のはず……どう……ですか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103112" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「しゅっ、しゅっ、しゅっ、しゅっ……。……手の中でどんどん硬さが増して\nきました。ぐんぐん反り返って……そうですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103113" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長の男性器……マスクごしに見ても、とても肥大化しています。ぐいぐい\nと私の手のひらを押し戻してきて……。強いですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103114" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それに負けないように、私も本気を出させていただきましょうか。……手の\nひらで、亀頭を撫でまわし……ん、先走りを塗りたくって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103115" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「濡れた手でペニス全体をこすります。くちゅ、くちゅ、くちゅ、くちゅ……\n。ローションのぬめりには劣りますが、これもなかなかの刺激でしょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103116" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ぬる、ぬる、ぬる、ぬる……先端から根元まで、何度でも手を往復させて…\n…ぬちゅ、ぬちゅ、ぬちゅ、ぬちゅ……ぷちゅ……くちゅ、くちゅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103117" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふふ……すごい。女の子みたいにビクビクして……。隊長がこんなに手淫に\n弱いだなんて、知りませんでした……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103118" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「もっと強く？　もっと速く……？　承知しました。しゅっ、しゅっ、しゅっ\nしゅっ……！　ぬりゅっ、ぬりゅっぬりゅっぬりゅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103119" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……素顔なら、きっと強烈な臭いを嗅ぐはめになっていましたね。だってほ\nら……湯気が出そうなほど、むわっとペニスが熱くなって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103120" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「これでは絶対に臭いですよね……。先走り汁も多いですし……。太くて……\n見た目もグロテスクで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103121" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こんなもので貫かれたら、価値観が変わってしまいそうです。立派で、卑猥\nで……。ああ、そうですね、思い出しました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103122" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「昔、こういう色と形の怪人と戦ったことがありました。あの時はどう退治し\nたのでしたっけ……。ヌルヌルで、ガチガチのいやらしい怪人チンポ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103123" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「平和のために倒さなければ……。しゅっ……しゅっ、しゅっ、しゅっ……。\n指先をうごめかせて……ぬめりを塗り付けて……しゅっ、しゅっ、しゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103124" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「休む暇も与えずに攻撃を続けないと……。逃がしませんよ。悪い怪人おちん\nぽはこのマスク・ザ・ブルーが許しません……。しゅっ、しゅっ、しゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103125" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……膨らんだ先っちょをぐりぐりぐりぐり……。尿道口をくり、くり、くり\n、くり……。あぁ、ここが敏感なんですね……いいですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103126" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「私をパワーアップさせるために……お好きな時に射精してください。息を合\nわせて……ほら。しゅっ、しゅっ、しゅっ、しゅっ、しゅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103127" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「シコシコ扱いて……。反応が良い場所を、徹底的に攻め立てて……。ごし、\nごし、ごし、ごし……しこ、しこ、しこ、しこ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103128" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……さあ……観念しなさい。悪いチンポにはマスカレードは負けませんから\n……。どんどんペースを上げていきますよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103129" ]},
		{"command":[ "SETTEXT", "「くちゅ、くちゅ、くちゅ、くちゅ、くちゅ、くちゅ、くちゅ……。はぁっ、\n気持ちいい……ですか？　スーツでの手コキ……マスクごしの視姦……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103130" ]},
		{"command":[ "SETTEXT", "「正義のヒロインに見つめられながら、悪いおちんぽをシゴかれて射精するん\nです。いいですね？　ペニス奥の劣情を……精液を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103131" ]},
		{"command":[ "SETTEXT", "「私の手に、手に出してください……。出して……出して、出して……！　正\n義のコスチュームを……真っ白に染めて……出して！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103132" ]},
		{"command":[ "SETTEXT", "「……あっ！　あ、あっ……！　出ましたね。マスクの女にシコシコされなが\nら精液びゅっびゅ出してますねっ……ん……ん、ん……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005001_01_02" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103133" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで搾り上げます……！　んん……！　あっ……！　だめです、\nマスクには……顔にはかけないで……！　あっ！？　だめ、だめ……です！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103134" ]},
		{"command":[ "SETTEXT", "「ああ……！　あ、あ……！　そんな……！　ドロドロで粘っこくて、臭い精\n液を……神聖なマスクにたっぷりと……はぁっ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103135" ]},
		{"command":[ "SETTEXT", "「見てください。手にもマスクにも、白いパックを施したみたいに……。隊長\nの精液がこびりついて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103136" ]},
		{"command":[ "SETTEXT", "「これ……洗っても取れなかったらどうしてくれるんですか。出動のたびに、\n今の射精のことを思い出してしまったら……最悪です……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103137" ]},
		{"command":[ "SETTEXT", "「……。本当に信じられない量を出しましたね。一向に、私のパワーが上昇し\nた感覚はありませんが……隊長の未知の一面は見られました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103138" ]},
		{"command":[ "SETTEXT", "「これ少しでも連携力が上がればいいのですが……。はぁ……。……え？　あ\nと少し出る……？　も、もうこれ以上は、ちょっと……って、あっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103139" ]},
		{"command":[ "SETTEXT", "「いやっ……！　ビュービュー出てるっ！　またマスクが汚れて……！　あっ\n、ス、スーツにも垂れて……ああああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "050_0103140" ]},
		{"command":[ "SETTEXT", "「隊長！　今度する時にはマスクは汚さないでくださいね……。これは、本当\nに本当に大切なマスクなのですから……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}