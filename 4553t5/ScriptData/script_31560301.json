{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「な、なんだ？　こんな時間に唐突に呼び出して……！　私は今から、皆と\nコンビニに行くところだったんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「まあ……他ならぬおまえの為だからな。急いでここにやってきたわけだが…\n…。どうした？　私にして欲しい事でもできたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「買ってきてほしいスイーツがあるのなら、特別に……。って、パイズリ？　\nで、出かける前にパイズリをしてほしい？　……ぱ……ぱいずり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「それは……あ、あの……。前に教えてくれた……アレだろう？　私の胸で…\n…チンポを喜ばせる、あ、あの……いやらしい行為……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「いっ……いや！　時間がないわけじゃないんだ。皆には少し待っていて欲し\nいと告げたし……。そうか……淫らな気分になってしまったんだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「それなら……うん。私に頼んでくれて正解だ。急ぎといっても、手を抜いた\nりはしない。だから……その。チンポを出してもらえるだろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303106" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っふっぁっ……♪　ブルンッて……！　ブルンッて飛び出してきた……！　\nい、いつ見てもおまえのオチンポは凶暴で凶悪だな……スゴいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015603_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「これを胸に挟んでいるといつも思うんだが……。はぁっ、こんなに大きくて\n熱いものを常に股間からぶら下げていて、まともに生活は出来るのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……ん？　いつもはもっと小さくてプニャプニャしている？　う……嘘だろ\nう。私が見たり触る時には、いつもコレはガチガチで大きくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「わ……私に興奮しているからそうなるのか……。そんな可愛い事を言われて\nしまったら……。ごくっ……なんだか愛情が湧いてくるぞ……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「両側の膨らみで、チンポを押し潰して……すりすり、すりすり……。ぁ……\n、ま、またビクンと震えて太くなった……上限知らずか。こ、このぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「待てっ……逃がさないぞ……。って、あっ……！　力加減をミスしてしまっ\nたか？　い……痛くしたか？　すまない……すまない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「もっとちゃんと優しくする……。いつくしむように……、ん……。優しく、\nやさしく……ふわ、ふわ、ふわと包み込んで……すりすりすり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「チンポにギリギリで触れるように……しゅに……しゅに、しゅに……。あと\n少し強くしても平気か？　なら……気をつけながら……ぷに、ぷに、ぷに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「胸を上下に揺らし、て……視覚的におまえを興奮させなが、ら……んんっ。\n少しずつ、激しくしていって……。くにゅ、くにゅ、くにゅぅうう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っン……♪　こ、このパイズリというのは……いつも、思ったよりもむずか\n、しくて慣れない……っ。なにせ、包むオチンポの形がいびつで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こすれ、る時に……こっちがゾクゾクしてしまって……んんっ……♪　だん\nだん落ち着かない気持ちに、なって……。はぁっ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……！　こ、こら……。せっかく私が真剣にパイズリをしているんだぞ\n。こちらの顔を見るな……。は、恥ずかしいじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「普段人に見せない胸、を……そんな熱い視線で見つめられると……。うう…\n…、くすぐったいような、むずがゆいような……。はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「それに……こういうパイズリは、地球では仲のいい恋人同士がすることなん\nだろう？　いちゃいちゃしながらする性行為で……。だ、だから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「剥き出しの……、んっ……裸の肌と肌をこすり合わせて、一番まろやかで\n甘いぬくもりを分け合い、感じるプレイでもあって……。密着もして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……おまえの大事な部分を胸でいじくりまわしているわけで……。う……。\nなあ、これは……可能ならでいいん、だが……。んっ、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「パイズリをしている間は……。こ、恋人っぽいプレイをしている間だけは\nヒカリ、と呼んでくれないか。エッチをしている時だけでいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そうしてくれたら……私はたぶん、すごく感じる。それで……、この胸も、\nなめらかになって……もっとパイズリしやすくなると思う……。いいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ヒカリ、と呼んでくれ……。あっ……♪　そう、そうだ……、あぁあ……♪\n　これ、これは……想像の１００倍気持ちいい……、あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「オチンポにたくさん尽くしたく、なる……！　熱をもってチンポを……っく\nぅっ♪　ずにゅずにゅずりずりして昂らせたくなるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ♪　呼んで……呼んでくれ……ヒカリと……新しい名で……。はぁああ\nっ♪　や、やばい……！　胸がキュンとして……。んっ……んん、ん～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っ……ふぅっ……。んん……ん……こう、だな……。わかってきた……。\nんっ……んん……。上手く肉棒が滑るようになって……。う……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「谷間が、熱気で蒸れてきた……。なんだ？　な、なんだか……心臓がうるさ\nい。冗談だろう？　私は……と、ときめいているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえのオチンポにご奉仕して……新しい名前を呼ばれて……うぅっ♪　\n恋人気分、で……パイズリするのが楽しくて……ハマってしまったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ……あぁ、あっ、あっ……。すまない……！　激しくしすぎ\nているかもしれない、でも、でも……止められない、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　パイズリ……パイズリ、気持ち……いい……っ♪　おまえのっ\n、おまえの声とチンポが悪いんだぞ……っ！　あっあぁあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「どんどんっ、胸で絞り取りたくなる……っ♪　あはっ……んんっ！　わかる\n、だろう……っ。私の胸が弾んで、めちゃくちゃに前後上下して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえのオチンポのためだけにおどって、るぅ……！　あっ……！　頼む…\n…っ。摩擦しすぎて、胸が、胸が熱いんだ……精液をかけてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ぬちゃぬちゃの精液でっ……私の胸が赤く腫れる前に！　あっ……潤してほ\nしい……。濡らして……♪　はやく……はやくちょうだい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　恵みの白い雨ぇ……♪　うん、うんっ……胸全体に出して、\nかけてくれ……！　真っ白な体液でこの胸を覆い尽くして……それから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ひゃぁっ……んん！　谷間っ……にも流し込んでくれ……！　ああっ……♪\n　なんて量だ……ヌラヌラとした精液の濁流……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んんっ……ありがとう……♪　これだけ出してくれれば、私の胸も潤って\nパイズリがしやすくなる……もっともっといやらしい動きが出来る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……そ……それにしても、精子はいつも独特の臭さがあるな……？　他では\n感じたことのない臭いというか……むわっと湯気が広がってくるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「味、も決して美味しい訳じゃないし……苦いし……。触感だってプルプルし\nているとはいえ、潰せばブチュブチュでちょっと気持ちが悪いともいえるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なのに……不思議だ。どんなものよりエロいと感じてしまう……。これは\n本能が、求めているからなのか……？　母性の象徴のはずの胸にかけられて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私は……精液まみれになった自分の膨らみを見て……。その……。股間が\nウズウズしてくるんだ……。はしたない女で申し訳ない……。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「いやらしい、エロい女だからこそ……パイズリに対する探究心は本物、だと\n思う……。こっちの世界の知識は初めはなかった……けれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえが何でも教えてくれたから……。ふぅっ……今では他の誰よりも、\nいやらしい事を知っている……はずだ。だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえが精液を出してくれる事を、したい。おまえが教えてくれて、お前が\n喜んでくれることを……。確か、まだ……出来るはずだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえは一度出したくらいでは終わらない……。だから、私は勝手に二回戦\nを始めさせてもらう……。ん……。トロトロになったオッパイで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「今度は乳首、もオチンポにあてながら……硬さと柔らかさのＷ攻撃で攻めて\nいく……っ。はぁっ……、はぁ、はぁ、はぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふ……ふふふっ……ど、どうだ……？　ここまで大胆なパイズリ、は……っ\n。こちらの世界の人間にも、なかなか……できないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「胸が大きくて……良かった。あっ……、わ……私、は……それなりに乳首も\n感じやすいし、勃起、しやすい……からっ……。はぁ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「チンポに当たると快感のアクセントに……なるっ……だろう？　んっ……。\n私が感じていることも、肉棒で理解できる、だろうし……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ……？　な、なんだ……？　夢中で奉仕している私の尻を揉みたい？　\nさ、触りながらパイズリされたい？　……それは……かまわないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「い、いちいち断りを入れなくても自由にしていいぞ……？　ん……っ。好き\nなところを触って、楽しんでくれれば……。っふぅっ……うう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　あぁ……、あっ……あぁ……！　わ、私が感じると……んん\nっ。パイズリにも力が入って、二人で気持ち良くなれていいな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っうん……ッ♪　そ、そうだ……。私も気持ち良くなっている……。こ、\nこういう性的嗜好をエムだとか、マゾだとか……呼ぶらしいな……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私、は……おまえ専用のマゾ、なんだ……。はぁっ……あぁ……♪　精液\nまみれのオッパイで、オチンポに快感を送りこむことが喜び、なんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　もっと、私のオッパイで、したたる汗で、出してもらった\n精液で……おまえのオチンポをヌルヌルしたい、したい……！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ずうっと……この胸の中にいていいんだからな？　あっ……♪　はぁっ、\n永遠にパイズリをし続けたっていいんだ、……あっ♪　あっ、んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「で、も……それじゃあおまえがずーっとイケなくて苦しいだろうし……。\nあっ♪　私、も……感じすぎておかしくなりそう、だから……いいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「今回、は……これくらいにしておいてやるから……♪　ぴゅっぴゅって出し\nて、いいよ……♪　あははっ……胸が痛くなるくらいガッチガチじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「どこの世界で、も……っ。私の胸に射精出来るのはおまえだけなんだから…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んぁっ……♪　あぁっ♪　あっ、あっ……！　いいぞ、いいぞぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なんって元気いっぱいな射精なんだ……っ♪　あぁ……２回目なのに……\n内側から胸を押し返してくるくらい……。かっこいい、凄い射精だよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ……んふ……♪　ふぅううっ……♪　私の女の本能が疼くくらい、大量\nでネットリした白濁液……。全部、全部この胸に吐き出してくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ヒカリ、と呼びながら……。あっ♪　ふふ、ふふふ……っ！　今、びゅるっ\nと精子の飛距離が上がったんじゃないか？　単純なやつめ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「うん……♪　恋人パイズリ、私も良かったよ……。新しい名前で呼んでもら\nえたし……。回数を重ねるごとに、技術が上がった感覚もあるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「さて……。最後の一滴まで出してもらうぞ？　ぎゅぅうううっ……！　胸で\n～……絞って～……♪　っよぉし！　ちゃんと出せたな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふはぁっ……♪　出しも出したり……だな。おそらく、だが……他の人間は\n、こんなに出したりしないと思うんだが……そのへんはどうなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「わ、私の故郷の女もこんなにいやらしい乳をしていたのか、だと？　そ……\nそれは……円盤少女達を見てくれれば……わかるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あちらの世界にも、こちらの世界にも……パイズリをするのに適した女は\nたくさんいると思う。でも……だ、だからといって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私以外に頼むおまえは見たくない。だから……また、したくなったら呼んで\nほしい。どんなに忙しくても、必ず時間は作ってみせるから……約束だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……はぁああっ……♪　んっ……♪　こ、今度は顔、に……？　あっ\n……二か所にかけるだなんて贅沢な……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あんっ、んん……！　ぷぁっ……ん～～～……っ！　チンポの中から、出る\nわ出るわ……。あっ♪　絶対に、この量はおかしいだろうっ……で、も」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「かけられると……自然と浴びてしまう魔力が……この精液にはある……♪　\nあはぁ……、ダラダラとつたいおちてくるこの生温かい雫……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ……結局、顔を流れて、顎からオッパイにたどりつくわけで……。はぁ\nっ、はぁ……これは効率のいいかけかたなのかもしれないな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「どうだ……？　全部気持ち良く出せたか……？　あっ……まだ尿道に残して\nいるんじゃないだろうな？　ちょっと見せてみろ……。ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「胸でしごきだして……。あっ♪　ほんの少しだけぴゅるっと出た……♪　\nはははっ……これでようやく本当にスッキリできただろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……な、なにをじーっと……人の顔を見つめているんだ……。胸を観察され\nるのも気恥ずかしいが……顔は……も、もっと照れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なに……？　パイズリをしている時の私は嬉しそう……？　ま、まあ……\nあれは、奉仕している方もかなり気持ち良くなれるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえが教えてくれた技術、だし……。出来るだけ活用して……お、おまえ\nに好かれたいと思ってるんだ。浅はかかな？　で、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私は……何でも知っているお前を尊敬しているし。そんなお前が喜ぶことを\nすると……自分が嬉しくなるたちなんだ。放っておいてくれ……」", "NORMAL" ]},
