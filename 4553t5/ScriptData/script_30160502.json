		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「クリスマスという特別感、それにラブホテルという場所の力がはたらいたの\nか……私もかなり、積極的になってしまっていたのだと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504102" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「サンタクロースの格好をしたまま、ベッドでイチャイチャしていたら……。\n想像よりも盛り上がってしまって、つい、探求心が湧いたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504103" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「な……なに……！？　アナルセックスをしてみたい、だと……？　っぅ……\n！　や、やめろ……後ろから甘く囁くのはズルいだろうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「わ、私がそんなお願いを聞くと本気で思っているのか……っ。……い、いや\n……知識では知っている、が……。アナルというのは尻の穴だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504105" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなところで子作りをするなんて……。ヘンタイになってしまう……！　\nそ、それに……想像もつかなくて、怖い……。だから尻の穴は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……んッ！　だ、だから待てと言っているだろうっ。そんなところに勃起し\nたチンポを押しつけるんじゃない……！　っぁ……。あっ、ぁ、あ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「う、動かすなぁあ……！　チンポの熱が……、蒸れた空気が、し、尻の穴の\n粘膜に……んぅ、伝わってくる……！　本当に、本当にしたいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「互いに、気持ち良くなれるものなのかどうかの補償はないぞ！　それに……\n。って、うっ！？　んぅううっ……話の途中で胸を揉むなぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「多少の愛撫なんかではごまかされないぞ！　っふ……ッ！？　く、首筋にキ\nスだと……？　身体中をまさぐりながら……。う、うぁ、ああああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様がそんなにも尻の穴に執着しているなんて知らなかった……！　っぁっ\n……。ど、どうすればいいんだ……。アナルなんて……。あ、う、うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ん？　絶対に痛くしない？　そ、それは……わかっている。貴様を信用\nしていないわけではなくて……。あ、あぁ、もう……。わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなに尻の穴に入れたいのであれば、入れてもいい……。だが、あまり焦\nるなよ？　そっと優しく……って、あ……！？　あっぁっあっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「き、貴様ぁあああ……っ♪　そんなに強引に侵入したら……、ぅ、あ……っ\n。圧迫感がすごすぎる……！　う……、く、くるしい……、ううう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「な、なあ……？　まだ全部、チンポ……入っていないのか？　まだ半分！？\n　く……！　くぅううっ……も、もういい、早くしろっ、耐えられないッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まだか……？　もう入ったか……？　あと少し？　……あ、うっ！？　ふぅ\nうううっ……！？　い、一番奥まで入ったな……。急に負担が楽になった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こう、フッ、と異物感が薄れて……。だ、だが、おかしな感覚だ。尻の穴に\n……排泄する場所にチンポを、しかもこんな太いチンポを入れるなどと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなこと誰にも言えな……。ッくぅっ！？　う、動くな……！　なにかが\nおかしいっ……！　うっ！？　んんっ！？　し、知らない、こんな感覚！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「う……ぅっ！？　オマンコでする時よりも、快感が鈍くて、重くて……ズン\nッと深い衝撃が、くる……っ。まだそんなに動かしていないのに……うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こ、これが……アナルセックス……っ？　尻の穴でする、子作りぃい……っ\n！　あッ♪　赤子はできない、のはわかっていても……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「後ろの穴で、無防備に交尾するなんて……下品すぎる、ぅ……！　ん、ぐ…\n…っ！　くふぅっ……♪　ん、んう～っ……んん……あっ、うっ♪　うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「な、なんだ？　私が尻の穴をチンポでほじられて……うぅっ♪　感じている\nように見える？　後ろの素質がある？　い、いい加減なことを言うなぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これは違うっ……！　あぐぅっ♪　おっ♪　おぅっ♪　オッ♪　おぉおっ♪\n　あっ……立て続けに攻めるな……！　声がもれてしまう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ク、クリスマスだし、ラブホテルだし声を押さえる必要はない？　……あっ\n、た、確かに別の部屋でも……淫らなことをしているのだろうが……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私、は……！　おぅっ♪　あ、あぁああ……、ダメだ、口で嫌がっても、腰\nが勝手に揺れてしまう、尻をくねらせてしまう……。あっぁっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ベッドのシーツが、オマンコから垂らした蜜でもうぐしょぐしょだ……！　\nあ、ああ……っ。こんな私を見ないでくれぇ……！　本当に違うんだぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おっ♪　おぅっ♪　ううっ……！　尻の穴の奥を突かれると……うぐっ♪　\n情けない声が溢れ出るぅう……！　ん、お、チンポが太すぎてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「少し動かされるだけで……おおおっ♪　尻の中がおかしくなるぅっ……！　\nあうっ……！？　ううううぅっ……！　あ、熱い……熱いぃい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポの熱が、直接っ……腸内の粘膜につたわって……！　あっぅっ！　う\nうっ……！　あっ！　１つになっているのも、すごくよくわかるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「愛液で濡れていないせい、か……！　チンポそのものの形っ、太さ、長さ…\n…！　ああああっ……！　デコボコした表面がはっきり、わかるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こ、れが尻の穴でのセックス……っ！　おっ♪　おぅうっ♪　んぉおおっ♪\n　おほっ♪　おッ！？　おっぉっおっ！？　んぉおおおっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「け、ケダモノのような呻きが止められないぃい……！　おほっ♪　こ、こん\nなのっ……貴様は気持ちがいいのか！？　あっ！　ど、どうなんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……入口の締めつけがキツくて最高！？　あっ、こ、こっちで操作している\nわけじゃない、勝手に……締まってしまう、だけだ……勘違いするなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「声がうわずっている？　尻の中も震えてる？　あっ……！　も、もう言うな\n……！　おっ♪　あ、ま、まずいっ……！　おっ♪　あぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「違うぅっ……！　本当に感じてなんか……あっぁっ！　うああああっ！　ダ\nメだ、もうイクっ、イクっ……尻の穴なんかでぇっ、ああイクぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぉおおおおっ！？　おッ！？　おおぉおおっ……！？　で、出てるっ……\n！？　尻の穴に、精子……精液発射されているぅうっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504136" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ！　だ、出すなんて聞いていないぞっ……、あっ！　す、すごい……！\n　チンポが脈打っているのがありありとわかる、痙攣しているぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ……あっ！　やめろぉ……！　絞り出すように射精するのは……あぁあ\nっ♪　精液の量が多くて……！　こっちまで、つられて絶頂してしまうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ、あああああ、イクッ……！　イくぅううっ……！！　尻の穴に精液出さ\nれて絶頂するうっ……！　おおっ、んぉおおっ♪　おおおぉおっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私の尻の中に、精液が溜まっていく……っ♪　あっぁっ、尻の穴が性器にな\nってしまった、精液を絞り取るいやらしい性器にぃい……！　うあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「っはぁあああ……、はー……っ、はー……はー……♪　あ、あぁ……いや、\nその……思ったよりは不快でも嫌でも……なかったかもしれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「わ、わからない……。クリスマスの雰囲気に飲まれただけなのか、それとも\n貴様が言うように、私には尻の穴の素質が元からあったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「痛みもなければ、もう苦しくもなくて……。ただ、腸内が貴様の精液で潤っ\nて、ヌメりが激しいことだけはよくわかる……。ま、満足か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これだけたっぷり精を放出したんだから、もう当分は枯れたままだろう……\n。って、……な、なんだ？　あっ……！　ま、またチンポが動きだした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うっ……！？　もしかして、全部精子を出しきっていなかったのか！？　そ\n、そうじゃなくて……もっとこのまましたいから、耐えた、だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……あっ！　そ、そんな気持ちの問題でっ、チンポを硬いままにして……う\nあああっ！　あぁっあぁっ！　私の許可も得ずに二回戦だなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……うっ♪　ンッ……んんっ……！　ううっ……！　精液を潤滑油にして、\nガンガン突き上げてくる、なんて……！　っああっ、あああっぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こ、こっちはまだイッた余韻が終わっていないというのにっ……あっ♪　う\nう……！　二度目だからか？　最初より快感が来るのが早い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あぁっ！　あっぁっ！　うあああっ、あぁっ！　はぁ……ンンっ♪　あぁっ\n、んぉおお……！　響くぅうっ、尻の穴に響く、あっぁっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポが太くて……拡張されてしまう、あっ！　あっ……！　尻の穴がガバ\nガバになって、開いたままになってしまう……！　それなのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「き、気持ち良くて……やめてほしくなくなってきた……！　う、あっ♪　あ\nぁっ♪　も……もういい、どうなってもいい、ヘンタイでもいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だから……だからずっと続けてくれ、このデカいチンポで！　遠慮なく、激\nしく、強くぅううっ！　尻の穴を犯してくれ！　おっ♪　おっ、おッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　まずい、ハマってしまう……！　この、ままでは尻穴での\nセックスに抵抗がなくなるどころか……自分から求めてしまいそうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぉっ♪　おオっ♪　おぉおおっ、おほぉおっ♪　んおっ！　おぉっ、もっ\nとだ！　もっと突けぇっ……♪　ふぅおぉおっ♪　んおっおっおぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おぉおおっ♪　おぅっ、おぉおおっ♪　おふぅうっ！　も、もう、マトモな\n声も発することができなくなって……しまう、んぉおおっ♪　おぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「イ、く……！　イクっ！　また尻の穴でイクっ！　おぅっ♪　おぉっ♪　ん\nぉおおっ、おほぉおおっ、おぉおおっ！　腰を止めるな、突き続けろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おふっ♪　あふぅうっ♪　尻の穴気持ちいいっ……！　おぉおおっ♪　あッ\n♪　あっ……！　熱い、尻の中が熱いぃっ……！　イグっ、イグぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ、あぁあ……っ！　貴様も、チンポを爆発寸前にまで昂らせているじゃな\nいか……！　ガチガチに屹立した、太すぎるチンポ……、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「い、いいから……！　性器になったトロトロの尻の穴に！　大量に精液をぶ\nちまけてくれぇっ！　あぁ、開くぅっ、尻の穴が期待で開いてしまうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「っぉおおおっ……♪　私も全力で締めつける……っ！　だからっ、そのまま\n、一番奥で射精してくれ！　精子っ……精液を注がれたいぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おほぉおおっ♪　おッほぉおおっ♪　んほぉおおおっ、ほぉおおおンンンっ\n……！　上がってきた、注入されているぅう、貴様の精液をぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504301" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ドクッ、ドクッと音をたてているかのようにっ……！　激しく、脈打ちなが\nら精液を撃ち出すチンポ……！　あっぁっ、こんなに逞しく……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「尻の中が火傷しそうなくらいに熱いぃいっ……♪　あぁあぁっ、尻の穴で、\nイクのがクセになる……ぅっ！　イキ癖がついてしまう、……おぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あへぇえっ♪　ひぅううっ、うううううう……ッ♪　尻が！　腰が、脚がぁ\nああ、ゾクゾクして絶頂が終わらない……！　おっ♪　おっ、最高だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「尻の穴を調教されてしまった、貴様の精液で喜ぶ、ヘンタイの穴に改造され\nてしまったっ……！　こんなに簡単に、たった二回の射精でぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おっ♪　ぁっ♪　尻の穴に中出しされて感じるヘンタイに……！　あっ！？\n　イグッ、イクッ……！　っあああああああ……！　イクぅうううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……今さら悔いても仕方のないことだが……。尻の穴でセックスをしてしま\nった罪悪感と、戸惑いが……今ごろ襲いかかってきている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ラブホテルでしたことが、誰かにバレるわけがない？　……フン、元より他\nの誰か、なんてどうでもいい。私が誰より知られたくなかったのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様だ！　貴様に……尻の穴でよがるヘンタイ女だと思われるかと思うと…\n…いたたまれない。共犯？　そ、そうかもしれないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うう……。この私が、クリスマスのムードなんかに流されてしまうとは。来\n年からは、この日には充分気をつけなければならないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504310" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あひぃいッ……！？　チンポが、チンポがいきなり！　尻の中から消えて…\n…抜けて！　っあああああっ！　外に出すつもりかぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504401" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んおほっ♪　おおおっ……♪　尻の中ではなく、う、上に……生クリームの\nような精液がドピュドピュと……！　うぁっあっあっ、垂れるぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ひぃっ……！　あぁっ、ほ、火照った尻の肉に……びゅるびゅると、しつこ\nく精液が塗りたくられて……！　っぁっ……臭いがとれなくなりそうだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……あふっ！？　こらっ、シーツにこぼすなぁあ……っ！　あっ！　尻の上\nと♪　谷間におさまらないような量を……身勝手に射精して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様というやつは……とんでもない尻の穴マニアだっ……！　あっ……ぅ…\n…！　ほら、尻の穴にまで精子を垂れ流して……んんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなことをされたら……っ！　貴様の精液の味を、私の尻の穴が覚えてし\nまうじゃないかぁあ……！　あぁっ……もう出すな、出すなぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……んん……っ。ベッドが大変なことになってしまった……。ホテルの清掃\n業者に迷惑をかけてしまったのではないだろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「プロは慣れているから大丈夫だと思う？　フン……。ふ、ふ、普通の恋人同\n士は尻の穴で交尾……アナルセックスなんてしないだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001605_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「もし万が一、彼らや受付の人や……近くの部屋を使っていたカップルにアナ\nルセックスがバレたらと思うと、今さらソワソワしてきてしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そ、それくらい私にとっては罪深いプレイだったんだ！　こ、今度からは…\n…する時は前もって言っておいてほしい。いいな？　わかったか？」", "NORMAL" ]},
