		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「む。もっとクリスマスの思い出を知りたい……？　貪欲なヤツだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "1", "CENTER", "0" ]},
