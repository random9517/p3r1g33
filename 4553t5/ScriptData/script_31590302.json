	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふぅ……今日もたっぷり付き合ってくれてありがとう。この休みの間に、随\n分泳ぎが上手くなった気がするわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さて……それじゃあ、ホテルに戻りましょうか。ゆっくり体を休めましょう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あら？　ふふっ……何だか当てが外れたって顔をしてるわね。どうしたのか\nしら、何か言いたいことでもあるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「えっ、こっちに……？　ちょっと、あっ……分かったわ、そんなに慌てなく\nてもちゃんと付いていくから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……ふふっ、いつになくがっついちゃって……そのまま帰るなんてイヤ\nだってことみたいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015903_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「だからって……こんな岩陰に連れ込んで……襲ってくるなんて……そんなケ\nダモノみたいな所もあったのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「でも、心配しなくても……私も最初からそのつもりだったわ……んっ、そう\n……そのまま脱がせてちょうだい……ビキニもずらして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふっ……後ろから鷲掴みにされちゃってる……あっ……ぎゅって……握り\n潰して……んんっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「いいわ……少し位荒っぽい方が燃えるもの……欲望剥き出しでがっついて欲\nしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぁ……首筋に、息が当たってる……すごい鼻息……ふふっ、興奮して……\n堪らないのね……私もそうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……！　今度は、お尻に……硬いのが当たってるわ……勃起したオチン\nチン……待ちきれないのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、はぁんっ……擦りつけられてるぅ……ズリズリされて……ん\nっ、私も……オマンコもその気になって来ちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ねぇ……あんまり、焦らさないで……そろそろいいでしょう？　立ったまま\n……後ろから、オチンチン……ずぶってハメてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ほら、オマンコ……もうちゃんと準備が整ってるの分かるでしょ？　付け根\nの所……ぐちゅって濡れちゃってるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、そう、そのまま……あっ、入れて……はぁっ、んんっ、くぅっ\n、うんっ、あっ、は、入るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁ……ずぶって来たわぁ……熱くなってるの……割れ目……かき分けて、\n来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……立ったまましちゃうなんて……思ってる以上に、ワイルド\nなのね……はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それで、これからどんな風に楽しませてくれるのかしら？　んっ……あっ、\n立ったまま……あふっ、突き上げて……来るのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あひぁっ、あぁっ……んっ、すごい……んんっ、オチンチ\nン……本気で盛って来てるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「待ちきれなかったのは……お互い様ってことね……あふっ、んくぅっ……あ\nぁっ、熱くなってるのが……暴れてるわ……んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、ええ、おっぱいも……んんっ、一緒にして……あぁ\nっ、指で……乳首っ……扱かれてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁ……すごい、上手……んんっ、そんなに擦られたらっ……あふっ、声…\n…漏れちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ダメよ……いくらプライベートビーチでも……んっ、誰か迷い込んでくるか\nも知れないんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そんな時に、こんな……裸で絡み合ってっ……あっ、オマンコ……突かれて\nる所……見られたりしたら……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「違う……んんっ、見られたがってなんかっ……んんっ、この……濡れてるの\nはっ、ただ、普通に感じてるからで……はっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「こんな恥ずかしい所っ……見せるなんて……あぁっ、ダメよ……んっ、これ\nは、貴方にだけ……見せるやつなんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、ひぃっ！　オチンチンっ！　あぁっ、中でっ……オマンコの奥っ……\n突き上げてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「い、今っ、そこはっ……あっ、感じやすいのっ……あぁっ、ダメっ、弱点ば\nっかりっ……あひっ、ず、ずるいわっ、あぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ、くぅっ……んふっ……私……だってっ、んふっ……！　んくぅぅっ\n……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ……やられるばかりじゃないわ……ほら、オチンチン……あっという\n間に、余裕がなくなって来たでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「私だって……貴方の弱いところは、ちゃんと……知ってるの……んっ、私…\n…自身も、感じちゃう……けどっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁんっ！？　また……んんっ、おっぱいっ……でもっ、簡単には止められ\nないわよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「貴方が入れたスイッチ……もう簡単には止められないんだからっ、あひっ、\nくひぃんっ、あぁっ、オチンチン来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、かき混ぜ……られてぇっ……あっ、出るのっ？　しゃ、射精\n……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ええっ、出してっ！　オチンチンから、いっぱい濃いのっ……中に来てぇぇ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんんぅぅぅぅーーーーんっ！　あっ……出て……来たっ、あっ、びゅくっ\nて……射精……始まってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「嘘……あ……こんな、外で……んんっ……なのにっ……中に出されてる……\nんぅ……気持ちいいの……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁ……射精されたまま……まだ、オチンチン動いてるの……こんなにぃ…\n…あっ、あぁっ、奥っ……イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……射精……終わった？　んんっ……はぁ、はぁ……はぁ……あ\nぁ、まだオマンコが気持ちいいままになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふ……こんなに蕩けた気持ちにさせてくれるなんて……やっぱり、貴方と\nの相性は抜群みたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……待って、まだオチンチンは抜かないで……んっ、どうせ一回\nじゃ小さくならないんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ……！　んふっ……ほら、またその気になって来たでしょう……？　\nケダモノに戻った同士……もう少し楽しみましょうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あんっ！　あぁっ……んふっ、すぐやる気になってくれるわね……ええ……\nもっともっとオマンコも……おっぱいも愛して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……乳首……引っ張られちゃう……んっ、あふっ、やっぱり\n強くされるのがいい……んっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ひゃふっ……あんっ、うなじ……舐めてるの……？　んぁっ……あぁ、ゾク\nゾクするぅ……私、こんな所まで弱かったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ……あぁ……お腹の辺りもさすって……お尻も……あぁ……身体中、い\nやらしい手が這い回って来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あひっ、そこっ……！　あぁっ……いっぱい身体……触ら\nれながら、オマンコ……かき回されるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あぁっ……！　んっ、はぅんっ、気持ちいいっ……１回目より\nも、もっと……あっ、身体中っ……感じるのっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あっ、はんっ、あぁっ、ぐちゅぐちゅっいってるっ……オマンコの恥ずかし\nい音っ……お尻がっ……パンパンする音もっ……あひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁっ……いいわっ、オマンコ気持ちいいのっ！　外でするオマンコセック\nスっ……あぁっ、すごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、もうイキたくなってるっ、あっ、このままイカせてっ、ぐ\nりぐりっ、弱点っ……集中的にしてっ、ひぃんっ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……あぁっ……またイッちゃった……んっ、オマンコ……勝\n手にヒクヒクしちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、ごめんなさい、私ばっかり先に……大丈夫だから……このまま、続け\nてして……オチンチン、グリグリしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あふぁっ……そうっ、あっ、今のっ、もう一回っ！　んひんっ！　あっ、オ\nマンコっ……感じるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁっ、あひぁっ、すごいっ……足が震えてっ……立って……られないっ！\n　んんっ……あぁ……支えて……おっぱいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0304215" ]},
