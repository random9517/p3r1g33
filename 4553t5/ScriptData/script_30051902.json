		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ご足労頂いてすみません。今日はその……他でもないお話がありまして……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はい……ここのところ、ずっと気になっていたことなんです……つまりです\nね、その、あ、貴方の……ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「においが……ずっと頭に染み付いてしまったみたいで……頭が……いえ、頭\nだけでなく身体もおかしくなってしまったのかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほ……ほら……ご覧になって下さい……あぁぅ……まだ何もしていないのに\n……こんなことになっているの……分かりますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「触られる前から、ずっと……ウチのオマンコがじゅくじゅくに濡れて……オ\nチンポが欲しくて……疼いているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「仕事をしている時も……ずっと貴方のオチンポのことが気になって……どう\nにもならなくなっていて……お願い……します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どうか、ウチの疼きオマンコを鎮めて下さい……貴方のオチンポで……ウチ\nのいやらしいオマンコを躾けて下さい……お願い……しますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁっ、あぁぁんっ！　あっ、んくぅぅぅっ……はぁっ、奥に……\nオチンポっ、入って来ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、んふっ……！　あぁっ、いっぱいです……太すぎるオチンポぉ…\n…奥の……奥まで届いてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くっ、んぅぅぅんっ……そうです……これを待ってたんです……あぁ、ずっ\nとご奉仕しているうちに、ウズウズし過ぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……今……ハメられただけで、少しイッてしまいそうになりま\nした……ウチのオマンコ……敏感になりすぎてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふっ、でも、大丈夫です……何とか、なりそうですから……んっ、このま\nま動かしてみて下さい……思い切り突いて……かき回して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、あぅっ、くぅっ、んぅぅんっ！　あぁっ、オチンポっ……ズボズボっ\n……混ぜ、られてますぅっ……あっ、ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、恥ずかしい……お汁がっ……いっぱいっ、溢れてっ……はした\nない音っ、響いちゃってますっ、はっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、オチンポの先端が……オマンコの奥ぅっ、コンコンノックし\nてぇ……ふひぁっ、あっ、ひっ、はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、くぅっ……あっ、あぁっ……ピストン……だんだん速くしていって\n下さい……貴方のオチンポ……もっと、いっぱい感じたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あぁっ、そこっ、そこですっ！　ウチのっ……あぁっ、気持ち\nいいとこぉっ……続けて、くひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ヒダがっ……あぁっ、擦れてっ……いいっ、くぅぅんっ、はぁんっ、いいで\nすぅっ……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、やだ……ウチのオマンコ、悦んでます……あぁっ、違うんです……\nいつもは、こんなのじゃないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも、あぁっ、ずっと待ってたからぁっ……いやらしい気持ちがいっぱいに\nなってっ、もっと……んっ、して欲しいって……思っちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ちゅぷっ……あっ、今……キスぅっ……はぁんっ……嬉しい……れ\nろぉっ、して欲しいって思ってたの……分かったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、顔が……そんな顔をしてた……あぅっ……ウチは、いつの間にか……\nそんな物欲しそうにしてましたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも……ちゅぷっ、そうかも知れません……れろ、ぴちゃ……今……舌と舌\nをれろれろ……んんっ、絡ませてるだけで嬉しくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そのまま、あっ、ズリズリって……出し入れされると……はぁん……全身の\n力が抜けて……蕩けちゃいそうです……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……こ、今度は……おっぱいですか？　そんなに……揉み心地はよく\nないと思いますが……それでもよろしければ……どうぞです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、手にぴったりで……肌触りも最高……あ、ありがとうござい\nます……けどっ、面と向かって言われると……は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……あぁ……優しい手触り……んっ、こういう技で……色々な女\nの子を籠絡してるんですね……ウチには分かります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、だって……ウチが今、正に堕ちそうになってますからぁ…\n…あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こんな色々なところ……されながら、はぁんっ、オチンポが……出し入れさ\nれるなんてっ……あぁっ……うんっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ズブズブされるのっ、すごすぎますっ……はぁっ、あふっ、オマン\nコっ……ぬるぬるが、また……広がっていきますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふぁ……熱いです……んっ、りゅぷっ……またキスぅ……はぁぁっ、奥を\n突かれながら……舌ぁ、レロレロさせるの好きれふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はっ、んくっ……オチンポが……中っ、膨らんでぇっ……これぇっ\n、あっ、そろそろ……出したがってますよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かりますっ、んんっ……あのっ、出したいなら……このまま中にっ……腟\n内射精っ……お願いしますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、んふっ、ウチの……オマンコは、もう完全にその気ですからぁっ……\n一番奥までっ……子宮に直接精液っ……出して下さいっ、はぁぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんんんんーっ！　あぁっ……出てますっ、熱いの……びゅくびゅくっ……\n濃い精液っ……ドプドプ出てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁぅ……んっ、これを待ってました……あっ、あぁ……ウチもイッてます\n……くぅぅん……オチンポ気持ちいいです……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……身体……ビクビクしてます……んっ、出てる精液……ごくごく飲ん\nでるみたいです……はぁ、あふぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ……いっぱい出してくれましたね……ウチの子宮が……受精したみたい\nで……すごく悦んでいます……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちいいことされてしまったら……本当に貴方なしではいられな\nくなってしまうかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゃんと責任取って欲しいです……ウチをこんなにメロメロにしたこと……\n分かっているんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……でも、まだ……オチンポ……ウチの中ですごい存在感です\nね……まだ、出し切れてないですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「今日のウチは……ちょっと甘えたい気分なんです……だから、おねだりして\nも……いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチの、イッたばかりで……敏感なオマンコ……もっと貴方のオチンポで可\n愛がって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「中の精液、ぐちゅぐちゅさせて……しっかり受精できるように……もっとオ\nマンコに染み込ませて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はんっ！　あっ、あぁんっ！　またっ、ピストン……始まりましたっ……ん\nふぁっ、中っ、混ぜられますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁん……ウチも、ずっと受け身ではいられません……ご主人さまに忠実に\n仕える……パーフェクトメイドなんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「しっかりオマンコを吸い付かせて……あぅんっ……オチンポに楽しんでもら\nえるようにしますから……んんっ、くふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、はっ、今のペースで、ちょうどいい感じです……んんっ、ウ\nチも合わせて動きますね？　んっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はふっ、粘膜が……ズリズリ擦れてますぅ……同じところを亀頭で何度も押\nし込まれると……はぁっ、身体が痺れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あんっ、んんっ、ウチも、もっと足を絡ませて……離れないようにくっつけ\nていきますぅ……あっ、おっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……はんっ、あぁっ、お願いします……また、おっぱいも触っ\nて下さい……貴方に、してもらうの……好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ、気持ちいいです……あぅっ、乳首っ……カリカリ引っ掻か\nれながらっ、あぁっ、オチンポが暴れてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁんっ、どっちもいいですっ！　ウチのオマンコもおっぱいもっ\n……どっちも、いっぱい悦んでますっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁんむっ、ちゅぷっ……あぁぁ……キスまでぇ……らめ……幸せしぇっく\nしゅぅ……こんらのされたら……蕩けまひゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あぁっ、ま、まられふ……もう少し一緒に、気持ちを高めてっ…\n…貴方がイクのと一緒がいいれふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、奥に入ってる時に……キュンってオマンコっ……してぇっ…\n…あっ、あぁっ、も、もうすぐですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「貴方もっ……後ちょっとですかっ？　はいっ、あぁっ、後もうちょっとだけ\n……頑張りますからぁっ、いっぱいずりゅずりゅして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぅっ、くぅんっ！　気持ちいいのっ、いっぱい広がってぇっ！　もうっ、\nこれっ、イキますっ、またオマンコイッちゃいますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、熱くて……濃いのっ、またいっぱい出して下さいっ！　ウチの中\nでもっ……ぶっ掛けでもいいですからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「イキますっ！　ひぅんっ、パーフェクトメイドのラブラブセックスでぇっ、\nオマンコまたイクっ……イキっ、まひゅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅぅんっ！　あぁっ、またっ……中出しされてるっ……ドピュド\nピュっ、熱いの……届いて……まひゅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……ぎゅってします……離したくない……んっ、オチンポ子宮にくっつ\nけてぇ……もっといっぱい出して下さい……はへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……ビクビク震えてぇ……こんなにいっぱい出してくれてます……あ\nふぅ……オマンコ……幸せですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ……あぁ……全部……出ましたか……？　オチンポの中に、まだ\n残ってたりしませんね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふ……はい、とても良かったです……おねだり……全部聞いてもらえて…\n…ウチは……幸せです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あっ、ちゅぷっ……なんですか……またキスですか……？　貴方も、大概甘\nえたがりですよね……ふふ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そうですね、たっぷり甘えさせてもらった分、またいつもの仕事でパーフェ\nクトなメイドであることを示さないといけませんからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ええ、日々の雑用から戦闘まで何でもお任せ下さい。どんなことでも、何の\n問題もなくこなしてみせますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですから、それがしっかりと出来たら、またその……お願いといいますか…\n…つまり、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ま、また……今日みたいに可愛がってもらえたら……ウチは……嬉しいです\n。よろしくお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁっ！　あっ……精液っ……いっぱい出てますっ……熱いの掛けら\nれて……また、イキ……まひゅうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あぁ……マーキングして下さい……ウチの好きな精液のにおい\n……もっと染み込ませて下さいです……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……ヌルヌルのオチンポ押し付けられてぇ……あぁ、お腹にも……おっ\nぱいにも……ネバネバがついてます……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……もうすぐ終わっちゃいますか……？　ちゃんと全部\n、ウチに出してくれましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ありがとうございました……いっぱいオチンポ頑張ってくれて……本当にお\n疲れ様でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000519_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふ……ちゅぷっ、あっ、すみません……一応、味見もしておかないと……\nただ拭き取るのは勿体ないと思いまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちょっとビキニの方にも染み込みましたが……いえ、それは気になさらない\nで下さい。パーフェクトメイドはお洗濯も完璧ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「どうせなら、もっと染み込ませる位の方がいいかも知れません。すぅぅっ…\n…んっ、ウチのエネルギーの源です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えっと……今日は、まだ大丈夫ですよね？　では、その……後でお風呂をご\n一緒しませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1904409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はい……ちゃんとお背中もお流ししますから……メイドのおつとめは、まだ\nまだ続きますです」", "NORMAL" ]},
