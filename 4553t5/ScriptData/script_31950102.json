{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ばっば～ん♪　あなたのえっちなラケシスおねーさんだよぉ～♪　ね～え～\n？　待っててくれたぁ？　それとも一人ではじめちゃってた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんと精液はぁ、もうわたしだけのものなんだから。勝手に\n自分で使っちゃ嫌よぉ？　ね？　ね、今から二人でえっちしよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……え？　罠？　これが罠なんじゃないかって……？　ぷっ、くすくすくす\n……！　やぁだ、そんな心配しちゃってくれてたのぉ？　おっかしい！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「まぁ～、そっかぁ～。わたしぃ、いかにもあやしいダークエルフだものねぇ\n♪　ふふふっ……。じゃあ、こういう趣向はどうかしら？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふふっ♪　こうして裸になってぇ、いっちばん無防備なポーズでお尻をあ\nなたに向けるから……。調べたいだけ調べてちょうだい？　気が済むまで」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「丸出しのおまんこも、お尻も……おっぱいにだって触っていいわよ。あやし\nいところがないか、１つ１つ調査して……ついでに気持ち良くしてぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……♪　んっ……。いいかも、こういうシチュエーション\n……。わたしの方はもう、身体が火照って興奮……してるから」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あとはあなたが確かめてみて？　わたしがぁ、ただの痴女ダークエルフでぇ\n……♪　ハメハメしたいだけのおまんこビッチなんだって……んふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「罠なんて１つも仕掛けられないくらい……おちんちんさえもらえればいいダ\nメエルフなんだって……よーっくわかるまでいじくりまわしてねぇ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ……さぁて、どこから触ってくれるの……？　あっ……♪　胸ぇ？　た\nゆんたゆんでおいしそうでしょ……？　あっ……指が熱くて気持ちいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「次……はお尻ぃ？　んふっ♪　さすがにわたしもぉ……そんなところに罠は\nしかけないわよぉ……♪　えっち……♪　んっ、中には何もないってばぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　あぁ……お、おまんこも……ただ、穴が開いてるだけだって\nぇ……。あっ……んん、さわさわぁって優しくなぞって開くのはだめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっふ……♪　ふぅっ……♪　ふぅうう……♪　身体中をまさぐって……♪\n　あっ、おまんことお尻の穴を、入念に開いてほじくって……あぁん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そ……そろそろわかってくれた、でしょぉ……？　罠なんかないんだって…\n…。触れば触るほど、わたしが感じちゃうだけなんだけどなぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あんっ……。かったるい触り方ばっかりしてないで、もっといやらしくして\nよぉ……。ほら、おまんこくぱぁって指で開いて待っちゃうからぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おまんこの奥の奥まで、おちんぽ使ってかきまわしてぇ……♪　ちんぽで直\n接調べて、探って、突きまくってよぉ。もう待ちきれないんだからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あなたが罠を疑って触ったから……愛液でもうおまんこがトロトロよ？\n　見て、みて……透明なおつゆが膣壁にまとわりついてるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「中はヒクヒク疼いて蠢いてるから……。挿入したら気持ちいいわよぉ……？\n　ね、バカになっちゃっておちんぽズプズプ入れちゃおう？　早く♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あぁっ♪　おちんちん……！　おちんちんオマンコの中にきたぁあ……\nっ♪　ああああっ、あ、あなたも興奮してたんじゃないぃ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんぽ熱すぎて、……あんっ、火傷するかと思ったぁ……♪　かったくな\nって尖って……あっ♪　あっ♪　おまんこ調べるつもりしかなくってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「カリ高のえっぐい極太おちんぽが……あっ♪　わたしのおまんこを……んん\nっ！　無理やり拡げてるぅ♪　あっ、すごっ……すごい、硬い……イイっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっんん♪　あやしいのは奥でしょ……っ？　ああっ、あはぁああ……！　\nめちゃくちゃにかきまわして、調べて、調べてぇ……！　あっあっあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「な、にかあったら大変だからぁああ……♪　丁寧に、丁寧におまんこの中を\n調べ尽してぇ……っ♪　あぁんっ、肉厚なぷにゅぷにゅおまんこヒダ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「濡れたヒダヒダがおちんぽの調査を邪魔してくるでしょ？　……あっ♪　そ\nうするとぉ……ムキになって突きまくりたくなっちゃうわよねぇ？　んっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたし、のぉ♪　貪欲おまんこに負けちゃだめぇ♪　あなたのつよ～いおち\nんぽで、まとわりついてくるマン肉をかきわけて進むの、よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……♪　はぁっ、はぁんんっ、あぁ……♪　いいっ、いいぃ……\n♪　強くて傲慢な調査おちんぽ、これ、これまずいわ、癖になるぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もーっともっと調べて欲しくなっちゃうぅ♪　あぁあああ……♪　どう？　\nどうぅ……？　なにかわかったぁ？　罠……あったかしらぁ……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もっともぉおおっと乱暴にしないとわからないかもしれないから……っ。あ\nぁんんっ、突きまくってぇ、びちゃびちゃのあそこを壊しちゃうくらいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「強引にっ……強くぅ……！　強くしてぇ……！　あぁっ♪　あっあっあっ！\n　わたしぃ……わたし、腰を振ってる時のあなたが好きっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「だってやらしい動き方、するんだものぉ……！　あぁ……♪　はぁあっ♪　\nおまんこの粘膜が震えるくらいえっちで、獰猛で……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こんなピストンされちゃったらぁ、どんな種族のどんなオンナだってイチコ\nロになっちゃうに決まってるじゃないぃ♪　エルフだって例外じゃないぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「知性も叡智も全部忘れてぇ……♪　えっちすることしか考えられなくされち\nゃう♪　最強のおちんちんよ……いい、いい……これ、だぁいすきぃ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ずっぽずっぽして♪　あっ……今の、今のところ気持ちいい♪　……あああ\nあ……！　なんってやらしい形のオスチンポなのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「気持ちいいところばっかりに当たるの、こすれるの……っ。どれだけ孕ませ\n特化のおちんぽなのぉ……！　女殺し、メスエルフ殺しの極悪ちんぽぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これを味わったらぁ……他のじゃ満足できなくなっちゃうじゃないぃ♪　か\nっこよすぎるの、強い……のぉ！　あなたのちんぽが一番いいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっああああああ……♪　やっぱりぃ、生ちんぽ、ゴム無しおちんぽってお\nまんこによく響くわぁ♪　ああっ、ああ、あなたのは特別好き……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「一応調査の名目なのに……わたし、勝手にイッちゃうけどいいわよね……？\n　っあああああ、イくぅ、我慢できるわけないぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「イぐイぐイクイクぅうう～～っ♪　あはぁああ♪　ねぇっ……あなたもイッ\nちゃって？　というかわたしが精液欲しい……出して出して出してぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っんんんんんん～～～～♪　どっぴゅどぴゅ音がしてる♪　重たい、濃密な\n精液が膣奥に流れこんで……眩暈しちゃう♪　ありが、とぉ……っ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「どっくんどっくん脈打って……。あああ♪　おいしー精液がおまんこに溜ま\nって、く♪　調査結果が届いてる♪　んんんん～っ、最高ぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふ、うふふ、ふふふ……♪　すっごく、すっごぉく良かったぁ……♪　あ\nなたって、こんな一面もあったのね。ますます好きになっちゃった」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おまんこの中は、奥の奥まで調べられちゃったけど……。まだまだ調べる場\n所はたくさんあるでしょ？　例えばお尻……とか。こっちは好きじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もし良かったら……わたし、こっちも調べ尽くしてほしいなぁ……？　うふ\nふふっ、わたしぃ、信用出来ないビッチちゃんで良かったぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「清純清楚な女の子だったらぁ……こんなにエッチではしたないお願い、なか\nなかできないもの♪　ね、調べて。また乱暴に、今度はお尻に……入れて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……なあに？　色々心配？　ふふ、大丈夫よぉ～。こんなこともあろうかと\n、ちゃぁんとお尻は綺麗にしてきたの。すぐ拡がるように自分でほぐしたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「少しオチンポを入れる感触は違うかもしれないけど……まったく気にしなく\nていいわ♪　めちゃくちゃに犯すつもりで掻き回して？　お願い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はやく……♪　早く犯してぇ♪　わる～いエッチなビッチちゃんのわたしを\n～。他のヒトは使ったことのないアナルで犯して～♪　……え？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お尻？　これが初めてよ。いやだった？　わたしね、ビッチだけあってエッ\nチにはうるさいのぉ。最高の男としか、こっちではしたくないんだも～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……だから、つ・ま・り……。こっちはあなた専用のビッチ穴ってこと……\n♪　んふっ……。もう待ちきれない。おちんちん、いただきまぁす……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ……んぁあああ……♪　これよ、これこれぇ……♪　は、ぁ……♪　や\nっぱり太くてカッコイイ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_12" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「すごぉい……。わたしのお尻がパンパンになっちゃったぁ……。あぁん……\n♪　こういう感じなんだぁ、お尻でするのって……悪くないかもぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うふふふ……。ゆーっくり動いてぇ……？　腰を揺らして……。あっ……♪\n　なに……？　なにこれぇ……知らない感覚……あっ、面白ぉいぃ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_11" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ぬぶっ、ぬぶってお尻の中で鈍い音がして……る、すごく、おちんちんの太\nさが感じられて……。あっ♪　そうなんだ、これがアナルでするって事」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「き、らいじゃない……。ううん、結構好き、かもぉ……♪　あっ、あっ♪　\nも、もう激しくしていいよぉ……。あぁんんっ、そぉ、そうやってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしのお尻の穴、アナル、ズンズン犯してぇ……♪　あはぁあっ……はぁ\nんん♪　あぁんっ、あん、あんっ……やだ♪　穴の中が熱いぃい♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_13" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わ、たし……腸内でもばっちり感じちゃうタイプ、なのねぇ……♪　んぁあ\nあ……！　お尻の穴にミッチリおちんぽが詰まって……背徳的よぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「いっぱい突いて……。あんんっ♪　おまんことは違う、深いふかぁい快楽ぅ\n……あっ！　少しずつ開発されて、感度が高まって……んふぅううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁっ……あぁ、素敵……本当に素敵……っ。あなたに抱かれていると……\nわたし、わたし酔っちゃう……悪い酔い方しちゃうぅ……！　んんんっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_11" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ね～ぇ……このままもう一度出して？　あなたの熱い精液を注がれたいの…\n…全部の穴の一番奥で、あなたに繋がれたい……あなたのモノになりたぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふぅうっ……あぁあん♪　あなただけのビッチちゃんにして、独占して……\n♪　私の誰にも挿入させなかった穴、アナルの一番奥に出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っくふぅうううううんん♪　んふぅううっ、ふぅうう～～～っ♪　これこれ\nこれぇ……！　いいの、いいのもっともっとぉ～っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、嬉しい……。うれしいよぉ……。やっと、やっとあなたにわ\nたしの初めてをあげられた……。ねえ、独り占めしてね。ずっとよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「この穴は……。あはっ……あなただけのえっち穴なんだからぁ……♪　あっ\n……。お尻の中って、精液出てるのがすっごくよくわかるぅ……熱いわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うん、うん……我慢なんかしないでぜーんぶぶちまけちゃって……♪　わた\nしもそれが嬉しいの、あなたの精子に満たされていくのが……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_16" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　ふぅうっ……！　んぁんん……♪　あぁ……。本当に、おな\nかいっぱいになっちゃった……。二回目なのにすごい量出すのねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そーんなに良かったぁ？　私のお・し・り……♪　ふふふ、喜んでもらえて\nよかったぁ……。さすがに、こっちはちょっとだけ自信がなかったから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_14" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「満足そうな顔が見られて……良かった。え？　おまんことはまた違った快感\nだった？　ふぅーん……。そぉなんだ……うふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……んん？　今……中でドロドロが動いたみたい……♪　わたしが腸壁を動\nかしちゃったのかしらね？　はぁっ……♪　はぁ、はぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんも、精液も……わたしのお尻はだぁいすきみたい……。\nこっちの穴だけは、いつだってあなただけのえっち穴だからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「また、したくなったら遠慮なく言ってねぇ？　あーん、でもおまんこでする\nのもいいしぃ……。贅沢な悩みで迷っちゃう～。どうしたらいいかなぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁううっ！？　あぁんんんっ！？　へっ……？　やだっ、あなた……とん\nでもないことするのねっ……！　んあぁああっ！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お尻、で……っ。わたしがお尻でイク瞬間におちんぽを抜き取って……。あ\nあっ♪　そのまま腰に……お尻に精液をぶっかけるだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「こ、ここまで予想外の動きをしてきた男は初めてよ……！　あなたって、本\n当に……本当に……！　っくぅうう……♪　やん、やん熱い、熱いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んもぉおお……♪　困ったひと……。お尻の中も外も、独り占めしないと気\nが済まないっていうの？　お尻に執着しすぎよぉ……。でも♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_19" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そこまでわたしのお尻……お気に召したなら本望だわぁ……♪　ふふふふっ\n、あなた専用の精液お便所よ？　好きな時に好きなところに出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っんふぅううう……♪　ふぅう……♪　あぁ……♪　量が多すぎて足の方ま\nで垂れてきてる……。確かに、この量を中に出したら危険だったかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「精液浣腸になっちゃって……ぶびゅぶびゅって溢れ出しちゃってたかもしれ\nないものね……♪　興奮しすぎて、そこまで頭が回らなかったわ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_02_17" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……え？　それはそれで見てみたい？　んも～……変態ねぇ。で・も……わ\nたしもあなたに対しては変態ぎみだし……いいカップルなのかもよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたとわたしなら……普通じゃ出来ないプレイだってできるはず。アブノ\nーマルなえっち……好奇心をかきたてられる、特別なプレイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もう、他の人なんてどうでもいい……。あなたとどこまでも堕ちていくって\n決めたわ。だから、最後まで付き合ってもらうわよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0104410" ]},
		{"command":[ "WAITINPUT" ]},
