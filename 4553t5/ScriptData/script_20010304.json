{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「待て、どこだ、どこに逃げた！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員" ]},
		{"command":[ "SETTEXT", "「そっちよ、その裏路地に逃げたわ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「くっ、こうなったら一時休戦だ！　あの道化師どもを、まず真っ先に捕らえ\nなければ……被害が広がる一方だっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員" ]},
		{"command":[ "SETTEXT", "「まったくよ、本当、噂どおり迷惑な小娘たちっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それぞれの組織への救援要請に応じ、続々と集まってくる隊員や戦闘員たち。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな追跡をかいくぐって公園を脱出した３人は、なんとかこの場を離れよう\nと市街を逃走し続けていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はぁー、もう、マジ疲れたー！　騒ぎ、大きくなりすぎー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020044" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……客観的に考えて、ピコさんが悪いんです！　相手の挑発に乗っ\nて容赦なく暴れたせいで、騒ぎが大きくなったんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020038" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はぁ？　暴れたのはティアも同罪だし！　っていうか、あそこまで派手な魔\n法使わなくても勝てる相手だったでしょー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020045" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「そ、それは、あの人たちが私のことを知的でないなんて、あまりにも非常識\n的な暴言を吐いたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020039" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もぐもぐ……まー、ふたりとも同罪？　もぐもぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020024" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ミランもでしょー！　っていうか、そのお菓子、どこから持ってきたのよ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020046" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もぐもぐ、さっき、通りがかりの屋台で買った。もぐ……クッキー、なかな\nか美味しい……もぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020025" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「走りながらものを食べるのは、マナー的によろしくありませんよ、ミランさ\nん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020040" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「でも、お腹すいて我慢できなーい。もぐもぐ……でも、最後の一個……がっ\nくり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020026" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "紙袋いっぱいに入っていたクッキー、ミランがその最後の一個を名残惜しげに\n口へ運ぼうとしたときだった。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「いたぞ、そこだ！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員" ]},
		{"command":[ "SETTEXT", "「問答無用！　やっちまいなっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「って、やばっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020047" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「今、魔法で障壁を……くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020041" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「うへぇ、さすがにこの数はちょっとめんどーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020048" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「まともに相手をしていては疲れるだけです。今度こそ、戦略的撤退を強く推\n奨します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020042" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「んー、ピコさまも疲れたし、それでいいかなー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020049" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「……けど……無理っぽい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020050" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「どうして？　……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020043" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……最後の……クッキー……」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "敵の放った攻撃の余波で、かじりつく前に砕け散ってしまったクッキーの破片\nを、呆然と見つめるミラン。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "小さく震えていた彼女は、やがて顔を上げ――。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……ぶっ潰す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020028" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "物騒な言葉を吐くとともに、殺到してくる敵へ向かって駆け出した。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「……お菓子を台無しにされて、ミランが怒らないわけないしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020051" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「客観的に考えて、止めようとしたら私たちまで巻き沿えを食うだけですね…\n…仕方ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020044" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「もう、こうなったらまとめて全部やっちゃうだけだし！　いくよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020052" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}