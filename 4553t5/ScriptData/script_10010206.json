		{"command":[ "SETTEXT", "ん……この声は！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッド！　任務は中止だ！　ただちに戦闘を停止せ\nよ！　繰り返す！　任務は中止だ！」", "NORMAL" ]},
