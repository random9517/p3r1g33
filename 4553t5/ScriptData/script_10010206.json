        {"command":[ "PLAYBGM", "BGM_002" ]},
		{"command":[ "SETTEXT", "それから俺たちは長官と先生とかいう奴の説明聞いたのだが……。", "NORMAL" ]},		
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え～と、つまり、こういうことですか？　この人たちは、ヴィランじゃない\nし、悪いことは……今は、していない」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "096_010102090002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そういうことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102090004" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そして、この子たちは俺たちの敵じゃないし、ましてや襲来者の仲間でもな\nい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そういうことになる」", "NORMAL" ]},
