		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「では、なぜ戦闘に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010102090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「だって！　撃ってきたんだもん！　しょーがないじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102090003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうそう！　変な光に包まれて、この場所に出てきたなー、と思ったら、い\nきなり弾が……あ、あれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102090002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102090003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「いや……今になって冷静に考えたらさ。あれ、ただの流れ弾だったんじゃ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102090003" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102090002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ……。言われてみれば、そんな気も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102090004" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「……ウ～～タ～～？　シャ～～ラ～～！？　あのねえ！　あなたたちねえ！\n　そもそもあなたたちが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102090004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ホクサイ、そのことはあとでゆっくり話し合おう。今はとにかく、双方にと\nって不運な事故が起きてしまった、ということでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102090005" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その通り。幸いにも、こちらの人員に負傷者は出ていないし、共通の敵であ\nる襲来者も排除できた。結果オーライだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102090004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……襲来者を倒したのは、主に俺たちだけどな。まあ、いいか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど。なんとなくだが、話が見えてきた。あちらの五人は、ワームホー\nルを抜けてこちらの世界にやってきた、ということか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_090102090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「わぁむ……ほぉる？　ゲン、知ってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102090005" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ごめん、私、聞いたことない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102090004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はいはーい！　ダイヤナちゃん知ってるー！　お仕事が大好きすぎる人のこ\nとよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010102090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それはワーカーホリックでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102090001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はははは！　ダイヤナはバカだなあ！　ワームホールったらあれじゃんか。\n腕の関節を、こう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102090001" ]},
