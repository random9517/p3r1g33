		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「おまえたち、いいかげんにしないか！　少し頭を冷やせ！」", "NORMAL" ]},
