		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「これから説明する。ひとまず、あちらのチームと合流するのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102090002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ヴィランたちと！？　なんでなんでっ！？」", "NORMAL" ]},
