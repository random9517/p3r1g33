{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さん、私のこと後ろから犯したいんだ……。んふふ、いいよー。隊長さ\nんの命令だったら、聞かなくっちゃね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「それに、隊長さんとエッチするとお仕事サボれるし、気持ちいいし、私とし\nては一石二鳥だしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「なに？　正義の味方にしては不真面目すぎるって？　大丈夫だいじょうぶ、\n私はやるときにはやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「そして、ヤられるときはヤられる系ヒロインなんだー……ってわけで、隊長\nさん、おまんこ、どうぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……。隊長さんのおちんぽが、おまんこ……こすれてる……ンッ\n……ああ……熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。もう濡れちゃってるでしょ？　私のおまんこ……。んふぅ\n……隊長さんとしたくて、びしょびしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　あっ、ああ……入って……きてるぅ……っ！　んっ、んぅ……\nすっごい……おっきい……よぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……こんなに……おまんこを満たすおちんぽ、初めて……っ！　\nあ……ああ……入ってきただけで、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「そ、そうだよね、動くんだよね……？　んっ、あっ、ああっ！　隊長さんの\nおちんぽ……出たり……入ったり……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、ぶっといおちんぽが、おまんこ……かきわけながら……ああ\n……いっぱいこすれてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんつ、んくぅう……っ！　どうかな、私のおまんこ……？　んっ、締め付\nけとか……緩く、ない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふっ、キツキツ、なんだ……。ンッ、意外って、失礼な。んふぅっ！　ガ\nバガバじゃ正義の味方は務まらないでしょー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「それもそうだなって、ああんつ！　いきなり深くまでおちんぽ突っ込んでき\nて……ぇ……っ！　あんっ！　そこぉっ、んっくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「私の腰、しっかり掴んで……っ、アアッ！　ンッ！　んぁっ、パンパンって\n激しくぅ……っ！　んっ、んんん～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、隊長さんのおちんぽ、アンッ！　おまんこの奥に、何度も\n、ああっ、当たってる……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おちんぽ、おちんぽが……ンッ！　一番奥、にぃっ、届いちゃって……アア\nッ！　突き刺さっちゃってるのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、隊長さんのおちんぽに、私のおまんこ、めちゃくちゃにさ\nれちゃってる……！　んつ、んぁああっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「わ、私の腰も……ンッ、動いちゃってる……？　あぁんっ！　だって、気持\nちいいんだもん。隊長さんのおちんぽ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「たくましいおちんぽで、アンッ！　おまんこの中、かき回されちゃったら…\n…ンッ、腰がぁ、動いちゃうよ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おまんこの中もぉ、ンッ、うねうね～って、あんっ、いやらしく、動いちゃ\nってる……でしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽのこと、いやらしく包んでしごいちゃってる……ああっ\n、いっぱい、気持ちよくなって欲しいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぁあっ、あはぁっ、はぁあんっ！　いっぱい動いて、アンッ！　おまんこ\n、ごりごりして……ぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　そこっ、そこぉっ！　そこ……イイ……よぉ……っ！　ああ\nっ、奥っ、奥ぅ……っ！　んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おちんぽ子宮に届いてる……っ！　どちゅっ、どちゅって、先っぽが入り口\n叩いてるよ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、すっごい、これ……全身が痺れちゃうくらい気持ちいいの……っ！\n　はあっ、はぁっ、おちんぽ……おちんぽイイ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「えっ、ああっ、まって……っ！　そんな、全身からいやらしい匂いがしてき\nた、なんて……んぁっ！　言わないで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「嗅ぐのもだめぇっ！　ああっ、そんなに覆い被さって、匂いを嗅がないでよ\n……っ！　んっ、んぁあっ、恥ずかしい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「だめ……それだめ……っ！　密着して、おちんぽぐりぐり～って押しつけら\nれると、ますますいやらしい匂いでちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ますます発情して、汗とか、おまんこのお汁とか、溢れてとまらなくなっち\nゃうよ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　おまんこおかしくなっちゃう～っ！　ああっ、ああ……っ！\n　いやらしい汁がどんどんかきだされちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「じゅぼじゅぼ、じゅぼじゅぼって、アアッ！　おまんこかき混ぜられるいや\nらしい音、どんどん大きく響いちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぁあっ、こ、このまま……汁漏れスケベまんこに射精するって……？　ん\nっ、いいよ……隊長さん……射精して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「正義の味方の淫乱まんこに、隊長さんっ、思いっきり……びゅーって、精液\nびゅーって……っ！　ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おちんぽが、膨らんできたぁっ！　ビクビクって、脈打って、射精する準備\nしちゃってるのわかるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、きてきてきてぇっ！　精液ぃっ！　私のおまんこに、たっ\nくさん、びゅくびゅく注ぎ込んでぇえええぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、ああああぁぁぁっ！！　すごいのぉっ！　どぴゅどぴゅきてるっ！\n　精液きちゃってるぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、イクイク！　中出しされて、私ぃ……っ！　あっ、あああ……イッ\nちゃうぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅうううう～～～……っ！　ああ、ああ……っ！　イかされちゃった…\n…。隊長さんの中出し……超……イイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「重油みたいに重たい精液……。ふふ、こんなに気持ちよくしてもらえるなら\n私どんどんお仕事頑張っちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「でも……今日はもっとしよ？　うふふ、お姉ちゃんに負けないくらい、おま\nんこを精液で満タンにしてほしいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んんっ！？　あははっ、おまんこのなかでおちんぽが返事したよ？　じゃあ\n、このまま継続だね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「知ってのとおり、私ってスロースターターだから。ほらほら、今度は私から\n動いちゃうよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　さっきあんなに射精したのに、まだまだ、硬いまま……全然萎\nえてないね……さすが隊長さんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅっ、おまんこ締めて……ンッ！　腰を……ああんっ！　隊長さ\nん、もう復活しちゃった？　ンッ！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「また、ああっ、私のおまんこ、いっぱい突いて……っ！　あんっ、あんっ！\n　イッたあとだから、感度も……上がってる、みたいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ああっ、アアッ！　さっきから、隊長さんに主導権にぎられっ\nぱなしだよっ！　んつ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「でも、このおちんぽが気持ちいいから、ああっ、もう、全然抵抗できなくて\n、なすがままになっちゃう……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「アアッ！　ぶっといおちんぽが、しっかり、また、奥までみっちりおまんこ\nに詰め込まれてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「おまんこ全部、ずっぽずっぽされちゃって……っ！　ああっ、アツアツのお\nちんぽこすれる……気持ちいいの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ひゃはぁっ、そんなにっ！　ああっ、中出しされた精液が、カリ高ちんぽに\nかきだされちゃってるよぉっ！　んひゅぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、だめぇ……っ！　気持ちよすぎて、力、入らなくなってき\nちゃう……っ！　で、でも……もっとぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽ、もっともっと、感じたいの……っ！　こんなところで\n気を失ったら、もったいないもんね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長さんも、私のおまんこを感じて、どんどん気持ちよくなってね\n。あんっ、いっぱい……頑張るしぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅっ！　ほら、ほらぁ……っ！　いっぱい、ぎゅ～っておまんこ\n締めると、気持ちいいよね～？　んっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「どう？　隊長さん、また……きちゃいそう……？　ンッ、おちんぽに、精液\nのぼってきちゃってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、また、私に精液びゅ～ってしてくれる？　んふっ、いいよ、隊長さ\nんの好きなところに射精していいから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんの、アツアツ精液を感じられるなら、どこに出されたってかまわな\nいから……だからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ラストスパートピストン！　容赦なくずぼずぼ連続突きぃっ！\n　あっ、あっ、ああっ、あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「イクッ、イクイクイク……ッ！　隊長さん、隊長さん……っ！　あっ、あっ\n、おまんこもう……隊長さんでイク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「だから隊長さんもぉ……っ！　ああっ、私のおまんこで、たっくさん射精…\n…してぇえええぇぇぇっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「あああっ！　ああぁぁぁあああぁぁっ！！　きたきたぁああっ！　中出し精\n液いっぱいそそがれるのぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「出てる……出てる……熱いの……ぉ……っ！　ああっ、ああ……またおまん\nこの奥の奥にまで精液流れてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。すごいよぉ……隊長さんの重た～い精液……。二度目な\nのに、子宮にずっしりきてる……の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「はぁ……ンッ！　ああ……っ！　まだ、おまんこの中でおちんぽがビクビク\nしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ビクビクするたび、びゅびゅって精液でて……くる……ぅ……。はぁ……。\nおまんこが温かいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふぅ……。隊長さん……。まだまだ……イけそう……？　ふふ、もっとも\nっと中出しされたくなっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「クロスホワイトの妹なんだから、姉に負けず劣らずエッチなんだよー？　ほ\nらぁ、おまんこまだ欲しそうに動いちゃってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さん……ねえ、いいでしょ……？　隊長さんだって、まだまだこんなに\nおちんぽ勃起してるままなんだしさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「なに？　エッチのときの持久力を戦闘でも活かせって？　ああん、それはそ\nれ、これはこれなのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「というわけで、朝まで付き合ってもらうよー。うふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ！　あっ、ああ……ああ……っ！　精液……そんな……身体に\nかかるぅううっ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ドロドロにされちゃってる。私の身体、隊長さんの精液\nまみれにされちゃってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「うぅ……。こんなにべっとり……。匂いも、すっごく強い……。隊長さんの\nいやらしい匂い……。こんなの……最高すぎ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「こんなに、ンッ！　まだまだ射精して、ああっ、どんどん身体にかけて……\nっ！　あっ、ああ……んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「ああ……ぶっかけで……ぶっかけられて、イッちゃった……よぉ……。んふ\nぅ……隊長さん、すごいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「射精してベトベトのおちんぽが、また、お尻に当たってる……。ぬるぬるで\n……熱いの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「こんなに射精しちゃって……。んふっ、嬉しいな……。はぁ……でも……や\nっぱり中出しされたいかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「隊長さんも……まだまだイけるよね……？　私はイけるよ？　もっともっと\n、隊長さんとセックスしたいな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00007601_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「んふふっ、そうこなくっちゃ。それじゃあ今夜は朝までハメまくりだね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_076_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスブラック" ]},
		{"command":[ "SETTEXT", "「私のスーツが真っ白になるまで、いっぱい射精して欲しいな。隊長さん、一\n緒にがんばろうね！」", "NORMAL" ]},
