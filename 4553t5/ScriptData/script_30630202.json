		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ふふっ……隊長さんったら……もう、こんなに硬くなってる……んっ、私の\n中で、ビクビク震えてますよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「部屋に来るなり、いきなりハメられちゃってぇ……あふぅっ……ちょっとが\nっつきすぎじゃないですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「エロい格好って……水着で来いって言ったのは、隊長さんじゃないですかー\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「私は言われた通りにしただけで……ひぃうっ……あっ、あぁあ……き、期待\nしてたとかじゃなくてぇ……んあぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　奥、ゴリゴリしないでください……んっんんっ……は、は\nい、ゴメンなさい……ちょっと期待してましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「だってぇ、隊長さんに部屋に呼ばれるってことはぁ……こういうこと、です\nし……しかも水着ですし……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ、うぅんっ……スケベって、それは隊長さんじゃないですか……私なん\nて、普通くらいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひぃあっ！　あっ、あうっ……急に腰を動かさないでくださいよぉ……んっ\n、びっくりするじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「えっ？　音、ですか……？　それは……うぅ、聞こえます……はい、くちゅ\nくちゅ鳴ってます……けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「オ、オマン……コ……です……私のアソコが……もう、言わなくてもわかっ\nてますよね？　教えて欲しいって言われても、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「えー、ちゃんと言わないとダメですかぁ……はい、オマンコが濡れてて……\nイヤらしい音が、してます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぅっ、あぁ、恥ずかしい……隊長さん、意地悪です……んっ、べつに興奮\nなんて……ひぃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ですから、濡れてるのは最初からで……あんっ、あっあうっ……お、奥まで\n……挿入ってるぅ……んっあぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「こ、これくらい声、出ちゃいますよ……んっ、だって……あっあふっ、あぁ\nんっ……！　あぁっ、あっんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「奥をっ……押し上げるの、ダメですってばぁ……子宮が圧迫されて……ふぅ\nうっ……アソコが、痺れるぅ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ！　あっ、あふっ……隊長さんのオチンチンで、中がいっぱ\nいになってて……ああっ、はあぁンっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え、えぇ……？　わ、私も動くんですか？　無理ですよぉ……こうやって、\n突かれてるだけで……力が抜けちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「確かにこの体勢だと、隊長さんはあまり動けないでしょうけど……それでち\nょうどいいくらいで……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ゆっくりでいい？　うぅ、そう言われても……あぅっ、んはぁぁっ……もう\n十分すぎるほど気持ちいい……ですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあっ……はあっ……隊長さんは物足りないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「わかりました……やってみます……けど、本当にゆっくりしかできないです\nよ……んっ、ンンっ！　ふっ、うぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、くぅうっ……やっぱり足に力が入らなくて……はっ、うぅっ\n……あっ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひぃうっ……中が擦れて、んんっ……！　出っ張りが、引っかかってます…\n…隊長さんもわかりますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「これが気持ちいい？　そうなんですね……私もすごく感じるというか、刺激\nが強くて……少しずつしか動かせないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「は、はい……大丈夫、です……なんとか、動けますから……ふぅ、あふぅっ\n……でも、これ……くっ、ううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「すみません、あまり上手くできなくて……結構気持ちいい、ですか……？　\nそう言ってもらえて、よかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「隊長さんの肩を支えにして……倒れないようにバランスを取りながら……こ\nう、して……んっ、ンっあふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「どうですか？　さっきより、少しスムーズにできてると……思うんですけど\n……いい感じですか？　じゃあ、続けますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あうっ……はふっ！　あんっ……！　んっ、あぁあっ……お、大きい\n……んんぅっ……！　中が、広がっちゃいそう……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「そうですね、オチンチンの形になっちゃうかもです……でも、隊長さんのな\nら、いいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ！　あんっ！　い、今またビクっていって……ンっ、硬くなりました\nぁ……はっううっ……あんっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ダ、ダメです……隊長さんまで、動いたらぁ……！　お、奥っ……奥までき\nちゃうっ……は、はぁっ！　あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……腰、止まらない、ですか？　あっ、あんっ……え？　そ、そ\nろそろ出そう、ですか……？　んっ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「いいですよっ……中に出して、ください……！　隊長さんのお好きなように\n……あんっ！　あっあっ……はぁあ！　はひっ、ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひぃうっ、うぅっ！　ま、またオチンチンが膨らんで、ますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁぁあぁぁぁぁぁ～～～っ！　あっあひぃいぃぃぃっ！　ああっ……で、\n出てっ……出てますぅぅっ！　んひぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ドクドクって……奥に、精液が……！　た、たくさん……出てっ……んんぅ\nぅっ！　子宮がおぼれちゃうぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あはぁ……はぁはぁ……んっ、すごいです……いっぱい……奥に流れ\n込んできます……あぁ……ンっ、ああぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……は、はぁあっ……終わりました、か……？　んっ……中、溢れてま\nす……はふぅ……出しすぎですよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え？　ええっ？　このまま二回戦……って、続けるんですか？　ひゃうっ！\n　んっ、んはぁっ……！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ま、待ってください……嫌ってわけじゃないですけど、少し休んでから……\nはっうっ……んんっ、あひぃいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「射精したばかりなのに……オチンチン、大きいままで……硬いし、熱いし…\n…ど、どうなってるんですかぁ……あはぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁんっ……水着、ですか？　そんなに違う……です、かぁ……あぁ\nっ！　ひっ、ひうっ！　んっあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「激しいっ……ああっ！　ふ、深いっ……オマンコが奥までかき回されてぇ…\n…アソコがとろけちゃいそうですぅ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……どうして、こんなに胸がドキドキして……しまって……はぁ、は\nああっ……あぁんっ、あはぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「き、気持ちいい……私も気持ちいいですっ……！　隊長さんのオチンチンが\n……奥に当たるたびに……身体中が、痺れちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長さんは？　隊長さんも……感じて、ますか？　はぁはぁっ……私、\n全然動けてない……ですけど……んっあぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ！　またエッチな音がしてっ……ひぃうっ！　声も、抑えられ\nなくてぇ……はっ、はひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「こ、腰？　あぁっ……勝手に動いてぇ……んんっ！　ンはぁっ！　ひぃあっ\n、あぁぁっ！　あぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長さぁんっ……あ、あぁんっ……全身から、力が抜けちゃってぇ……\nひぃう、ひぃいぃぃぃっ！　ら、らめぇぇえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっあっ、あふぅっ！　あっ、ひぃいいっ！　オチンチン、すごいっ……オ\nマンコの中で暴れてますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁあっ……あんっ！　あぁんっ……！　き、気持ちいいっ、気持\nちいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　イ、イキそうっ……になってぇ……！　ひうっ、あっ、あ\nぁぁっ……一緒に、イキたいですっ！　隊長さぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はひっ！　ほ、欲しいっ……またあの熱い精液……いっぱい出して欲しいで\nすっ！　は、早くっ……出してっ！　出してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　オ、オチンチンっ……ゴリゴリ当たってるぅっ！　んっ、んん\nっ……イクっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長さん……もっ……出してっ！　私のオマンコで、イッてくださいぃ\nっ……！　ひっ、ひぃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「どこでもいいですぅ……あっ、あんっ！　隊長さんの好きなところに……ン\nっ、ンンっ！　しゃせ、射精してくださいぃぃっ！」", "NORMAL" ]},
