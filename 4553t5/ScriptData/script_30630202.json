		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あふぅうっ！　ひ、ひぐっ……！　ひっ、ちゃうっ……！　イッちゃ\nいそうなんですぅっ……！　んっひぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「は、はあっ……激しいっ！　あんっ、あぁんっ！　た、たいちょぉ……さぁ\nぁんっ！　イッて、イッてぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ……はっはひっ！　ひっ、うっ……い、いくっ……！　イクイ\nクイクイクイクぅぅぅぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁぁっ！　あっあひっ……ひぃいぃぃぃ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ま、また中にぃっ……出てるっ……！　んっ、んんっ！　はっ、うっ……と\n、止まらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっひっ……！　さっきよりも、量が……多いっ……ああっ……！\n　お、奥で、ドクドク出てぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁー、はっ、はひっ……はぁあっ、ああっ……隊長さんったら……どれだ\nけ溜まってたんですかぁ……こんなに出してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「妊娠しちゃったら、どうするつもりなんですか……？　私は……隊長さんの\n赤ちゃんなら欲しいかも、ですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「本気？　さあ、どうでしょうねー……それより満足していただけましたか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「……それはばっちりですか？　ふぅ……よかったぁ……お役に立てて、本当\nによかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「……水着がよかった？　すごく興奮してましたもんね……喜んでもらえて、\n嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「またですか？　もう今ヤッたばかりなのに……もう次の話ですかー？　ふふ\nっ……本当にエッチですね、隊長さんは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「嫌だなんて言ってませんよー。隊長さんのためなら、水着でもなんでも着ま\nすよ。エヘヘ……私も楽しみですー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ひっあっ！　あぁぁぁっ……んっ、あぁぁぁぁぁぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「抜いちゃ……たら……！　かかって……！　んっ、んはぁぁっ！　あんっ…\n…あ、熱いっ……くひっ、ひぃあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「すごい勢いっ……あぁっ……身体にかかっちゃう……んぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はぁ……はぁ、はーっ、はーっ……んっ、たくさん出てるぅ……に、\n匂いも……キツくて……頭がクラクラしてきますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「さっきも射精したのに……まだ出てますよぉ……んっあぁ……元気よすぎで\nすぅ……はぁ～～……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00006302_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「水着がよかったから……ですか？　その水着も隊長さんの精液でベトベトに\nなっちゃいましたよぉー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それが興奮するんですか？　もうっ、本当に変態さんなんですから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ええっ、またして欲しいんですかー？　水着で……？　そんなに気に入った\nんですか……これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「そんなにお願いされたら、断れないですよぉ……わかりました。また水着で\n、しちゃいましょうー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「私も期待してる？　エヘヘ、どうでしょうかね～。内緒ですよー」", "NORMAL" ]},
