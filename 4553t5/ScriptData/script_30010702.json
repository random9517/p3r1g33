		{"command":[ "PLAYBGM", "BGM_015" ]},		{"command":[ "WAITMOVE" ]},		{"command":[ "PLAYVOICE", "001_0704101" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁぁ、すごい……あなたのオチンポ、もうこんなになってる……固くて、\n熱くて……はぁぁっ、私の水着を見て、こんなにしてしまったの……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},		{"command":[ "DISPNAME", "TRUE" ]},		{"command":[ "DISPTEXT", "TRUE" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704102" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「もう、ヘンタイなんだから……でも、嬉しい……。いいわよ、もっと見て…\n…恥ずかしいけど……あなたになら、もっと見られたい……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704103" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あんっ、オチンポがビクンってして……あぁ、すごい、まだ大っきくなるの\n……？　いいわよ、もっと見て……私の水着姿でもっと興奮して……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704104" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「私のココも、ほら……んふぅぅっ……濡れてるの、わかる……？　あなたに\n見られるとね、私も、興奮しちゃうの……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704105" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「Ｈな目で、私の水着姿を……おっぱいやオマンコを見られると思うと……ん\nふぅぅ、すごくイヤらしい気持ちになってきちゃう……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704106" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「地球の女の子たちみたいに、んんっ、水着姿でＨなことしたくなっちゃう…\n…男の人を誘惑して、イケないこと、したくなっちゃうの……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704107" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「だから、ね、いいでしょ……？　この間の、続き……この格好で、あなたと\nＨなこと……ひと夏のイヤらしい思い出、作りたいの……いいでしょう？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704108" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁっ、オマンコがジンジンして、変になっちゃいそう……！　あなたのオ\nチンポを、早くナカに挿れて……セックス、しちゃいたいの……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704109" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ねぇ、シちゃってもいいでしょう……？　ほら、オマンコもこんなになって\nる……あぁんっ、カチカチのオチンポと、ヌルヌル擦れて……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704110" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっ、あっ、前後にぬりゅぬりゅっ、気持ちいいっ……あんっ、そこっ、入\nり口……！　先っぽがあたって……あ、あ、入って、きちゃう……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704111" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あふううぅぅんっ……！　あっ、あっ、あぁっ……オチンポ、入ってきちゃ\nった……オマンコのナカに、ぬりゅりゅうってぇ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704112" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁんっ、カチカチの先っぽが、トロトロのオマンコをかき分けて、あうぅ\nぅんっ、ナカに、入ってくるぅ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704113" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっ、あぁっ、あっ……んふぁあっ！　今、奥に、コツンって……！　んふ\nぅぅっ、オチンポの先っぽが、当たってるぅ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704114" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はぁううぅぅっ……そこ、ダメぇ……あぁんっ！　赤ちゃんのお部屋のとこ\n、ぐりぐりぃっ……！　んふぅぅっ、オマンコしびれちゃうぅっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704115" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「お腹の奥が、ジンジンしてぇ……はぅぅっ、力が、ぬけちゃうぅっ……足が\n、ガクガクして……力が入らなくなっちゃうぅっ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704116" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……あぅぅっ、オチンポ、挿れただけですごい……固くて、太く\nてぇ、あふぅぅっ、オマンコのナカ、みっちりハマっちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704117" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あんっ、オチンポがナカで、びくん、びくんって……やぁんっ、動いて欲し\nいの……？　わかったわ、じゃあ、抜いていくわね……んふぅぅっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704118" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっ、あっ、あぁんっ！　ナニ、これぇ……！？　抜けてくときに、でっぱ\nりのところが、オマンコのお肉を、ぷりゅぷりゅって、ひっかくぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704119" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁぁっ、あっ、あっ……入ってくときも、あふぅぅっ、パンパンにふくら\nんだ先っぽが、オマンコのナカをむりゅむりゅって、かき分けてくぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704120" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「んふぅううっ……！　オチンポが、ぜんぶ入ると、奥が、どちゅってなって\nぇ……はあぅぅぅっ、腰が、しびれちゃうぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704121" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁぁっ、ダメよぉ……このオチンポ、凶悪すぎるぅ……あふぅぅっ！　す\nごく意地悪な形をしてて、あぁんっ、オマンコをイジメるのぉっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704122" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁっ、あんっ、ダメぇ、止まらないぃっ……！　オチンポすごいっ、気持\nちよすぎるぅっ！　こんなの、女の子はみんな、夢中になっちゃうわよぉ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704123" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ここっ、擦るとぉっ……あはぁんっ！　すごいぃっ、セックス、気持ちいい\nのッ！　こんなの、ハマっちゃうっ、ダメになっちゃうっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704124" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はぁっ、はぁっ、あなたは、どう……？　あぁんっ、私のオマンコ、ちゃん\nと気持ちいい……？　私とのセックス、楽しい……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704125" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「え？　いい眺めって、なにを……きゃああっ！　ダメ、見ないでぇっ！　オ\nマンコにオチンポが刺さってるところ、そんなにじっくり見ちゃダメぇっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704126" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「やあぁんっ！　そんな、エッチな言い方しないでぇっ！　やんっ、あぁんっ\n！　詳しく言わないでいいからぁっ！　オマンコの解説しないでよぉっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704127" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あんっ、あんっ、ちがうのっ！　腰が勝手に動いちゃうのっ！　こうしない\nと、力が入らないからっ、だから全部、丸見えになっちゃうのぉ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704128" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁっ、あっ、あっ、ヤダっ、なんかキちゃうっ、恥ずかしくてっ、オマン\nコおかしくなっちゃうっ、変なのキちゃうっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704129" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「お願いっ、あなたも、一緒にっ、あんっ、あんっ、オチンポ、イってぇ！　\nオマンコにどぷどぷっ、精液、出ししてぇ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704130" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっあっあっ、もうダメぇっ！　エッチに腰を振って、オマンコにズポズポ\nっ、見られながら、イっちゃうっ、ダメになっちゃううう～～っ！！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704131" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あはぁああああんっ！　あっ、あっ、あぁっ！　オマンコの奥に、いっぱい\n……！　あぁんっ！　精液、びゅーびゅー出てるぅっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704132" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あぁぁっ！　ザーメン熱くて、ナカがジンジンするぅっ！　あぁんっ、オマ\nンコ焼けちゃうっ！　精子でヤケドしちゃううっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704133" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっ、あっ、奥にもっ、びゅく、びゅくってぇ……あぁんっ！　ドロドロし\nたの、当たってるっ！　子宮のとこ、気持ちいいのぉっ……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704134" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっあっあっ、ダメ、またキちゃうっ……！　オマンコにナカ出しされて、\nあぁんっ、種付けされるとこ見られながら、またイっちゃううう～～っ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_07" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704135" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あ、あ、あ……せーえき、すごい……まだ、出てる……ナカで、どぷっ、ど\nぷって……オマンコ、精子でいっぱいになっちゃう……あぁっ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704136" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あはぁぁ……オマンコのナカ、あったかくて、ポカポカするぅ……はあぅぅ\nっ……ナカ出し、気持ちいい……オチンポも、すごいぃ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704137" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はふぅぅぅ……まさか、水着でするセックスがこんなにも気持ちいいものだ\nったなんて……地球の女の子たちがハマってしまうわけだわ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704138" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あなたは、どうだったのかしら？　ちゃんと気持ちよかった？　その……な\nんだか私ばっかり盛り上がってたような気がして……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_07" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704139" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「だ、だから、あんまりアソコばっかり見ないでってば！　うぅぅっ、そうい\nうエッチな言い方も、やめなさいよぉ……はぅぅっ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704140" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「だって、あなたに見られながら、そういうこと言われると、その……身体が\nゾクゾクして、変になっちゃうんだもの……しかたないじゃない……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704201" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あんっ！　オチンポがオマンコのナカで、ピクンって跳ねて……あぁっ、す\nごい、まだこんなにカチカチなの……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704202" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……たしか、オチンポが満足するまで続けるのよね……？　あな\nたがどうしてもシたいと言うのなら、もう一回シてあげてもいいけど？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704203" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あ、あ、ダメぇ、抜かないでぇ！　わかったわ、ちゃんと正直に言うからぁ\n！　うぅぅ、意地悪……！　そうやってまた、私を辱めるのね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_08" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704204" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「うぅ、あの、ね……奥がまだジンジンして、切ないの……精液をナカに出さ\nれされたら、よけいに疼いちゃって……もう、おかしくなりそうなの……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_07" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704205" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「だから、お願い……。もっと、セックス……シよ？　あなたとのひと夏の思\nい出、もっといっぱい作りたいの……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704206" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「ちゃんとオチンポも、気持ちよくするから……いっぱい腰を振って、オマン\nコを締め付けながら、オチンポをたくさんシゴくから……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704207" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「お願い、もっとセックスしたいの……激しくぬぽぬぽ、オマンコしたいの…\n…頭がおかしくなっちゃうくらい、イヤらしいこといっぱいシたいの……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704208" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「シてもいいの！？　え、その代わりの条件って……？　はうぅっ、またそう\nいうことを……ホントにヘンタイなんだから……！　でも、いいわ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_08" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704209" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「オマンコにオチンポが出入りするところをイヤらしく見せ付けながら、さっ\nきよりも激しく腰を振って、エ、エッチな実況をたくさんすればいいのね？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704210" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ、い、いいわよ、シてあげる……だから、もう動いていいわよね\n……？　オマンコ、シていいでしょ？　セックス、シちゃうからね……！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704211" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あふぅぅぅんっ！　あぁっ、あっ、あっ、これっ、これなのぉっ！　オチン\nポすごいっ！　セックスすごいのっ！　オマンコっ、気持ちいいぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000107_02_09" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704212" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「あっ、あっ、ナニコレぇ、しゅごいっ！　イったばかりのナカ出しオマンコ\nっ！　ビンカンなのっ！　さっきよりもすっごく気持ちいいのぉっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704213" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「オチンポもしゅごいっ！　さっきよりもごつごつしてるのぉっ！　んひぃぃ\nっ！　カチカチのカリ首が、ナカをゴリュゴリュ、引っ掻いてるっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0704214" ]},		{"command":[ "SETNAME", "ルルーナ" ]},		{"command":[ "SETTEXT", "「やぁんっ、動きが激しすぎて、精液じゅぷじゅぷっ、泡立っちゃってるっ、\nオマンコのエッチなお汁と混ざり合って、すごくエッチな音してるっ！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
