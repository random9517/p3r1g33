		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ヒルダお嬢様っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023880008" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「大丈夫かっ、スクルドっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023880007" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「は……はい……！　何とかギリギリで避けられましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023880004" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「あ、あんなのに当たったらひとたまりもないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023880002" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん、流石にまだ少し勝手が分からぬな。もう少し力の出し方を調整する必\n要がありそうじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023880015" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「エファナティカ様～、そこから吸えるともっと力が出ますよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023880002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なるほど、分かった。あちらじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023880016" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「マズいぞ！　これ以上、ヤツを強くするといよいよ手に負えん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023880003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今のうちに食い止めておかないと、かなり厄介なことになるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023880004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「私達も協力します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023880009" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、ちょうどいい腕鳴らしじゃな。構わんぞ、纏めてかかってくるがい\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023880017" ]},
		{"command":[ "SETCHARA", "0", "char_00000318_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余のヴァルキリーとしての力……たっぷりと見せつけてやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023880018" ]},
