		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……隊長！！　そんなところにいては駄目だ！　早くこちらに来てくれ！　\n……そう、声を出さずに……。足音をたてないでくれ、今だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0084" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふぅ。この岩場ならば、奴らに見つかる心配はないな。……ん？　何がどう\nしたかって？　決まっているだろう、怪しい輩から隠れたのさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、これは長丁場になるかもしれないな……。隊長、どうかしたか\nい？　この体勢が卑猥すぎる？　まるで誘っているみたいだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00007903_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「フッ……馬鹿なことを言わないでもらいたいね。この鳳雛、天に誓ってその\nような……。うん……たぶん……違う。おそらく……うんうんうん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふ、二人きりになるための虚言！？　さぁて、それはどうかな……。なんな\nら君の目で確かめてみるといい。僕の言葉が真実かどうか……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「罠にかかったのは君か僕か……。っは、ぁ……♪　おいおい、いきなり胸を\n揉むなんて大胆だな。え？　僕も股間を押し付けてきている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「し、らないよ……。そんなこ、と……。ぁっ……！　僕は無実さ、別に君を\n煽って襲ってもらおうとなんてし、ていないよ？　むふ、フフフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ……♪　こ、こらえしょうがないのは君のほうだよね。少しくっついた\nだけで、コレだ……。いつみても立派なモノで感心、するよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ね、ねえ……？　どうだろう。せっかく見事に勃起したんだ\n。少しだけ……挿入してみないか？　ほんのちょっとだけ……はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほ、ほら。怪しい輩がいなくなるまで動けないのだから。その間に……僕と\n……。夏の思い出なんかを作ったり……。なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……んんっ♪　あぁ、どうしてだい！？　なぜ焦らす……！　ギンギンに勃\n起しているのに……。ううぅ、ぼ、僕の身体を撫で回したりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「や、やめて、くれ……。とっくに我慢の限界なんだ。君としたくて、なのに\n君は僕を放っておくから……って、あっ！　い、言ってしまった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あ、ああ。そうさ……笑うといい。僕は浜辺の美女たちに嫉妬して、君、を\n独占したくて……罠を張った。君は捕らわれの小鳥……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「やっ、ぁ、あ……！　尻にズリズリこすりつけないでくれっ！　違うっ、も\nう少し下……！　あっ、濡れているからわかるだろう、前の方に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……くぅううっ……！　どうしてノってこないんだぁあ……！　あっ！　感\n度だけを高められて、放置……。触るだけ触って入れないなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「お願いだ、隊長……。あざむいたことは悪かったよっ、し、したいんだ……\n。隊長とシたくて、シたくてどうにかなってしまいそうなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だからっ……ぼ、僕の……ポンコツおまんこ、に……。君のことを考えるだ\nけで愛液が溢れ出す愚かな肉壺に……お、お仕置き……してほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「お仕置きしてください！　な、なぁ、いいだろう……！　欲しい、欲しい…\n…！　君のその逞しいものをここに……。あっ、そこ！　そこにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっああああああああああッ♪　あああああああっ♪　そうっ、そう、そ…\n…こだぁっ、奥っ、奥まで突いてくれ、あああっ、嬉しい、嬉しいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「隊長っ……あっ♪　たい、ちょうぅ……！　あはっ……♪　やっぱり君はス\nゴいや……あっ♪　するたびに太くなって、いる♪　たまらないよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ああ、好きなだけ堪能してくれ……。は、ぅ……信じられないくらい濡れて\nいるだろ……？　ずっと待っていたからさ、あっ、この時を……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ、あぁ、ああっ……！　すまない、僕からも動かすよ……、っ\nぁあっ……！　あ、ぅっ♪　すごい、すごい、気持ちがいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕の腹の中を……ぉおおっ♪　太い肉棒が出たり入ったりして……んあぁあ\nふっ、あぁ……！　摩擦が熱をはらんで……あっ、止まらない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「隊長っ、隊長は名器なのかなっ……！　あっ♪　それとも僕がだらしなくて\n、はしたなくて、いやらしいんだろう、か♪　両方か♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁぁ～～～……♪　ぐりぐり中で動かすだけで全身に快感が伝わってくる\n……♪　禁断の交配だ、……あっ、皆が近くにいるかもしれないのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そう思えば思うほど腰を振ってしまう♪　ッあっ、うっあぁっ、不思議な魔\n力で操られているみたい、に……ああっ、性欲に没頭して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、君も気持ちいいかい……？　っあはっ……♪　僕はすごくイ\nイ……あっ！　女の部分を、粘膜をグリュグリュこすられて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「膣襞という襞を、膣壁という膣壁を一度に貫かれるこの悦びィっ……何者に\nも代えがたい♪　あっ、んふぅっ、ふぅっ、まともでいられ、ない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おかしいだろうっ？　いつも澄まして探偵面をしている僕が……ああっ、一\n本の男根に夢中になって尻を揺らし、てぇ♪　快感に身悶える姿はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「でも、どうすることもできないんだ、……あっ♪　君のコレはっ、き、禁断\nの果実のように蠱惑的すぎるっ、一度味わえばもう逃れられ……な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ッン！？　ンンンンンッ！？　ああっ！？　あっ、ぁっ、あっ！？　す、す\nまない……！　興奮すると口が回るタイプなん、だっ、あああっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んふぁあっ！　偉そうなことを言っていないと……！　あ～～～っ♪　男根\nに頭が支配されて……ああああっ♪　困るぅ、困るよ、あっ、うううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「肉棒でニュブニュブ陰部をかきまわされて、拡張されて♪　ボキャブラリー\nのない単純な喘ぎしか出せなくな……。ふ♪　んぁあああああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……何！？　射精したくなってきた！？　ぁ……やめたまえっ、そんなこと\nを言われたら、僕は……ああっ！　感じるっ、感じてしまう、ンン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それにダメだ！　まだ始まったばかりなのに……。って、うぁっ！　ああっ\n、ああっ！　こらぁっ、巧みに腰を使うなぁあっ、小刻みに揺するなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まだ出すなぁっ、もっとシたいぃ……！　あっ！　待て、待て、待って……\nんああああっ！　照準を定めるな、……あっ、やめろおぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ！？　ひっ……ひぃいっ♪　んああああああっ！　うぁ♪　うぁああっ\n♪　容赦なく出てる、出ているよっ……ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「一番奥……狭い行き止まりに君のっ、君の分身が次々に放たれて……♪　あ\nあぁっ……君色に染められていく、君の物になるぅ♪　ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あったかい……！　っぅ……身体が芯から満たされてい、く……。でも、で\nも……ああ……まだ、まだ僕は君としていたいんだよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なあっ、お願いだぁ……。僕にもう一度チャンスを……。ん？　なんだって\n？　あっ……！　射精したのに全然柔らかくなっていない、衰えていない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「っあはははっ、君はスゴいな……！　いつも僕の想像を超える……！　ああ\nっ、もちろんだ。このまま抜かずに……あっ、継続してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「もっともっと僕を屈服させて、喘がせて……悦ばせてく、れ♪　もちろんこ\nちらも……あっ♪　こうやって、動いて協力する……よっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「っぁ……僕の中でヌルヌルのドロドロが動いてる……。っんふぅうう……♪\n　抜かずの二発目っていうのは景気がいいね、もう精液でいっぱいなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ♪　そこを更に突かれるなんて……あっ♪　背徳的で興奮してしまうよ\n、……膣内もキュンキュン疼いて、うねってしま……ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あふっ！　あっ、あっ、あっ♪　君ぃ、その動き……いいよっ♪　僕の好き\nなタイプだ……ああっ、精液を膣内になすりつけるように、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅ前後に動い、て♪　ドスドスと最奥をえぐるぅっ……♪　はぁ\nああっ♪　目の前に火花が散るよ、あぁっ、それ、もっと欲しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぅああっ♪　あうっ、あぅううっ、うう……！　締めつけがいつもより強\nい？　そうかもしれないねっ……自分でも制御できないんだ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「勝手に肉壺が君を求めて蠢いてしまうんだよぉ……♪　あっ♪　あっ、うぅ\nーーーー♪　あぁっ……ここ？　ここがいいのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んふっ……んん♪　ピストンしている時に、急に締めつけられると感じるだ\nろう？　ぁっ……ギュッ、ギュッて……わかるよ。あっ、こうだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あは……♪　そりゃあ僕だって君の悦びそうな動きくらい習得……し、て…\n…いく気だけどぉおっ、おっ♪　締めている時にねじこまれると♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「こっちも気持ち良くなりすぎてしまうんだよぉお……！　あっ♪　あっ♪　\n君のモノに僕のが絡みついて、んふぁああっ！　密着、密着、して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そこを一度に突き上げられてぇ……っ♪　んふぉおおおっ♪　あぁっ！　意\n識がトぶトぶっ！　君はテクニシャンすぎるよぉ……！　あっうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ああっ、あぁ、あああっ、降参だぁ……降参んん♪　はひっ、ひぃっ、いい\nっ……♪　隊長……隊長のオチンポすごくいい、硬い、気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕は何度もイかされてしまうから……、あっ♪　絶頂して締まるオマンコで\n君も、君もよくなってくれたまえぇ♪　あぁイクぅっ、すぐイく、イくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ♪　んふぅうううううう～～～～っ♪　ふぅうう～♪　あふっ♪　……\nうん、うん、そうだろうっ、僕がイくとアソコがうねって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君の物に媚びて波打って……あっ♪　精子を、精液を欲しがるんだ♪　あっ\n、ふぁっ、し、子宮ですら……意思をもっておりてくるぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はひぃっ♪　ああ、そこ、そこ、子宮口に思いっきり肉棒を叩きつけて……\nぴったり合わせて吐精してくれっ、全部もらう、いただくよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君の精液は僕のオマンコが飲み干すからぁあ♪　こぼさないように、はふぅ\nっ♪　奥の奥の奥で射精、射精して、さっきみたいに大量、に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！　はぁああっ♪　イクの止まらない……！　イキっぱなしに\n、なって、僕……僕はもう、あっ♪　君のことしか考えられない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「受け入れる準備は出来てるよっ……！　来て、来てくれぇっ……！　でない\nと僕の渇きは満たされないっ、精液注入してほしいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んふぁああああっ♪　キタっ、きた、来たぁ、来たぁあああ……！　あああ\nあっ、動かないでくれっ、そのままっ、そのまま流し込んで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ♪　ビュルッ、ビュルッてかかってる、僕のオマンコがまた君\nの、君の白濁液でいっぱいになって……幸せだよぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ああっ♪　いいよ、いいよ全部……全部ちょうだい……。大丈夫、まだ入る\n、よ……あああああっ♪　熱い……気持ちいい……素晴らしいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はははっ、中でビクビクしているね……っ♪　はぁあっ……♪　最高の気分\nだ……あっ♪　君が僕で射精してくれた、こんなに、こんなにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ！　あっぁっ、とめどなく注がれる熱い体液……はぁああっ♪　君のエ\nナジーが僕に流れ込んでくる、……ああああっ、いいよ、いいよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……ッんぅううう♪　……はぁああ、はぁああっ♪　あ～～～♪　二度も中\nに出されたら、さすがに下腹が苦しくなってくるな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、これだけの量を連続して射出できるだなんて、本当に天才さ。\nいつも満足させてくれてありがとう。我が相棒……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ん？　なんだい。受精したら？　決まっているだろう、何人だって産んであ\nげるよ。そして、家族で探偵団を作ろうじゃないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕が所長で、子どもが団員で……君は……ええと、そうだなぁ。こ、こうし\nて団員を増やす係というのはどうだ？　何年でも付き合うぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「フフ、僕とエッチばかりしていればいいのだから楽しい仕事だろう♪　決ま\nり決まり♪　君は僕の、永遠のパートナーだからね、期待しているよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「き、君ぃ～～～～！！　中に出して欲しいと言ったのにっ……！　ああっ、\nも、もったいない……もったいないぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ああああっ……♪　良質な、素晴らしい精液が身体に……！　あっ♪　ああ\nあっ、びちゃびちゃと……！　あふ、多い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「確かに僕はかけられるのも好きだ、それは否定しないっ……！　でも、でも\n……ああっ、オマンコが疼きっぱなしで辛いよ……！　んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君はエキセントリックなことをするねぇ……。あっ、そういう突飛なところ\n、嫌いじゃないが……。あっ♪　出すなら膣内に……んんぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だ、出し過ぎじゃないか！？　なんって量だ……。くぅう……！　これが中\nに出ていたら、受精確実だったというのに～っ！　なぜ外に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「で、でも……こうして肌に精液を感じるのも悪くはないな……。ネットリと\n皮膚にまとわりつくこの熱、粘り気、そして……この色だ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「この濃い白色は……膣内射精では目にできないから……。い、いや！　不服\nは不服だぞ！　でも……君のすることだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「甘い僕は結局受け入れるしかないってことさ。……フフ……。磯臭くって、\nイカ臭い……ある意味海を体現しているな。この白濁液は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304408" ]},
		{"command":[ "SETIMAGE", "0", "still_00007903_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「水着を着ていたからか、服の心配もせずに思いっきり受け止められて良かっ\nたよ。この、プリップリでゼリーみたいな最高の白濁液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いつでもどこでも浴びてあげるから、覚えていてくれよ♪　僕と君は……公\n私ともに、ベストパートナー……なんだからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}