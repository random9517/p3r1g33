	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「敵の襲来を見事退けた……。退けたのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107070001" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「寒いいいいいいい！！　寒すぎるっ！　下僕！　火！　火はないのかぁっ！\n　下僕ぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107070002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って言われましてもねえ……燃やせそうなものは見当たらないし、だいいち\nたき火をしてもこの吹雪の中じゃ、すぐに消えてしまうような」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「使えないヤツめ！　もういいっ！　アナザー！　もうお前でいい！　こっち\nにこい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107070003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0133" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ……！　ぁっ……！　あぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "1", "char_00000109_01", "3", "CENTER", "200" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぽいん！　ぷるん、ぷるん……！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザーのロケットおっぱいに、ルナテミスのよく似たおっぱいがすり寄せら\nれる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何をする……ああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107070002" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おかしな声を出すな！　こうやって、身を寄せ合っていた方が温かいだろう\n！？　皆もこちらに来いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うん！　わかった、まりあ姉ちゃん、行こ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうね、みんなで温め合いましょう！　さあ、こちらへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おう！　えへへへ、オボロはちっこいから抱っこするのにちょうどいいや！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カイロ代わりにされるのは心外ですが、緊急時なので仕方ないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああー……これが人のぬくもりか……。あたたかい……スリスリスリ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107070005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「う、うう……。でも確かに……随分寒さがマシになったような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107070003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「これで、しばらくはしのげそうだねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか！　人と人とで温め合えばいいってことだな！　俺もその間に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「って、なに触ってんだヘンタイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げふっ！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやらしい手で触るな！　このボケナスビ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐええっ！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鋭く振り払われて、暖かくて柔らかそうな肉の集まりから弾き出され……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ、ああああ、カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はいはい、カグヤちゃんはこっちよ～？　はぁああ～思ったとおり、柔らか\nさもあったかさもいい感じぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、ごめんなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107070002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
