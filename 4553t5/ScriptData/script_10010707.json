		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさい！　貴様などを入れたら、大惨事になるのは目に見えている！　寒\nければどこかで、野猿とでも……んん？」", "NORMAL" ]},
