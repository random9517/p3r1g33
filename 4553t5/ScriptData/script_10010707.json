		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おほめにあずかり光栄ですな。さあ、どうぞご遠慮なくワタクシで暖をお取\nりください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010107070001" ]},
