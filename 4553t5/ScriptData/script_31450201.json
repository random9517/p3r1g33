{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ……どうした……き、緊張しているのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「その、何だ……何も遠慮することはないのだ。お主は……農作業を手伝って\nくれた……この忙しい時期に、それがどれほど助かったことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「だから、これは正当な代価であって、拙者の感謝の気持ちでもある。思う存\n分、その……お、男の……モノを……だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「え……い、言い方？　う、うぬ……つまり、だからアレだ……おっ、オチン\nチンだ！　は、恥ずかしがってなどないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「大体……目の前にここまでデカくさせたモノを突きつけておいて、今更それ\nを言わせることに何の意味があるのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「だ、だから恥ずかしがってないっ！　か、顔っ！？　それはいかんっ、拙者\nの素顔は将来を添い遂げる伴侶以外に晒すことはないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「それとも、お主は、それを今この場で誓うと？　だとすれば、拙者としても\nこれを外すのは吝かでは……やっぱりいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ふ、ふん……ヘタレめ。とにかく、今果たすべきは……その……パ、パイズ\nリ奉仕というものだ。早く……オチンチンを挟むがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　そうだ……ふん……何だかんだ言いながら、しっかり身体は\n反応しているではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「待っていろ、今、拙者が気持ちよくさせて……ん、何だ……？　まだ注文が\nあるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「なっ……自分で、おっぱいを……こね回してみたい……だと？　む、むぅぅ\n……調子に乗って……いや、だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「そうだな……お主は、それだけの働きをした。分かった……好きなように揉\nみしだいていい……だ、だが痛いのはダメだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ……ふっ……そうだ……ちゃんと……力加減を上手くしてく\nれれば……悪くない……んふっ、あぁ……は……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「しっかり……オチンチンを押し付けて……よく、揉み込んでくれ……はんっ\n、あぁっ……そうだ……んっ、悪くないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「こうして……挟むと、太さがよく分かるな……んんっ……この位のサイズが\n……男の平均か……それより小さい位か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ふふっ、冗談だ。そもそも、他の男のサイズなぞ知らぬ。拙者が知っている\n……知るべきサイズはコレしかないのだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ、だから……んんっ、気にせずに……おっぱいを……うんっ、使うがい\nいっ……んんっ、はっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「せ、拙者のサイズ……？　そんなものは……見れば大体分かるだろう……そ\nの、９０のＧカップだ……ふ、普通だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「大きい……？　いや、だが……あそこには並外れた奴らがゴロゴロしている\nからな……大きさにアイデンティティーは求めないようにしているのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ……ふっ！　あっ……か、感度か……それならば、他の者に……引け\nを取るつもりはないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「つまり……あっ、そ、そうだ……んっ、感じやすい……ということで……ば\n、バカモノっ……何を言わせるつもりなのだっ、あっ、んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ……仕方、ないだろう……そこまで自覚はなかったが、お主\nに……色々と開発されたお陰で……意識してしまったのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「今のように……あっ、おっぱいを……んんっ、ぐにゅっと掴まれて……あっ\n、強く揉みしだかれて……痛みより、心地よさが勝って来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふっ、オチンチンの……脈動も、しっかり感じて……はぁっ、それは……\n肌の感覚が鋭敏だからこそ……分かることだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「どくどく……脈打って……浮き上がった血管が目の前で動いてるのを見ると\n……拙者も……んっ、興奮を隠せぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁ……だから、もっと押し付けてくれ……今、このおっぱいはお主の所有\n物なのだ……存分にこねくり回して……あっ、使ってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ひぅっ！　あっ……ち、乳首は……そのっ、特に……弱い……。だから、そ\nの、ある程度……手加減をだな……あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁぁっ、くりくりっ……あっ、つままれてるっ、あっ、弱いって\n……言ってるのにぃっ、は、ひぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……そのままっ、おっぱいもっ……ぎゅってされるのっ……く\nぅんっ！　あっ、いっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁっ、そうだ……このオチンチンのにおいと……熱とぉ……こ\nれで拙者は虜にされたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……先端が熱い……乳首、どんどん感じて来るぅ……あぁっ、オチン\nチンに直接当たるのぉっ、だ、ダメだぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ、はっ、あぁっ……感じる……あっ、おっぱいがピリピリしてぇっ…\n…気持ちよくなってくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あふぁっ、お主は……どうなのだっ？　ここまでしておいてっ……何でもな\nいなんてことはないだろうなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ、もう……出そうっ？　そ、そうかっ、そうだなっ……あぁっ、いいぞ\n……好きな時に出していいっ、おっぱいに……中出しだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あぁっ、激しくなって来たっ……はんっ、あっ、ふっ、本気の…\n…扱き上げっ……あぁっ、出して……くれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんーっ！　あぁっ……出たっ……射精……出たっ！　ドプッて\n……おっぱいに……出て……るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふぅ……熱いドロドロが……あぁっ、おっぱいに広がっていく……んくぅ\nぅ……ねとねとだ……は、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あぁ……ぬめってる……元気な子種の力……おっぱいに感\nじるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はふ……んんっ……あぁ……どうやら落ち着いたようだな……全く、呆れた\n量を出す……本当に遠慮なしだな、お主は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「だが、それだけ拙者のおっぱいの具合が良かったということだからな。うむ\n、いい働きが出来たこと……素直に喜んでおくとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、ところで……全く手を離さないで、揉み続けているのは……\n果たしてどういう了見によるものだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「もっとこの感触を味わっていたいだと……ま、全く……お主というやつは臆\n面もなく、そのようなことをぬけぬけと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「それだけ気持ちよかったから……ふん、相変わらず口だけは達者だな。そう\nやって拙者をまんまと言いくるめて……本気？　ああ、分かった分かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「むぅ……正直、これでは奉仕というよりも、完全におなほーるにされている\n気分だが……いや、まぁ、それも承知の上でのことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「いいだろう、続けるがいい。その代わり、また手がいる時には、しっかりと\n働いて貰うぞ？　んぁっ、はっ、ひぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿者っ……あっ、交渉成立はいいがっ、そんな無遠慮にっ……あっ、\n揉みしだくなぁっ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「射精されてっ……かなり、感覚が……鋭敏になっているのにっ、ひゃいんっ\n！　ちっ、乳首ぃっ、あっ、あんっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あぁっ……どうなってるのだ……確かに気持ちいいのは認めるが\n……あぁっ、こんなに……昂っているのは、わ、分からないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「お主の……精液なのか……？　これが悪さをして……はぁぁ、身体を痺れさ\nせて……何か毒でも仕込んでいるのかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「違う……？　んんっ、では……これは、拙者自身が……あぁ……発情してい\nる……？　はぁ……んっ、おっぱいが……感じ過ぎてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、そうなのだな……んんっ、男に……組み伏せられて……おっぱい\nを好きなように弄ばれる……あぁ、そんな状況に興奮している……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「人聞きが悪い……？　実際そうだろうがっ……んんっ！　んふっ、全く手を\n休めずに……あぁっ、拙者のおっぱいを好き放題にしてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「オチンチンも遠慮なく……擦りつけてっ……道具のように使ってぇっ……あ\nぁっ、だがっ、それが……い、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「そうだっ……玩具でもいいっ、今の拙者はお主の言いなりなのだっ……オチ\nンチンに逆らえないっ、愛玩道具だっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、だからっ……もっとするのっ！　あぁっ、乳首……コリコリ引っ\n掻いてっ！　んひっ、オチンチンにくっつけてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んくぅんっ……あぁっ、そこっ、そこだぁっ！　オチンチンが当たるっ……\nあぁっ、今のとこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁっ、腰もそうっ……ズリズリっ……擦り上げてっ！　あぁっ、いいっ、\nオチンチンっ……オチンチンと乳首っ……擦れ合うのいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、震えてるなっ……また、射精したがってるっ……そうだな\nっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ、下手な我慢はするなよっ？　出し切れっ……好きなだけ浴びせていい\nからなっ……くぅっ、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ビクビクしてるっ……オチンチンっ……もう出したがってるっ……\nあぁっ、出る所っ……見せてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁんっ！　あぁっ……二発目っ！　また射精っ……始まったぁっ…\n…んくぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……また呆れた量を……んふっ、射精漬けにされるぅ……おっぱいが\n……塗りつぶされてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……びゅくびゅくして……んんっ、絡んだのが糸を引いてる……出し\nたての精液……濃厚過ぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「すごい……谷間がヌルヌルしすぎて……ヘンな感覚だ……もしかして……拙\n者も達してしまったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、またオチンチンを震わせて……んぁうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「び、びっくりしたぞ……まだ出すならちゃんとそう言っておけ……全く……\n仕方ない奴だ……はふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁ……どうやら終わったみたいだな……んっ、まだオチンチンが脈打って\nる……余韻が強く残ってるみたいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ、もう少し落ち着くまではこのままでいいぞ……まだ痺れてるだろう？\n　これだけ出したんだ、無理は禁物だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「いつになく優しい……？　馬鹿者……拙者はいつでも、お主のことは気にか\nけているのだ……それ位は心得ておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「それで、満足したか？　そうか……ならばいい。また働きに免じて、してや\nらなくもないからな……た、楽しみにしているがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んぁっ……オチンチンが外れて……ひゃぁぁあんっ！　かっ、顔にっ……ん\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んくっ、お主というやつはっ……覆面を外さぬからと思って、顔に掛けると\nは……んんっ……あぁっ、しかもなんて量だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203402" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「いいも悪いも……もう出してしまっているではないか……ええい、構わん…\n…そのまま出し続けるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ……それにしても、あぁ……強烈な匂いだ……覆面をしていても分かる\n……これが拙者を参らせるのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「な、何？　また出る……？　そんな急に……んぁぁぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ま、まだ、そんなに残していたのか……全く……本当に呆れた奴だ……とに\nかく、全部出してしまえ……中途半端なことのないようにな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「今度こそ終わりか……？　ふぅ……あぁ……ようやくだな。体中が精液まみ\nれだ……よっぽど堪能したと見える……」", "NORMAL" ]},
