        {"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「わははは！　思った通りこの世界もスシが豊富で、征服しがいのある世界で\nはないか！　しかも日替わりメニューは創意工夫に富んでおる！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "145_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「いたぞ！　あそこだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102140003" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「マッポーサムライ！　ホントにこっちに来てたんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれがお前たちの追ってる敵なのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「むぅっ！？　ウサピョン姉妹！？　どうしてここに！　ややや！？　よく見\nるとケッタイな仲間たちまで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あなたが悪事を企んでたら、私たちはどんなところにでも現れるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「仲間じゃないけど、お前はなんか気に入らねー！　相手になってやるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「おのれおのれ！　せっかくの計画を邪魔されてたまるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102140003" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「計画ぅ！？　よく言うよ！　思いつきでこっちの世界に来たくせに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だいたいなんでスシなんだよ！　胸に自前のまな板持ってんだから、サシミ\nでも食ってりゃいいだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140006" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「なっ……！　キサマ……！　言ったな！？　決して拙者に言ってはならぬそ\nの一言を……！　わざわざ異世界で言ってしまったな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102140004" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「言ったがどーした！　このえぐれまな板！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140007" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「おのれおのれウサピョン姉妹！　もう許さん！　キサマらなど、拙者のカタ\nナでタタキにしてくれる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102140005" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「いくらまな板があるからって、そんなことはさせない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102140003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「もうやめろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102140006" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
