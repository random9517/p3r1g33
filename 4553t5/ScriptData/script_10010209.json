        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「せ、先生～！　もうわかったよ～！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "098_010102140001" ]},
        {"command":[ "SETCHARA", "0", "char_00009801_01", "4", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「いくら戦っても時間の無駄です！　こんなの意味がないですよぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そのとおり！　わかっているではないか。我々がここで戦ったとて、なんら\n得るものはない。むしろマッポーサムライを利するだけだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「でもよぉ、先生！　こいつらが邪魔しやがるから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何を言う！　我々を妨害しているのは貴様らではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「何をー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「双方とも、いいかげんにしないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさい！　貴様が口をはさむな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　これから戦うってのに邪魔すんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あれ？　二人、なんか気が合ってんじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140004" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102140003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「共通の敵を前にすれば、人は小異を捨て大同につくもの。マッポーサムライ\nに対しても、同じように立ち向かうことはできんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「う、うーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102140005" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしたちの実力は、そこで見せればいいじゃない。まずは事件現場に行こ\nうよ、ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010102140001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……お前がそう言うのなら仕方がない。皆の者、現場に急行するぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102140004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……また勝手に号令出して。まあ、どうせそうなるだろうとは思いましたが\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー、お前とはいずれきっちり話をつける！　よいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102140005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいだろう。だが、今は当面の脅威を取り除くことだ。さあ、行こう。カツ\nマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんかアナザーは割と俺を立ててくれるというか、なにかと気づかってくれる\nんだよな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "それに引き換え、こっちに元からいるルナテミスは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………ふんっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010102140006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "これだよ。相変わらず。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……どうでもいいが、早く現場に向かってくれんか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "049_010102140001" ]},
