{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなところまで呼び出すからには、何か重要な要件なんだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903101" ]},
		{"command":[ "SETCHARA", "0", "char_00010009_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うん？　アイドルとして、より高みを目指すための修行……？　なるほど…\n…人に見られることを意識する訓練……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903102" ]},
		{"command":[ "SETCHARA", "0", "char_00010009_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふん、なかなか上手いことを言う。世事に疎い奴なら、何となく言い包めら\nれるのかも知れんが……単にエロいことがしたいだけだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903103" ]},
		{"command":[ "SETCHARA", "0", "char_00010009_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くくっ、露骨に声を裏返さなくてもいいだろう。隊長の考えることが分かり\nやすいだけだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが……アイドルに、そんな不埒な考えを持っていたとは……ちょっと見逃\nすわけにはいかないようだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふん……今更なかったことにはならないぞ？　隊長には、しっかりとお仕\n置きが必要だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そーら、脱がしてやる。ほら、暴れるんじゃない。アイドルに淫行したかっ\nたんだろう？　ある意味望みを叶えてやろうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふふっ……ほうら、どうだ……？　隊長は、こういうことがしたかったん\nじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00010009_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アイドルの一番秘めておくべき場所が、目の前にある……夢のような瞬間だ\nろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっと……ふふっ、お仕置きをしようと思ったのだが……もうペニスがギン\nギンに勃起しているじゃないか……どういうことだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長は、こうやって……顔にアソコをプレスされるのが大好きな変態だった\nということか？　んっ……ほら、どうなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……ビクビクと分かりやすく震わせて……触って欲しいのか？　んんー\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだな……私のアソコを、舐めて気持ちよくさせてみろ。クンニだ。上手\nくできるようなら、ちゃんとペニスもよくしてやるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903113" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら……隊長に選択の余地はない筈だ。遠慮することはない……しっかり舌\nを伸ばしてもらおうか……あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……そうだ……目の前に、割れ目が見えているだろう……？　どんな風\nになっている……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「じんわり濡れて……光っているか……んふっ、なら……ここをしっかり舐め\nとっていかないとな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、そうだ……舌をピッタリと押し当てて……そうっ、あっ、な\nぞりあげる……んっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いい調子だ……よくできたご褒美に、竿を……上下に扱いてやろう……ほぉ\nら、シコシコ……シコシコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くくっ、また勃起が跳ねて膨らんだな。続きをして欲しいなら、分かってい\nるよな？　んっ、そうだ……もっと舌を押し付けろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいぞ、ぴちゃぴちゃ音をさせて……ああ、もっとはっきり鳴るようにな…\n…んんっ、吸い付いて……啜るんだ……あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、うっ……んんっ……さすが歴戦の隊長だ……んっ、くっ……弱\nい場所を嗅ぎ当てるのが上手いな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ヒダの……一つ一つを丁寧に舐めて……あぁっ、クリトリスっ……ん\nっ、くぅっ……つついてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいだろう……そこまでするなら、あっ、んっ……もっとペニスも扱き上げ\nてやらないとな……ふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いい子だ……もっと、私を感じさせるんだ……あぁっ、んっ、ふっ……私と\nこういうことをしたかったんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「特訓と称して、いやらしい行為に持ち込もうとするその欲望に忠実な姿……\n案外嫌いではないぞ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おお……亀頭がビクビクして……ふふっ、指を絡ませるのがそんなに気持ち\nいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「弱い場所だからな……つぅっと……触れるかどうかの感じでくすぐってやる\n……こちょこちょこちょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ、跳ねる跳ねる……全く可愛い反応をしてくれる……んぅっ！　おっ\nと……また反撃が始まったようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……舌が……中の方までめり込んで来る……んぁっ……！　く\nぅ……ズリズリと湿った先端がなぞって……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぁっ、ふっ、やってくれるな……あぁっ、粘膜が……トロトロになって…\n…新しい汁が……溢れ出して来るっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「花弁の一つ一つを……丁寧に、舐め回されてっ……溢れた汁を……チュウっ\nと吸われて……あっ、そこだ……そこっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903131" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私も……負けていられないな……ふっ、んくっ……もっと、このビクついた\nペニスを可愛がってやらないと……んっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どうだ……？　あふっ、リズムをつけて……皮をぎゅっと……中心に巻き込\nむようにして……うんっ、ふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ……先走りが出てきたじゃないか……まだだぞ？　いきなり漏らすよ\nうなみっともない真似はするなよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ふふっ……扱く速度が上がってる？　そうだな……余裕がなく\nなっていく状況で、それでも我慢できるか……見ものだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほらほら……舌も止まりかけているぞ？　ペニスが何度も痙攣して……一気\nに限界か？　なら……もう出してしまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ！　ふふっ、飛んだ飛んだ……派手な射精をしてくれるじゃな\nいか……手にべっとりザーメンが絡みついてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、扱く度に、ドクドク溢れて来る……全く呆れた量だ……そんな\nに手コキが気持ちよかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……呆けた顔をして……ちゅぷっ、うむ……濃度も申し分ない……栄養\nたっぷりの子種だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「空打ちさせるのは少し勿体ない気もするが、これはお仕置きだからな。こう\nいうのも悪くはないだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さて……終わった気分でいるようだが、お仕置きはまだまだ続くからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「当然だ。私への舐め奉仕は中途半端なままなんだからな。このまま、消化不\n良で終わらせるなどありえんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さあ、またペニスを扱いて欲しければ、もっと舌を押し付けるんだ……んん\nっ、そうだ……くふっ……今の場所をもっとだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　お前が、あふっ……私に特訓と称して……んくんっ、\nどんなことをさせるつもりだったかは知らんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これはこれで……少し望みが叶っていると言えるんじゃないのか？　ふふ…\n…アイドルの秘められた場所を間近にして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「舌で直接舐めることなど……誰にでもできることではないんだからな……あ\nっ、んんっ……クリトリスも……いいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ、んんっ……！　あふっ……分かってきたじゃないか……くぅぅ……気\n持ちいい場所を続けてつつくように……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁ……ムズムズする……身体の内側から、新しい汁が湧き出る感\n覚が気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ふふっ、よし……またご褒美にペニスを扱くぞ……精液が固まりきっ\nてしまわないようにな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずりゅずりゅっ……んんっ……ふふっ、出したばかりだから、かなり敏感に\nなっているだろう？　優しくしてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「その分、私のアソコも休まず奉仕するんだ……んっ、そうだ……今度は同時\nにしていくぞ……弱点同士を責め合うんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぅんっ……！　いいぞ……遠慮なく奥まで舌を届かせてみろ……そうだ…\n…あっ、あぁ……音をさせて啜ってくるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もう……腰を浮かせてもいられない……直接プレスしてやるからな……んふ\nっ……顔面騎乗はご褒美だろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁっ、んっ……レロレロ……舌が……絡みついてくるっ……あぁ……ペニ\nスもビンビン震えてっ……また敏感になっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010009_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くふぅ……あぁ……ムズムズしてきた……気持ちいいのもそうだが……これ\nは、尿意もありそうだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ、ふっ……んっ、むっ……これは、私の方も……本気でしないと……は\nっ、んっ……くぅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0903216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
