{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あーっはっはっは！　楽勝！　もう私、最強！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910001" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……くぅ、姉さん、マジで強くなっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910001" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ってか、こんなに調子ぶっこいちゃう人だったんだ……うう、ヤバくない？\n　これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910001" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "破も急も力を合わせ、全力で覚醒した序に挑んだが、まったく刃が立たなかっ\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "このまま、姉が敵側に寝返り、その刃を地球侵略に向ける──そんな予感がし\nて、寒気を感じた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、あの……姉さん？　今後、どーすんの……？　ま、まさか……『この力\nさえあれば学業や学歴など不要！』とか言わないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910002" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……ふぅ……そんなわけないです。ひと暴れして、ストレスがスッキリスー\nって感じです。これから家に帰って勉強するですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910002" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「よかったー……ボク、どうなることかと思っちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910002" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "姉が悪に染まることはないらしい……破と急は、明らかにホッとした顔を見せ\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……このテンションなら、悪ノリして、ちょっと周りに迷惑の１つや２つや３\nつは掛けてしまうんじゃないか──そう思ったことは姉には内緒だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「あの、余計な心配されてますけど、あなた達の力は、お亥さまのお導きによ\nるものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021910001" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「もし、悪に染まるようなことがあれば、力は簡単に取り上げられてしまいま\nすからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021910002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「や、やだなぁ……私、今までどおり、サムライテールとして頑張るですよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910003" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「うむ、そうあってもらいたいでござる。でなければ、拙者が手助けした意味\nがござらんからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021910001" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "虎之丞は末裔に力を貸せたことが素直に嬉しいらしい。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うんうんと笑いながら、アイナと視線を合わせていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「迷いを切る力……それこそが己を最大限に引き出すきっかけとなる。目の当\nたりにできて、拙者も嬉しいでござるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021910002" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「い、いえ、手伝ってくれてありがとうです。けど……まさか、あの赤点って\n、私を覚醒させるため、わざと一点足りないようにしたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910004" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「いえ、点数が悪すぎたので、お亥さまの点数補正能力が若干及ばなかった…\n…ということのようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021910003" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……流石姉さん。一筋縄でいかないバカね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910003" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「…………は、はははははは、まあ、ともかく！　あらたな力を手に入れたし\n、これからもバンバン厄災を倒していくですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910005" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うん、そしたら、赤点をもっとしっかり回避させてくれるだろうからね。頑\n張ろー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910003" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「姉さんは、その前に、明日のテスト頑張らなきゃね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910004" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「は、はははは！！　よーし、それじゃ、今日の締めくくりで、一番いい声を\n出すですよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910006" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ええ～～～……そんなぁ、無理やりやらなくても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910005" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「これにて～～～～……一見落着ぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910007" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910006" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910004" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　ど、どうしたの？　ふたりとも元気ないですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910008" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ってかさ、あたしも悩んでるんだけど？　ほら、この……なんていうか思春\n期特有のモヤモヤ感？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910007" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「感情の乱高下で、宇宙エネルギーが抽出できるレベルなんですけど？　あた\nしには、そーいう覚醒予定は組まれてないわけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボク、お腹すいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910005" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「や、思春期特有のモヤモヤで覚醒してしまったら、世界中の若人がヤバい力\nを持つことになってしまいますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021910004" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「それ、不公平だってばぁ！！　あたし、納得できなーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910009" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ボクもちょっと不満かなぁ。だからさぁ、サムライテールの戦果は、三\n人でわけあう形にするのはどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910006" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、それなら納得。そうしましょ！　ふっふっふ、労せずして、赤点回避が\n出来そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910010" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ちょっ、それは私が不公平じゃないです？　あなた達、私より怠け者じゃな\nいですか！　私一人に戦わせるつもりでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910009" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……まあ、それは力あるものの義務って感じで。ほら、えーっと、古人いわ\nく『ノブレス・オブ・リージュ』ってやつ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910011" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あ、英語で言うパターン？　それかっこいいねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910007" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「でっしょ～～？　ふっふーん……なんたって、あたし、姉さんや急より成績\n良くて、でもギリギリ赤点レベルなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910012" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021910003" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「なんですか？　そのあからさまな視線そらしは……まさか、あなたも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021910006" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「や～～、血は争えぬものでござるなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021910004" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "かしましく言い争う三姉妹を見て、アイナと虎之丞は色々複雑な表情を浮かべ\nていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな二人に気づかず、序破急は答えの出ない議論を交わし続けた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああ、もう……とにかく、今は目先のテストが大事です！　そろそろ帰るで\nすよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910010" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んー……だね。あたし、疲れた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910013" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボク、マジで腹ペコ。機嫌悪くなりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910008" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はいはい、晩ごはんはピザでも取るですよ！　その前に、いつものようにち\nゃんと締めをするです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910011" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……はぁ、この空気でぇ？　さっきやったから、もうよくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910014" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「お腹すいた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910009" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「駄目です！　次はしっかりやるですよ！　じゃないと、うちに帰れませんで\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910012" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はいはい、わかったってばぁ……急、ちゃんとやるのよ。時間がもったいな\nいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021910015" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ピザか～～……ま、いっか……はい、いつでもいいよ～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021910010" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「せーのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021910013" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "6", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "0", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "0", "CENTER", "-600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
