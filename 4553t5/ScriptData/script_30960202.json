{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「人に日焼け止めを塗ってもらうのって、こんなにも心地いいものだったんだ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あぁ～、ワビサビを感じるよぉ～。ショーテンするってこんな感じなのかな\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……ちょ、ちょっと……そこは僕の大事なとこ……！？　んっ、\nあふっ……隊長さん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ひょっとして……僕とそういうこと、したいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「別にイヤじゃないよ。むしろ隊長さんとなら嬉しいっていうか……あっ……\n！　た、隊長さん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ワァオ……！　これが隊長さんの……とってもホットで、ストロングだね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああっ、あんんっ！　アソコに軽く当てられてるだけなのに、すっごく気持\nちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……み、見ないで……！　僕のアソコ、エッチなお汁でトロトロ\nになってるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うん……実は隊長さんに日焼け止めを塗って貰ってるときから、少しだけ濡\nれてたの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だって、隊長さんの手つきがいやらしかったし……！　それに、隊長さんの\n温もりが肌から伝わってきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「しょ、しょうがないよね！　このビキニって衣装、肌の露出がいつもより全\n然多いんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だから……んっ！　　こんな風に発情しちゃうのも、自然なことなんじゃな\nいかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んひっ……！　あっ、ふああぁ……本当に挿れちゃうんだね……僕のアソコ\nに隊長さんのを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　入ってくるっ……！　アソコのお肉、思いっきり掻き分けら\nれて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんっ……ぐっ、はああぁ……！　隊長さんの出っ張ってる部分が入口に引\nっかかって……んっ、んんんんっ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うぐっ、はっ、ふああぁ……！　お腹の中、隊長さんのでいっぱいになって\nる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「苦しいけど、幸せな感じがするよ……ハッピーが溢れて止まらない感じ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああっ！　そ、そんな……急に動くだなんて……んんっ、あぐっ、くううう\nぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「やっ、あはあぁ！　隊長さんのが出入りするたびに、ずちゅ、ずちゅって、\nいやらしい音がしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「硬いのでお腹がゴリゴリ抉られてるのに、すっごく感じちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「我慢しようとしてるのに、突かれるたびに変な声が出て……あっ、んっ、ふ\nあぁん！　僕の身体、おかしくなっちゃったのかな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「交尾ではこれが当たり前……？　そうなんだ……じゃあ、もっと乱れてもい\nいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「もっと乱れた姿が見たいだなんて……隊長さん、すっごくヘンタイみたい…\n…きゃううぅん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ち、違うよ……！　今のは軽いジョークで……んひぃ！？　心の底からヘン\nタイって思ってるワケじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んっ、うぎゅうぅ……！　ああぁっ！　それ、ダメ……！　奥の方\nをコリコリしないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「痛いワケじゃなくて……！　そこを刺激されると、頭と身体が変になるから\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「急に切なくなって、僕の大切なところが、きゅうぅ～って締め付けられる感\nじになっちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だからそんなに激しくズポズポしちゃダメ……あああぁんっ！　ダメって言\nってるのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕、本当におかしくなっちゃうっ！　隊長さんのを、ずっと僕のアソコにハ\nメハメして欲しいって思っちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「別に構わないって……やああぁあっ！　また赤ちゃんの部屋がきゅんってし\nて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「今そんなこと言うの反則だよ……！　隊長さんから離れたくないって、身体\nが訴えてきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「アソコが勝手に締まって、隊長さんのを締め付けて……！　なのに、隊長さ\nんは容赦なく僕の大事なところを突いてきて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あああっ！　ひっ、ひゅううぅん！？　あっ、あっ！　くるっ！　なにかが\n奥からきちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んひゃうっ！？　た、隊長さんのがビクビクって震えて……なにかが来る気\n配が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「一緒にイこうって……ど、何処にイクの！？　あっ、ふあっ、ああぁあん！\n　た、隊長さん！　隊長さん～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふあああっ！？　どぴゅどぴゅ出てるっ！　隊長さんのアソコから、液体み\nたいなのが僕の膣内に……あひぃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「熱いのたっぷり出されて……あっ、んんっ！　僕もなにか来ちゃう！　ふあ\nあっ、あっ、くあああぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、んはぁ……！　赤ちゃんの部屋に液体が流れ込んできてるの\nわかるよ……！　これ、一体なんなの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「これが精子……赤ちゃんのモトなの……？　じゃあ僕、隊長さんの子供を孕\nんじゃうの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんとの赤ちゃん……ああっ！　想像しただけで、ハッピーな感じが…\n…またアソコから何かが来ちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……すごい……このいろんな感覚が溢れ出す感じ……たまらない\nよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「これがイクって感覚なの……？　じゃあ僕と隊長さんは、同時にイッたって\nことなんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それに……えへへ。隊長さんとの赤ちゃんかぁ……ニンジャになる前に、マ\nマになっちゃいそうだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「確かにニンジャにはなりたいけど、隊長さんと一緒になるのは……イヤじゃ\nないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あははっ！　なに言ってるんだろうね、僕……！　こんなのまるでプロポー\nズみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うぐっ、んんんっ！　どうしてまた動くの……！？　えっ……僕の言葉が可\n愛くてエッチだったから興奮した……？　そ、そうなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　あはぁん！　それはとっても嬉しいけど……！　急にピスト\nンなんかされたら……はううぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕のアソコ、気持ちよくて壊れちゃいそうなのに……！　隊長さんの動きに\n合わせて、腰が勝手に動いてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ワァッツ！？　ナンデ！？　どうして！？　怖いよ、カイキゲンショーだよ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「これは僕の本能が、隊長さんを求めてるから……！？　イエス……！　言わ\nれてみれば、確かにそうかも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕、隊長さんと一つになりたいって思ってるんだね……！　いいよ、隊長さ\nん……もっとめちゃくちゃにして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んはあぁん！　あっ、あっ！　さっきよりも隊長さんのが硬くなって、僕の\nアソコをズポズポしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「こんなに激しくムーブするなんて……とっても気持ちいいんだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕もすっごく気持ちいいよ！　アソコの奥からハッピーがフルスロットルで\n襲ってきてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　隊長さんのが、僕の大事なところをツンツンしながら、グ\nリグリって抉ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁん！　僕、限界かも……！　またさっきみたいに、なにかが\n来て……イッちゃいそうだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ああぁん！　隊長さんものさっきみたいにビクビク飛び跳\nねてるよっ！　イキそうなんだねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「いつでも出してオーケーだよ！　カミング！　精子プリーズ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「さっきみたいなドロドロの精子、好きなだけどぴゅどぴゅしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オーイェ！　隊長さん！　ああっ！　僕……もうイッ、イクッ！　イッちゃ\nうううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああああっ～～～！　出てるっ！　隊長さんの精子、また僕の膣内に出され\nちゃってるぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　はあぁああぁん！　僕のアソコが勝手に締まって、隊長さん\nから出る精子をどんどん絞り上げてるよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「奥の方に流れ込んできてるのがわかるっ！　ママになりたいって、訴えかけ\nてくるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くあっ、んっ、ふああっ！　イッてるのに、またイッちゃうっ！　あっ、あ\nっ！　んはああああぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「こんな感覚が味わえるなんて……！　イエス！　イエス！　アイム・ソー・\nハッピー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はああぁ、んっ……隊長さん、とってもすごかったよ。アリガトウゴザイマ\nス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でも、本当に赤ちゃん出来たらどうするの？　隊長さん、困ったりしない？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕は全然困らないよ！　むしろ、隊長さんとの確かなキズナが出来て嬉しい\nよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えへへ……妹たちも喜んでくれるかな？　それとも、嫉妬されたりするのか\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ！　妹たちに手を出すのはヤブサカじゃないけど、ママになるのは僕だ\nけだからね！　そこだけはちゃんと守って欲しいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んひゃあぁ！？　急に抜くなんて、一体なにを……！？　あっ、ひゃぁ、ふ\nあああぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「身体に隊長さんの精子がかかってるっ！　どうしてこんなことするの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、やっ！　まだ出てるっ！　どぴゅどぴゅってエッチな音させながら、\n熱い精子出てるよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　それにこのニオイ……クサイのに、クセになりそうな感じが…\n…！　んぐうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、ダメっ！　ニオイだけでもイッちゃうっ！　あっ、あっ！　ふきゅう\nううぅん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああっ……僕の身体、膣内も外も精子でベトベトだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「これだけ僕のことを汚したんだし、責任取ってもらうからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふええぇ！？　責任を取って、ずっと一緒に居るだなんて……僕、そういう\nつもりで言ったワケじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ただ、汚れた身体を拭いてもらおうと思っただけで……！　ハッピーエンド\nなことまで考えてたワケじゃないんだよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「やっぱり言葉ってムズカシイ！　まあでも、結果的にハッピーならオーケー\nだよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0204410" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}