{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ホラ、泣いたりしたら可愛い顔が台無しだよー？　涙拭いちゃうよー？　ハ\nイふきふきー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「水を飲んで落ち着きなさい。用意があれば、私が手ずからお茶など淹れて差\nし上げたのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010021260005" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの……オレはいつまで正座していれば……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "翔生子を泣かせてしまったカツマは、部屋の真ん中で正座中である。否応など\nはない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "男として産まれたからには、女を泣かせた以上は仕方がないのである。石を抱\nかされないだけ、まだ慈悲があろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁ、あの、ちがっ、違うんです……っ。嫌だったんじゃなくて、な、懐かし\nくて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021260011" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「え？　懐かしい？　どういうこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260007" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あの、故郷のおじいさまが、同じ撫で方をしてくれてて、それで懐かしくな\nって、胸がいっぱいになっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021260012" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……なるほど、命拾いをしたようですね、従僕？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010021260006" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本気の目で物騒なことを言うなよ！？あと隊長から地味に格下げすんのやめ\nてね！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか、翔生子も別世界の人間だったよな。元の世界へ気軽に里帰りが出来\nるわけじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一瞬、カツマの脳裏にクリスタルを売りつける強欲商人の顔が浮かんだが、あ\nんなのに頼ったら後々もっと面倒なことになりかねない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「でも良かったあ、隊長さんのせいじゃなくって。　……ん？　泣いたのはや\nっぱり隊長さんのせいなのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「蒸し返すのはやめてくれ。　……でもまあ、翔生子の緊張も解けたようでな\nによりだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ……っ、お、お騒がせして、ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021260013" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「気になさらないで、あれは隊長さんの軽率な行動が招いたことですわ。それ\nより、貴女のお名前を是非知りたいのですけれど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010021260007" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ミルラに優しく促され、翔生子は頬を赤らめながら、居住まいを正して頭を下\nげる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「積上　翔生子です。宜しくお願いしますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021260014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（ま、これでアナザーの心配も、ちょっとはマシになるだろ……。さあ\n、こっちは書類を片付けないとな）", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "談笑を始めた少女たちを尻目に、カツマはそそくさと仕事に戻る。この山を片\n付けなければ、休憩を取るのもままならない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「隊長さん、随分と仕事が山積みですのね？　少々お手伝いしてもよろしくて\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010021260008" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あ、わたしも手伝うよ！　というより、この部屋汚すぎ！　ちょっとは整理\n整頓しなきゃ、能率も上がらないってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260009" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……マジで？　お前ら女神か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "邪魔をしてきたり、場をかき乱すことしかしない幹部連中に日々虐げられてい\nるカツマにとって、少女たちの申し出は信じ難いものだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「まっかせてよ、これでもお父さんの部屋とかお掃除してるんだから！　じゃ\nあ、隊長さんの職場環境改善、始めるよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260010" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおい、マジかよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "少女たちの助力によって、カツマの仕事能率は過去最高値を叩き出した。もっ\nとも、今までが悪過ぎただけとも言えるが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「これはこっち、これはあっちで……。あ、書類は翔生子ちゃんお願いねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260011" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「こちらは整備部に回して下さいな。こちらは渉外部に。青い封筒は冴島長官\nに持っていって下さる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010021260009" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "部屋を整理整頓して人の導線を確保し、大まかな分類をテキパキとこなすさく\nらに、秘書たちに的確な指示を下してゆくミルラ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして翔生子の書類処理能力が加わったことで、山のように積み上がっていた\n書類の山は、みるみるうちに溶けてゆく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これなら……この分なら……定時で帰れる……っ！！　ジュンジローを洗う\n暇が出来る……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正直、最近ちょっと臭うのだ。今すぐにでも洗いたいのだ。だが、仕事量がそ\nれを許さなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、ちょっとジュエリーショップ巡りしたいの～！　だからあ\n、これ、任せるわ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021260001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……うわああああああ！！！！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなカツマの儚い希望も、突然やってきたダイヤナが、書類の山を机の上に\nぶちまけたことで、脆くも崩れ去った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あら？　もう、この部屋狭っ苦しいわねえ～。汚れたらどうするのよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021260002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほあああああああああああああああ！？！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ちょっとダイヤナさん！！　それ以上の狼藉は、隊長室警護少女隊が許しま\nせんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_090_010021260012" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……そのようなものに所属した覚えはないのですけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010021260010" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「でも、せっかく片付いてきたおしごとが増えちゃったら、隊長さんがかわい\nそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021260015" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "珍しく食い下がった翔生子に少々驚きつつも、ミルラは微笑と共に頷いた。ミ\nルラとて、折角上手く回り始めた仕事の邪魔はされたくない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え、ええええ！？　ちょっとちょっと、何なのよお～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021260003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "茫然自失となったカツマの代わりに、少女たちは侵略者に立ち向かうのだった\n――！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}