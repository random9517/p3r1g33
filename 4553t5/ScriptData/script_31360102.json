		{"command":[ "PLAYVOICE", "136_0104101" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「えーっとさあ、その……今からセックス、するんだよね……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104102" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「うん。別に怖がってるわけじゃないの。イヤでもない。ただ、あなたのオチ\nンポがわたしのオマンコに入ってきて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104103" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「スペルマたっぷり子宮に注がれて妊娠させられちゃうんだな、って思ったら\n興奮してきちゃって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104104" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「それに、その。他人に見せたことのないオマンコ見られちゃってるし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104105" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「え？　もう我慢できない？　ん……うん。入れて……？　わたしのオマンコ\n、あなた色に染めて欲しいの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104106" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んっ、んんん……！　んんぅ！？　んああぁぁ～～！？　んっ！　んっ！　\nふあぁ……えっ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104107" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「は、はじめて……だよ。それなのに感じちゃうっておかしいの？　でも……\nはぁ、はあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104108" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「気持ちイイんだもん、この感じ……好き。あなたに後ろから襲われて、オチ\nンポで突かれてるの好きぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104109" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ふああぁ！？　ま、まだオチンポおっきくなるの？　えっ、えっ？　もっと\n奥まで入ってくる……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104110" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んんぅ！　んんん！　ちょっ、やあぁ……！　おっぱいはダメだって、ああ\nぁぁ～～～っ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104111" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「揺れてるおっぱい見たら我慢できなくなった、なんて……言い訳なんだから\nね、くっ、うぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104112" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「だ、だから乳首は……ああああぁぁ～～～っ！！？　くひぃ……ひんっ！　\nひぃぃ……ああぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104113" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「よ、弱いのぉ。いつもビンカンすぎるから、ブラも選んでるぐらいなのにぃ\n……あうぅ！　やあぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104114" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「くりくりって弄くり回さないでぇ、す……すぐイッちゃうぅ！　ひっ！　ひ\nぃぃん！　あああぁぁ～～！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104115" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「さ、さっきからイカされっぱなしだよぉ……ええっ？　オチンポまだ奥に…\n…くぅぅ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104116" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あうぅ！　んあああぁん！！　子宮ぅ、突かれてるぅ……！　ごつ、ごつっ\nて当たって……ひぃぃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104117" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　わたしの子宮ぅ、あっ……あなたのせーし欲しがってるぅ……\n！　ビュルビュルって出されてぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104118" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あなたの子を孕まされたがってるの、ふあぁ、あうぅん、わたし、いつもこ\nんなしゃべらないのに……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104119" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて、くぅぅ！　くひぃぃっ！？　ひん！　ひんっ！　しゃ、喋\nってないとイキっぱなしになっちゃう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104120" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「頭が変になって、帰ってこれなくなっちゃうの……！！　いいの？　それで\nいいの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104121" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「わたしが気絶したら、オチンポで突いて起こしてやるって？　ふああぁ……\nこ、興奮しちゃう……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104122" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「それいいかも、じゃあわたし遠慮なくイクから……くぅぅ！？　んあああぁ\n～～！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104123" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「乳首ぃ、んああぁん！　おっぱい揉みぃ、ながら……オチンポでガツガツ突\nかれて……くひぃぃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104124" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「クリトリスまで弄られたらわたしっ、わたしぃ……あああぁぁ～～～～！！\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104125" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「すぅ……すぅ……んああぁん！！　あっ？　あれ？　あうぅ！　あああぁん\n！　い、いま気絶しちゃってた……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104126" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「そ、そうなの。あなたにオチンポをハメられて、気持ち良すぎてイッちゃっ\nて気絶して……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104127" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「初めて、なのにぃ……すっかり、あなたの虜になってるの……！　ああぁ！\n　あぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104128" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あなたにも気持ち良く、なって欲しい……！　イッちゃって、子宮にザーメ\nン注ぎ込んで……くうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104129" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「孕ませてぇ、わたしの子宮ぅ、屈服させてぇ……んあああぁん！　気持ちよ\nしゅぎるよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104130" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「んんぅ、あなた……ちゅっ、ちゅるる、ちゅむ、ちゅっ。んっ！　んんっ！\n　ふああぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104131" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ファーストキスも、あなたに、くぅぅ！？　奪われちゃったぁ……もっと激\nしくしてもいいんだよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104132" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「わたしのカラダ、あなたに全部あげるからぁ……オマンコも、おっぱいも、\nお口も、お尻だって……ふあぁ！　あぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104133" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ぜんぶ、ぜぇーんぶ、好きにして……め、メチャクチャにして欲しいの！！\n　好きぃ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104134" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あなたの全てが好きぃ……！　も、もっとイジメたくなってきた？　いいよ\n、わたしの子宮ぅイジメてぇ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104135" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「はひっ！　ひんっ！　ひぃぃ！　あっあっあっ、ああああ！？　来るぅ……\n来ちゃう、またぁ……あああああぁぁ～～～～っ！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "136_0104136" ]},
		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「はひっ！　ひんっ！　ひぃぃ！？　出てりゅう……精液びゅるびゅるって子\n宮に注がれてぇ……んあぁ！」", "NORMAL" ]},
