		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「頭の奥が灼け、ちゃうよぉ……ぜ、絶対に孕んじゃったもん、わたし……\nはぁぁ！　はぁーっ！　はぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
