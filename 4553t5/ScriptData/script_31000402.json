{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……やっ、待ってくれ、隊長どの……！　エッチなことをしてもいいと\nは言ったが、こんな場所でなんて……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと人目につかないところで……！　やっ、あああっ……！　ペニスがア\nソコに擦れて……んっ、あっ……！　そんなに、擦らないでくれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひっ、あああぁ……！？　クリトリスがペニスで擦れているっ……！　そん\nなに押し付けられたら、私も我慢ができなくなる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わ、わかった……！　ここでいい……！　もう人目なんて気にしないから、\nここで挿れてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ど、どうしたんだ……？　何故ペニスを挿れてくれないんだ\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゃんとおねだりしないと挿れてあげないだと……！？　そんな……私のア\nソコはもうこんなに濡れているというのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これでは生殺しではないかっ……！　た、隊長どの……！　お願いだからペ\nニスを挿れてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うううぅ……わかった……！　ちゃんとおねだりするからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わ、私のぐちょぐちょになっているアソコに、隊長どののたくましいペニス\nを挿れてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いっぱいズポズポして、たくさん犯してっ……！　私のいやらしいアソコを\n、ペニスでかき回してくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふううううぅ！？　かっ……はっ……！？　あ、合図もなしに……いきな\nり挿れるとは……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　ぐっ、んひいぃ……！？　おっ、おおぉ……奥の奥ま\nで、入っているっ……！　こ、これ……苦しっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！　そんな……いきなり、激しっ……はあああぁあぁんっ！　私の\n大事なとこ、メチャクチャにされているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だ、ダメだっ……！　そんなに奥ばっかり責めたら……うあああああぁ……\n！？　あっ、やっ、ダメって、言ってるのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなエッチな声出してたら、誰かに見つかってしまうっ……！　抑えない\nといけないのにっ……エッチな声、止まらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ！　あっあっあああぁっ！？　赤ちゃんの部屋が開いているっ！　感じ\nすぎて、アソコがおかしくなってしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うああああっ！？　き、気持ちいいっ！　隊長どのに犯されるの、すっごく\n感じるぅ！　もっと激しくズポズポしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「えっ……ど、どうして急に動きを止めるんだ……！？　もっと奥をペニスで\n突いて欲しいのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「自分からも腰を振れだと……！？　そんなはしたないこと……やっ、あああ\nあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「す、するっ！　ちゃんと自分から腰を振って、ペニスを気持ちよくするっ！\n　だから奥をグリグリしないでくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……くっ、あふっ……！　あっ、ぐっ……ペニスが奥に届いて……！　\n自分から動くと、余計にエッチな音が響いてくる……んふううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちいいところに何度もあたってくるっ……！　やっ、あっ……！　こん\nなの、イクッ……！　イッてしまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　やっ、ああああぁ！　私の動きに合わせて、パンパンしない\nでくれぇ！　そんなにされたら、アソコが壊れるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひっ、ぐっ……おおおぉ……！？　もっ、もうダメっ……！　限界だっ…\n…！　あっ、い、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああああぁ！　イクッ！　イクぅぅぅんっ！　隊長どのより先に、イッて\nしまうううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふああああぁ……！？　あっ、ああああぁ……！？　アソコの奥から、気持\nちいいの溢れて……ひぐうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「感じすぎて、潮吹きが止まらないっ……！　やっ、ああぁ……！　私のエッ\nチな音、隊長どのに聞かれているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ……あぐっ、んんんんっ！　アソコも勝手に締まってきている……！　\nんひっ、くはああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスのカタチがはっきり伝わってくるぅ……！　こんなのダメだっ……！\n　またイクッ、イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んはあああああぁ！？　イッてるのに、アソコをペニスでほじらないでくれ\nぇ！　おかしくなるっ！　私の身体、変になるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404130" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あぅ！？　お、お願いだ隊長どの……！　少し休ませて……ん\nひいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もうそろそろイキそうだから、アソコを締めろだなんて……！　そんなこと\n言われても、イッたばかりでチカラが入らないんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うあああああぁ！？　わかった、締めるからぁ！　だから無理やり子宮口を\nこじ開けないでくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ぐうううぅ……！　あっ、あっ！　ペニスの動きがどんどん速くっ…\n…！　やっ、あああぁ！　精子来るの、感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　出されるっ……！　イッたばかりのエッチな子宮に、孕ませ\nミルク出されてしまううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おおおおおぉ……！？　で、出てるっ……！　妊娠させる気満々の精子、び\nゅーびゅー出ているぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんな……外で孕むなんてぇ……！　やっ、あっ……！　妊娠するなら、も\nっと雰囲気のあるところがいいのにっ……あはあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひっ……がっ、かはっ……！？　本当にここで妊娠してしまうっ……！　\nもう奥で出さないでくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「別に孕ませないでくれとは言わない……！　だが、せめて別の場所で……！\n　布団の中とかで……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……あっ……！？　そん、な……！　出さないでって言っているのに、\nまだ精子が出て……ああっ、あああああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あっ、んんっ……！　少しは落ち着いたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そ、そうか……では早くペニスを抜いて……んっ、くっ……！？　どうした\n……なぜ抜こうとしないんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「せっかく膣内に出したんだから、確実に孕むまでペニスで馴染ませてやるだ\nと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、やめてくれっ……！　私もイッたばかりで、今は完全に子宮が開いて\nいる……！　そんな状態で馴染まされたら、受精してしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……あっ……！？　ペニスがまた大きくなって……！？　やっ、イヤっ\n……！　孕みたくない……！　こんなとこで妊娠したくないいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うあああああぁっ！？　ペニスがまた奥をトントン突いてくるぅ！？　これ\n、気持ちよすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコの奥に溜まってる精子が、無理やり子宮の中に押し込まれるの感じる\nっ！　もう入らないっ！　子宮の中、いっぱいなんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おおおおぉ……！？　入らないって言ってるのに、無理やり押し込まれて…\n…ぐっ、がはっ！？　あっ、あああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひっ……！？　あっ、ぐっ……ふっ、あはあああぁん！？　隊長どのが本\n気で孕ませようとしてるの、アソコから伝わってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなの、もう絶対に逃れられないっ……！　絶対に妊娠させられるっ……\n！　隊長どのの赤ちゃん、野外で仕込まれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わかった……私も覚悟を決めるっ……！　もう孕ませないでくれなんて言っ\nたりしない……！　だからせめて、もう少し優しく……！　んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　やっ、また一段と腰の動きが速くなって……あふうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「優しくしてと言ってるのに、なぜ激しくするんだ……！？　今日の隊長どの\nは、なにか変だぞ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さっきの屋台で変なモノを飲んでから、気分が昂ってしょうがない……！？\n　そ、そんなっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だとしたら、私のせいだ……！　私が飲めと無理やり勧めたせいで……ぐっ\n、ああああっ！　またペニスが奥を抉ってっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あああっ……！　すまない、隊長どの……！　私が悪かった\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゃんと責任を取らせてもらう……！　ペニスも鎮めるし、妊娠もする……\n！　だから、早くイッてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私の身体、もう限界なんだ……！　犯されすぎてアソコがジンジンして……\nくっ、あああっ、んふっ、ひうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！？　ペニスがビクビク跳ねてるっ……！　ああ、出してくれっ\n……！　私にちゃんと謝罪させてくれっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404219" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「好きなところに出してっ……！　気がすむまで、射精してっ……！　あああ\nっ、出してっ！　出してくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひいいいぃ！？　ま、また膣内にいっぱい出されて……あっ、あっ！　子\n宮が悦んでいるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちいいのがどんどん頭に響いて……やっ、あっ！　イクッ！　またアソ\nコから潮吹いてしまうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くはあああぁ……！？　あっ、あっ！　おしっこしてるみたいに、エッチな\nお汁が吹き出しているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　隊長どの、見ないでくれっ！　私のエッチな潮吹きの音、聞\nかないでくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くあああぁ……！　あっ、やっ……！　まだ出るぅ……！　射精に合わせて\n、潮吹き止まらないいいぃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふっ、かはっ……やっと、落ち着いてくれたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……そう気に病むな……私は大丈夫だ……それより、隊長どの\nの身体はどうだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さっきまで妙に興奮して、荒々しかったが……んっ、そうか……大分おさま\nったようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さっきは変なモノを勧めてすまなかったな……安心しろ。さっきも言ったが\n、今回の責任はちゃんと取らせてもらう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404309" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに私は、隊長どのの赤ちゃんを孕めて幸せだと思っている……お腹の子\nのためにも、そんな悲しそうな顔をしないで、もっと喜んでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああぁん！？　ぺ、ペニスが勢いよく抜けて……ひっ、んふううぅ……！\n？　あっ、あふうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「身体にいっぱい、精子がかけられているっ……！　こんなの、マーキングさ\nれてるみたいで……あんんっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコの奥が疼いてきてるっ……！　あひっ、んんっ！　やっ、また潮吹き\nしてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ！　精子かけられながら潮を吹くなんて……！　あっ、ダメだっ…\n…！　まだ出るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404404" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ、んんんっ……あっあっあっ！　精子もびゅるびゅる出続けてるっ……\n！　私の身体、精子のニオイでいっぱいになってしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……はあぁ……どうやら、ペニスも頭も正気に戻ったようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どのが謝るようなことではない……全て私が招いたことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「少し乱暴で怖かったが、気持ちよかったのは事実だ……だから気にしないで\nくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気にするなと言われても、そんなの無理だと……？　ううむ……どうしたも\nのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだな……では気を取り直して、もう１回エッチするとしよう。今度は人\n目につかない場所で、優しく愛してくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0404410" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
