{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……このプラグ、なに……？　お、お尻が……いままで以上に疼い\nて、たまらないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「アナル奴隷プラグ！？　そ、そんなもの挿入されたら、私……あなたの……\nんっ、ああっ、肉奴隷に……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「四つん這いになって尻を向けろだなんて。うぅ……身体が勝手に……あなた\nの命令に逆らえなくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたが望むなら、これくらいプラグを使わなくったって……んぁあっ！？\n　ちょっと、まって……お尻がぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そ、そのリモコンで、私のプラグを操作しているの！？　あぁあっ！　やだ\nっ、お尻の中で、プラグが震えて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「振動で、お尻が……んぁっ、あっ、ああ……っ！　んっ、んぅっ、ふぅうう\nっ！　はぁっ、はぁっ、んっくぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「か、感じてなんか……。だって、お尻だし……お尻で気持ちよくなんか、な\nるわけない……！　はぁっ、あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「プラグの振動強くしないで……お尻の中、めちゃくちゃになっちゃう……！\n　んひぃいっ、おおっ、お尻……ダメ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「勝手に、恥ずかしい声が止まらないの……！　んぁっ、お尻……くねくねっ\nて動いちゃうの……んぁっ、止まらない……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ダメ……！　キちゃう……なにかっ、アアッ、お尻から…\n…キちゃう……んぁっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「い……イッちゃった……。お尻で……んはぁ……お尻……んぁっ、ああ……\nダメ……でちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「イキながら……お、おしっこまで……。あなたの前で……こんなの……恥ず\nかしすぎる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。でも……あなたのオチンチン……おっきくなってる……\n。私のこんな姿を見て、興奮したの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううぅ……オチンチンを見たら、お尻が……。アナル奴隷プラグのせいで…\n…オチンチン……お尻に欲しくなってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そうなの……欲しいの……。私のお尻を、あなたのオチンチンでめちゃくち\nゃに犯して欲しいの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「プラグを自分でひりだせって？　ん、わかった……。んっ、んんぅ……んは\nぁ……ああ、ああ……っ、んむぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　はぁ、はぁ……。ほら……お尻から、プラグが抜けたよ……。\nこれで、私のお尻に邪魔者はいなくなったね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「き、きて……。お尻、オチンチンを挿れる準備はできているから……んっ、\nああ……熱い先っぽが、お尻の穴に……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んひっ、ひぃいいっ！　どんどん入ってくる……っ！　おっ、おおっ、オチ\nンチン……んぉっ、おおおぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻が……ひぃ……ひろげられて、るぅ……っ！　んっ、んっくぅううっ！\n　オチンチン……どんどん、深くにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「は……入りきっちゃった……。私のお尻に、あなたのオチンチン根元まで入\nっちゃった……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いままでのプラグよりも太くて、長いの……。それに、すっごく熱くて……\nお尻の中が火傷しそう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　う、動いちゃうの！？　んっ、そうだね、めちゃくちゃに犯し\nてって言ったの、私だもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぉっ、おおっ、おおぉおっ！　お尻っ、んっ、ひぃっ！　中をオチンチン\nが、出入りして……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻の中を……ぉお……っ！　ひぃ、ひっかいて……んぁあっ、ずりずりっ\nて……してる……んくぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻が勝手に動いちゃうの……っ！　んぁっ、あなたのオチンチンを、んひ\nっ、気持ちよくしようとしちゃってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻の中をきゅうってして、お、オチンチンのこと、お尻でしごいちゃう…\n…んんぅっ、オチンチンのこと感じちゃうぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、お尻……感じちゃう……っ！　あなたのオチンチンで、気持\nちよくなっちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンがいっぱい奥までっ！　お尻の奥まで……んひっ、ひぎぃいいっ\n！　一番奥までオチンチン届いてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お腹の奥からっ、オチンチンに身体を貫かれてるみたいぃっ！　んふぅうう\nっ！　おっ、おおっ、おおぉおおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチン膨らんできた……んぁっ、ますます私のお尻をひろげて……んひ\nぃいっ、射精……しちゃうの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だ、出して……アナル奴隷忍者のお尻に……中出しぃ……っ！　精液いっぱ\nい注いで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃっ！　おぉっ、お尻にっ、精液いっぱいきたぁああぁっ\n！　あぁっ、んはぁああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチン、ビクビクしながらっ、んくぅっ！　熱いのいっぱい……お尻に\n、流れ込んでくる……んふぅ……あっ、はぁあ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お……お尻なのに……イッちゃった……。お尻に中出しされて……イッちゃ\nったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻でイクほど感じちゃうなんて、恥ずかしい……。でも……すごく気持ち\nよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ち、違うんだからね。このスーツは、お尻でエッチするためにプラグを挿入\nするわけじゃないんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だけど……このスーツがなかったら、あなたのオチンチンをお尻で受け入れ\nることもなかったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これで私の身体は、オマンコもお尻の穴も、あなたのものにされちゃったね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ねえ……もっとシて……？　お尻の疼きがとまらなくて……もっと、ずぼず\nぼって犯して欲しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたがアナル奴隷プラグなんて使うから、お尻がオチンチンをほしがって\nたまらないんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　そ、そう……そうやって……っ！　ひぃいっ！　まだまだ硬い\nオチンチンで、お尻っ、突いてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ！　んぉっ、おほぉおっ！　お尻っ、めくれちゃうくらい激し\nく動いてっ、んふぅううっ！　ふひぃっ、ひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「感じるっ、感じちゃうぅっ！　おっ、おっ、お尻ぃいいっ！　気持ちよくな\nっちゃうのっ！　ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お腹の奥までっ、おおっ、オチンチンで突かれてるっ！　ぐひっ、めちゃく\nちゃに、かき回されてっ、るぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くふぅうっ！　お尻がすっかり、エッチな穴になっちゃってるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンで、気持ちよくなっちゃう穴に、なって……くひぃいっ！　おか\nしくなっちゃってるぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あなたも感じてくれてる？　お尻の穴で……ンンッ、ますます、オチ\nンチンをおっきく膨らませて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くはぁっ！　あなたが気持ちよくなると、私まで気持ちよくなっちゃう。お\n尻がいやらしく動いちゃうのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、お尻が止まらないっ！　どんどん気持ちよくなっちゃう！\n　お尻っ、くふぅっ、もっとずぼずぼしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻が、オチンチン出し入れされて感じちゃう、どうしようもないスケベな\n穴になっちゃってるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻でまた、イキそうになっちゃってる……！　んぁっ、無理っ、我慢だな\nんて、無理だよぉっ！　んふぅうっ！　はっ、はぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなただって、我慢しているでしょ？　さっきから、オチンチンがお尻の中\nでビクンビクンしているし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お互い我慢してないで、んぁっ、お尻で……気持ちよくなって……。んはぁ\nっ、はぁあっ、一緒に……一緒に、イこう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっくっ、アアッ、私もう……限界なの……っ！　お尻気持ちいいのっ、お\n尻っ、ああっ、クセになりそうなのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻の穴まであなたでいっぱいにされてっ、気持ちいいっ、気持ちいいぃっ\n！　ああっ、気持ちいいよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいのに止まらないぃっ！　お尻がっ、あなたのこと求めちゃうっ！\n　アナル奴隷だからっ、あなた専用のお尻だからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「思いっきり深くまで、オチンチン突き刺しながらっ！　精液、射精して……\n射精して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、キ、きちゃう……っ！　い、イクッ、イク、イク……イ\nッちゃう……イッくぅううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んはぁあああっ！　ああっ、ああっ！　きたっ、ンンッ、お尻にっ、はぁあ\nんっ！　あっ、ああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いっぱいまた、お尻に精液注がれてる……っ！　はぁっ、はぁっ、オチンチ\nンが、ビクンビクン震えてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「精液のっ、塊が……ああ……っ！　私の、お尻の奥に……な、流れ込んで…\n…くる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んはっ、はぁっ、お尻がまだ、イキまくってるの……っ！　んくっ、お尻が\n……ヒクヒクって、とまらないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。だめ……お尻がまだ、うずうずしてる……。オチンチン\nを意識すると……勝手に動いちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……ああっ！？　ぬ、抜いちゃうの？　今は、お尻に力が入らなくて、精\n液が溢れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んくぅっ！！　あっ、ああ……また、プラグを入れられちゃった……お尻に\n、栓をされちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こ、このまま、次の任務をするの……？　お尻に、あなたの精液をいれたま\nまで……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もう……スケベなこと考えるんだから……。でも……プラグがないと精液が\n漏れちゃうし……仕方ないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だから、任務から戻ってきたら……また、アナル忍者のエッチなお尻にたっ\nぷりご褒美をちょうだいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　おっ、おおっ、お尻にぃっ！　いっぱい、熱いのがかかてる\n……んんっ、んふぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「感じちゃうっ、お尻にびちゃびちゃ精液ひっかけられてっ、あっ、ああっ、\nイク、イク……イク……だめ……とまらないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んはぁあああぁぁぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ま、また……おもらしぃ……っ！　イキながら、おしっこしちゃう……はぁ\n、恥ずかしいのにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻でイッちゃうことも……おもらししちゃうことも……。クセになっちゃ\nったら、どうしよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも……。こんないやらしい私でも、あなたが興奮してくれるなら……気持\nちよくなってくれるなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000212_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私の全部は、あなたのものだもの……。だから、かまわないって思っちゃう\n……かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……んぅっ！？　また、オチンチンをおっきくしちゃったの？　また、私の\nお尻で……？　ふふっ、いいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いつかはあなたに捧げたかったお尻の穴だから。それに私も、もっとお尻で\n気持ちよくなりたいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お尻の穴があなたのオチンチンを覚えちゃうくらい、いっぱいお尻でエッチ\nしよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}