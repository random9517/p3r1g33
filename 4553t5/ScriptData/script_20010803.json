{
		"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ロッテたちが仲間になり、襲来者（インベーダー）を退けてから数日が経過し\nた……。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロッテぇ～。肩が凝った～」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　それでは、いつもの肉球マッサージをさせてもらいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150023" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああぁ～、気持ちいい～……ロッテの肉球マッサージは本当にクセになるな\nぁ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、車の中熱くない？　エアコンの温度調整する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150015" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「丁度いい温度だから、気にしないでいいぞ。それにしても、ＭＯＥの座席シ\nートはいつもふかふかで、最高だなぁ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様……書類仕事、全部片づけておいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150019" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クララはとっても優秀だなぁ～。ほら、よしよししてあげるから、こっちに\nおいで～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あうぅ……ご、ご主人様にナデナデされると、よくわからないエラーがたく\nさん出る……でも、イヤじゃないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150020" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「クララ、ズルいですよ！　私だってご主人様にナデナデして欲しいのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150024" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「私だって、もっといろんなところをカツマちゃんに触って欲しいわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150016" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これは事務仕事をした私へのご褒美だから……いくら姉さんやＭＯＥが相手\nでも、譲れない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150021" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんな喧嘩するなよ～。ほら、順番にナデナデしてあげるからさぁ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　嬉しいです、ご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150025" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「んっ……！　そこ、もっと触って……！　とっても素敵よ、カツマちゃん…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150017" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様……もっと頑張るから、いっぱいナデナデして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150022" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ご主人。ちょっといいですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150015" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジローじゃないか。どうしたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ロッテ殿とクララ殿と一緒に、ＭＯＥ殿の中で生活するようになってから、\n随分と様変わりしましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「仕事はこなしているみたいですが……そろそろその堕落しきった生活をやめ\nて、車から降りてきてはどうですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それに、この前言ってた男のプライドとやらは何処へ行ったのです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺だってこのままじゃダメだと思うけどさぁ～……こんな良い生活辞められ\nるワケがねぇよ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「好きな時に食べて、寝て、甘えさせてもらってさぁ。しかも仕事もやっても\nらって、シモのお世話まで……男からすれば、理想の生活だよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それを世間ではヒモというんですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様のお世話をするのが一番の使命です。私はご主人様が望むことは、\nなんでもして差し上げますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150026" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私もご主人様のためならなんでもするよ……基地での仕事なんて、私にかか\nればすぐ終わらせられるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150023" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの足になるのは私の仕事だもの。誰にも譲らないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150018" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんなんでしょうなぁ。このダメ人間製造機は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150020" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「か、カツマさん、これは一体どういうことですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあじゃないか。どうしたんだ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうしたもこうしたもありません！　ジュンジローさんから、カツマさんが\n堕落した生活をしているから、なんとかするよう頼まれたんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そもそも、このロボットたちはなんなんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ダメ人間製造三銃士ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150021" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダメ人間製造三銃士？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「甘やかしの専門家、ロッテ殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150022" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はい、よろしくお願いしますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150027" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「代理仕事の専門家、クララ殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150023" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様のために頑張る……よろしく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150024" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人の専用カー、ＭＯＥ殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150024" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの愛車よ、よろしくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150019" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「全然意味がわからないんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150005" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「簡単に言えば、ご主人を堕落させた原因のロボットたちですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150025" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「堕落って言われてもなぁ～。ちゃんと仕事も任務もこなしてるだろぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、それはそうですけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150006" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私たちがバッチリサポートしてるので、ご主人様のお仕事が滞ることは絶対\nにありえません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150028" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんの仕事は多岐に渡るんです！　それに、こんな堕落した生活だと\n健康面も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150007" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様の肌艶は出会った頃よりよくなってる……私たちが側にいてずっと\n体調管理してるから、当然だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150025" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）への対応だって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150008" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「昨日の襲来者（インベーダー）退治も、ちゃんと現場にカツマちゃんは居た\nでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150020" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「本当にその場に居ただけじゃないですか！　戦いは他の人に任せっきりだし\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150009" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人が戦いで役立つことはないので、ロッテ殿たちが戦うのは効率的では\nありますけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150026" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「と、とにかく！　このままカツマさんを堕落させるわけにはいきません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150010" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「なるほど……つまり貴方は、私たちがご主人様のお世話をするのが気に入ら\nないと言いたいのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150029" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なっ！？　ち、違います！　これはあくまでも一般論で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150011" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「じゃあ、ご主人様をイジメにきたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150026" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんをイジメるなんて許せないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150021" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「話が通じない……！　こんなの、私一人じゃどうにもできないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150012" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はてさて、どうしたものですかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150027" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}