{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はー、もう、よっわよわのくせに、数だけ多くて面倒だったー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020022" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦いを切り抜けた３人は、魔法石を持ったまま逃走。ひとまず、市街の外れに\nある公園に身を隠していた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「うん、周りに誰もいないみたいだし、ここならちょっと休憩できそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020023" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……さ、さすがに体力的に少しきついものがあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020017" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「むー、お菓子、ちょっと食べただけだし、もうエネルギー切れ……しょんぼ\nり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020013" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「なによー、テンション低ーい！　ちゃーんとお目当てのお宝は持ち逃げでき\nたんだし、オールオッケーだしー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020024" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「そうは言っても……ずいぶんと大騒ぎになってしまいました。これでは噂が\n魔女王の耳に入るのは確定的かと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020018" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……またお説教される？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020014" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「べっ、別にあんなオバサンのお説教とか、怖くないしー！　だって、ピコさ\nまたちはいよいよサイキョーの力を手に入れるんだから！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020025" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「もうあんなハンマーにびびって逃げるとかしなくていいしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020026" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「そう簡単にいけばいいのですけど……私としては、かなり楽天的すぎる考え\nかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020019" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「オバサン……怖い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020015" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫だから！　ピコさまたちトリプル・クラウンはサイキョーで無敵\nだしっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020027" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あんな、いつまでも婚活失敗してばかりの哀れすぎるオバサンに頭を下げる\n毎日、終わらせるんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……ピコ、ちょっと足、震えてるー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020016" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふ、震えてないし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020029" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……魔女王は地獄耳なので、あまりその……挑発的な言葉を吐かないほうが\n、安全的には賢明かと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020020" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「もう、ティアは心配しすぎー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020030" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そんなことより、この魔法石、どう使えばパワーアップできるんだろ。ティ\nア、知ってるんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020031" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「そうですね。ひとまず、その石から魔力を抽出し、それを効率よく取り込む\nことができれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020021" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「こうして少し眺めているだけで強い魔力を感じられる、魔術的にとても興味\n深いものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020022" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「早く戻って、落ち着ける場所で研究したいところですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「えーっ、こう、石に願いを込めればすぐにパワーアップとか、そういうお手\n軽な方法ないのー？　ぶー、ぶー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020032" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「もう、そんな直接的な方法でどうにかできるほど、魔法は甘いものではあり\nません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020024" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「どちらにしても、この辺りに長居していては追っ手に見つかるでしょうし、\n早く移動を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020025" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー……もう、遅いみたーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020017" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ミランが指さす向こうから、女怪人が戦闘員を引き連れて駆けてきた。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「はっ、見つけたぞ、こそ泥娘ども！　我らが狙いをつけていた宝を横取りな\nど、許すと思ったか！！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「えーっ、あれだけぼっこぼこにしてあげたのに、まだ諦めないで追ってくる\nのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020033" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「というかー、怪人なんかでチョー強いピコさまたちをどうにかできると思っ\nてるなら、頭の中までざっこざこ過ぎてウケるんだけどー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020034" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員" ]},
		{"command":[ "SETTEXT", "「黙れ！　今度はさっきのようにはいかないぞ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「そのとおり！！　戦闘員どもが世話になった分、たっぷりと礼をしてやろう\n、道化師どもがっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はぁ？　だから、ピコさまたちは道化師じゃなくて王冠だし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020035" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ピコ、落ち着いて……この数なら、幻惑の魔法で誤魔化して撤退という策も\n現実的ですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020026" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はぁー？　こんなざっこざこ相手に逃げるとか、マジありえないし。普通に\nぼっこぼこにしちゃえばいいって！　いくよー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020036" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁ……脳筋的過ぎて私好みではありませんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020027" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー……どっちでもいいけど、早く帰りたーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020018" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「なら、最初から全力でぶっ飛ばすわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020037" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}