		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、お、お尻にっ？　はいっ、ペンペンされてっ……赤くなったお尻に\nっ……ぶっ掛けして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
