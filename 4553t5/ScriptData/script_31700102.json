{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んくっ、うぅぅっ……こ、こんな……格好っ……くっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「別に……あっ、んんっ、するならするで……普通にすればいいじゃんか……\n自由を奪って……こんな風に、しなくたって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「し、躾……？　あたしが、その方が感じるからって……何、バカなこと言っ\nて……あっ、こ、こら……見るなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ダメだよ……うぅっ、そんな股間を……まじまじ……覗き込むなって……ん\nぁっ、濡れてるとかっ……い、言わなくていいからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……いよいよ今日は、するからって……あたしだって、覚悟し\nて……んっ、あぁ……指っ……か、かき混ぜてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁ……そんな、焦らさなくていいだろ……も、もう一思いに……\nんっ、入れてってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えっ……？　だ、だから……その、あんたのオチンポを……あ、あそこに…\n…ひぁうんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「何でお尻っ……あっ、叩いて……おねだりの仕方がなってないって……そ、\nそんなこと言われても……どうしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「や、やらしい……言葉……それ、は……ひぁんっ！　わ、分かったからっ…\n…ちゃんと言う通りにするからぁっ、お尻っ……許してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「それで、どんなことを……う、ぁ……それを、あたしが……言うの？　あっ\n、はい……い、言いますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はぁっ……お願い……しますぅ……あんた、じゃない……ご\n、ご主人さまのオチンポを……あたしの……オマ、ンコにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ、ご、ごめんなさいっ、ちゃんとっ……はっきり言いますか\nらっ、お尻っ……またらめっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「オ、オマンコッ！　あたしのオマンコにっ……ご主人さまのっオチンポッ…\n…入れて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「も、もっといやらしく！？　あぁっ……だからっ、あたしの……エッチで、\nはしたなくっ……汁を垂らしたオマンコにぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ご主人さまの……大きくて、立派なオチンポっ……！　ずぶってオマンコに\nっ、ハメてっ……下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「くひぃぃぃぃぃぃぃんっ！　あぉっ……入って来るっ……おっ、オッ……オ\nチンポぉっ、奥に、ずぶって……来るぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁ……深いとこまでぇ……んくぅ……届いて来るのぉ……はぁ\nぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっくぅ……痛いのは……そんな、でも……ないけど……くぅぅ……んっ、\nキツい……いっぱいになってる感じするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、うんっ、だ、大丈夫ぅ……動かしてぇ……あっ、はっ、んふ\nっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「くぅうん……あぁっ、大きい……ご主人さまのオチンポ……んくぁ……奥ま\nで……広げられてく感じ……するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「く……んんっ、はっ、ふっ、あぁっ……それで、あたし……ど、どうしたら\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「は、はひっ……オマンコっ……ぎゅって締め付けますっ……んっ、くぅっ…\n…これで……いいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　また、お尻……ぶたれたらぁっ！　あぁっ、もっと、頑張りま\nすからぁっ、んっくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ど、どうですか……？　んんっ、これでっ……んくっ、ちゃんと……出来て\n、ますかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぅんっ……あ、ありがとうございますっ……はぁ……んっ、後は……どん\nな風に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「オチンポが、どんな感じか説明……えと……今、あたしのオマンコの中を、\nずりゅって擦りながら……出たり、入ったりして、ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「特に……んんっ、ずぶって入って来る時に……お尻に力が入っ……あっ、そ\nの瞬間が……すごく、気持ち……いいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……また、ご主人さまの手が……お尻に当たってる……また、パチンっ\nてされちゃうの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ちが……期待してる訳じゃ……あっ、でも……そんなさすって……は、ひぃ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ……何で……お尻、叩かれてっ……痛い筈なのに……ジンジンしてる\nのに……あたし、何だか……気持ちいいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あぁっ、オマンコ……感じるから……んっ、お尻……気にならな\nくなってるの……？　一緒にすると……あぁっ、ホントっ、気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、ご主人さまも……出そうになってるっ？　はひっ、あぁっ、あた\nしっ……もうすぐ中出しされちゃうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いっ、いいですっ、出していいですっ……あひぃんっ！　射精っ……いつで\nもっ、いいですからぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、いいっ、いひぃっ、オチンポっ、いいっ！　あぁっ、な、\n中にっ……来てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んひぁぁぁぁぁぁぁーーっ！　あぁっ……出てっ……るのっ、中にっ……あ\nっ、精液……出て……るぅっ……んふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「精液……いっぱい……どぷって、あぁ……流れ、こんで来るぅ……んくぅぅ\nん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んはぁ……あぁ……あふっ、んぁ……からだ、ふわふわするぅ……あ\nぁ……あたしも……イッちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっく……はぁ……オマンコ……こんな感じになるなんてぇ……はぁふ……\nひゅごい……んっふぅぅ……あ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「本物のオチンポすごすぎるぅ……せっくすぅ……気持ち……いいのぉ……ん\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「して、下さって……ありがとう、ございまひたぁ……ご主人……さまぁぁ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　えっ、あっ……ま、まだ……続けてっ……あ、はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、くぅんっ……はっ、んふっ……オチンポ硬いまま……はひっ、が、頑\n張るぅ……このまま、して……下さい……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、出してもらった精液がっ……ぐちゅってっ……んっ、もう……全然\n……痛くないですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あふっ、後は……普通にっ、あひっ、気持ちいいのが……ずっと続いてる…\n…んんっ、オマンコの中からじゅわぁって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしい……汁が漏れてるの、分かっちゃう……んっ、あぁ……ちゃ\nんとお行儀よくしないと……ふぐっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ダメ……んんっ、漏れちゃう……あぁっ、またお仕置きされちゃう……あぁ\nっ、いやらしいミラに、お仕置きして下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　あぁんっ、お尻っ……叩かれてるのにっ、身体っ……ジンジン\nしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、い、一緒にオチンポ、ずぶってされたらぁっ！　おぉぉんっ！　\nオマンコッ！　オマンコきくぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はいっ、ちゃんとっ、あぁっ、頑張ってオマンコ締めますっ、オ\nチンポキュってしますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「だからっ、またズンズン突いてぇっ、あぁっ、ご主人さまぁっ、お尻ペンペ\nンもしてぇっ、はぁぁんっ、お、おかしくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はひっ、らめっ、これらめっ、また何か来てるのっ……ひっ、イクッ！　ん\nぁぁぁぁっ、オマンコがっ、またイッちゃうのっ、んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「イクッ、あひぉっ、イッてるぅっ！　オマンコいいのっ、止まらないぃぃぃ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、まだっ、ズンズン来てるっ！　イッてるのにっ、あぁっ\n、ご主人さまのオチンポっ、元気過ぎてぇっ、はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あたしもっ……んぐっ、頑張って……キュンってするのっ、ちゃんと……オ\nチンポ感じてもらうのっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、今度はお尻……撫でられてる……熱くなってるの……そんな、優し\nくさすられたらぁ……また、気持ちよくなっちゃうのにっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、んくぅっ……気持ちいいっ、くぅぅんっ、オチンポッ……\nあぁっ、どんどんよくなってくのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ご主人さまぁっ！　もっとっ、あひぁっ、もっとオチンポして下さいっ！　\nあたしのオマンコッ、絶対逆らえないように躾けてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ズボズボっ、グリグリってっ、いっぱいっ、いっぱい気持ちよくしてっ！　\nまたっ、あぁっ、身体中っメロメロにさせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あひぁっ、ご主人さまものオチンポも喜んでくれてるっ……！　うんっ、オ\nマンコの中で……ビクってしてるのっ、分かるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「もうすぐ……あっ、はひっ！　出るのっ、分かりまひゅっ！　射精したくな\nってるのっ、オマンコ……分かっちゃいまひゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はいっ、続けて出して下さいっ……オマンコッ、子宮に出して貰いたがって\nるからっ、だから、このままっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「中にっ……ご主人さまの精液っ……赤ちゃんのもとっ！　全部出してっ……\nあたしのことっ、孕ませてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁぁぁんっ！　中っ……出てるっ！　また、ドロって……熱い\nのっ……出されてるぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104303" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、いっぱい……あふぅ……漏れて、来ちゃう……んんっ、あ\nぁ……オチンポ……凄いのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あたし……完全にご主人さまに躾けられちゃったぁ……もう、絶\n対逆らえないのぉ……んふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「え……？　言葉遣いは……戻していい？　ど、どうして……？　だって、あ\nたしはもう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「普通の方があたしらしいから……エッチする時だけ……ご主人さま……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……そういうことなら、うん……分かった。ご主人さま……じゃな\nい、えっと……あんたの言う通りにする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「でも、あたしの中にこんな一面があったなんて……あんたは……最初から見\n抜いてたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「次も……色々、教えてくれるんでしょ……？　その、また……待ってる、か\nら……」", "NORMAL" ]},
