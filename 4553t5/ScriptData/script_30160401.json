{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ……来たか。……ん？　何をそんなにビクビクしている。私の顔が怖い\nから……？　この顔は生まれつきだ。と、そうじゃない。今日は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「最近、何かと貴様に気を使わせている礼にだな。前に言っていた……夜のオ\nカズになる話というものを、１つ教えてやろうと思って呼び出した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「何のことかわからない？　貴様が言っていたんだぞ。私の卑猥な姿を想像し\nて、たまに自慰を楽しんでいると。新しいネタを提供してほしい、と！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……覚えていないのならやめにするか。……なんだ？　聞きたい？　はじめ\nから素直にそう言え。コホン……この事は他言するなよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私は、鍛えに鍛えたこの肉体を……そちらの方向でも活かす方法を編み出し\nた。それが……下着のままの着衣パイズリ……というものだった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403105" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ハハ……やはり、思った通りだった。貴様……。私にこうして、運動直後の\n汗臭い胸にチンポをキツく挟まれたいと思っていたんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001604_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いつからこんなにしていたんだ？　こんなに腫らしていたのなら……誰かに\n気付かれていたかもしれないぞ？　恥知らずのスケベチンポめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ……私に気付いて欲しくて勃起させていただと？　本当かどうか怪しい\nものだ。貴様は誰でもいいんだろう？　どうだ？　……はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こうしてパイズリをしてくれる女なら……。が、私に頼んできたのは正直、\n悪い気はしない。特別にしっかりサービスしてやろうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「フフ……嬉しそうな顔をして……。まあ、いい。最近貴様はよく努力してい\nる。ご褒美だ……たっぷり搾り取ってやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私には男の悦ぶ力加減などわからないからな。痛みを感じたらすぐに伝えろ\n。そうでなければ……おとなしく、されるがままでいるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「確か……貴様が好きな動き方は、こうだったか……？　ンッ……。多少不器\n用なのは許せ。……乳房を絡み付けて……大きく上下して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ふっ……。ふぅっ……ふ、う……はぁっ。ハァッ……はぁ、はぁ……♪\n　ん？　乱暴に、胸にもみくちゃにされるのは嫌いか？　ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「少し強いくらいがいいんだろう？　んっぅ……っ、は、ぁ……はぁっ、はぁ\n……♪　チンポの形に添って……裏筋も亀頭も全て刺激する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ、こう、か……？　はぁっ……これでいいのか……？　ふぅっ……♪　\nふぅ、ふ、ぅ……んんっ……。ああ、間違っては……いないようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「チンポがいちいち、敏感に反応して貴様の気持ちを代弁してくれている……\n。やっぱり、強めに攻められるのが好きなんじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そう焦るんじゃない……。何もかも私に委ねろ。……っふっ……♪　ふぅっ\n……ふぅうっ……。腕で乳を持ち上げ、て……寄せて絡めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「グニグニ、と絶え間なく密着させて……。はぁっ♪　貴様の良いところを探\nり当ててやる……。んっ……ふぅっ、ふぅっ……ふぅううっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ん？　乳房の形がどんどん変わって面白いだと？　んッ……♪　貴様の\nチンポが硬すぎるから……っ、柔らかい肉が歪む、んだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私には肉棒が生えたことがない、から……よくわからないが……！　っふぅ\nっ……、男とは皆これほどまでに頑強なペニスをしているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「胸で挟んでシゴくのも、……んぁっ、一苦労だ。ずっしりと重くて、みっち\nりと詰まっていて……、見るだけで心臓がザワザワする……。っふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「女を狂わせる魔性の棒……。グ、グロテスクな形をしているのに……私の乳\n房に甘えるように近づいてきて……。も、もぐりこんで、きて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぁぁうう……♪　ゴリゴリと硬く変貌し……。っふっ……、ふっ、あっ…\n…♪　自身の存在をこれでもかと主張して、くる……♪　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ふっ、ふぅっ、ふぅうっ……ふぅ……♪　パイズリというものは、とて\nも心地いいもののようだな。表情がだらしなくなっているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「癒される……？　ふぅむ……？　そんな卑猥な表情で言われても信用出来な\nいな……。とろけた、バカな顔をして……。ンッ……！　うぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「乳房に突き刺さりそうなほど……！　チンポをそそり勃たせておいて……。\nんぅっ♪　はぁっ……はぁ、はぁっ……はぁああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そ、そんなに良いものなのか……？　パイズリ、は……。貴様が夢中になる\nほど……。んっ……。んぅっ……ふぅっ、ふぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私のやり方なんて、そう上手くもないだろうに……。こんなに、こんなに硬\nくして……馬鹿者が……。あっ……！　おい、何をしている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こらっ、自分から股間をすり寄せてくるんじゃない！　動き、にくい……ん\nっ！　私の胸を勝手に使うな！　うっ♪　わ、私を感じさせるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私……が気持ち良くなってどうする！　これは貴様のための奉仕なのだから\n……。一人でよがっていればいいだろう。ん、邪魔をするなよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こっちだって、別に慣れているというわけじゃないんだ。チンポに尽くした\nりなんて、普通鬼はしない……。私だって貴様にくらいしか、しない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それなのに……。んっ！　んん……！　貴様はいつも、私の拙いパイズリで\nこんなに大喜びして……。本当にどうしようもない……！　あっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だから許可なく動くなと！　……はぁ？　キンタマから精子あがってきて我\n慢できない？　今にも出そう？　知るか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様のタイミングで射精させるほど、私は優しくない。……んっ？　おいっ\n……！　腰を振るな！　胸が、胸が摩擦で熱くなって……！　うあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こすれ、る……！　あっ！　き、貴様ぁ……！　私の善意を利用して気持ち\n良くなるなぁ！　あっ♪　おっぱいを犯すな、突き上げる、なぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ううっ！　我慢汁でニチャニチャしたチンポが……胸の間をズプズプと\n犯してくる……！　わかった！　わかったからもう射精しろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「一度射精して少しは落ち着け……ッ！　ん、ぁ……！　私も協力してやるか\nら……！　乳房で思い切り押し潰して……こう！　搾り抜いて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うっ……！？　うっぁっ、あっ……！？　なんて勢いだ……！　あっ、私の\nおっぱいが……白濁に染められていく……！　あっ！　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「心臓に染み込むかのような熱さだ……。あぁ……♪　ドキドキと、自分の鼓\n動がうるさくてたまらない……！　プリップリの元気な精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……ンンッ！　ま、まだ出すのか……！　落ち着きがないな！　……あっ…\n…♪　こ、これ以上は垂れる……！　やめろっ、やめ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁあああ……♪　これだけ出しても、貴様のチンポはまだ萎えないのか…\n…。まあ、だからこそ責めがいがあるというものかもしれないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「当然、このままパイズリを続けて欲しいんだろう？　貴様のイチモツは、私\nの胸が好きで好きでたまらないと言っている……違うか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ハハ……。遠慮しなくていい。こちらも、体力だけは無尽蔵にある。この程\n度のパイズリで、疲れたなんて甘ったれたことは言わないさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いくよ……。……ンッ……♪　ん、はぁっ……は、ぁ……はぁ……！　ああ\n……。この、もったりした臭い精液の臭い。久しぶりに嗅がせてもらった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これを胸で混ぜ合わせると……んんっ、オスの臭いがたちこめて……。鼻か\nら肺いっぱいに、貴様の臭いが充満する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……なんだ。嫌がっているわけじゃない。ただ……気分は若干高揚する。こ\nれを私が引きずり出したのだと思うと……悪い気分じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「と、精液の感想などどうでもいい……！　パイズリを続けるぞ。精子のぬめ\nりで摩擦しやすくなっているな。もっとキツくいくぞ……！　ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んんんん……ッ♪　おおぉっ♪　こ、これは……んんっ♪　こちらにも感触\nが生々しく伝わって……ああっ、おかしな気分に、なる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぉっ……♪　う♪　ぁ……ああっ、あっ……♪　ぉっ……♪　おっ……お\nぉ♪　ニチャニチャして……ああっ、す、すごい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それにしても……。ん、ふ……♪　随分と反抗的な態度のチンポだな。せっ\nかく分厚く、柔らかい私の胸で包みこんでやっているというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「離せ離せと、暴れているかのように反り返ってくる……。ククッ……貴様ご\nとき、私の胸から逃れられるわけもないというのに……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ははっ……逃がすものか……！　くぅっ……♪　ふぅううっ……！　貴様の\nモノは既に私の支配下のもとにある……。あきらめ、ろ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「体重をかけて……思いっきりシゴき抜いてやる♪　……んんっ♪　んっ、は\nぁああっ♪　うっ♪　うぅ……っ♪　んぅっ、ンッ、んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「フフフ……情けない嬌声を漏らすんじゃない。男の弱点を、容赦なく乳房で\n責めたてられる気分はどうだ？　降参したくなって、きたか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「大胆に揺れる私の胸……。あっ♪　ユサユサと重たげに跳ねるこの乳房を見\nて、精液をまた作っているんだな……♪　伝わってくる、ぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「肉棒がはりつめて……。んっ♪　射精する準備をしているのがわかる♪　は\nぁっ……、この胸にたっぷり種をつけようとしているのだろう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁああ……♪　やれるものならばやってみるがいい……\n♪　んふぅっ……傲慢にこの胸に、精液を注いでみろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「乳房から溢れて……。あっ♪　ぼたぼたと零れ落ちるくらい大量に出せばい\nい……♪　んふっ……、んん……ドクドクとチンポを脈打たせながら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私のっ♪　胸を汚すんだ……。っ……は、ぁ……♪　はぁっ、あっ……♪　\nなあ……チンポがビクビク震えているぞ。これは合図だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……また精液をほとばしらせたい？　好きにするがいい。だが、私に迷惑は\nかけるなよ。おとなしくこのまま、胸の中に射精しろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……そうっ！　そう、そうだ……！　ハハッ、私も精子を搾り上げてやる！\n　そのまま出せ……！　尿道口から精液を噴出し続けろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん……うっ♪　ぉっ……おぉ♪　うう……♪　これはすごいな……。シゴけ\nばシゴくだけ溢れ出してくる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「さっきスッキリするまで出したくせに、少し胸に押し潰されて、いじられた\nだけでこの有り様……。貴様は危険な男だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「他の者たちに迷惑が、……んっ♪　かかる前に……私が定期的に抜いてやる\nしかなさそうだ……。そら、どうだ？　全部出しきったか？　ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まだ出そうか……？　っんっ……！　噴水のように噴き上がって……っ、あ\nぁ……。うっ……♪　くぅ……♪　このっ、まだ出すのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぅ……！　はぁっ……はぁ、はぁ、はぁああ……！　貴様の白濁汁が、私\nの胸に白い層を形成しているぞ。二重どころじゃない量だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん……。私の汗の香りに混じって、すえた精子の悪臭が……。だが、しかし\n……ここまで射精したということは、気持ち良かったのだろうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「喜んでいいのか、この後の処理に困るか迷うところではあるな……。ハハ、\nびゅるびゅると精液を搾り取られる貴様の姿は見物だったが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「どうだ？　なすすべもなく女の私にしてやられた気分は。……何？　最高だ\nった？　またしてほしい？　……ちょ、調子に乗るな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「今日のコレは褒美だったのだから……！　ま、また褒美がもらえるように勝\n手に努力すればいいだろう。それは貴様の自由だからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ん？　なんだと？　私の顔にぶちまけたい……？　この顔に射精したいと言\nったのか？　今……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「き……貴様は本当に変態だな。私の顔をザーメンで汚したいのか？　そんな\nことをして何を得られるのかはわからないが……ククッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それを期待して、貴様がグイグイと腰を押し付けてきていること……。興奮\nしてチンポを破裂寸前まで高めていることは私にもわかる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「出来るものならやってみればいい。この私の顔に、子種をまき散らす覚悟が\nあるのなら……。と、き、貴様！　少しは悩め！　うっ、や、やめろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「グイグイ来るんじゃない！　おいっ……本当に顔に出す気、なのか！？　あ\nっ……！　胸で、胸でいいだろうっ……なあ！？　あっ、こらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぉぁあああああっ……！？　あっ！？　本気かっ！？　あっ……！？　顔\nに！　私の顔に粘り気のある精液が……！　あ、あ、ああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403406" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ！？　口っ……口の中に入れるのはやめろ……！　うぁっ……！　んん\n……！　唇にべっとり生温かい感触が……！　んぷ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様ぁ……ッ！　誰がここまで自由に射精していいと許可した……！？　見\nろ、ぬぐい取れないくらいに大量の白濁液にまみれてしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……気持ち良すぎて飛距離が出てしまった……？　ほう……。確かに、この\n飛ばしっぷりは世界記録並みだったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403409" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「射精の勢いを競う競技があれば、貴様はかなり上位に食い込めるのだろうな\n……。ああ……この有り様を、どう処理したものか。参ったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0403410" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}