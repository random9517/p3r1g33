{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0123" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_006" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……本格的に日が暮れちまったな。なのに、雨が止む様子もなければ、長官\nが帰ってくる気配もなしか……」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まあ、戻ってこられないよね。この大雨じゃ。下手すると、県道が通行止め\nとかになってるかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106070001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だな。いつまでもこうしててもキリがないし、とりあえずメシでも食おうぜ\n。なんか食えるもんあるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もともと自炊する予定だったから、食材は持ち込んであるわ。なにか作りま\nしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうね。ところで、エファナティカだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106070002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「呼びに……行く？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……そのほうがいいよな。あいつも腹は減るだろうし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「…………ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "全員が不安そうな顔を見合わせる。やっぱり、どうしてもルナテミスの件を思\nい出すからな……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「やはり、みんなで動いたほうがいいでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、いうわけでぞろぞろとエファナティカの部屋の前までやってきたが……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「エファ。これから飯の準備なんだ。おまえも来いよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………返事がない。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「エファ？　なにやってんだ？　エファ！　出てこいってば！　エファ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106070003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……！　まさか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エファナティカ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なんてこと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「冗談じゃねえぞ……！　エファまで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106070004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どういうこと！？　いったい誰が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106070003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0061" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「…………っ！　全員、その場を動かないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　どうした！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こういうときは、まず遺留品探し！　ダイヤナちゃん、二時間ドラマをよく\n見るからこういうの詳しいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「遺留品？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「たとえば、どんなものを？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106070001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だから、えーと……えーと……あ！　あれ！　ダイニングキッチン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ダイニング……キッチン？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010106070005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダイイングメッセージと言いたいんじゃないかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そう！　それ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ダイイングメッセージはありませんでしたが、ノートパソコンは開かれてい\nました。どうやら、メールチェックをしていたようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「死因は、おそらくルナテミス様と同じ。鈍器による頭部への一撃。ですが、\n後頭部ではなく前頭部寄りの左側頭部から打撃を受けていますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070007" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「おそらくエファナティカ様は、そこの机に向かってパソコンを見ていた。し\nかし背後から忍び寄った何者かに気づき、振り向いたところを殴られた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070008" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「と、すると、犯人はそちらのドアから入ってきたはずですが、今私たちがド\nカドカと踏み込んでしまったことで、痕跡が消えてしまっているかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070005" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070009" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「セレーナ、なにか遺留品はないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「足跡は残ってないな。でも、こっちに日本酒の瓶とグラスが転がってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106070005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「飲みながら仕事をしていたということでしょうか。エファナティカ様らしい\nですね。ですが、それでは手掛かりにはなりません。他には？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070007" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070010" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ん？　これは……この机のへこみは、殴ったときに勢い余ってついちゃった\nのかな……？　木が削れたばっかりのようなにおいがするぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106070006" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なるほど。凶器を特定する手掛かりになるかもしれません。よくやりました\n、セレーナ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070008" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……………………！　んもぉおおおおお～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070011" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、なんですかダイヤナ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070009" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そういうの、ダイヤナちゃんがやろうとしたのに！　やりたかったのにぃ～\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070012" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………あのな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……わかりました。ではダイヤナは、そちらの窓を調べてみてください\n。侵入経路がそちらと言う可能性もゼロではないので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070010" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っ！　わかりましたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106070013" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "体よく追っ払ったな。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カツマさん、あなたはドアの外を調べてみてください。押し入ったときの痕\n跡が残っているかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070011" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺もか？　まあ、いいけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ん……？　オボロ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070005" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どうしました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070012" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんを一人で外に出しては、危険では……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070006" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070013" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわああああああーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「しまった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106070014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010106070007" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今行くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106070002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおおーいっ！　どうなってんだ！　誰か助けてくれーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "廊下に出たとたんに、正体不明の黒い影に――こいつら、何者だ！？", "NORMAL" ]},
