{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あの……秘密の特訓と聞いてやってきたわけなんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00013101_01", "5", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ど、どっ、どうして隊長さんは……その、えっと……それを出してるんです\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おちんちんを……し、しかもあり得ないくらいおっきくなってますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もしかしてこれ、私の特訓じゃなくて隊長さんの特訓なんじゃないですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そんなことはない？　これを触って……えぇ。わぁ……！　こんなに熱いん\nですね……それに、硬い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんっ、ビクビクって脈打ってる……これを、えっ？　お手々で……ええ。\nこんな特訓があるなんて知りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ？　いま気持ちイイって言いませんでした？　ええ……これを舌で舐め\n……えっ。えーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「これは特訓じゃありませんね、違いますか？　はぁ……やっぱり。私に気持\nち良くして欲しかったんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103108" ]},
		{"command":[ "SETCHARA", "0", "char_00013101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あの……と、特訓じゃなくても、いいですよ。隊長さんにはいつもお世話に\nなってますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103109" ]},
		{"command":[ "SETCHARA", "0", "char_00013101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「こういう恩返しもいいかな、って。でも、どうしたらいいのか分からないか\nら……教えて下さいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「片手で玉を支えて、揉んだり、転がしたり……こう？　えっ、上手いですか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103111" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「褒められると嬉しいものですね……おちんちんをしごいて、い……痛くない\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もっと強く？　分かりました、こうかな……もっと？　ええ……こ、こんな\nにしても痛くないんですね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「先っぽを舐める？　咥える？　んんっ……分かりました、はぁ、はっ……い\nきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あむ、ちゅるりゅっ、ちゅるる……んっ、ちゅぱ、ちゅうぅ、んあぁ、熱ぅ\nぅい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「熱い棒をしゃぶってるみたいです……んちゅ、ちゅぷぷ、んふぅぅ……えっ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「とっても上手い？　そんな……隊長さんこそ、人を褒めて伸ばすんですから\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ本当に上手なんですか？　い、いえ、こんなことしたのはもちろん初め\nてで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もっと深く咥えて欲しいんですね……じゃあ、やってみます。あむっ……じ\nゅぷぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もごもご、じゅっぽ！　じゅっぽ！　頬をすぼませて……？　んじゅむむ、\nじゅむみゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふぅ、いまきっと私……とっても変な顔になってます……んんぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やあぁん、こんな時に可愛いだなんて褒めないで下さい、ドキドキしてきち\nゃって……んんぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んみゅううぅ！！？　ふぇ……！？　私の頭を掴まないで、んんん～～～っ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「喉ぉ、奥っ、深くまで入ってる、入ってます……けふぉ！　えふぉ！　じゅ\nるりゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ！　じゅぷぷ！　じゅぷぷ、じゅるるりゅ！　じゅぷ！　じゅっぷ\n、じゅぷぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えほっ！　けほっ！　えほぉ！！　はぁっ！　はあぁ！　はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もぅ……ひどいですよ、喉までおちんちん突きこむだなんて……えっ？　あ\nれが気持ちイイんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ……と、それなら、私が、します。ムリヤリされたら苦しいけど、きっ\nと自分でやったら……はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「いきますね？　じゅむみゅ……あむぅ、じゅぷぷ！　んっ、ん～～っ！　じ\nゅぷぷ！　じゅむみゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「くぽっ、くぽっ……んふぅぅ！　りゅぷぷぷぷ……！！　ぢゅっぷ！　ぢゅ\nぷ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふぅ！？　出る？　せっ、精液が出ちゃうんですか？　んんぅ、あぁ……\n来て下さいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゅむむ！　じゅっぷ！　じゅぷぷ！　じゅむみゅ！　じゅるるる……！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅるりゅ、じゅっぷ、じゅぷ……んっ、ん～～～っ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んぎゅ！！？　んふああぁぁ……！！　ごきゅっ……！！　えふぉ！　けふ\nぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……そんなぁ、喉の奥で射精するなんて、ひどいです……んあぁ、\n思わずごっくんしちゃいました……はぁ、はあぁぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふぇ？　全部、飲んで欲しい……？　わ、分かりました……じゅむ、じゅぷ\n、ごきゅっ……ごっくん……んふぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「…………あぁ、んふぅ。ぜ、全部飲めました、よ？　あぁ、顔にも髪にも…\n…いっぱいヌルヌルの精液がついちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00013101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「こ、これ以上したいって……え、えっと、それってもっとエッチなこと、で\nすよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わ、私もあなたのこと……もごもご……い、いえっ、何でもありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「でも、あなたの気持ち……分かりました。ち、近いうちにお返事……きっと\n、お返事しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}