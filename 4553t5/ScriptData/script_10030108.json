{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そもそも、ルナテミスたちがなぜ虫採りをさせられているかと言えば……？", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいだろう。書類仕事……じゃなくて……カツマのため……でもなくて！　\nえ、えーと、あれだ！　仲間のためだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「仲間のため！　仲間を救うためなら、どんな危険な任務でも引き受けよう！\n　そう、それ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなた、報告書通り面倒な性格をしていますね。まあ、そのことは置いてお\nいて……お願いしたいのは、蝶の捕獲です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「蝶か！　相手にとって不足は――え？　蝶？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「蝶です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「虫の？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「虫のです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114700003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ！　わかった！　なんかこう、すごいでっかい蝶なんだな！？　双子の美\n人の歌声を聞かせないと暴れ出す、とかそういう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「普通サイズの蝶です、暴れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114700004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんで……そんなものを？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「たいへん希少な蝶なのです。惑星バタフライに生息する『クリスタルモンツ\nキハカマアゲハ』という蝶を、無傷で捕獲してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114700005" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、この話を聞いたインクレディブル・スクワッドの面々は……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「蝶々？　虫？　捕まえるだけ？　それが条件？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はははっ！　楽勝じゃーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それでカツマさんを取り戻せるなら安いものです！　行きましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "そして、意気揚々と『惑星バタフライ』に乗り込んだインクレディブル・スク\nワッド。彼女たちがそこで見たものは！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うわああああああああ～っ！　蝶だらけだぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「惑星一面に咲き誇る色とりどりの花……その上を乱舞する蝶、蝶、そして蝶\n！　蝶の大群！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こりゃ、数百万匹はいそうだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は、話が違ぁ～～～～うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「と、とにかく片っ端から捕まえてみるしかない……！　カツマのため、カツ\nマのため……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、帰りたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなわけで彼女たちは、惑星バタフライで蝶の捕獲を続けていたのである。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのとき！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ！　ルナ様～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっちにそれっぽい蝶が～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114700003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あれは……！　間違いなくクリスタルモンツキハカマアゲハ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114700003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「データ照合！　９９・８７％一致！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114700002" ]},
		{"command":[ "SETCHARA", "0", "char_00001499_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　みんな捕まえろ！　絶対逃がすなぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114700010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おおっと！　そうはイカのなんとやら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なっ！？　お前は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あの蝶は、お前らには渡さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んだとぉ～！　邪魔すんじゃねぇ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114700004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}