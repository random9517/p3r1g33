		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、ああ……っ！　お、オチンポきた……ぁ……っ！　すごく、太いのが\n……オマンコいっぱいにひろげながら……きて……！」", "NORMAL" ]},
