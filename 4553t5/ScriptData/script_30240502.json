		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んぁっ、気持ちを口にしたら、変なスイッチ入っちゃったかも……。身体が\nすっごく熱いわ、おかしくなってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ねえ、もっとちょうだい。オチンポでもっと、私のオマンコをかき回して…\n…っ！」", "NORMAL" ]},
