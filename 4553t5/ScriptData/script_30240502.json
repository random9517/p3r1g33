		{"command":[ "SETIMAGE", "0", "still_00002405_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「今度はおしひろげられるのっ！　オチンポが、どんどん奥まではいってくる\n……これ以上は無理なのに、一番深いところまで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、本当に、ダメだってば……！　んっ、う、動いちゃダメなの\n……き、気持ちいいからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「オチンポが、出たり、入ったりするたびに……ご、ゴリゴリって、先っぽが\nイイところに、当たってて……あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「わ、私を感じさせるために、わざと当ててやってるって、いいたいわけ？　\nんっ、そんなこと、別にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「だって、そんなことされたら、私ばっかり感じちゃう、じゃないの……！　\nあんっ、だから、そんなに……んひゃぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「どちゅって、奥……きたぁ……っ！　んぁっ、ああっ、今度は奥ばっかり、\nズンズンって突くの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「先っぽが、子宮に届いてる……！　んぁっ、ああっ、グリグリって押し付け\nるの……子宮持ち上げられてるの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んぃっ、いちいち言われなくても、自分で……わかってる……！　んぁっ、\nき、気持ちいいの……あなたのオチンポ、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「イイとこ擦りながら、奥までズンズンくるピストン気持ちいいのぉっ！　ん\nぁっ、ああっ、もうダメ、全部バレちゃってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「私の感じるところ、あなたにみんな知られて……んっ、ああっ、なすすべな\nく気持ちよくされちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「こんなに私の身体……オマンコのこと知りつくすなんて……。あ、あなた…\n…どんだけ、私が好きなのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ねえ、好きなんだったら、そう言ってよ……。あなたの口で、あなたの気持\nちを伝えてほしいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ん……っ！？　そ、そんな……耳元で優しくささやかないでよ……。ひゃぁ\nっ、た、確かに言えって言ったの、私だけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「そんなふうに、言われると……。嬉しくて、恥ずかしくて……。んぁっ、だ\nめ、オチンポ動かしながら、何回も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「『好き』って、そんなに……んっ、ああっ、私だって……私だって、あなた\nのこと大好きなんだからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「大好きだから、濡れたオマンコで王子様のことユーワクしちゃうの♪　ピス\nトンされながら、エッチなお汁いっぱい溢れさせちゃうのっ♪」", "NORMAL" ]},
