		{"command":[ "SETIMAGE", "0", "still_00002405_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「愛液、どんどん溢れてくるって、当然じゃない。ンッ、ああっ、大好きなあ\nなたと、こうしてエッチしてるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「オマンコだって、最初っからあなたの精液欲しがっていたでしょ？　オチン\nポのこと、ぎゅうぎゅうっていっぱい締めつけて、うねって……」", "NORMAL" ]},
