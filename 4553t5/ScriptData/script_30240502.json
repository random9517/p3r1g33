		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、激しいの……きたぁ……っ！　はぁっ、はぁっ、じゅぷじゅ\nぷ、エッチな音しちゃってる……！」", "NORMAL" ]},
