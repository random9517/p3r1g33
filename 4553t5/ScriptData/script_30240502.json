		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「オチンポをガチガチに硬くしてるくせに……。ほら、早く。入れなさいよ、\n王子様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ンッ！　まだ焦らすの？　オチンポでワレメをなぞって……んっ、ああ、熱\nいの……当たってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「オマンコから、エッチなお汁がどんどんでてきちゃうから……んっ、んふぅ\nっ、もう十分濡れてるってばぁ」", "NORMAL" ]},
