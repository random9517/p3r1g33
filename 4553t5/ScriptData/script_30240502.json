		{"command":[ "SETIMAGE", "0", "still_00002405_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はいっちゃった……。オチンポが、私のオマンコの奥まで\n……はいっちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ふぅ……。やっぱり、すごい……お腹の中が、パンパンになってる感じ……\n。あなたの、大きすぎるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002405_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「ああっ、ちょ、ちょっとまって……んぅっ、う、動くの……まってってば…\n…！　んはぁっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「動いちゃダメだってばっ、んっ、んくっ、はぁあっ！　お、オチンポ……ん\nんっ、ずりずりって、中ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0504109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンキャリバー" ]},
		{"command":[ "SETTEXT", "「オチンポに、オマンコの中をひっかかれて……んふっ、くぅっ、お腹の中、\n引っ張りだされるみたいな……ぁあっ！？」", "NORMAL" ]},
