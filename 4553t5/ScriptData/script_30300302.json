{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふ……お忙しい時にお呼び立てしてしまい、申し訳ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今日は、他でもない……貴方にしかお願い出来ないことがありまして……\nもう、お分かりかも知れませんが……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……その、ずっと胸が張って仕方がないんです。その……母乳が溜まっ\nてしまいまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「このままでは、どうしても疼いたままになってしまいますので……どうか\n吸い出して頂けないでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「よろしいですか？　ありがとうございます……それでは、こちらにお座り下\nさい。はい、そこで……上から失礼致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304105" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……ではどうぞ……あぁ……はい、んっ、もう乳首から滲んでいるかと\n……あっ、お願いします……チュウって……吸って下さい……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003003_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁんっ……んっ、かなり出てしまうと思います。すごく溜まってしまって\nいて……ですから、おっぱいをよく揉んで頂いて……あっ、そうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、そうして……ぎゅっと……搾るようにして頂けると……あひっ、\n母乳が……あっ、出て来ますからっ……あ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……コリコリの乳首……吸われています……んんっ、母乳が止まらなく\nて……あひっ、チュウって……あんっ、はぁんっ、あ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、ここのところ……ずっと貴方におっぱいを可愛がって頂い\nて……すっかり、母乳が出やすくなってしまってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今も、こうして……あっ、先端を軽く摘まれてるだけで、疼いて……また、\n出て……んんっ！　あっ、吸われてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、ごめんなさい……どんどん溢れさせて……はしたないおっぱいで\n申し訳ありません……はぁっ、あっ、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「美味しい……ですか？　んっ、ふふ……そう言って頂けると、ちょっとだけ\nホッとします……多少なりとも私の我儘でご迷惑をお掛けしてるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そんなことないですか……よかった……あの、それでしたら……我儘ついで\nにもう一つお願いをしてもいいでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「その、貴方のミルクも欲しいです……私の足の下で、ずっと大きくされてい\nるオチ○ポ……オマ○コに頂けないでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、ずっと勃起されていて苦しそうなのは承知していましたので……私も\n、足の所に感じていましたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ですから、少しずらして……このまま、はぁぁっ、んんっ、入り……あっ、\nますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくぅぅっ……あぁ……硬いのが、あっという間にオマ○コに全部ハマって\nしまいました……あふっ、気持ち……いいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……こうして、奥にオチ○ポが届いてると……はぁ、内側から\nムズムズが強くなって……また、母乳が出ちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ、はい、もっと搾って下さい……新しく出る分も、いっぱい吸い出して\n頂いて……んんっ、出ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁ……右の乳首と左の乳首……こんな、いっぺんにされるなんてぇ……\nあぁ……恥ずかしいです……ミルクが止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、すっきりした飲み口……ですか？　んふぅ……自分で味わった\nことはないので、それは分かりませんが……あ、んむちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、じ、自分で自分の母乳を味わうというのは……変な気分です。そう\nですね……少なくとも、嫌な感じはなさそうで安心しました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　後はっ……はい、下からオチ○ポで……ぐりぐり……突き上げ\nて頂けたら……あひっ、あっ、おっぱいにも……刺激が届いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、また出ます……ミルク……あひんっ、新しいおっぱい出ますっ、\nんっ、んふぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁっ、あっ、すごいです……一生懸命吸って頂いて……乳首が、\nとても敏感になっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、乳房全体も……ずっと張った感じが止まらなくて……指で、ぎゅっ\nとされると……じぃんと気持ち……よくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、今の私の身体……とても淫らです……どこを触られても気持ちよく\nて……特に、あっ、このオチ○ポがぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あはんっ、あぁんっ……あぁ、ぐちゅぐちゅ……していま\nす……母乳だけじゃなくて……オマ○コのおつゆも溢れて来ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、はいっ……かき混ぜて下さいっ……私も、一緒に腰を振って\n……オチ○ポ……ちゃんと締め付けますから……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくぅっ……如何ですか……？　オチ○ポがキュってされるの……気持ち\nいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ、んんっ……はい……私も、とても気持ちいいです……おっぱいも…\n…オマ○コも……どちらも幸せになってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、はぁっ、あぁっ……出し入れがだんだん速くなって……あっ\n、はぁんっ、これはっ……射精が近いのですねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……はいっ、もちろん……このまま中に下さい……貴方の濃い\nミルクを……オマ○コに直接飲ませて下さいませっ、あっ、はひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁっ、私も……また母乳出ますっ……びゅるって……溢\nれて来ちゃいますぅっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ……出てる……んんっ、熱いのが……とぷんって……オマ○\nコの中を満たして行きます……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ、びゅくってされながら……母乳も飲まれてます……んふぅ…\n…お互いのミルクを飲み合うなんて……ドキドキします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……収まって来ましたか？　はい、私も……少しだけ、\n落ち着いて来たみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ、身体が……母乳と精液でヌルヌルですね……汗もかいてし\nまいましたから……とても暑くて……火照っています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……でも、離れないで下さい……このぬくもりが、私にとって……とても\n大切なものですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ところで……なのですが、まだミルクがおっぱいの中に残ってるみたいです\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「貴方さえよろしければ……もう少し続きをしてもらってもいいでしょうか？\n　はい、もっと私のおっぱいを味わって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……？　あ……ふふっ、貴方のミルクもまだ出し切れていないと……承知\nしました。そちらは私がお引き受け致します……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……こうして、ぎゅっと密着したまま……ゆっくり腰を回して……んっ\n、オチ○ポ……感じて頂きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、もういっぱいオマ○コに出して頂いてますから……はしたな\nい音がいっぱい鳴ってしまいますね……んぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この音……くちゅくちゅって……貴方のミルクとオマ○コが馴染んでいる音\n……あっ、聞こえますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ、はい……この音を聞きながら、あんっ、おっぱいを吸われると……\nあぁっ、とっても……興奮して……んくっ、疼きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、乳首……また、コリコリになってしまってますか？　はふ……あぁ\n……はい……また出ます……ミルク……あっ、出ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁっ、ごくごく……飲んで……私の母乳だけでお腹いっぱいに\nなったりしませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「まだ全然……いけますか……あふっ、とても頼もしいお言葉……あぁ……は\nい、お任せします……ぎゅっと搾って下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ……また出る……んくぅ……母乳が出る瞬間……とても、\nドキドキします……あぁ、それを……吸われてる時も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ふぁっ……んっ、舌が……乳首をくすぐって来ます……んぅっ、あん\nっ、悪戯っ子ですね……んふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「なら、私も……悪戯しちゃいます……このオチ○ポを……オマ○コでトロト\nロにさせちゃいますからぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、んくぅぅ……あぁん……ほら、気持ちいいですか……？　また、オ\nチ○ポ出したくなって来てませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あひんっ！　あっ、ふっ……！　私も……腰を……回しすぎてっ、あぁっ、\nイキそうに……なってっ……ますっ、あうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「このまま続けたらっ……あっ、はっ、またっ……新しい母乳も漏れてしまい\nそうでっ……全部……飲んで下さいますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、嬉しいですっ……して下さいっ……グリグリっ……オチ○ポ……突\nき上げてっ、オマ○コイカせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁぁんっ、イキたくなってますかっ？　あぁっ、このまま激しく\n突いてっ……イッて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ひぁっ、はっ、んくぅんっ！　後はっ……お好きにっ……私もイキま\nすからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「また……中でもっ……身体に掛けてもっ、いっぱいっ……出して下さいっ…\n…びゅくびゅくっ、射精……なさってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んうぅぅぅぅんっ！　あぁっ……入って来ます……中っ……オマ○コっ……\n奥に出てますっ……私も……イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あぁ……びゅくびゅく……熱いの流れてぇ……また母乳も\n……出て……ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……！　あぁ……飲んで下さい……はぁぁ……張ってるおっぱい\n……チュウって吸ってぇ……あふぁ、うっとりしてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、はい……後少し出そうです。えっ……貴方もですか？　ふふ……勿論\nです。ちゃんとオチ○ポの奥の分は残さず出してしまって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……ぁっ……！　出て来ました……んふぁ……最後の分が……びゅくっ\nて……溢れて来ています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ……母乳もやっと落ち着きそうです……あふぁ……ずっと\n敏感なままでしたから……少しだけホッとしました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ん……まだ、余韻が強く残っています……はぁ……オチ○ポが中を感じてい\nるからでしょうか……もう少しこのままでいさせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「でも、こんなにたくさん飲んで頂いて……お腹いっぱいになりませんでした\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「大丈夫でしたか……ふふっ、本当に頼もしいお言葉を聞けて、私はとても\n嬉しく思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「またおっぱいが張ってどうしようもなくなった時にはお願いしてもよろしい\nですか？　はい、ありがとうございます……では、また……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304310" ]},
