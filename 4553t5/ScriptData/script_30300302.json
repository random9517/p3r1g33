		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……オチ○ポ抜けてっ……はぁんっ！　あぁっ、お腹に……精液っ…\n…びゅくって出てますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304401" ]},
