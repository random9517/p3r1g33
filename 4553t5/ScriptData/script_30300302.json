		{"command":[ "SETIMAGE", "0", "still_00003003_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふぁ……私の母乳もまた溢れてっ……んんっ……あっ、イキ……ますぅっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁ……吸われてます……どんどん溢れてくるのを……いっぱい\n飲んで頂いて……あぁ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、精液……ヌルヌルです……オチ○ポがずりゅずりゅ擦れて……あ……\nまだ出ますか……？　はい、どうぞ射精も続けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ……熱いのがまた……んんっ……トロトロの精液と母乳が混ざりあっ\nて……はぁぁ……濃厚な匂い……興奮してしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……もうすぐ母乳も出し切れそうです……全部吸い出して下さい……あ\nっ、んんっ……！」", "NORMAL" ]},
