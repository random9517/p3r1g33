{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0121" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……そして、何日か後。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺達はＥＤＯの近所にある、とあるペットショップの経営するカフェにやって \nきていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここのウリは、とんでもない種類のペットと触れ合えることらしい」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふふふ、今まで争っていたエジプトの神々様方も、とっても楽しそうにして \nおりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ジュンジローの言う通り、３人の女神はここで思い思いの動物と戯れている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……おぉ、よしよし。よしよしよし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190001" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "寡黙でクールだけど、心には熱いものを秘めている……らしいメジェドは、ア \nヌビスの司る犬と。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……は、初めて……触った、けど……。猫も柔らかくて、あったかくて…… \n可愛いかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023190001" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そしてアヌビス本人は、自らの膝に乗ってきた、大きな猫をそっと抱きしめる \n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「にゃにゃにゃ！？　なんなのにゃ、このメジェドっちゅう生き物は！？　予 \n測不能にゃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023190001" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "猫の神様であるバステトは、小型のメジェドたちに群がられ、細い謎のビーム \nを何本も打たれていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あびゃびゃびゃびゃ、シ、シビレるにゃ……。シビレるけれども実害はナイ \nにゃ……っ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023190002" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ここにいるメジェドたちは本当に友好的……。よくしつけをされている…… \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190002" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、メジェド！？　メジェドがいるのかこの店には！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「メジェドとは、ペットショップで遊べるような種族でしたでしょうか……？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ、わからん……。しかし実際にいるんだから、いいのか？　ど、どうなん \nだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "困惑する俺とジュンジローだが、他の客は一切それに疑問を抱いている様子は \nない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「メジェドって、動物の一種っていうカテゴリーであってるか……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いいんスよ。エジプトではよくある事っス。あるあるっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ア、アーマーン……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイも、触れ合いたいエジプトの動物がいたら遠慮なくモフっちゃって \nくださいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「……この前のお詫びなんで。今日はあーしのオゴリですんで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ。ありがたく気持ちだけ受け取っておく」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「５人分のお金……払ったの大変、だったよね……？　ありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023190002" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ジュンジローパイセンの分も払ったんで、５人と１匹分の料金でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「な、なんですと！？　私めの分まで……かたじけない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ゆーて、あーしのせいで皆さんの仲がこじれてたワケですし。これくらいさ \nせてくださいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「……もちろん、もう今月は……節約生活しないとですけどね。トホホホ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そんなことを言いつつも、困り顔のアーマーンは両手両足に巨大な鳥を何羽も \nとまらせて楽しんでいる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……ジュンジローも、なでなで……したい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023190003" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わ、私はペットショップの犬ではありませんぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「それなら私は隊長さんをなでなで、する。モフるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190003" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ああッ！？　それって抜け駆けぇ！？　だめだめだめ、隊長君をモフるのは \nバステトおねーさんなんだから～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023190003" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、もう好きにしてくれ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "身体の左右前後をエジプトの女神にもてあそばれ、抱きしめられ、密着された \nり匂いを嗅がれたり。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……いい匂い。なめる。ぺろぺろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190004" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んにゃ～、なんか落ち着くぅ～♪　ねえねえ、おねーさんきみに膝枕してほ \nしいにゃ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023190004" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ、あ……。それなら私は、隊長さんを後ろからギュッてする……。ぎゅぅ \n～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023190004" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "エジプトの女神たちの、優しくも情熱的な愛撫を一身に受けながらだんだん眠 \nたくなっていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ペットショップ特有の、のんびりとした空気に身を任せていると……俺の頭の \n上に、一匹の小さなメジェドがのぼってきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あ、いいなぁ。メジェドがそんなにべったりくっついてくるなんて、なかな \nかないことなんだよ。良いこと……だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190005" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「メジェド……メジェドってなんなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どんどん数が増えたり減ったり、姿が現れたり消えたりもしていますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「究極に謎の生命体だぞ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "エジプト最大の疑問を残しつつも、なんとか今日からは……神様たちも心穏や \nかに過ごせそうで、一安心した俺とジュンジローなのだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「って、イイ感じにシメないでくださいよ！　まだ約束してたエジプトの宝を \n渡してないんで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190007" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、そうだった。俺は宝に目がくらんで協力してたんだった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が忘れていたのに、自分から申し出るとはアーマーンは律儀な性格をしてい \nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で？　宝っていうのは」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ここにいる大量のメジェド様たちから、一番好きなのを一匹連れて帰ってい \nいそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190008" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「スゴくないですか！？　神っスよ！？　神を持って帰れるんスよ！？　ささ \n、どのメジェドにしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023190009" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはいらん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「なに？　メジェドがいらない？　……みんな、ビームしてあげて。ビーム」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190006" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "その号令を聞いた途端に、俺に向かって細く弱々しいビームを浴びせてくる小 \n型メジェドたち。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やめろ！　いてててててて！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「もっと！　もっとビームを！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023190007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「にゃははは、やれやれ！　もっとやれにゃー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023190005" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "バステトが言っていたとおり、そのビームは……耐えられなくもないが、痺れ \nてだいぶ鬱陶しかった……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}