{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「山道を抜けたＭ．Ｏ．Ｅは市街地へとやってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114110001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「話には聞いていたけど、なんというか……なにこれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「暴走した車が、路上で踊っているわね。誰かがプロポーズでもするのかしら\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なにを言ってるんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「山道では車がレースを仕掛けてくるだけだったけど、街の中はもっとひどい\nありさまだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「縦横無尽に車が走り回って……歩行者天国ならぬ自動車天国って感じだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110003" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「何者かによって暴走させられているのですから、どちらかといえば地獄です\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「その時である！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114110002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あの見間違えようのない派手な車体のバスは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あの車を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「見つけたわよ、Ｍ．Ａ．Ｍ．Ａーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110004" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひぃいっ！　また殺人的な加速を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「暴走している車の間を縫いながら一気に追いつこう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さ、左右に揺られる！　Ｇが、Ｇがぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ、Ｍ．Ａ．Ｍ．Ａが曲がる！　内輪差で歩道に詰まれた段ボールが吹き\n飛ばされる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃっ！　段ボールの中身は生クリームじゃないの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110005" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ボディがミルクまみれだわ。後でカツマちゃんに洗ってもらわないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そんなことより前！　交差点に大型タンクローリーが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「減速していられない……突っ込むわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110007" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あああっ！　また加速っ！　ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「間一髪だったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あと数秒遅かったらあの事故に巻き込まれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「事故なんて起こさないわよ。カツマちゃんをとりもどして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110008" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんにボディを丁寧に洗車してもらうんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「それから、徐々にＭ．Ｏ．ＥはＭ．Ａ．Ｍ．Ａとの距離を詰めていった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114110003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もうＭ．Ａ．Ｍ．Ａのミラーに私が映っているはずなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110010" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ところでさー、なんでほかの車はみんな暴走しているのに普通に走れてるん\nだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そういえばそうね。気にしたことなかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110011" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うーん、もしかしてほかの車がおかしくなったとき、私はロボット形態にな\nっていたから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「えっ、Ｍ．Ｏ．Ｅってロボットになれるのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、最新のＡＩカーだもの。ロボットモードに変形くらい出来なくち\nゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110013" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「な、なんですか……その理論は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あ、さっきからおとなしいと思ってたけど、もしかして車酔い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あんな運転されたら誰だって酔いますわ！　……うぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……吐きそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ダッシュボードにエチケット袋が入っているから、必要な時は使ってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114110014" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114110012" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}