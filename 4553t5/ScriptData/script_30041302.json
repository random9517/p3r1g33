		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「よう、来てやったぞ。へへ……そろそろお前が呼ぶ頃じゃないかって思って\nたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304101" ]},
		{"command":[ "SETCHARA", "0", "char_00000413_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「今日は、めっちゃ忙しかったしな……何か、ムラムラしたんじゃないか？　\nていうか……私が、そうだったんだけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「だから、今日はお前の好きなようにさせてやるぞ。普段と違うようなことで\nも、大サービスしてやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、やる気満々だな……ポーズを変える？　どういう風に……おっ、おお\n……こうして……こう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304104" ]},
		{"command":[ "SETCHARA", "0", "char_00000413_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「な、なぁ……これで本当に合ってるのか？　これは……何て言うか……いく\nらなんでも、は、恥ずかしいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000413_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あ、合ってるのか……うぅ……ま、まぁ、してやるって言ったんだ……少し\n恥ずかしい位は我慢する……んっ、えっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「お、おい……ちょっと待て……そ、そっちは……違うだろ？　チンチンの入\nれる場所は……あっ、あぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、ふぁぁぁぁっ……！　バ、バカっ……！　そこはっ、お、\nお尻っ……！　お尻の穴だろっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あ、合ってるっ……！？　今日はっ……こっちでするって……あっ、くぅっ\n……！　そんな……いきなりなんてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「くっ、んぁぁ……大体、ろくに準備もしないで……チンチンなんて入るわけ\n……あっ……あぁっ、なんで……あっ、入っていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「嘘だろ……あぁ……私のお尻……んっ、チンチン……咥えこんで……あっ、\nひっ、はっ、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……いっぱいにさせられてる……チンチンが根元までずっぽり埋まって\nる……んくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「き、キツいって……こんなの……慣れるワケないだろっ……くぅっ、んっ…\n…い、痛み……？　それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「その、確かに……痛みは……ない……はぁ、んっ……余裕はないし……ムズ\nムズして、落ち着かないけど……ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、何か……変な感じだ……お尻の穴から……変なのが広がってぇ……\nあ、あぁっ……何だよ、これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、も、もっと速く動くのか……？　んっ、あぁっ、チンチンが\n……あっ、ずるってっ……壁……引っ掻いてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んくっ、あぁっ、あへぁっ……ヤバいって……こ、こんな……あひぉっ！　\nあっ、へ、変な声っ……出ちまうからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「も、もっと聞かせろっ！？　バ、バカっ……ただでさえ恥ずかしいカッコし\nてるのにっ、そんな真似っ……あぅっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、あふっ……！　だっ、めっ……！　あっ、あぁっ、ごりゅご\nりゅっ……来てるっ……おっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ヘンだっ……こんなっ、あっ……チンチン入れるところじゃないのにっ……\n気持ちっ……あっ、よくっ、なるっ、なんてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「うぁっ……！　お尻から……チンチン出てくるっ……あひっ！　出ちゃダメ\nなものまで出てきそうなっ……んぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ま、また……あっ、ずぶって……入ってくるぅっ……うぁぁ……お尻の中っ\n……チンチンで埋まって……つ、繋がってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、チンチン熱い……くぅっ、中が……溶かされちまいそうな\n位……熱くなって……はぁぁ、ぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁあっ、んくぅっ……オマンコと……全然違う……これがっ、アナル……\nセックスぅ……あぁっ、あぉっ、くぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「お尻の穴……痺れてる……んくぅっ……ジンジンする感じ……んぁぁ……こ\nんな、ゆっくりしてるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「も、もう少し速く……？　くぅっ……んっ……わ、分かった……好きにして\nくれていい……あっ、んくぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぅっ、はっ、あぁっ！　お、お尻の中をっ……チンチンがっ、いっ\nぱいっ、出入りしてるっ、あぉっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ……ぐぽぐぽっ、音……させてぇっ……ダメだっ……これっ、あぁ\nっ、足っ……広げるなぁっ、んひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……し、締め付けっ……？　んんっ、こんな、感じで……どうだ\n？　んっ、んふぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁっ……チンチン……キュってすると……お尻の穴がムズムズして……\nはふっ、き、気持ちいい……かもっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……お前も気持ちいいのか……？　チンチン……お尻で感じてる\nんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「なら……もっと、んんっ！　締め付けるっ……あぁっ、擦れるぅっ……尻穴\n全体でっ……チンチンのことっ、包んでいくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ヤバい……アナルセックス……い、いいかもぉっ……お尻の穴が……広がり\nながらっ、喜んでいるのっ、分かるぅっ……ふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、あぁっ、何だかっ……チンチンっ、膨らんで来てるっ……\n！　そろそろ出したく……なってるのかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「やっぱり……んっ、あふっ、そうなんだなっ？　はぁっ、んっ……い、いい\nぞっ……アナル……中出ししたいんだろっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「してっ、いいからなっ……私の中っ……アナルに中出しっ……してっ、いい\nからっ……そうだっ、そのままっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぅぅぅぅぅぅんっ……！　出てっ……るっ……熱いっ……！　お尻の中っ\n……精液で……いっぱいになってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……気持ちいいの広がってる……お尻……燃えてるのっ、うくぅぅぅ\n……止まらない……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……チンチンがビクビクしてる……はぁ、お尻に突き刺さったまま…\n…震えてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……あふ……止まった？　んんっ、あぁ……まだ、お尻の中……ジンジ\nンして……よく分からねぇ……ふぁ……あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はふ……あぁ……アナルで……尻でイかされるなんて……思わなかった……\nはぁ、アタマ……ヘンになりそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「中でずっとムズムズした感じが続いてて……今も、まだ妙な感じがしてる…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ところで……ま、まだ続ける気なのか？　チンチン……ずっと入ったままな\nんだが……あっ、んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「慣れてきた頃って……そりゃ……さっきよりは……け、けど続けてするのは\n……あっ、あひっ、あっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「このまま……私のお尻をもっと開発するっ！？　んくぅっ……バカッ……そ\nんな、勝手に決めて……はぅっ、あぅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁっ、あっ、あぁんっ！　ぐちゅぐちゅっ……中っ、精液……混ぜられて\nっ……な、馴染ませるっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、確かに……さっきより、よく滑って……くふぅっ……チンチ\nンが、もっといっぱい動いてるっ……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あぁっ……ひっ、あぁっ、腰を回してっ……さ、さっきと違\nうところにっ、当たってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……お尻の中で……あっ、オマンコの近いところに擦れてぇ……く\nひぁっ！　い、今のっ……あ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はうっ、うんっ、くぅんっ！　あぁっ、ヤバいって……！　敏感なトコっ…\n…ずっと、されてるとっ、あっ、あぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あぉっ……お尻の内側がっ……捲れてっ！　ひぃんっ、も、戻\nらなくなるっ……！　くっ、んぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁぁっ、あぁっ……こ、この格好……力が入らないっ……んんっ\n……！　い、一回……元に戻してくれないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ち、違う……別にイヤってワケじゃ……ただ、その……んっ、お、お尻じゃ\nないところも……ムズムズしてて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「このままだとっ……そのっ、ヤバいことになるというかっ、ふひぁっ、あっ\n、んくぅっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「そのっ、だからっ……お、おしっこっ……出そうになってて……一回、とり\nあえず仕切り直しで……ふぁっ、あひぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「き、気にしないってっ！　私が気にするんだってっ！　んぁっ、あぁっ、ち\nょっと、ひゃらっ、お尻っ……そんらっ、激しくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、もじもじしてるのが可愛いとか言うなぁっ！　もっ、それどころ\nじゃないのにっ、あっ、チンチン……ぐりってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、らっ、らめっ……あぁっ、そんなっ、ズボズボってぇっ！　またイ\nかされるっ！　お尻イクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぉっ、あぁぉっ！　激しいっ……あぁっ、チンチンっ……ビクビク\nしてっ！　来るっ……来ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁぁぁっ……お尻っ……イクっ！　くひぃぃっ、またっ……お尻\nっ……イックぅぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ……！　お尻っ……中ぁっ……またっ……入って……あっ、来て\nる……ふぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「イクっ……あぁぁ……も、もう、ダメだ……我慢……できなっ……はっ、あ\nぁぁぁぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……み、見るな……んんっ……見ないでくれ……おしっこ漏らしてる\nとこぉ……見ないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぅ……やだ……止まらない……いっぱい溢れて……掛かってるぅ……よ\nけてくれ……お前にも掛かってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「気にしないって……だから私が気にするんだっ……！　んぁぁ……あぁっ、\nあぷっ……か、顔にも……飛んでるのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁ……はぁ、はぁっ、はぁっ……んんっ……あぁ……や、やっと……止ま\nった……うぅ……私は……なんてことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「お前……なぁっ……好きにしていいって言っても、限度ってもんがあるんだ\nぞっ？　こ、こんな恥ずかしすぎること……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「だからっ、か、可愛いとかっ……そういう問題じゃねぇっ！　お尻……まだ\n、閉じきらないで、スースーするしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「き……気持ちは……よかったけどっ……いやっ、今回はごまかされないぞっ\n！　タダで済ませる気はないからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「食べ歩きツアーっ！？　ホントだろうな……？　い、いいぜ……それで手を\n打ってやる。なら……ついでにもう少し……続き、しても……いいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ……！　お尻っ……熱いの……掛かってるっ……んっ、ふぁぁぁ\nぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁんっ、わ、私もっ……もうっ、イッ……イッてっ……うぁぁっ……\nダメだっ……あぁぁぁ……出るぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「や、やだ……あぁっ……止まって……はぁぁんっ……おしっこ、止まれぇぇ\n……あぁぁ……ふぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「あぷっ……！　そんなっ、あぁ……漏れるの……我慢できない……はぁぁ…\n…精液も掛かってる……汁まみれになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁ……はぁぁぁ……あっふ……あぁ……全部……出しちゃった\n……はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000413_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅぅっ……だ、だから待ってくれって言ったのにっ……！　お、お尻はと\nもかくっ……お、お漏らしまでさせるなんてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅっ……最悪だ……お前に、こんなみっともないところを見せるなんて…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「みっともなくない……可愛い……そ、そんなこと言ったって、ダメなもんは\nダメだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「メシ１週間分……？　いや……ダメだ……そんなんじゃダメだ。そうだな…\n…二人でバカンス……それなら考えてやってもいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "超・セレーナ" ]},
		{"command":[ "SETTEXT", "「ああ、二人だけで食べ歩きとか……いろいろ行くんだ。そ、そしたら……そ\nの、お尻でも……もっとして、いい、かもな……」", "NORMAL" ]},
