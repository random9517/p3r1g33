		{"command":[ "SETIMAGE", "0", "still_00022701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっんンンぅっ！　あはあぁっ！　お、おくっ……当たってるっ……！　\nチンポの先っぽが、ノックしてくるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あっ、あふっ……！　んっ……あ、あなたも……気持ちいいの？\n　んっはっ……一緒に、感じてぇ、るぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「わ、わからないっ……！　わからないけど……あ、頭まっしろでぇ……はっ\n、ああっ……あんっ！　あんっ！　あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「でる？　んっ、ああぁっ……！　しゃ、しゃせぇ？　射精するの？　んっ、\nあぁっ……い、いぃっ！　あなたが好きなようにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はんっ！　はぁ、あぁっ！　ひっ、ひぃうっ！　は、激しいっ！　浮いちゃ\nうっ……！　腰が浮いてぇ……あっあっ！　はぁぁぁぁぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
