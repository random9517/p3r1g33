		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はあっ……あっ、あふうっ……まだ、出てる……んっ、オマンコ……精液で\n、いっぱいになって……気持ち、い、いぃ……」", "NORMAL" ]},
