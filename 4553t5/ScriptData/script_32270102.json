		{"command":[ "PLAYVOICE", "v2_227_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はあっ、はひぃんっ！　んっ、はぁっ、あんっ……あんっ！　や、あぁ……\n音、すごいっ……はっあっ……！」", "NORMAL" ]},
