		{"command":[ "SETIMAGE", "0", "still_00022701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「なにって……あなたが、出した……精液が、中で……オマンコの中でかき回\nされて……あふっ、あはぁんっ……！　はっふうっ……！」", "NORMAL" ]},
