		{"command":[ "SETIMAGE", "0", "still_00022701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ンっ、あぁ……はぁあっ……確かに、気持ちよかった……けど……んあっ…\n…オマンコどころか、身体中火照ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「身体、疼いて……全然、火照りが冷めないけど……はぁ、はぁ、はぁ……\nセックス、足りないの……？」", "NORMAL" ]},
