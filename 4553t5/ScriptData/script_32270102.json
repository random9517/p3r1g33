		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あぁっ！　ま、また……さっきの……大きいの、くるっ！　\nあ、あくめ？　あくめしちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ひっ、ひんっ……チンポ、チンポアクメしちゃうっ……！　はっあっ、あぁ\nっ……欲しいっ、射精、して欲しいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、ああっ……出してっ！　んっ、お、おまんこっ……ハメまくって\n、いっぱい出してぇっ！　あっあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「いい、あなたの好きなとこに……出してっ！　あっ、ああっ……オマンコの\n奥でも……身体に、かけてもいいからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ひゃあああっ！　あっ、あっ！　あんっ！　おっ、おほぉっ！　おおっ！　\nお、おほっ！　んっほっぉ！　おほおぉおぉぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「イ、イク？　イクッ……！　オマンコいくっ！　イ、イクっ……おっ、おお\nっ……！　おっひっ、ひいぃぃぃぃぃ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ひぎぃいいいいっ！　ひっ、ひぐっ！　ああっ！　出て、出てるぅぅぅっ！\n　中にぃっ……んっ、はぁぁぁぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「な、中出しっ！　オマンコの中に、ザーメンっ……！　ザーメンっ……！　\n熱くて、ドロドロのザーメンくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「オマンコ、すごいっ……感じすぎて、とろけちゃうっ！　はっ、はひぃっ…\n…んっ、んんっ！　あはぁっ、はぁあぁぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「チンポがぁ……オマンコの中で、跳ねて……ひぃうっ！　ザーメン……さっ\nき出したザーメン……押し流してるっ……！　ひっ……んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はあ～～～っ……はぁはぁ……はっ、あはぁ……あんっ……す、すごかった\n……んぅっ……まだふわふわしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「これが、セックスなのね……んっ……絶頂？　アクメ……味わったわ……\nもう、ヘトヘト……あなたは大丈夫なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「言われてみれば……さっきまで、あんなに身体も熱かったのに……なんだか\n、すーって熱が引いていく感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「本当に、すっきりした……気がする……それに、幸せな気分ね……疲れてる\nんだけど、心地いいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ええ。あなたの言った通りだったわ……これからも、身体がどうしようもな\nく火照ったときはお願いしていい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ふふっ……一方的にしてもらうだけは悪いし、そう言ってくれると嬉しい。\nあなたもいっぱい楽しんでちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んあぁっ！　はっ、はっあっ！　チンポ、抜けるっ……！　抜けちゃうぅぅ\n……はっあぁぁぁぁぁぁぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ひゃあっ、あはっあぁんっ！　ひっ、あぁんっ……あ、熱いぃっ！　ザーメ\nンがっ……ひぃいんっ！　ひっひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっあぁっ！　か、顔まで……かかっちゃう……！　ひっ、ひぃんっ……\nはひぃいっ……ひゃっ、あぁっ……ひゃあぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あぁんっ……気持ちいい……ザーメン、浴びせられてるのに……\nんっあぁぁっ……！　身体中が熱いぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あぁ、ザーメン……熱くて……匂いもすごい……はぁぁ……はーっ……はぁ\nはぁ……んはあぁっ……あ、頭、真っ白になっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ……ひゃっ、あぁんっ……！　お、終わった……？　すごい量ね…\n…はぁ……はぁ……はぁ……んっ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「身体は……まだ火照ってるけど……確かに、少しすっきりした気分……セッ\nクスって、不思議ね……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ええ、気持ちよかったわ……ふぅ……とても疲れたけど、満足よ……あなた\nはどうだった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そう。あなたも気持ちよかったなら……わたしも、嬉しいわ。あれだけ激し\nく動いてもらったし……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「また身体が火照ってきて、どうしようもなくなったら……あなたにお願いす\nるわね。ええ、楽しみにしてるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104410" ]},
