		{"command":[ "SETIMAGE", "0", "still_00022701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ンンっ、胸、まで……揉んで……な、なんなの……これぇ……はっ、あぁあ\nっ、あはっ、あんぅンっ！　んっ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「気持ちいい、か……とか言われても……わからない……ンンっ、はンっ……\nんっ、ああっ！　チンポが、出たり、挿入ったりぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あンっ、あはぁっ！　お腹の中……かき回されてるっ……んんぅ、はっ……\nお、おまん、こ……？　オマンコって、いうの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そ、そう……オマンコが、すごいの……あっ、あぁあっ！　オマンコが、\nとろけちゃいそうで……き、気持ちいぃ、のかも……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっんっ！　そうやって、チンポで……オマンコの奥、突きあげられると…\n…あ、ああっ！　なにも、考えられなくなるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ、あ、ああぁあっ……ち、乳首、こりこりしないで……敏感になってて\n……あんっ、ああっ！　ひぃっ、あっ、ひぃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「さっきから、おかしいの……！　身体が火照りすぎて、変になっててぇ……\nはっ、くっふぅ……ああっ、こ、これでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「い、いんご……？　え、えっちなこと……言いながらだと……もっと気持ち\nよくなれるの？　わ、わかった……あ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「チンポっ……！　チンポぉ……わたしのオマンコ、ズポズポかき回してるっ\n……は、ああっ……はぁあっ！　チンポ、すごぃいっ！」", "NORMAL" ]},
