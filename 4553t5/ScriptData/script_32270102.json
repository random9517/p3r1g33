		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……本当に……これでいいの？　なんか、さっきよりずっと身体が\n火照ってきてるんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あなたが言うから……その通りに、してるけど……んっ……こんなことする\n必要あるの？　わたしを騙そうとしてない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ええ、そうよ……身体が火照って、ムラムラして仕方ないの……だからあな\nたに相談、したんだけど……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「いい方法があるって言うから……お願いしたのに……これから？　本当に\nこれから身体の火照りはおさまるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっ、わかった……じゃあ、始めて。なにをするか知らないけど……んんっ\n……なに？　おっぱい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっあんっ……だって、おっぱい……敏感、だから……あっ、あふっ\n……んっはぁ……え？　そっちも……？　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「なんで、チンポまで……擦りつけて……あっ、あふぅっ……さっきから、\n身体、熱くなってばっかりなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「これからが、本番なの……？　わかった……あなたに任せてるから、言われ\nた通りにする……わたしはどうすればいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「……その、おねだり？　って、のをすればいいのね……つまり、お願いって\nことよね？　普通に言うだけじゃダメなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「いんご……？　イヤらしい言葉、で……？　信じてないわけじゃないけど…\n…本当に必要なの……？　そうなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あなたの、ガチガチに勃起した立派なチンポを……わたしの、オマンコに…\n…ぶちこんで……ハメまくってぇ……こんな感じでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「もっと感情をこめてって、言われても……んっ、ねえ……さっきから、チン\nポ擦りつけるの……なんなの……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「切ない、感じ……かも……ンっ、それも全部……吹き飛ぶの？　ええ、欲し\nい……あなたのチンポ……デカチンポ欲しいわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ンンっ！　んっ、ンンーっ！　はっ、ああっ、あっひっ……はい、って……\nくるっ……！　んっうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁぁっ……！　チンポっ……奥まで、ズブズブ……くるっ……\nはっあっ……あぁあっ、あんっ……んあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「な、なに……これっ……股間が熱いっ……んっ、ああぁあっ！　はっ、ああ\nっ……はひぃ、い、痛みは……そこまで、ない、けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあっ……はーっ、んぁあっ……！　お腹が、押し上げられて……\n圧迫感が、すごいっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「本当に、こんなことして……身体の火照り、おさまるの……！？　さっきか\nら、むしろ身体が熱くて、堪らないんだけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　ねえっ、聞いてる？　んっ、あっ……腰、動かさないで…\n…はっ、あっ、あっ……んはっ！　あぁあんっ！」", "NORMAL" ]},
