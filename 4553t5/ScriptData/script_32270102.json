		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「さっきよりっ……んぅっ！　か、感じるっ……チンポが動くたびに、中、\n擦れてぇ……ひっ、ひぐっ！　はっ、ひぃいいっ！」", "NORMAL" ]},
