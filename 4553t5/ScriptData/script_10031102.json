		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「甘いです！　防御陣っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "オボロとハルノブの間で、俺の割り込む余地など全くないハイレベルな攻防が\n続いている……。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000511_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「傍観しながら言い訳している暇があったら、ハルノブ殿に助太刀のひとつも\nなさっては？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の割り込む余地など全くないハイレベルな攻防が続いている……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、ご主人は要するにそう言う人ですな。存じておりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「これならどうです！　はあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……やはりそう来ましたね。あなたの考えること、手に取るように読め――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「それはウチのセリフです。あなたの動きは、とても読みやすいですよ。まる\nでウチ自身の頭の中をのぞいているようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……でしょうね。というか、アナタもうすうす気づいてはいるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ？　なにに気づいてるっていうんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「…………やれやれです。いつぞやのチラ見せで、いいかげん気づいていると\n思ってましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いいでしょう。はっきり見せてあげるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120007" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういってハルノブは仮面を外した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その下から現れた、この顔は……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「これならわかるでしょう？　いくらアナタでも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120008" ]},
		{"command":[ "SETCHARA", "0", "char_00000515_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？　は、ハルノブ……！？　おまえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000515_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やはり、そうでしたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「『やはり』って、おまえ、知ってたのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにを今さらですぞ。シーズン３の第５話で、ハルノブ殿はとっくに素顔を\n見せておるではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0220" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まったくです。てっきりあのときに、気づいていると思ったですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120010" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、それはそうだし、あのときも『オボロそっくりだ』とは思ったん\nだよ！　でも……なんていうか、確信が持てなくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、要するにそう言う人なのですぞ。ご主人は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116120005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ！　そんなことで責めなくたっていいじゃねえか！　っていう\nか、ハルノブ！　おまえは……アナザー・オボロだったってことか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いえ、違いますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「アナタたちを基準にしていうなら『アナザー』はウチ、ということになりま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0217" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_008" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチは元々、アナタたちとは別の次元から来たオボロ。そう、言うなればア\nナザー・オボロです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116120008" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「アナタたちの次元のオボロと、すり替わっていたのですよ。アナザー・ルナ\nテミスを監視するためにね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116120001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ、ハルノブは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「それがアナタの知っていたオボロですよ。正確に言うと、採石場でアナタと\nシルバスターを始末しようとしていたオボロです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「！！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「アナタがカグヤに助けられ、逃げ回っているドサクサにまぎれて、ウチはそ\nの人と入れ替ったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「きちんと始末しておこうとしたのですが……残念ながら逃げられてしまいま\nしてね。まあ、記憶をなくす程度の深手は負わせたですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当なのか！？　ハルノブ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「残念ながら、ウチには記憶がありません。ですが……そのオボロがそういう\nのなら、おそらく事実でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116120012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「まあ、衝撃の告白はここまでにしておきましょう。今度こそ、そちらのオボ\nロにはボケ隊長共々消えてもらいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116120005" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}