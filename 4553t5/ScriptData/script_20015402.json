{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0167" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして迎えたクリスマス当日。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "真夜中の私立大戸岐学園の門前に招集されたのは、俺とジュンジローの他にル\nナテミス、修羅姫、そしてクィン・テイルの４人と１匹だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これで全員集まったか？　で、依頼主のサンタガールってのはどこに……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「ふぉっほっほっほっほっ！　ここにおるぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おーっ、サンタガールだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な？　サンタは実在しただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当だ。ガールだけど……確かにサンタだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それにしても、真冬にあの格好で寒くないのだろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023530001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「元々寒い国に住んでいるはずだから、これくらい平気なのかもしれない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なるほど……。しかし、生まれて初めて本物のサンタというものを見たな。\n感動した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023530002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……。お前たちに喜んでもらえたみたいで良かったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023530001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "（付け髭があるだけで気付かないとか……。呆れを通り越してもはや悲しさ\nすら覚えるわい）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「ほれほれ。ぼさっと突っ立っていないで、さっそく手伝いをしてもらおうか\nの。この衣装に着替えるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これは……サンタの衣装？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「そうじゃ。今宵、お主らも立派なサンタの一員になってもらわねば困る。善\nは急げじゃ、はようはよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それじゃあ……着替えてくるとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023530003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああ。私も共にいくとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023530002" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……女性の皆様が行ってしまいましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「どんな服になるか楽しみじゃろ？　今のうちに、ゆっくり妄想しておくとい\nいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "……そして１０分後。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「なんだい。私が一番最初かい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023530003" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おおおおっ……！　なんてゴージャスなクリスマスなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「見る者全てを圧倒する迫力と、そこはかとなくにじみ出る威厳がありますな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クィン・テイルここにありって感じだな。今日しか着てもらえないのが残念\nなくらいだぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そんなに褒めてもらえるとはね。わざわざ着替えたかいがあるってものだよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023530004" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「お。そうこうしている間に次が来たぞ。次は……修羅姫のようじゃな。来る\nがよい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530006" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……着替えてはみたものの、これでいいのかよくわからんな。……と、なん\nだその目は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023530004" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、馬子にも衣裳だなと思って」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「な、何ぃ！？　それは褒めているのかけなしているのか、はっきりしてもら\nおうじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023530005" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「褒めてる褒めてる。服一つで、結構印象って変わるもんなんだな～。驚いた\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そ、そうか……。まあ、それならいいか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023530006" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おっと。私が最後になってしまったようだ。待たせてしまってすまない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「いやいや。ちょうどいい頃合いだったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000799_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お～。姫様のために作られた衣装って感じだな。すごくいいんじゃないか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まさに聖夜の主役！　と言ったところですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんだ。あまり褒めるな。妙な気持ちになるじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも真面目に似合ってると思いますよ。そもそも姫様はスタイルがいいから\nなんでも似合うのかもしれないですが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うっ……。ぐ、ぐぅ……。そ、そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、この衣装……とても素敵だとは思うが、露出度が……その、少し気に\nなるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「どうせ皆寝ているから恥ずかしがる必要はないぞ。それに、誰かに見られた\nとしても今日はクリスマス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530008" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「サンタの服装さえしていれば、そういうものだときっとみんなが考えてくれ\nるはずじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530009" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それもそうか……？　ところで、衣装と一緒に入っていたこの剣は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「生前のルナルバース陛下から預かっていた遺産じゃ、先に渡しておいたぞ。\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530010" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんだと！？　これが……母上様からの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530008" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「聖夜に輝く伝説の聖剣『ルミナリアンサーベル』じゃ。ルナルバース陛下曰\nく、いずれ役に立つ……とのこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530011" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「母上様からのプレゼント……。あああ……もうそれだけで、私の心はいっぱ\nいになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023530009" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「確かに渡したぞ。それじゃあ、出発するかの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530012" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ファッションショーもそこそこに、いざ聖夜の町へ出発した俺達。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "これからパトロールをやって、それからプレゼント配りに移動するらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちなみに、俺には陛下の遺産ってやつは無いんですか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「……最初は誰からプレゼントを配るんじゃったか？」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023530013" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「む、無視された……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは、期待できそうにありませんな……。ファイトですぞ、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う、う、う、うるせえ！　下手な慰めなんていらないっつうの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「悲しいくらいの負け惜しみですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}