{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "057_0103101" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「やっほー、隊長さん。来たよー、どないしたん？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103102" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「おや？　うちだけが呼び出されたのん？　これはなんやただ事じゃないねぇ\n？　おっかなーい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103103" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んん？　パワーアップのお手伝い？　へーぇ、そんな大層なことうちがお手\n伝い出来るんかな？　何すればいいのん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103104" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「へー、隊長さんのオチンチンをうちのおっぱいで挟んで、それを口で咥えた\nり舐めたりするとー……ほうほう……出来るかーい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103105" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「もー、いきなり下ネタぶっこまれてびっくりしたわぁ。……はい、本当のと\nころは何すればいいの？　……え？　これが本当のところ？　うひゃぁ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103106" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あぁっと……あー……隊長さんが嫌いとかやないんだけど……。うーん、困\nったねぇ。受け止めきれないだけで……。こんなんなかなかすんなりはねぇ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103107" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「隊長さんは、困って、るぅ？　……そうか。じゃあ腹括るか。……分かりま\nした、やりましょ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103108" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ふむ……まずは、おっぱいを……出す、のか。うむむ……おっぱい……おっ\nぱい……うーーーー、おっしゃ出すよ！　うりゃぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103109" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「うひゃぁー、恥ずかし！　あんまり見んといてね？　もう、隊長さん……あ\nんたさんにお願いしてんのよ？　聞いてんの？　ガン見やんかー……」　", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103110" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「え？　……あったかい？　うちのおっぱいが？　へぇー……うちは隊長さん\nのオチンチン熱いから、隊長さんはうちのおっぱい冷たく感じてると思った」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103111" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「まぁ、おっぱい冷たいねって言われるのと、あったかいねって言われるのや\nったら……あったかい方がいいかなぁ？　よう分からんけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103112" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あと、あぁ……柔らかい？　そっか。まぁおっぱいやからね。それなりには\nね、柔らかいかも、ね……。ほーれ、むぎゅむぎゅ、ぷにぷに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103113" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ハハ、気持ちええんやろ？　隊長さんの顔、ぽやぁってなってきたから……\nえ？　うちも？　フフフッ……そんな訳あるかい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103114" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あれ？　隊長さんの先っぽから透明なお汁が出てきた。えっと、どうしよう\nかいな、これ……零れ……あー、仕方ない！　じゅるるぅぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103115" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「れろぉ、じゅるるぅう……ちゅぱぁ……れろれろれおぉぉ……じゅるるぅぅ\nぅ……はぁ、困ったねぇ。後から後から出てくるやん、じゅるるぅぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103116" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「どんなに舐めても、追いつかんやんかー。れろれろれろぉ……はぁ、青臭い\n匂いやねぇ。……あ、嫌とかじゃなくて……エロい味やなぁってさぁー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103117" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　……うちのおっぱいも、エロい？　なんやそれー？　じゃあ隊長さ\nんのエロい味のお汁とうちのエロいおっぱいで、おあいこでいいわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103118" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「なんや……あれ？　……おおぅ、隊長さん、オチンチンが硬くなってきたね\n。それに血管が、はぁ……がっつり浮き上がって、ボコボコやぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103119" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいにも伝わるよ？　隊長さんのオチンチンがじんわり形変っていくの\n。ちょっと……おっかない形になっていくのがさ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103120" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅぅ……ちゅぱちゅぱぁぁ……はぁん……では、隊長さんのいきり\n立ったオチンチンを、ペロペロして仲良くなりますかぁ？　じゅるるぅぅん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103121" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるるるぅぅ……れろれろぉぉ……はぁ、お汁の匂い、きつくなってき\nたぁ。……あぁ、あやまらんといて？　じゅるぅぅ……れろれろぉぉっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103122" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「だって、うち……隊長さんのこのお汁の味も匂いも……なんつーか……好き\nになって、きてるみたいやからさぁ……。あー、ちょっと恥ずかしいなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103123" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「だからね、もっといっぱい出していいよ？　エッチなお汁。……じゅるるる\nぅぅ、れろれろれろぉ……ちゅぱぁぁぁ、じゅるるぅううぅぅぅ……はぁん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103124" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「なんやもぉ……舐めてるだけじゃ、じれったいなぁ。お口全体で……御奉仕\nさせてもらいましょ？　はぁむ……じゅろぉぉお……むぐぅぅむぐぐぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103125" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「じゅるぅぅ……じゅっぽじゅっぽ……はぁ……口の中で、むくむく膨れてる\nぅ、じゅるぅ……ちゅぱぁぁああぁ……はぁん、不思議な感じやなぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103126" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あふぅ、喉の奥まで……届きそぉ。ちょっと苦しいけど……じゅるるぅぅ、\n隊長さんが気持ちぃなら……じゅるぅ、頑張ろうか？　れろれろれろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103127" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「口の中、あったかぃ？　んぅ？　れろれろぉぉ……ちゅぱぁ、じゅるるぅぅ\n……はぁ、舌にオチンチンの血管のデコボコが……んじゅるるぅうぅう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103128" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ここの筋ぃ……ペロペロすると……ん？　……んぅ？　じゅるるぅぅ……れ\nろぉぉぉ……アハハ、気持ち良さそうな顔するねぇ、隊長さん？　ちゅぱぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103129" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「気持ちぃんやったら、気持ちいいって言葉で教えて？　うちは、教えればち\nゃんと覚える子よ？　れろれろれろぉ……ちゅぱぁぁ、フフッ、どうやの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103130" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「じゅるぅぅ……れろぉ、はぁ……そっか。気持ちぃぃんやね？　ここが。ち\nゅるぅぅ、れろれろぉ……はーい、覚えましたぁ。んっじゅるるぅぅう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103131" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるぅぅ……れろれろぉ……あふぅ、隊長さん……？　オチンチンが、\nなんや……ビクビクって……おぉ？　暴れとるよ？　どしたんかな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103132" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　あぁ、イきそうなんね？　分かった、じゃあ奥まで咥えましょかね\n。じゅるるぅぅ……じゅっぽじゅっぽじゅっぽぉぉぉ……れろぉぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103133" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「じゅぷっ……じゅぷぅぅ……んぐっ？　んんぶううぅうう！　あはぁ、んじ\nゅるぅぅ……んぶぅううぅうぅううぅううぅぅ……ゴクゴクッ……はぁ」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103134" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「はぁん……あー、びっくりした。いきなりどろーってした熱いのが飛び出し\nてくるんやもん。口から溢れそうやったから、慌てて呑み込んだわぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103135" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あぁん、まだ口の中にイゴいの残っとる。はぁ……隊長さんの精液、なかな\nか濃い味やったよぉ？　……忘れられん。全部呑んだからかも、ね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103136" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「え？　あ、水？　アハハ、いいよいいよ！　何度も言うけどさ、別に嫌じゃ\nないんだって。慣れない味やからびっくりしただけなんよ、本当に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103137" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「オチンチンとか、精液とか……そんなの口でどーのとか……いや、慣れない\nことだからアレやけど……でも、隊長さんのやからね。嫌じゃないの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103138" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「まだ、好きには……なれんけど……でも、隊長さんが、またパワーアップの\nお手伝いしてほしいって思ったら、喜んでお手伝いしたいとは思ってるよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103139" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「勿論、他の誰よりも先に……一番に、声かけてほしいなって、そう思ってる\n。……あ、隊長さん次第やけどね、こんなのは。ごめんごめん、聞き流して」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0103140" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「まぁ、またいつでも呼んでってそんな話よん。うちはほら……隊長さんに頼\nられるのは、嬉しくて光栄なんやから。そこは是非に、覚えとってね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}