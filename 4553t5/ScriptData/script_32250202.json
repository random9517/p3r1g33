		{"command":[ "PLAYVOICE", "v2_225_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……別に不思議なことじゃないのよ。私のアソコは人間を模して作\nってあるから、性器の構造はそのままなの……」", "NORMAL" ]},
