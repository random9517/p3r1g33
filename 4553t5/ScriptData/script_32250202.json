		{"command":[ "SETTEXT", "「ひっ、うぐっ、んふぅ！　ああぁ！　もっとカツマちゃんを感じたいのに、\nアソコの制御がきかないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「イッちゃうっ！　またカツマちゃんの大きいので、イカされちゃううううう\nぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「くっ、ああっ！　あふっ、んふうぅ！　あっ、あっ！　カツマちゃんのもま\nたビクビクしてるっ……！　イッ、イキそうなのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「いいわよっ！　また膣内に出してっ！　私の子宮に向けて射精してっ！　思\nいっきり種付けしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「最新の技術を使って、赤ちゃん孕んであげるっ！　カツマちゃんと私で、２\n人だけの愛の結晶を作りましょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「だからさっきみたいに、精液をびゅーびゅー子宮に注ぎ込んでっ！　私のこ\nと、妊娠させてぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んくうううぅぅぅ……！　あっ、あふっ……！　また一番奥に精液出されて\nるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「さっきと同じくらいの量が子宮に流れ込んできてっ……！　あっ、あっ……\n！　これ、すごいわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「量だけじゃなくて、勢いも強くてっ……！　奥の奥にまで流れ込んできてる\nの感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんなのイッちゃうっ！　カツマちゃんの精子で、イカされちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　イクッ！　イクッ！　イッ……イクぅぅぅぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はああぁ……うふふっ……私の子宮、カツマちゃんの子種汁\nでいっぱいになってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……これならすぐにでも可愛い赤ちゃんが産めそうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あらっ……そんな顔してどうしたの？　まさか人間と機械との間に、子供は\n出来ないとでも思ってるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「そんなの現実的にありえない……？　あら、この世界ではどうかは知らない\nけど、私の居た世界の技術を使えば不可能は可能になるのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんが出来たら、カツマちゃんにはちゃんと責任をとってもらわないと\nね……！　うふっ……うふふっ……！　うふふふふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　カツマちゃんの熱い子種が、お尻にかかってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「どうして途中で抜いちゃうのっ！？　膣内に出していいって言ったのにっ…\n…あっ、あぐっ、あはああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　でも、お尻にかけれるの気持ちいいわっ！　カツマちゃんの精\n子が、ボディに染み込んでくるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「膣内だけじゃなくて、膣外もマーキングされてるみたいでっ……！　私のす\nべてが、カツマちゃんの色に染まっていくわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、はっ、あんんっ！　もっと塗り込んでっ！　カツマちゃん\nの精子、全部私にぶっかけてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……たくさん出したわね……精子感じすぎて、塗装が剥げちゃう\nかと思ったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「それにしても、どうして膣内で出してくれなかったの……？　カツマちゃん\nは、種付け嫌いなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「本当かどうかわからないけど、孕むって言われたから……？　うふふっ……\n射精直前でも、随分と冷静だったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「でも、今更膣外に出しても遅いわよ……だってカツマちゃん、１回膣内に出\nしてるんだもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　精子はしっかりと子宮に確保してあるから、逃げられない\nわよ……！　絶対に責任とってもらうからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204410" ]},
