		{"command":[ "PLAYVOICE", "v2_225_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「だからカツマちゃんは安心して、私に身を委ねて頂戴……大丈夫よ。痛くな\nんてしないから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
