		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……どうしてこんなことをするのかって……？　それは勿論、私が\nカツマちゃんのことを世界で誰よりも愛してるからよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0204103" ]},
