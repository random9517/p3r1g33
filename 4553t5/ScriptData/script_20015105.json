		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「じゃじゃじゃーん！　ハマちゃんハンマー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まりあの前に立ち、ディーネリンド達に立ちふさがったラヴリエータが、どこ\nからともなく取り出したのは……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "信じられないくらいに巨大なハンマーだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま……まさか、これでやるってんじゃないだろうな！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「大正解ですっ、ご主人様！　いきますよーっ、全力でぇ！　ドッカーンッ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぎゃああああああああ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ラヴリエータが振り下ろしたハンマーは、その場の全ての物を破壊した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……かに思えたが、その鈍器を片手で受け止めた人物がいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……む？　この騒ぎは一体何事だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_087_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えええええっ！　すげえ！　あの一撃を簡単に……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ああっ！　アーリッド先輩！　それにエアルミン先輩も！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「戻ってきてくださったんですね……。ああ、ほっとしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あと少しのところで、カフェが吹き飛んでしまうところでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「……フン。これくらいのこと、どうということもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_087_010023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ま、また新たなエルフの登場ですぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「アイナリンド。状況を説明なさい。どうしてニンゲンの男を奪い合っている\nの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうかまず、お前たちが誰なんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「私たちはこの、聖エルフ騎士団の騎士……。エアルミンとアーリッドです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_010023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ま、前に聞いていた……出張中の凄腕経営陣たちですな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「ええ。……ですが、私たちはあなたたちのことをまるで知らないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ！　それならちょうどいいじゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「せっかくゆっくりお話が聞けるようになったことですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「聞かせてもらえますか？　あなたたちがなぜここに来たのか。その目的と、\n理由について」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400006" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「というわけで、私たちは敵の攻撃に吹き飛ばされたカツマさんを探していた\nんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「それほど強靭な一撃を放つ敵……。一度戦ってみたいものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_087_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、そういう感想を抱くタイプなのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「アーリッドは戦闘狂なところがありますから。……あ、私は違いますので誤\n解なきように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「でもですよ！　エアルミン先輩は聖エルフ騎士団の騎士団長ですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400007" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「いざ強敵とやりあっている時なんて、すーっごく楽しそうなんですよ！　で\nすよね、エアルミン先輩！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400008" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「……客人の前で、余計なことを口にしないように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「そうだ。そもそも、お前のその浅慮さが……先程のハンマーでの攻撃に至っ\nたことを反省しろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_087_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「は、はぁい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400009" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあでも、ああでもしないと全員止まらなかったのは確かだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あああっ♪　私をかばってくれるんですね！　ご主人様！　大好きですっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400010" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ムフフフフ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……だらしない顔をしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ！　こ、これはだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……と、話の腰を折るのも大概にしてほしいですぞ。まりあ殿、続きを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「は、はい。元々カツマさんは私たちと同じ……。別の組織に所属している人\n間なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「だから、そこに戻らないといけない……ということなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「事情があるのはわかりました。ですが……やはり私達はご主人様を渡すわけ\nにはいきません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ええ。ご主人様は、もう私たちにとっては失えない、かけがえのない大切な\n存在なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「絶対に連れ戻されたくない……。それが私たちの本音です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「でもでも！　離れていたってご主人様はご主人様ですよね。私たちはご主人\n様に大切なことを教わりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400011" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「その教えを守りながら、力を合わせて頑張っていくのが……ご主人様と、そ\nのお仲間さんのためにも良いのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400012" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それはそう……なんですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……メ、メイドに主人がいないなんておかしいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それにもう、私達は……ご主人様無しでは生きていけない身体になってしま\nったんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「な、なんてこと……！　やっぱりここはいかがわしいカフェ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023400002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、違う！　誤解だ！　あくまで仮のオーナーとして！　経営上の理由だ！\n　そ、そうだよな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あああああ、意味深な沈黙を……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……ご主人様。私達はご主人様に、どうしてもこの森にいてほしいです。い\nいえ、この遠征だけではありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400006" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「カフェの経営が終わっても、聖エルフ騎士団に来てほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023400006" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「そう、ですね。ご主人様がいてくれたら……。正直、私も嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023400013" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「皆にここまで言わせるお前の……力量をじっくりと見てみたいものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_087_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00008701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エアルミン" ]},
		{"command":[ "SETTEXT", "「これだけ慕われているのであれば……きっと、良い所のある方なのでしょう\nし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_086_010023400006" ]},
		{"command":[ "SETCHARA", "0", "char_00008601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、お前ら……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "いつも、なんだかんだで虐げてくる……こき使ってくるＥＤＯのやつらとは違\nって、この森のエルフは皆優しい。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「感動した。俺もここにずっといたい……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ダメ！　皆、戻ってくるのを待っているんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、そうですよ！　それに、私達だってカツマさんのこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「な、なんでもありません。ですが、元々の店長たちが戻ってきたとなると…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もう、カツマさんはこのカフェに必要がなくなったということですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そ、そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400007" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……そうなら何も問題はない。カツマは返してもらう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「連れ戻すのなら今、でしょうね……。行きましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、待ってくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "がし、がしっ、と両腕を掴まれて、問答無用で引きずられていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それを悲し気な表情で見送っていたエルフたちだったが……何かを思い出した\nのか、アイナリンドが駆け寄ってきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ、最後にこれを……。どうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400008" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　何かのメモみたいな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「後で一人になったら開けてください。私達からの感謝の気持ちです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023400009" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ありがとな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……後で開いてみてわかったが、そこに記されていたのはこの森……そして聖\nエルフ騎士団本部の住所と……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『ご主人様永久無料券』と書かれた、ハートマークでいっぱいのメンバーカー\nドだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（……思っていたよりずっと近所だな。これなら、こっそり抜け出して通える\nかもしれない）", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「何か、よからぬことを考えている顔をしておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023400004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はん！　お前は置いていくからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「な、何がですか！？　ひどいことを言われていることだけはわかりますぞ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それよりカツマさん……心配かけさせないでくださいっ。今回ばかりは本当\nに死んでしまったかと思いましたよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023400009" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「目を離すとすぐいなくなる。これからはしっかり監視しないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023400005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "左右から説教を食らいつつ、ＥＤＯに連行された俺。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001401_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
