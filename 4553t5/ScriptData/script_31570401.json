{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふっふっふっ～♪　来たねお兄ちゃん！　さぁ、ご奉仕の時間だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ？　何の話だって？　だからご奉仕だよ、ご奉仕！　あなたのメイド\nさんによるえっちなご奉仕！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あ～！　今こんな小さなボディで何ができるんだとか思ったでしょ！　思っ\nたよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「確かにおちんちんを挿入するのは大変かもしれないけど……それならそれで\n、いくらでもやりようはあるも～ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいからおちんちん出して出して♪　ここで……太腿とおまんこでぎゅ～っ\nて挟んで、い～っぱいご奉仕して、あ・げ・る♪　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃん♪　お兄ちゃんのおちんちん、最初からがっちがちだね？　なんだか\nんだ言いつつ、ロッテのロリロリボディで興奮してたんでしょ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……いいよいいよ、素直なお兄ちゃんだ～い好き！　このままおまんこを使\nってい～っぱいご奉仕してあげちゃうからね♪　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こーゆーの、素股って言うんだよね……んっ……太腿ぎゅってして、われめ\nでおちんちんをすりすり～って……んんっ……ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あ、あれ？　これであってるのかな……？　んっ、んんっ……おかしいな、\n資料映像だともっと簡単に動いてたはずなのに……あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……上手にできなくても仕方ないじゃん！　えっちなご奉仕なんて初めてな\nんだから！　この馬鹿お兄ちゃん！　笑うなぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「うぅ……いっぱい勉強してきたはずなのに……ぱーふぇくとメイドのロッテ\nに掛かれば素股なんて簡単なはずなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もっと太腿をぎゅってするのかな……んんっ……おまんこももっとぴったり\nくっつけて、こ、腰を振る……？　んっ……やっぱり違う気が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……え？　お尻をもっと後ろに突き出すの？　えっと……こう、かな……？\n　立ち方も違う？　もっと両足をくっつけて立つ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お、おおおっ！　すごい！　おちんちんの反応が全然違う！　おまんこです\nりすりってすると……んんっ……ビクビクって跳ねてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「このまま続ければいいんだね、わかった！　太腿でぎゅ～って締め付けて…\n…んふっ、んぁ……割れ目ですりすり、おちんちんすりすり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んにゃうっ……にゃふふ、これだこれだ、映像資料の人もこうやって\n素股してた……んっ……んぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「確か腰を横に振るのもいいんだよね……んふっ……おちんちん左右に振り振\nり、おまんこですりすり……にゃふ、先っぽがぬるぬるしてきた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これをもっと割れ目に塗り込むように……あっ、んにゃう……おちんちんに\nゅるにゅる、おまんこでにゅるにゅる……んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ねぇお兄ちゃん、気持ちいい？　ロッテのおまんこ、気持ちいい？　ロリロ\nリボディの素股ご奉仕、喜んでもらえてる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふ♪　わーい、褒められた～♪　えっちなご奉仕、もっともっと頑\n張っちゃうんだから～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……んにゃうっ……おちんちん、血管が浮き出してきた……あ\nっ、んぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「凸凹がわれめに擦れて……あっ、んにゃうっ……にゃふふ、お兄ちゃんはこ\nれが好きなんだね、おちんちんまたビクビクしちゃってるね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「人間と違って、ロッテのボディは毛とか一切生えないからね。知ってるよ、\nこーゆーの、パイパンっていうんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ロッテのロリロリパイパンおまんこで、いっぱい気持ちよくなってね。おち\nんちん、もっとも～っとにゅるにゅるってしてあげるからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃ、あっ、んぁんっ……ぐちゅぐちゅって、えっちな音もどんどん大き\nくなってきた……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんにゅるにゅる、太腿でぎゅっぎゅっ……にゃふふ、お兄ちゃんの\n弱点、どんどん分かってきたかも……にゅるにゅる、ぎゅっぎゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んにゃうっ……おちんちんの先っぽ、膨らんでるところが割れ目に引\nっかかると……んんっ……にゃふふ、ロッテも気持ちよくなっちゃうかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんのがまん汁だけじゃなくて、ロッテのおまんこから溢れたぬるぬ\nるも塗り込んでっ……あっ、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もっとおちんちんがおまんこに食い込むように……んふっ……！　ぷにぷに\nの太腿もぐりぐりしちゃうね♪　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんのおちんちん、すごい熱……さっきからビクンビクンって暴れま\nわって……知ってるよ、もうちょっとで出ちゃうんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ロッテのえっちな素股でイキそうなんだ♪　ロリロリボディのロッテで精液\nびゅーびゅーって出したいんだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ロッテのお兄ちゃんは変態さんなんだから♪　んんっ、んにゃうっ……！　\nこ、このまま素股で搾り取ってあげちゃうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、んにゃんっ……！　もっと早く、おちんちんをにゅるにゅる\nって……あっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ！　あっ、んあぁんっ……！　さっきぽぴくぴくしてる、にゃ\nふ、お兄ちゃんのおちんちん、かわいいかも♪　んにゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……うん、いいよ、このまま出して！　お兄ちゃんの好きなところに、い～\nぱいぶっかけちゃっていいからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んやぁんんっ♪　精液出てる、おちんちんビクビクさせながら、びゅーびゅ\nーって熱い精液がいっぱいっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごい勢い……メイド服がお兄ちゃんの精液でドロドロになっちゃうよ？　\nにゃふふ、お兄ちゃんはこーゆープレイが好きなんだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ、んぁんっ……まだまだ出てる……こうして見下ろすと、まるでロッテ\nからおちんちんが生えてるみたい♪　にゃふふ、素股っておもしろいねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「どうだったかな、ロッテ、ちゃんとえっちなご奉仕出来てたかな？　お兄ち\nゃん、気持ちよくなってくれた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふふ、なーにお兄ちゃん、頭をなでなでなんてして♪　くすぐった\nいよ、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お？　おおお？　お兄ちゃんのおちんちんがまた固くなってきた……流石は\nお兄ちゃん、性欲魔人だねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふ♪　もちろん、ロッテのオマンコはお兄ちゃん専用だよ！　満足\nするまで、何度だって好きにお使いくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……え？　今度はお兄ちゃんから腰を振るの？　分かった、ロッテもタイミ\nングを合わせるね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあっ、にゃぁんっ……！　こ、これすごい、さっきよりおちんちん\nがおまんこにぎゅ～って食い込んで、あっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「精液のおかげかな、さっきよりもにゅるにゅるっておちんちんが滑って、あ\nっ、んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんの凸凹が、クリトリスにも擦れてるっ、あっ、あぁんんっ……！\n　お、お兄ちゃん、最初から激しすぎるからっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふふ、別に嫌じゃないよ♪　ロッテはお兄ちゃんの専用メイドだも\nん！　好きに使って、い～っぱい気持ちよくなってよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ、ほら、ロッテも頑張っておまんこしこしこするよ？　あっ、あぁんっ！\n　太腿ぎゅ～ってして、割れ目でにゅるにゅるするからねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、ひ、んひゃぁんっ！　パイパンおまんこを、すごい勢いでおちんちん\nが滑っていくっ、にゃ、にゃぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、気持ちいいね、お兄ちゃん♪　えっちなご奉仕、幸せだね♪　ん\nにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんの口からも聞きたいな。ねぇ、気持ちいい？　ロッテのつるつる\nおまんこ、気持ちいよね？　ね？　おにーちゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もー、こんなロリロリボディで興奮するなんて、ロッテのお兄ちゃんはどー\nしよーもない変態さんですねぇ♪　あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でも、そんなお兄ちゃんがだ～いすきだよ♪　もっとも～っといっぱい、え\nっちなご奉仕、させてくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁん！　あっ、あぁんんっ！　思考プロセスにエラー発生……あひっ\n、あぁんんっ！　今度は、ロッテも一緒に！　んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ダメなノイズなのに、このエラー、気持ちいいよお兄ちゃん！　あひっ、あ\nっ、ああぁんんっ！　もっと欲しい、気持ちいいの、もっとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃは♪　おちんちんがまた膨らんできたね！　先っぽぴくぴくして、どん\nどん熱くなって、あっ、んにゃんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「我慢なんてしなくていいからね、お兄ちゃんの好きなタイミングで出して！\n　ロッテのロリ素股でびゅーびゅーって射精して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんんっ！　また早くなった！　おちんちんぐりぐりっておまん\nこに食い込んでっ、あひっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「素股すごい！　お兄ちゃんのおちんちん、すごすぎるよぉ！　ロッテもイク\n、一緒にイクッ、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「出してっ、ロッテの事、またぐちょぐちょに汚して！　ロッテの身体はぜー\nんぶお兄ちゃんのモノだから！　好きなところにいっぱい出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひゃぁんんっ！　あっ、んにゃぁあぁんんっ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ドロドロの精液がおまんこと太ももにいっぱいかかってっ、んひゃぁんっ♪\n　イッてる、ロッテも一緒にイっちゃてるよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんがくれたエラー気持ちいい……んんっ……！　壊れちゃいそうな\nのに、変なノイズ、気持ちよすぎるの！　あっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんもっと頂戴！　ドロドロ精液、もっとドクドクって吐き出して！\n　ロッテのつるつるおまんこを汚してほしいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃあぁんっ！　これ、ただの素股なのに、中に出しても\nらったわけじゃないのに……んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ロッテのすべてはお兄ちゃんのモノだってマーキングされたみたいで……幸\nせ、ロッテは幸せだよお兄ちゃん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んにゃ……もう終わり、かな……？　すごい、しっかり立っ\nてるつもりなのに、両足がガクガク震えちゃってる……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ロッテ、しっかり出来てた？　お兄ちゃんに満足してもらえるぐらい、えっ\nちなご奉仕できてたかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……完璧だった？　にゃふふ、ま、とーぜんだけどね！　なんたってロッテ\nはぱーふぇくとメイドだもん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃん、ロッテの事使いたくなったら、またいつでも声をかけてね♪　\n誠心誠意、ご奉仕してあげちゃうからね♪　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁあぁんんっ～～♪　あっ、んああぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「またボディまで精液が飛んできてる！　あっ、あぁんんっ！　これ、精液の\nシャワーみたい♪　んにゃんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんっ、んんっ、ああぁんっ♪　ボディにかけられるの、すっごく気持\nちいい！　さっきのノイズがいっぱいになって、んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごい、これが絶頂……♪　あっ、あぁんっ♪　ダメなエラーもいっぱい出\nてるのに、気持ちよくて、幸せで、んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「我慢なんてダメだよお兄ちゃん！　精液を全部、ぜ～んぶロッテの身体にぶ\nっかけてね！　ロッテの身体はお兄ちゃん専用なんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んぁんっ……！　め、メイド服の中も外も、ドロドロになっ\nちゃった……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんてば、ほんとにロッテの事汚すのが大好きだよね～♪　ロッテの\n素股ご奉仕、そんなに気持ちよかったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　素直なお兄ちゃんかわい～！　ねねね、ちゃ～んとご奉仕でき\nてたなら、ご褒美をもらえないかな～、なーんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……もちろん、頭なでなでだよ！　さっきみたいに優しくなでてほしいな♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わわわっ！？　乱暴！　乱暴だよお兄ちゃん！？　ぐりぐりしないで～、目\nが回るぅ～……！」", "NORMAL" ]},
