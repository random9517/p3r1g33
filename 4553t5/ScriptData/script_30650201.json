		{"command":[ "PLAYVOICE", "v2_065_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ、はあっ……熱いっ……さっき射精したばかりなのに……どうして\nこんなに大きくなったまま……ふぅ、うぅんっ……」", "NORMAL" ]},
