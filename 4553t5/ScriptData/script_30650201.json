		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「水着で来いという時点でおかしいとは思ってましたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203102" ]},
