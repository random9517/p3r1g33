		{"command":[ "SETTEXT", "「もっと……長く楽しみたい？　そう言ってもらえるのは嬉しいですけど……\nい、今は早く……んっ、我慢しないでくださいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「お、おねだり……ですか？　うぅっ……趣味が悪いですね……でも気持ちよ\nく射精してもらうためなら……仕方ない、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あっ、んはぁっ……！　く、くださいっ……隊長殿の、精液……私の胸にっ\n！　さっきみたいに……いっぱい射精、してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁあっ、は、早くっ！　お願いですっ……！　だ、出してっ…\n…出してぇっ！　んっんんっ！　ひぃううぅぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「んううっ！　あっふっ……んンンンンぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はっ、くひぃっ……！　ンっ、あんっ！　ま、また……すごい勢いで……精\n液が、出てっ……はうぅっ、くふぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……あ、熱いぃぃっ……あはっ、あっあぁっ！　んんっ……ひうっ、\nうっうぅっ……こんなに、たくさん……んはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁっ……ンっ……だ、出しすぎ、ですよ……胸から、溢れ\nてしまって……んんっ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「なんですか、この量は……先ほどもいっぱい出してましたけど……今回の方\nが多くないですか……？　どうなってるのですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「興奮したし、気持ちよかったから……そう、ですか……ところでパワーアッ\nプの方はどうですか？　ちゃんと上手くいきましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「それならよかったです。私の水着姿も役に立ったようですし……なんですか\n？　役に立つどころじゃなくて、最高だった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「コ、コホン……隊長殿は相変わらず口が上手いですね……そうやっておだて\nても何もでてきませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「また水着で奉仕をして欲しい……ですか？　そういうことでしたら、まあ…\n…能力向上のために必要みたいですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「そこまで言われれば、仕方ありません。頼りにされるのも悪い気分ではあり\nませんし……準備しておきますので、必要な時はご命令ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ど、どうして……抜いてっ！？　ひっひうっ！　んっあっ、はぁぁぁぁぁぁ\n～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あっあひっ！　ひっ、いぃっ……んっ、ンンっ！　胸に、かかって……ひゃ\nうっ……あ、熱っ……熱いぃぃっ……くっはぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「なんで、こんなことっ……んぅう！　ひゃっ、うぅうっ……もうっ……身体\n中がドロドロになってしまって……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「こ、これがいい？　なにを仰ってるんですか……ひぃうっ！　んっ、んんぅ\nっ……あぁ、匂いまで……すごいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はーっ……はぁはぁっ……お、終わり……ましたか？　ううっ……二回目と\nいうのに、こんなにたくさん……うっ、むせそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「私の水着姿がよかったから？　その水着も隊長殿の精液でぐちゃぐちゃにな\nってしまいましたが……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ところで肝心のパワーアップは上手くいきましたか？　そうですか、それな\nらよかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「私が恥ずかしい思いをしたのも無駄にならずに済んで、本当によかったです\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「なんですか？　継続的に必要？　こ、これを……ですか？　ううっ……ぜひ\n私にお願いしたいって……ズルいですよ、その言い方……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「わかりました。隊長殿の頼みですから……水着も？　ええ、ちゃんと用意し\nておきますので、ご安心ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203410" ]},
