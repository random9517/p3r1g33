		{"command":[ "PLAYVOICE", "v2_065_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「特に先端はかなり膨張してますね……あっ……んっ……胸と擦れて、引っか\nかる感じがするほど、出っ張ってきてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「これは感じてる証拠ですか？　では私の奉仕が上手くいっているということ\nですね……それはよかった、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
