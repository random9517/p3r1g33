		{"command":[ "PLAYVOICE", "v2_065_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ、ンっ……隊長殿、できたら……あまり動かないで、欲しい……ので\nすが……気持ちいいから無理？　仕方ありませんね……」", "NORMAL" ]},
