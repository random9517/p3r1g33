		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……とりあえず、挟んでみましたが……こんな感じでよろしいでしょう\nか？　はい……もう少し強く圧迫するんですね……んっんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「確かに水着というのは……こういう行為をするのに適した格好かも、しれま\nせんね……汚れてもすぐ洗えますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「次は挟んだまま胸を動かして……扱く、ですね……わかりました。すぐ取り\nかかりますので……はっ、ふうっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「なんでしょうか……この不思議な感覚は……男性器を、胸で擦るなんて……\n考えたこともなかったですし……はぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00006502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
