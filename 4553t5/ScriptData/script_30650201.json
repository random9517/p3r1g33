		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あのですね、胸で奉仕しろって……隊長殿は自分が何を言っているか、理解\nしていますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「そんなこといきなり言われて、はいわかりましたとは言えませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「なんですか？　これはパワーアップのための行為？　私をからかわないでく\nださい。いくら冗談でも……え？　本当に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「にわかに信じられませんが……そこまで仰るなら、信じますけど……それが\n本当だとしてどうして私が？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「え？　私の水着姿が見たかった……？　なんですか、それ……ふぇ！？　す\nごく似合ってる？　あ、ありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「つまり隊長殿の能力を増幅させるための重要任務に選抜された……というわ\nけですね？　ふむ……行為内容はアレですが、名誉なことですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「わかりました。そこまで仰るなら、ご協力いたします。それで、私は何をす\nれば……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203109" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「胸で隊長殿の……こ、これを……射精へ導けばよろしいのですね。では、早\n速……胸でご奉仕させていただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203110" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「し、失礼します……んっ、あっうっ……あ、熱いですね……思ったより、す\nごく熱いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0203111" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
