{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……その……一応確認しておきたいが……重くは……な、ないよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか、よかった。いや、逞しい旦那様を相手に聞くことではないと分\nかっているが、一応……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……はは、何というか、こうして改まって二人になると、やはり……ちょっ\nと緊張するな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「分かっている……その、今日は……子種を貰いたくて……こうして、来た…\n…訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それで、最初は……私に、任せて貰えないだろうか？　気持ちを高めて……\nその気になってもらって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「太くて硬い……逞しいオチンポで……私のオ、オマンコを……いっぱい……\n可愛がって欲しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もうその気になっている？　う、うむ、それは何となく分かるが……私の気\n持ちの問題もあるから……まず……ここ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……オマンコの……入り口と……オチンポを……優しく……這わせて…\n…擦って……やる……んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ、素股だ……はぁぁ……んっ、臨戦態勢万全のオチンポに……私の…\n…溢れた、オマンコの汁を……直接……塗りつけていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……こ、この動き……恥ずかしいな……普通に入れてしまうより……余\n計に、いやらしいような……そんな気がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……オチンポがよく動く……あふっ……そうか……この動きで、\n興奮してくれているんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、恥ずかしい……けど……あぁっ、嬉しい……んっ、もっと…\n…もっとオチンポ大きくさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……私も早く入れたいんだ……だが、ここはぐっとこらえて……ちゃん\nと、オチンポ全体に汁をつけるまで……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よい……しょっ……先っぽの後は、付け根の方……あぁ……あ、あんまりじ\nっと見ないでくれ……腰を突き出す格好は……は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ！　これでもう準備は整ったな？　私も……もう駄目だ……はぁんっ、\n入れてしまうぞっ、オマンコに……オチンポっ、ハメ……るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんんんんんっ！　はぁぁぁぁぁぁぅぅん……あぁ……入ったぁ……あっ\n、あぁ……熱い……いっぱいに……なって……るぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……簡単に……奥まで……届いて、来たぁ……ぁぁぁ……オマンコ、\nぐいって……広げ、られて……るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……あぁ……太い……オチンポ……思ってた以上に……逞しいっ…\n…これぇ……すご……すぎるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、待っててくれ……すぐ、動くから……でも、まず……ちょっ\nと私の方の準備をさせて……このオチンポに慣れさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっふ……あぁぁ……本当に太い……かたくて、ごつごつしてる所と……ぐ\nにゅって柔らかくなっている所が……一緒にあって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「中で、ちょっと擦れるだけで……身体が……じーんと痺れて……はぁぁ……\n腰に、力が入らなくなりそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、でも……全身が幸せに包まれていて……もう、すごく……気持ちい\nい……これから、動いたら……もっと凄いんだろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……大丈夫だ……そ、そろそろ……動くから……はっ、あっ、あぅんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、はぁっ、あぁっ……擦れるっ……んくぅっ、オマンコっ…\n…あぁっ、グリグリ……されて……来るぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、これ、ダメだ……ダメぇ……あっ、思ったより……ずっと気\n持ち、よくてっ……あひっ、と、蕩けるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あひんっ、あぁぁ……いや、大丈夫だ……んっ、この位で\nメロメロになっていては、到底あなたのオチンポを満足させられない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のオマンコも……ちゃんとあなたに尽くすための準備は出来ているんだ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あんっ、あぁっ……あっ、はんっ、ゆっくり腰を回して……ヒ\nダを……オチンポに擦りつけていく……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、はっ……ここ……どうだ？　んんっ、キュッと締まると……はぁっ、\nオチンポ……ビクビク震えて来るだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ……少しずつ速くしていくからな……んっ、あっ、ふっ、あぁっ……\nはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコが埋め尽くされてる……オチンポ……前より、もっと大き\nくなっているみたいな……んぅぅっ、これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ……くぅんっ……分かってる、先端をグリグリって……\nするのがいいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、子宮の入り口と……オチンポの先が……何度もキスして……あぁ\nっ、オチンポ震えて来てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、出したくなったら……すぐ出して……いいんだからな？　はぁんっ\n、もちろんこのまま中出しだっ……オマンコに種付けだからなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、ほらっ、激しく……腰を振ってっ、んんっ、あぁっ、ラス\nト……スパートっ、さあっ……出してっ、射精っ……してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅぅぅんっ！　あぁっ……イッ……ク！　はひっ……中っ……出て\n……るぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……オマンコがいっぱいになる……子種がじわぁって……広がってい\nく感じ……するぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ、あっ、ふっ……んぁっ、はぁっ、はぁ……はぁ……はぁぁ……\nはぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……すごかった……元気な精子が、私の中でいっぱい泳いでいるんだな\n……ふふ……ちゃんと受精出来るだろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はふ……頭がずっと真っ白だ……しばらく、この感じを味わっていたい位だ\nが……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうやら、まだ、中でオチンポはずっと硬いままだからな……このまま続き\nといこうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、一回位で終わるなんて最初から思ってない。私も、もっともっと…\n…あなたのオチンポを感じていたいんだ……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっく……うんっ……んふっ……だから、このまま抜かずの２戦目\nだ……はっ、ふっ、んんっ、あんっ、はぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……さっき出された精液が……オマンコの中で……ぐちゅぐちゅしてる\nっ……んっ、ふっ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、んんっ、ヌルヌルが混じると……最初の時と……また、違う気持\nちよさで……あんっ、ずっと、腰を回していられるな……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……どうだ……？　ちゃんと、オマンコ……感じてくれているか\n……？　あんっ、こんな……私ばっかり気持ちよくなって……ないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……あぁっ、なっ……か、感じてる顔をずっと見ていられる……おっぱ\nいの揺れも……楽しんでいる……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「バ、バカっ……そんな、は、恥ずかしいことを見ていたのかっ……うっ、や\n、やめるなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　あっ、突き上げっ……られるぅっ！　あひっ、はっ、ひぁんっ\n、あぁっ、急に……そんなっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、らめらっ、オマンコっ……そんなにされたらぁっ、はんっ、あぁっ\n、またっ……ビクビク……するっ、んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、あぁんっ、ほ、本当だっ……揺れてるっ……おっぱい……\nこ、こんなに恥ずかしく揺れてるなんてぇっ……はひっ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあっ……顔もっ……いやらしい顔もっ……今っ、見られてるっ…\n…オチンポ突かれてっ、メロメロになってる顔……バレてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、恥ずかしいっ……！　けどっ、気持ちいいっ！　オマンコっ、ズリ\nズリかき回されてぇっ、んぁぁっ、幸せになってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、もっと愛してっ！　オチンポいっぱい突いてっ、おっぱ\nいもっ、あぁっ、好きにしていいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私もするっ……！　んくぅんっ、あなたのオチンポに喜んでもらうっ！　は\nぁんっ、ヌルヌルのヒダを……もっとずりゅずりゅしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ！　これっ、あぁっ、オチンポがビクンって跳ねる時の感じぃっ\n……もっと……味わいたいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000118_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　オマンコ……ぎゅってするのっ、すごくいいっ！　オチンポと\nくっついてるのっ……すごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁんっ……こんなのっ、またイクっ……気持ちいいの、\nずっと続いてっ……あひぉっ、どんどん……よくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「また……出るっ？　んんっ、あぁっ、私もだからっ……一緒にイキたいっ！\n　はんっ、あぁぁんっ、あなたと一緒がいいっ！」", "NORMAL" ]},
