		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「中っ……あぁっ、それでいいっ、中出しっ……んぁぁんっ！　もう一回……\n奥にっ、届けてぇっ、私もっ……はぁんっ、イクぅぅぅぅぅっ！」", "NORMAL" ]},
