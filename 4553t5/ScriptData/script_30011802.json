		{"command":[ "SETIMAGE", "0", "still_00000118_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁぁ……んふっ……中でとぷんって精液が泳いでるみたいな……\nあぁ、本当にいっぱい出してくれたんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
