		{"command":[ "WAITMOVE" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ……やっとホテルの中に入れましたね……もう、ずっと二人きりにな\nるのが待ち遠しかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほらほら、シャワーなんて後です。今、服も脱がしてあげますからね……は\nーい、全部ですよ……全部……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、そのままベッドに……ええ仰向けのまま……リラックスして下\nさい。全部、私がしてあげますから……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふふ……もうオチンチン、ギンギンじゃないですか。この凶悪なサイズ…\n…オチンポって言う方が相応しいみたいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001404_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さすさす……こすこす……あら……ぴくぴくって震わせちゃって……見た目\nより、ずっと可愛らしい反応しちゃうんですね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、今日は……このオチンチン……いーっぱい、いっぱい可愛がってあげ\nますから。私、色々な本を読んで勉強したんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「今日は、んふふ……本で読んだコト……気持ちよさそうなこと全部してあげ\nますからね……んっ、ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「おっぱいが当たってるの……分かりますか？　私の乳首も……まだ触ってな\nいのに、すごくコリコリになってるんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、んっ、れろ……ぺろ……んふふ……それは、貴方の乳首もそうみたい\nです。こんなにツンって盛り上がって……可愛い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、オチンポだけじゃないですよ……今日は、この可愛いおっぱいも……\nすごく感じる場所なんだってこと……教えてあげますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……んっ、ふふ……舌……ちょっとぬるってしますけど、我慢\nして下さいね……ぺろ、れろぉ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……お腹の辺りも結構敏感なんですね。ほら、またオチンポがぷるんっ\nて……まだシコシコする前からいっぱい震えて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ここは、後もうちょっとだけお預けです。その前に……手にローションを付\nけて……滑りやすくしておきますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ……これでよしと。それじゃあ……そろそろ、シコシコしちゃいますよ\n……んふっ、はぁい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わぁ……すごく熱くなってます……手のひらに収まらない位……オチンポ、\n太くて……逞しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「すぐに出しちゃったら勿体ないですからね……ゆっくり、少しずつ気持ちよ\nくなっていきましょうね……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れろ……んちゅ……当然……おっぱいも一緒ですよ……んふっ、敏感過ぎる\n場所……同時にレロレロしちゃいますから……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、身体がもぞもぞ動いてます。いいですよ、好きなように動いてもら\nって……逃げても追いかけちゃいますけど……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅ……シコシコ……オチンポを根元から握り締めると、腰が浮き\n上がって来ちゃうでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうして腰を浮かせた状態で……ふふ、今日は……オチンポの先っぽのとこ\nろ……手のひらでしてあげますからね……えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら、こうして亀頭の所を抑え込んじゃうんです。そのまま、手をぐりぐり\nって動かすと～、ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ね、敏感なところがムズムズして堪らないでしょう？　敏感オチンポの一番\n感じやすいところ……強めにされちゃうんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ローションの音もヌチュヌチュってして……恥ずかしくなっちゃいますね…\n…？　私……聞いてるだけでゾクゾクしちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら……んっ、ちょこんって……私の乳首……当たって、かたくなってるの\n分かりますか？　貴方のと同じ位……コリコリにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンポご奉仕してるんだって思うと……身体……熱くなって、すごく興奮\nしちゃうんです……れろ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くすっ、貴方の乳首も同じですね……いいですよ、口でもっと弄ってあげま\nすから……れろ、あむ、ちゅぱ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はむ、んく……あぁんむ……れろ、ふふ……おっぱいとオチンポ……感じる\n場所がバラバラだと気持ちが追いつかなくなるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そういう時は、余計なことは考えずに身を任せちゃうしかないんです……れ\nろ、んっ、ちゅぷ……また、手……動かしますよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぐりぐり～しこしこ……ずりゅずりゅ……ふふ……下の方で、すごくエッチ\nな音がいっぱいしちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こういう時に、不意打ちで……えいっ……んふふっ、ちょっとキンタマをさ\nすってあげると、ビクンってなるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このまま、ギュッて握って……思い切り扱いたら、すぐ精液でちゃいそうで\nす……でも、もうちょっと待ちましょう……ゆっくりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、そう……いつもオナニーしてる時より、多分ずっとゆっくりで\n……もどかしいんじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、ちゃーんと身体は気持ちよくなってるんです。今はとろ火で、じっく\nり身体全体を炙ってる時……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……んふ……身体の色々な場所を舐め回して……ちゅぷっ、全\n身が性感帯になる感じにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……んっ、さぁ、そろそろ待ちきれなくなってますよね……？　ここ\nで、また亀頭をぎゅうっとしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰がビクビクって……そうですね……一回出しちゃいましょうか…\n…ここで、一気にぎゅうって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そう……このままですっ、私の手の中に……思いっきり射精しちゃいましょ\nうっ、はーい、どぴゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふふっ……！　はぁ……んっ、出てます……！　すごい勢いで……手の中\nに熱いスペルマ……トロトロになってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁ、あったかい……ローションと一緒に混ざって……私の手が大変なこと\nになっちゃってます……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……オチンポ、よかったですか……？　気持ちよさそうなお顔を見てる\nと……私も、とっても嬉しいです……はふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも……本当に気持ちいいのはここからですよ？　一度出して、まだ痺れて\nるオチンポ……ローションの手の中にぎゅっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふふ……温泉の中に浸かってるような感じしませんか……？　このまま、\nくにくにって……敏感な亀頭をくすぐって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……れろ……思い出したように……ちゅぱっ、乳首……吸ってあげた\nりして……ふふっ、また下半身が落ち着きなくなりましたね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「可愛いです……はぁい、キンタマも……モミモミしちゃいましょうね……ぎ\nゅうっと……ふふっ、どんどん力が入っていきますよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このまま押し潰しちゃう位、むにゅって……苦しいですか？　えっ……気持\nちいいかも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、この強さでも気持ちいいって思っちゃうなんて……ちょっとマゾっ気\nがあるのかも知れませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、そういうことでしたら遠慮なく……んっ、ふっ……オチンポもキツく\n握りしめて……またシコシコしちゃいますよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……音……ぐちゅぐちゅ鳴ってます……まるで手の中でオマンコ\nしてるみたいに……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい……私の手がオナホールみたいに……ローションまみれのエッチなオマ\nンコ穴になっちゃってます……んっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、興奮しちゃいますよね……私もすごくドキドキしています……ほら\n、乳首もさっきよりコリコリですし……オマンコも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、見えてないから分からないかも知れませんけど……もう、ぐしょぐし\nょなんですよ……お汁が……止まらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「中に入れたりしたいですか？　ふふっ、それとも……こうして手でシコシコ\nされてるだけでも満足しちゃいますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なんて……ふふっ、今はそれどころじゃありませんよね。はい……普通じゃ\n味わえない極上の手コキ……もっと楽しんでもらいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「にゅるにゅる……くちゅくちゅ……オチンポが精液とローションまみれで、\nいやらしく光ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほぉら……また先っぽ……手で押し込んじゃいますよぉ？　んふふっ、また\nビクビクって……次の精液上がって来ちゃいましたね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……れろ、さあ……今度はどんな風に出したいですか……\n？　いやらしいローションの中にびゅびゅって出すのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それとも……私のお顔にぶっかけとか……しちゃいます？　いいですよ……\n貴方の濃いスペルマ……浴びちゃうの……素敵です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、シコシコ……くちゅくちゅ……ほら、そろそろ決めちゃわないと…\n…もう余裕が全然なくなっちゃってますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンポ……今度はもっと精液出ちゃいますよね……ほらほら……さぁ、決\nめちゃわないと……間に合いませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……もう手が止まらないです……さぁ……イッちゃいま\nしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んくっ……このまま手の中で出したいんですね……？　はい、大丈夫です…\n…ぎゅってして……はぁい……ドピュって出しましょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はんっ……！　んふふっ……あぁ、出てます、出てます……オチンポ、プル\nプルして……いっぱい射精なさってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……今、オチンポをシコシコすると……もう、たまらないでしょう……\n？　痺れてる所をぎゅうっと絞り出してあげると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はふっ、またいっぱい出て来ました……ふふっ、やっぱり絶倫オチンポです\nね……まだ溢れて止まらないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、そろそろ落ち着きそうですか？　じゃあ、ゆっくりにしていきますね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、お疲れ様でした。ふふ……手の中がザーメンまみれですごいです……\nれろ……ちゅぷ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「美味しい……んふっ、ちょっとローションで薄くなっちゃうのが惜しいです\nけど……でも、この味……ウズウズしちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ……それじゃあ、待って下さいね。今、オチンポ綺麗にしちゃいますから\n……ん、ふっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、これで綺麗ですよ。いえいえ、どういたしまして……気持ちよくなっ\nてくれたら、それが何よりですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……それに、まだこれから長いですからね……この後も、私のこと……\nいっぱい可愛がって下さいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ……顔に掛けたいんですね？　いいですよ……今、そちらにお顔を寄\nせますから……思いっきり飛ばして下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　はぁんっ……オチンポっ……ドピュって……元気……いっぱ\nいっ……んぁふっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「素敵です……まるで噴水みたいに飛んで……はぁぁ……顔に……スペルマ…\n…浴びてます……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……ちゅぷっ……はぁ……トロトロのを直接味わう喜び……他では替え\nがたい楽しみです……ちゅぱ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001404_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ……流石に、もう終わりですか……？　じゃあ、後もう少しだけ……シコ\nシコしますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ……！　最後に残ってた分を搾り出して……はい、これで終わりです。\nお疲れ様でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……ちゅぷっ……このねとねと……ずっと触っていたい心地よさですね\n……でも、そういうわけにもいきませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、オチンポの方はしっかり後始末させて下さい。ちゃんとこのぬめりは\n取ってあげて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、これでよし。綺麗になりました。ふふっ、どういたしまして。これは\n次の準備のようなものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい。夜はまだまだこれからです。少し一息ついたら……今度は私自身のこ\nとも……いっぱい味わって下さいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0403410" ]},
