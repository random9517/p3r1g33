		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「となれば、余が許す雄といえばお主しかおらぬ。ふふ……光栄に思うがよい\nぞ。ほぅれ……もっと近くで見てみるがいい」", "NORMAL" ]},
