		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうじゃ、細かいところまで精巧に出来ておるじゃろう……？　ヒダもしっ\nかりよじれて……内分泌液も、ほぼ同成分で湧いてくる……」", "NORMAL" ]},
