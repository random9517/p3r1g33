		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「それで……どうじゃ、味は……？　ふふ、そうか、そうか、ちゃんとマン汁\nを感じるか。そうであろうな」", "NORMAL" ]},
