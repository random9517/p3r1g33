		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぅんっ、あっ、んぁっ……！　い、今っ……また奥をっ……オマンコされ\nたらっ！　くひぃっ！　はっ、はひっ、あっ、あひぃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「それぇっ、あっ、エロ音っ……ズボズボさせてぇっ！　グリグリっ……擦れ\nるのがっ、あぁっ、良すぎてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「またっ……ああっ……次のが来るっ！　また気持ちいいのが来てるっ！　イ\n、イクッ……オマンコっ……イキそうになっておるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んはぅっ……お主もっ……また出したくなっているんじゃなっ？　よいぞっ\n……んっ、この先はお主の好きにするがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「また中に出してもよいっ……んぅっ、余にぶっ掛けるのもよいぞっ！　顔で\nも……おっぱいでもっ、お主の欲望のままにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……そうじゃっ、オマンコッ……もっと激しくぅっ！　とにかく全\n部っ……熱いのっ……出すのじゃぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁぁっ！　くぅぅぅぅんっ！　中っ……あっ、また中にっ……ザ\nーメンっ……出て来てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁん……溢れてくる……まだ出てぇ……あぁ……どれだけ出すつもりな\nのじゃ……だが……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっふ……はふ……あふぅぅ……もう少し……？　うむ……今更遠慮するこ\nとはない。全部出してしまうのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ、余も締め付けて……搾り出していくからの……んんんっ、むぅっ…\n…ふっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁぅ……お腹がいっぱいにされていく……はふぁ……身体がずっとイッた\nままで……ビクビク……するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「終わったか……？　はふぅぅ……全く、いっぱい出してくれたものじゃ……\nいや、余が望んだことではあるがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、じゃが……たっぷりのデータを得ることが出来た。ふふ……余のＡＩ\nも様々なテクニックを学習できたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「さて、当然次はこれを活かして、もっとすごいことをしてやらんとなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふん、決まっておる。これだけ余を責め立ててくれたのじゃ。この魅惑の\nボディにメロメロでなければ、そうはならぬよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「期待しておくがよいぞ。お主の想像を超えた、より艶めかしい余の姿を震え\nて待つがよい。くふふふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁっ！　んぁっ、チンポ……抜けてっ……熱いのっ……ザーメンっ\n、びゅるびゅるっ……出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁ……中だけでは飽き足らず……身体にまで……んっ、お主も本当に\nドスケベじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……別に怒っているわけではない。中途半端にするよりずっといい。残\nさず、余の身体にシャワーを浴びせるのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ……この濃い匂い……クラクラするのう……余のボディに染み渡るこ\nの感じ……クセになってしまいそうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ……！　あぁっ……イったぁ……余も……ザーメンの匂いで\nイッてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、もう射精も終わりか……？　ふふ、よく出したのう……うむ、ご苦労\nじゃったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「お陰でたっぷりのデータが取れた。メンテナンスとしても、予定以上の成果\nがあったと言えるじゃろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「後は、この得られたデータを学習して……次は更にどエロいことをしてみよ\nうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ……とぼけずともよい。お主は、この魅惑のボディでしっかり興奮で\nきるマニアだと分かったからな」", "NORMAL" ]},
