		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……ほれ、本物と同じかどうか舐めて確かめてみるがいい。そして、余\nのオマンコを感じさせるのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ……！　はぁんっ……そうじゃ……舌を割れ目のところに丁寧に押し\n付けて……なぞっていくのじゃ……ん、くぅぅ……んふっ」", "NORMAL" ]},
