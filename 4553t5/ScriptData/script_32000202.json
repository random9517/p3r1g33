{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あら……隊長様。もう、海で遊ぶのはおしまいにしたの？　いいえ？　いい \nのよ、私を誘ってくれて嬉しいわ。だって、ほら、二人っきりだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……岩陰で一体何をするつもりなのかしら。なぁんて……大体予想はついて \nいるわ。そして、私もたぶん、同じ気持ち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「どうしましょうか。何から始めたい？　情熱的なキス……それとも、密着し \nてサンオイルを塗りっこするとか。……って、あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「やぁん……もう、そんなに焦らないで……♪　びっくりしちゃったじゃない \n。急に襲いかかってくるなんて、今日の私、フェロモン出てたかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……んっ♪　こぉら……お話もしないでさわさわお尻や太ももを撫で回すな \nんて……。あっ、だめ、よ……♪　んんっ、あん、胸も触るのぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「っぁ……♪　私のアソコが、オマンコが濡れてお股から愛液が溢れ出してる \n……ですって？　ウフフ、やっと気付いてくれたのね。んん、そう、よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「私、待ってたの……。あっ、あなたがいつ襲ってくれるのか。ずっと楽しみ \nにしてた……♪　でも、夜じゃなくてこんなお昼真っ最中だなんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「本当にお盛んでありがたいばかりだわ……♪　はぁっ♪　ん、はぁ……♪　 \nぬちゅ、ぬちゅっていやらしい音、してるでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「今、私の股間にオチンポをこすりつけているあなたにならわかるはずよ…… \n。っんっ♪　これね、中まで濡れてるの。もうずっとぐっしょり……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「オチンポをっ……はぁっ、はぁ、こんな風にあてがわれて、焦らされたらた \nまらないわ……。疼いてどうにかなっちゃう、身体がおかしくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ね、え……♪　オッパイやお尻、どこでもいくらでも触っていいからぁ。オ \nマンコにおあずけするのはやめてほしいわ。……犯してほしいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんっ……おねがぁい♪　こんなはしたない、濡れたお股じゃ浜辺になんて \n戻れないわ……太くてかたぁい、おっきな何かを入れてもらわないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……そうよ♪　オーヴァーハング四天王のマグナスはぁ♪　あなたのオチン \nポ狂いなの♪　他の子とは違ってドスケベなドMなの、だから……ねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あんまり切なくさせないで……っ。オチンポが欲しくてヒクヒクしっぱなし \nの、淫乱オマンコにあなたの太いのが欲しいのっ、早くちょうだいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……ッ♪　あぁあああんっ……♪　やだぁ♪　すっごいぃいい……っ \n♪　あらっ？　あらぁっ？　いつもより硬くて乱暴な気がするわぁっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ううん、嫌じゃないわ……。むしろ嬉しいのっ、あぁっ……はぁあっ♪　な \nんて素敵なの……ガチガチのフル勃起オチンポがオマンコに入ってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんっあぁっ♪　遠慮なんていらないわ……あっ♪　どうせ、オチンポを入 \nれてもらっただけで軽くイッてしまいそうなドMよ……私は……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「他の女の子にはとても出来ないような、下品な腰使いで突いてちょうだい… \n…っ！　乱暴に！　力任せにっ、ケダモノのようにっ……はぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……っあっ♪　ああああああッ♪　そ、う♪　そうよぉ、上品に愛し合うな \nんて、そんな生半可なプレイじゃ満たされないの、犯して、犯してぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んんんぁっ♪　あぅっあああっ♪　あはぁんっ♪　んふっ……♪　あッ♪　 \nあッ♪　そうよ、これよ……硬いオチンポでオマンコを串刺しにされてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ズポズポズコズコ肉穴として使われるのっ……！　あぁんっ、イイわ、すご \nく感じるぅ……！　いっぱいイジメてぇっ、壊すつもりで突いてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んあッ♪　おっ♪　おぉっ♪　っひぃいっ♪　イイ……イイっ、すごくイイ \nっ……！　太いオチンポに無理やり貫かれて、道具みたいに動かされてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んっあぁああっ……最高よぉっ！　すぐにイクわっ、あっ……♪　あっ…… \n♪　……あ、あら？　どうしたの、腰のスピードを落とさないでっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あと少しよ……ほんのちょっぴり子宮を突いてくれるだけでイけるのにぃっ \n！　……えっ？　ピストンをしてほしければおねだりをしろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「してるじゃないぃっ♪　こんなにオマンコのヒダヒダが、うねって、濡れて \n、あなたのオチンポにおねだりしてるっ！　それじゃダメなのぉっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……あぁんっ、いやよ、いやぁ……♪　もったいつけて腰を動かすのをやめ \nるだなんてぇ……♪　わ、わかったわ。言葉で言ってほしいのね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「い、淫乱四天王のアルスラ・マグナスはぁ……！　いやらしい衣装を身に着 \nけて、エラそうに過ごしていながら本心では隊長様のオチンポ奴隷なのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「隊長様のたくましいオチンポを想像して、ずっとオマンコを濡らして待って \nたのよっ……！　あぁっ、強引に犯されて、めちゃくちゃに抱かれてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「生のオマンコに思いっきり濃い、純白の精液をドクドク注ぎ込んでもらって \nっ……はしたなくお外で妊娠したかったのっ！　はぁ、はぁ、はぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ねえ……突いて、私のことイカせてぇっ……♪　熱いオチンポがオマンコに \nぐっぷり突き刺さってるのに、おあずけなんて死んじゃうわぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「精子っ……精液くださいっ♪　淫乱四天王のドスケベオマンコに、生で特濃 \n精液注入して……♪　んんっ、あぁ……だめ、自分で腰を動かしちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ほ、しい……欲しいのっ、男らしいピストン♪　おねがぁい……！　んぁあ \nっ！　そうっ、それよ！　そのまま……突き上げてぇっ！　はぁああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あっ、イクぅっ♪　イクわ、イクぅうっ……！　あぁんっ♪　隊長様のオチ \nンポ本当に好きよぉお……っ♪　私の好きなところに当たるのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「一番気持ちいいところ、えぐって、かきまわしてくれる……ぅっ♪　いやら \nしいオチンポっ、あぁっ、あっ、長くて気持ちいい……あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「んぁああっ、ピストンのやり方もっ、好きっ……あっぁっあっ♪　世界一の \n生オチンポっ、入れてくれてありがとうっ……あぁんっ、またイクぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ふぁああああンッ♪　あっ……いいのぉっ！？　私の中に……オマンコの中 \nに貴重な精液っ……大事な子種をビュクビュク解き放ってしまってぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっあっあっ……！　ダメなんて言っても、もう離さないわ……っ \n！　あぁんっ♪　この精液はぜ～～んぶ私のもの、そうよねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あぁああああ……！　容赦なく子宮に撃ちこまれるこの精液……ぃっ♪　あ \nっ♪　入ってくる、私の一番奥に入ってくるぅう♪　あぁっあっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「はぁんん♪　まだ出るの……！？　そう、私の卵子が欲しいのね……！？　 \nあっぁっ、いいわよ、孕ませてちょうだい……たくさん出してぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「真夏の海で無理やり種付けされるなんて……最高だわ♪　あぁ、もっと♪　 \nもっと出して……精液の海で溺れさせてぇえっ……んぁんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ぅ、くぅううう……♪　ん～～～～～～っ♪　……あ、あぁ、ごめんなさい \n……？　強制的に妊娠させられる妄想で勝手にイかせてもらったわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「一方的に、無理やり中出しされてる～なんて言っちゃって悪かったわね…… \n。うふふ、私がおねだりして出してもらったのに……うふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「つい、盛り上がると変なことを口走っちゃうわ。……その、お詫びと言って \nはなんだけど……。このまま、少しここで休んでいかない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「せっかく海に来たんですもの。少しはイチャイチャしましょうよ。あぁ、で \nもイキすぎて疲れてしまったから、日陰でゆっくり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……ひぁん！？　やっ……？　た、隊長様？　どうしてオチンポが私の中で \n……オマンコの中で復活しているんですか？　あっぁっ、ま、待ってぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「だめよ、まだイッた余韻が抜けていなくて……あぁんっ！　今動かれたら… \n…あっぁっ、いつまでもイキ続けることになっちゃう……だめぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あなたの精液で満たされたオマンコを……ひぁんっ！？　休む間も \n無しにかき混ぜられて、２回戦だなんて……あっぁっ、予想外よ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あなたの体力は無尽蔵なの……！？　あっ♪　ち、ちがう……？　今日の私 \nの姿が……何度でもしたくなるほどエロかったから？　そんなぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00020002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そんなこと、言われたら……ぁっ♪　気持ち良くなっちゃう♪　あっ、でも \n嘘じゃないのね……！？　オチンポの強さがそれを証明してるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「気に入って、オマンコからオチンポっ♪　抜きたくなくなってくれたなんて \n……あっ♪　わかったわ、もうどうなってもいい……イカせ続けてぇっ♪」", "NORMAL" ]},
