		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……ん……♪　結局、部屋にいようが海にいようが、二人ですることなんて \nいつも同じね。えぇ？　嫌だってことじゃないわ。当たり前でしょう？」", "NORMAL" ]},
