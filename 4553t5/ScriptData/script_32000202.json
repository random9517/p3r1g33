		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あぁっあっあっ！　もっとぉ♪　もっと浴びたいわ、もっとかけて……！　 \nはぁあっ♪　何度出しても出したての精液のこの量、この多さ……っ」", "NORMAL" ]},
