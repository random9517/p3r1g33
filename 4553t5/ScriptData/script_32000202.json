		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　最後まで絞り取ってあげる……んんんっ♪　あんっ♪　んんっ \n、ドロドロぉ……♪　たくさん出してくれてありがとう……っ♪」", "NORMAL" ]},
