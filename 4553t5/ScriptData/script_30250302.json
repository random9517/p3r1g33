{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「よいしょっと……♪　まあ、お前の体勢はこんなモノかねぇ……？　フフフ\nフッ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「今日も勤務ご苦労様。……だけども、お前は一番大切なことを、どうやら見\n落としていたらしいねぇ……。ああ、そうだよ。私のことさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304102" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私にこんな格好をさせておいて、放置したままお仕事だなんて……許される\nはずがないだろう？　こっちはとっくに、アソコに火がついてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……。身体を疼かせて……、海水なんかに浸かったくらいじゃ、ちっと\nも冷めない情欲の嵐……。火照る肉体をさんざん持て余していてねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いつもなら、こんな栄誉を与えてなんてやらないけどさ。今夜は例外だ。お\n前に、私の発情を慰める……癒す役目を与えてやろうっていうんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……おっと。多少暴れたところで、無駄だよ。今夜の私は全力全開だ。抵抗\nなんかさせるわけないだろう。……それ、チンポを見せてごらん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っ……ごくっ……♪　なんだ、お前もすっかりその気じゃないか。したかっ\nたんだろう？　私の水着を見てからずっと。抱きたかったろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それをこっちから願い出てやったんだ。せいぜい感謝してもらわないとねぇ\n……。さあ、ここからどうやって襲ってやろうか。楽しみだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……♪　こういうプレイの事を、逆レイプって言うそうじ\nゃないか。すこーし興味があったんだ。ちょうどいいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら……私もさ、すっかり準備ができちまってるんだ。さっきからずっと、\n脚にまで蜜が……愛液が垂れて流れるくらい濡れちまっててねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「指かなんかでほぐしたりしなくても、すぐにチンポが入っていきそうなくら\nい……大洪水。くちゅ、ちゅくってあま～い水音まで聞こえてくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……ね～え、いいだろう？　チ・ン・ポ♪　お前のチンポを私にくれるだろ\nう？　今日のオマンコは凄いよぉ？　熟れてまとわりついてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「絶対に、チンポを掴んで離さない……。想像してごらん。シロップでひたひ\nたなヒダが、敏感なチンポを咥えこんでむしゃぶりつくす……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいよねぇ？　ご馳走になっちゃってもさぁ……。さぁて、さっそくいただ\nくとするかね……。このデカチンを……行くよ？　腰を落として……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ンッはぁあああああああ～～～♪　これだよっ、これっ、コレぇえええ～～\n～♪　あああああ♪　硬いっ、デカくて下品な極太チンポぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……ああっ♪　一番奥までぐ～～～っぷり入ってきた♪　んっ\n……おっ♪　ああああっ♪　カリ高の美味しいチンポ♪　チンポっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、響くよォ……♪　子宮にズンズン直接響いてくるっ……！　\nはぁっ、はぁ♪　い、いやだね♪　今の私ったらまるで痴女じゃないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「男の部屋に忍び込んで、疲れて寝てるとこに夜這いして……♪　はははっ、\n許可も取らずに逆レイプ♪　避妊もせずに生挿入だ……！　っぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「昂るだけ昂らせた身体にズップリと、ぶっといチンポを埋めるこの快感……\nっ♪　敵を一方的に殲滅するよりも気持ちいい、最高さ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っあぁ……♪　下郎の肉棒を、オナニーに使うこの悪行……♪　感じなかっ\nたらウソだろう♪　ほんっとうに気持ちがいいよ、痺れちまう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……ん？　なんだい？　いきなり襲いかかってきて、チンポを咥えて失礼だ\nって？　あっはははっ、そりゃそうだろう、これはレイプなんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「嫌かい？　嫌なら我慢してみなって……。少しも感じずに、先走りの汁も出\nさずに……声を抑えて、精子も出さなきゃいいじゃあないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私は勝手に、腰を動かして……。ッぁっ♪　こう、やって……こうやってぇ\n♪　好きな角度で、やりたいように、動く……からねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そんな一方的なレイプじゃイかないってんなら根性見せなよ……。っあぁっ\n……♪　私はチンポが萎えちまったら抜くだけさ♪　……んぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ただねぇ？　デカくしたまんまなんだったら……自由に使っちまうってだけ\nのことだ……。っはぁっ♪　はぁっ、はぁ……ここ……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「もう少しこっち、か……。あっ♪　そうだ、ここ……ここだ♪　んぁああっ\n♪　奥っ、の……♪　一番奥の少し手前、子宮口の前……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ここを亀頭でズリまくるのが気持ちいいねぇ……！　っあああああ♪　あぁ\nあああっ……！　あはははっ、ちょうど都合のいい形をしてるからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こん、な風に腰を振られて♪　カリを勝手に使われちまうのさ♪　っあぁあ\nあ……♪　イイ♪　イイッ……すごくイイとこに当たるぅっ、いいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あっあっ……！　やっぱりオナるなら、お前のっ……チンポ\nを使うのが一番だ♪　あぁ……あぁ、あああああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁああんっ、ああっ……ああああっ♪　チン、ポ♪　チンポ……すごくイ\nイ……♪　逞しいチンポっ、バキバキの強いチンポが効くぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私、のオマンコが悦びに震えてるのがわかるだろうっ……！？　んあああっ\n……ああああっ、はぁああっ♪　腰っ、腰、止められない、ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい？　チンポをびしょぬれにされてっ……あっ♪　ぐちょぐちょのオ\nマンコで絞りあげられるのはっ……！　股間が熱くなってくるだろっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁあああ……♪　最低だねっ……！　犯されて感じているなんて♪　女に\nっ……私に馬乗りにされて、使われて、利用されて……♪　ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「まともにっ、動くことも出来ずに尻を揺らされて……。フフフフッ♪　チン\nポを支配されてるんだ、悔しくて悔しくてゾクゾクするだろう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……おや……？　どうして勃起が強くなってきてるんだい？　まさか、射精\nしそうになってるのかい？　あははっ、いいよ？　別に出してもさ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こっちが襲って締めつけてるんだ。中に出されたって文句は言えないし……\n。あっ♪　あっ♪　ちょうど精子を注入されたい気分だしねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「出、してみるかい？　フフ……ふふふ、その勇気がお前にあるかねぇ？　チ\nンポばかり立派な、犯されたがりのドマゾのぼうや……。ッんんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あはははっ、あははっ♪　我慢出来ずにしーしーしちゃったね\nぇ♪　射精っ……♪　膣内で、ドッピュンドッピュン音をたててるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ンぁあああああ♪　あはぁあああ♪　美味しい……美味しいよ♪　お前の精\n液……！　ゼリーみたいにブビュブビュ、固形で出てきてさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私の子宮っ、に流れこんでくる……！　ああああ♪　もっと、もっと出しな\n！　ん～～～♪　そうさ、そのまま……そのままぁ♪　んああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あ～～～～～～♪　っふぅううっ♪　んふぅううう～～～♪　……はぁああ\nっ、あぁ～♪　イキのいい、プリップリの精子がいっぱいだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ？　これで腹がいっぱいになっただろうって？　冗談を言うのはおよし\n。このくらいの量で、快感で、私が黙って退くと思うのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……まだまだこれからさ。ンふふ……♪　射精直後の、感じやす～いオチン\nポをねぇ……抜かずに二発目、美味しくいただくよ♪　ふんっ、ふんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　お前も硬いままじゃないか♪　なんって使い勝手のいいチン\nポなんだ♪　自分の精子を奥にっ……子宮においやって……。あぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「萎えることなく、容赦なく突き上げてきてる……♪　ああ、そうかい♪　逆\nレイプされるのが好きなのかい♪　なら、もっとしてやるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「次に出す時はねぇ、一度目よりも新鮮で濃い……っ、特別な子種を出すんだ\nよっ……！　はぁっ♪　はぁ、キンタマ空っぽになるまで出しまくって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私を見事に孕ませるんだ♪　っふぅうう……♪　良質な、このデカチンに見\n合った最高の精液を……溜めて、溜めて、凝縮して打ち出しな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　はぁ、私はそのためにだったら……こうしてねぇ♪　腰をぐりぐ\nり回しながら、卑猥な顔でお前の上でピストンしまくってあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っあぁ……♪　嬉しいだろ、ありがたいだろうっ……！　肉厚の名器、クィ\nン・テイル様の至上のオマンコでチンポを責められて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ♪　おっ♪　おっぉっ♪　あははあっ……♪　ブルンブルン揺れる胸が\nさぁ……！　心地いい風を、お前の身体におくってくるだろうっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それを浴びてっ……興奮するといい！　あっ♪　あはぁっ♪　んぉっ♪　お\nぉおおっ♪　おぉんっ♪　んぉおおんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あれぇ……？　まったく人権を無視、されて♪　肉バイブとして使われてい\nるのに……随分と気持ちよさそうにしているねぇ？　お前……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふふふっ♪　優れた女のオモチャにされるのがそんなに良いのかい？　あ\nぁ♪　いいんだろうねぇ、チンポ、に力がみなぎっているよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「これだから……お前は面白い♪　私をいつも楽しませてくれるっ……あぁっ\n♪　欲望を、こらえきれなくなるほど……たぎらせてくれるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　お前、は♪　一生私のモノだよ……あぁんっ♪　私が使いたい時\nに、チンポをおったてて使われる……専用のオチンポ奴隷になりな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そのかわり……。あはぁああっ♪　こうやって、いつでも使ってあげようね\n♪　処女のようにキツくて締まりのいいオマンコで可愛がってあげるよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「永遠にっ……飼い殺して、このオマンコのオチンポ奴隷にしてあげるからっ\n……！　それを楽しみに、毎日勃起してな！　あっあっあっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ああああ……♪　駄目だ、もうダメだっ……イクよっ！　ああああ、イク…\n…！　ずっとイキっぱなしで、……あっ♪　精子を待つよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「子作りOKの合図っ……、子宮口から出てるだろうっ！　あっ♪　あっ♪　\n子宮が下りて、きて……お前に孕まされるのを待ってるっ、凄いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こっちの子宮に亀頭、亀頭押し潰されて射精しな！　んぁああああっ……！\n　ほらっ！　特濃ザーメンぶびゅぶびゅ出すんだよっ、早く……早くぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おぁああああああ♪　そうさっ……そうっ！　子宮口にチンポッ、チンポの\n先をねじこんで……そのままっ！　そのまま出し続けなぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あふぁあああっ♪　あ～～～～～っ♪　あ～～～～～っ♪　んおぉおおおお\nあああぁああああ♪　精子、精子、子種、精子ぃいいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前の大切な遺伝子情報が、私にっ……私のオマンコに、粘膜に吸収されて\nいくよ……♪　あはははっ、されるがままだね！　可愛いやつだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私が欲しい時に、欲しいタイミングで精を注ぐ最高のオチンポ奴隷……！　\nあああ～～～～っ♪　もう、お前さえいれば他には誰もいらないよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ドックンドックン注がれてる……っ♪　んほぁあああっ♪　これだよっ……\nこれを感じると……！　子宮も子宮口も両方トばされるんだっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ♪　おおおおっ……！　長く尾を引く絶頂ぉおお……♪　中出\nしアクメッ……♪　ザーメンビームで孕みながら連続絶頂っ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっあっあっ……♪　んはぁああああ……♪　あ～～～～～……♪　んっ…\n…♪　わ、私としたことが……良くないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「下品な声上げてイキまくっちまった……♪　フフフフ♪　しょうがないだろ\nう、お前は本当に具合がいいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前は……お前は、もう私のモノだ……♪　私が決めたんだ、他の誰にも渡\nすもんか……！　っあぁっ♪　あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前もチンポも、このクィン・テイルが丸ごといただくよ……！　こんなに\n誰かを求めるなんて……私の歴史の中でも唯一のことだ、良かったねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんんうっ……！？　は、派手にやってくれたじゃあないか……っ！　アッ\n♪　ああっ……でも、出すべき場所が違うんじゃあないかいぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くぅううっ……この私が中に出していいと言ったのに、外に……しかも顔や\n胸に出しまくるなんて……なんという反骨精神だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あっああ……！　本当にもったいないよ！　二度目だっていうのに、これだ\nけ出ているじゃないか……受精確実な良い精液が垂れ流しだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「えっ！？　そんなに欲しかったのか？　……ちょ、調子に乗るんじゃないよ\n……！　でも……。ううっ……本音を言うと、そうさ……。ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「い、まっ……！　今私のあらゆる場所にかかっている熱い子種……ッ！　こ\nれを膣内に欲しくない女なんているものかねっ……愚か者ぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ビチビチと跳ねるくらいに勢いがあって……♪　あぁ……、この臭い！　絶\n対に味だって苦くて、喉に絡まるレベルの精液に違いなかったのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002503_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「っ……い、今からすくいとって……中に入れるのは……ダメだろうね……。\nえ？　なんだい？　精液をかけられた姿が見たかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そ、そうかい……。おかしな趣味だよ。でも……。お前が見たかったってい\nうなら……今回は諦めてやってもいいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら。好きなだけ見な……！　自分で言うのもなんだけど、グラマラスな肉\n体に白濁液は映えるだろう……。ゆっくりとつたいおちる白い雫」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「まさに魔性といったところかねぇ……。これを見られる果報者は、この世界\nでお前だけ……。そう言われてみると、幸せだろう？　んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
