		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ふああぁ……！　カツマちゃんとの子供……私の二号機を想像したら\n、超ＡＩにエラー音が……！　んはああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203404" ]},
