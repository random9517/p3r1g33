		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ。私の胸部装甲に寝転がりたいだなんて……カツマちゃんは本当に変\nわってるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「別に不快だなんて思ってないわ。むしろこうして抱き着いてくれて、嬉しい\nと思ってるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「落ちないようにちゃんと支えてあげるから、いっぱい甘えて頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはっ……！　そんなに焦らなくても、私は何処にも行かないわ。だから…\n…んっ、そう……もっと手を広げて、私の胸部装甲の感触を楽しんでね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……カツマちゃんの身体から、すごい熱源反応が……！　こ、\nこれ……もしかして、カツマちゃんの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああん……！　胸部装甲の隙間に、カツマちゃんの大事な外部挿入器が入っ\nて……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああんっ、あっ、はぁああぁ……と、とっても硬いわ……！　まるで私の強\n化装甲みたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あん、うぅん、はぁ……カツマちゃんのアソコ、すっごくビクビクしてる…\n…！　私で興奮してくれてるのね……！　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もっと抱き着いて、いっぱい感じて……！　私もカツマちゃんのこと、いっ\nぱい感じたいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「思っていた以上に胸が柔らかい……？　ふふっ。胸部は衝撃を緩和させるた\nめに、特殊な素材を使ってるの……人間の胸みたいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、はあぁ……だから遠慮しないで、もっと動いていいのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私の胸部装甲の上で腰を動かして、いっぱいシコシコして……！　私で気持\nちよくなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……そ、その調子よ……はぁああんっ、あん、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……はっ、激しっ……そんなに気持ちいいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、それなら……滑りをよくするために、少しオイルを注入するわね……大\n丈夫よ、人体に害のないものだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああんっ……んっ、んーっ……！　はぁ、はああぁぁ……お、オイルのおか\nげで、動きがさらに速くなって……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「お、オイルと一緒に、カツマちゃんが私の胸で暴れてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁー……ああんっ、これ、すごい……！　私の制御回路も熱くなって\nきてる……はああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「熱暴走しそうだけど……カツマちゃんに抱きしめられてると、冷却ファンが\nいつもより激しく動いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……ああぁんっ……！　わ、私の身体……おかしくなっちゃった\nのかしら……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「し、心配してくれるの……？　大丈夫よ……私は全然平気だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それより、カツマちゃんの方こそ大丈夫……？　くっ、苦しくない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ。気持ちいいのね……それなら、いいの……んっ、あっ……はああぁ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁっ……胸がぷるぷるって震えて……！　か、カツマちゃんからの衝\n撃だと思うと、興奮しちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　な、なに……！？　今度は本格的にシステムにエラーが\n……！　未知の感覚を理解しようと……必死になって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁ……！　あっはああぁん……！　た、例えシステムで理解でき\nなくても……わかるわ……！　これが、感じるという感覚なのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「くっ、ふっ……か、カツマちゃん。身体が震えてるわよ……特に股間のとこ\nろが、ビクビクって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひょっとして、もうすぐ出そうなの……？　もし出すなら、このまま中に出\nしていいからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私の身体が汚れる……？　ふふっ。心配してくれてありがとう……でも、カ\nツマちゃんのなら全然イヤじゃないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……そ、それに、汚れたら洗えばいいだけよ……だから好きなだ\nけ出して、スッキリしてね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、あっ……はああぁん……！　はっ、激しっ……！　カツマち\nゃんの形、胸の中でちゃんと感じてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はんっ、あはん……！　あんっ、あぁあんっ！　カツマちゃんのが破裂しそ\nうなぐらい、ビクビク震えてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「出るんですね、私の中に……！　いいですよ、遠慮なく私の奥に突き入れて\n……だっ、出してっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あああぁん！　くるっ、きちゃうぅ！　か、カツマちゃん……\n！　カツマちゃんので、いっぱい私を汚してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひあっ！？　あっ、熱いの出てるぅぅ！　カツマちゃんのがたくさん……ん\nあああぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、くうぅ……！　胸部装甲に染みてきて……！　エンジンまでカツマち\nゃんの熱いのが届くような気がするわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、はあぁ……まるでガソリンを入れられた時のような感\nじね……んっ！　気持ちよくて、オイルが漏れちゃいそう…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んくっ、ふっ、ああぁ……たくさんぴゅっぴゅっできたかしら……？　うん\n……熱源反応もさっきより落ち着いてる。スッキリできたみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それにしても、私の胸の奥……オイルとカツマちゃんの出したもので、ベト\nベトになってる……なんだか、いやらしい感じがするわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「えっ……？　もう一度したいの……？　ふふっ。そんな必死にならなくても\n大丈夫よ。カツマちゃんのお願いだし、断るわけないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「よっぽど私のおっぱいベッドが気に入ったのね……とっても嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　さっきあれだけ出したのに、もうこんなになって……すごい\nわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うっ、あっ……ああぁっ……！　また私の胸の中に入って……ああぁん！　\nこ、今度は身体ごと……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　わ、私の胸部装甲の隙間に……カツマちゃんの身体がね\nじ込まれるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「熱源感知機能なんて使わなくても、カツマちゃんの熱を感じるわ……！　カ\nツマちゃんを抱きしめられるなんて、夢みたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うっ、ううんっ、ああっ……すごい……！　密着感が今までの比じゃなくて\n……！　もっとくっついて、擦っていいのよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああんっ！　いっ、いいわ……！　その調子で腰をしっかりと動かして……\nあはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「いっ、くっ、ふああぁ……！　は、激しっ……！　夢中になるぐらい、私の\n身体が気に入ってくれたのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁん！　私も気持ちいいわ……！　胸部装甲が発熱して、溶けち\nゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、ああんっ！　カツマちゃんの腰振りに合わせて、胸の隙間からオイル\nが飛び散って……んっ、身体中ベトベトになっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁん、はあはあ……！　ふぁ、はぁあああ……！　おっ、奥にっ……カツ\nマちゃんの大きなのが届いてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「興奮でガチガチに硬くなった、カツマちゃんの立派なレンチで……私の胸の\n中を激しく整備されてるみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああ、駄目っ……！　こんなの、我慢できない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んあっ、ふああぁ……！　これが快楽という感情なのね……！　機械の私で\nもわかる……！　カツマちゃんのモノを通して伝わる、この想いが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……！　カツマちゃんのモノで……もっと私のおっぱいを感じて…\n…！　たくさん愛して……！」", "NORMAL" ]},
