		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あんっ、んんっ！　装甲にカツマちゃんの熱くてドロドロのお汁が……！　\nすごいわ……まだこんなに出るのね……！」", "NORMAL" ]},
