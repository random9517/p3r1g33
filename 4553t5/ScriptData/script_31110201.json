		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こ、これ……異常を示すエラーじゃなくて、もっと別の……！　人間でいう\nところの、幸福感みたいなものが……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「し、心配してくれるの……？　ありがとう……カツマちゃんに抱きしめられ\nると、エラーが解除されていくわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあぁ……エラーも無事に解除されてスッキリしたわ……カツマちゃんも、\nスッキリできたかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203407" ]},
