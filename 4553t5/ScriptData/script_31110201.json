		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふああっ……！　か、カツマちゃんのモノが抜けて……はぁあああんっ！」", "NORMAL" ]},
