		{"command":[ "PLAYVOICE", "v2_111_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私のことは気にしないで……！　中でも外でも、好きなところに出していい\nから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっ！　か、カツマちゃん……！　カツマちゃん……！　だっ、出して\nっ！　私にカツマちゃんを感じさせてぇ！！」", "NORMAL" ]},
