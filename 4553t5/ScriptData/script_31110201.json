		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「この遺伝子を解析して、私の超ＡＩと結びつけることができたら……か、カ\nツマちゃんと私の子供が出来たりするのかしら……！」", "NORMAL" ]},
