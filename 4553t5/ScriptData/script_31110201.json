		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ……遠慮しないで、好きなだけ私の身体にかけていいのよ……！　カ\nツマちゃんのなら……イヤじゃないのもの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ……ま、まだ出てる……！　私でこんなに興奮してくれるなんて、本当\nに嬉しいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんっ……さっきから、私の臭気センサーに変なノイズが混じり続けてる…\n…！　でも、全然イヤじゃないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんを感じて生じたエラーなら……愛おしくすら感じるわ……！　\n壊れてもいいって思っちゃうぐらい……不思議な感覚なの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「壊れて欲しくない……？　ふふっ。誤解を招く言い方だったわね……私はこ\nの程度じゃ壊れたりしないから、安心して頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　いっぱい出たわね……こんなに白くカラーリングされ\nたら、カツマちゃん専用機だって一目で判別されちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カラーリングのせいで狙われることになったら、カツマちゃんが守ってくれ\nるの……？　ありがとう……優しいのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「でも、カツマちゃんを守るのは私の役目よ。どんな相手だって、指一本触れ\nさせたりしないから、安心してね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0203310" ]},
