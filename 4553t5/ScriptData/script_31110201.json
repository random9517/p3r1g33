		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んあああっ！　思考回路が……ショートしちゃいそう……！　カツマちゃん\n、お願い……！　早くカツマちゃんの熱いエナジーを、感じさせて……！」", "NORMAL" ]},
