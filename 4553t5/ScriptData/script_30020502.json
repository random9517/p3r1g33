		{"command":[ "PLAYVOICE", "002_0504218" ]},		{"command":[ "SETNAME", "輝夜" ]},		{"command":[ "SETTEXT", "「んぉっ！　おっ、おっ、ここっ、しゅごいっ、キモチイイッ！　恥ずかしい\nのに、お尻とまらないっ、オマンコ気持ちよすぎるのぉっ！」　", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
