		{"command":[ "PLAYVOICE", "002_0504216" ]},		{"command":[ "SETNAME", "輝夜" ]},		{"command":[ "SETTEXT", "「ちゃんと、おねだりしたからぁ、おねがい、はやく動いてぇっ、あへぇええ\nっ！　オマンコいいのっ！　このままだと、ひとりでイっちゃうからぁっ！」", "NORMAL" ]},
