{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さぁて……楽しい時間の始まりだねぇ……んふふっ、どうしたんだい……緊\n張してるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なに、何も怯えることはないよ。お主はそこに寝ていればそれでいい。もち\nろん、チ○ポを勃起させる位のことはしてもらうけどねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁ、そいつは余がわざわざ言うまでもなく……しっかりとビンビンにさせ\nてるみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……それじゃあ……よいせっと……ふふ……やっぱりこうして見下ろす\nのは悪くない眺めだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主はお主で、余の身体を存分に見ることが出来るんだ。そう悪くもないだ\nろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほうら……余のマ○コがすぐ近くじゃ。このまま腰を落とせば、ずっぷりと\nチ○ポが呑み込まれていくぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……何もしないで、ただこのマ○コが味わえると思ったら大間違いだ\nよ？　ちゃんと、このマ○コが欲しいっておねだりをしないとねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そら、この欲望まみれのエロチ○ポは、一体どんな風になりたいんだい？　\nしっかりと求めてみせるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……そうかい、そうかい。ちょっとチ○ポの先をくすぐってやるだけ\nで、もう出ちまいそうな位に余裕がないのかい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしてもこのチ○ポにして欲しいと……そこまで言われちゃあ仕方ないね\nぇ。たっぷりと味わわせてやろうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……ほら、よーく見てな。余のマ○コに、お主のチ○ポがず\nぶずぶ入っていくよ……んっ、ふぅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁ……んっ、あぁ……しっかり熱を持っているね……んんっ、悪く\nないよ……このまま根元まで沈めるからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉぅ……んっ、ご覧……しっかりと余のマ○コに、お主のチ○ポが埋め込\nまれただろう？　どうだい、しっかり味わってるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふふっ……そうかい、そうかい。この震えるチ○ポが何より正直に悦んで\nるって教えてくれるようだねぇ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……まだ血が集まって大きくなるのかい。上出来だよ……んっ、粗チ\n○で余を満足なんてさせられないからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、十分に大きくなったところで……勃起チ○ポ……楽しませてもらおう\nかね……んっ、はっ、んんっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ゆっくりと腰を回して……マ○肉のヒダをチ○ポ全体に絡ませてやるよ。ほ\nら……グリグリ擦れて……いい具合だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……ふふ……汁がよく絡んでくるだろう？　あぁ……いつもよ\nりマ○コが濡れてるのは間違いないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こいつを、じっくり馴染ませる為に……腰を揺らすよっ……はっ、あっ、ん\nんっ、んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふふっ……あぁ……硬いのが……子宮のトコまで届いてるよ……もっとだ\n、もっとめり込ませるんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ、はっ、うんっ、んふっ……ふふっ……おっぱいが揺れるのが気にな\nるかい？　呆けた顔でじっと見て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいとも、好きなだけ見るがいいさ。夫なんだから、何も遠慮することはな\nい……触ったっていいんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「けど……その分、きっちりチ○ポにも働いてもらわなきゃねぇ。ほら、お主\nもタイミングを合わせて動かしてみな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……！　そうそう……余のピストンと合わせて……ちゃんと腰を突き上\nげるんだよ……おっ、んふっ……おぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいよ……せっかくのチ○ポを持っておるんじゃ。しっかりヒダを擦り上げ\nて……余を楽しませるのじゃ……ふんっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうだい、チ○ポが堪らないだろう……？　けど、簡単に出しちまうんじゃ\nないよ？　余が満足出来るように、もっと腰を振ってみせな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぅっ、んくっ、あっ、おぉっ……いいねぇ……それだよ……んんっ、くぅ\nぅっ……カリが……丁度いい所に当たってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　あっ、んくっ……ふふっ、生意気に……続けて同じところを狙\nって来るね……確かに、そこは余の感じやすい場所……けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……ふっ……！　お主のチ○ポの弱いところも、こっちは……しっか\nりと分かっているからねぇ……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ここからが本番じゃ……そぅらっ、マ○肉が……締まるぞ……んんっ、くぅ\nっ……おふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、いい表情じゃ……こうして、お主のチ○ポを味わいながら、快感を\n堪える顔を見るのは……実に愉悦じゃな……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、おぅっ……またビクビクさせて……まるで陸に打ち上げられた\n魚のように、チ○ポが跳ねておる……んっ、くぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もっとじゃ……ぐちゅりと、蕩けたマ○コを突き回せっ……んんっ、あぁっ\n、よいぞっ……くぅっ……もっとじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、ふぁっ……チ○ポが震えてっ……いよいよのようじゃなっ？　この締\nめ付けが……いよいよ我慢できなくなって来たなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくっ……それなら、このまま中に出してしまえっ、当然子宮の奥に……中\n出しじゃっ……はっ、ふっ……そらっ、そらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんんっ……！　あぉぉぉぉっ……来たぞっ……！　お主のドロ\nドロ精液っ……チ○ポザーメンっ……出て来てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅぅ……おぉ……届いておる……子宮に一気に流れ込んでぇ……おおぉぉ\n……そうじゃ、それでこそ余の伴侶……おふぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんんっ……あぁ……まだ中でチ○ポが蠢いておる……んふぅ……こいつを\n味わっちまうと、もう他のチ○ポなど考えられぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁ……まだまだイクまいと思っていたが……あっけなくイカされてしま\nったわ……生意気なことだが……そうでなくてはな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ、子宮が満たされておる……いい気分じゃ……褒めてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……射精は落ち着いたか。だが、もちろんここで終わるようなタマでは\nあるまい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主のチ○ポは、まだまだビンビンに勃起したまま……しっかりマ○コを抉\nっておるし……抜かずに続けてするのが必然」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たっぷりと精液も入って……これを、マ○コの中で混ぜるのもまたオツとい\nうものよ……ふふっ……ゆくぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、んくっ、は……んぅ……ふはっ……あっ、はぁ、んっ、あっ\n、くぅぅぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いいぞ……ぐちょぐちょと……下卑た音がよく響く……お主のチ○ポの先で\n、ヒダの一つ一つ……丁寧に精液を染み渡らせるのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、余も協力してやろう……上下……左右に……腰を……振りた\nくって……あぉっ、くっ、あぉんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……どうじゃ……？　余の淫らな舞を見ることが出来るのは……お主\nだけじゃ……特別の中の特別じゃぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やはり……揺れるおっぱいに目が行って仕方ないようじゃな？　んふふっ、\n今日は気分がいい……存分に余のおっぱいを愛でるがいいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……んくっ……チ○ポがいきり立って来る……んんっ、あっ、あぉっ\n……はぁっ、マ○コッ……そこぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、ポルチオの感じる部分……しっかり責めて来るじゃないか……あ\nひっ、あぁっ……んっ、そのがっつきっぷり……いいよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まだまだ……んっ、余もここからだからねぇっ……ズボズボっ……勢いをつ\nけていくよっ……んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はんっ、そらっ、そぉらっ……よーく見えるだろう？　マ○コの入り口が広\nがって……ぱっくりチ○ポを咥えてるところ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうしてっ、んんっ、腰を揺らす度にっ……肉ビラがよじれてっ……めくれ\nる感じっ……その瞬間が……気持ちいいねぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁっ……まだだよ、踏ん張りな……これから先も……余と\nお主は……四六時中……どんな時でも、まぐわいまくるんだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あっさり果てるフニャチ○はいらないよ……しっかりチ○ポを引き締めて…\n…そうだよっ、もっと突き回しなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くぉぉぅっ！　あぉっ……いいよぉっ、くぅぅっ……生意気だけどっ……そ\nいつは効くぅっ……あぁっ、イキたくなって来たよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっくっ……けど、余だけイクなんてことはしないからね……ちゃんとお主\nのチ○ポをイカせるまでは……止まらないよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ……チ○ポ震えてるっ……ビクビクしてっ……イクんだろう\nっ？　もう気にせずに出しちまいなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぐっ……んんっ……おぁっ……あぁっ、いいよっ……ジンジン来てるっ…\n…余のマ○コもっ、もうイクよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「だからっ、出しちまいなっ……！　チ○ポッ……射精っ……濃厚ザーメンッ\n……思いっきり出しなぁっ……んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぉぉぉっ……！　また、来たっ……！　お主の……精液っ……また、子宮\nにっ……流れ込んで来るぅっ……んぁぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぉぉっ……イクッ……んむぅぅっ……マ○コイクッ……！　おぉぉぉっ…\n…濃すぎるのっ……孕まされるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……２発目とは思えない、呆れた出しっぷりじゃないか……はぁぁ\n……んっ、入り切らずに……溢れて来るよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……だからって、下手な遠慮なんかするんじゃないよ？　お主の出す\n精液は全て余のモノなんだからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「は、ふぅぅ……んっ……そう……イキマ○コに……どんどん流し込んでっ、\nくふぅぅぅっ……ま、またイクッ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅ……すごい量だ……後少し残ってるのは……締め付けで搾り取ってや\nるからね……んむっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はふぁ……んんっ……やっと、出し切ったみたいだね……ふふ、まだチ○ポ\nがビクビクしてるのが伝わってくるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……余のマ○コを楽しめたかい？　これから何発だってするんだからね\n、一気に味わい尽くしちまうのは勿体ないかも知れないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうとも、これからもじっくりと楽しんでいく……それを確かめる為のまぐ\nわいのようなものだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「後は……どれだけ、世継ぎを孕ませてくれるのか……ふふっ、期待している\nからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　んふっ、チ○ポ抜けてっ……んくぅっ、ドロドロザーメンっ\n……ぶっ掛けられてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……中だけじゃ足りないからって……んっ、身体に掛けてくるなん\nて……いい度胸してるねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000313_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「けど……このふざけた量……悪くないよ……んふぅっ、じゅぱっ……余に浴\nびせるなら、これ位濃くなくっちゃね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁっ……生臭い……このエキスを味わってると……はぁぁ……\nゾクゾクして……余もまた……んっ、イクっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……糸を引いてる……ちゅぱっ、ぴちゃ……れろ……ねっとりが、喉に\nまとわり付いてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、味わってるとも。わざわざ中出しじゃなく、ぶち撒けた精液だ……飲\nまなきゃ、勿体ないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうやら、終わったみたいだね。ちゅぷっ……ふふっ、流石に息が荒いよ。\n楽しめたかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ……それならいい。この先、何度だって子作りはしていくんだ。たっ\nぷりと楽しまなきゃ損だからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて……一息ついたら、また続きをするかね。夜はまだまだ長くなりそうだ\nよ……んふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}