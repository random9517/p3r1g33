{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それじゃあ……えぇと……こんな感じで……いいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「全く……確かに、ご褒美に何でも言うことを聞いてやるとは言ったけど……\nまさか、おっぱいを吸いたいなんて甘えてくるとはね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「けど、あたしのおっぱいが欲しいって思ってくれるのは……ちょっと嬉しい\nからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……例の薬……ボニューデマクールも飲んでるから……多分、ミルクも\n飲ませてやれると思うよ……はぁっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんなにいきなり吸い付いて……心配しなくても、あたしのおっぱ\nいは逃げやしないよ……落ち着いてゆっくり吸いな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、そうそう……唇で挟んで……チュウって……そう……あっ……んくっ\n、いい感じだよ……あ、ふっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと……そんなことを言ってたら……いつの間にかチ〇ポ……すっかり大\nきくなってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「分かってるよ……シコシコして欲しいんだろう？　ほうら、いい子にしてい\nたご褒美だ……優しくオチ〇チ〇、してあげるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……んんっ……気持ちいいかい？　あぁ、偉いねぇ……赤ちゃん\nなのに、ちゃーんと頷けるんだねぇ……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あっ、こらっ……そんなにがっついて……おっぱいは逃げない\nって言ってるだろう？　そんなに……んっ、強く吸い付いてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、そんなに……甘えん坊だったかい……？　仕方ない子なんだ\nから……あっ、んんっ……はっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら……いい子だから……んっ、もっとオチ〇チ〇をさすって欲しいんだね\n？　あぁっ……こんなにビクビクさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「皮をくにくに引っ張って……んっ、先っぽがクチュクチュいってるよ……ふ\nふっ、目を細めちゃって……可愛いねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんっ……何だい、可愛いって言われるのはイヤなのかい？　でも、仕方な\nいじゃないか……可愛いものは可愛いんだからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……こうして一生懸命おっぱいを吸って……あたしに甘えて来る\n所を見せられて……可愛いって思うに決まってるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ふっ……ヤバいね……乳首が、ムズムズして来たよ……薬の\n効き目が本格的に……出てきたかもね……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「出るよ……んっ、もう少しで……あっ、あぁっ、おっぱい出るよっ……あた\nしの母乳っ……飲んでっ、いいからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふぁっ……んっ……出てきたぁ……はぁっ、んっ……おっぱいの中心が熱\nくなって……ミルク……溢れて来てるよぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……いいよ、どんどん飲んで……あぁっ、赤ちゃんにミルク吸われ\nてるっ……あぁっ、でも……そんな乳首を強く……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あひっ！　こ、こらっ……歯は強く当てたらっ……ダメだからっ……！　ん\nっ、それでなくても……敏感になってるんだからっ……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、そうだぞ……オチ〇チ〇だって……あまり乱暴にしたら、痛くてイヤ\nだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そ、それはそれで……？　バ、バカっ……そういうことじゃないんだよっ…\n…全く、本当にしょうがない子だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「とにかく、優しく吸うようにして……はぁんっ……そうそう……心配しなく\nても、どんどん溢れてくるから……いっぱい飲んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっん、ふっ……いい子だ……たくさん飲んで大きくなるんだよ……んん\nっ、はぁっ、オチ〇チ〇もいっぱい擦ってあげるからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら……気持ちいいかい……？　ふふっ、良かったよ……根元から、ぎゅう\nっとしてあげるからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ……あたしの手の中でオチ〇チ〇が元気よく跳ね回って……おー、よ\nしよし……んふっ、これはチ〇ポっていう方が正しいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……こんなのを見せられたら……おっぱいの方もムズムズして\n……また、母乳が……出てきちゃうよ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ、そうそう……どんどん出てくるからね……ごくごく飲んで……大き\nくなって……はぁっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ……チ〇ポの方も、ちょっとヌルヌルが漏れて来たみたいだね……い\nいよ、先っぽのところ……なでなでしてあげようねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉら、敏感なところだから……やさしーく、やさしくね……ふふっ、こん\nなのでも、チ〇ポがプルプル震えちゃって……可愛いねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このつるりとした割れ目の所を……つぅっと……指先でさすりあげて……あ\nぁ、跳ねてる跳ねてる……んふっ、出したいのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいよ……射精したくなったら、遠慮なくぴゅっぴゅって出していいからね\nぇ……あたしの手はその為に準備してるんだから……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ……！　またチュウって唇が強くなったね……これは、一生懸命出す\nのを我慢してる時の動きだ……分かってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも……んっ、ふふっ……もう止まらないからね……ほぉら、こすこすして\n……ぐちゅぐちゅの音が止まらないんだから……出したいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、いいんだよ……赤ちゃんなんだから、お漏らししても大丈夫……いー\nっぱい、ぴゅっぴゅしてごらんっ、ほらっ、ほぉらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ……！　ふふっ、出てきたね……元気な精液がどぷどぷ溢れ出して来て\nるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「すごい勢い……あっという間に手がミルクまみれだよ……んふふっ、元気が\nあって何よりだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゃんと残さず搾り出してあげるからねぇ……ほぉら、シコシコ……シコシ\nコぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……んーっ……コクのある味がするね。あぁ……そろそろ収まった\nかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いっぱい出して偉かったねぇ……ほぉら、いい子だ……いい子……ふふっ、\n逞しいチ〇ポで嬉しいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうだい……気持ちよかったかい？　んっ、ならよかった。おっぱいも……\nたくさん飲んでいい子だったねぇ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしたんだい……まだ、もっと飲みたいのかい？　分かった、分かったよ\n……もう、必死に乳首を咥えちゃって……駄々っ子みたいだねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいよ、好きなだけ味わいな……あたしのおっぱいは、全部赤ちゃんのもの\nなんだから……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「けど……んふっ、こんな……チュウチュウって……本当に、エッチな吸い方\nをするねぇ……あんたは……もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「乳首……あっ、ずっと転がされて……なんだか、すごく感じやすくなってる\nのに……んっ、あっ、はぁっ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、また……母乳出てきた……この薬……よく効くねぇ……あっ、ふっ\n、ふふ……いっぱい飲んでる……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……手の中で、また……チ〇ポが膨らんで……分かったよ、こっちもち\nゃんとしてあげないとだね……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「大丈夫かい？　射精したばっかりで……痛くなったりしてないかい？　って\n……そんなヤワなチ〇ポじゃなさそうだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……いいよ、ほぉら……シコシコ……ずりずり……ぎゅっと握って…\n…モミモミしてあげるからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「気持ちいいかい？　ふふっ……これだけ元気にチ〇ポが跳ねてくれると、あ\nたしも手コキのしがいがあるよ。んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さっきの精液が……べとべとに絡みついて……においもムワッと広がって…\n…はぁ……イヤでも興奮させられちまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……あたしも乳首……感じてるし……一緒に気持ちよくなって\nいこうね……んっ、あっ、はぁっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、また腰が浮いてる……気持ちいいところが丸わかりだねぇ、ほら、\nほら……しこしこ……くちゅくちゅー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　そうやって……乳首を強く吸ってあたしの動きを止めようと\n思ってもダメだよ……？　もう、止まらないからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくっ、あっ、あんっ……んふっ……そうだね……あたしも、また\nおっぱいが溢れそうになってるからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このまま一緒に……んっ、射精しちゃおうね……ほら、我慢できなくなって\nるチ〇ポ……コスコスして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「汁がぴゅっぴゅって溢れて来てる……んっ、今度は派手に飛びそうな感じが\nするね……んっ、ふふっ、いいよ……元気よく出して欲しいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しこしこ……こすこす……さあ、もう我慢出来ないだろ……？　あたしのお\nっぱいを飲みながらいっぱい出しちゃおうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ビクビク震えるチ〇ポ……ぐっと腰を突き出して……あぁっ、そうだよ……\nいっぱい掛けていいからねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ……気持ちよく……びゅびゅって、精液……出しちゃおうねっ\n……んっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！　あっ……出たねっ……んんっ、顔に……思いっきり……飛ば\nされて……んふっ、ちゅぷっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……男の子の精液……この匂い、粘り……味も……たまらないよ……\nんふぅ……ちゅぱっ、ぴちゃ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……すごいね……ゾクゾクする……またこれだけで……母乳\nが溢れて来るよ……んっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ……射精しながら……おっぱいも飲むなんて……本当に欲張りな子な\nんだから……んんっ、でも、男の子はそれ位じゃなくちゃね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……まだチ〇ポは少し硬いけど……流石にもう出なくなったみたいだね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……あぁ……おっぱいも出し切った感じがするよ……んっ、ふふ…\n…射精と同じ位に終わったね……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、手がべとべとだ……口の周りも母乳がついて……やれやれ、後でしっ\nかり綺麗にしてあげないとダメだねぇ、これは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「全く世話の焼ける赤ちゃんだよ。図体はしっかり大きいままだし……本当に\n甘えん坊なんだからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも、面白いもんだね……こうしてちゃんと甘えられたら……あたしも、包\nみ込んであげなくちゃって……そんな気持ちになっちゃったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……いいよ、これからも甘えたい時にはいつでも言いな。ちゃーんとよ\nしよししてあげるから……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ひゃあっ！　思いっきり飛んで……んぁっ、精液っ……髪にまでっ……届い\nてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000312_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「全く、元気よすぎだよ……はぁ……んっ、ベトベトだ……髪にべったり絡み\nついて……んっ、はぁぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……あたしも……気持ちよくなっちゃったよ……んっ、ふっ、まだ……\n身体がイッて……ふわふわしちゃってるtね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱいも吸ったままだね……そこは本当にブレないんだから……ま\nぁ、元気があって何よりだけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
