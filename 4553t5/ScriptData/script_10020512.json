{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "劇を見ている間に、ジュンジローがいなくなっている。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　どこへ行ったんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、そろそろ出番ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジュンジローの声がした。どうやら先に出番の準備をしていたようだが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、その格好……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "馬の被り物をつけている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「心の目で見れば、私も立派な白馬に見えるはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人の愛馬が～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや見えねえよ。あと歌はやめとけ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ゴレイジョーたちのコスチュームを用意するので予算がいっぱいだったので\nす。察してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……。まあ、しかたないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、白馬の王子様なんてガラじゃないし、これがちょうどいいのかもしれな\nいな。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "舞台袖へと移動して、ステージを見る。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやぁ、まるで本物の戦場のような激しいバトルが繰り広げられているのだが\n、ここに飛び込むのか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、震えていますな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「馬鹿野郎。武者震いだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "台本では、悪の女幹部にやられることになっている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大丈夫か？　本当にやられるんじゃないか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "実戦さながらの動きで、５対１の殺陣がステージの上で繰り広げられている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "わりとみんな目が本気なんだが、不用意に割って入ったら命がいくつあっても\n足りないのでは……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなことを考えていたら、いよいよジュンジローともに登場する場面がやっ\nてきてしまった！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "が、その時", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんな時に敵が！？　助かった！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「敵ですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000116_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どうやら、勝負はここまでのようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000117_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナたちが劇の途中にもかかわらず校庭へ飛び出していく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「待ちなさいゴレイジョー！　決着はまだついていないわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113530001" ]},
		{"command":[ "SETCHARA", "0", "char_00002803_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それを追う桃花。これまたステージで戦っていたアクレイジョーのコスチュー\nムのままだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、お前たち！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、私たちも行きますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、わかってる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "校庭に襲来者（インベーダー）がやってきていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「ふははははーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ、これじゃあ楽しい学園祭がめちゃくちゃだ！　どうしたらいいんだ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、芝居が下手ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「黙れ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「待ちなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000116_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「あぁん、だれだぁっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「緊急時により口上は省略よ！　５人そろって、令嬢戦隊」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000116_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "４人" ]},
		{"command":[ "SETTEXT", "「ゴレイジョー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000117_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00001204_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00001703_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00002403_01", "0", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それと、アクレイジョー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113530002" ]},
		{"command":[ "SETCHARA", "0", "char_00002803_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「令嬢戦隊ゴレイジョーだと！？　……って、なんで暖色系ばかりなんだ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「うん、それあたしも思った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113530003" ]},
		{"command":[ "SETCHARA", "0", "char_00002803_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たち、わかってるよな！　被害をあまり出さないように……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「こいっ、インベーダーロボ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "急に空が割れて、ロボットが姿を表した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああっ、いきなり巨大ロボとは掟破りなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういうものは、まずは等身大の敵を倒してからではありませんかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113530009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前はなにに憤っているんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こちらもロボを出すしかないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530005" ]},
		{"command":[ "SETCHARA", "0", "char_00000116_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ、ゴレイジョーにそんなものがあるのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大道具で舞台装置をいろいろ用意していたのは知っているが、まさか巨大ロボ\n戦までやるつもりだったのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そんなものはありませんから、あるものを呼びます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113530003" ]},
		{"command":[ "SETCHARA", "0", "char_00000117_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ドラグソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113530004" ]},
		{"command":[ "SETCHARA", "0", "char_00000117_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、掟破りには掟破りで対抗するのだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ベビー、ローズ、ロボの方は私たちに任せて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530006" ]},
		{"command":[ "SETCHARA", "0", "char_00000116_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「わかったわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113530002" ]},
		{"command":[ "SETCHARA", "0", "char_00002403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こっちの敵を片付けちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113530002" ]},
		{"command":[ "SETCHARA", "0", "char_00001703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「アクレイジョーも、小さいほうをお願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113530002" ]},
		{"command":[ "SETCHARA", "0", "char_00001204_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「じゃあ、さっさとやっつけちゃおう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113530004" ]},
		{"command":[ "SETCHARA", "0", "char_00002803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にか、体育館から校庭に観客がやってきている。これもヒーローショ\nーの一部だと思われてないか？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「せっかくの学園祭をジャマするというのなら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113530007" ]},
		{"command":[ "SETCHARA", "0", "char_00000116_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「正義の令嬢が、徹底的にしつけてあげちゃうんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113530003" ]},
		{"command":[ "SETCHARA", "0", "char_00002403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……あたしは悪の令嬢役だけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113530005" ]},
		{"command":[ "SETCHARA", "0", "char_00002803_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
