		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ふあぁーっ、はぁっ、はあぁ……はっ、あぅぅ、あっ……！？　か、帰って\nきたか……あうぅ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104102" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あなたの言いつけ通り、ず、ずっとバイブ抜かずに待ってたわ……本当に、\nふあぁー、はあぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104103" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「どうしたらいいのか分かるなって……？　う、うぅっ。どうしてあたし、こ\nんなドＳ男に惚れちゃったんだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104104" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「う、うん。分かる。その、拙者の……うぅ、言い直せ？　分かったよ……ち\nゃんと言い直す」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104105" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「き、聞いて下さい……あたしの、バイブに散々いじめられたオマンコ……は\nぁ、はあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104106" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あなたを待つ間、何度もイッちゃって、あ、愛液でぐちょぐちょになっちゃ\nってるんです……んうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104107" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「そ、そう。太い棒ならバイブだって構わない、そんな淫乱オマンコに……く\nぅぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104108" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あなたの極太オチンポをハメて、あなた専用のオナホにして下さいっ……！\n　ふぇ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104109" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んあああぁぁ……！！　また来るっまた来るぅぅ……！？　すごいの来ちゃ\nうぅぅ……！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104110" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んあっ！　ああああ～～～っ！！！　はひっ、ひっ、ひあぁぁん……！！　\nあぅ！　ああっあああぁぁん……！！！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104111" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「な、何が入ってるか、って……？　あなたの……んあぁぁん！？　乳首つま\nまないでぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104112" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ごっご主人様の、オチンポが入ってきてまひゅ……んぉ、んぉぉぉ……！！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104113" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ぐりっ、ぐりってオマンコほじられて……！　ひっ、ひぃぃ！？　もちろん\nですっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104114" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ば、バイブなんて比べものにならなぁい……はひ、ひん！　ひぃぃ！？　ん\nあぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104115" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ！！！　はひっ……ひん！　ひぃぃ！　子宮ぅ、突き上げ、ら\nれて……やうぅ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104116" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「い、イクの早すぎ……？　ごめんなさい、ごめん……だってあたし、バイブ\n入れっぱで放置されたから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104117" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「お仕置き？　お仕置きなの……？　こ、今度先にイッたら、中出し５回追加\nする……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104118" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やだぁぁっ……そんなの楽しみすぎて乳首が勃ってきちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104119" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ふああぁ、拙者とか、上から目線で言ってたくせに、だなんて……言わない\nでぇ、だって……だってぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104120" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「こっちが本来のあたしなんだもん、サムライの鎧を脱がされて、あなたにメ\nスにされたあたし……くぅぅ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104121" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁぁ！？　やめ、やめやめぇ……やめっ、てぇぇ！　子宮ぅ、がつがつ突\nき上げないでぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104122" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「く、口答えしたら、また首輪と手錠をハメちゃう……！？　だっダメぇ、あ\nれクセになるの……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104123" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あんなので犯され続けたら、はひっ、ひぃぃ……き、きっと縛られたままじ\nゃないと満足できなくなっちゃう……！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104124" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んあぁぁ！？　ま、またお尻の穴もいじるぅ……！　ふぇ……！？　そ、そ\nのうちお尻も開発してやる？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104125" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ぜ、絶対にムリだって……あなたの太いオチンポ入るわけないよぉ……あぅ\n！　んああぁん！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104126" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はひっ、ひん、ひぃぃ！　確かに……あたしオマンコの時も最初はそう言っ\nてたけど……あぅぅ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104127" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「乳首やだぁ……りょ、両方の乳首くりくりしながら腰ぃ振らないで……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104128" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ひゃぅぅ！　くひっ……あひぃぃ！　乳首いじられるとオマンコがきゅっと\n締まる……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104129" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「だ、だってあたし、そこ好きだから……！　オナニーする時ぃ、い、いっつ\nも乳首にローターつけてるもん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104130" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はうぅん、んあぁ、あっ、あ～～～っ！　んぉぉ……！！　ごつ、ごつって\n子宮ぅ揺らされてるぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104131" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やだっやだやだぁ子宮ぅ降りてきたぁ……あなたの孕ませザーメン、今日も\nたっぷり子宮に注がれりゅぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104132" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ひぁっ、え……えぇ？　どうしてやめちゃうの？　あ、あぁ……！　は、は\nい……分かりました」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104133" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あなた専用の肉オナホに、貴重なスペルマいっぱい……いぃっぱい注ぎ込ん\nで下さいっ……あひっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104134" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やあああぁっ！！　もぅダメぇぇ、止まんない、止まんないよぉ……！　イ\nクッイクイクッ、頭おかしくなっちゃううぅ～～！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104135" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ、んああぁぁ！？　あっ、あぁ、ああああ～～～！！！！　あひっ……\nひん！　ひぃぃん！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
