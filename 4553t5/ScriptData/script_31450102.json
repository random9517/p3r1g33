		{"command":[ "PLAYVOICE", "145_0104136" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「せ、精液ぃ、多すぎぃ……熱いの、ドクドクッて注がれて……んあぁ、あた\nし幸せ……あうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104137" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ね、キスして……？　んっ、ちゅるる、ちゅぱ、ちゅうぅ、ちゅっ、ちゅ…\n…んうぅ、好きぃ」", "NORMAL" ]},
