		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104138" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あなたのこと大好きなの、あなたのお嫁さんにして……！　す、好きなだけ\n種付けしていいからぁ……あ、あぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0104139" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「今日も朝までコースなの……？　う、うん。じゃあ……そ、そのっ。さっき\n言ってたアナルファック……」", "NORMAL" ]},
