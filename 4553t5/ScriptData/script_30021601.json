		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「来てくれてありがとう。あのね、あなたに聞きたいことがあるの。あなたは\nこの衣装……どう、思う……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603101" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私は……私にはこういう派手なの、似合ってないと思うんだけど……。え、\nそんなことない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603102" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お姫様みたいじゃないか、って……そ、そうかな？　あなたにそう思っても\nらえるなら、すごく嬉しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603103" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私がお姫様なら、あなたは王子様……かな？　ふふっ、照れてる？　いいじ\nゃない、本当のことなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603104" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私のことを愛してくれているあなたに……今日はたくさん、ご奉仕してあげ\nるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603105" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチン、挟んで……。ンッ、おっぱいの間で、ビクビクってしてる……\n私のおっぱい、気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こうやって、おっぱいでオチンチンしごいてあげれば……。どんどんおっき\nく、硬くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「特別な格好だから、余計に興奮してるのかな？　オチンチンがガチガチにな\nって、先っぽもパンパンになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチンから、いやらしい匂いが漂ってきて……。はぁ、はぁ、私もすご\nく、ドキドキしてきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このまま……おっぱいだけじゃ足りないよね……？　うん、わかってる。だ\nって、幼馴染だもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……ちゅっ。んふ、れろ、れろぉ……。パイズリだけじゃなくて……舌も\n……でしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そろそろ……れろぉ、フェラもして欲しいって顔……ぺろっ、してたよ……\n？　ちゅぷっ、ぺろぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603112" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっぱいからでてる、オチンチンの先っぽ……んちゅっ、いっぱい舐めてあ\nげる……れろ、れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「興奮して……どんどんよだれがでてきちゃう……んちゅぷっ、オチンチンが\nヌルヌルになってくね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んはぁ、ンッ、れろ、れろれろ……んれろっ、れるれるれる……っ。舌と、\nおっぱいで……アツアツオチンチン、感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私の舌……気持ちいい……？　ふふっ、だって幼馴染だもの。あなたの弱い\nところ、ちゃんと知ってるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ちゅ、ちゅぷ……。れろ、れろれろ……んふぅ……ちゅ、ち\nゅる……んっ、ちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「腰が動いちゃってる。んちゅ、それにオチンチンから、我慢汁もでてきてる\nよ……ちゅ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いっぱい感じてくれているのがわかって、嬉しくなっちゃう……。おっぱい\nでしごくと、どんどん溢れてくるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「エッチな匂いと味がして、れろっ、もっとオチンチンに気持ちよくなっても\nらいたくなってきちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、だから……オチンチン、咥えちゃうね……。舌だけじゃなくて\n、口いっぱい使って、ご奉仕するから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁ……む……。んふぅ……んっ、んじゅる……っ。オチンチン、すごく熱\nい……んっ、んじゅるっ、じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こうやって、ちゅぶっ、オチンチン咥えて……ンッ、オチンチンしごかれる\nのも、好きだったよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んむっ、んむっ、んじゅっ、じゅるっ！　じゅぷっ、ンッ、じゅるっ、じゅ\nるるっ！　オチンチン……おいしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ちゅぼ、ちゅぼ、ちゅぼ、ちゅぼっ！　口の中、よだれいっぱいで……んち\nゅぶっ、オチンチンを舌で、舐めまわして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そして……しごくの……んっ、ぢゅぷっ、カリが唇にこすれるの、気持ちい\nい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「腰、んちゅ、跳ねちゃってるね。ちゅぷっ、口だけじゃなくて、ちゃんとお\nっぱいでもご奉仕するよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私のよだれで、ヌルヌルのベトベトになっちゃってる、あなたのオチンチン\n……おっぱいでも、しごくから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ンッ、すごい……オチンチンがパンパンになってる……じゅぷっ、じゅぷっ\n、もうイキそうに、なっちゃってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いっぱい感じて……たくさん、射精して……。んんっ、じゅるるっ、じゅぷ\nっ、じゅぷっ、じゅるるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　んっ、んふぅうううぅぅぅ～～～～っ！！　んっ、んん……ん\nっく……ンッ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、んっ、んふぅ……んく、んく……っ。ふぅ……ふぅ……んく、ンッ\n、ふぅ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぷはっ！　はぁ、はぁ……。んふふ……。ちゃんと、全部飲んだよ。あなた\nの精液」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「口いっぱいに射精してくれた、ドロドロのザーメン。大好きなあなたのだか\nら、こぼすなんてもったいないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「オチンチン、すっごく悦んでくれたみたい。よかった……。ふふっ、まだま\nだこんなにガチガチだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まだ、興奮がおさまらないみたい。いいよ、遠慮しなくったって、あなたが\n満足するまで奉仕してあげるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「この格好は、きっとそのためのものでもあるんだから。王子様に奉仕する、\nエッチなお姫様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「すっごく恥ずかしいけど、あなたへの想いが溢れて止まらないの。大好きな\nあなたをいっぱい気持ちよくしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「１回射精したくらいじゃ、あなたも満足できないでしょ？　だから、このま\nま……おっぱいとお口で、射精させてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ん……ちゅっ。溜まっている精液、いっぱいだしてね、王子様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。んちゅ、ちゅぷ、ン……れろぉ……。んふぅ……ちゅぱ\n、んっ、んちゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「よだれで……ベトベト……。れろぉ……オチンチン、すっごくいやらしくな\nってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっぱいも……ヌルヌル……。んっ、いっぱい感じて……また、ぎゅって、\nおっぱいでオチンチン抱きしめて、しごくから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ああ……すごい……。あんなに射精したのに……。んちゅ、ちゅぷ……元気\nなまま……れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっぱいで、しごきながら……ちゅっ、オチンチン……ペロペロって、舐め\nるね……ンッ、れろ、れろぉ……ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「れろ、れろれろぉ……ンッ、ちゅぷっ、ちゅぅ……っ、舌で、オチンチンく\nすぐっちゃう……んふっ、気持ちいいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「れろれろれろれろんっ、ふふっ、またオチンチンが膨らんできた。おっぱい\nの間で、ビクビクしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、わかった。また咥えて、口の中で気持ちよくするね。んむっ、じゅる\nっ、じゅぷ、じゅぷ、じゅぷぅ……！」", "NORMAL" ]},
