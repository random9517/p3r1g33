		{"command":[ "SETIMAGE", "0", "still_00000216_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぶっ、んぶっ、んぶっ、んぶっ！　おっきいの、口、いっぱい……ンンッ\n、じゅぷっ、じゅぶっ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「熱いのが、ンッ、口の中にこすれて……ンッ、あなたの味……すごく、好き\nぃ……じゅぷっ、じゅるじゅるぅっ！」", "NORMAL" ]},
