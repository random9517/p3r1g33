		{"command":[ "SETIMAGE", "0", "still_00000216_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、吸いだすみたいに、フェラするよ……じゅずずっ、オチンチンから\n、またたくさん射精できるように……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっぱいで、竿もしごいて。じゅぷっ。パイズリと、フェラチオで、いっぱ\nい精液、ださせてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1603212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000216_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んじゅっ、んじゅっ、んじゅっ、んじゅっ！　じゅぶっ、じゅぶっ、じゅぶ\nっ、じゅぶっ！　フェラチオ……とまらない……」", "NORMAL" ]},
