		{"command":[ "SETIMAGE", "0", "still_00006102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっあふっ……あぁんっ！　お、お腹が熱くて……んんっ……身体中が貫か\nれてる感じっス……！　ヤバすぎるっス……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「な、なにって、隊長のコレっスよ……ええっ？　ちゃんと言わないといけな\nいんスか……？　う、ううっ……オ、オチンチン……っス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひぐっ！　な、なんスか……今、また大きくなったスよ……くっ、ふうっ…\n…もう中、いっぱいになってるのにぃ……くひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ダメっスよ……これ以上、強くするのは……なんでって、自分が……もう意\n識保ってられないっス……身体ももたないっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ううっ……そうっスね……これくらいで弱音吐くなんて、情けないっスよね\n……わかりました！　自分も頑張るっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁあぁっ！　あっ、あぅっ……！　んんっ……だ、大丈夫っス……平気っ\nス……隊長の、しっかり受け止めるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んっ、ンはぁっ……！　すごいっス、隊長……さっきからオチンチンずっと\n硬くて、大きくって……刺激、強すぎっス……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「どれくらいって……あひっ……言われてもぉ……あっ、あぁっ……とにかく\n、すごいんスよ……んんぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「か、身体中がしびれて……頭が真っ白になりそうでぇ……はぁはぁっ……こ\nうやってるだけで、せいいっぱい……ひぃあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長は……？　た、隊長はどうなんスか……ちゃんとパワーアップしそうな\nんスか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「絶対にする？　ならよかったスけど……んっ、あぁっ……なんスか、急に優\nしくなって……えっ、ええ？　水着？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ホントどうしたんスか……急に褒めて……似合ってる……可愛い……もー！\n　こんな時に言われたら、余計に恥ずかしいっスよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ち、違うっス……中が、ヒクヒクしてるって……嬉しいから、そうなってる\nわけじゃなくって……あっ、ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長こそ……オチンチンが、また震えてるっスよ……なんか、さっきからど\nんどん大きくなってる気がするっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「それだけ自分の水着姿に欲情してるって、こと……っスか？　ううっ……そ\nうやってストレートに言われると照れるっスよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「でも、隊長の役に立てて……そう言ってもらえて……嬉しくて、胸があった\nかくなってくるっス……本当っスよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「……ひぃぐぅぅっ！　な、なんっスか……今、いい話をしてたのに……ひっ\n、ひぃっ！　ああぁっ……あんっ！　あはぁんっ！」", "NORMAL" ]},
