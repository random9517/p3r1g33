		{"command":[ "PLAYVOICE", "v2_061_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あはぁぁっ……もう始めるんスか？　今、ヤったばっかりなのに……\nくっふぅっ……はっ、あぁっ……ひぃぐぅっ！」", "NORMAL" ]},
