		{"command":[ "PLAYVOICE", "v2_061_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「わ、わかるっス……さっきから、オチンチンが……超硬くなってるっス……\n出したばっかりなのに……隊長、絶倫すぎるっス……」", "NORMAL" ]},
