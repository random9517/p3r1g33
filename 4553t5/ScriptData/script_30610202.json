		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひぃいっ！　ひっあっ……あぁんっ！　またオチンチン膨らんでるっス……\nえ、ええっ……なんスか、もうすぐ……イ、イキそう？」", "NORMAL" ]},
