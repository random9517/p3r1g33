		{"command":[ "SETIMAGE", "0", "still_00006102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そうっスね……き、気持ちいいっス……自分もびっくりしてますけど、正直\n言うと……結構感じてるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長はどうなんスか？　自分で出した……中をそのまま突きまくってるって\n……？　はい、超興奮してる……？　そういうもんなんスね……」", "NORMAL" ]},
