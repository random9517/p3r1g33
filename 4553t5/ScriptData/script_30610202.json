		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ザーメン出したいって、いってるの……めちゃくちゃ感じるっスから……！\n　んっ、んっあっ……あんっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「い、いいっスよ……また出してください……！　隊長の……特濃ザーメン、\n欲しいっス……んひっ、ンンっ……あぁぁぁあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　オマンコぐちゅぐちゅ鳴ってる……！　ヤらしい音がして\nぇ……んあっ、はぁっ！　イ、イクっ……！　ヤバいっス！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んぉおおっ！　おっ、おほぉっ……！　じ、自分もイクっ……イッち\nゃうっス！　隊長のオチンチンで……あっ、あはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おっ、おひっ！　おおおっ！　いっ、いいっ……イクイクぅぅぅぅっ！　は\nひっ、ひぃぎぃぃぃぃぃぃぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あはぁぁぁっ、んんんぅぅぅぅ～～～っ！　ひっ、ひぃあっ、あぁぁ\nぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おっおおっ……！　おぉっ、んぉっ……で、出てるっ……！　中に……また\n出てるっスぅ……んっ、んひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おひぃっ、おっ、おほぉっ……き、気持ちいいっ……気持ちよすぎるっスぅ\nぅ……中出し気持ちよすぎてぇぇ……んっひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「オマンコに隊長のザーメンぶちまけられてぇ……イ、イクっ……またイクぅ\nぅっ……！　んっ、んはぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁぁ……はっ、はぐっ……はぁはぁ……すごすぎるっス……さっきより、\n量多くないっスか……はあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぅ……うぅん……そ、そんなによかったスか……？　はうっ……嬉しい、\nス……なんか、面と向かって言われると照れるっスね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「も、もちろん嬉しいっスよ……！　隊長の力になれて、しかもこんなに褒め\nてもらえて……最高に嬉しいっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　ま、また……スか？　いいですけど……水着も？　わかったス、隊長\nのお願いならなんでも聞くっスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そ、そうっスね……自分も気持ちよかったんで……結構楽しんじゃったス…\n…それでいい？　そう言ってもらえると、安心するっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ヘヘヘッ……隊長に期待してもらえると、なんかその気になっちゃうっス…\n…またいつでも呼んでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ふぅうっ！　ど、どうして抜くんスか……！　あっ、あぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひゃぁあああああっ！　な、なんっ……なんスか！？　熱いっ……あぁっ、\nひっ、ひぃあっ……か、かかってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長のザーメンがかかってるっ！　ひっ……ひぅっ、ひぃあっ！　なんで、\n自分にかけてるんスかぁ……あぁ、あはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、はぁあっ……ヌルヌルしてて、熱くって……蒸せるような匂い\nで……頭が変になりそうっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「うぅ……ぶっかけられて、イッちゃったス……ひぅ……中に出さなくてよか\nったんスか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「水着姿の自分をザーメンで汚したかった……ううっ……そういうもんなんス\nか……？　隊長がいいなら、いいっスけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「確かにすごい量っスよね……さっきより多いんじゃないスか……？　それだ\nけ興奮してくれたってことっスよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そう考えると嬉しいっス……はい、自分も気持ちよかったですし……とって\nもよかったス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「また水着でして欲しいんスか？　仕方ないっスね～、隊長にそう言われたら\n断れないっスよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「いいっスよ。もっと喜んでもらえるように、新しい水着も用意しておくんで\n。いつでも言ってくださいね、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0203410" ]},
		{"command":[ "WAITINPUT" ]},
