		{"command":[ "SETIMAGE", "0", "still_00006102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ、あひぃっ……お、音は、聞こえてるっスから……言わないでくださ\nいっ……あっ、あんっ！　やらしい音って、わかってるっス！」", "NORMAL" ]},
