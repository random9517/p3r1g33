{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0118" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「状況は、いま話した通りだ。隊長たちは現在、月面で戦闘を続けているもの\nと思われる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112030001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「戦闘を続けているって……つまり、隊長たちは孤立無援ってことじゃないで\nすか！　なにか手を打たないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。彼らを見捨てるわけにはいかん。私が地球に帰ったら、なにか策を\n考える。それまで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112030002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おっと、まもなく地球の大気圏に入るようだ。いったん通信を終わる。それ\nまで、本部のことはよろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112030003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「わかりました。こちらでも救出計画を考えてみます。それでは、またあとで\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……………………はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「救出計画……？　地球から３８万キロ離れた月面で孤立した隊長たちを助け\nる？　ゲートも使えない状態で？　いったいどうやって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんか考えろよ。冷静な頭脳がウリなんだろ。おまえはよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「赤塚ほむら……！？　あなたがどうしてここに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どうしてもこうしてもあるか。あたしだってインクレディブル・スクワッド\nのメンバーだぜ。それに、隊長やルナテミスたちには世話になったしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長たちのことを、知っているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「知ってるさ。みんな知ってるぜ。だからこうして集まってきたんじゃねえか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「みんな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ、秘書さんから連絡をいただきましてねえ。こうして大急ぎで駆けつけ\nてきたっていうわけですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「お七さんまで！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私たちだけじゃあござんせんよ。九姉妹（ナイン・シスターズ）の主だった\n幹部はほぼ全員。それに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ニンジャ・ラビッツやほかのヒーロー連中、怪人連中、どっかの世界のプリ\nンセスたちも詰めかけてきてんだぜ？　みろよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「こんなに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030009" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「もっと大勢います。来てくださった皆さんには、会議室でお待ちいただいて\nいたんですが、入りきれなくなってしまって……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「会議室って、あの大会議室ですか？　そこに入りきれないぐらい、集まって\nきたっていうんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030010" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「なんだかんだ言っても、これまで一緒に戦ってきたメンバーですからねえ。\n月に置き去り、ってわけにもいきませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それはそうです。彼女たちを見捨てることはできません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030011" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だろ？　わかってんなら、さっさとなんか考えろ。みんな待ってんだからよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたに指図されるいわれはありません！　あなたのような、戦隊を追放さ\nれた裏切り者になど――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030012" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んだと、この！　だいたいおまえは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「はい、おふたりともそこまで！　地球で仲間割れしてる場合じゃないでしょ\nう。いまはとにかく、月にいる人たちをどう助け出すか、問題はそこです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「う……まあ、そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……たしかに、そのとおりです。ですが、この人が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030013" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んだよ！？　あたしのせいだってのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_014" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「じゃかぁしいわ！　おどれら、ええかげんにせんかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030014" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「小学生じゃあるまいし、いつまでも意地を張り合わないでくださいな！　目\nの前の、やるべきことを片付ける！ケンカの片ぁつけるのはそれからです！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……おっしゃるとおりです。ちょっと、失礼します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030015" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「どちらへ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「奥の打ち合わせスペースへ。静かなところで、考えをまとめたいんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030016" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「承知いたしました。でしたら、私たちは外に出てますので――ああ、でも、\nほむらさんは残ってくださいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんでだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ひとりで考えるにしたって、助手は必要でしょう？　資料をまとめるなり、\nお茶を入れるなり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030009" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「って、なんだってあたしがそんなことを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「どうしてほむらを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030017" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……今、やるべきことは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030010" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……わかっています。ですが、ほむら。くれぐれも邪魔をしないように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030018" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「誰がするかよ。おめぇこそサボんじゃねえぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「では、どうぞごゆっくり。それじゃ秘書さん、私たちは出ましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030011" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「はい……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_002" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「あの、お七さん？　どうしてほむらさんを部屋に残したんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「え？　ああ、あのことですか。ひとりで考え込むより、刺激があったほうが\nいいアイデアも沸くだろうと思いましてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030012" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「……それは、そうかもしれませんけど。うまくいくんでしょうか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「いくかもしれないし、いかないかもしれない。まあ、私だったらうまくいく\nほうに全財産でも張りますけどね。ふふふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112030013" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0095" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0096" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……なあ。まだなんか思いつかねえのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ほむら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お！　思いついたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「コーヒーを。砂糖は２杯です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0097" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「またかよ！　またコーヒーかよ！　コーヒーばっかり飲んでねえで考えろよ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0098" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「考えてますよ！　考えてるに決まってるでしょう！　考えてすぐ思いつけば\n苦労はしないんですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0097" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……そんなに難しいのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ええ。あなたにはたぶん想像もつかないぐらいね。隊長たちが対峙している\n相手は。かなりの戦力を持っているはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030024" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0095" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「と、すれば、グレート・ルナリアムの皆さんがルナパレスからの通勤に使っ\nていたようなゲートを再生できたとしても――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それで移動できる程度の人数を、ちまちま送り込んだのでは焼け石に水です\n。各個撃破されるだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうならないためには、大人数のヒーローや悪の幹部を、一度に月まで送り\n込まなければならない。でも、どうやって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さあなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0097" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あああああ！　もう！　考えただけで頭が痛いですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0099" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……コーヒーいれてくらぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ドーナツもお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はいはい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ほむら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030030" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんだよ、まだなんかあんのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030024" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0100" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……いちおう、お礼を言っておきます。……ありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112030031" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……まあ、いいってことよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「しかし月にいる連中、いまごろどうなってんのかねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112030027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤ、大丈夫か！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「大丈夫！　かすり傷！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こちらへ！　いちおう手当てをします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ、いったん退こう。向こうのクレーターまでだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それがよさそうだな……よし！　みんな！　あのクレーターまで走れ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}