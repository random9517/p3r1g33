{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ええこうなること、くらい予想してましたよんっ、しょっとおっぱいでご奉\n仕されるの、好きですもんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「大丈夫です。夫も、娘もこの時間は帰ってきませんからゆっくり楽しんでく\nださい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「私も？　そうですね、正直期待してましたあん、言わないでください悪いの\nはわかってますでも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「でも、我慢できないんですこんなふうにしたのはあなたですよ？　責任、取\nってくださいねんっ、ちゅっちゅく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「わかって、ますちゃんと胸でご奉仕します、からあん、なににってちん、ぽ\nあなたのチンポです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ガチガチに勃起して、反り返ってて胸の中で、熱くてごつごつしてて素敵で\nす男らしくて、本当に素敵なチンポれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっはむっんんっは、恥ずかしいですよ今でも、チンポなんて言うの\nはれるっでも、あなたが悦ぶから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ほ、ほらぁチンポって言うたびに、胸の中でビクビク震えてどんどん硬くな\nってますあぁ、あんっ先っぽも膨らんでんむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「やっぱり若いチンポってすごいはぁあぁっここまで、イヤらしい匂いが漂っ\nてくるぅんっ、んっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「そう、ですJカップです誰のものって言われてもんんっ、あぁ、言います言\nいますから、抜かないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あなたのものです夫の、ではなくてあなたのおっぱいですあむっいつでもど\nこでも好きに使って、くださいくちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「うぅ、はい欲求不満のJカップ人妻の浮気パイズリご奉仕楽しんで、くださ\nい舌も、使ってあぁあっふぅちろちろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「わかってます、動かしますから急かさないで、くださいんっだって、今まで\nそんなにしたことなくてぴちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ですから、夫にはあまりしたことないって言ったじゃないですかあなたはい\nつもやらせますけどんふぅっパイズリフェラ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁはぁっ少し、慣れてきましたけどこうやっておっぱいを揺らし続けるだ\nけでも大変、なんですよんん、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あぁ、んっ、それに谷間が擦れてチンポですチンポがグリグリ当たってはぁ\nあんっ私まで、興奮して、きて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「だって、胸に挟んでるだけでも、チンポの形も熱も伝わってきてあぁ身体が\n火照ってきてはぁ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はっ、あんっあぁ、あふっす、好きですあぁあっチンポ、好きぃチンポにご\n奉仕するの、好き、ですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「だって正直に言わないとあなたが、意地悪するからぁあんっは、はふぅご褒\n美、あぁ欲しいっれるっ、れろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっふぅ、うんっはぃ、頑張りますデカパイ欲求不満の淫乱デカパイ揺らし\nてチンポにご奉仕ぃんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「どこで、覚えたってあなたが言わせてるんじゃないですかぁあ、あふっんん\nっも、もっとですか？　んちゅっちゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はあっ、はっふぅっああ、恥ずかしい本当ですよ本当に恥ずかしいんですで\n、でもでもぉチロっ、れろんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「やめられないんですチンポにご奉仕、やめられないんあっおっぱい、擦れて\nべろ、れろぉっ気持ちよくってぇあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「たくましくて、男らしいチンポあなたのデカチンポをこうやって、擦ってる\nだけで胸がドキドキしてぇはぁ、あむぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、んっあっあぁ、乳首、勃起してるビンビンに尖ってますぅ興\n奮しすぎてはぁはあ、はあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んんっ！　グリグリ、しないでください気持ちよくてぴちゅっご奉仕、でき\nなくなっちゃうんぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅはいぃ、勃起乳首、揺らしてJカップのデカパイを擦りつけてぇ\nあっ、あんっはぁぁぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「だ、出していっぱい出してくださいんうっ、ふっふぅうっれろ、れろんっは\nぁ、あんっあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「どこ、でもいいですザーメン、おっぱい中出しでもぶっかけでもいいですか\nらぁあ、あふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっか、顔、ですか？　いいですよんんっちゃんと受け止めますから\nあんっくちゅ、ぴちゅぴちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ぺろっ、れろっんっぷっはぁはぁ、出してれろぉっんんぅっ！　んっ！　ら\nひてぇふぅっ！　くちゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、んっんっ！　はっあっ、むっんんっ！？　んん～～～！　はっ、あぁ\nぁぁぁぁぁぁぁ～～～っ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あっ！　あぁあっ！　はんっ出て、るぅっひゃぁぁっ！　ザーメン、どくど\nくって出てぇひぃううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっすごい、いぃあぁ、はぁ、はぁぁぁあ、熱いんんっあんっ！　\nんっ！　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ！　ひゃっ！　あんっあっあっはぁぁあぁぁぁっ！　んっふっ、んんん\nん～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はふぅ顔が、ドロドロになってぇうっぷはぁ、あんっすごい量あぁん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、ぴちゅ味も濃くってはぁあふっ、うぅん悦んで、もらえたみたいでよ\nかったですんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はい、そうですねチンポ、まだ硬いままあんたくましいです射精しても勃起\nしたままだなんてあぁんぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「これだけ出したのに反り返っててヒクヒクしてて、本当にすごいです夫のと\nは比べ物になりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっわかりました。いいですよ、このままご奉仕続けますおっぱいと、口で\nまた気持ちよくしてあげますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっんっ、本当に元気なチンポですねんっ、ふうっはぁ、はぁあふっ\nんんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「私の胸が気持ちいいから？　そう言ってもらえるのは嬉しいですねんっ焦ら\nないでください、ちゃんと舐めますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅれろっんんっ、ふっんんっちゅぱちく、ちゅくっああ、大きいん\nっ、んっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁさっきより、熱くて、硬くてザーメンの味も残っててあ、あんっちゅぷ\n、んっぷっはぁ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「おっきくて、先っぽだけでも、咥えてるとんっ、んぶっはっああっ顎が、疲\nれてきてぇはっ、んはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぶっ、んっ、ふうっふぅっちゅむ、ちゅるっちゅっぱ、ちゅっぱんんっん\nぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「は、はひぃおっぱい、も動かし、ますからぁんっ、んはっあっあふっんっし\nょっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「同時にするの結構、大変なんですよんむっ、んちゅっはっ、ふっ、んぶっち\nゅぼ、ちゅぼっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「慣れて、きたのはあなたが、させるからですんっ、はぁあっい、嫌々ってわ\nけじゃないですけどんっぷ、ちゅむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ぴちゅ、ちゅぶっんぶっ！　じゅるるっれろ、れろぉっンぶっ気持ちい、い\nっですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ほうやっへさきっぽちゅば、ちゅちゅぶっんちゅっしゃぶりながらおっぱい\n、擦りつけてぇれるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　パンパンに膨らんだカリが、谷間で擦れて私も、んっあぁはっ\n、くっふぅはぁ、あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「お、美味ひぃんっ、ちゅぶっちゅく、ちゅうっれるっ、んぶぅっ！　我慢汁\nがドバドバ溢れてきてんっ、ぢゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「またイキそうなんですか？　はぁっ、はっはっんふっれろれろっんちゅっち\nゅ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「さっき、あれだけ出したのにんっ、ちゅぶっんんぅっ！　はむっぢゅっ、ぢ\nゅぶっんんっあんっ、んむぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「もっと強く、挟んでちゅぶっ、ちゅぶぅうっんっ、んんっおっぱい、擦りつ\nけてぇんふぅっ！　ちゅるっ、んちゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ！　だ、出してぇっは、はいっおっぱいと、お口でんっ、んんぅ\nっじゅる、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「は、あぁっあなたの、好きなんぅっ、ようにちゅ、ちゅぶっしていいですか\nらはあ、はあっはっンン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んぷっ！　ちゅ、んむゅっ！　んっ、んんっぐっぷ、ぐぽぉじゅぽっじゅぼ\nっ！　んっンンぅぅぅぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あふぅっ、うっ、んぶぅっ！　出ひぃてっんぶっ！　じゅぶっんっんっ、ん\nううぅぅっ！　んぐぅぅぅぅっ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はんんっ！　んぐっんぶぅぅぅっ！　むっぐぐっ、んぶぅぅぅぅぅ～～～っ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んぶっ！　んぐっ！　んくっごくっ、ごくんっんぐっ、んっんむっんぶぅっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ぷはっ！　はあ～～～はぁ、はぁっんっ、じゅるるっんくんんくちゅ、ちゅ\nるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁんっすごい、量出ましたね喉に絡みついてきて飲みづらいですンくっご\nくんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「え？　飲み、ますけどだって、あなたがそうするのが普通って言ったんじゃ\nないですかだから、私っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「でも美味しく、はないですけど正直言うとまずいのに、ザーメン飲んでると\n、興奮しちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「それだけ、私の口とおっぱいで気持ちよくなってくれたんだって思うと嬉し\nいですしはい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「なんていうか、女として自信がわいてくるっていうかご奉仕も好きですしご\nっくんも嫌じゃないですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「そんなに褒められると恥ずかしいですんっなんですか、まだ足りないんです\nか？　仕方、ないですねんふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「心配しなくても、大丈夫ですよ。私のおっぱいはあなたのものですから満足\nするまで、ご奉仕しますふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「きゃっ！！　んっ、あっあぁぁあぁぁっぁあ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅっ！　きゃっ、あぁっ！　やっ、ンっはぁあっま、また顔にんっ、\nんぶっ！　ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あ、熱いザーメンがまたびゅっ、びゅって飛び散ってやんっはっ、あうっは\nふぅんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「さっきあれだけ出したのにドロドロで、量も多くってひぐっんっ、んん～は\nぁ、はぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「顔が精液まみれになってんっ、すごい匂い生ぐさくて、むせそうはぁっはぁ\nあんっ、あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「こんなにかけられたら、洗っても匂いがこびりついてバレちゃう夫に、浮気\nがバレちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「は～はぁぁ、はぁはぁす、すぅんっはぁくさい本当にオスの匂いがぷんぷん\nしてます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「興奮したとか、言わないでくださいそ、そうですけどううっもうこのチンポ\nの虜なんです身体が求めてしまうんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「夫や娘には悪いってわかってますけどでも、でもあぁガチガチのチンポをグ\nリグリしないでくださいあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁあっヤらしい匂いまたしゃぶりたくなっちゃいますまだ時間はあ\nりますからいっぱい気持ちよくしてあげますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}