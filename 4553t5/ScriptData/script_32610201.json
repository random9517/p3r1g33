		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先ぱ……じゃない、カツマ隊長、マスク・ザ・ホワイトただいま参上です。\nって、こんな場所に呼び出してどうしたんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「えっ、EDOに所属するマスカレード隊員として特訓をする、ですか？　は\nい、分かりました。私、皆よりもまだ力が足りないのは分かってますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「厳しい特訓になる……？　ええ、大丈夫です。ランニングだって、組み手だ\nって、こなして見せます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「じゃあこっちにって……ここ、人気のないところですけど。見られたらまず\nい特訓ですか？　マル秘特訓って奴ですね！！　って、きゃあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00026102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「た、隊長！？　これって、どういう……んっ、やあっ、あんっ、こんなとこ\nろでおっぱい揉んだら、ダメ……やあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_03" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「て……敵の怪人にエッチな攻撃を受けたときの特訓って、んっ、あんっ、あ\nあっ、そんな状況……ひああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、脚の間に、先輩のおちんちんが……あんっ、あっ、おっぱい、ダメ\nですって、ここ、外なのに……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「外だから耐える意味があるって……んっんっんっ、あっ、あふうっ、ふっ…\n…えっ、前よりおっぱいが大きくなってるって……それは……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「そんなことはないと思いますけど……やっ、あっ、あっあっあっ、そんな揉\nみしだかないでください……ふあっ、あんっ、あくうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「敏感、敏感になってるからあっ、ひあああああっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、そう、そうです、先輩の言うとおりですっ　前に先輩がしたのを思い\n出して……自分で、おっぱい……弄ってたら、大きくなって、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「そうしたら、敏感になってきて……だから、お願いします、揉むのは……声\n、抑えられなくなっちゃうから……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あううううっ、んっ！！　なんで、なんでまた手を動かしてるんですか、先\n輩っ、ダメ、ダメですってば、やああっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んうううっ、うっ、それに耐えるから訓練になるって、そんな、ふっ、あっ\n、ああっ、あんっ、あくううっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ふうっ……先輩、手つきがいやらしいです……それも特訓だっ\nて言われても、ふうっ、ああっ、あんっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ダメ……ダメ……おっぱい熱くなってきちゃって、ふううっ、あっ、あんっ\n。んっ、先輩の手が、気持ちよくて……んんっ、あっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ひあああああっ、あっ、先端、出てきたの、弄ったらダメっ、あっ、あくう\nっ、んんっ、あっ、気持ちいいっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「そこ、そこ指先でくりくりってされると、ふああっ、お腹がきゅんきゅんし\nちゃう、んっ、ああっ、あんっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、あふうっ！！　ダメ、ダメダメっ、腰が、ヘコヘコって…動\nいちゃう……んんっ、先輩のおちんちんにこすりつけちゃう、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふうううっ、んっ、これを、耐えろって……そんなの、無理っ、んふううっ\n！！　先端、指でくりくりしちゃ……っ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んうううっ、お腹が、きゅうきゅうって、ふううっ、先輩のおちんちんと指\n、熱くて……ふうっ、うっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんんんっ、ダメっ、ダメっ、私、正義の味方なのに、えっちな事ばかり考\nえちゃってる、んんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ダメなのに、こんなことばっかり考えたらダメなのに、んんんっ、先輩に、\nもっともっとっておねだりしちゃう、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んううううっ、それも特訓だって、ふうっ、うううっ、こんなえっちなこと\nをしてくる敵なんて……あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「そんな敵、先輩ぐらいしか……ひあああああっ！！　んんっ、指摘したら強\nくいじるなんてっ、んうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「耐えてみせろって、そんなの、そんなの無理ですっ、あっ、んっ、ふううっ\n、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「だって、だって、先輩の手もおちんちんも、気持ちいいっ、気持ちいいから\nっ、ふあああっ、こんなの耐えられないっ、あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んふううううっ、んっ、んんっ、あっ、んっ、先輩のおちんちん、私のお汁\nでべとべとに……ふううっ、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、濡れたおちんちんがぬるぬるって動いて、それも、気持ちよくて…\n…んううっ、ふっ、あっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、指と一緒に動かされたら、ああっ、んっ、ふうううっ、気持\nち、いいっ、こんなの、気持ちいいしか……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ、先輩の指とおちんちん、気持ちいいですっ！！　こんなの、\n耐えられない、でも、特訓だから……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「もっと、もっと責めて、責めてくださいっ、ひああああっ、あっ、あんんっ\n、あっ、ダメダメダメっ、やっぱり、無理っ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、くっ、うっ、イく、イく、イっちゃう、特訓なのに、イっちゃうっ！\n！　先輩の指とおちんちんでイっちゃううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんんんんっ、おっぱいの先っぽ、潰しちゃダメっ！！　イく、イっちゃう\n、おっぱいでイっちゃいます、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ、気持ちいいの、来た、あっ、イっく、イっくううううう\nうううううううううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああああああああっ、あっ、んんんっ、ふううううううううっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ひああああああっ、先輩のおちんちんも、んんんっ、あっ、脚にかかって、\n熱い……んっ、ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、あっ、凄い、気持ちよかった……特訓なのに、耐えなきゃい\nけないのに、先輩の指とおちんちんが凄く気持ちよかった……です……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩も、よかったんですね。ふふ、おちんちんびくびくしてる……特訓なの\nに、気持ちよくなっちゃうなんていけませんね、私たち……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふふっ♪、下半身が私のと先輩のでびしゃびしゃになってます……ふっ、ん\nっ、熱くて、気持ちいい……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ん……でも特訓は失敗しちゃいましたね……私も先輩も、ただ気持ちよくな\nっちゃっただけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「だから、もう一回…お、お願いします、…特訓。　んふふ、次は頑張って耐\nえて見せますから……ね？　ふあっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「そんな、いきなりまたすぐに……んっ、ふううっ、んっ、おっぱい、敏感に\nなってるからって言ったじゃないですか、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「だから特訓してるって、そうですけど、んっ、もうちょっと、もうちょっと\n優しく……ふああっ、あっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんんっ、優しすぎるのもダメっ、そんな先っぽさわさわされたら、余計に\n気持ちよくなっちゃう、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「わがままって、だって先輩が私のこといっぱい気持ちよくしちゃうから、ふ\nあっ、んんっ、うっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あうっ、おちんちんもまた動いてっ、ふうううっ、私の腰も動いちゃう、ん\nっ、あくうっ、ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、またおっぱいとお腹がきゅうきゅうって熱くなってる……ん\nんっ、先輩のこと、好きって言っちゃってますっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あふううううっ、硬くなった先っぽ、潰したら、んんっ、私の身体全部、気\n持ちよくなって、あくううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「はあっ、あっ、あああっ！！　無理っ、こんなの無理っ！！　やっぱり耐え\nられないっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「おっぱいも、おまんこも、気持ちよすぎるうううううううううっ！！　ふあ\nあっ、先輩の指とおちんちんが気持ちよすぎる、んんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「特訓だから耐えてみせろって、無理っ、無理いっ！！　こんな気持ちいいの\n、無理ですっ！！　だって、だってぇ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先輩のこと、好きだからっ！！　好きな人に責められて耐えるとかできない\nですっ！！　絶対気持ちよくなっちゃう！！　ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、また指が強く……んんっ、先っぽつまんじゃダメっ、ふああ\nああっ、あっ、おまんこ、きゅっきゅってなっちゃいますっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、うっ、また、またイっちゃう、特訓なのにまたイっちゃう、\n乳首とおまんこでイっちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んうううっ、先輩もイきそうなんですね、んっ、おちんちん、さっきみたい\nにびくびくってしてます。私の脚の間で、切なそうに跳ねて……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「イきましょう、一緒にイきましょう、んっ、私と先輩、これも特訓ですよ、\nね？　あんっ、ふううっ、ほら、呼吸を合わせて、あんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「先っぽ弄っちゃダメですって、んんっ、だったら、私も腰を、んんっ、あっ\n、ふうっ、これ、また違った気持ちよさが、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あうっ、んくうっ、あっ、イく、イく、またイく、先輩の指とおちんちんで\n、おっぱいとおまんこで、またイく、うううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「イっくううううううううううううううううううううううううっ！！　ふああ\nあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふあああ、おまんこから、お汁が……止まらないっ、んんっ、先輩の精液も\n……んううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203301" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「私のと、先輩のが入り交じって……脚がどろどろになってます……んっ、太\nももが真っ白になっちゃった……ふふっ、私の色と一緒ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、うっ、こんなに一杯……これって、私も先輩に勝ったってことになる\nんじゃないですか……？　あんっ、それダメっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「言い負かされたらおっぱい弄ってくるの、反則です、……んっ、ふうっ、ん\nんんんっ！！　さっきイったのに、また……先端弄るのダメですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、んんっ……敵はいつも卑怯なことをするって……もう、先輩\n、……ふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、でも、そうですね……私も先輩の攻撃に耐えきれたってわけじゃな\nいですから、今回は引き分けですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んっ……負け…てはないですよ…先輩だっていっぱい出したじゃないですか\n。私の脚、妊娠しちゃうかもってぐらいに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「……でも、私もおっぱい、……先輩に責められて……たくさんイっちゃいま\nしたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「とはいえ、特訓は引き分けじゃダメ……ですもんね。……私が先輩に勝たな\nきゃ、特訓の意味はないですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「だから、また……一緒に特訓……してくれますか？　次は、負けませんよ…\n…先輩の指と、おちんちんに。えへへっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、おちんちんの角度が……あっ、ふううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203401" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_25" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んうううっ、んっ、顔や、胸に……ふあああっ、熱いっ、匂いも……んんっ\n、んふうっ、あっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、まだ出て……出しながらおっぱい弄っちゃ……んくうっ、んっ、ふ\nうっ、ああああああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「また……軽くイっちゃった……んっ、あんっ、あっ、先輩の指とおちんちん\n、凄すぎます……やあっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_24" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あんっ、ふうっ……特訓は私の負けって……そうですね、悪い\n先輩にやられちゃいました……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「んふっ、身体中こんなにされて、イかされて、完全に……負けてしまいまし\nた……これが本当の戦闘なら、私、危ないです……よね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「悪い先輩に……こんな風にやられて、このあとお部屋に……連れ去られちゃ\nって、そこでいっぱいいっぱい……えっちなことされちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「やんっ、先輩、想像しちゃいましたか？　おちんちんがぴくぴくって。ふふ\nっ、……私もちょっとおっぱいが熱くなっちゃいました、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「でも、このままじゃダメですもんね。こういう攻撃にも耐えられるようにな\nらなきゃ……足手まといはいやですから。だから、先輩」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ホワイト" ]},
		{"command":[ "SETTEXT", "「また特訓してくださいね……私の身体、いっぱいいっぱい責めてください…\n…次は耐えてみせますからね。ふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0203410" ]},
		{"command":[ "SETIMAGE", "0", "still_00026102_01_22" ]},
