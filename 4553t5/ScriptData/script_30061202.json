{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんっ。いきなり後ろから抱き着いてくるなんて……。ンッ、またここで…\n…するつもりなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そんな……スーツをずらしたら、おっぱいが……。ああ、もう乳首が勃起し\nているだなんて、言わないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「だって……あなたがこのスーツを、ずっといやらしい視線で見ているから…\n…。んふぅ……わたしも……意識してしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。なにを……ンッ、オチンチン……こすりつけて……ああ\n……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「すごい……こんなに、ガチガチになってる……。ずっと我慢していたから…\n…なんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぅっ、あんぅっ、スーツ越しに、熱い……！　オチンチン、ああ、ごしご\nしって……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……だめです……。ここで、オマンコに挿れるなんて……。誰かに見ら\nれたら、大変なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁっ、そんな……乳首責めながら、オマンコも同時に……っ！　ああっ、\nああ……オチンチンでクリトリス……潰されるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いやぁ……言わないでぇ……。クリトリスも、乳首と同じくらい勃起してい\nるだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたがいやらしく責めるから……身体が勝手に……オチンチンを欲しがっ\nてしまうんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……腰が動いちゃいます……。こんなこと……いけないのに……。誰か\nが来てしまうかもしれないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「淫乱マンコが……お汁垂らして……。んはぁ……あなたのオチンチンを、欲\nしがってしまって……ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あんっ、局長がそんなおねだりをしていいのかだなんて……。そんなこと…\n…いいわけありません……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたがわたしのことを発情させるから……。我慢がもう……できなくなっ\nちゃうんです……！　おねだりもしちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「スケベスーツの発情マンコに、あなたのたくましいオチンチンを挿れてくだ\nさい……！　たくさん、ずぽずぽして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはぁああっ！　あひぃいいいぃぃぃんっ！　ぶっといのぉっ、きたぁああ\nあぁぁぁ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、あはぁあっ！　おっ、潮ぉっ！　オマンコから、お潮吹くぅっ！　\nんっひぃいいいぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……だって……言ったじゃないですか……。あなたにずっと、いやらし\nい視線で見られていたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「任務中……あなたに視姦されているみたいで……。身体が、疼いてしまって\nいたんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぅっ！　あっ、ああっ！　突きあげてっ、んひぃんっ！　オチンチンで、\nわたしのこと、思いっきり突きあげてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「熱いオチンチンがっ、子宮に刺さるくらいっ！　ああっ、ああっ、強くぅ…\n…っ！　んひっ、ひぃいいぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、グショグショのオマンコ、あなたのオチンチンにかき混ぜ\nられてるっ！　ああっ、オチンチン感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いいっ、いいのっ！　とっても気持ちいい……！　ああっ、ああっ、いけな\nいのに、腰も勝手に……動いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　はぁんっ、ああっ、ああっ、悦んじゃってるっ！　オマンコが\n、あなたにずぽずぽされて、感じてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「どんどん、お汁溢れさせちゃうの……。奥からスケベ汁がとまらないぃ……\n！　んひぃっ、ああっ、あはぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そ……それは……。んぁっ、こんなに、声を出していたら……ああ、外を歩\nいている局員に、気づかれるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしが、あなたとセックスしている、はしたない声……聞かれちゃう……\nのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　ああ……っ！　だめっ、声を我慢できないぃっ！　オチンチン、\n気持ちいいから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンにオマンコめちゃくちゃにされるのっ、すっごく……感\nじるの……ああっ、あひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こんなところでセックスしてるのに、ああっ、はしたない汁で、床までびち\nょびちょにしながら腰振っちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、オチンチンも膨らんできてる……！　ああっ、あなたも、興奮し\nてくれているんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁっ、もっと、オマンコを締めろって……？　ああ、わかりました……締\nめます……締めます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、ますますオチンチン感じるうぅ……！　射精しそうになって、ビ\nクビクしてる、オチンチン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「えっ、このまま中出し……？　それは……でも……ああんっ！　奥に先っぽ\nが……当たるぅううぅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、欲しがってますっ！　あなたの精液を、中に……欲しいの……！　\nだして、くださいっ！　このまま……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　中出し……中出しぃいいいぃぃぃっ！　んぁあっ！　ああ\nっ、あはぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「きてっ、きてるぅうううぅぅぅっ！！　ドロドロの精液ぃっ、中にっ、オマ\nンコにたくさん注ぎ込まれて……んぃいっ、くぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ひぃ……ひぃ……オマンコうねらせてぇ……オチンチンから精液、いっぱい\n搾っちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……そんなにぃ……オマンコぐりぐり……射精しながら責めないで……\n。あっ、ああ……イクッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「オマンコ……簡単にイかされるぅ……！　ああっ、ああ……ひぃいっ！　ん\nひっ、ひぃっ、あっひぃいいいぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。こんなにぃ……オマンコ、イクなんて……。ああ……恥\nずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ドスケベ局長にふさわしいイキっぷりだったなんて……。そんなの、誉め言\n葉じゃありませんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んっ、ああ……。もっと……ですか……？　はぁ……はぁ……さっきあんな\nに射精したのに、オチンチン……まだ硬い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしも……もっと欲しいです……。わたしの淫乱マンコ……オチンチンで\nお仕置きしてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　はぁああぁんっ！　また突きあげてっ！　腰ぃっ、んっひぃっ！\n　オマンコぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ずんずんしてっ、ああっ、硬いオチンチンで子宮を持ち上げてぇっ！　あは\nぁっ、ああっ、ああ……気持ちいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「は、はい……！　自分ばかり気持ちよくなってないで、ちゃんとあなたのオ\nチンチンも気持ちよくします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしも腰振って、オマンコ締めて……んぁあっ！　アツアツオチンチン感\nじるぅっ！　あっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……オマンコから、お汁が……！　中出しされた精液と一緒に、オチン\nチンにかきだされちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「でも、とまらないの……！　自分から、腰を弾ませて、オマンコでオチンチ\nンをしごいちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ごめんなさいっ！　もったいないことしてごめんなさいぃっ！　お\n詫びに、もっと腰を振りますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「さっきよりもたくさん精液をだせるように、ドスケベ腰振りがんばります…\n…！　はぁっ、はぁっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あなたのピストンも激しいぃっ！　ああっ、ああっ、それにオチンチンも暴\nれまわって、オマンコがめちゃくちゃに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひっ、はっ、はっ、はぁあっ！　こすれるっ、いいところに、オチンチン\nがごりごり当たるのっ、んひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「また、射精しそうになってる……？　ああ、あなたも、イキそうになってい\nるんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「わたしも、またイキそうです！　さっきから、こみあげてきているんです…\n…！　んぁっ、あはぁ……イキそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「淫乱マンコ、イクッ、イクッ、イッちゃう……！　ああっ、あなたもイッて\n……精液……だして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「お、おねだりよりもお詫びしろって？　ああっ、そうですね、まずはごめん\nなさいっ、いやらしい格好でごめんなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「おっぱいやお尻をみせつけるドスケベスーツで、視姦されて欲情するような\n、変態局長でごめんなさいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ごめんなさいっ！　変態局長、イキますっ！　あなたの精\n液を浴びて……イキますぅうううぅぅぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んはぁあああぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　イッくぅうううぅぅぅっ！！　またオマンコに中出し\nされてっ、イクのっ、おおっ、おほぉおおおぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「熱い精液びゅーびゅーきてるぅうっ！　子宮にっ、べっとり、張りついてき\nてるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「イクッ、潮吹いてイク……ッ！　んぉっ、おっ、おおおぉぉぉっ！　オマン\nコが……こわれるぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「んひぃ……ひぃ……。はぁ……んふぅ……。また……こんなにぃ……中出し\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……わたしが、この服装だから……いっぱい射精、してくれたんですか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふふ……うれしいです……。あなたが、いっぱい気持ちよくなってくれたか\nら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。なんですか……？　まだ、物足りないんじゃないかって\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「それは……その……。もっと、してくれるのですか……？　ああ……あなた\nが、したいのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あっ、まって、抜かないで……！　して欲しいです！　わたしがして欲しい\nですから！　だから……オマンコもっと、犯してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいぃぃぃっ！　でてるっ、ああっ、オチンチンから精液ぃっ！　\nああっ、ああ……いっぱいぃいいいぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「精液っ、いっぱいかけられて……イク……ッ！　んぃっ、イクッ、イク……\nイク……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁぁ～～～～っ！！　精液浴びてぇっ、潮吹きっ\n、アクメ……キちゃうのぉおおおぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ああ……イキましたぁ……。ぶっかけアクメ……あなた\nの……精液でぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000612_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「スーツが……ドロドロ……。熱くて……濃厚な精液で……汚されてしまいま\nした……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「床も……わたしのマン汁と……潮で……びっしょり……。はぁ……わたし、\nこんなに興奮していたなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……そんな……。部屋が、わたしのスケベな匂いでいっぱいだなんて…\n…。恥ずかしいから、嗅がないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いやらしい匂いに包まれてぇ……。んふぅ……わたし、何度もイッてしまい\nそう……です……。はぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ああ……そうですね……。部屋を、スケベ汁でべちょべちょに汚したことを\n……謝らないとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。マン汁おもらし局長で……どうも、申し訳ありません…\n…でしたぁ……」", "NORMAL" ]},
