		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「クリスタルの影響か、貴様を見ていると普段よりドキドキするのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「普段よりとはどういうことか、だと？　それは、普段は指揮するお前の姿を\n見て……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803103" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……って、そんなことはどうでもいい！　と、とにかくこんなことになるの\nは貴様のせいだ！　そ、そうに違いない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803104" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいから、黙って言うことを聞け～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん。貴様だって期待していたのではないか。もうこんなにオチンポが勃\n起しているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「せっかくだから、その期待に応えてやろう。私がご奉仕してやるから、感謝\nするんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こう……だろう？　胸で、オチンポを挟み……ふふっ、もうすでに悦んでい\nるようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「谷間で、オチンポが震えているのが胸に伝わってくるぞ。ンッ、こら暴れる\nな。大人しくしていろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……んん……すごいな……。こうやって、胸で揉むように刺激して……。\nああ、オチンポの脈動を感じられる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「浮き上がった血管が、ドクドクと……。そんなに気持ちいいのか？　相変わ\nらず、お前のオチンポはチョロいなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。どんどんオチンポが膨らんで……。先っぽもパンパンで\n、破裂しそうになっているじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま……オチンポも責めてやろうか……？　お前のことだから、こうさ\nれることも期待していたんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……ちゅっ。れろ……れろぉ……。んふぅ……どうだ……？　さきっぽを\n……舌で……舐めてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「プリップリの亀頭ぉ……れろ、れろぉ……。んれろぉ……。お前の……オチ\nンポ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ……？　んふっ、気持ちよさそうな顔をして……んちゅっ、もっと…\n…いろんなところを責めてやるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅ……ほら……ここはどうだ……？　オチンポの……裏筋ぃ……れろ、れ\nろれろっ、舌先で……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「くすぐるみたいに、舐め……て……。ぴちゃっ、ちゅっ、ちゅぱっ。ふふっ\n、腰が暴れているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「しっかり押さえつけて……逃がさないからなぁ……れろ、れろれろぉ……。\nお前の感じている様子……全部見てやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……ほら……ここは……？　舌を……カリに潜り込ませるように……んれ\nろ、れろぉ……れろ、れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じっくり……れろ、舐めてぇ……責めて……。んじゅるるっ、よだれまみれ\nになっていくオチンポ、味わってやる……んぢゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んれろ、れろぉ……んっ、んれろ、じゅるるぅっ！　はぁ\n、鼻先にぃ……お前の先走りの匂いが漂ってきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ……今度は鈴口だな……。先ほどから、いやらしい匂いの汁をタラリと垂\nらしている……。んれぇ……ろぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、ンッ、ぴちゃっ、ぴちゃっ。オチンポが、さらに激しく震えて…\n…ンッ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここを舌先で舐められるのが、随分と効いているようだな……。んちゅぱっ\n、れろっ、れろれろれろ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「舌先で……穿るように舐められるのがイイのか？　んちゅるっ、ンンッ、先\n走りの味を感じて……私もどうにかなってしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の舌で感じてるお前を見て……はぁ、はぁ……胸がますますドキドキして\n……身体も熱く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んなっ！　奉仕している私の姿がエロすぎて興奮するだと！？　そんな恥ず\nかしいこと、言わなくてもいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたい、こんないやらしいオチンポをしている貴様にも問題があるんだ！\nんっ、んちゅっ、もっと……奉仕してイかせてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んれろっ、れろれろれろぉ……っ！　ほら……この小さな穴……ココがいい\nんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「さっきから、ここを責めるとオチンポがビクついて、ますます先走りを滴ら\nせているからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぱっ、もっと……責めてやるから……。れろれろっ、先走り\nだけじゃなく……精液まで出させてやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅるっ、ちゅるっ、ちゅるるぅっ！　んぁっ、なんだ、もう限界なのか\n？　んちゅっ、なら……いいぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私が……この舌で思いっきり射精させてやるから……んれろぉっ、ほら、ほ\nら……射精……思いっきり射精するがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんぅっ！　あっ、ああ……っ！　んぁっ、い……いっぱい……精液が…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……口に入ったではないか……。ん……コク……。はぁ……お\n前の……精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「濃厚で……匂いもとてもいやらしくて……。はぁ……はぁ……にしてもすご\nい量だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなに大量に射精してしまうほど、私の奉仕が気持ちよかったということ\nだな。まあ、当然のことだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様が相手だから、こんなにはりきって奉仕してしまうのだ……。ふふ、だ\nがこんなものではないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のパーフェクトな奉仕は、貴様を満足させるまで終わらないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら……貴様のオチンポは、まだまだヤる気に満ちているではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなに……胸の間で硬いまま、そそり立って……。んれろぉ……まだまだ\n、イけるんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ……私は……このオチンポに奉仕したくてたまらないんだ……。ん……こ\nの姿になったせい……？　そう……なのだろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、難しいことを考えるのはナシだ。いいからもっとオチンポに奉仕させ\nろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様だって、くだらないおしゃべりで、勃起しているオチンポを放置された\nくはないだろう……？　ん……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁ……ンッ、ちゅっ、ちゅぷ……んれろ、れろれろぉ……んっ、ちゅる\nるぅ……ちゅぱっ、んふぅ……れぇろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「胸で……オチンポをぎゅっとおさえると……んちゅぱっ、精液がむりゅっと\n顔をだすな……ん、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「これも……残らず舐めとってやるから……な……。んれろぉっ、れろ、れろ\nぉん。感謝……するんだぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんな……オチンポ……。んちゅるるっ、隅々まで、舐めるような女は……\nれろ、れろぉ……私しか、いないのだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様と……んちゅぅ、もっと、イチャイチャ……エロエロするぅ……。んち\nゅっ、ちゅぱ……ちゅ、んちゅぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほらぁ……また、オチンポがビクついてきた……。ちゅぱっ、私の奉仕で、\nまたイキそうになっているのだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ……ちゅ、ちゅぷ……先走りも、また……。れろれろっ、たくさん、\n滲み出て……んじゅるるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁ……。本当にいやらしいオチンポだな……貴様のは……。ちゅぱっ、\nいやらしすぎる……エロオチンポ……んっ、ちゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここからまた……さっきみたいな精液を……びゅくびゅくと、射精するんだ\nろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000128_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅる……いいぞ……。好きなだけ……ちゅぱっ、射精して、しまえばい\nい……。んじゅるぅっ、んちゅ、ちゅぱ、ちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｃ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私は……準備できている、から……。貴様のだす……いやらしい汁ぅ……ど\nこでも、受け止めるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2803216" ]},
