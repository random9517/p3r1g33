		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……この夜が来るのをずっと待っていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204101" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今夜一日は、寝かさない……ただひたすらに交わりあう……私の準備はこれ\n以上ないほどに万端だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「貴方の方はどうだ？　んっ……なるほど……何よりも、股間が雄弁に物語っ\nていると……そういう訳だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204103" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……もう、回りくどいことはなしでいい。脱がせてくれ……私も、貴方\nの服を脱がしてしまおう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204104" ]},
		{"command":[ "SETCHARA", "0", "char_00000122_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……邪魔するぞ……ふふ……んっ、重くはないだろう……？　こんな風\nに無防備に背中を預けるのは、貴方だけだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000122_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……もう、オマンコは十分に濡れているとは思うが……念の為、様子を\n確かめさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……ちゅぷっと音がするな……思っていた以上に、ヌル\nヌルになっている……はぁっ、あっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このぬめりを……オチンポにも……塗りつけて……あっ……んっ……熱いの\nが……お尻に当たっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……すごい……ビンビンだ……貴方も、もう待ちきれなくて仕方\nないという訳だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それなら、もう入れてしまって……あ、ど、どうした……？　するんじゃな\nいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「始める時は……エッチにおねだり……そ、それがいい妻の務め……うっ……\nそ、そのように言われては……確かに、そうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「その、では……あ、貴方の……この、太いオチンポを……私のオマンコに入\nれて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もっといやらしく気持ちを込めて……？　き、気持ちは入っているぞっ\n！　くっ……もっと……いやらしく……だなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうか……貴方のビンビンに勃起した、ぶっといオチンポを……私の、いや\nらしい……ぬ、濡れ濡れオマンコにハメて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「発情して、はしたなく涎を垂らしまくった、スケベオマンコを……とびきり\n逞しいガチガチオチンポで……躾けて欲しいんですっ、んぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ……あぁぁぁっ……は、入るぅっ……！　いきなりっ……奥までっ、あ\nひぉぉぉっ、くぅぅぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……こ、こんな……ハメられただけで、んっ……く……イ、イッてし\nまった……はぁ、んふっ、済まぬ……こんな筈では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫だ……私に構わず、動かしていい……貴方のオチンポに気持ちよ\nくなってもらうのが、私の務めなのだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あひっ……！　あぁっ、そうっ、だっ……あぁぉっ、遠慮しな\nいでっ……好きなペースでっ……グリグリっ……かき回してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくあぁぁぁっ！　オマンコッ……全部埋まってるっ……硬いオチンポでっ\n……いっぱいにされてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ……身体……揺らされたらぁっ……はっ、ひっ、あぉっ\n、くぅんっ、ふっ、あぁっ……ひ、響くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぅんっ、あっ、あぁっ……んっ、あぁっ、汁が……後から後からっ……溢\nれてぇっ……止まらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぁっ……オマンコすごいっ……あぁっ、続けてオチンポされてぇっ、気\n持ちっ……あっ、よすぎるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、完全に分からされているっ……貴方のオチンポがっ……隅から隅ま\nでっ……オマンコっ……支配しきっているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くひぁっ！　あぁっ、押し込まれてるのっ……ずりゅって来てっ……あひぃ\nっ、子宮口までっ……ノックしてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、くぅんっ、あぁっ、オマンコいいっ、亀頭でっ……感じるとこっ\n、全部……されてぇっ……また、イ、イキそうになってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、続けてイッてなんてっ……そんなっ、ことっ……あぁっ、で、でも\nっ……はひぁっ、私……ばっかりっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「イキ顔を見たいなんてっ……あぁっ、そんなことぉっ……あひっ、おっぱい\nもぉっ……！　い、一緒にするのはっ、反則だっ……ダメェっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃっ、ま、またイクっ！　んくぁっ、オチンポグリグリされてっ、イク\nのっ、オマンコっ……またイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅっ……！　あ、あぁぁ……ま、またイカされた……身体……ど\nんどんイキやすくなって……んくぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……ま、またオチンポがっ……い、いや、構わない……今の私は、貴\n方のオチンポ妻なのだっ……好きなだけオマンコして欲しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅんっ！　あぁっ、はんっ、あっ、あぁんっ！　おっぱいっ、ぷるぷるっ\n、揺らしてぇっ！　あんっ、あはっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……こんなっ、熱いのが……漏れてくるっ……マン汁のお漏ら\nしが止まらないっ……あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふぁっ、ピストンがどんどん激しくなってっ……これっ、もうす\nぐなのかっ……？　イクんだなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ……欲しいっ……中に出してっ、赤ちゃんが欲しいっ、私と貴方のっ\n……赤ちゃんっ……だからっ、このまま来てっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「イクっ……んぁぁっ、またイクからっ、ビュクビュクっ……出してっ、オマ\nンコの奥に射精してぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁーっ！　熱いのっ……オマンコっ……ビュクビュクっ、\n出てるっ……オチンポ中で震えてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……んんっ、あぁ、イ、イクっ……またイッてるっ、オマンコずっ\nとイキっ放しで止まらないのぉっ……はぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁぁ……子宮が満たされているのを感じる……ザーメンが流れ込\nんで……はぁぁ、着床してしまう……嬉しい……中出し気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ……染み込む……貴方の遺伝子が、私の中で溶け落ちて……\n一つになっていく感覚……とても好きだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……素敵なセックスだった……今も、身体中の細胞が喜んでい\nるのがよく分かる……最高だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……だが……まだ、私のオマンコは満足していないぞ……旦那様\nのオチンポも射精し足りないと、中で訴えかけているからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま続けよう……あっ、んくっ、おぅっ……ふっ、そうだ……今度は私\nも本格的に腰を振らせてもらうからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ……あぉっ……！　はぁっ、うんっ、あっ、はひっ、あっ、ひぃっ……\nんっ、くひぃんっ、あっ、ふぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ……自分から……オマンコを使うのっ……恥ずかしいっ……んぁぉっ\n、くぅっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、あっ、んくっ、あぁっ、この……オマンコの中のザーメンを、かき回\nす音がっ……はぁっ、ゾクゾクしてしまうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「硬い……亀頭を……キュンキュンと締め付けてぇ……んぅっ、踏ん張る度に\n……オチンポと擦れて……ジンジンするぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ、あぁっ……リズミカルに……揺らしてっ、いちっ、にぃっ、\nさんっ、しっ……！　あんっ、はんっ、はひっ、あひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……一緒に合わせてくれているっ……貴方のオチンポがっ……ぐりっ\nて突き上げて……くれてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうっ、そこぉっ、そこがいいんだっ……あぁっ、そこもっ、捨てがたいっ\n……あぁっ、オマンコ……感じるところっ、全部知られてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、しかもっ……どこを突かれるのかっ、全然分からないっ……はひ\nっ！　お、おっぱいもぉっ……ぎゅうってされてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、はぁっ……あぁっ……花嫁姿のスーツでっ……何度もオチン\nポされてっ……あぁ、恥ずかしい姿をお披露目しているみたいなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメ……ダメだっ……こんな恥ずかしいところを見せるのは貴方だけだから\nぁっ……！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコがぱっくりオチンポ咥えてるとこぉっ……！　見せられないからっ\n……あぁっ、こんな恥ずかしい格好で、腰を振ってるなんてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だめっ、あぁっ……気持ちいいっ……！　あぁっ、さっきから……ずっとイ\nッてる感じが続いてるっ……オマンコッ、そこっ、あぁっ、あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだっ、オマンコ気持ちいいっ、オマンコ気持ちいいっ……オチンポグリ\nグリされてっ、オマンコ……ずっと気持ちいいんだぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ……またオチンポが跳ねてるっ……！　私もっ……もうっ、ダメにな\nりそうっ……またっ、すごい波が来てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はひっ、もっと激しくっ……！　あぁっ、ズンズンしてぇっ、下からっ……\n私のオマンコ突き上げまくってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「またイクッ……オマンコイクからっ……！　貴方も出してっ……また、私の\nオマンコでオチンポビュクビュク射精してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、すごいの来るっ……また来てるっ！　あぁっ、このままっ……もう\nイクっ……オマンコイクッ！　気持ちいいのっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぁぁぁぁぁぁっ！　なかぁっ……またっ、熱いのっ……中ぁっ……びゅ\nくびゅくっ……出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はひぃっ、オマンコっ……ずっとイッたままぁっ、子宮が……精液いっぱい\nにされてぇっ……オチンポっ……まだ動いてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……あぁっ、奥……打ち付けてぇ……そう、それぇ……んくぅっ、待\nっててくれ……オマンコ締め付けるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「残さず出してぇ……精液……んっ、根元に残ってる分も搾り出してあげるぅ\n……んっ、ほら……ここを、きゅぅぅぅってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ……！　また出てきた……オマンコの中……新しいのがぴゅるって出\nてくるの……分かってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……ゆっくりと出して……んっ、くぅぅ……そのまま……あっ、それぇ\n……気持ちいいっ……はぅんっ……あっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁ……あぁ……落ち着いた……んっ、はぁ、あぁ……腰を落としたま\nまだと……ずっと硬いのがハマったままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……だが、この状態……悪くない……ふふ……たっぷり出してもらえた\nな……これなら、きっと受精したんじゃないかと思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まぁ、してなかったとしても、するまで続けるだけのことだしな。ふふ……\nそこは覚悟してもらうぞ、旦那様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まだまだ夜は長い……少し一休みしよう。その後は、またたっぷりと……私\nのオマンコを可愛がってくれ……んっ……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あっ……オチンポ抜けてっ……びゅくびゅくっ……身体っ……\n掛かってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ……顔にまで……届いて……んっ、またオマンコもイッてるのにっ…\n…どんどん溢れてっ……頭……追いつかないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……んぱぁっ……あぁ、粘ってる……んちゅぷっ、この味ぃ……はぁ\n、貴方のザーメン、美味しい……ちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、まだ……出せるなら……んっ、オマンコの割れ目で……オチンポを\n擦って……射精の手伝いをしよう……んっふっ……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、出た……びゅくびゅくっ……溢れて……あぁ、そうだ……んっ、もっ\nといっぱい掛けてくれっ……私の身体に染み込ませて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁん……顔も、おっぱいもぉ……背中もぉ……全部……あぁ、貴方のザ\nーメンまみれにさせて……んぁぁ……また、オマンコイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000122_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁぁ……あっ、射精……終わった……？　はぁ……はぁ……んっ\n、出し切ったんだな……ふぁふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……腰がガクガクしてる……ふふ……こんなにも燃え盛る子作りをした\nのは初めてだ……あぁ、まだずっと気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、お腹の中が熱い……受精したのかな……まぁ、してなくても構わない\n。するまで続ける……それだけだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ、少しだけ休もうか。軽く風呂を使って……そこでも、また私のオマン\nコを……可愛がって欲しい……楽しみにしてるぞ、貴方……」", "NORMAL" ]},
