		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「今日は……お世話になりましたね。貴方のおかげで助かりました。お礼と言\nってはなんですが、私も貴方のためにこの身を貸しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「む、早速ですか？　いいでしょう。貴方に仇なすものは誰であれ斬り伏せて\n見せます……って、こっちは貴方の部屋では……きゃあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ムラムラしてるから身体を貸してほしいって、そういう意味では……んんっ\n、あっ、そんな、いきなり胸に……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「もう、こういうやり方は……んっ、ダメですってば……んんっ、あっ、んう\nううっ、こら、話を聞いて……んっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「おっぱいのなかでおちんちん動かしたらダメですって……ふうっ、んんっ、\nもう、こうなったら止まらないんですから……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、そんな強く揉まれたら、痣になっちゃいます……んふうっ、んっ、\n顔が、怖いですよ……んっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「おっぱい揉みながら動かしたら、あんっ、私も……身体が熱く……んんっ、\nまったく、下半身のことしか考えてないんですか……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「分かってるんですからね、戦いの最中も胸とかお尻とかじっと見てるの……\nんんっ、私のような女でも、そんな視線には敏感なんですから、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「見透かされたからって、そんな激しく、あっ、んっ、やあっ、もう、そうや\nってごまかそうとして……ふうっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それとも、言い当てられて興奮しましたか？　おちんちん、さらに硬く熱く\nなってますよ……ふふっ、やっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んっ、うっ、私の身体だって熱くなってるって……それは……んっ、貴方に\n触られれば、こうもなります……んんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「でも、まだ私は怒っていますからね……こんな不意打ち、女性に対して卑怯\nすぎる……んんっ、あうっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「だから話を聞いてください、んんっ、腰を動かしてごまかそうとしたって、\nそうは――ひああっ、あっ、んっ、胸の先端、触ったら！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、うっ、はっ、イってなんかいません、んっ！！　ふううう……んん\nっ、くりくりするの、ダメです……ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんんあっ、乳首触りながら腰動かすのもダメ、あっ、くうっ！！　ダメだ\nしばかりで卑怯って言われても……んっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「そもそも、私の言葉を捉えてこんな風に押し倒した貴方の方が……んんんっ\n、反論できなくなったらおっぱい弄ればいいって思ってるでしょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、ふうううっ！！　顔真っ赤にして言っても説得力ないって、\nだったら動くのを止め……ひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「逆に激しくしたら、んっ、おちんちんが私の胸でこすれて、んっ、ふっ、ん\nんんっ！！　ベトベトしてきてる……ふううっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、この匂い……くうっ、ううっ、おちんちんの先からお汁がでて……\nふうっ、あっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふうううっ、おっぱいにお汁塗りつけないでください……んっ、にゅるにゅ\nるって動いて……谷間で暴れ回って……んくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「本当に嫌なら抵抗すればいいって……そんな、そんなの……貴方がそんなに\n気持ちよさそうな顔をしてるから……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それに、約束は約束ですし……んっ、私なんかの身体に興奮するのは貴方ぐ\nらいしかいませんよ……あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「喋ってる途中に胸を弄らないで……んっ、私の身体は充分エロいって、言い\n方……んんっ、ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「おだてなくてもいいんですよ……ってなんで腰をまた激しく、んっ、んんっ\n、おちんちんが身体にぶつかって、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「エロくなきゃこんなに大きくならないって、貴方は女であれば誰でもいいん\nでしょう、私みたいなのでも……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「じゃあ証拠を見せてやるって……んっ、あっ、んんっ、なんで、急に黙って\n腰を……あっ、まさか、貴方っ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「な、何か言ってください、んんっ、そんな獣のような目で腰だけ動かして、\nひああっ！！　指も動かしたらいいとか、そういう問題じゃ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あうっ！！　おっぱいの中でおちんちんが膨らんで、ふうっ\n、ううっ、するんですね、私の身体で、射精するんですね、あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ど、どうせ私が嫌がってもするんでしょう。だったら、すればいいじゃない\nですか。性欲処理で、私の身体を勝手に使って……んっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ふうっ！！　おちんちんの先端が膨らんで、鈴口がくぱくぱし\nて……んんっ、お汁もねっとりしてきて……あっ、ううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんんっ、あっ、来るっ、精子が来るっ……んっ、ふうっ、あああっ、あっ\n、そんなに胸を強く掴んだら、あああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},	
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んうううううっ！！　精液、来た……っ！！　ふうああっ、あっ、あっ、こ\nんなにいっぱい……ふうっ、ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私のおっぱいが、貴方の精液でべとべとに……んうっ、あっ、まだ、まだ出\nるんですね……あくうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「熱くて……匂いも……これが男の匂い……んんっ、ふうっ、頭が灼けてしま\nいそう……んんっ、くうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「なに……これが、私がエロい証拠って……普通ならこんなに出ないって……\nそんなの……んっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「他の女じゃなくて、私だからこんなに出したって……おちんちん丸出しで口\n説いたって、全然様になってませんよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「お前も気持ちよかっただろって……そんなの……生理的な反応です……んっ\n、身体を弄られれば、誰だってこういう反応に、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「こういう声が出ちゃいます……！！　貴方だって、女の身体であれば誰であ\nってもこういう風に出せるでしょうに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「……なんですか、そんな怖い顔をして、終わったなら、もういいでしょう。\n約束も果たしたんですし、そろそろ離れて……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「えっ、なんでまだおちんちんが大きく……男は一回出したら小さくなるんじ\nゃ……んんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふううっ、ふっ、あっ、意地でも証明してみせるって……そんなこと、した\nってしょうがないでしょう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私が自分の価値を見誤ってるのがムカつくって……なんですかそれ、前々か\nら思っていたけれど、変な男ですね、貴方は……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それはそれとして気持ちよくなりたいって、それが本音でしょう、あんっ、\nあっ、ああっ、ほらまた、反論できなくなったら動いてるっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それも私がエロいからだって、責任転嫁しないで、あっ、んっ、んんっ、お\nっぱいぎゅってしたら、おちんちんがもっと密着してる、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「さっき出した精液がぐちゅぐちゅになって、んっ、おっぱいの中で音が……\nふううっ、それもエロいって、それしか言えないの……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「こういうことをしているときはそれぐらいでいいだなんて……んっ、貴方の\n都合のいいようにしか聞こえないような気がしますが、ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、でもこの匂いと音を感じてると、そう思えてきて……んっ、胸も、\n身体も、熱くなって……ふうううっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「貴方の興奮に私が反応してるからだって、そんな、そんなの……んっ、ふう\nっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、でも、確かにこんな風にされたら、んっ、ちょっと気持ちよ\nくなってきたかも……んっ、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「熱と香りで、頭の中まで貴方の手とおちんちんで満たされて……ふううっ、\nあっ、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「同じように私のことだけを考えてるって、んっ、ふうっ、ふっ……んんっ、\n性欲処理なんかじゃないって、あっ、くううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「このタイミングでそんなことをいうの、反則です……私なんかに……なんの\n価値もない私なんかにそんなこと言うの……ダメ……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「貴方にとって価値はあるって、あっ、ふうっ、本当にダメ……そんな、そん\nなこと言われたら、んんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私、その言葉を信じてしまいます……んっ、貴方にとって、価値のある人間\nだなんて、そう思っちゃいます、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それでいい、それでいいって、んっ、あっ、ダメっ、ダメっ、んんっ、身体\n、頭も、熱くて……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ああああっ、今乳首を触られたらっ、ふああっ、あっ、んんんっ、あっ、イ\nっく、イく、胸だけでイくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「我慢しなくていいって、貴方もイくからって、そういうことじゃ……ふああ\nあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、一緒に、一緒に気持ちよくなろうって本気で……ふああっ、あっ、あ\nっ、んっ、気持ちいいっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「本当に私なんかと……あっ、くううっ、あっ、私なんかで……私だからいい\nって、そう言ってくれるんですね……あんっ、嬉しいっ……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、その言葉だけで、イく、イっく、イくうううううううううう\nうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あふううううっ！！　またおっぱいに精液が……んんんっ、あっ、あうっ、\nふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、こんな、さっき出したのに、同じぐらいの量が……んんっ、ふっ、\n熱い……凄い……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「この量が自分の興奮の証、私の身体が好きだっていう証拠って……んんっ、\n確かに、それは感じましたけど……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、おちんちん擦りつけないで……分かった、分かりましたから……少\nなくとも、私のことを想ってくれていることぐらいは……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「もう、それだけでそんなに嬉しそうな顔をして……んっ、ふふっ、でも、そ\nうですね……こんな風に求められるのは、悪くありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私のような誰かに利用され続けるような女でも、こんな風に求められるなら\n……少しは生きている意味を見いだせます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「え、俺と一緒にいる時点で意味があるって……？　ふふ、本当にもう、貴方\nは……普段はどこか抜けているのに、こんな時だけ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「でも、そうですね。そう思うことにしましょう。そうすれば、少しは日々に\n楽しさがあるのかもしれませんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ただ、今回のようなだまし討ちみたいなやり方で関係を持つのはダメですよ\n。私だって、女なんですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「だから、この先はちゃんとそういう関係になってから……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},	
		{"command":[ "FADEIN", "NORMAL" ]},	
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、なんでおっぱいからおちんちんを抜いて……ふああああっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私の、顔に……精液が、んんんっ、ふうっ、ああっ、凄い、これ、ダメっ、\n鼻が、匂いで、頭がおかしくなっちゃう……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、まだ、まだ出てくる、んっ、頭の中が精液でどろどろになっ\nちゃう、匂いだけで、中まで満たされちゃう……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、あっ……やっと、終わった……んっ、私のおっぱいも、顔も、\n貴方の精液でいっぱい……ふふっ、ここに出したって意味はないのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「意味はないのに、それでもなんだか嬉しく思ってしまいます……んっ、私が\n貴方を気持ちよくできたってしるしだからでしょうか……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「そんな、最後の一滴まで主張しなくても、もう私は貴方のものですよ……さ\nっきの言葉で、もうそう決めましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103406" ]},		
		{"command":[ "SETIMAGE", "0", "still_00027501_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「物好きな人ですね、貴方は……でも、貴方がそう言ってくれるなら、貴方だ\nけがそう言ってくれるのであれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「こんな私だけれど、少しは自分のことを好きになれそうな気がします……ふ\nふっ、こんなぐちょぐちょの顔で言っても説得力ないかも、ですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それにしても、いっぱい出しましたね……いいんですよ。それが気持ちよく\nなってくれた証ですから。ただ、もう少し誘い方を考えてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「だから次は……次の段階は、もっとムードを考えて誘ってくださいね、貴方\n。私だって、女なんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}