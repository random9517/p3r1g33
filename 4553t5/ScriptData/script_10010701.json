{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "地球防衛機構本部、ある日の夕方……。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふぅー……今日はこんなところか。最近は終業時間前に業務が終わることが\nが多いな。少しは敵の動きも緩やかになった、と信じたいが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うん、そう信じよう。信じた信じた！　信じるの大事！　そんじゃま、今日\nもいつもの正義（まさよし）で一杯……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010002" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003"]},
		{"command":[ "SETNAME", "情報課隊員" ]},
		{"command":[ "SETTEXT", "「た、大変です長官！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「って、なんでこのタイミングよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "情報課隊員" ]},
		{"command":[ "SETTEXT", "「え！？　どうしたんですか、長官」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「い、いや、なんでもない。気にするな。それより、何事だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010004" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "情報課隊員" ]},
		{"command":[ "SETTEXT", "「敵襲です！　宇宙港に襲来者（インベーダー）が！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010005" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "情報課隊員" ]},
		{"command":[ "SETTEXT", "「警備部隊が応戦しているようですが、このままでは持たない、すぐに応援を\n、とのことです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「わかった、すぐに手配する！　引き続き、情報の収集を続けてくれ、なにか\nわかったらすぐに知らせるんだ、いいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010006" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "情報課隊員" ]},
		{"command":[ "SETTEXT", "「了解！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……というわけだ！　総員、ただちに出動準備を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010007" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　ちょっと待ってください！　俺はつい５分前に、他の任務から戻っ\nてきたところですけど！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "帰って、お湯を沸かすのに２分！　カップにそそぐのに３０秒！　そして待つ\nこと２分３０秒！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あと３０秒で、ようやく晩飯にありつけるところだったんだぞ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまけに俺、昨日は徹夜で見張りをやらされてたんですよ！？　その前は、\nいきなり休日出勤！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ええい、うるさい！　文句を言うな！　私だってこれから飲みに行こうと…\n…げふんげふん、重要任務を中断してここに来たんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010008" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「その重要任務とやらについては聞かないでおきますが、仕事中には冷静沈着\nな長官が、ここまで慌てているということは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「容易ならぬ事態、と考えていいのだな？　襲われたのは、よほど重要な施設\nなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。現在襲撃を受けているのはＥＤＯの『宇宙港』だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010009" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「宇宙港か……それはまずいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うちゅう……こう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……地上から偵察衛星を打ち上げたり、物資を宇宙ステーションに輸送した\nりして、維持する重要な場所ですよ。姫様」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！　う、うるさい！　それくらい私も知っている！　偵察衛星な！　宇宙\nステーションな！　知ってる！　知ってるぞ！　疑うつもりか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いえ、別にそういうつもりはないですけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だったら言うな！　宇宙港か！　宇宙港だな！？　ああ、知ってるとも！　\nルナ、おぼえた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107010003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いま、「覚えた」って言ったか。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「諸君も知っての通り、宇宙港は我々ＥＤＯの重要拠点だ。ここを失えば、情\n報収集や警戒に重大な支障が出る。なんとしてでも守って欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010010" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「承知した。カツマ、いいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……せめて、ラーメン食ってからじゃダメすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「食べるなら移動中にしてくれ！　すでに第４ゲートに車を回してある！　総\n員、戦闘装備と座布団をもって直ちに出撃！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010011" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「座布団……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「緊急事態のため、用意できる車が廃車寸前の１台しかなくてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010012" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「緊急時だってのに、オンボロの車ねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、うんざりよ……外車とまでは言わなくても、せめてもうち\nょっとお高い車でお迎えしてほしいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「大丈夫！　乗り心地は悪いがまだ走る！　さあ、行った行った！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010107010013" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うううううう……とんでもねえブラック組織だ……やっぱり隊長なんか引き\n受けるんじゃなかった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}