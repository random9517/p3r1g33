{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出して……どうしたんですか？　もしかしてー、わたし\nにえっちなことして欲しかった、とか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「え？　正解？　あら、ずいぶん正直ですね。でも、そういうの嫌いじゃない\nですよ。うぅん、むしろ大好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だってー、男から求められると、自分が女だって感じられるでしょ？　うふ\nふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それで……わたしはどうすればいいのかしら？　フェラ？　パイズリ？　そ\nれともいきなりハメちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「まずは口とおっぱいでご奉仕……ね。いいわ……任せて。いっぱい気持ちよ\nくしてあげますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「じゃあ、脱がしますね……よいしょっと。……うふふ。相変わらずおっきー\n……えー、なにがって……チンポです。あなたのチ・ン・ポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018202_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「もうー、意地悪ですね。わざわざ言わせるなんて。わたしだって恥ずかしい\nですよー、チンポなんて言うの……本当です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「当たり前じゃないですか。夫の前じゃ絶対に言いませんよ。あなたは……う\nーん、特別です。てことで……早速ご奉仕、始めちゃいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「この……Hカップの爆乳で、ガチガチのバキバキになったチンポを……ムニ\nって……んんっ、ふっ、うぅん……どう、ですかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ……ん……熱い、チンポ……熱ぅい、し……とっても硬い……やっぱり\n若い子のチンポって素敵ですね……あぁん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいに挟んでるだけで……わたしも、興奮してきちゃう……はぁ、あっ\n……あんっ……あぁ、淫乱だなんてぇ……言わないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そういうあなただって……外なのに、こんなチンポ勃起させてぇ……んぅん\nっ、んっ……変態じゃないですかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「えー？　それは……そうですね。ふにゃチンよりは……どこでも勃起させち\nゃう男の人の方が好みですけどぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「やだ。変なこと言わせないでください。ご奉仕に集中、できないですから…\n…んっ……んっ、んっ……は、んぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わかってます、ちゃんと口でも……ご奉仕しますから……焦らないでくださ\nい……んふっ、ふうっ……ちょっと待ってくださいねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あんっ、先っぽもパンパンに腫れてて……カリが膨らんで、本当に男らしい\nチンポ……スンスン……えっちな匂いもすごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「我慢汁がトロトロ溢れてて……おっぱいも濡れちゃって……んー、あぁ……\nれろっ……んちゅっ……ちゅ、ちゅく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「うふふ……舐めた瞬間に、ビクビク震えちゃって、かわいい……先っぽ弱い\nですもんねー、ほら……ぺろぺろ……んー、ちゅぱちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いいじゃないですか、これくらい……んちゅ……ちゅく、んぷっ……れろ、\nれろ……ぴちゅ、んっちゅ……くちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「チロ、チロぉ……んっ、だめ、です……まだ舐めるだけ……ちゅっ、んれろ\nっ……いっぱい焦らした方が、気持ちよくなれますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ほら、気持ちいいでしょう？　竿をおっぱいでむにむにってされながらぁ…\n…先っぽ舐められるの……んぢゅ、れろれろっ……ちゅっぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「うふっ……チンポが嬉しいって言ってるみたい……もっともっと気持ちよく\nしてあげますね～……んっ、しょ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいをグイグイ～って……押しつけて……ぐい、ぐいってぇ……んっ、\nんふぅ……チンポを、挟んで……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あは、またおっぱいの中で……チンポが跳ねてます……気持ちいいんですね\nー、かわいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、素直でかわいいチンポには……ちゅーもしてあげますね……んー、ち\nゅっ……ちゅぷ、ちゅ、ちゅく……ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……どうしましたー？　そんな切なそうな声、出しちゃってぇ……イキそう\nなんですか？　れろ、れろれろっ……ぴちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いいですよー、いつでも、出して……ください……んっ……ちゃんと口で受\nけ止めますから……んっ、ぷっ……ちゅぷっ、ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふっ、我慢しないでください。それだけ……わたしのご奉仕が気持ちよか\nったってことですよね？　全然情けなくないですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、あんっ……はっ、あはぁ……ちゅぱ、ちゅぱ……れろ、れるっ……先\nっぽも、舐めてあげますから……ほら、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっんっ……！　んふぅ……！　いいですよ、いっぱいおっぱい揺らして…\n…チンポをいいこいいこって……してあげます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はあっ、あっあふっ……あんっ……！　ちゅぶっ、ちゅくっ、ちゅううっ…\n…んちゅっ、ちゅぶっ……くちゅ、くちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「らしてぇ……いっふぁい……くち、にぃ……んっんぶっ……ふぅ、んぶっ…\n…んちゅ、ちゅ、ちゅぷっ……んふぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はあっ、あぶっ……！　ちゅる、ちゅくぅっ……く、ください……若いザー\nメン……れろれろっ……いっぱい、出してぇ……んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ンっ！？　……んぶっ！　んぅぅぅ～～～～っ……ん、んくっ……すご、い\n……くっ、んぅんっ、いっぱい……でて、るぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁはぁ……んっ……さすが、若いだけあって量も多いし……濃いわ\nね……喉に絡みついてくる……ンくっ……ぷはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぅ……こんなに出してもらえると、わたしも嬉しいです……ふふっ……じ\nゃあ、あとはどうしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「一応、外だから聞いてみただけです。あなたが一回射精したくらいで、満足\nしないことくらい知ってますよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はいはい。もちろんです。ちゃーんと……このおっぱいで、たっぷり搾り取\nってあげますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「口も？　ええ、今度は先っぽを咥えて……じゅぽじゅぽ吸ってあげますから\n……あぁんっ、チンポ押しつけてこないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「すぐに、ご奉仕してあげますから……んっ……わたしのフェラとパイズリ…\n…いっぱい楽しんでくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁ……はぁ、はぁ……んふっ……出したばかりなのに、こんなにギ\nンギンに勃起して、反り返って……本当に素敵なチンポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ええ、夫のなんかとは比べ物にならないです。それどころか、今まで見たチ\nンポの中でも、一番かも……本当ですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だって……んっ、あっ……こんな絶倫チンポ、今まで見たこと……ない、で\nすし……はっ……ふぅ、んっ、んぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「たくましくって、男らしくって……んっぷっ……れろ、れろれろっ……もっ\nとおしゃぶりしたくなっちゃう……はぁむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぷ、ちゅ……ちゅくっ……ザーメンの味、して……さっきより苦い、けど\n、おいひぃ……ちゅぷ、ぴちゅ、ちゅるちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、ぷぅ、んぷっ……わかってますって……先っぽ、咥えてあげますから\n……んぶっ……じゅぷっ、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あふぅ……んぶっ……れろっ、んちゅっ……はぁ、あぁ……チン\nポ……ますます硬く、なって……んふっ、んぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それに、大きい……んっ、ぐぷっ……ちゅっれるっ……咥えてると、顎が疲\nれてきちゃう……けど、おしゃぶり止まらない……んぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はあ、あんっ……またいっぱい射精して欲しいから……ぺろぺろっ……んっ\n、んっ……口とおっぱいで、チンポ……じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいも、こうやって……交互に擦りつけて……んんっ、んっ！　ふっ、\nうぅっ……はっあっ……んぷ、ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっはぁっ……また、我慢汁、溢れてきてますけど……どうですか？　出ち\nゃいそうですかぁ……？　んっ、んぅんっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁん、たくましい……さっき出したのに、もう出そうなんて……本当に素\n敵なチンポぉ……んっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅぱっ……れろっ……おい、ひぃ……んぢゅ、ぢゅぷっ……チンポ\n、とっても美味しいっ……んぷ、ちゅぷぷぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい、お口でも……顔でも……好きなところに、出して……んんっ……くだ\nさいっ……はぁ、はっはあっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「もっと強く、ですか？　んふぅ……はい、おっぱい、ぎゅーって……しなが\nら、亀頭舐めまくって……あげます、ね……んっ、んちゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁあっ……！　あふっ、んぶっ……ちゅくっ、ちゅぷっ……んふっ、んぶ\nぅっ……！　れろっ、くちゅっ、ちゅぱっ……んぶぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だし、てぇっ……んっ！　出してぇ、いっぱいザーメン……出してぇっ……\nんっんっ、はっ、あっ……あんっ、んふぅっ！　はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、あふっ……あの、こくって、熱いザーメン……いっぱい、欲しい……ん\nっ、んぶぶっ……ぢゅっ、ぢゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、はんっ！　あんっ！　あっ、ふうっ……んちゅ、ちゅるるっ……は、\nはやく……んふぅっ……らしてぇ……んっんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぶっ！　んっ、んぶっ……！　ぢゅっ、ぢゅぽっ、ぢゅるるっ\n……！　んっんむっ……じゅぶぅぅぅぅうっぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んぷっ！　んぶっ、ンンぅぅっ！！　んっ、んぅ……んん～～～！　\nんっんっ……んぐっうんぅぅぅぅぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、ぷっ……のど、おく……んぐっ……でて、るぅ……んくっ、ちゅっち\nゅぷっ……んぶっ……コクッ、んぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……はぁぁ……熱い、ザーメン熱くって……喉、焼けちゃいそう……はぁ、\nはっんっ……んぐっ……ゴクゴクっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はあはあっ……んっ、ちゅるっ……ちゅるるっ……ふぅ、全部……飲みまし\nたよ……もちろん、あなたのザーメンですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「匂いはキツくて、味も濃くって……こんなの飲んだら、絶対に発情しちゃい\nます……オマンコがぐちょぐちょになっちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だってぇ……欲しくてたまらないんです……このチンポぉ……これでわたし\nのオマンコかきまわしてぇ……ねえ、お願いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい、欲しいです……あなたのチンポ……わたしのオマンコにぃ……このぶ\nっとくて硬くて、絶倫の若いオスチンポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「えぇ……？　おしゃぶり……？　もちろんおしゃぶりもしたいですけど……\nあぁん、迷っちゃう……全部、このチンポ全部好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そう、ですね……外でこれ以上は……じゃあ、どこか人気のないところに行\nきましょう？　そこで……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「当たり前です。わたし、全然満足してないんですから。欲求不満の人妻を甘\nく見ないでくださいね？　うふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……ぷはっ！　きゃっ……んっ！　んんっ……！　ん～～～っ\n、んっあっ……んぅぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁふうっ！　すご……んっぶっ……いっぱい、でて……んんっ、はぁあ…\n…はぁあぁぁっ……あつ、い……ひゃんっ……あ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……あぁん、すごい量……顔に、かかって……ンンっ！　あんっ……ザーメ\nンでドロドロになっちゃう……はぁ……あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「やーん……さっきより、全然多い……んはぁ……ザーメンパックされちゃっ\nた……おかげで、匂いもすごくて……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ここ外なんだから、顔にかけられると後片づけが大変なんですよ……んっ…\n…匂いも残っちゃいますしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んもぉ、そんな聞き方ずるいです……興奮したに決まってるじゃないですか\nー……これだけ大量の精液ぶっかけられてぇ……はぁ、あぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ぺろっ……んっ、んぷっ……はぁ～～……美味しい……この生ぐさくて、ド\nロドロのザーメン……本当に美味しいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00018202_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……あんっ！　ほらぁ、チンポももっと射精したいって……おっぱいの中で\nビクビクいってますよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい、もちろんです。あなたが満足するまで……うぅん、わたしが満足する\nまで搾り取ってあげますから……うふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「口でもおっぱいでも……オマンコでも、好きなだけ使っていいですから～…\n…いっぱい射精してくださいね」", "NORMAL" ]},
