{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつら、また暴れて……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「カツマ先生？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113590001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「が、学園長……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0127" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "特訓を見守っていたら、学園長室へ連れていかれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「まったく、元気が有り余っている様子ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113590002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あはは、まったくです……本当に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "窓の外を見ると、ルルーナの特訓はまだ続いているようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "腰にタイヤを括りつけて兎跳びとか、いつの時代の特訓なんだか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それでは、エキシビジョンマッチについてですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113590003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園長の用事は、当日の打ち合わせだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うちのクラスがめちゃくちゃな試合をするだろうという予想をしているらしく\n生徒の安全をどう確保するかとか、万が一のときの避難経路の確認をした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ここまでする必要はないとは……まあ、言い切れないな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「では、確認は以上です。カツマ先生」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113590004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでしょうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「くれぐれも、一般の生徒に迷惑をかけないように。よろしくお願いしますね\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113590005" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ、わかってますって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひぃ～っ、圧力が凄いっ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、それでは失礼します！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0159" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……とは言ったものの、なぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "勢いで返事をしてしまったが、実際どうすればいいものか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっきだって、校庭で堂々と暴れ始めたような奴らを、押さえろと言われても\nなあ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやー、教師とは大変ですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113590001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大変がってないでお前も少しは考えろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それを考えるのは教師の仕事。犬の仕事ではありませんゆえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113590002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当につかえねーなーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、頭を抱えて歩いていた時だ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "廊下にとんでもない恰好をしている人がいる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「お悩みのようですね。迷える子羊さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いたる部分に牛のモチーフが……そういえばこの学園には牛神様が出るって話\nを聞いたことがあったな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「教育のことでお悩みですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかりますか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私は神ですから。お見通しですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さすが神様だ。でも待ってほしい。ここは学園、教育の悩みを持たない教師は\nいないんじゃないか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふふふ、教育に悩む若い教師にアドバイスをするのが、私の役目なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ちょっと胡散臭いが、神様ってのは本当だろうし、ここは相談に乗ってもらう\nか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、俺の悩みを聞いてくれるか？　相談したいことがあるんだ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ええ、もちろんです。あなたの抱える悩みの解消に協力しますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「とりあえず、学食でお茶でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「……かくかくしかじか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふんふんはぁんはぁん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学食に移動して、ルルーナの暴走をどう止めればいいか悩んでいるという話を\nした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113590001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこへ夜日楽が飛び込んできた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うわ、全身泥だらけじゃねーか。誰がこんな……って、ルルーナか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「カツマ先生ぇっ！　助けてくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113590002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、まてまて。どうしたんだよ、まあ、大体予想はつくけどさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜日楽が言うには、ルルーナのあまりにも無茶な「特訓」に耐えられなくなっ\nてしまったようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ルルーナさん、お姉ちゃんより怖いんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113590003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すっかり怯えている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「カツマ先生、ルルーナさんの特訓をやめさせてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113590004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうは言っても、球技大会に向けての特訓って言うなら口出ししにくいな…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お待ちなさい。部活動において熱心な指導や練習は美化されがちですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590008" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「特訓に名を借りたしごき、かわいがりはいじめと見做されかねませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「むぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「当事者は愛の鞭のつもりでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、あの鞭は茨すぎます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113590006" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「……と、このように受け取っている以上、いじめとして対策すべきでしょう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590011" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そして、教育現場においていじめを止められるのは、教師であるあなたです\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺は副担任だし、警備員だし、隊長職が本業なんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あなたも、見て見ぬふりをして、保身に走るサラリーマン教師に成り下がり\nますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「むぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "牛神様の言うこともわかる。それに、いくら勝利のためとはいえ仲間を怯えさ\nせるルルーナを放っておけない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「身体を張って学生を守る教員こそが、教育現場でのあるべき姿。そう、それ\nこそが……愛」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「愛……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113590015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "愛かー。愛ならしょうがないかー。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと、ルルーナと話してみるか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}