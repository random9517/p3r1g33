		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「おかえりなさい。どうでした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114680001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマは！？　無事なんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、無事だ。憎ったらしいほど無事だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「釈放してもらえるんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114680001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、そのことなんだが実は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
