		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「当然です！　カツマさんを救うチャンスですよ！？　みすみす逃す手はあり\nません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114680002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いいんじゃな～い？　無茶ぶりは、長官ちゃんで慣れてるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
