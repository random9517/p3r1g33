		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「条件次第ではカツマを解放してもいい、だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114680004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうかそうか！　それはよかった！　これでやっと書類から解放され――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、待て。その条件とやらを聞こうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114680006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい。我々次元管理統制局は、インクレディブル・スクワッドの能力を高く\n評価しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、当然だな。高いからな、能力」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114680007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そこで皆さんに、我々からの依頼を受けていただきたいのです。もし、受け\nていただけるのなら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

