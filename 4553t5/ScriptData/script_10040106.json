		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、あれぇ！？」", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "慌てて普通科の教室に飛び込んでみると、そこはもう空っぽ。生徒たちはとっ\nくに避難してしまったようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ、あいつらずいぶん素早いな……それじゃ地球防衛科の方は？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こらぁ～っ！　下僕ーっ！　さっさと校庭にこーいっ！」", "NORMAL" ]},
