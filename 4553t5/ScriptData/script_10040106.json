		{"command":[ "SETTEXT", "そんなわけで翌日。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さーて、そろそろチャイムもなるし教室に行きますか……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と思ったら突然、校内放送でサイレンと学園長の声が鳴り響く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「特別授業です。地球防衛科の生徒と教職員は、ただちに校庭に集合してくだ\nさい。繰り返します。特別授業です。地球防衛科の――」", "NORMAL" ]},
