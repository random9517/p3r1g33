{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「にゃにゃにゃ～♪　隊長？　今日もお仕事おっつかれさまぁ♪　お疲れなの\nに、呼び出したら来てくれて……めちゃくちゃ嬉しかったよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ……？　何の用かって？　ま、当然気になるのはソコだよね～。つって\nもバステトおねーさんは、君に危害を加えたりはしないから安心して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あのね～。最近お疲れのきみに、ご奉仕がしたいんだぁ。ご奉仕♪　え？　\nギャグじゃないし罠でもないよ！　ほれほれ～リラックスしてして～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「はい、ベッドにドサーッ♪　ふっかふっかで嬉しいねぇ～♪　で・も♪　こ\nこにはもーっと柔らかいフカフカがありま～す♪　答えはなんでしょーか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……はい♪　正解は～おっぱい！　エジプトおねーさんの生おっぱいでした\nぁ♪　んふふふ、あったかくって～、モニュモニュで気持ちいいでしょ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「この国の男を癒すには生おっぱい一択ぅって誰かがどっかで言ってたの！　\nだからねぇ、きみは王様みたいにそこにゆったり座っててくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「うんうん、おねーさんに任せて。いい子にじーっとしててくれたら～。この\nまま、きみの期待してるココ……おちんちんを癒してさしあげよう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「っん……♪　んふふふ♪　へ～え……いきなり襲われてぇ、ベッドに押し倒\nされて、おちんちんをおっぱいで生挟みにされてるのに、動じないねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「もしかして経験豊富ぅ？　……あっは♪　おねーさんとは正反対、だねぇ…\n…。うん、そーなの。こういうことって初めて……。っあははっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「すっごい刺激的……。っていうかまず、おちんちんをこんな風に顔の真ん前\nで見ることないよね。しかも、むぎゅーって挟んでさあ。自分の胸で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ♪　今の私ぃ、ちょっと痴女だもん♪　いきなり男の人襲って\nぇ、おちんちん癒したい～、ご奉仕したい～って突然パイズリして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……でも。そうしてあげた～いって思っちゃうくらい……。最近のきみは超\nお疲れモードだったんだよ？　自覚ないでしょ。ホント疲れてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「だから～、今だけは無礼講ってことで、生おっぱい楽しんでほしいな～♪　\n……って、むふ～♪　おちんちんが先にハーイってお返事してくれた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「そうかそうか、おちんちんちゃん、きみはおねーさんに甘やかされてイチャ\nイチャぱふぱふしたいんだねぇ♪　ん～、カワイイカワイイっ。そんじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んむぅ～っ♪　これはどう～！？　ん♪　おっぱいの中に、完全におちんち\nん埋めちゃうの♪　私の体温がもーっと激しく伝わってくるよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「この状態でね？　おっぱい……動かすとスゴいらしいんだよ♪　だからぁ、\n今日はいっぱいご奉仕させてね♪　そう、おっぱい全体使っちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「いくよ……。っふ……♪　ふぅうっ……♪　んふ～……♪　ふんん♪　はぁ\nっ、はぁ……んんんっ、ん～♪　い、イイ感じぃ……♪　ん～っ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「きみのおちんちんって平均的なサイズ……ではないよねぇ？　あのさぁ、ち\nょっと胸を動かすだけで……んぁっ、暴れてハミ出してくるのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「すっごく長くて硬い……♪　あはっ、コレ……普通はエッチなことする時に\n使うやつなのに、私のおっぱいより長いとかありえないでしょ、危険～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んんっ……♪　砂漠によくいる大蛇、みたい……♪　なんだっけ、アナコン\nダ……？　あっ♪　太さも硬さもそんな感じかも、エジプト～♪　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「となればエジプトの女神様である私が責任をもってご奉仕してあげなきゃだ\nよね～♪　んっ……、どう？　きみは私のおっぱいで……いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ふふふっ……。まーたおちんちんがビクビク～ってお返事してる♪　口で言\nってほしいけど……まあいっかぁ♪　んっ、強さもこんなものでい～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「もっとねっちり、おっぱいのお肉をおちんちんに巻きつけたほうがいいかな\n～♪　……あっ♪　ご、ごめん、あんまり密着すると……私の方が、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと感じる……かも。んんんっ、なんか急に恥ずかしくなってき\nたぞ……♪　……あ！　だ、だいじょうぶ、しっかり続けるしぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んんんっ……んんっ、んんん……♪　あははは、根元から先端に、ぎゅむぅ\nうう～って絞り上げられるのが好きぃ？　じゃあ、大きめの動きでぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おっぱい上下運動いきま～す♪　んんっ、いっち、に♪　いっち、に♪　お\nっぱいで♪　ラブラブご奉仕♪　女神の♪　お役目♪　パイズリぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んふ……♪　谷間の中で、おちんちん喜んでくれてる～♪　嬉しいな、もっ\nと攻めちゃお～♪　もいっかい♪　いっち、に、いっち、に、……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　カチカチのおちんちんでおっぱいの中、こすれると……汗かいち\nゃうなぁ♪　はぁっ……んんっ、やだ♪　力強い、押し戻してくる～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おねーさんのおっぱいだって負けないぞぉ♪　そりゃぁあ♪　むぎゅっ、む\nぎゅううっ♪　たぷたぷたぷ♪　ずりずりずり♪　んふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おちんちん……だんだん愛おしくなってきてるぅ♪　愛着わくなぁ♪　よー\nしよしよし、おねーさんのおっぱいと仲良くしようね……♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「お返事上手だね、かわいいね……♪　ずりゅずりゅこすられて気持ちいいね\n……♪　おねーさんのおっぱいも気持ち、いいよ……もっとしよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ♪　んんっ、んん……んっんっ……♪　ふぇ？　このままおっぱいの中\nに出したい？　え～？　ベトベトになっちゃうよぉ……どうしても～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……なんちゃって♪　どーしてもならいいよぉ♪　だって、最後まで面倒み\nるからご奉仕なんだしぃ……。いっぱいいっぱい中に出しちゃえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ね……♪　おねーさん、きみがおっぱいの中に精液出すところ見たいなぁ♪\n　……んっ♪　きみのペースで……私の胸に出しちゃおうかぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「精液♪　精液っ♪　ちょーうだい♪　おねーさんのお胸に出して♪　ぴゅっ\nぴゅして♪　いくよぉ？　さーん、にーい、いーち♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ひぁああっ♪　あッ！？　こ、こういう勢い！？　きゃっ♪　お、思ってた\nのより１０倍くらい多いっ……あっあっあっ受け止められるかなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ……！　あああああっ！　そんなにぃ！？　バステトおねーさんのおっ\nぱいの谷間に、真っ白なナイル川ができちゃうよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「やぁんっ♪　まだ出てるぅ♪　びゅるっ、ぶびゅるるるって……♪　え～～\n～～♪　すごいぃ、きみの精液ってこんなにすごいのぉ、びっくり～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「うん、うんうん♪　そこらじゅうに飛び散っちゃってもいいから……スッキ\nリするまで出そうっ♪　わぁ……♪　ああああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「きみのヌルヌル……♪　赤ちゃんの種が私の胸にこんなに……っ。これって\n、もしかしてご奉仕大成功ってやつじゃない！？　うれしい～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あは……♪　谷間の中でにゅるにゅるしてる……。精液って、私の体温より\nずーっと熱いんだね……♪　すんすんすん、不思議な匂い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「少しだけ磯臭いっていうか……私の好きなお魚の匂いに似てるかも～♪　え\n？　味も苦いんでしょ？　なんか、海産物って感じだね～。違うかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……えへ……♪　もぉ♪　バステトおねーさんのおっぱいでさぁ～♪　たっ\nぷり出しちゃってさ～♪　もうこれおっぱい大好きな証拠じゃぁん～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ねえねえ、私のおっぱい良かった？　満足できた？　……そうなんだぁ～♪\n　でも、なんでまだおちんちんが元気なのかな～？　うりうりうり♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「もしかして……このまま、もう一回してほしかったりするぅ？　……あー、\n照れてる。きみが答えてくれないならいいよぉ～だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おちんちんに直接聞いちゃう♪　ねー、もっともっとおっぱいでもみくちゃ\nにしてほしーよねー♪　バステトおねーさんのおっぱい好きだよねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……と、いうことで再開ぃ～♪　んふふっ、人の話を聞いてないって思うか\nもしれないけど～。こういう時くらい、いいでしょ？　はじめるよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ん～っ♪　んん～っ♪　……んっふ……♪　んん～っ……♪　あ、気付いた\n？　今回は、大きく縦におっぱいを動かしてみてるんだ。それからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「めいっぱい上に伸ばして～、たぷんっ！　っておっぱい落とすのとか～♪　\nぐにゅぐにゅぐにゅ～っておちんちんに合わせて波打たせるとか～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「回転っ♪　させたりぃ……小刻みに左右からパフパフしたり♪　色々テクニ\nカルにやってみるよぉ。んっ、んっ、私が今何をしてるか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おちんちんだけで把握してみて？　ッんっ♪　んっんっんっ♪　んん～～～\n～～っ♪　んんっ♪　んんんぅ♪　んんっ、んんんぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「はぇっ！？　あんまり遊ぶなぁ！？　えぇ～、本気で新しいテクニックを披\n露しようと思ってたんだけど……そっか。フツーが一番いいかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「バステトおねーさんの爆乳におちんちん丸ごと包まれて～♪　おっぱいのあ\nったかさでホカホカにされちゃって……おもいっきり上下にしごかれるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あっ♪　これっ、ね？　この上下の、動きぃ……♪　おっぱいの内側で、お\nちんちんがこすれるからぁ……形がすっごくわかる、の……。んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「だから興奮しちゃって、ご奉仕に集中できないかな～って思ってた、んだけ\nど♪　そこは……んぅ♪　愛の力でなんとかしなきゃね、……んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ふふふふふ♪　おねーさんのおっぱいで、トロットロになってるお顔可愛い\nよ……。精液でヌルヌルのおっぱいで力いっぱいしごいてあげるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「えいっ♪　えい……♪　ぐにぐにぐにぃ♪　ヌルヌルヌルぅ♪　にゅるにゅ\nるにゅるっ、ヌルヌルヌル～♪　んっ♪　んっ、んっんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あれぇ？　おちんちん、膨らんできたね……♪　このやり方が一番気持ちい\nいんだ……♪　はいはい♪　そのまま……力を抜いてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ♪　んっ、出せそうだったらもう一度出してみよっかぁ♪　おねーさん\nのおっぱいは、今……きみだけのおっぱいなんだから、遠慮しないで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ほら♪　ほら、出ちゃうの？　精液出ちゃう？　さっき出したばっかりなの\nにぃ……また出ちゃう？　おいで……♪　出すのはここだよぉ♪　はい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ふぁっ♪　あっあぁんっ！　溢れ出しちゃうっ……ああっ♪　溺れちゃいそ\nうなくらい出てるぅ……かっこいいよぉお～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あははっ♪　びゅぅっ、びゅぶぶって音まで聞こえるぅ……♪　\nあっ、そうだよね、私がおっぱいで押し潰してるから……ごめんねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「でも、ぴゅっぴゅして欲しかったのは本当だから……責任とって最後まで絞\nり取ってあげよう♪　ん～～～っ♪　あはっ、出る出る、すっごいねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あっ……♪　二回目だから、やっぱりこぼれちゃう……。気持ちいい……♪\n　あったかいのがトロトロ～っておっぱいをつたいおちて……んぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「なん、だか私がおっぱいミルク出しちゃったみたいで恥ずかしくなってきた\nぁ……♪　あっ♪　あっ、だめ……♪　こぼしたくないのにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「量が多くて……。あっ♪　私のおっぱい、もうぜーんぶ、どこもかしこもき\nみの精液でマーキングされちゃったぁ……♪　しあわせすぎ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……ん……♪　うひゃぁ～♪　無限の泉みたいに、ばんっばん精液が湧き出\nしてきてびっくりしちゃった～。きみって意外とタフなんだねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ここまで盛大に出してくれるとさ？　バステトおねーさんもぉ、ご奉仕のし\nがいがあったってもんよ♪　うん、そりゃあ反応は大きい方が嬉しいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「私が君の役に立てたんだ～、喜んでもらえたんだ～って思うと、それがね。\n最高に気持ちいいの。だから……、今回は１００億点満点だな～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……きみにもっと、もーっとご奉仕してあげたいなぁ。だからね？　疲れた\nら、すぐにおねーさんを呼んで？　あの手この手で癒しちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ひんんっ！？　わっ、待って待って！　おちんちんが暴れて……ひゃあっ♪\n　か、顔にかかってるっ、んぁっ！？　待ってぇ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んうっ……んん、息できない……！　あっ、口の中に入っちゃう……んんっ\n♪　そんなに出さないでぇ♪　あっ♪　あっ、飛距離すごいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、おっぱいだけじゃなくておねーさんの顔にもかけちゃうんだ\n……♪　大胆だね、きみってホントやりたい放題なんだからぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「でも、うれしいっ……。私のおっぱいで気持ち良くなって、顔に精液飛んじ\nゃうくらい感じてくれたなんて……あっあっ、嬉しい、嬉しいよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「これってさぁ♪　きみの国ではマーキングっていうやつでしょぉ♪　好きな\n相手に自分の体液っ、塗りつけて……自分のものって印をつけるのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「だとしたらこのおっぱいも、私も、私の顔も……ぜーんぶきみのモノになっ\nちゃったね♪　あつあつの精液で印つけてくれて……感謝だよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ふぁああ……♪　きみってたまーに、バステトおねーさんの想像の上を行く\nっていうか、斜め上っていうか～……完全に油断しちゃってたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「どれだけおっぱいでぎゅーって止めても、その上で顔に精液かけてくるんだ\nもん……。驚きまくりだったけど……うん、刺激的でも……あったかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「君の新しい一面を見られたっていうか、見せつけられたっていうか。んふふ\nふ、おねーさん……そういう強引なのもキライじゃないからさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「これからも、色んなご奉仕させてもらってぇ、色んなきみを知りたいなあ～\n♪　きみくらい面白い人って、どこの国にもなかなかいないんだもん♪」", "NORMAL" ]},
