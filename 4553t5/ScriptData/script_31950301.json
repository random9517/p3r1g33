{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「トリック・オア・トリ～トぉ～♪　うふふふふふっ♪　わたしのことぉ……\n待っていたでしょう？　だ～って今日はハロウィンの夜……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「な・の・に・お菓子を持っていない、わる～いオトナがいるみたいだけど…\n…？　あら？　あらあら？　これってもしかして誘惑のサインかしらぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お菓子を持っていないなら……トリックを。イタズラを受けるってことでい\nいのよね？　それなら遠慮なくぅ……♪　いただきまぁ～す♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「は～い、ぱふぱふぅ～♪　わたしのトリックは～。ちょ～っと過激だよぉ？\n　なんと！　あなたがだ～いすきなパイズリ～♪　ふふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「期待してた？　してたよねぇ～？　だからお菓子を持ってなかったんだ～♪\n　わたし、そういうズル～くてイケないわる～いオトナってだ～いすき♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ。だけど、あなたってば特別におっきくてカタ～いキャンディ♪　ここ\nに隠し持っているみたい……。ねえ？　ねえ？　これって何かしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303106" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたし、清純派で清楚だからぜんぜんわかんなぁい……♪　今、わたしのお\nっぱいの谷間でぇ、ガチガチに勃起してるこれ……なんていうお菓子かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん？　ん？　なぁに？　声がちっちゃくってきこえな～い。おちんちん～？\n　お・ち・ん・ぽ？　へ～ぇ、この立派なのはおちんぽって名前なのね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ジューシーそうでとーっても美味しそう……♪　先っちょのちっちゃな穴か\nらぁ、肉汁がもう染み出しそうになってるし……♪　って、なあになに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あ……♪　これぇ？　わたしのおっぱいから……乳首から出てる、このあま\n～い匂いの可愛いお汁？　これはねぇ、もちろん母乳だよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたとわたしが～、一対一で密室で密着したら、ぜ～ったいエッチな展開\nになるってわかってたから……前もって飲んできたの。そう。あのお薬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「『ボニューデマクール』……うふふ、このお薬については、わたしなんかよ\nりあなたの方がくわしいでしょう？　赤ちゃんがデキてなくってもぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おっきなおっぱいから、い～っぱいミルクが……母乳が出てくるようになる\nお薬♪　ちょうど、わたしも……あなたのおちんぽミルクが欲しかったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「交換っていうのはど～お？　わたしのトロトロおっぱいミルクと、あなたの\nドロドロおちんぽミルク……。二人でベトベトになっちゃうの～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……いいよねぇ？　気持ちいいのが一番だもんね♪　と、いうことでぇ～。\nいきなり本気で吸い取っちゃおっかな？　ごちそうのミルク♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「モチモチでプリプリのおっぱいにおちんぽ挟まれて、おしゃぶりされるの好\nきだよねぇ～？　それじゃあ、いくよ～。覚悟して……♪　あ～ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はむぅうっ♪　んふっ……♪　ちょっとしょっぱくれ美味ひ～い……♪　も\nっと舐めひゃお……♪　くちゅっ、くちゅっ、ぺろぺろぺろぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅぱっ……♪　ちゅっぷっ♪　くちゅ……くちゅっ、ぴちゃっ\n♪　れろっ……れろ、ぷっちゅっ……んふふふう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お～っきくて、おくひの中に入りきらなぁい……♪　ビクビクしてるしぃ、\nおっぱいで抑えておくのもた～いへん♪　でもぉ、それがい～のよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「イキが良くって、元気で、強くて……あはぁ♪　最高のおちんぽから出る最\n良のおちんぽミルクにしか興味にゃいのぉ……。れろっれろ、れろっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んちゅ♪　おっぱいのお肉で、根元から先っちょまで精液絞りあげられなが\nらぁ……んむっ♪　やわ～らかい唇とベロでイジメられるのいいでしょお」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……でもねぇ♪　今日はハロウィンだしぃ。わたしは今、最強の吸血鬼だか\nらぁ。それだけで終わらせてなんてあげないんだ～。どうすると思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「男の子の弱点～……♪　はむっ♪　カリ首をぉ……やさしくやさし～く、こ\nの八重歯で甘噛みひひゃうの……♪　カプカプ～って……♪　んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はむ♪　カプっ♪　かぷかぷっ♪　はむ……っ♪　あはっ！　おちんぽの反\n応おもしろぉい♪　そんなに感じる～？　敏感なんだねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「カプカプしながら、お口でクチュクチュしてあげるぅ……♪　んちゅ♪　ち\nゅぅっ……ちゅっ……カプっ♪　今油断したでしょ？　はむはむっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「全力でおちんぽに集中しないとだ～め～♪　んっ……♪　ちゅぷっ、くっち\nゅっ、ちゅる……はむっ♪　かぷかぷ♪　ぴちゃ……ぷちゅっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「甘噛みとくちゅくちゅの二重奏♪　それに加えてふわふわポヨポヨおっぱい\nが思いっきりおちんぽを攻めたててくるの……♪　耐えられるかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「な～んて、耐える必要も、実はなかったりするんだよねぇ～♪　はむ♪　ハ\nロウィンはお祭りだしぃ、お祭りといえば夜這い……楽しもうよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んん？　もうちょっと強く甘噛みするぅ？　かぷ♪　かぷ♪　くちゅっ……\nんふふふ♪　おちんぽの先っちょチロチロ……んふ、もどかしい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「一気に攻めて射精させてほしい？　ん～♪　あむっ♪　どうしようかな～♪\n　だっておちんぽ、すっごくおいひいんだもん♪　ずっと舐めてた～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……わたしの気が向いたらイかせてあげるね♪　んっ♪　くっちゅっ♪　く\nちゅっ、ちゅっぷっ、れろれろっ……♪　れるっ、れるんっ、れろっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふ～♪　ね～ぇ、息があがってきてるんじゃなぁい……？　気持ひい～い\n～？　くっちゅっ、あむっ♪　ぴちゃっ、ぴちゃ、ちゅくっ♪　かぷっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あ～～♪　もう限界ギリギリって感じらねぇ♪　それじゃあ、おっぱいも本\n気で使ってぇ、信じられないくらいの量の精液絞りとっちゃお～っとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んむぅっ♪　んむ♪　んむ、んむっ♪　ンッ……おっぱいとぉ、舌と八重歯\nとぉ……♪　快感の逃げ場がないねぇ♪　気持ちいいねぇ～？　っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ほ～らぁ♪　出ひひゃえぇ♪　負けひゃえぇ♪　わたひにトリック……イタ\nズラされてぇ、されるがままに精子出しひゃえ♪　ほらっ、ほらほらぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ！？　んむぅうううっ♪　んふ～～～～～っ♪　ひゅっごい量～～っ♪\n　んぷ♪　溺れりゅ♪　いいよぉ、しゅっごいよぉおお～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ごくっ……♪　出ひた精子はどんどん吸いとってあげるから……全力で流し\nこんれぇ……♪　っごくっ、ごくっ……んん～っ♪　にがぁい～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あはっ♪　まだ出るよねぇ♪　こんなものじゃないよねぇ♪　そぉれ、びゅ\nーっびゅーっ♪　びゅ～っびゅ～♪　ん、ぅ……口の中に溜まっれきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それを舌で転がひてぇ……。お口の中でくちゅくちゅひて、よぉ～く味わっ\nれぇ……♪　それから……。ごっくん♪　んッ、この喉ごしが最高ぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしはねぇ～？　ハロウィンの日だけの、ニセモノの吸血鬼だからぁ。血\nは吸えないけど、精液だったらいっくらでも吸えちゃうよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……ふふふっ♪　興奮してたくさん母乳が出てきちゃった……。これ、ぜー\nんぶあなたの分だから、飲んでいいよ？　わたしもぉ……。んむっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お掃除フェラしちゃお～っと……♪　好きなんだぁ、自分で絞りとった後の\n、精液きれいにおしゃぶりして飲むの……♪　達成感があるっていうか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「たまにはあなたもぉ、こういう積極的な女の子とするのって楽しいでしょ～\n？　……って、あ～れ～？　わたしはマジメにお掃除してるのに～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんぽ、ちゅうちゅう吸われてる間にどんどんかた～くなってきちゃって\nるんだけど……。これじゃお掃除にならないよ？　んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……もう一回してほしい？　いいよ～？　っていうか、せっかく勃起したん\nだから続けないと損じゃない。ニセモノ吸血鬼がんばっちゃいま～す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん……♪　んふ……♪　まずは母乳で濡れたおっぱいでぇ、精液を出したば\nっかりのピクピクおちんぽをやさし～く刺激していきま～す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「むにっ♪　むにっ、むにゅぅう……♪　ん～♪　すっごい回復力♪　太さも\n長さも、すっかり一回目の時と同じくらいに戻ってきたね～。かっこいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「きちんと勃起さえしちゃえば～、わりと強めに刺激しても痛かったり苦しか\nったりっていうのはないよねぇ？　それじゃあもう一度咥えちゃいま～す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んんっ。ぐちゅっ♪　んちゅ……ちゅぅううう♪　んぁ♪　尿道の奥に残っ\nてたお汁もいただきぃ……♪　ぢゅるっ、じゅるっ、じゅる……ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんぽを空にしたところで～。即、新しい精子を溜めていっちゃいま～す\n。ん……じゅるっ、ぺろっ、れろ……くちゅっ、ちゅっ、ちゅぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あはは……♪　吸ってるのバレちゃった？　ん～♪　だ～って待ちきれなく\nって、もう……♪　男の人のおちんぽってホントに素敵……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ちっちゃい時はプニプニしてて可愛いし……、れろっ♪　大きくなっていく\nのを見るのも楽しいし……ぴちゃっ、太くなったらかっこいいし……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんぽをね？　こうやっていじってると……これがいつも、わたしのおま\nんこをめちゃくちゃに掻き回してるんだ～って想像してムラムラするの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「強くてぇ♪　かっこよくてぇ♪　れろっ……ンンッ♪　逞しくて～……ぴち\nゃっ♪　み～んな形も硬さも違うおちんぽ♪　あぁ、おちんぽ好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「その中でもぉ……♪　もちろんあなたのおちんぽが一番のお気に入りよぉ♪\n　はむっ……んむ♪　ちゅくっ♪　くちゅっ、ちゅっぷっ、ぷちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んぁあ♪　アゴが外れそうなくらいおっきい……♪　おいひぃい♪　くちゅ\nっ、ちゅぷっ、おっぱいの感触も、ぬくもりもたくさん楽しんでねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っちゅぱっ♪　れろっ……ぴちゃっ♪　ぢゅるっ……じゅるるっ……♪　…\n…あ～♪　もしかしてぇ、精液……吸いあげてほしかったりするぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「いいよ？　もう出しちゃう～？　ちゅるっ♪　わたしはぁ、何度でも飲んで\nあげるよぉ。だって～、精液専用吸血鬼……吸精鬼なんだも～ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「また飲みたいなぁ♪　飲ませてぇ♪　じゅるっ……じゅるっ！　ぐっちゅっ\n、ぢゅうっ♪　精子ぃ……♪　精液ちょうら～い♪　じゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっちゅっ、じゅっぷっ♪　ぐっちゅっ……ぢゅるっ！　本気出しちゃう～\n♪　いっくよ♪　じゅる……じゅるるるるっ、じゅる、ちょうだぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっむぅううう♪　ん～～～～～っ♪　んんん～～～～っ♪　ンン～～～っ\n♪　ごく……ごくんっ♪　んぅ……濃厚～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303301" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ♪　いいわぁ……っ、うれひいっ♪　もっと出ひて、お口の奥に注いれ\nぇ……♪　ンッ……、んっんっ、んぅうう～っ♪　いっぱいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303302" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……♪　あっ♪　ごめんなさい♪　量が多すぎて溢れてきひゃった…\n…♪　今舐め取るねぇ。……ぴちゃっ、ちゅっ、じゅるっ、ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んく……っ、んくっ……♪　んん♪　精液の海で溺れちゃいそぉ……♪　ど\nれだけ飲んでも、次のお汁がどぴゅって入ってくるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うん、うん♪　だ～いじょうぶ♪　残さず飲んであげるからねぇ～……。じ\nゅるっ♪　ごくっ、ごくっ……。んぅう♪　喉の奥でひっかかるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「健康で優秀なネバネバ精液……♪　んぷ♪　んぅ、んん……おいしいよぉ♪\n　ごくっ……ごくっ……。ん～♪　ずっと飲んでたい～……でも終わりかなぁ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……え～？　わたしがご機嫌に見えるって？　ふふふふ、理由なんてわかっ\nてるくせにぃ。おなかい～っぱい、あなたが精液をくれたからだよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「精液ってぇ、喉ごしや味が苦手～！　独特ノエグみが～、って嫌う女の子も\n多いって聞いたけど、わたしは全然イヤだとか思わないんだよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「むしろドロドロしてて、なかなか飲みこめないくらい質量があることで……\n達成感をおぼえるっていうか。お～っ、これを吸いとったのか～って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「自分でもおかしな感覚してる～って思うけど、やめられないんだよねぇ。…\n…なんて、これはナイショの話だから、あなたの心に秘めておいてね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303310" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「きゃっ♪　勢い余って精液がこ～んなところまで飛んできちゃって……♪　\n真っ白な噴水みたい……♪　んっ♪　お顔？　ここがいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303401" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「逃げたりしないで受け止めるからぁ～♪　よぉ～く狙って、かけたいところ\nにびゅっびゅしてねぇ♪　はい、びゅーっびゅーっ♪　びゅるるる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303402" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「よくできまちたぁ～♪　びゅっ♪　びゅっ、びゅぅ～～♪　あはっ♪　発射\nの音が聞こえてきそうなくらい、豪快に飛んでるよぉ……♪　びゅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ひゃんっ♪　んふふふ、ねばっこ～い……♪　それにこんなに飛ばしてくれ\nるなんて、吸血鬼……吸精鬼にとってはすっごいご褒美だよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ほとばしって、爆発するおちんぽのエネルギー……♪　栄養たっぷりの精液\n♪　これって最高のご褒美だし、がんばったね～って褒められてるみたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んんっ♪　慌てないで……。出しきるまで付き合うからぁ。じっくり、こっ\nてりした精液をかけて……♪　そう、そうだよ、顔に……あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふわぁ……♪　顔中が精液でダラダラになっちゃったぁ～♪　これだけ出し\nたら、身体が軽くなってるんじゃない？　いいなぁ～、ズルいなぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「男の人ってぇ、本当にうらやましいなぁ……。おちんぽがあって、射精がで\nきて……。精液を出すって、ものすご～くスッキリするんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふ、女の方がおっぱいもあるし、イク時の快感も強いからおあいこさま？\n　あぁ～♪　確かにそれはあるかも♪　でも、一度は経験してみたいなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303409" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「男の人の快感を知ったらぁ、女に戻った時、もーっと攻めるのが上手になる\nと思わない？　母乳もいいけど……精液も出してみたいな～。ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}