		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ん……？　なぁに……この部、屋……。私は自分の部屋で寝てた、はずじゃ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あっ！？　た、隊長様！？　良かった、事情をお聞かせくださ……いっ！　\n……あっ！？　……え？　腕が、腕が動かない……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104102" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「まさか、コレ……。拷問ですか？　私、粗相をした覚えはありませんけど…\n…！　ンッ……くぅうっ……結構キツく締めたのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あ、の……。大股開きで恥ずかしいですわ。その……、寝る前、少し……隊\n長様のことを考えて、……じ、自慰、を軽く行いましたので……匂いが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「匂いが気になります……。せめてシャワーを浴びさせて……！　……あっ！\n　だ、だめですっ……！　触らないでください、私の身体、今は、今はっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「は、ぁう……あぁああ……！　あふ……ぅ！　ほ、他でもない隊長様がここ\nまで開発したんでしょう！？　なのに、不用意に触れないで！　……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「いやっ……い、や……いやぁ……っ。あっ……！　胸……胸ぇ、そんなに激\nしくまさぐって……！　あぁっ、乳首……乳首なぞらないで、ふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「勃っちゃ……勃っちゃいま、す……！　あっ……！　それ、に……！　あ、\nくぅううっ……！　股間が……湿ったままで、……あ、や、だ……ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「愛液が……隊長様の手に……！　んふっ……、ふぅうっ、ふ、ぅ……うう…\n…！　だって、だって……毎日、毎日毎日……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「焦らされるだけ焦らされて……お情けは無しで！　この身体、いじくるだけ\nいじくって、最後はおあずけされていて……だから、だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あなたの思う通りに熟して、食べごろになってしまっただけ……でしょう！\n？　『下の穴からトロトロと涙が溢れている』？　そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「はぁっ、ぁ、あ、あ……ッ。なにゆえ、こんな回りくどいこと……！　普通\nに願われれば、あ、脚だって好きなだけ開いたのに……こんな、こんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……ンンンッ！？　乳首つねらないでくださいっ！　ひうっ！　おまんこっ\n……おまんこクチュクチュしないで、クリッ……クリこねないでぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっぁっ、あっあっあっ……！　全身っ、全身敏感になっている、\nのに！　どこまでも、どこまでも追い詰められて……。くぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「悪くっ……ありませんけど……けど、でも……！　あっ……あっ！　される\nがままというのは性に合いません……！　……はぁんっ！？　あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ど……どうしたらこの、やっかいな攻めから解放して……だ、抱いてくれる\nんですかっ……。したいです、ここまでするなら……抱いてほしい……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『おねだり』……？　わ……わかりました、なんでも……なんでも言います\n……。知っての通り、私の口は軽いですから……。……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『本心をこめて、全力でおまんこにチンポを入れてもらえるように懇願しろ\n』？　『ドスケベ四天王のユルマンに』……『太いペニスを』……くぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ゆ……ゆるくありません！　だって、わ、私……！　わ、わかりました……\nお伝えします。『ド、ドスケベ四天王の濡れっぱなしのキツマンに』……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『ペニスが欲しくて疼きっぱなしの、い、淫乱処女まんこに、隊長様の素晴\nらしいペニスを……生オチンチンを恵んでください。入れてください』！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『奥の奥までヌレヌレで、いやらしくヒダヒダが蠢いています。オチンチン\nを入れるために開いた穴なので、存分に使ってください……』っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「う、うう……！　ええそうよ、経験豊富にみせかけたのも嘘！　私……私本\n当は……経験なんてない、ただの生娘で……それなのに、それなのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「毎日毎日開発、されて……耐えられなくて……！　うう……な、情けない…\n…！　ここまで言わせたのよっ！　いいから黙ってチンチン挿入して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……んぐぅううっ！？　ぐぅううっ、うううううーっ！　はァッ……！　ミ\nチミチと……ミチミチと処女膜っ、肉襞貫通して……。くぅううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あ……ひっ、あひぃいいっ！　指なんかとはまるで違う、あ……！　あっ、\nこんな太いもの……！　硬いもの、私の中に入るなんて……うううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁ、はぁあああ……！　い、息をするのもためらわれる、く\nらい……おまんこがギチギチ……。それに……それに……。……うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「なんなの、この欲求は！　オチンチンを入れられただけで、腰が砕けて……\n全身がゾクゾクして、止まらない……震えが止まらないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「私の女の本能が、おまんこの意思がコレを欲してうねり出すぅ……！　あふ\nぁあああっ、いや、いや、貪欲に、蠢いてすがりついて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あぅっ、あうっ、あぅうっ！　腰、が勝手に揺れちゃう……！　あっ！　あ\nっぁっ、理性じゃ止められない……本能に乗っ取られるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……っああああっ！　あぁっ！　あっ！　あっ、ぁっあっ！　ま、まだ隊長\n様は動かないでくださ……いぃっ！　あっ、『それは無理』？　そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『お前がエロく腰を振るから』？　あッ、それは……それ、はぁ……！　私\nじゃなくて、私はそんなはしたない女じゃ、なくて……ん、ん、でも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……っ！　腰、動かしてます……！　うまくできなく、て、ヘ\nコヘコって……っ！　情けなく腰揺らして、オチンチン味わってますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んんっ……ああああっ、あぁ……あっ、ぁっ、あっ……！　これがチンチン\nっ……隊長様のオチンチン……！　目で見た時は余裕があったのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「入れられて、しまう、と……もうだめぇえええ……！　粘膜で感じると何倍\nにも……何倍にも大きく感じるっ……！　異常とも思えるサイズ、です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「う、ぁ……あああっ！　あぁっ、はぁっ、はぁ、は、ぁ……！　あぁ、情欲\nが抑えきれない……！　隊長様、隊長様、私をいじめて、いじめてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「パンパンって乾いた音がするくらい！　腰を叩きつけて、オチンポっ、チン\nチン、オチンチン天国にしてくださ、い……あぁ！　あぁっ、あああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んっ！！　ふぅううっ♪　ふぅうう……くふぅうう……っ♪　嘘、みたい…\n…っ！　私が、この口が余裕をなくして嘘より嬌声を選ぶ、なんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　隊長様！　隊長さま、素敵……ステキ……！　私の人生\nっ……おまんこからオチンポで変えちゃってくださ、い、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あ……あ、イ……く、イクぅっ、イ……く♪　あんっ！　隊長様も……隊長\n様もイキそうなの？　だったら……ちょうどいいわ、あっ……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「タイミング……！　タイミングを合わせて……ええ、そうですっ……！　そ\nのまま……っ、そのまま来て……！　あぁっ！　イッちゃううぅッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あッ……はっ……はぁあっ……！？　んぅっ……んんんぅっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「イッたと同時に……中に、中に出て、るぅ……出されちゃってるぅう……！\n　私があんまり喘ぐ、から……？　あっ、あなたもよくなってくれたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「う……れしい、嬉しいけど……。っ……ぅううんん……♪　初めての絶頂に\n、初めての膣内射精まで加えられたら、身体がもたないよぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「一番感じやすい状態のおまんこに、ドピュドピュされたら……。っふぅうう\nっ……全身が真っピンクになって、……アソコが喜んじゃって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「おまんこからオッパイの先まで快感が……快楽がほとばしって、波打つの…\n…！　他のことでは味わえない絶対的快感……！　でも、でもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「全身から力が……抜けて……。もう何もできない……。あなたもそうでしょ\n？　私のおなかいっぱいに精子出したんだから……。……あら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「やっ……！　な、何してるの！？　インターバルも、休憩もおかないで、…\n…あっ！　おまんこに入れたまま……また、また始めてる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ッあああああっ！　体力……ぅ、体力どうなっているのっ！？　私はこんな\nにクタクタでヘトヘトなのに間髪も入れず……、っぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「またっ……またオチンチン、オチンチン硬くなって……どっちゅんどっちゅ\nんあそこをえぐって、る♪　突き上げてくる、冗談みた……いぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あくぅっ！　くぅううっあぁっ！　いやっ……いやっ、いやっ！　イッたば\nかりのおまんこに射精してすぐフル勃起、ピストンなんて……いやぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「こっちの気持ちいいのがおさまってないのに、次の快感をおくりこまれたら\n……あッ♪　蓄積されて……爆発し、ちゃう、これ以上は無理ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『もっとよくしてやる』？　……ええええっ！？　胸っ……胸を揉みながら\n、腰を揺らさ、ないで……それは本当にだめっ、感じすぎるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……ふ、ぁ♪　あっぁっ、あぁっ、あぁああッ……あぁんっ♪　オチン……\nチンっ、オチンチン、のことで頭がいっぱいに、なって、きちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「も、もう好きにして……好きにしてぇ！　あっ……あぁっ！　響くわ……っ\n、隊長様のオチンチン、私の奥に響くの……あっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「気持ち……いいっ、気持ちいい……！　逞しい男根が、精液まみれのおまん\nこを、突いて、突いて、貫いて……おかしくなりそうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふぅっ♪　ふぅううっ♪　ふぅぁっ、あぁ……あぁっ、あぁ……！　抱き\nつきたい……あなたにしがみついてめいっぱい腰を振っちゃいたいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「でも、この身動き取れない状態で……される、のも、背徳感でゾクゾクしち\nゃう……！　あぁっ、一つに……一つになってるぅ……あぁあんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「おねが……い、お願いよ隊長様……！　私の身体も頭も真っ白にして……っ\n。特別に濃い精液、で、漂白して、浄化……してぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「おまんこいっぱい締めるから……。くぅううっ……♪　どう？　どうっ……\n？　収縮するヒダヒダが吸い上げて……あなたが出すのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あうぅうっ、んぁうううっ……！　欲しい、欲しい欲しい……！　出して、\n出してぇ！　私のおまんこの中をたぷたぷに満たしてよぉ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んぁあああっ♪　これっ……これ、これぇええっ！　あっ……、おまんこの\nっ、一番奥っ……一番奥にかかってるっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「隊長様……隊長様の熱い子種……！　あ～～～～～っ♪　私の子宮にぶつか\nって♪　化学反応起こしてるっ……調和してるぅうう～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ、あんっ、あんっ……あああああ……♪　出たぁ……？　\n全部出たぁ？　あっ……あっあっ……出し惜しみなんてしないで全部っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ぜーんぶ私にちょうだいぃい……♪　っ……ぷぁああ……♪　すご、い……\n。何回出しても同じくらい、ううん……今回の方がすご、いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「大量の精液が、私の中に溜まっていって……。くはぁあっ♪　全身が、足の\n先から頭の中までカァッと燃え上がっていくようで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ッ……あぁ、だめ……今は動かないで♪　太いオチンチンできっちり栓をし\nておいてもらわないと……量が多すぎて漏れちゃうわ、溢れちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「逆流して……ドビューッておまんこからお漏らししちゃうから……ジッとし\nててぇ……♪　はぁっ、はぁっ、受精するまで、中にいてほしい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……ひゅぅうう、ひゅー、ひゅー……♪　っぁ……ご、ごめんなさいね……\n。快楽に溺れすぎていて、一瞬意識を失ってたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふふふ……これがセックス……これがまぐわい……。酔ったみたいに恍惚\nとしちゃう、今までに楽しいと思っていたことなんて全て吹き飛ばして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「こればっかりしていたい、してもらいたいって思っちゃうような……。禁忌\nの快楽よ。これからも、何度だってしてね？　約束なんだから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふぁああんんっ！？　いやんっ、オチンチンが、オチンチンが逃げちゃ…\n…ああああっ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「と、ところかまわず発射ぁ……！？　あっ……私の顔……私のむ、ね……あ\nんっ、あんっ！　すっごくオッパイ狙って撃ってくるぅうう～～♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　二発目は奇をてらってオッパイに集中させるなんて……隊長\n様は、私に劣らずトリックがお上手だわ……。あぁんんっ、でも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「おまんこに精液をいただけると信じていた私を裏切る、なんてひどぉい……\n！　今も期待で、秘裂がパクパク喘いでいるのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「くや、しい……悔しいぃ……♪　だけど同時にっ、すごくときめいちゃう…\n…！　隊長様の精子っ♪　精子、まともに浴びせかけられてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あなたの色に染まってく……。そうね、この強烈な臭いと粘つく感触は……\n。肌にかけられて初めて感じられるものかも……。それにしても」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ん、ぅ……。はぁ、はぁ、はぁ……。なんてゴージャスな量……。一度目は\n、この量が私の中にねじいれられていたなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「毎日、……こんな量が出るの？　だとしたら……ごくっ♪　わ、私……毎日\nあなたとエッチしなくちゃいけないわね。溜まると辛いって聞くし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「毎日毎日、朝から晩まで顔に、胸に、身体に……おまんこに精液を浴びてあ\nげる。二人でドロドロになって絡み合って……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「こればっかりし続けていたら、世界の平和なんて守れない♪　でもしたい…\n…。あなた、私を目覚めさせちゃったわね……怖い人♪」", "NORMAL" ]},
