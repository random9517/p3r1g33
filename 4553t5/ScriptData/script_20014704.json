{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ってわけで、逆に２人を怒らせてしまった。すまん……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "バステトとメジェドが争っていた場所から、アヌビスの居場所へと戻った俺た \nちは落ち込んでいた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「途中までは、全て順調……うまく運んでいたと思ったのですがなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの箱って、中身は普通にエジプト銘菓……の予定だったんだよな？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「う、うん。エジプト銘菓にもいくつか種類が……あって」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "PLAYVOICE", "v2_081_010023180001" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「その中でも２人が前に好きだって言ってたものを……選んだつもり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「でも……もしかしたら、好みが変わってしまって……？　余計なことをして \nしまったの、かも……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "1", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああいや、なんというか。好み以前の問題っていうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「派手に話が食い違っているのを感じるのは私めだけでございましょうか…… \n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいや、俺もだ。しかし、どういうことなんだろうな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180004" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アヌビスが何かを言いかけた瞬間、ダダダダダッ、と２人の女神が追いかけて \nきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「アヌビス……！　ゆーるーさーなーいー……！　ぬか喜びした！　説明を要 \n求する……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023180001" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「殊勝にプレゼントだよ～♪　なんて喜ばせておいてぇ！　空の箱を贈りつけ \nてくるなんてがっかりだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023180001" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「空の箱……って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180005" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ぽかんとしているアヌビスに、なおも２人の女神は激しく詰め寄っていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00026601_01", "7", "CENTER", "300" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "-300" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「そーんな、しゅんとした可愛い顔をしてもダメにゃ！　これは信頼関係の問 \n題にゃ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "PLAYVOICE", "v2_266_010023180002" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私はアヌビスが、こんな卑劣な手を使ってくる女神だとは思っていなかった \n。心が裏切られた。すごく悲しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023180002" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ま、まあまあそこまで詰めなくても……。その、アヌビス様はぁ、嫌がらせ \nとかするタイプじゃないっていうか～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「そういうわけにはいかない……。これは由々しき事態」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023180003" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「そうだよ！　ものすごく納得のいく、深い理由でもないことには怒りがおさ \nまんないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023180003" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えとえと……。も、もういいんじゃないっスか！？　些細なことです、忘れ \nちゃいましょ～よぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「好きな食べ物を一回チラつかせといて、やっぱりナシでーすなんてのはすっ \nごく残酷なイタズラにゃああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023180004" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んんんん……。いやぁ～……こ、これは……困っちゃったですねぇ～……ん \nん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アーマーン」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「……は、ははははい、なんでっしょう！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「素直に白状しろ。お前、何かやっただろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ぴぇ！？　やっ……たようなやってないような……。あははは」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「……どんなことでも、怒ったりしない……から。教えて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180006" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "プレゼント空箱疑惑の容疑者にされているアヌビスに、静かに命じられてしま \nえば……もうアーマーンはそれに従うしかなくなる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ、あの～。その……アヌビス様からセンパイに託されたっていうエジプト \n銘菓……。それをですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ま、まさか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はい。そのまさかっス。あーし、アレを今日のおやつだと思ってちょくちょ \nくパクついてました！　本当にごめんなさぁい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180007" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ちょくちょくパクつく……ってどういう意味？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180007" ]},
		{"command":[ "SETCHARA", "0", "char_00008105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「はぁああ……。何度も盗み食いしてた、ってことにゃ！　つーまーりー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023180005" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「全ての罪の根源は……アヌビスではなく……アーマーンにあるということ… \n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023180004" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ひえええええ！　悪気はなかったんっス！　すみませんっスぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180008" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あれ？　これってマズい状況っスか？　あーし、ド派手にやらかしちゃいま \nしたよね？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180009" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ってことで、あとはセンパイ！　い～いカンジによろしくお願いしま～す！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023180010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、逃げた！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "脱兎のごとくその場から逃げ去ったアーマーンだったが……事情がわかってホ \nッとしたらしいアヌビスの表情は、とても優しく穏やかだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00008105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「大丈夫……、すぐに反省して戻ってくると、思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010023180008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それもそうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アーマーンは、ヌケたところもあるが基本的には明るくて良いヤツだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺とアヌビスは、アーマーンが反省して謝りにくるのを気長に待つことを決め \nたのだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}