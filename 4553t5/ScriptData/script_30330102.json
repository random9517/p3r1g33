{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "033_0104101" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「隊長さまっ……隊長さま……やっと。やっと私と一線を超える覚悟……お決\nめになったそうですね？　ああ……私の隊長さま……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104102" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「お七は今日のことをどれだけ待ち焦がれていたか……。憎い人。ええ、ええ\n、わかっております。極道の女を抱くその意味を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104103" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「貴方さまも考えて、私を遠ざけていたのでしょう。けれど……愛し合う男と\n女が結ばれない、なんてぇことはお天道様が許しません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104104" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「いずれこうなると信じていました……。ふふ、お七の……私の愛しい人。Ω\n組を預けることすらためらわない、本物の漢（おとこ）……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104105" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……貴方さまがまだ、迷っていらっしゃるようでしたら……そうです。私が\n貴方さまを犯した、という言い訳を差し上げます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104106" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……ですから、どうか……隊長さまと肌を重ねさせて……一晩だけでも……\n私を貴方さまの仮の妻に、貴方さまだけのお七に変えて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104107" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふふ……ここをこんなにして。本当は私に、カタギとしての自分を壊して連\nれ去って欲しかったのでしょう？　マラが期待しています」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104108" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「一刻も早く、お七の膣内に入りたいと……。契りっ……血の契りを交わした\nいと……！　鎌首をもたげ意思表示しています……ああ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104109" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「もう……もうだめ……。我慢できない。貴方さまを模した張り型や、他の男\nでは物足りない……どうしても隊長さまがいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104110" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「入れますよ……。お七の花弁で、深い肉の壺で……隊長さまのデカマラを受\nけ入れたく思います。どうか拒絶なさらないで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104111" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「んッ……ああ……♪　あはっ……ああああ……っ♪　大きい……大きい、大\nきい……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104112" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「わかり、ますよねぇ……私のおまんこの中、ぁっ♪　ねじりこんだ太いイチ\nモツ……それが肉ヒダをかきわけて、こじあけて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104113" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私を貴方様のオンナにするべく、膣穴を拡張……してくだすってる……♪　\nあは……あはあああ……雄々しく強い、肉マラ……ぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104114" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「お七は……お七は貴方様のもの。貴方様だけの雌犬です。どうか、その逞し\nいもので、任侠の髄を教育してくださいまし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104115" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……あっ♪　あぉ……っ♪　おっ♪　おっ♪　おっ……おっ、おぉおっ……\n♪　ぐっぷりと、腹の底まで届いて……すごい♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104116" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ああ……ッ、美味しい……っ♪　美味しいです……ぅ♪　お七はもう、もう\n……、渇望が止まらない……ああぁ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104117" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「貴方さま、のっ……隊長さまのオンナになりたい♪　なにも本妻なんて望み\nません……情婦（イロ）でいい、イロにしてぇ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104118" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「小娘どもの浅い肉壺じゃあ味わえない至上の快楽を……二十四時間、三百六\n十五日いつでもお譲りします♪　あっあっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104119" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ですからお七と……お七と呼んで、俺のために死ねと命令して……っ！　あ\nぁ、それが極道の女の幸福なの……あっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104120" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「貴方さまが私の死に場所っ……このデカマラが……あっ♪　巨マラが私を殺\nせる唯一の……ものっ、あっ！　好き……好きよ、好き……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104121" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「他のものなんていらない、隊長さまが願うならどこだって火の海にしてきま\nすっ♪　誰だって倒すわ、お金だっていくらでも……だから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104122" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「貴方さまのお役にたったら、ご褒美として……ご褒美としてこれをください\n、あふ……っ！　愛した男の生きた証……を♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104123" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「っあぁ……ああああっ、あぁ……！　すごく……いい、すごく……っ！　す\nぐに達してしまいそ、う……あはぁああっ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104124" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ねえ……ねえ、隊長さまも気持ちがいいですか？　お七の極道まんこ……年\n期の入った、なめらかで汁気の多い淫乱まんこ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104125" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あっ♪　んぉおっ♪　使い古しではありますけど……ぉっ♪　その分締まり\nが凄いんですよ……鍛え、ています、の、で……おっあっあっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104126" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「膣圧も……処女だった時のまま、いいえ、それ以上に研鑽して高めまし、た\n……そんじょそこらの生娘よりいいでしょう……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104127" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「精液を搾り抜く動き……肉ヒダをうねらせて……あああっ、射精欲求を……\nぉ、煽る腰使いぃ……っ！　あッ、あぉおっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104128" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「最高の男にだけ開かれるこの観音様の奥で……天界の門をくぐっていただく\nため、に……常に努力を続けてきました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104129" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「だから隊長さまは、お七とだけ繋がればいい……シャバの娘が何十人……束\nになっても敵わない獄門天女の高級おまんこで……はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104130" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「Ω組を継ぐ、最強の子を成しましょう……。っあぁ、ぁ……子宮が降りてき\nて……貴方さまを待っていま、す……んああああっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104131" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「たくさんの男にいくらノックされても、開かなかった最後の門……私の子宮\nに思いっきり出してください……あぁっ……あぁ、あぁ、あぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104132" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私を内縁の妻にする……特濃精子をちょうだ……い♪　ほら……っほらっ、\n非処女まんこ締め付けますっ、極道ババア頑張って受精しますっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104133" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「くだ……さい、ください……！　どうかお恵みを、あっ♪　隊長さまのプル\nプルした元気な精子……お恵みくださいっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104134" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「っはぁっ……！　はぁ、はぁ、はぁ……あぁ……腰が止まらない……！　相\n当な数の男を知ったつもりだったのに……形無しぃ♪」　", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104135" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「貴方さま以外はいないのと同じですっ、隊長さまのおマラが世界でいちば…\n…んんんっ、ああああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104136" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あひっ！？　ひっ、あああっ、ああああっ！　許可なくいきなり種付け、ぇ\n……ああああっ、あぁ……あぁっ！？　と、飛んじゃ……うぅっ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104137" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「いっぱい出て、出て……あああああっ！　あ、ありがとうございます！　あ\nりがとうございま、す……どぷどぷ溜まってますっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104138" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「子宮に直接注入されて……あったかい……！　あああ、ありがとうございま\nす、ありがとうございま、す……ぅぅううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104139" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「っはぁっ……！　はぁ、はぁ、はぁ……あぁ……す、すごかったです……隊\n長さま……膣口から脳天まで串刺しにされた、ような……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104140" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「これだけたくさん射精していただいたら、絶対に妊娠できますね……。お七\nは……お七は幸せです……。ふぅううっ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104201" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……え？　今、子宮のそばでどくんって……。隊長さまのが、むくって……\n起き上がって……えっ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104202" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ま、まだしたいとおっしゃるんですか！？　……あ……。も、申し訳ござい\nませんでした……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104203" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「私、まだ……隊長さまをどこかで見くびっておりました。これだけ出せば、\n当分は満足されるだろう、と……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104204" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「でも、違ったのですね。まだ……隊長さまはお七を求めてくださっている…\n…。なら、それに応えるがΩの心意気……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104205" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふ、ふふふ……でしたらどこまでもお付き合いいたします、それがΩの心意\n気……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104206" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「生きるも死ぬも、隊長さま次第……さあ、下から突いて！　突いてください\nっ……私も精一杯犯します、……いきますよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104207" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「んっはぁっ……！　あはぁっ、はぁっ……はぁっ、はぁ……！　隊長さま…\n…隊長さ、ま……ああっ、あああっ……ああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104208" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「んぉおぉっ……おっおっ♪　おっおぅうっ♪　おぅうっ♪　ああ……二匹の\nケダモノに、なって……交尾、交尾し続けるんです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104209" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「交尾っ、生交尾っ……！　オスのペニスでメスのおまんこを突いて、突いて\n、突いて、突いて……ぇえっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104210" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「精液と愛液と、汗にまみれて……一つに溶け合って……っ、おっ♪　おっぅ\nっ、おっうっ♪　おおぅううっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104211" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あ……は、あははは……っ、響く……ぅ、太鼓の皮ぁぶん殴られてるみたい\n、に……子宮の口がズンッズン叩かれて、る……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104212" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「大晦日の鐘突き棒みたいに……どすぅんっ、どちゅぅんって響いて、る……\n！　こんなのカタギの娘じゃ気絶しちまうよぉ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104213" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あああああっ……！　私っ……私、も、気を失いそう、しっ、失神っ、して\nしまいそう……目の前がクラクラする、おまんこが勝手に締まるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104214" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あっあっ……隊長さま……隊長さま……ごめんなさい、私先に……先にイッ\nてしまいそうです……気持ちが良すぎて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104215" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「耐えられな……あああああっ！　あーっ！　あひっ、あ、んぐっ、んぐぅう\nううーっ……！　イグ……っ！　イクっ……イク、イク……ぅうっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003301_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104216" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そ、んな……っ！　この私が……私がぁ……！　先にイかされるなんて……\nあっ！　あっ！　天賦の才……女を食らい尽くす、魔物……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104217" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「意識をもう手放してしまいたい……けれど、こちらにも意地がございます…\n…！　最後の力で……！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104218" ]},
		{"command":[ "SETNAME", "お七" ]},
