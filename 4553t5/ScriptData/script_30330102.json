		{"command":[ "PLAYVOICE", "033_0104307" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ああ……ッ素敵、素敵……素敵……っ……！　もう貴方さましか見えない…\n…一生お尽くしいたします……ああああっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "033_0104308" ]},
		{"command":[ "SETNAME", "お七" ]},
