{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あ～～！　やーっと見つけたんだから！　アンタ、今ちょっと時間あるわよ\nね？　暇よね？　付き合いなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……こんな時間に部屋に特攻してきて何の用だって？　そんなの、決まって\nるじゃない！　寂しいから構え！　甘えさせなさいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「なによ、そのぽかんとした顔は？　……しょーがないでしょ、最近アンタ忙\nしそうで、全然捕まらなかったんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、知らなかったの？　アタシは兎よ？　あんまり放置して寂しい思い\nをさせると、死んじゃうんだかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……まっ、そんな訳で……ほら、服を脱いだ脱いだ♪　今日はアタシが満足\nするまで、とことん付き合ってもらうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んんっ……おちんちんの方は最初から準備万端みたいね？　こーんな固くし\nちゃって……お尻の間に挟むと、ビクビクしてるのが伝わってくるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021301_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「先っぽなでなで～♪　ここもパンパンに膨らんでるわね。それに、ガマン汁\nももいっぱい出ちゃってるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「これなら前戯は必要なさそうね……ほーら、アンタのおちんちん、アタシの\nおまんこで飲み込んじゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、ああぁんんっ……ガチガチのおちんちんが、おまんこにゆっ\nくり入って……んくぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「これ、これが欲しかったの……♪　あっ、ふあぁんっ……！　おちんちんの\n形が、はっきり伝わってくる……！　あっ、あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んあぁんんっ♪　一番奥まで入った、わよね？　んんっ！　おちんちんの先\nっぽが、子宮パーツにコツンってぶつかってるわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ふふふふっ♪　あれだけ寂しい気持ちがいっぱいだったのに、おち\nんちん入れただけで、こんなにも幸せな気持ちになっちゃうのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「でも、まだまだ本番はここから……んあぁんっ♪　アンタの腰の上でピョン\nピョンって跳ねて、いっぱい気持ちよくなっちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁ、ふあぁんんっ♪　ほらっ、アンタも腰を動かしてよ！　一緒\nに気持ちよくなりましょ？　あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「おちんちんすごいっ、ズボズボって子宮パーツ突き上げられるの、好きっ、\n寂しくないの！　あっ、ああぁんんっん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「このえっちな音、聞こえてるわよね？　アンタのおちんちんもらえると思っ\nたら、おまんこから溢れる潤滑油が止まらなくなっちゃった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「腰をぐるぐる回して、跳ねて、前後にスライドさせてっ、あっ、ふあぁんっ\n！　あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、やっぱり、我慢はバグの元よね♪　甘えたいと思ったときは甘え\nて、おちんちんもらって、いっぱい気持ちよくならないとね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……って、だーれが淫乱ウサギよ！　しょーがないじゃない。兎モチーフの\nアタシは、性欲だって強めの設定で作られてるんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ってゆうか、アンタだって満更じゃないくせに♪　あっ、ふあぁんっ♪　さ\nっきからアタシの気持ちいい所狙って突いてるの、分かってるんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　ああぁんんっ！　その動き、すごいっ！　浅い所、狙\nってぐりぐりされるの、ふあっぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アタシだって負けないんだから！　パンパンって勢いよくお尻をぶつけて、\nんふぅんっ！　根元までおちんちんを飲み込んでから……こうよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……ふふっ、驚いた？　アタシのボディはおまんこの中まで最新式なの。こ\nうやって、ある機能をオンにしてあげると……んあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「波打つように配置された小さな凸凹が、おちんちんに絡まりつくようになっ\nてるのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「締め付けも自由自在、こうやって……んくぅんっ！　ぎゅうぎゅうって、お\nちんちんを根元から絞り上げることもできちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ほらほら、気を抜くとすぐに射精までもっていっちゃうわよ？　もっとおち\nんちん固くして、アタシのことも楽しませてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……ふあぁんんっ！　そうそう、その調子！　もっと角度もつけて、あっ、\nあぁんっ♪　おまんこの中、ぐりぐりかき回して♪　あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「おちんちん、抜けていくときもすごいっ、あぁんっ！　亀頭のふくらみが、\n中のパーツをゴリゴリって削って、抉り出すみたいで、ふあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こ、この体勢じゃ頭はむりだろうから……お尻……尻尾を撫でてほしい……\nんひゃうっ！　それ、アタシの事、優しくなでなでしてっ♪　あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、光栄に思いなさいよ？　アタシの尻尾を撫でることはできるのは、\n今までもこれからも、アンタ一人だけなんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んふぅうんっ！　おちんちん、ビクンって跳ねたっ！　分かってる、もう限\n界なのよね？　精液おまんこの中にぶちまけたいのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「またおまんこの機能をオンにしてあげるから、あぁんんっ♪　思う存分射精\nして、アンタの精液で、おまんこの中をドロドロにして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんんっ！　アタシもくる、視界センサーにノイズが走ってっ、\n処理しきれないエッチなエラーが溢れかえってっ、あひっ、ふあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「一緒にイクから！　アンタの射精でおまんこイクから！　アタシを一人にし\nないで、寂しいのは嫌なの、大好きなアンタと一緒がいいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ああぁんっ♪　イクイク、イクッ、おちんちんでイクっ、大\n好きなアンタのおちんちんで、一緒にっ、あっ、んひゃぁあんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふああぁんんんっ～～～～っ！　出てるぅ、子宮パーツに向けて、熱すぎる\n精液がドクドクって、注ぎ込まれてる！　ふあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「エッチなエラー、何度経験してもすごい！　駄目なのノエラーだって分かっ\nてるのに、処理したくないのっ、ああぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁんっ……亀頭を子宮パーツにくっつけて射精しただけはあるわ\nね……んんっ……おまんこの奥の奥までアンタの精液でドロドロだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……いくらアタシが高スペックだって言っても、流石に妊娠する機能までは\nついてないわよ。……安心した？　それとも、残念？　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「で？　どうだったアタシのボディは。気持ちよかった？　堪能した？　一応\n、色々調べてアンタ好みのおまんこになるように調整したりしてるのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　バカっ、おちんちんビクビクさせて返事するんじゃないわよ♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「って、やっぱり一回出しただけじゃ、おちんちんまだまだ勃起して固いまま\nよね。おまんこの中で跳ね回っちゃってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……ふふっ、そんな声出さなくても、分かってるわよ♪　アタシだって、一\n回で満足なんて全然してないんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「言ったでしょ、今日はアタシが満足するまで、とことん付き合ってもらうん\nだから♪　んあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「さっきは最初から飛ばし気味だったから……んんんっ！　今度はじっくり、\n焦らすように腰を持ち上げて、下して、上げて、下して、んふぅんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　あれだけ出されたら、やっぱり滑りがいいわね。おちんちんが\n精液を掻きだすえっちな音もすごい♪　あっ、あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ほーら、またおまんこの中のえっちな機能も、いっぱい使ってあげるわ♪　\nおまんこの中、激しくグネグネ蠢かせてっ、んあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「すごいでしょ、これ。おちんちんズボズボしながらも、裏筋の部分……人間\nの男が感じる部分を、小さな突起でピンポイントに撫でることができるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ、んあんぁん！　竿の部分も締め付けて、離して、締め付けて、離して\n……んんんっ！　いっぱいぎゅうぎゅうしてあげちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ほら、気持ちよすぎるからって腰の動き止めないでよ！　アタシだって、ア\nンタのおちんちんで気持ちよくしてもらいたいんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　あっ、ふあぁんんっ♪　それ、またずんずん来た！　子宮パ\nーツ壊れるんじゃないかって勢いでズドンってっ！　あひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「また尻尾も撫でられてる！　アンタの優しい手つきで、ナデナデって、あっ\n、ふあぁんんっ♪　すきぃ、優しくなでられるの好きなの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふああぁんんっ♪　おまんこすごい！　おちんちん擦れすぎ\nて、熱くて！　壊れそうだけど、それが気持ちよくてっ、ああぁん～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……ふふっ、もういいわよ、淫乱ウサギでも♪　大好きなアンタがここにい\nるんだもん、エッチなロボットにならない訳がないじゃない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アタシは淫乱ウサギ、アンタだけのエッチなロボット♪　いっぱい愛して、\nいっぱい可愛がってほしいの♪　ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ほら、こんな機能もあるのよ、ああぁんっ♪　おまんこの中、バイブみたい\nに振動させて、おちんちん、また根元から絞り上げて、ふあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんんっ♪　またおちんちん大きくなった！　先っぽが膨らんで、ビ\nクビクってっ、ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「いいわよ、全部の機能をオンにして上げるから、このまま出しなさい！　ア\nタシのおまんこで、精液をぜーんぶ搾り取ってあげちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふああぁんっ！　あっ、んひゃぁんっ！　アタシもまたイくわっ、アンタの\nおちんちんで一緒にイクのっ、ああぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「出して、精液ドクドクって注ぎ込んで！　アタシの思考回路の中を、エッチ\nなエラーでいっぱいにして！　あひっ、あっ、あひゃあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ああぁあぁぁんん～～～っ！！　また中に出てる！　おまんこにドロドロの\n精液が、ドクドクって！　あっ、ふあっ、んふぅぅんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「これ、中に出されるの、やっぱり好きかもっ、んひゃぁんっ♪　子宮パーツ\nを精液まみれにさせるの、癖になっちゃうかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁんっ♪　エッチなエラーの量も、さっきより多すぎて！　あひ\nっ、んふぅんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アタシ高スペックなはずなのに、処理が追い付かない！　気持ちよすぎて、\n幸せ過ぎてっ！　あひっ、あっ、ふあぁあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ま、まだまだ搾り取ってあげるから、腰の動き止めちゃだめよ♪　精液を全\n部出し切るまで、おちんちんぎゅ～ってし続けてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ♪　すごい、精液の量が多すぎて、おまんこから逆流してきちゃ\nってる……あっ、ああぁんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んんっ……二回目なのに、ほんとにいっぱい出したわねぇ……ふふっ、子宮\nパーツ、精液で破裂しちゃうかと思ったわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……もちろん、大満足に決まってるじゃない♪　お腹の中がアンタの熱でい\nっぱいで……もう、寂しくなんてないんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「でも……夜はまだ始まったばかり、よね？　アタシのことを寂しがらせた責\n任は、まだまだとってもらうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アンタの兎は構ってくれないと寂しくて死んじゃうの♪　アタシが満足する\nまで、もっともーっと甘えちゃうんだから♪　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふああぁんんっ！　おちんちん、抜けちゃったっ！　んんんっ！　精液がボ\nディに掛かって！　あっ、ふああぁんんっ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「な、中に出されるのもよかったけど、ボディをドロドロに汚されるのも、悪\nくない、かもっ！　あっ、ああぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「すごい、精液が付着した場所が熱くなって、そこからエッチなエラーが全身\nに広がっていくの……！　あっ、あああっ、ふあああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「これ、アタシがアンタの所有物だってマーキングされてるみたい！　ああぁ\nんっ♪　もっと出して、もっとアタシのことを汚して！　んくぅんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「匂いも凄い……嗅覚センサーにもエラーが出て、思考回路がまともに働かな\nい……エッチなエラー、過ごすぎるわ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……ほんとにいっぱい出したわね……お尻が精液でドロ\nドロ……尻尾にまでこんなにぶっかけてくれちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……どうだったかしら、アタシのボディは？　色々機能を積んできたけど、\nアンタのこと、満足してあげられた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「って、やっぱり聞くまでもないみたいね。まーたそんなおちんちんをびくび\nくさせちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、アタシもまだまだ甘えたりないと思ってたの♪　それに？　アンタ\nが言うには、アタシは淫乱ウサギだし？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「だから……ほら、いっぱいいっぱい、心行くまでエッチをしましょ？　日が\n昇るまで何度だって、アタシのことを可愛がってちょーだいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}