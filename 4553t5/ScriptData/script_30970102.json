{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "097_0104101" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……はっ……はぁああ……あんっ！　お、おい……た、隊長\n？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104102" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああっ！　はっ、あああああ……な、なんなんだよ……！？　\nいきなり呼び出して……こんな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104103" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　おしおきぃ？　ふざけんな、なんでオレがお前にこんな――だか\nら、んなとこいじってんじゃね――はぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104104" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ？　ほぐしておかないと、オレがつらいだとぉ！？　つまり、ヤル気満\n々ってことじゃねえか！　おしおきとか、ただの口実だろ、てめえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104105" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったくよぉ、ヤリてえならヤリてえって、最初から言えばいいじゃねえか。\nそうすりゃこっちだって――んあっ！　はああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104106" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああ……な、何言ってんだよ！　何が『もうびしょぬれ』だ\n！　そんな風にいじくりまわされりゃ……ん！　んああああっ！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104107" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああっ！　あっ！　お、おいっ！　隊長……っ！　なんか…\n…話が違うんじゃねえのか……はぁああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104108" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だ、だ、だってそうだろうよ！　それだけビショビショになってるってんな\nら、手でいじくりまわしてねえで、もっとやることがあるだろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104109" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「う、うっせえ！　そうだよ！　欲しいんだよ！　指よりぶっといのがっ！　\nだから――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104110" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んあぁあああっ！？　い、いきなりぃ！？　ん、ん、んはぁあっ！　太い…\n…っ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_05" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104111" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「い、いきなり……そんな……あっ！　あっ！　ああああ！　くっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104112" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ふぁあああ……な、なんだよ、隊長……もう、ガチガチじゃねえか……んん\nんっ！　そんなに、興奮してた――んあああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104113" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ。そりゃお互い様だってか！？　あ、当たり前だろ？　オレだ\nって、さっきから……ふぁああんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104114" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、あ、ああああっ！　ふああああ……く、くそっ……ふ、ふざ\nけんじゃねえぞ……こいつ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104115" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ！　ラビットパワー！　んっ、んっ、んっ、くううううっ！　\nふんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104116" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、ん、んんっ！　へ、へ、へへへへっ！　ど、どうだっ！　アタ\nシの、リズム感、満点の、腰の、動きはっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104117" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へ、へ、へへへっ！　どうした、どうしたっ！　さっきまでの勢いは！　オ\nマエなんざ、このまま骨抜きに――んぉおおっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104118" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ！　あああああっ！　くぅうううっ！　な、なんでぇ！　\nその程度で……逆襲のつもり、か、よ！　ふぁああああん！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104119" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　はああああん！　あ！　ひぃっ！　い、今、奥に……ふぁ\nあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104120" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こ、この……っ！　そっちが、その気……ならっ！　んんっ！　んあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104121" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、くっ！　なにぃ？　急に、締まったぁ？　へへへ、当たり前だ\nぜ……締めてんだ、よっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104122" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ど、どうだ、この、まま、オマエの粗末なもんを、ぎゅうぎゅうに、締めあ\nげ……てっ！　んんんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104123" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あああああっ！　し、しまったあ！　締めすぎると、こっちも\n、中に、こすれ……てっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104124" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、いいいいっ！　すげえ気持ち……いいいっ！　あああん！\n　あっ！　あっ！　グッド！　ソーグッド！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104125" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ。オマエ、も、気持ち、いいのかよ……！　そ、それじゃ、今\n日は引きわけ……ああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104126" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お、おう！　いいぜ。二人で、一緒に、気持ちよく……あああん！　あ、あ\n、あ、はああああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104127" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　いいいいっ！　はぁああああ……あ！　あ！　あああん！　\nあんっ！　あ――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104128" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んああああっ！？　あ、あ、あ、あ、あ、ああああっ！　ふぁあっ！　奥！\n　奥に……イェッ！　オー、イェッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104129" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ、隊長！　いきなり、ペース速めて突いてきやがって…んあっ\n、あっ、くっ、はっ、あ、あああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104130" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「な、なんだと？　げ、限界？　そりゃ、こっちだって――い、いや、なんで\nもねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104131" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だ、だったら、ガンガン突いてくりゃいいだろうが！　おら来い！　オマエ\nの粗末なモノ、一気に昇天させてやらぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104132" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　あんっ！　んっ！　くっ！　ぅぅうう……はっ、あ、あ、あ、オー\nウッ！　イェ―ス！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104133" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くうぅうっ……！　な、なかなかやるじゃねえか……こ、このままじゃオレ\nのほうが……あ、あ、あ、あああああああっ！　オーマイトロ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104134" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああ……はあっ！　ああああああん！　んっ！　お、おい！？　まだか！？\n　まだイカねえのかっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104135" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お！？　限界か！？　限界なんだな！？　おっしゃ！　イケえええっ！　あ\n、や、やべ！　オ、オ、オレも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104136" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、はっ！　あああああああ～っ！　カミング！　アイムカミ～～～～ン\nグ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104137" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、、ああああ……！　んっ、んんっ……！　な、流れてくる……！　熱く\nて、濃いのがオレん中に………あ、あ、はあああ……あっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104138" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……。さ、さすがだぜ、隊長……このオレを、ここま\nで追い詰めてイカせるとはな……へへへへへ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104139" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だけどな。この次はこうはいかねえ……オマエを先にイカせまくって、ヒイ\nヒイ言わせてやるぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104140" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だから、またヒマなときにでもよ……ここで会おうぜ？　いいだろ？　へへ\nへへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104201" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ん……ちょっと待て隊長。オマエ、今終わったんじゃねえのか？　どうして\nまだつながって……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104202" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んあっ！　あっ！　ああん！　なんだよ！？　また硬くなって……ファック\n！　またファックする気かよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104203" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「何ぃ？　一発じゃ足りねえだと！？　オマエ、まだまだ出す気か！？　さっ\nきのでだいぶ、オレの腹ん中はいっぱいに……ふぁあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104204" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああっ！　い、いきなり遠慮なく動きやがって……んああ\nあああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104205" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そ、そっちがその気なら、こっちだってよ……んっ！　んっ！　んんんん！\n　あああんっ！　くっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104206" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ど、ど、どうだっ！　まだまだ、こっちだってへこたれちゃ、いねえっ！　\nんっ！　んっ！　んんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104207" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへへ。せっかくだし……たっぷりと、楽しませて、もらう、ぜっ！　んっ\n、くつ、ふぅっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104208" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「……んああ！？　あ！　あ、ああああああっ！　て、てめえ！　またそうや\nって、いきなり奥を……オー！　ノォオオオオッ！　イエスッ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104209" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あああああん！　あっ！　くぅうう……うっ！　うっ！　\nオー！　イェッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104210" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ、ふぅうっ……んっ！　ん、ん、ああああん！　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104211" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「イエス！　イエスイエスッ！　オレんなかで、硬くて熱くてぶっといのが大\n暴れしてやがるっ！　くうううううっ！　こりゃたまんねえっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104212" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あっ！　はああんん！　いいっ！　気持ちいいぜぇ……！　日頃の\nストレスが、肉にこすれて溶けてく感じだぜ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104213" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お……オマエのアレ、だいぶ限界に近づいてんじゃねえのか？　わ、わかる\nぜ……オレん中で、ひくひくしてんじゃねえか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104214" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへへ、そうかそうか……気持ちいいか。まあ、そうだろうそうだろう。へ\nへへへ……どうだ？　ホクシィとオレ、どっちが気持ちいい？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104215" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうかそうか！　オレか！　まあ、当然だな！　ホクシィのやつより、どん\nなことでもオレが上に決まって……あああんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104216" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お、おう、いいぜ、イキたちゃ……ガンガン突いてこいよ。オレもしっかり\n、楽しませてもらう――ぜっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104217" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ん、はっ、はああっ！　んんんん……くぅうっ！　んっ、んっ、んっ、オー\n！　オーウッ！　……どうだ？　気持ちいいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104218" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お、おう……！　オレも、気持ちいいぜ。さっき一回イッてっから、ずいぶ\nん敏感に……んっ！　ん！　ああああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104219" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あっ！　ああああああっ！　んあああああっ！　イクのか！　イク\nんだな！？　ちょうどいいや！　オレもそろそろ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104220" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああああっ！　イ、イッピカイエエエーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "097_0104301" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ふぁああああっ！　あ、き、来たあっ！　二発目……！　中に……！　ああ\nああ……熱い……っ！　イッツソーホット！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104302" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あああああ……、な、何だよ。まだ、ドクドク言ってんじゃね\nえか……！　二発目だってのに、どんだけ出すつもりだ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104303" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんんっ！？　お、奥に押し込んで……あ、あ、ああああっ！　くっ……最\n後のしずくを、奥に出し切ろうってのか……よっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104304" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……だ、出し切ったの……か？　そうか、そうか……\nったく。さっきも出したばっかだってのに、よくこんなに出るもんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104305" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく。オマエが遠慮なくぶちまけるからよ、腹ン中、オマエの精液でいっ\nぱいだぜ……あ、また垂れてきやがった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104306" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「しかしなんだな。こんなに出されたんじゃ、オレ、妊娠しちまうかもしれね\nえなあ？　そう思わねえ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104307" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへへ、ウサギは多産だからな。きっと、すっげえにぎやかだぜ？　退屈し\nねえぜ？　隊長さんよお――って、こら。なに逃げてんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104308" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「冗談だよ、冗談。なにも、そんなに焦るこたあねえじゃねえか。オレだって\nよ、さすがにまだ、ママになる気はねえぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104309" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ま、妊娠するしねえに関係なくよ。オマエとはなかなか、カラダの愛称よさ\nそうだし。そのうちヒマみてまたやろうぜ！　な！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104310" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、でもな、いっとくけど、ホクシィの野郎にはもう、手出すんじゃねえぞ\n。あいつなんかより、オレの体のほうがいいに決まってんだからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]}, 
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "097_0104401" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んああっ！？　こ、この野郎！？　何抜いてんだ！　せっかくいいところだ\nったのに――んあああっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104402" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んおおおおっ！？　ガッデム！　なにぶっかけてやがんだ！　熱くてどろど\nろのが、オレの体中に……アー……イェー……」　", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104403" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はああ……相変わらずキッついな、お前の臭い……体の芯がムズムズしてく\nるぐらい、ひっでえ臭いだぜ。へへへへへ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104404" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おまけに、濃厚でドロドロだ。さっき出したばっかりの二回目だってのに、\nよくこんな濃いぃの出せるよな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104405" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「しっかし、あぶねえところだったぜ。出されたのが外で、まだよかったな。\nへへ、へへへへっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104406" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「何が？　って、決まってんじゃねえか。こんな濃いのを二発も中に出されて\nたら、間違いなくデキちまうとこだったぜ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104407" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんたって、ウサギは多産だっていうからな！　はははははっ！」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104408" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「……って、なんだよ、その目は！　も、もしかして、オレを孕ませたいとか\n思ってんじゃねえだろうな、オイ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009701_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104409" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ま、まあ、それはそれでいいかもな。姉妹四人でワイワイ暮らしてきたから\nな、いっぱい子供作って、大家族で暮らすっていうのも嫌いじゃねえよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "097_0104410" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ご、誤解すんなよ！？　オマエと家族を作りてえって話じゃねえからなっ！\n　ま、まあ、拒否もしねえけどな。へへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}