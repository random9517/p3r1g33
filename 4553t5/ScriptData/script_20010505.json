{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0125" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……そこネ！　隙ありヨ、隊長さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080001" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一旦倒れ込んだかのように見せかけて、油断したところに蹴りを炸裂させる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉあっ！？　あ、あぶねっ！？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "蚩尤の足をすんでのところで避けた俺を、待っていたのはセレインの右拳だっ\nた。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まだまだ！　一人防げば安心ってわけにはいかないよ、隊長！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080001" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヒッ……！　こ、コンビネーションを組んでくるなんて……卑怯だぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「卑怯なコトなんてないネ。これが本気を出した中華娘の連続攻撃ってやつヨ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080001" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうそう！　勝てばいいんだよ、勝てば……！　うりゃあああ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080002" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「いいアルね～！　でも、金華だって容赦しないヨぉ～……！　青龍刀が火を\n噴くネー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080002" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「私の攻めも終わっていませんからねっ！　とりゃあああああァアア！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080001" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華＆紅華" ]},
		{"command":[ "SETTEXT", "「食らえっ！　中華姉妹アターック！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080003" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "7", "CENTER", "-300" ]},
	{"command":[ "SETCHARA", "1", "char_00014301_01", "7", "CENTER", "300" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「拳に刀に蹴りに……あああっ！　こんなの対応しきれるわけねぇ！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一瞬たりとも途切れない攻撃に、ついに俺は膝をつく。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まいった！　まいった！！　俺の負けだ、これでいいだろ！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よぉっしゃぁ！！　どうだっ！　これでわたしを最強だって認める気になっ\nた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080003" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「わたしを……ねェ？　ま、言うだけあって、おまえの蹴り……なかなかだっ\nたアル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080002" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「だろだろー！？　でもさ、そっちのパンチも凄かったぜ。威力がでかくって\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080004" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「フフフン♪　褒めても何も出ないあるヨ～？　でも、悪い気分じゃないネ。\nにひひひ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080003" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「金華ちゃんの秘められた力を引き出してくださったお二方には、感謝しかあ\nりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080003" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「そうヨそうヨ！　おやつ食べにきただけなのニ、パワーアップさせてもらっ\nて感謝感激ヨ！　謝々～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080004" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「こっちこそ、いい運動になった！　ありがとな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080005" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「相手がいるのといないのとじゃ、クンフーの量も桁違いだしナ。良かった良\nかったアル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080004" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いいってことよ！　また、暇があったらやりあおう。約束だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080006" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ハイハーイ！　それには金華とオネーチャンも絶対呼んでナ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080005" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「まあまあ……。金華ちゃんったら……うふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080004" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あれ……？　なんだこの流れ……お前ら、さっきまでの争いはどうした\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戸惑う俺を尻目に、中華娘達はいつの間にか互いの実力を認め合っているよう\nだった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「これだけ気持ちイー汗かかせてもらったら、肉まんなんて些細なことネ。私\n、譲ってもいいアルヨ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080005" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「そうアルな。これ持ってて欲しいアル。オマエこそこの肉まんにふさわしい\n武人アル！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080006" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いやいや、そういうわけにはいかないアル！　お前らこそできる戦士アル！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080007" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「口調移っちゃってるじゃねぇか！　キャラ被りの件はどうなるんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アハハハ……。でも、ホントに悪い人じゃないのはわかったヨ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080006" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「良かったらだケド、これから皆で料理店にいかないカ？　冷めた肉まんは隊\n長さんにあげテ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080007" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そりゃいいね。そういや……そうだ！　忘れてた！　オススメの店があるん\nだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080008" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そこの肉まんは最高でさー！　ふっかふか！　モッチモチ！　で肉汁ジュワ\nー……天国なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「アイヤー……想像しただけで桃源郷ネ～……。早く行くアル！　連れていく\nアル！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080007" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「フフフフ♪　それじゃ、豪勢に肉まんパーティーとシャレこむネ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080008" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「その後は、こっちのオススメを味わってもらうアル。最高級フカヒレスープ\n、北京ダック……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「激辛マーボー豆腐も美味しいヨ。羽根付き餃子、小籠包……じゅるる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080008" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「代わり種として、巨大桃まんなんていかがです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080005" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「おーっきな桃まんの中に、小さな桃まんが８つ入っているんですって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「縁起のいい８個のミニまんを食べると、幸せになれるんだとか……。甘くて\nたまらないんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「また饅頭を食うつもりなのか！？　どんだけ食うんだよ、このアイヤー娘ど\nも！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ンー、隊長さんは一緒にいかないアル？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080010" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「せっかくだから来たらいいヨ。この街のコト、いっぱいいっぱい知って欲し\nいしナ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080009" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「少しでもお役に立てたら嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080008" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よぉーっし！　それなら決まり！　決まり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080010" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレインはがしっ！　と両脇に蚩尤と金華をつかまえた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「中華街食い倒れツアーだっ！　今日はぶっ倒れるまで、食べて、食べて食べ\nまくるぞぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080011" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「もちろんネ！　もーお腹ぺこぺこヨ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080011" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「このままじゃお腹と背中がくっつくアル。事態は刻一刻を争うアル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080010" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「まあ。はしたないですよ、金華ちゃん。……というわけで、隊長サマ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080009" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「同行いただけたら、嬉しいです。さ、お手をどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080010" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まったく……さっきまでの死闘はなんだったんだ……もうこんな、仲良\nくなっちまって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あはははっ、当然当然！　死闘を超えた先には友情が生まれるんだ！　それ\nに、中華娘に悪いやつはいないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080012" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやお前、悪の組織の幹部だろうが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「細かい事は気にしない！　それじゃ、肉まんパーティー一番乗りだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本当に嬉しそうに豪快に笑うセレインが、誰より先に走り出す。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アーッ！　抜け駆け禁止ヨ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080012" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ホラ行くヨ、オネーチャン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080011" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「はいはい。ちゃあんと付いていきます。金華ちゃんは心配性ねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080011" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、いいか……俺も腹減ったしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こうして、中華街の朱雀門にて突如勃発した『肉まん中華娘大戦』は集結した\n。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "紅華に手を握られ、引っ張られながら……今日くらいはハメを外してもいいか\nなと考えていると……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ア、お会計は隊長さんの奢りダヨナ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080013" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "蚩尤にそう言われて目の前が真っ暗になる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おい。まさかお前ら全員、俺にタカる気か……？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「わたしタチは戦う、隊長さんはオカネだす。オトコは財力こそがパワーネ♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021080014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「可愛い娘っ子たちでハーレムだもんネ。そこは当然……ネ。きしし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021080012" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「え、オゴリなのかっ！？　じゃあますますお腹いっぱいにしないとだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021080014" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「そうでしたか。ゴチソウさまです、隊長サマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021080012" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなこったろうと思ったよ……はぁああああ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "日々、幹部達に虐げられ、弄ばれてきた俺の生活。それはここ、中華街でも変\nわらない。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "せめてもの抵抗に、大きなため息をつくことしか出来ない俺なのだった……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}