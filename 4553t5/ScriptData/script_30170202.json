{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えへへ……お互いにエッチな話をするのって、なんだか照れ臭いですね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わ、わかってます！　あなたも話してくれたんですから、私もちゃんとお話\nしします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ですが、その……あなたみたいに過激なことはしてなくて……本当に普通の\nエッチをしただけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「どんな体位でしたのかって……普通に正常位ですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「だ、誰もがあなたみたいに、変な体位でエッチなことしてると思わないでく\nださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんなに足を広げるるなんて……すごく恥ずかしいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私のオマンコ、丸見えになってて……あっ、はああぁ……！　オチンチンが\n擦れてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あああぁ……！？　クリトリスを、オチンチンでズリズリしないでっ\n……あっ、あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんなに弄られたら、感じちゃいます……！　まだ挿れてもらってないのに\n、イッちゃいそう……くっ、あふっ、んくぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くっ、あっ、あふっ……！　えへへ……オチンチンも気持ちよくて、ビクビ\nクしてますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私のオマンコやクリトリスに擦り付けるの、そんなに気持ちよかったですか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「早く挿れたいだなんて……は、はい。私も……オチンチン挿れて欲しいです\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「軽く擦られただけなのに、オマンコ感じて……いっぱい濡れちゃいました…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いいですよ……その血管の浮き出た、熱くてカタいオチンチン……私のオマ\nンコに挿れてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……！　やっ、ああぁっ……！　オマンコ拡げられながら、ど\nんどん奥まで入ってきて……あっ、んっ、んくぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ、あっ、んんっ……！　くっ、はああぁ……！　濡れてたせいで\n、一気に奥まで入っちゃいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くっ……はあぁ……！　身体中がポカポカしてきます……オチンチンを挿れ\nられるのって、こんな感覚なんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はじめてだって知らなかった……？　あ、当たり前です……！　セックスは\n好きな人とするものだって、お母さんに教わったので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、んんっ……！　はい……平気です。痛みもありませんから、\n好きなように動いてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そのまま、私の奥をいっぱいズポズポしてください……たくさん、気持ちよ\nくなって……あっ、あんっ……！　あはぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　オチンチンのカタチ、はっきりわかりますっ……！　オ\nマンコの膣内をズリズリされてるの……か、感じるっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「奥まで届いて……くあぁっ……！？　赤ちゃんの部屋、トントンされてちゃ\nってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひっ、あぐっ、んんっ！　そ、そんなに突き入れないでくださいっ……！　\nそれ以上、奥に入りませんからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　くっ、あああっ……！　入らないって言ってるのに、\nどうしてオマンコの奥をグリグリするんですかぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「グリグリして気持ちよくなると、子宮口が開いて、妊娠しやすくなるって…\n…あっ、んんっ！　ダメっ……に、妊娠だなんて……あくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「妊娠したら、お腹が大きくなっちゃいます……！　絶対に隠し切れません…\n…！　お姉ちゃんにバレちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「バレてもいいって……あっ、はああぁっ！　ダメっ、気持ちいいっ……！　\n奥をグリグリされるの、すごく感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　子宮口を責められると、オチンチンでわからされち\nゃうっ……！　赤ちゃん、欲しくなっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんなの、ダメなのにっ……！　あっ、はああぁ！　私の身体が、オチンチ\nンをを求めて……くっ、あぐっ、んふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　はあっ、あっ……くっ、あっあっ……！？　赤ちゃんの部屋\n、開いてきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「精液をどぴゅどぴゅして欲しいって……私の本能が、訴えてきて……くっ、\nああっ！　ひあぁぁぁあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「絶対に妊娠させるって……！　私、人じゃなくて鬼なんですよ……！？　そ\nれでも、いいんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「鬼とかどうでもいい……私だから孕ませたいだなんて……！　そんなこと言\nわれたら、断れなくなっちゃうじゃないですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あふっ、んんっ！　オチンチンがオマンコの膣内で膨らんでるっ……\n！？　あっ、これ、出るってことですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　やっ……！　ビクビクしてるの、感じますっ……！　あ\nっ、んっ、あああっ！　ふあああぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、ああああぁ……！？　熱いですっ！　奥まで精液びゅーびゅー出てる\nの、感じますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「な、なんですかこれ……！　子宮に出されると、また違った気持ちよさが、\n身体の奥から溢れてきます……！　あっ、あはあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「幸せな気持ちが、オマンコがどんどんきて……！　くっ、ああっ……！　ダ\nメっ、幸せすぎて、イッちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、くふっ、んっ……！　あああっ……！　イッ、イクッ……！　イッち\nゃうぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「膣内出しされながら……あっ、イクッ！　イクッ！　イクぅぅぅぅぅ～～～\n～～んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ああぁん……すごいです……本当に膣内出しされちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はい……感じます……子宮の中が、温かい精液で満たされてます……こんな\nの、すぐにでも妊娠しちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！？　どうして、またオチンチンが膨らんで……！？　ま、\nまだ出したりないんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「男の人って、一回出したら終わりじゃないんですか……？　えっ……私とも\nっとセックスしたくて、オチンチンが勝手に大きくなるんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えへへ……好きな人に求められるのって、なんだか嬉しいです……わかりま\nした。また好きなだけ、動いてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くっ、ああっ……！　オチンチンが、オマンコをズリズリしてるっ……！　\nさっきよりも、オマンコ感じちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、はああぁ……！　私のオマンコが、勝手に締まってきてますっ……！\n　い、痛くないですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「気持ちいいから、もっと締め付けて欲しいんですね……！　わかりました…\n…いっぱい、オマンコ締め付けます……んっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふっ、あぐっ、んくうぅ……！　締め付けるほど、オマンコがどんどんオチ\nンチンのカタチになっていってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、んふううぅ……！　ああっ！　気持ちいいっ！　デコボコしたところ\nが、擦れるのすごく気持ちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それ、もっとしてください……！　奥の方だけじゃなくて、浅いところも…\n…！　Ｇスポットのあたりも、ズリズリして……くああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっあっあっ！？　すっ、すごいですっ！　私のビンカンなところ……Ｇス\nポットのところ、トントンされてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私も頑張って締め付けるので、そのままデコボコの部分をＧスポットに押し\n付けながら……スリスリしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んぐっ！　あっ、きゃっ、あああぁ……！？　か、身体のチカラが抜けちゃ\nうぐらい、感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「クリトリスの裏側を刺激されてると……お、おしっこが出ちゃいそうな感じ\nがしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　こんなの続けられたら、簡単にイッちゃいますっ……！　\nあっ、んんっ、ふあぁ……はぁ、あああっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お、オチンチンがどんどん大きくなって、ビクビクしてるっ……！　イキそ\nうなんですねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私も……限界ですっ……！　すごいの、すぐそこまで来てるので……！　一\n緒に、イキたいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あああっ……！　オチンチンの動き、すごく速いっ……！　やっ、あっ！　\nそんなに刺激されたら、もうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ！　んっ、んんんっ！？　イクッ！　イキますっ！　あっ、あ\nっ！　オマンコ、イッちゃいますぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、ぐっ、あひっ……！？　んっ、ふあああぁ……！？　そ、そんな……\n膣内で出すと同時に、奥を突くなんてぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんな不意打ち、卑怯ですっ……！　子宮口開きっぱなしなのにっ……！　\nあっ、あああぁ……！？　くふっ、ひぐうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204302" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ダメっ……！　イッ、イクのとまりませんっ……！　浅いところと深いとこ\nろから、気持ちいいのきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それに、熱い精液をオマンコ全体で感じてっ……！　こんな気持ちよさ、味\nわったことありませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んぎっ、くっ、あっあっ、んぁぁぁ！？　イクッ！　何回でもイッちゃいま\nすっ！　ふあっ、ふあぁぁぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……すごかったです……自分でシても、ここまで感じたことは\nありませんでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「オナニーもするのかって……あ、当たり前です……！　鬼だって、そういう\n気分になることはあります……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私のオナネタを教えて欲しい……？　そ、そんなの言えませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ううぅ……どうしても言わないとダメですか……？　わかりました……ただ\nし、絶対秘密にしてくださいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと……好きな人とのセックスを想像して……つ、つまり、今みたいなこ\nとを思って……ううぅ！　は、恥ずかしいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！？　オチンチンが抜ける感触が、オマンコに響いてきて……\nあっ、あはぁぁぁぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、それに……あっ、んっ、あんんっ！　精液がいっぱい、身体にかかって\nますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、あぐっ……くうぅぅ！　膣内も膣外も、精液を感じますっ！　\n温かいの、感じちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「もっとかけてくださいっ！　濃厚なドロドロ精子、私の身体に好きなだけ撒\nき散らしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、はああぁ……！　幸せですっ……！　精液まみれになるの、\n気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えへへ……いっぱい出しましたね。私のオマンコ、気持ちよかったですか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はい……私も気持ちよかったです。おヘソの下のあたりがじんわりして……\n精液が注がれてるのを感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それに、オチンチンの感触も残ってるみたいで……なんだか、不思議な気分\nです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「でも、さすがにベトベトしすぎてるので……早くシャワーを浴びたいですね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「一緒にシャワーを浴びたいんですか……？　いいですけど、エッチなことは\nしないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}