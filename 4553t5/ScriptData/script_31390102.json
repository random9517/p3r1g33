		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……先ほど敵から変な薬品を浴びせられてから……な、なんだ\nか……んくっ、身体がおかしいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「性的な興奮が治まらなくて……あぐっ……！　アソコが……オマンコが疼い\nて……あはあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「か、カツマさん……なんとか、してくれないかしら……このままだと、歩く\nこともできないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「た、助けてくれるの……？　ありがとう……それじゃあ、あっちに行きまし\nょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ここなら……人の気配もないし、丁度いいわね……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ち、チンポがあてがわれるだけで、感じて……！　オマンコがぐちゃぐちゃ\nになってるの、わかるでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「は、早く……カツマさんのぶっといチンポを、あたしの膣内に挿れて……気\n持ちよくさせて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ふくうううぅ……！？　なっ……なんで、ワレメを擦って……！？　あっ、\nあああっ……ダメっ、感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「クリトリスが亀頭とキスして……気持ちいいの、止まらないわ……！　んっ\n、ぐうっ、ああぁ、んあぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「こんなに濡れてるのに、まだ濡らすだなんて……！　早く挿れてくれないと\n、頭がどうにかなりそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んひいいぃ……！？　また、クリトリス弄られて……！　挿れてって言って\nるのに……まだ焦らすの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……わ、わかったわ……もっといやらしくおねだりすれば、挿れ\nてくれるのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ……か、カツマさん専用の発情メスマンコ……チンポで犯されたくてた\nまらないの……！　好きなだけずぽずぽして、ほじくってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……！　あっ、硬いの、ヌルって入ってくるぅ……！　マンコ\n肉がカツマさんの形に広がって……いえ、広げられてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んひいいいいいぃ……！？　えっ、あっ、ほおおぉ……！？　チンポがオマ\nンコほじってくるぅ……！　こんなの、ダメになるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「い、いつもより感じて……！　あっ、おっ、んほおぉ……！？　ぬちゃぬち\nゃのムチムチオマンコ、チンポ気持ちよくさせる穴になるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「こ……これ、本当にダメ……！　動かれたら、もっと発情する……！　膣奥\n押されてただけで、絶対にイク……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「か、カツマさん……！　もう、大丈夫だから……！　挿れられて、興奮治ま\nったからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「だ、だから……う、動かないで……！　お、オマンコほじほじしないで……\n！　あっ、あああぁ……！　ダメっ、ダメ……！　ダメええええぇ！！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ふああああぁ～～～っ！？　あっ、あぁんっ！　ひあああぁんっ！？　イッ\n、イッてるぅ……！　挿れられただけで、達してるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「もっ……もう、十分よ……！　イッたから……は、発情してるの、治まった\nからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んひいいいぃ！？　太いチンポ動いてるぅ！　カリ首がオマンコをかきわけ\nて、発情マンコ突いてきてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ば、バレてる……！　発情が治まったとか、ウソついてるのバレてるぅ……\n！　ゆ、許して！　ウソついたこと、謝るから……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「せ、せっかく協力してやってるのに、ウソをついたからお仕置きしてやるっ\nて……！　そ、そんな……！　そんなことされたら、私……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あはああぁ～～～！？　オマンコの奥っ！　私の大事なところ、グリグリし\nないでえぇ！　凶悪チンポが、オマンコと子宮口を折檻してるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、オマンコダメにされてるぅ！　あっあっ、ぐううぅ……あ\nはああああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、んはああぁんっ！　ゆっくり引き抜くのもダメぇ！　カリがＧ\nスポットに引っかかって……んんんっ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「すごいっ！　気持ちいいの止まらないぃ！　ハマっちゃうぅ！　カツマさん\nのチンポ奴隷になっちゃううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ど、奴隷じゃないですって……！？　そんな……！　こんなにもチンポで躾\nけられてるのに……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あなた専用のオナホール……？　いつでもどこでも、チンポを挿れて精液を\n出すだけのメス穴……！？　そんな……性処理道具みたいな扱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んひいいいいぃ！？　わ、わかったわ……！　ど、道具っ！　道具だからっ\n！　私はカツマさん専用の、チンポコキ穴だからあああぁ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっ、あっ！？　イッ、イクぅ！　ただのオナホールなのに、カツ\nマさんより先にイクうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「おほおおぉ！？　チンポビクビクしながら、子宮口突かれてぇ！？　か、カ\nツマさんもイクのね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あんっ、あはあぁんっ！　イッ、イクッ！　イクうううぅ！　私の性処理オ\nマンコに、ザーメンいっぱい膣内出ししてえええぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あはあああぁんっ！　お、オマンコの奥に出てる！　ドロドロのザーメン、\nびゅるびゅる出てるうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「子宮の奥まで流れ込んでるっ！　こ、こんなの、我慢できない……！　また\nイクッ……！　膣内出しでイクううううぅ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はあああぁ……す、すごいわ……！　快感で、脳が焼き切れるかと思ったわ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あ、ありがとう……もう本当に発情も治まったから……チンポを抜いて、ん\nんっ……そ、そう……ゆっくり抜いて頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「えっ……ちょ、ちょっと待ちなさい……！　どうして、抜くのを途中でやめ\nるの……？　ま、まさか……！　いっ、イヤ……それは、ダメ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んほおおおおぉ～～～～～！？　ま、また……！　オマンコの奥まで……ち\n、チンポが刺さって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「い、今ので……また、イッて……！　んひいいぃ！？　ぜ、全身がビクビク\nして、痙攣が治まらないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「や、やめて……もう本当に、これ以上は無理……！　んひいいいいぃ～～～\n～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「イヤああああぁ！　もうパンパンしないでっ！　オマンコほじほじしないで\nえええぇ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ひいいぃ！？　せ、専用のチンポ穴なら、喘いでないでオマンコ締めろだな\nんて……！　あ、あれは冗談じゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はひいいいぃ！？　し、締めるっ！　オマンコちゃんと締めるからぁ！！　\nだから、そんなに激しく突かないでぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ、ぐっ、あああぁ！　オマンコ締めれば締めるほど、チンポ感じ\nるっ！　カツマさんの形になってるから、気持ちいいの止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、んはあぁ！？　　すっ、すごいっ！　イったばかりで敏感なオ\nマンコに、容赦なくチンポ打ち付けられてるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「さっきよりも大きくなったチンポが、膣内をごりゅごりゅ抉ってるのわかる\nっ！　何度も引っ掻いて、オマンコ犯してるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あ～～っ！　あああぁ～～～っ！！　ダメっ！　イクッ！　イグうううぅ！\n　またオマンコ、イッ、イグううううぅ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はああぁ……！　ま、また気持ちいの、きてる……！　もう、\nなにも考えられな……いひいいいいぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「押しつけながらグリグリしないでぇっ！　それ、本当にダメなの！　私の弱\nいところを、的確に責めてるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「えっ……か、勝手にイッた罰……？　そんな……！　こんなにも気持ちいい\nのに、イクの止められるわけが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！？　また子宮口をズンズンって！　あっ、あっ、はひぃいいっ！\n？　また、イクううううぅ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「イクの止めるなんて無理だわっ！　カツマさんに犯されると、身体とオマン\nコが悦んで、イクことしかできないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0104215" ]},
		{"command":[ "WAITINPUT" ]},

