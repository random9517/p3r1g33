{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えぐっ……うぐっ、ぐすっ……うっ、んぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ、あー……その……んむ……えぇと、ですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさっ……うぐっ、んっ……おとーさっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「と、とにかく……一度戻りましょうイルル殿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「で、でもっ……えぐっ……おとーさんがっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「大丈夫です。あれで、ご主人はなかなかしぶといのです。必ず、無事でまた\n姿を見せてくれますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……うぐっ……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そ、そうです、こういう時は……エファ殿に助けを求めましょう！　お母上\nがきっと何とかしてくれる筈です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「お……かーさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい。さあ、どうかお泣きやみ下さい。イルル殿が、ずっと泣いてると、私\nも悲しくなってしまいますぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ……うんっ、うぐっ……うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さあ、私が責任を持って帰り道をご案内しますから、どうぞこちらへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん……あの……えと、ワンちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうかされましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「帰り道……たぶん……こっち」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780008" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ……そ、そうでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イルルちゃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うっ、うぇぇぇぇっ……お、おかーさっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780009" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どうしたの一体っ……カツマさんは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「その、それがですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうだったの……怖かったわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぐっ……イルルは……大丈夫……だけど……えぐっ、お、おとーさんがっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780010" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ヤムって言ったのね……彼女が連れ去ってしまったと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はぁ、その……雰囲気としては人質のようなもので……ただ、どうも目的と\nしてはイルル殿の筈なので、よく分からないのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「確かに、イルルちゃんを連れ去る方が理にかなってるわよね……けど、彼女\nの状態じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうも、イルル殿の母親について浅からぬ因縁があるということでしたが…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「母親ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさっ……おとーさんっ……助けてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780011" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イルルちゃん……カツマさんを助けたいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うんっ……おとーさんっ、イルル守ってくれたのっ、けどっ……イルルっ…\n…何も……出来なくてっ、うぐっ……だからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780012" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「分かったわ。ちょっとだけ待てる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「う、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021780013" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうなさるおつもりなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イルルちゃんのことは、こちらでも気にしてはいたの。そもそも、どうして\nうちの倉庫に眠っていたのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780009" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「その手がかりが眠っている場所が……恐らく、ＥＤＯの書庫……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「書庫……あそこは全く掃除されていない魔窟ですぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ええ、それこそ倉庫の比じゃない程に、あらゆる物が埋もれている危険な場\n所……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780011" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「けれど、今のＥＤＯにはうってつけの人物がいるわ。彼女に頼んでみましょ\nう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こ、これは……素晴らしい場所ですっ……正しく財宝の山、叡智の集まり…\n…世界の深淵の一部がここにあると言っても過言ではなく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「盛り上がっている所悪いんだけれど翔生子さん……貴方にお願いしたい仕事\n……分かっているわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780013" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ……し、失礼しました。はい、この書庫の中から竜の伝承にまつわる古文\n書を見つけ出して読み解いていくということですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780002" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ええ……これだけ膨大な資料の中から見つけるのは大変だと思うのだけど…\n…増援を出そうにも、古代知識に精通した者はなかなか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780014" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「分かっています。そして、無事に見つけ出した時には、この書庫の中身を自\n由に閲覧できると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780003" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ええ、約束しましょう。それで、どれくらい時間が掛かりそうかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780015" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ほんの少しお待ち下さい。ええと……これは……これ……こっちが、これ…\n…それで、この辺が……なるほど、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780004" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780016" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「とすると、まず最初に調べるべきは……大体……ここから４列ほど奥……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780005" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは……何をなさっているんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021780014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「何か彼女なりのアプローチがあるんでしょう。素人が口出ししても仕方ない\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780017" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……ああ、やっぱり。後は……けほっ、ちょっとホコリっぽいですが……表\n紙を……探して……あっ、この辺がよさそうですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780006" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「えっ……も、もうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021780018" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃに積まれてるように見えますけど、あまり手が入っていないよ\nうで、蔵書は大体時系列に並んでいるようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780007" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「イルルちゃんと竜の伝承ということを結びつけるのは、恐らくイルルヤンカ\nシュ……ヒッタイト神話に関わるもので、そうすると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021780008" ]},
		{"command":[ "WAITINPUT" ]},

