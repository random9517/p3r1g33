		{"command":[ "PLAYVOICE", "v2_001_1404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「で、出るっ……！？　あぁっ、待てっ……お尻の中にはっ……あぁっ、しゃ\n、射精は待ってっ……そんなのされたらっ……私はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁぁんっ！　と、止まらないっ……チンポ止まらないっ……！　\nあぁっ、お尻っ……熱いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……ぐじゅってっ、あっ、もうっ……ダメだっ……本当にダメェっ\n……来ちゃうっ、あっ、ひぁぁぁんっ！」", "NORMAL" ]},
