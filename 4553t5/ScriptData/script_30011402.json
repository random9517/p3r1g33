		{"command":[ "SETIMAGE", "0", "still_00000114_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　な、馴染んでるって……あぁっ、精液がっ……ぐちゃって……そ\nんな、お尻の中で……かき混ぜるなっ……はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あくぅっ……あっ、あぁっ……も、もっと……肛門を締め付ける……？　そ\nんなことまでさせるつもりか……ひぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、分かったっ……するから、尻を叩かないでくれっ……ふっ、んぐっ……\nんくぅっ……こ、こう……かっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……！　くぅっ……ふぐぅっ！　んぁぁっ、締め付けてるっ……！　\n太いチンポをっ……私のお尻の穴でっ……ぎゅって窄めてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぉぉっ！　チンポに引っ掛かるっ……ぐりぐりっ……出ていく時に、擦れ\nるのぉっ、あっ、あぁぁぁっ！　それぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、んぁぁっ……どうしてっ……あぁっ、お尻っ……よくなっ\nてるっ……！　チンポでっ、ズボズボっ……中をかき回されてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、ドキドキするっ……！　お尻っ……辛い筈なのにっ……熱くてっ\n、ムズムズしてぇっ……気持ちっ……よくなってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぉっ……今のとこぉっ……あぁっ……！　押し込まれたままっ……腰を回\nされるとっ……気持ちいいのっ……広がるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、あひっ！　ダメだっ……こんなのっ、続けてっ、あっ、されたらっ…\n…あひぉっ、気持ちっ……良すぎるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナル好きなんてっ……違うっ……断じて私はっ……そのようなことはっ、\nあぁっ、待ってくれっ……今っ、そこはっ、あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「またっ……あっ、チンポ深くてっ……お尻おかしくなっちゃうっ！　はひぁ\nっ、あぁっ……お尻っ……気持ちよくなっちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこぉっ、あくうっ……はひぁっ……硬くて熱いのっ……みっちり\n……詰め込まれてぇ……お尻っ……イ、イキそうっ！」　", "NORMAL" ]},
