		{"command":[ "PLAYVOICE", "v2_001_1404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……はぁ……はぁ……んっ、あっ、あぁっ……な、何をしている\n……もう終わったんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　あっ……そんなっ……続けてっ、ま、まだチンポが硬いから\nってっ……もう一回っ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待ってくれ……今、お尻の感覚が変なままでっ……あ、ひっ！　ぐりってっ\n……あくぅっ、あおぉっ、続けて……するのはっ、あっ、あぉぉっ！」", "NORMAL" ]},
