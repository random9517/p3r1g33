		{"command":[ "PLAYVOICE", "v2_001_1404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっく……あふっ……と、止まった……？　はぁっ、はぁ……はぁっ、あふ\nぁ……」", "NORMAL" ]},
