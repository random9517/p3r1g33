		{"command":[ "SETIMAGE", "0", "still_00000114_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、あぁぁっ……くぅっ……抜けていくっ……あっ、あぁっ！\n　またっ……奥にぃっ……くひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぐぅっ……ダメだ……この出し入れはっ……身体がっ、受け付けないのに\nっ……勝手にっ……食い締めてぇっ……ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ、あくっ……んんっ、違うっ……チンポを喜んでっ……食べてな\nんかぁっ……あっ、ないっ、あ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
