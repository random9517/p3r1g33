		{"command":[ "PLAYVOICE", "v2_001_1404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違うっ……感じてないっ……お尻で気持ちよくなるなんてっ……そんなこと\nっ、ダメだっ……ダメっ……なのにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はひんっ！　あぁっ、いやらしい音っ……さ、させるなぁっ！　あぁっ、チ\nンポっ……ズボズボされたらっ、お尻っ……ダメになるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000114_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
