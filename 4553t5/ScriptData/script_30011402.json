		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、あっ、あぁぁぁっ！　ダメだっ……イクッ、あぁぁっ、チ\nンポっ……ズボズボされてっ、お尻っ……イクぅぅぅぅっ！」」", "NORMAL" ]},
