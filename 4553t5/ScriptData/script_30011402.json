		{"command":[ "PLAYVOICE", "v2_001_1404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁんっ、どこでもっ……何でもいいからっ、あぁっ、熱いのっ…\n…いっぱい射精……してぇぇっ！」", "NORMAL" ]},
