		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……あぁっ、やめろ……チンポをお尻になんて……ま、間違っているっ\n……あぁっ……待ってくれっ、そこはっ……あっ……！」", "NORMAL" ]},
