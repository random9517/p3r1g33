		{"command":[ "SETIMAGE", "0", "still_00000114_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「く……ぅぅぅぅぅんっ……！　んくぁっ……あぁぁ……めり込んで……来て\nる……な、何だこれは……あぁ……ビーズなんかと……全然違うっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「肛門が……広げられてぇ……んくうっ……ち、力が入らないのに……どんど\nん奥に……チンポが……入り込んで来るっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぅぅ……あぁ……キツい……息が出来なくなる……この圧迫感……ダメだ\n……んふぁぁぁっ、はっ、あぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、んくぅ……ね、根元まで飲み込んでしまった……そんな……\n私のお尻に……チンポが……全部……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「く……んぅぅぅ……熱い……内側から燃やされてしまうような……んっくっ\n……感じが……するぅっ……はぁっ、はぁっ、あぐっ……」", "NORMAL" ]},
