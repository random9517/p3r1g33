		{"command":[ "SETTEXT", "「んはぁぁぁぁぁぁ……あぁぁ……あふっ……んくっ……くぅぅうっ……あぉ\nっ、まだ……お尻……かき回されてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
