{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_003" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……くっ！　裏切り者どもめ、なかなかしぶといな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010101040001" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから裏切ったのはそっちが先だろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「相手は幹部５人……！　カグヤとムーンナイトが味方になってくれても、や \nっぱり厳しいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "続けざまに戦闘行ったせいか変身時間が限界に達したのか、十五夜姉妹は\nシルバスター状態から普段の姿に戻ってしまっていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから！　俺たちはまだそっちについたわけじゃない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "あー、もう、ホントにややこしいことになってきた。いっそのこと、こいつら \nが戦ってるうちに俺だけでも逃げだすか……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「むむ！？　ご主人様？　あれはなんですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何って、ただの空じゃねえか。お前とうとう頭が……あ！　ああっ！？　な \nんだありゃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「むっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あああああっ！　まりあ姉ちゃん、見て！　空にヒビが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「空が、割れた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「中からなんか出てくるぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "侵略者" ]},
		{"command":[ "SETTEXT", "「同胞たちよ。叩け！　壊せ！　破壊せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "901_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんと、次元の間から次々と現れた異形の人形生物が街を破壊しはじめる！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「街を、壊してる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだありゃ！　おい！　あれもお前らの作戦か！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前らって我々か！？　知らん！　知るはずがないだろう！　そちらではな \nいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わたしたちが、街を壊したりするわけないでしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだそうだー！　そういうことするのは、あなたたちでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んなわけがあるかい！　あたしたちは、壊す場所は慎重に選んでるんだよ！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……慎重？　そうだっけ？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうよ～！　若いイケメンに被害が出たりしたら、大変じゃないの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ああ、まあ、そういう意味じゃ慎重と言えなくも――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわぁああああっ！　まただ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "次から次へと湧き出してくる侵略者たちに被害が拡大していく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETNAME", "侵略者" ]},
		{"command":[ "SETTEXT", "「我々はこの次元を破壊するべくやってきた、……慈悲はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "901_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "侵略者" ]},
		{"command":[ "SETTEXT", "「さぁ、同胞たちよ。この世界を壊してしまうのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "901_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おいおい、あいつらメチャクチャしやがるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いかん、このままでは我々の目的も達成出来なくなる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様、ここはひとまず争いをやめて、共通の敵を討つのが先決では \n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと？　どういう意味だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「シルバスターと一時手を組む、ということです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「じょーだんじゃないわよ～！　なんでこいつらと手を組まなきゃならないの \n～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「こっちだってお断りだよ！　街を壊すようなヤツらと手を組むなんて！　で \nしょ！？　まりあ姉ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……待て。それはおかしくないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきはお前たちも似たような理屈で、俺とカグヤに手を組もうって提案し \nたよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「やっぱりか！　この裏切り者ーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はいはい、外野はちょっと黙って！　えーと、とにかく、どうなんだ？　俺 \nたちと手を組めて、あいつらと組めないってことはないだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは……たしかにその通りね。こちらとしては、街への被害を食い止めら \nれるのならば、一時的にＧ・ルナリアムとの休戦、共闘を受け入れます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まりあ姉ちゃんがそう言うなら……そっちはどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こちらとしても、占領予定の街を破壊されるのは本意ではないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ！　まりあ姉ちゃん大変！　あいつら、逃げる人たちを狙ってるみたい \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101040007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……とにかく考えておいて！　そちらの返事がどうあれ、わたしたちはヤツ \nらと戦います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "十五夜姉妹は、またシルバスターに変身し直すと走り去っていった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ルナ様～？　どうしましょう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「今ならば、背後からシルバスターを仕留めることもたやすいかと思われます \nが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……いや。シルバスターの言う通り、当面の障害は突然現れたあの『侵略者 \n』どもだ。奴らに街を破壊されては、我々の目的自体が水泡に帰すこととなろ \nう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なるほど。では……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101040004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「総員攻撃開始！　これよりシルバスターを援護する！　我らの敵はただひと \nつ。『侵略者』どもを排除せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101040009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "幹部たち" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "000_010101040004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "幹部たちも、シルバスターのほうへと向かっていく。さて、俺たちはこの隙に \n……", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、私たちも。……さっきの借りを返さないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あ、やっぱり？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですな。先ほどはずいぶん助けられたのですから、今度はご主人がシルバス \nターを助けるのは当然かと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101040002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから他人事みてえに言ってんじゃねえ！　お前も来るんだっつーの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}