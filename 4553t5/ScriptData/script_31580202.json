{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ごめん、ご主人……少し時間貰っていい？　実は新しい魔法の練習をし\nてたんだけど、ちょっと失敗しちゃったみたいでさ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっちなエラー止まらくなっちゃって……んっ……魔力も限界まで使い切っ\nちゃったみたいで……精液での魔力補填、お願いできないかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うわぁ……何そのニヤニヤした顔……んんっ……嫌な予感しか、しないんだ\nけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああっ、待って！　行かないでご主人！　……ほ、ほんとにちょっと限界な\nの……言う通りにする、から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――え？　この『魔女の本』を置いてその上に跨れって？　うぅ……人が反\n抗できないのをいいことに、この鬼畜ご主人め……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こ、これでいいの？　足をもっと下品に開けって……うぅ……さ、流石にち\nょっと、恥ずかしすぎるんだけど……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015802_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「折角の新パーツをこんな風に使わせるなんて、ほんと信じらんない――んひ\nゃっ！　ご、ご主人、本、揺らされるとっ、あふぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「角の所に、おまんこグリグリ当たってっ、あっ、ふあぁんっ！　ま、まんざ\nらでもないっていうか、身体が変になってるんだってばっ、あひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人、お願いだから……んふぅんっ……おちんちん、入れてよ……本\n当に我慢、出来そうになくて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おねだりも、しっかりするから……ご主人のたくましいおちんちんを、ぐち\nょぐちょおまんこに突っ込んで、いっぱい魔力、出して下さい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うぅ……仕方ないでしょ、本当にきついんだってば。魔力を補填してもらえ\nれば、この失敗した魔法もどうにかできると思うからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――って、ご主人！？　そ、そこ後ろの穴だよ？　どうしておちんちんの先\nっぽを宛がってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まってまって！　魔力補填はおまんこの奥にある生成機関に精液を出しても\nらった方が効率的なんだって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　肌からの吸収でも魔力補充できるんだからアナルでもいけるって？　\nそ、そう言う問題じゃ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぐぅぅぅっ！？　おっ、うぅぅぅっ！　ほ、ホントに入れたっ、おちんち\nん突っ込んできた、この鬼畜ご主人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そ、そこは補給するところじゃないのにっ、おっ、んおぉぉっ！　奥までお\nちんちんグリグリ来てっ、おっ、んひぃぃんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んおぉぉんっ！　い、いきなりアナルで感じ過ぎだろ、って\n……そ、そんな呆れた声出さないでよっ！　んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぜ、全身敏感になってるんだって言ってるでしょ！　あっ、あひぃんっ！お\nちんちんずぼずぼされちゃうと、変な声止められないっ、んおんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「排泄の必要もない身体なのにアナルを搭載してるのはこういう時の為だろっ\nて……うぅ、確かにそう、でもあるんだけどっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「い、今は本当に、感じ過ぎちゃってっ、んおっ、おぉぉんっ！　さ、察して\nよご主人、恥ずかしいんだってばっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひぃんっ！　お尻パチパチ叩かれたらっ、んほぅうんっ！　一緒にアナル\nもズボズボ、おちんちんっ、あっ、んひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　あ、アナルじゃなくてケツまんこ？　け、ケツまんこ凄いっ、おちん\nちんでケツまんこ穿られるのっ、気持ちいいっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいのに、恥ずかしいはずなのにぃ……おっ、んほぉおんっ！　気持\nちいよご主人、恥ずかしいのが気持ちいいのっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ま、また本がおまんこに食い込んでっ、んあぁんっ！　がたがた左右に揺ら\nされると、おまんこの割れ目に背表紙が食い込んでいくっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のおちんちんが、ケツまんこの中で、どんどん大きくなってるのが分\nかるよ。ビクビクって、小さく跳ねて、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、んふぅぅんっ！　だめ、自分でも腰が動いちゃう……ああぁ\nんっ！　ぐりぐりって本におまんこ押し付けるの、気持ちよくてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人、ま、またお尻もぺんぺんしてよ！　私に優しくしないで、ちょ\nっと痛くしてほしい、かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――そ、そりゃ恥ずかしいよ？　でも、今のパーツを搭載した私は素直なの\n。大好きなご主人に、いっぱい甘えたい、から」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひゃぁんっ！　きた、お尻ぺんぺん好きっ、あぁんっ……！　恥ずかしい\nのに、気持ちよくてっ、んやっ、ふあぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ジンジンって、痛覚センサーが反応してるはずなのにっ、んふぅんっ！　そ\nれが快感に変換されちゃってっ、んひゃ、んふぅうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「エラーがどんどん増えていくっ、ノイズ走ってっ！　おっ、んおぉぉんっ！\n　ケツまんこを無茶苦茶に突かれるのもっ、よすぎて、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お、おまんこも、ぐりゅぐりゅするの！　おっ、あひぃいぃんっ！　大事な\n魔導書をこんなえっちなことに使ってっ、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おっ、んほぉぉんっ！　もうイク、私もうイクからねご主人っ！　んふぅん\nぅっ！　もう我慢、できないからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のおちんちんも限界なの、伝わってるよっ、んふぅんっ！　ケツまん\nこの奥で、どんどん大きく膨らんでっ、おっ、んほぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んほぉおんんっ！　エラー止まらないっ、ホントに身体壊れちゃいそう、だ\nけど、んひゃんぁ！　イクから、ご主人も一緒に、ふあぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だ、出して！　このままケツまんこの中に、魔力の詰まった精液をいっぱい\nぶちまけて！　私のケツまんこをドロドロにしてぇぇ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひぃぃいぃぃんっ～～！！　出てる、おちんちんビクビクして、熱い精液\nがっ、おっほぉおんっ！　ケツまんこの中、ドロドロになっちゃうの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わたひもイッてる、ケツまんこでイッてるっ！　んほぉっ！　恥ずかしいの\nが嬉しくて、イッてるのっ！　あひっ、んあぁぁんんっ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――はぁ、はぁ……ご主人、ホントに大量に出したね。んっ……ちょっとお\n腹が重い、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ……ありがとね、ご主人。魔力の方はちょっとは持ち直したみたい。\nこれなら身体のえっちな不調も治せるはず……なんだけどさ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のおちんちん、ガチガチのままだよね？　んんっ……分かってるよ、\nまだ物足りないんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……このままもう一回、しよ？　ご主人に甘えさせて？　私のケツまんこを\n、思う存分、苛めてほしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んほぉおんんっ！　それっ、それが好きなのっ、じゅぶじゅぶって下品で恥\nずかしい音を立てながら、ケツまんこ穿られるの、気持ち良いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこも弄ってっ！　大事な『魔女の本』を乱暴に揺らして、おまんこぐ\nちょぐちょしてほしいのっ！　あひっ、あっ、んひゃあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「で、でも、今度は私もこーゆーことできる、からっ、あぁんっ！　少し回復\nした魔力で、こうやって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「けつマンコの奥で暴れるおちんちん、集めた魔力でぎゅっぎゅって！　んほ\nぉんっ！　亀頭を包み込んで、コネコネしてあげる、からっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「けつマンコの入り口もこうやって締め付けてあげるっ！　んんっ！　ご主人\nが言ったんでしょ、排泄はしないのに何のためにアナルが付いてるんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こーゆー時の為、だよ！　んふぉんっ！　ご主人に悦んでもらう為に、私の\n身体はあるんだからっ、おっ、んおぉっぉんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ケツまんこ全部でおちんちんぎゅっとして……あっ、んあぁんっ……おちん\nちん、根元から全部しぼりとってあげるっ、おっ、んおぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、おっ、んほぉおんっ！　膨れ上がった亀頭が、ケツまんこの壁、ガ\nンガン叩いてくるっ！　全身に響いてっ、おっほぉおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「は、はげひすぎるっ、ご主人にケツまんこ壊されひゃうっ！　んほっ、おひ\nっ、んほぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やぁんっ、言わないで、みっともない声聞かれちゃってるの分かってるから\n、わざわざ指摘しないでっ！　おっ、んほおぉんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お尻もまたぺんぺんしてっ、んひゃぁんっ！　あひっ、あっ、あひゃぁんっ\n！　パーツがジンジン熱くなるのが、気持ちいいよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、私だって、負けない、ご主人に気持ち良くなってもらうんだからっ！　\n魔力を使って、ご主人のおちんちん、左右に振り回してっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だ、だめぇ、もう繊細な魔力操作なんてできないよっ！　私、魔女なのに、\nウィッチパーツを搭載してるはずなのにっ、あひっ、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「素直になるしかできないのっ、ご主人のおちんちんで苛められて、下品でえ\nっちな声出して可愛がってもらうしかできないのっ！　おほぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「またくる、大きいノイズが走ってっ！　おっ、おほぉんんっ！　い、いいよ\nね！　ケツまんこでイッちゃっても、いいよね！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おっほぉっぉんっ！　おちんちん、ケツまんこで跳ねた、ふあぁん！　ビク\nビクって熱くてっ、ご主人もまた射精しちゃいそうなんだ、んほぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「このまま、またケツまんこに出してほしい、けどっ、あひゃぁんっ！　身体\nにもぶっかけられたいっ、ご主人の精液でお尻をドロドロにしてほしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、きてぇっ！　おっほ、んおぉぉんっ！　好きな所でいいから、おち\nんちん、びゅーびゅー射精してっ！　ご主人と一緒にイクからっ――！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おっほおぉぉぉおぉぉんっ～～！！　あひっ、おっ、んおぉぉぉぉっ！！ど\nろどろ精液、ケツまんこの一番奥まできてるぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「濃厚な魔力が、ケツまんこから広がってっ！　おひっ、おっ、んおぉぉぉっ\n……！　にゃにこれっ、思考回路が壊れひゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、はっ、あははははっ！　イクの止まらない、嬉しい、一緒にイケて\n嬉しいよぉご主人！　おっ、んおぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、好き、大好きだから！　もっと感じさせて、ご主人の熱を、ケツま\nんこの奥に！　魔力をいっぱい注ぎ込んでぇ～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ……おぉぉ…………ほ、本当にすごいノイズの嵐、だったかも\n……こ、今度ばかりは、本当に壊れるかと思った……ぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さ、流石のご主人でも、もう出し切った、よね？　んっ……お腹揺らすとご\n主人の精液でたぷたぷ聴こえてきちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ありがとね、ご主人。こんなにも魔力をくれて……私を愛してくれ\nて、甘えさせてくれて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん……こんなに素直に言葉が出てくるんだもん、ウィッチパーツに換装し\nたのはやっぱり大正解だったかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――さて、次はどんな私を望むかな、ご主人？　ドＳな私？　ドＭな私？　\nお嬢様な私？　パンクな私？　元気な私？　物静かな私？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人が望むのなら、どんなパーツだって取り寄せて、ご主人好みに換装し\nてあげる。だって私は、ご主人の所有物、だからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んほぉぉぉんんっ～～っ！！　ケツまんこから、おちんちん抜けてっ……あ\nひぃんっ！　お尻に熱い精液、ぶっかけられてるっ、ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、ご主人にマーキングされてるみたいで、嬉しいっ、あっ、ふあぁんん\nっ！　私はご主人様の所有物、だからっ、あっ、あひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「か、考えるだけでっ、イクの止まらないっ、あっ、あぁんんっ！　ボディを\nドロドロに汚されるのが、気持ちよくてっ、あぁあんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お、おまんこも、気持ち良いっ……！　『魔女の本』グリグリして、あひっ\n、イッてる、おまんこでもイッちゃってるよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ……ぁぅ……こ、こんなエラーの数、始めて、かも……魔力は\n充填できたけど、壊れちゃうかと思った……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇご主人、このお尻の穴、閉じるようになると思う……？　おちんち\nん抜かれてからも、開きっぱなしなんだけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015802_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「部品の交換……？　できればメンテナンスでどうにか……ねぇ、何笑ってる\nのさ！　ご主人のせいなんだから、責任……とってよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……まぁ、直らなかったら直らなかったで、次のパーツを探してみるのも面\n白そうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さて、次はどんな私を望むかな、ご主人？　少女な私？　大人な私？　制服\nな私？　ロックな私？　ボーイッシュな私？　厨二病な私？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の望む通りの私になってあげる。だって私は、貴方だけのお人形、だ\nからね？　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}