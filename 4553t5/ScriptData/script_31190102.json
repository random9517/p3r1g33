		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「んぁっ……あっあぁっ！た、隊長さま……っ！何を、何をするのですか……\nッ、ああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「急に呼び出したかと思ったら……！私の、女神の身体を拘束……するなどと\n！これは問題行為ですよっ……は、外しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「な、なぜこのようなことを……。いやっ！ま、待って！そんなにがっちり動\nきを封じられたら……、に、逃げることもできなく……ああああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……ふ、ぅ……ふぅ、ふぅ、ふぅ……。だめ……まったく動けません……。\n隊長さま……これは普通の拘束具ではありませんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「おそらくは、私のためにだけ開発された……。特注のもの……。んっ！しょ\n、証拠に、全力を出してもまるでビクともしないのですから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……このまま？ここでじっとしていてほしい……？世迷いごとを……！そん\nなことをして、何の利益があるのです！……私の身体が、開発されたから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「毎日毎晩、限界まで熟れた肉体を放置して……。淫らな気持ちを盛り上げる\n……？……そ、そんな……！冗談、ですよね……放置？放置とは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「このまま、私は一人にされ……あっ！い、行かないでくださいっ！置いてい\nかないでっ……あ！あぁ！解いて、解いてください、これを……いやあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「………本当に……行ってしまった……。んっ……確かに、色々なところが疼\nいてしかたない……。薬をもられた？いいえ、違う……。こ、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「触れられないと意識すればするほど……。んんっ、私の身体が、切なくなっ\nて……勝手に反応してしまっている……！はぁ、はぁ、股間が潤んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「乳首、が……勃起して……あぁ……！それだけなら耐えられても、……皮膚\nも、敏感になって……。ぁっ……クリトリスがくっきり……。っ……ぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「た、隊長さま！隊長さま！お願いです！まだ近くにいるのでしょう！こんな\n悪趣味なことはやめてください！……く、苦しい……もどかしいのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、こ、こういう条件ならばどうです！？拘束はしたままでかまい\nません、ですから……触っていただけませんか！？どうか、どうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「空気に触れているだけで……。ぁ……感じ、て……しまうんです……。ん…\n…。隊長さま……！隊長さまぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「………。何の音もしない……。本当に、見捨てられてしまったの……？あぁ\n……。疼きが止まらない、あ、愛液が溢れ出して……びちょびちょに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……なんとか、一部分だけでも……！んんんっ……！んーっ…\n…だめ……計算されつくしてる。どこにも手が触れない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ、あぁ……。うう……。んぅっ……うぅ……はぁ、はぁ、\nはぁ……うう……。……んっ？た、隊長さま！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「良かった！戻ってきてくださったのですね！でしたらどうにかお慈悲を！…\n…お、お慈悲とは何か、ですか……？あ、私の、乳首やアソコを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「っ、それではわからない？あ、あの……！私の、はしたなく勃起して上を向\nいている乳首、とだらしないお乳……それから洪水になっているオマンコを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「いじっ……いじってください！イカせてください！……っ……ま、まだだめ\nなの……？うぐ……であれば……もう、し、仕方ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ド淫乱性欲狂いの女神、石凝姥命のヌルヌルオナホールオマンコに隊長さま\nの極太黒光りオチンポを挿入して、イくまでピストンしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「その時、私の、大きなだけで何の生産性もないスケベ専用下品おっぱいと！\nその先端でビンビンになっている乳首を同時に攻めてもらえませんか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……うぅ……恥ずかしい……恥ずかしい……！っ……あっ、し、してくれる\n……のですか？あっ、い、淫語を言っている間だけ！？わ、わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「愛液垂れ流してヒクヒクしている私の肉穴に！私の大好きな、大好物のガチ\nガチオチンポを入れてくださ……！ッあああああっ！入って、入ってきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ひぁーーーああっあああああっ！チンポ！チンポ入れていただきましたぁあ\nあ！腰を、腰を振ってください！私も情けない雌犬のように尻を振りますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あひっ、ひぃっ、ひぃっひぃいっ♪ぉおっ♪おぉっ♪き、気持ちいい！気持\nちいいですっ！女神だからってもうどうでもいいですっ、気持ちいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「オマンコッオマンコにオチンポどちゅどちゅしててくださいっ！んぁおお♪\nおまんこっ、おまんこにチンポ入ってないと私だめなんですっ、ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「お……っきぃいい♪棍棒みたいな太マラおちんぽっ、ゴリゴリ男根で貫かれ\nながら……ああっ！胸を上下左右に揺らすのが、好き、好きですっ、好き！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ、おっぱいも触ってください……！いいえっ、ちぎれるくらい握\nって！鷲掴みにして、握りつぶしてぇ！手の痕がつくくらいぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……っそうっ、そうですうっ！おっぱいっ！ひどくされるとオマンコがうね\nうねうねっちゃうの、アソコがビクビク痙攣しちゃうんですっ！あーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「うれ、しい……嬉しいっ！ミチミチにオチンポ挿入していただいてっ！おっ\nぱい……っ、おっぱい、痛いくらいに揉みしだかれ、てぇえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「もう絶対に抜かせませんっ、このオチンポは私のものですぅうっ！あーっ！\nあーっ！中で、膣内で動いてる……ぅ、オマンコ蹂躙されて……るぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「でも、それがいいの、それがいいのですぅうっ！あぐっ、んぐぅっ、んぐぅ\nうっ♪オマンコ、オマンコに大きいの入ってるの好き、好き、好きぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「っあひぃいっ、ひぃいっ、ひぃっ……！あーっ！あっあっあっ！いやっ！愛\n液が噴き出して……ああっお潮吹いちゃった、あっ、お漏らし、するくらい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「オチンチン好きですぅうう！あっ、あーっ、あーっあーっ！そうですっ、私\nはオチンポ狂いのオチンポ女神ですぅうっ！あぁ、あぁ犯して、犯して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「犯しながら種付けしてくださ……い、アッ♪そうですっ……私、隊長さまに\n種付け……してほしい、人の子に孕まされたいのですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「出して……出し、て……あっ！あぁ、も、もどかしい……ぃっ！自分から精\n液迎えにいきたいのに！出してぇ！お願いです、出してくださ、い……あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「んふぅうううっ！ふぅうううーっ！びゅくびゅくっ、ビュブビュブ……！あ\nあ、ああ、膣内に思い切り精液が撃ちこまれて……あぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「これが……これが欲しかったのです……！私の体中に、隊長さまの白濁液が\n満ちて、いく……ンああああっ……！素敵……っ、でも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「でも、一回じゃ足りません！ねえ……ねえ、もっとください！このまま！抜\nかないままで……あと一回、出してくれるまで抜かせませんからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ッふっ、ぁっ、あっぁっ！あぁんっ、あっあっあっ！大きく動けない、から\nこそ……あぁんん！細かく、速く……何十回でも腰を揺らしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ひぅっ……うう、あはっ……♪あうっ、あぅ、あふ……ぅうう♪いい……い\nいっ、いいぃいい♪……っうぅん♪驚いたでしょう……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「女神のオマンコの締まりは……んっ、自由自在なのですよ……！あっ！快楽\nを、コントロールする方向は……苦手、ですが……膣圧ならばっ、あぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あんっ、あんっ……いくらでも操作できるのです……！ですから\nっ、さきほどいただいた精液をこぼさず……愛液を溢れさせ、ながら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ぎゅうぎゅうに、隊長さまのサイズに、形に合わせて……ふぅううん♪カス\nタマイズできるのですっ、おまんこの中……ヒダヒダも、肉圧……も♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「ふふ、うふふふ……♪逃がしませんよ……あっ！あっ！驚いた、でしょう…\n…？私を煽って、逃げられないようにしたのに……自分が捕まっていた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「でも、怖がることは……ありませんよ♪私のここは、女神のおまんこは人の\n子を傷つけはしません……ッ！癒し、愛でるための器官、ですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「はぁーーーっ♪ああああっ、ああ……！そう、そうですよっ！恐れず奥、に\n……奥に、奥に突き立てるのです、その凶悪な肉棒を！あっ！あっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00011901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「……神にも等しい名器の持ち主ぃ……！隊長さま、あなたこそ、この世界を\n統べるべき王の器……あーっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "石凝姥命" ]},
		{"command":[ "SETTEXT", "「私も、鈴も、葉金も……ぉっ、世界を救うために選ばれし女は、全てあなた\nのものになるべき、なのです……ですから、仕方ないのですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_119_0104210" ]},
		{"command":[ "WAITINPUT" ]},

