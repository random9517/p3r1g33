		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「うう、全然目立てませんでしたわ……」", "NORMAL" ]},
