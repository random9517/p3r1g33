{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0127" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「お昼休みに呼び出してしまってごめんなさいね。最近貴方も忙しそうだし、\nこんな時にしか時間をもらえないかと思って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00025502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「前に、話したことがあったかしら？　私、貴方と特別な時間を過ごしたいと\n思って、とある薬品を取り寄せていたの。その名もボニューデマクール」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「名前の通り、女性の胸から母乳……つまりは男性を癒す液体を出すことが出\n来る秘薬だそうよ。それが、先日手に入ったの。それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「さっそく、貴方に味わってもらいたいと思って……大丈夫だったかしら。こ\nのお薬、いつ効きはじめていつ効果が切れるかがよくわからなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「どうせなら、その瞬間を貴方と待とうと考えたの。うふふふっ、楽しみね。\n……え？　母乳を出すのに、なぜおちんちんを乳房に挟み込んだのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00025502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「いやだ♪　わかっているくせに……。んっ。確かに今日の目的は母乳です。\nでも……何も、癒しの種類は１つでなくてもいいはずでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00025502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の乳首から母乳が出るまでの時間は、別の方法で貴方と貴方のおちんちん\nに優しくしてさしあげたいの。……嫌かしら？　嫌じゃないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00025502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「だって……こんなに、もう硬くしているもの。ふ、ふふふ♪　貴方は重たい\nおっぱいをおちんちんの上に乗せられて圧迫されるのが好きね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025502_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私も、こうすることはとても好きです。まじまじと、顔の近くでよーくおち\nんちんを観察できますし……この胸の谷間に感じる熱さ、大きさ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「少し前まで小さくしなびていた男性器が、ムクムクと巨大化して胸肉を押し\n返そうとしてくる力強さを感じると……う、疼くんです。母性、が……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……んっ？　ふふふ、このおちんちん、とてもいいですね。綺麗に洗えてい\nます。もしかして……ここに来る前にお風呂に入ってきたのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私との、甘い時間を期待して……♪　もちろん、お望み通りにたっぷりご奉\n仕させてもらいますが……唾液で濡らしてしまうのは許してくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……はい。おっぱいでこうして……。んっ♪　おちんちんを気持ち良くしな\nが、ら♪　お口でも愛してあげます。覚悟してください……♪　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「まずは、私の体温に……乳房に貴方のおちんちんをよーく馴染ませて……♪\n　パイズリ……♪　んっ♪　こうかしら……こうやって、強めにしごく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あん♪　この反応は正解ね。わかりました。このまま続けます……。っはぁ\nっ♪　はぁ、はぁ……♪　ふぅう……。んっ、んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「血管の浮き出た太いおちんちん……♪　お世話のしがいがあります、……ん\nっ♪　この色、臭い……すごく好きですよ。とっても私好みです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あら？　ぐいぐいと亀頭を突き出して……どうしたのですか？　舐めてほし\nくて仕方が無い？　…・・ふふ、それならこうしましょう……。んむ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はむ……んむっ、ちゅぷ……♪　ふ、ぅ……♪　先っちょしか咥えられなく\nてもどかしいかしら……？　でも、肉竿は胸で愛してあげますから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んんんっ♪　んんっ、ん～っ……♪　ねぇ？　こうやって、おちんちんの全\n体をぉ……おっぱいでずりずりこすりながら、先端だけを舐め回していく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「このもどかしさ……身体の一部分だけがどんどん敏感になって研ぎ澄まされ\nていくめずらしい感覚……♪　たまにはこういうプレイもいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っちゅっ♪　くちゅ♪　ちゅっ、ぷちゅっ、んん……♪　はいはい、心配し\nなくてもお胸でもしっかりシゴいていきますからね……♪　ちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ちゅむ♪　ぺろ……れろっ♪　くちゅっ、ちゅっ、ちゅぷっ、ぷっちゅっ…\n…はぁはぁ♪　おちんちんが熱くなってきました……くちゅっ、ちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁああっ……！？　きょ、胸部を適切に刺激したことでっ、母乳\nが正常に分泌されましたよ……♪　ど、どうですか……私のミルク……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「甘くて幸せな匂いがするでしょう？　んっ……♪　乳首がムズムズします…\n…！　はぁっ、はぁ、ぴゅるっ、ぴゅるって飛び出して、垂れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっあっ♪　こぼれてしまっています……！　んぁっ♪　も、もった\nいないので、指ですくって舐めてください……んっ、いいんですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「これは貴方のために出しているものですから、貴方に全て捧げます……♪　\nれろっ♪　私もおちんちん、たくさん舐めてご奉仕しますから……んれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ご奉仕♪　させてもらっているんですから、ウィンウィンですっ♪　……ふ\nぅうっ♪　母乳っ、貴方の手が私の乳首から母乳をすくって……んふぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　んぁううううぅ……っ♪　溢れ出してしまいました、……ち\nゅっ♪　私っ！　おちんちんおしゃぶりしながら母乳を溢れさせて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、すごく気持ちいい……！　ねえっ、お願いです！　私の胸……\n搾ってください、乳首もつまんで、母乳も味わって！　あっあっあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はしたなく乳首から母乳を溢れさせている私をたくさん見て……！　貴方の\nおちんちんを……！　ぴちゃっ、舐めて興奮している私を……っ、ちゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「おちんちん♪　味わいながら射精みたいに母乳をぴゅっぴゅ出している私を\n……！　あっぁっ、見て、見てぇ、エッチなお世話大好きな私をぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……んん！？　あは……♪　貴方のコレも……♪　おちんちんも淫らに反応\nしてくれていますね。好きなんですか？　母乳まみれの胸でパイズリされて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「お口でレロレロフェラチオされるの……♪　だったらいくらでもしてあげま\nす……！　っちゅぱっ！　ちゅっぷっちゅくっ♪　くちゅ、くちゅ、くちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んん～っ♪　んぁあ♪　少ししょっぱくておいひぃ……♪　れろっ、れろ…\n…♪　もっと腰を突き出ひてくだひゃい……♪　っちゅぷっ、くっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んぁあああ♪　貴方のミルクも出してください♪　母乳と精子でミルク交換\nしたいっ……！　ください……出して、私の口に注いでぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んんぷっ♪　ん、ぅううう……♪　むぅううっ♪　んむぅうう……♪　ゴク\nッ……ごくっ、ごくっ、ごく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あ、ぁ……♪　ごめんなさい、また許可も得ずにためらいもなく飲み干して\nしまって……♪　ちゅる……もっと出して、全部……早くぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「やぁ……♪　舌の上にびゅくびゅく放たれる新鮮なミルク……♪　私の母乳\nとは全然違って、ねばっこくて、臭くて、濁っていてドロドロで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ♪　貴方の精液はいつも、栄養がたっぷり詰まっていそう\nでたまらなくなってしまいます……欲しい、あるだけ欲しくて我慢できない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……尿道に残った分まで吸わせていただきます。吸い上げて……飲みたいん\nです♪　ちゅ……ちゅ、ぢゅるるる……じゅるっ、ごくっ、ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　ごちそうさまでした……。ん、んん……。まだ、喉の奥にひ\nっかかっているような……。フフ、それだけ濃い精が出たのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「これだけ精を大量にほとばしらせれば、精力自慢の貴方でもさすがに……。\nと、待ってください。なんですか？　コレは。んっ、萎えていない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あらあら……もしかして、まだ終わりにして欲しくないとでも言うつもりで\nすか？　そんなに母乳まみれのおっぱいが好きだったなんて驚きです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……別に悪いことではありませんよ。むしろ、歓迎してしまいます。そうで\nすか……うふふふ、一度出したくらいでは収まらない、と……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「いいでしょう。何度でも吐精させてあげましょう。私の胸にも、まだまだ母\n乳は溜まっています……お互いに、ぴゅるぴゅる出して気持ち良くなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「とろけるような甘い時間を過ごしましょうね……♪　ほら♪　ママのおっぱ\nいが、貴方の太いままのおちんちんをもう一度刺激していきまちゅよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っふ……♪　ふぅっ……♪　ふぅううっ……♪　ん……♪　もぉ♪　私にそ\nんなに舐めてほしいんですか、亀頭が口元まで伸びてきて……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んれろっ♪　ぴちゃ……くちゅっ、ちゅぷ……♪　なんておねだり上手なお\nちんちん……♪　よしよし、たくさん可愛がってあげましょうね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ママのおっぱい、気持ちいいでしょう……？　お口だってネロネロしていて\n、舌が長くて愛情いっぱいで大好きよね……？　ぺろっ、ぺろっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっ♪　んん……♪　んむっ♪　ちゅぷっ、くちゅ、ちゅぅっ、ちゅっ……\nちゅっ♪　ふふふふ♪　先走り汁が出てきています……れろれろれろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そうなの♪　パイズリフェラされると股間がピクピクしちゃうのね♪　んふ\n……♪　もっともっと喜ばせてあげましょう……っちゅっ、ちゅぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んッ♪　ふっ♪　くちゅっ、ちゅっ、ちゅむっ……♪　ぢゅるっ♪　はぁっ\n……はぁ、あっ、あぁ……！　んぁっ、母乳、出ちゃう……あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んふぅううっ♪　ああああっ……見てください♪　再び母乳が……！　おっ\nぱいミルクが……っ♪　あっ♪　あっ、母乳を出すのは好きです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の、貴方への……そして生徒たちへの母性が、形になってあらわれている\nようで……♪　ふふふっ♪　いつもは博愛主義の私ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「今、私の母性を感じられるのは貴方だけです♪　れろ……♪　ぐちゅっ♪　\n母乳、おちんちんで……その身体でたくさん浴びてねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぷ♪　くちゅっ！　ぐちゅっ、ぐちゅっ……んんん♪　母乳の甘ったるい\n香りで頭がクラクラしてきます……♪　ぴちゃ♪　っちゅく♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はむぅ……♪　んぢゅっ、じゅるっ、じゅるるっ……！　んぷ♪　口の中に\n収まりきらない肉厚な亀頭……本当においしい……♪　じゅるるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ♪　私、胸でイッてる……？　あぁっ♪　だめ……だめ♪　母\n乳止まらないわっ……！　あっ！　あっ、うぁあっ、ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「いやらしい声、止められないから……おちんちんで口をふさがないと！　は\nむっ！　ぐちゅっ！　じゅるっ、じゅぷっぐっちゅっぐちゅっぐちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「いやらしい、ママでごめんなさいね……っ！　貴方もイッていいの\nよ……！　ねえ、イッて！　んじゅるっじゅるっぢゅるっじゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んぷッ……♪　むふ……っ、んむぅううう……♪　んんッ……ん～っ、んぅ\nうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ゴクっ……ごくっ、ごく……♪　うふふふっ、どんどん出ひてね、いくらで\nも飲み干してあげますから……♪　ごくっ♪　ごくっ、ごきゅ……ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んふ♪　まだ出ています……。こらこら、そんなにはしゃがないで……♪　\nんんっ……。全てすすり取って、舐めて、味わって、ごちそうになります♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ちゅぅ……♪　ちゅぅっ、ちゅるる……ごくっ♪　ごくんっ！　……は、ぁ\n♪　喉いっぱいに絡みつくような粘り気のある体液……若さの証拠です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちんは、やんちゃすぎますよ。ほら、まだお汁が尿道に残って\nいる……。ぢゅる……じゅるっ、じゅるるっ……ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ああぁあ……♪　鼻孔を貫くこの生臭い香り。いつまでも舌先に残るクセの\n強い味……。苦いだけのはずなのに、もっと飲みたくなってしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……え？　精液を飲んでいる時の私が、まるでスッポンみたいに貴方のおち\nんちんに食らいついていた……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「さすがに、それは言い過ぎです。ただ……熱いほとばしりを舌に感じた瞬間\n、理性を失って本能丸出しで喉を鳴らしてしまったのは確かですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「だって……二回目だというのに、貴方の射精は勢いが強くて、精子は濃くて\n。無我夢中でどんどん飲んでいかないと、溺れてしまいそうだったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の口と胸、気に入ってくれたようで嬉しいですよ。これからも、貴方の世\n話は私がします。私だけが、ずっと、ずっと、ずーっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　んんっ、激しいわ……！　荒々しい射精……っ♪　んぅっ♪　\n私……こうやって無理やり顔にかけられるの、好きですよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふぁあっ♪　あぁ、んぁあん……♪　あったかいです……♪　顔中に振り注\nぐ貴方の精子……♪　そうですか、ずっとこの顔にかけたかったのですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふふ、うふふふ……♪　胸は母乳で、顔は精液で真っ白だなんて……♪　も\nう私ったら、生徒たちの学園長というより……貴方専用のエッチなママね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「生徒たちにはこんな姿見せられないと思えば思うほど……。あっ♪　感じて\nしまうの……♪　裏ではこんな風に♪　精液かけられているんだって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の顔には濃厚な精子がこんなにかかっているんだって……自覚すると、ん\nんんっ♪　それだけで身体が快感でブルブル震えてしまう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んはぁっ♪　ヌルヌルした精液のこの感触……♪　明日、お肌がツヤツヤし\nてしまったらどうしましょう♪　バレてしまいます♪　あんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あ……、あ……♪　ぜんぶ……気持ち良く出すことができましたか……？　\nうふふふ♪　私に遠慮することなんてありませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私達はとてもとても深い仲です……。二人だけの秘密を共有して、何度も身\n体を重ね合わせて……粘膜の色も具合まで互いに把握している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「彼氏と彼女、いいえ……母と息子以上の、他に代わりのいない関係……。こ\nれからも継続して、もっともっと愛情を深めていきましょうね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……私の顔が怖い？　ふふふ♪　真剣なだけですよ……♪　これからも、改\nめてよろしくお願いしますね。……ずっと、お世話しますから♪」", "NORMAL" ]},
