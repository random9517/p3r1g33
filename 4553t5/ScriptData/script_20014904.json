		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたし！？　やったわ～っ！　まっ、ダイヤナちゃんにかかれば当然だけど \nぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023280001" ]},
