		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "FADEINCHARA", "0", "VERYFAST" ] },
		{"command":[ "FADEINCHARA", "1", "VERYFAST" ] },
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUTIMAGE", "1", "VERYFAST" ] },
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、ほかのバックダンサーたちとは少し様子がちがう……？", "NORMAL" ]},
		{"command":[ "DISPIMAGE","1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_290023280001" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "2", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "1", "char_00000129_01", "2", "CENTER", "-600" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「く……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_280023280001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふたりとも……平気なのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「平気……だが……くっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_290023280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「胸が……ああ、頭が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_280023280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不用意に近づいた瞬間、俺はアナザーに引き寄せられた。怯んだ俺の唇を、ア \nナザーの唇が塞ぐ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぅ……んっ、ちゅぶっ、ちゅるる、んふぅ……っ！　これ、こうした \nかった……ちゅばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_290023280003" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、こら！　下僕を独占するな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_280023280003" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおぉっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今度は姫様にハグされる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、お前は私と！　私とイチャイチャするんだ！　あ、アナザーのように、 \nキスだって、し、してやる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_280023280004" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ど……どうなってますの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023280006" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もしかして、ふたりのもつ願いが、ダイヤナさんの願いに勝ったのかな…… \n？　でも、邪な願いだから、邪なまま叶っちゃった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023280008" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そんなの……アリかよ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この状況を冷静に分析するグリムロック。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あの光を浴びても……強い願いがあれば洗脳されない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023280009" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だったら……もしかしたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023280010" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　グリムロック！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「グリムロックさま！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023280007" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックは前に出て、わざと光を浴びようとした。アンがそれを止めよう \nする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "姫様のハグから抜け出し、俺も止めようとしたが、すでにふたりは洗脳光線に \n包まれていた。", "NORMAL" ]},
