		{"command":[ "SETTEXT", "コスプレコンテストはついにグランプリ発表の時間となった。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ステージには最終選考まで残った選りすぐりのコスプレ美女たちが並んでいて \nとても華やかだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナたちは３人そろってステージの上にいる。あ、姫様たちもいるな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あの黒いオボロとハルノブは……やはりあんな騒ぎを起こしたせいで選考から \n外されたか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あとは優勝して、スタークリスタルを手に入れれば、任務完了だな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……と、油断はできない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間帝国の連中が、ほかにも潜りこんでいる可能性は十分にある。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ただでさえこのイベントは、参加者がコスプレなのか、俺たちのように本物な \nのか、判別しにくいのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一般の参加者が戦闘に巻き込まれないように、一応、身構えてはおくか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「結果発表～～～～～～ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020023280001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「コスプレコンテスト、グランプリは……」", "NORMAL" ]},
