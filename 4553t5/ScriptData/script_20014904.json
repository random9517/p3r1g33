		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「洗脳光線ということですか。なんてやっかいな……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000519_01", "1", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_005_110023280004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうこうしている間に、ステージに乗りきらないほどの人数がダイヤナのバッ \nクダンサーになっていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あは～ん♪　ダイヤナちゃん優勝記念のダンスパレードよ～♪　もちろん主 \n役はあ・た・し♪　みんなで踊りまくりましょ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023280007" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こっちを見て～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023280008" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "-400", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナがステージを降りて、会場を進んでいく。洗脳光線を無差別に放ち、 \nそれを浴びた参加者や観客を列に取り込んでいく。", "NORMAL" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "400", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このまま世界中のみんなを……いいえ、すべての次元のみんなを、ダイヤナ \nちゃんの虜にしちゃうんだからぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_130023280009" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおい、ダイヤナのやつ、願いのスケールがでかくなりすぎじゃない \nか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「人の願い……望みには果てがありませんの……。あのクリスタルが星から追 \n放されたのも、納得ですの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023280005" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そ、それより……どうしよう……。止めなくちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023280007" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「止めるってったって、どうやって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "作戦を考えていると、ダイヤナの洗脳光線が俺たちの方へと飛んできた！", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「危ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023280002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もはやこれまでと思った瞬間、姫様とアナザーが俺たちの前に立つ。そして光 \n線を浴びてしまった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00000109_01", "3", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しまった……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "FADEINIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEOUTCHARA", "0", "VERYFAST" ] },
		{"command":[ "FADEOUTCHARA", "1", "VERYFAST" ] },
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "光を浴びたふたりは、やはりダイヤナと同じように身体をクリスタルに覆われ \nた姿になっていた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000128_01", "3", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "1", "char_00000129_01", "3", "CENTER", "-600" ]},
