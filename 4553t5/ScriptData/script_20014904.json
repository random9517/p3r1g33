		{"command":[ "SETTEXT", "ドラムロールが開始される。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ナンバー００６１３、ダイヤナさん！」", "NORMAL" ]},
