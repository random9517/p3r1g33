		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あぷっ……あんっ、オチンポっ……外れてっ……んふぅっ……顔\nにっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303401" ]},
