		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい、これで全部になります。本当に助かりました。もう、本当に人手が足\nりないみたいでして～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「この広さなんですから、もう少しお手伝いを増やしてくれてもいいと思うん\nですけど……でも、いっぱい働いて下さってありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「何かお礼をしなくてはいけませんね。何かご希望はありますか？　えっ……\nご褒美が欲しい……はい、えっ……パ、パ……パイズリっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、す、すみません……パイズリ……ですか……えっと、でも、確かに…\n…一生懸命してくれましたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「分かりました……誰にも、内緒……ですよ？　こ、こちらへ……どうぞ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_01" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「それじゃ……んっ、おっぱい……挟んじゃいますね……あっふ……わ……す\nごいです……こんなに熱く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303106" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えっ……ずっと期待してた……？　もう、それでお掃除をあんなに張り切っ\nてしてたんですか？　しょうがない人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、それなら私も一生懸命ご奉仕してお返ししないといけませんね。おっ\nぱい、動かしちゃいますよ……あっ、ふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「まず、皮の付け根のところを、ぐにぐに……揉み込んで……それから、強く\n……押さえ込むようにしてっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……オチンポが震えてます……中でひくん、ひくんって\n……これ、気持ちいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「よかった……んっ、じゃあ、もっと大きく動かして、扱いていきますね。ん\nっ、はっ、あっ、んふっ、はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……いっぱい働いて、オチンポもお疲れになっていませんか？　\nたっぷりねぎらってあげませんとね……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふふっ……おっぱいの中でまた少し膨らんでます……疲れてるなんてとんで\nもないという感じですね……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……いかがですか……？　おっぱい……まだ、垂れてるわけで\nはないと思うんですけど……ちゃんと気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「よかったです。んふっ……あぁ……でも、こうしてオチンポに擦り付けてい\nると……私も……なんだか気持ちよくなってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、やだ……乳首もピンってしこってきて……はっ、ふっ……んんっ、は\n、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もっと、乳首も押し付けて……は、はい……んぁふっ！　あぁっ……ピリピ\nリっ、しますぅっ……あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「さ、さすがに……もう母乳は出ません……でも、こんな風に……乳首を弄ら\nれたら……あんっ、私の方が……あっ、感じてしまいます……ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ……大丈夫ですよ……気持ちいい声が出ちゃいました……ご奉仕なの\nに、私の方が感じちゃうなんてダメですね……あっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「か、可愛いなんて……も、もうからかわないで下さいっ……んっ、本当に恥\nずかしいんですからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あぁ……オチンポの先がプルプルしてきました……んっ、亀頭\n……して欲しいんですか？　はい、それでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅぽっ、んっ、くぷっ、ちゅぷぅぅぅ……あぁん、私……いやらしい顔で\n……オチンポ、思いっきり頬張っちゃってまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふぅ……あぁ、この濃い味ぃ……んりゅっ、れろっ、舌先に広がって……\nちゅぱっ、んちゅっ、れろ、ぴちゅ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「舌……もっとした方がいいんですか……？　ふぁひ……んれろ、りゅぷっ…\n…もっと、舐めちゃいまひゅね……れる、れりゅ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「くすぐったいですか？　んふっ、オチンポが、びくびくって何度も震えてる\nのが分かります……あんっ、おっぱいの中で暴れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「しっかり押さえつけてあげないと、こぼれちゃいそうです……むにゅって…\n…しっかり左右から挟んであげて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい捕まえました～♪　そしたら……ちゅぽっ、んちゅぅぅっ……れろ、ん\nりゅっ、じゅるっ、ちゅぷっ、んちゅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふっ、亀頭を……強く吸い上げて……んちゅるっ……オチンポの根元はし\nっかりとおっぱいでロックして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「全体を揺らすようにして……はっ、んちゅぷっ……たっぷり唾液をまぶしな\nがらぁ……また舐めてぇ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「この繰り返しで……はぷっ、どんどん気持ちよくなっひゃいまひょうれぇ…\n…じゅぱっ、ちゅぷっ、んちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふぁ……おっぱい熱いれふ……乳首もずっとムズムズしたままれぇ……震\nえるオチンポも止まらなくてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、んむっ、あっ、ふっ……ちゅぱっ、あぁ……んちゅ、先端……お汁…\n…滲みだして来ました……少ししょっぱいれふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ここまで来たら……後はもっと圧力をかけて……んっ、オチンポをズリズリ\n……刺激してあげて……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ビクビクが、どんどん強くなっていきまふ……いいれふよ……？　私……飲\nんじゃいますから……口の中に出しちゃって……下さいね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふぁい、我慢なさらないで……欲望に身を委ねて……んっ、あっ、はぁっ、\nあふっ……！　あぁっ、オチンポがビクビクしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ……！　んふっ、れてっ、まふっ……！　んぐっ、ドロっと\n……濃いのがっ、あぷっ、れてっ……まひゅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっくっ、こくっ、んくんっ……はぁぁ……これを飲んでしまうと……ダメ\nなんれふ……私も……あっ、おっぱいれ……イクぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、んふぁっ、ちゅぱっ、はっ、ふっ……んっくっ、んふっ、はぁっ、は\nぁ……いっぱい出ましたね……全部飲むのも大変でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、あぁん……ほら……全部いただいてしまいました……。はい、お味に\nは慣れてますし……その、美味しくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふ……ご奉仕で私もイッちゃいましたけど……どうやら喜んでもらえたよ\nうで……んふっ、何よりでしたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あら……でも、オチンポ……まだ、沢山溜まってるみたいですね……こんな\nにビンビンのままでたくましいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「このまま続きを……はい……で、でも、ちゃんと出来るかしら……私……今\n、とっても感じやすくなってて……あっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「すみません……今、おっぱいが……すごく敏感なままで……オチンポと擦れ\nる度に……はぁん……声が……出ちゃいまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「こらえなくちゃと……思えば、思うほど……はっ、んぁっ、気持ちが高ぶっ\nてしまって……あっ、逆らえなくなって……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「我慢しなくていい……んふっ、さっき私が言ったことを、そのままお返しさ\nれちゃいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「分かりました……では、改めておっぱいも……頑張っちゃいます……んっ、\nふっ……精液のぬめりをお借りして……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ、あっ、はぁぁっ……乳首っ……擦れ……ますぅっ……くち\nゅくちゅ……はしたない響きさせてぇっ……おっぱい感じてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぴちゃっ……んっ、舌も……もっと動かしますね……？　少し下\n品になっちゃいますけど……れろ、くぽっ、んりゅっ、じゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んはぁ……ぴちゃ……んちゅぷぅぅ……んちゅっ、ちゅるるっ……んぁぷっ\n……おいひぃっ……オチンポの味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……私、また夢中になってる……んっ、いやらしくオチンポを舐めてる\n所……見られて……ドキドキしちゃってるのぉ……りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ……はぁぁ……止まらない……んっ、おっぱいも……ずっと動かしち\nゃってます……んんっ……くぅん……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっふ……どうですか……？　オチンポ……感じてくれてますか……？　あ\nっ、はっ、あんっ、はぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私ばっかり気持ちよくなってしまってたら……申し訳なくて……あっ、あぁ\nんっ……！　はい……私のおっぱい……気持ち……よくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はいっ……んくぅんっ！　このままだとっ、私……また、おっぱいだけで…\n…イッちゃいそうですっ、はっ、んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゃんと……感じてくれてますねっ……んふっ、よかった……りゅぷっ、ん\nちゅぷっ、この滲んだお汁……次の準備が始まってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、しっかり押し込んで……激しく、縦に……ズリズリさせて……この感\nじ……たまらないですっ、んくっ、あふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンポもビクビク震えてっ……！　また、あぁっ、出したくな\nってますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、はいっ……今度も我慢しないで出して下さいっ……私っ、全部……受\nけ止めますからっ……ちゅぷっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「お口でもっ……顔でもっ、貴方のしたい所にっ、全部欲しいですっ、はぁん\nっ、りゅぷっ、出してっ……精液っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はひぁっ、私も……イキますっ！　一緒におっぱいイッちゃいますからっ、\nんちゅぷっ、はぷっ、んふぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303220" ]},
		{"command":[ "WAITINPUT" ]},
		
