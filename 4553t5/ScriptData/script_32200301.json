		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぐっ、こくんっ、んっくっ……ふごい……量……んっ、んくっ、はふっ、\nんんっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303302" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……やっぱり沢山溜まってらしたんですね……んんっ、これ……全部吸\nい出しちゃいますから……ちゅうっ、んちゅうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「オチンポがずっと震えたままれふ……可愛いですね……んちゅっ、ちゅぷぅ\nっ、んっ、ふっ……じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、はぁ……はぁ……んふ……沢山出しましたね……じゃあ、せっか\nくのお掃除ですから、先っぽきれいにしちゃいますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅる……ちゅぱ、れろ……んふ……大丈夫ですよ……優しく吸い出しちゃ\nいますから……んちゅぅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ぴちゃっ……はい、これでおしまいです。ふふっ、いえいえ、\nどういたしまして。お役に立てたなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい、これはあくまでもお礼ですから。私の気持ちということで……受け取\nって下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも……こんな神社でいけないことをしてしまうと……罰当たりかも知れま\nせんけど……思った以上にドキドキしちゃいましたね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「その、まだまだムラムラしちゃって……今度は……私も欲しいかも知れませ\nん……なんて……ふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303310" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_04" ]},
