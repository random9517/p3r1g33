		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふぁ……すごい量……止まらないです……こんなに、はぁ……んっ、べと\nべとぉ……粘っこくて……元気ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「まだ、出るんですか？　はい……じゃあ、おっぱいで扱き出しますね……ん\nんっ、はぁ……残りも全部搾り出しちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「は、ふっ……あぁ……弱まっていく……あふ……ちょっとだけ名残惜しいで\nすね……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、おしまいですか……？　あぁ、すごい……おっぱいが大変な\nことになっちゃってます……ドロドロぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んちゅっ……後はオチンポの先もお掃除しちゃいましょうね……\nちゅるっ……奥の分も吸い出して……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふっ、ご馳走様でした……♪　いえいえ、お礼なんてとんでもないです。\n私の方まで気持ちよくなってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00022003_01_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも、喜んで頂けたのなら何よりです。少しはご褒美になってくれてれば嬉\nしいですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ただ……その、これだけ夢中になってしまうと……その、まだ多少火照りの\n残り香と言いますか……疼きが……」", "NORMAL" ]},
