		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　んぐっ、あっ、んぷっ、まらっ……お口にっ……んふぅっ\n、れてっ、まふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0303301" ]},
