{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "100_0103101" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「来たぞ、隊長どの。ああ、みなまで言わなくていい。何故呼ばれたのかは、\n察しが付いている」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103102" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私に奉仕されたいのだろう？　そうやって潜在能力を引き出すのが、隊長の\n能力だからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103103" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「嫌ではない。任務であれば、ただ従うのみだ。己の好き嫌いと大局など、比\nべるまでも無い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103104" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや、そもそも私は、奉仕することに嫌悪を感じてはいない。むしろ、こう\n言ったことは得意だからな。声がかかるのを待っていたくらいだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103105" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さあ、そこに横になってくれ。隊長どのの期待に応えられるよう、全力で奉\n仕させてもらう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103106" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ただし、私にも隊長どのの愛撫を頼む。それぐらいの役得はあっても良いだ\nろう？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103107" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ。今の言葉に反応したのか？　ペニスがズボンの中でぴくりと跳ねたぞ\n。そう逸らなくとも、ちゃんと最後までしてやるから安心してくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103108" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さあ、出てこい……ん、んん。ふふふ、もうこんなに大きくして。取り出す\nのが大変だったじゃないか」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103109" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「では、始めるとしよう。まずは、胸で挟んで……ん、んん。どうだ？　私の\n胸は？　そうか、柔らかいか。ふふふ、良かった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103110" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私か？　私は、少しくすぐったいな。それにペニスが暖かくて、なんだか不\n思議な気分だ。これが、隊長殿の熱なんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103111" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん、あ、ふあぁぁ……あ、アソコも、指ぃ……んんんっ、あ、ふあぁ。指が\n、触れてる。ぞわぞわする……んんんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103112" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ。優しいタッチだな、隊長どの。どうやら、女の扱いを心得てると見え\nる。さぞかし多くの女を泣かせてきたんだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103113" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はは、図星か。今、ペニスがびくっと跳ねたぞ。ぎくりとしたんじゃないか\n？　ん、あ、ああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103114" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こ、こら。黙らせるために、いきなりアソコに口づけるなんて……あ、ふあ\nぁ、あ、ああ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103115" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お、おのれ。図星を指されてムキになるとは、隊長どのもまだまだ子供っぽ\nいところがあるんだな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103116" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいだろう。このまま、お互いに……ん、あ、ふあぁぁ。くっ、負ける、も\nのか……ん、んんっ、ん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103117" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ。今の悲鳴、なかなか可愛かったぞ、隊長どの。私の胸、予想以上に\n感じてくれているらしいな。なら、もっと力を込めて……んんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103118" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん、んっ、んんん！　ど、どうだ……いや、答えなくても分かるぞ。ペニス\nが、どくどく、私の胸に挟まれたまま、脈を打っている」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103119" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「血管も、太いのが浮き出てて、びくんびくん脈動している。おまけに、どん\nどん熱くなってきてる。気持ち良いんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103120" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ、おまけに、匂いも……むわっとした、オスの匂い……マタタビよりも\n下腹部と脳みそが痺れるような匂い……ふあぁぁぁぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103121" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと、嗅がせてくれ。この匂いを、もっと……ん、んんっ！　どうだ？　\n胸でもっと強く挟んで、擦れば、匂い、濃厚に……んんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103122" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふは！　透明なのが、先っぽから出てきたぞ、隊長どの。我慢汁だ。感じて\nいる証拠だ。おかげで、狙いどおり、匂いが濃くなってきてる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103123" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ。駄目だ、我慢、できない……あむ、ん、ちゅっ。ん、\nちゅ、ちゅうぅぅうぅうぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103124" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぷあっ。ふ、ふふふ。どうだ、隊長どの？　先っぽを、吸われる感想は？　\nははは、そうか。暖かくて、気持ちが良いか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103125" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なら、もっとだ。もっと、気持ちよくしてやる。んちゅ、ちゅうぅ、ちゅ、\nんちゅうぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103126" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅ、ちゅ、ちゅ、ちゅうぅぅ……んぷ、ちゅっ。んふふふふ。\n可愛い鳴き声だぁ、ぞくぞくする」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103127" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうか、舌が当たるのが、そんなにいいか。正直だな、隊長どのは。だが、\nその方が私も、奉仕のし甲斐があるというものだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103128" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから、もっと味わうといい。んちゅ、ちゅぶぅ、れるぅぅぅ、ちゅ、ん、\nれるぅぅぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103129" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんん！？　びくっれ、ペニスが……どくどく、激しく、震え始めた！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103130" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「イクんだな？　わ、分かった……そのまま、果ててくれ！　んちゅ、ちゅ、\nちゅうぅぅ、んちゅう、ちゅ……んぶううぅ、んん！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103131" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぶう！？　ん、ん！？　んぶぅぅううぅぅぅううぅうぅぅ！　ん、えう、\nえほ！　えほえほえほ！　きゅ、急に、射精……えほ！　げほげほっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103132" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……う、えうぅぅ……いきなり、出たな。それも、口で受け止め\nきれないほど、大量に」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103133" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おかげで、飲んでしまったじゃないか。濃厚だったから、喉に絡んで、いが\nいがして……はぁ、匂いが、身体の内側からする」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103134" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ。溺れそうなほどだったぞ。そんなに気持ちよかったのか？　だとし\nたら、女の本懐だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103135" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、嬉しいとも。惚れた男を気持ち良くできたんだ。嬉しいに決まってる\nじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103136" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「照れたな、隊長どの。分かるんだよ。なにしろ、まだ胸にペニスを挟んだま\nまだからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103137" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「惚れたと告げた瞬間に、このしぼみかけていたペニスが、ぴくっと跳ねて、\nあっという間に堅さを取り戻したんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103138" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、まただ。また、びくって……まるで胸を内側から押しのけるみたいに\n膨らんで来てる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103139" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっという間に、また勃起したな。さすがは隊長どのだ。雄々しくて、反り\n返るような勃起だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103140" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「では、続けてもう一回戦といくか。ふふふ。ご奉仕は、まだまだ始まったば\nかりだぞ。それに、求めてきたのはそっちだ。覚悟はできてるな、隊長どの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103201" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ところで、気づいてるか、隊長どの。途中から隊長どのの愛撫がお留守にな\nっていたことに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103202" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おかげで、私はまだ絶頂に達していないんだ。もどかしくてたまらない状態\nなんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103203" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「次こそは、私も感じさせてもらうからな。頼むぞ、隊長どの。思いっきり、\n私を気持ち良くしてくれよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103204" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに、私のご奉仕も、この程度で終わりじゃ無いぞ。我が忍術の神髄、房\n中術を、とくと味わってくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103205" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふああ！？　さ、早速、アソコを……くぅぅ！　し、舌が、ゆっくり……ん\n、んんんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103206" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ま、まるで、踊るように、くぅぅぅ！　ぬるぬる、擦れてぇぇぇ。あ、ふあ\nぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103207" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひうう！？　は、入って、きた……舌が、中にぃ……はうぅ！？　ぬるんっ\nて……そんな、奥に！？　ふああああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103208" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「や、やるじゃない、か、隊長どの。危うく、イキかける、ところ、だったぞ\n。だが、まだまだ……今度は、こちらの番、だっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103209" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あむぅ、ん、むぅ……んむぅ、じゅる。じゅるぅうぅ。んじゅ、んじゅ、じ\nゅるるるるるる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103210" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ、どう、だ？　口にくわえた途端に、ペニスが、踊るように、跳ねた\nぞ。頬の内側に、びたんびたん、当たってる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103211" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだ、さっき出た精液を絡めて、胸に……ん、んんっ。ふふ、気持ちいい\nんだな？　びくんびくん震えてるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103212" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあぁ！？　また、アソコ……舌ぁ。ひうう！？　しかも、今度は、一番感\nじる場所、唇で吸ってる！？　んんんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103213" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「く、クリトリスへの、キス、上手いじゃないか、たい、ちょう、どの……あ\n、ふあぁ！？　気持ちいいぃぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103214" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、来てる……ゾクゾク、来てる。このままだと、すぐにでも……んんん\nん！　ああ、すぐにでも、イッてしまい、そう、だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103215" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だ、だが……んむぅ、ん、じゅるるるる、ちゅ、じゅぶぅ。ん、んんっ。ふ\nふ、一人ではイかん。隊長どのも、いっしょ、に……じゅるぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103216" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふふ。ペニスが、また、びくんびくん、震えだした。それに、我慢汁ぅ、\nあふれて、きてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103217" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、二人、一緒に。それが、一番、嬉しいんだ。だから……んぶぅ、じゅ\nる、じゅぶ、じゅるぅうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103218" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぶぅ！？　ペニスが、今まで以上に！？　くひのなかに、はいり、きらな\nい……んうう、ぶ！？　んん！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103219" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はううう！？　し、舌ぁ……アソコにねじ込まれてる、舌ぁ……動き、激し\nぃぃぃ！　クリも、そんな、強く！？　あ、ふあああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103220" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんん！　たいちょう、どの！　ん！　あ、ふああ！？　んあああああ！？\n　イクぅ！　イクぅううぅぅうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "100_0103301" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んああ、あ、ひゃあああああああああああ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103302" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ、ふあああ！？　熱い！　熱いのが、胸に！　大量に……んんんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103303" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあ、はぁ、はぁ、はぁ……す、凄い。二回目なのに、なんて量なんだ。お\nまけに、濃厚で、ドロドロしてて、熱いぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103304" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに、匂いが……身体中から、隊長どのの匂いが、する。青臭くて、脳を\n痺れさせるような匂いだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103305" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まるで、隊長どのに包み込まれてるような気分だ。それに、胸を真っ白に汚\nされたせいか、隊長色に染められて気もする……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103306" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ。イッた後の身体に、なんだかこの暖かさが心地良い。ずっと、こう\nしていたい気分だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103307" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ。女の本懐だ。幸せで、身も心も満たされているような気分だ……って\n、隊長どの。ペニス、まったく萎えていないじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103308" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あんなに濃厚に射精したのに、まだ反応するなんて……隊長どのはもしかし\nて底なしか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103309" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んああ！？　お、おい、舌、また、アソコを……ひああ！？　イッたばかり\nだから、敏感に、なってる！　んんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103310" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあ、ふあぁぁ……まったく、隊長どのと来たら。いいだろう。今ので私の\n身体にも、また火が付いた。今夜はとことん、堪能しようじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "100_0103401" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んじゅ、じゅぶ、ん、ぶぅ！？　んぶんぶぅ……んっ！　ぷあ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103402" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひゃんんんんんんんん！　か、顔に……んん！　顔に、精液が……くぅぅぅ\nぅぅぅ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_11" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103403" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあ、ふあ、はぁ、はぁ、はぁ……顔にぃ、射精、された……私の顔に、隊\n長どのの、精液が……ふあぁぁぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103404" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こ、こんな、どろどろな、精液……二回目なのに、こんなに、熱くて、匂い\nも濃厚なのが、顔に……ふあぁぁぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103405" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ。まさか、顔射されるとは思わなかったぞ、隊長どの。どうやら私が\n思う以上に、変態だな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103406" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「とがめているのではない。むしろ、隊長どののそういう所が知れて嬉しいん\nだ。私に、さらけ出してくれたのがな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103407" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと教えてくれ。隊長どのの性癖を。私がその全てを叶えてやる。顔でも\n胸でも、なんならアソコにだって、たくさん出してくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103408" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ。想像したのか？　またペニスが膨らみ始めたぞ。次は一体、私の身\n体のどこを汚すつもりなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103409" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「髪でも口の中でも、好きなところを汚してくれ、隊長どの。もちろん、もう\n一度顔にかけてくれても構わないぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0103410" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さあ、夜は長い。ゆっくりと楽しもうじゃないか。眩暈がするほどの快感を\n、二人で味わおう」", "NORMAL" ]},
