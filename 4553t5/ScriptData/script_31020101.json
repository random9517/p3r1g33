		{"command":[ "PLAYVOICE", "102_0103106" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　どうすればいいのかわかるかって？　わかんないです……ええっと、\n踏みにじって、痛い目に合わせればいいんですか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103107" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ええ？　違う……？　繊細な足さばきで、やさしく丁寧にマッサージをする\n……？　うう、細かい作業なんて、苦手中の苦手なんですけどねー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103108" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「わ、わかり、ました。一応頑張ってみますけどー……上手くできないからっ\nて、不機嫌になったりしないで下さいよ？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103109" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「うう……変な感じですぅ……オチンチン……硬ぁい……爪先の間で、ゴリゴ\nリ音立ててる……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103110" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　ストッキングの感触が気持ちいい……？　そ、そうですか……履いて\nてよかった……生足だと、爪で怪我させちゃいそうです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103111" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……足を動かして、気持ちよくして欲しい？　あうぅ、上手くできるか\nなぁ……まあ、一応やってみますけど……よいしょっと──」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103112" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……ふぅ、え？　気持ちいい？　あの、気を使って言ってくれてません\n？　正直に言ってくれていいんですよ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103113" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、あふぅ……そ、そうですか？　そんなに悪くありませんか……ありが\nとうございます……んっ、くぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103114" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、あううぅ……そんなに、見ないで下さい……わかってますっ、パンツ\n丸出しになってます……だから、見ないで下さいってばぁっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103115" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁぁ……恥ずかしい……こ、これは、とっとと終わらせて、この恥ずかし\n地獄から脱出しないと……はぁ、はぁ……んんん～～……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103116" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ふぅ、んん……これでどうです？　ちょっとは気持ちいいですか？　はぁ、\nはぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103117" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「力、挿れない方が、スルスル動かせますね……ん、はぁ……ああ、オチンチ\nン、かたぁい……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103118" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「それにしても、手でもろくに触ったことないのに……いきなり足で、こんな\nこと、させられちゃうだなんて……はぁ、はぁ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103119" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「普通、もっと、こう……別のことをしてから、こういうことをするんじゃな\nいんですか？　いきなり足でさせるだなんて……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103120" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……まあ、エッチの上達が目的じゃないんですから、どうだっていいん\nですけどねー。それより、どうですか？　気持ちいいんですか？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103121" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、あははぁ、聞くまでもないって感じですねー……よし、このままガシガ\nシ行きますよー。こういう時は、ためらってはいけませんよねっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103122" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「古人いわくっ、善は急げ！　速度こそ正義という意味ですっ……はぁ、はぁ\n……え？　意味が違う……？　そんなの些末なことですっ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103123" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……さあ、どんどん、力を込め、動きを大きくして行きますよー\n……はぁ、はぁ……んん、は……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103124" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ……段々調子が出てきましたっ……ふぅ、ふふ、このまま『おち\nんちん足ゴシゴシサムライ』の二つ名を得られるかもしれませんね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103125" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……ふぅ……ふふ、気持ちいいでしょう？　え？　ちょっと痛い？　錯\n覚ですっ……さあ、もっと行きますよー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103126" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……ふぅ、ほらほら、オチンチンが、ビクビクしていますっ……気持ち\nいいんでしょ？　え？　普通に痛い？　痛気持ちいいってことですね？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103127" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、はぁ、あははは……人間素直が一番、ですっ。さあ、いっぱい気持ち\nよくなって下さいねー……わぁ、あたし、サービスいい～♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103128" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ふ、ん、はぁ、はぁ……あああ、オチンチン、こんなに大きく、硬くなっち\nゃって……はぁ、はぁ……ん、あぁあ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103129" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「爪先が、ジンジンしちゃいます……はぁ、ふぅ……あたしの爪先、そんなに\n気持ちいいんですか？　うふふ……もう、隊長ったらぁ……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103130" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ほら、あたしのパンツ、もっと見ていいんですよ……はぁ、あはぁ、隊長の\n視線が、ムズムズして、気持ちいい……はぁ、ふぅ……ん、んんん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103131" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はー……はー……え？　イキ、そう？　ふふふ、さすがあたしの足使い……\n性欲を成敗って感じですね！　はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103132" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「いいんですよー……いつでもイッて下さいねー……はー……はー……このま\nま、たっぷり、ぶち撒けくれて構いません、から……んん、あふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103133" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あぁぁ……隊長、苦しそう……ふふ、ほら、今楽にしてあげます……！　だ\nから……はぁ、はぁ……いっぱいイッて、下さいねー……♪」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103134" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……はぁ……さあ、トドメですっ！　不言行殺！！　せぇの……よっこ\nらしょ～～～……っとぉ！！」」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103135" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ひゃぁぁぁん！！？　あっ、あああ、あはぁぁ……すごぉい……こ、これが、\n精液、なんですねー……はー……はー……あふぅ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103136" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「うわぁぁ……リアルで見たのは、初めてです……はぁ、はぁ……おお～～…\n…本当に白く濁ってる……それに、変な匂い……くんくん……んふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103137" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ああぁ、まだ出てる……うわぁ、あたしの爪先、精液でドロドロにされちゃ\nってる……はー……あふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103138" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「うわぁ、いっぱい、出るんですねー……これ、おしっこより出てるんじゃな\nいですかー？　はぁ……爪先がビチャビチャぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103139" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……ふぅ……ふふ、恥ずかしかったぁ……でも、興奮して……今も胸が\nドキンドキンしています！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103140" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「隊長のトレーニングって、すごいんですねぇ……まあ、ストッキングは駄目\nにされちゃいましたけど……。ちゃんと弁償して下さいね──」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103201" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「……って、これで終わりじゃない？　え？　あ、そうなんですか……。ええ\nっと、ひょっとして、続きをするつもり……なんでしょうか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103202" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、ああ……マジですかー……うーん……隊長って、アレですね……アレ…\n…なんているか、性欲モンスター……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103203" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「え？　いや、何でもありません。なんにも言ってませんよー？　きゃー、隊\n長ってセクシーでかっこいい～～！　そう言ったんです。ほんとです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103204" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「ええっと、それよりもですねー……このまま続きをすればいいんですか？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103205" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「つまり、またおんなじように、『おちんちん足ゴシゴシサムライになれと…\n…そーいうことですか？」」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103206" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ、わかりました。まあ、さっき頑張ったので、段々慣れてきたところな\nんですよねー……だから、さっきよりも、早めにやってみます」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103207" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、いえ、かったるいからとっとと終わらそうとか、そーいう意味じゃない\nんですよー？　ええ、マジで」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103208" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「さて、と……それじゃあ、早速やってみましょう……よいしょ、どっこいし\nょっと……ん、んん、はぁ……あふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103209" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「うわぁヌルヌルがすごぉい……。精液の感触って、本当にすごいですね……\nはぁ、はぁ……変な感じぃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103210" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「でも、ん、んん……ふう、オチンチン扱くと、スルスルぬるぬるして……オ\nチンチン気持ちいいんだろうなーって……はぁ、んふぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103211" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「はぁ……んふぅ……あれ？　ヌルヌルした感じが、ネトネト感に変わってい\nく……はぁ、ふぅ……これ、どうしてなんですかー？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103212" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へぇ？　精液って、すぐ乾いてしまうんですか……へぇ、そうなんですか…\n…どうりで……ん、はぁ……んん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103213" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あ、でも……すぐ乾いたりして大丈夫なんですか？　子宮にたどり着くまえ\nに乾いちゃったりしたら、精子死んじゃいません？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103214" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へ？　大丈夫なんですか？　あ、ああ、オマンコの中は湿ってますもんね…\n…あ、あはは……確かにそうですねー」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "102_0103215" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あー、その、あたし……セックスのこと、全然詳しくなくって……えへへ…\n…」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010201_01_05" ]},		{"command":[ "WAITINPUT" ]},
