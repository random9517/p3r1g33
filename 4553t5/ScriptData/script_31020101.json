		{"command":[ "PLAYVOICE", "102_0103105" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「あぁぁ、ど、どうして、こんなことになっちゃってるんですか～～……ああ、もう\n……お、お、オチンチンが……あたしの足で……」", "NORMAL" ]},
