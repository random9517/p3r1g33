		{"command":[ "PLAYVOICE", "102_0103103" ]},		{"command":[ "SETNAME", "破" ]},		{"command":[ "SETTEXT", "「へ？　恥ずかしいことをしろ……ですって？　あー、いやー……そーいうの\n、遠慮したいですねー……あははー。じゃあ、あたしはこの辺で──」", "NORMAL" ]},
