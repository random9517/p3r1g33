		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ。お前、わかってるよな？　ハロウィンなんだから、ちゃんとア\nレを用意してるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404102" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お菓子はもってないのか？　そ、そういうことなら仕方ないな。お菓子じゃ\nないのを、もらうしかないみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404103" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ほら、ここ……。発情期と重なっちまって、オマンコが\nめちゃくちゃ疼いてるんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「前張りパンツもすっかりぐしょぐしょになるくらい、汁……垂れ流しちゃっ\nてて……。はぁ、はぁ。だからさぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ははっ、お前もその気になったか？　そう、チンポをオマンコに……んっ、\nああっ、こすりつけて……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「焦らす必要ないってぇ。オレのオマンコ、すぐにハメても大丈夫だから……\nあっ、ああっ、はやくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……へ？　この衣装はなんだって？　そりゃあ、キョンシーだけど……。お\n、お前のことをご主人様と呼べだぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いくらキョンシーの格好してるからって……。でも、そうすればチンポくれ\nるんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ついでにおねだりもしろぉ！？　くぅっ、し、しかたない……やってやるよ\n、今日だけ、お前のキョンシーになって、言うこと聞いてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だ、だから……ご、ご主人様……。んっ、発情キョンシーの、オマンコに…\n…チンポ……チンポを、ハメて……ください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁあああぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「い、一気にきたぁっ！　お前、もっとゆっくり挿れたっていいじゃないかぁ\nっ、んっ、ああっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「待てっ、待てって！　んっ、んくっ、イッたから、さっきので、オレのオマ\nンコ、イッちゃったからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、すごく太いぃ……っ！　チンポが、出入りして……中、いっ\nぱいかき回されてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、でっぱりがオマンコひっかいて……んくっ、ごりごりって、気持ち\nいい……っ！　あっ、ああっ、もっとそこ……ぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前も、ンッ、気持ちいいのか？　さ、さっきから、激しく……腰を、振り\nまくって……んぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、発情してるから……オマンコが、すごくチンポを欲しがってるから\n……！　すごく、締まってるんだぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「キツキツのオマンコで、お、お前のチンポ、ぎゅってして。ああっ、射精…\n…させようとして、る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そ、それだけじゃないだろって？　さっきから、オレのオマンコがイキまく\nってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それは、お前のチンポが気持ちいいからぁっ！　オマンコの奥まで届くオス\nらしいチンポで、子宮口までぐりぐり犯してくるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「も……もっと突いて……お前のチンポで、オマンコもっとめちゃくちゃにか\nき回して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、そ、そうだった……ご主人様だったぁ……。ご主人様……エロキョ\nンシーの濡れマンコ……いっぱい、犯して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃぉっ、そ、それ好きぃっ！　ずんっ、ずんって、オマンコの一番深いと\nこまで、力いっぱいチンポねじ込まれるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ガッチガチのチンポに、子宮つぶされるぅっ！　んひぃっ、屈服させられる\nっ、子宮制圧されるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぉっ、おおっ、そんなに……っ！　んぉっ、チンポ、チンポで……あっ、\nああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「突かれまくると、子宮おかしくなるっ！　くひっ、どんどん汁、あふれさせ\nて……ご主人様のチンポに、夢中になるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オマンコ発情しまくって、きゅうきゅうチンポ締めるぅっ！　んぁっ、ご主\n人様の精子っ、中出しっ、して欲しいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「子宮にたくさん、ご主人様の子種欲しいのぉっ！　ご主人様っ、オレ、おか\nしい……こんなに、子宮疼いて……んぉっ、イキそ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、ご主人様のピストン……！　は、激しくなって、ま、ますま\nすチンポがぶっとくなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「このまま中出し……ご主人様に、種付けしてもらえる……！　ああっ、して\nっ、してぇっ！　種付けしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「精液欲しがってる発情マンコに、ご主人様のドロドロ孕ませ汁、たくさん、\nたくさん注いでぇえええぇぇぇ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あうぅうううぅぅぅ～～～～っ！　あっ、ああっ、でてるっ、熱いのが注が\nれてるぅ～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くひっ、ひぃっ、ご主人様の子種、たくさん注がれて……。オレも、イク…\n…ッ、オマンコ……イ……イッてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だめぇ……気持ちよすぎて、腰が、抜けちゃう……んぁっ、ああ……ああぁ\n……でるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃはぁあああぁぁぁ～～……っ！　おぉ……オシッコぉ……。あっ、ああ\n……とまらないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ご主人様に種付けされて、オマンコすっごく悦んじゃってるよぉ……。はぁ\n……はぁ……まだオシッコでてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やっぱりお前のチンポすごいぃ……。お前のチンポ……めちゃくちゃ気持ち\nよくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「熱い精液でオマンコいっぱいにされると……美味いもん食べたあとみたいな\n、幸せな気持ちに、なるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。すっきりしたぁ……。発情も、少し楽になったみたい…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！？　ま、待てってお前……あぉっ、おっ、チンポ、また動いて…\n…くひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ご主人様を放置して、ひとりで満足するんじゃないって！？　くはっ、その\n設定、まだ生きて……んひゃぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だめ、だめだって、イッたあとだから……あっ、あぉおっ、オマンコ痺れる\nっ、ご主人様のチンポ、まだガチガチぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、硬いのでまた、オマンコ突きまくられるっ！　んぁっ、チン\nポすごいっ、激しいの、気持ちいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いっぱい中出しして、しっかり種付けしてやるって、くひぃっ、んなこと、\nふ、ふざけるな……あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そんなにしなくたっていいのにぃ……。んはぁっ、で、でも……でも……オ\nマンコまた、疼いてきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「発情して、ご主人様のチンポを搾るみたいに、ぎゅうぎゅうって動いちゃっ\nて……あっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「尻尾振っちゃう……腰も振っちゃう……！　こ……このチンポを……身体が\n勝手に欲しがっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぉおっ、おっ、激しいっ。中出しされて、ドロドロになったオマンコ、い\nっぱい、突かれてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「またチンポの先っぽで、オレの子宮をゴツゴツ叩いてくるっ！　おっ、おお\nっ、覚えるっ。ご主人様のチンポ覚えるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぶっといオスチンポでオマンコ調教されるっ！　主従関係わからされちゃう\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くひぃっ！　強いっ、チンポ強いっ！　思いっきり腰を打ちつけて、オレの\nオマンコめちゃくちゃにされるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、イッてる……オマンコ、イッてるからぁ……。ご主人様に、\nイかされまくってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000414_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「イキまくって、チンポ、きゅうきゅう締めつけるぅ……！　んぉっ、おおっ\n、ご主人様ぁ……もっと、使って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「発情メス犬キョンシーのトロトロマンコ穴ぁ……ご主人様が、満足するまで\n、じゅぽじゅぽ突きまくってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
