{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
 		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
 		{"command":[ "DISPIMAGE", "0", "true" ] },
 		{"command":[ "FADEOUT", "NORMAL" ]},
 		{"command":[ "PLAYBGM", "BGM_005" ]},
 		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "将軍風の男" ]},
		{"command":[ "SETTEXT", "「即応部隊はすでに待機中だが、襲来者（インベーダー）をどう察知する？」", "NORMAL" ]},
 		{"command":[ "DISPNAME", "TRUE" ]},
 		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "黒マントの男" ]},
		{"command":[ "SETTEXT", "「わが組織の観測網を使えば、ある程度以上の空間変動は補足できるはずだが \n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "白衣姿の男" ]},
		{"command":[ "SETTEXT", "「組織間のデータリンクが問題だな。調整に少し時間が必要だ。あとは人員」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "妖艶なドレスの女" ]},
		{"command":[ "SETTEXT", "「人はこっちから出せるわよ。とにかく、やれるだけのことはやってみないと \n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "黒いルナテミス……いや、Ａルナテミスの言葉は、会議の出席者たちに強い衝 \n撃を与えた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ああでもない、こうでもないと右往左往していた連中がすごい勢いで、正義と \n悪の垣根を越えた協力体制を築きつつある。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "共通の危機を前にしたときに、人々の団結力は強まる……ってな話はよく聞く \nが、これにはちょっとビックリだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "しかし何より驚いたのは――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「――ということで、よろしく頼む。ムーンナイトくん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
 		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ええええ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、なんでこいつが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「びっくりしたなあ！　もう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご指名ですぞ、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。聞いておられますかな？　ご主人？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101100002" ]},
 		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おい！　しっかりしないか、このゴクツブシ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「納得いかん……なぜこのような役立たずが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　あ、ああ……なんとか。あの、今、なんと？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もしかして、話を聞いていなかったのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、聞いてた。聞いてたけどな、あまりのことに一瞬意識が……あの、す \nみませんがもう一度」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ムーンナイトくん。君には悪と正義の混合チーム、『独立超常部隊（インク \nレディブル・スクワッド）」の隊長に就任してほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100002" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「や、やっぱりぃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんだよ！　正義と悪の混合チームって！　なんで正義と悪を混合すんだよ！ \n　よく言うだろ『混ぜたら危険』って！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "だいたい、正義の味方も悪の幹部も、どいつもこいつも一筋縄じゃいかないっ \nつーか、面倒くさいヤツばっかりじゃねえか！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "嫌だ！　そんな面倒なヤツらの隊長になんかなりたくない！　断ろう！　ここ \nはビシッと断ろう！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと、あのですね、私ごときをそのような大役に抜擢していただけるなど \n、大変に光栄ではございますが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "あ。いかん。ビシっと断るつもりが……。なんだか偉そうな相手には、いつも \nの癖で下手に出ちまう……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "まあ、いいや。とにかく、相手の機嫌を損ねないことも大切だ。このままいこ \nう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『が』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100003" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「私はあくまでグレート・ルナリアムのいち幹部でありまして、そのような面 \n倒くさ――げふんげふん、栄誉ある立場は分を超えるかと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがご主人。円熟のへつらい芸ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101100003" ]},
 		{"command":[ "SETCHARA", "0", "char_00000901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……このクソ犬。あとでしばく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに敬愛する女王様の許しが無い事には、勝手な事は出来ませんし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "これだ！　女王の名前を出せば、どうにか面倒くせえ仕事を断れるだろ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なるほど。謙虚なことだ。だが、その心配はないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100004" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そうおっしゃるだろうと思って、先に許諾を得ておきました。そうですよね \n？　陛下」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101100001" ]},
 		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ、へいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "お七がそう言った瞬間、部屋の一角にあった通信装置のようなものに灯りが \nついた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あー、あー、マイクテスト、マイクテスト。本日は晴天なりなのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「えっ？　何？　もう繋がっておるのか？　それを早く言わぬかばかもの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ルナルバース陛下。さっそくですが、今回の出向の件、ご承認いただけてお \nりますよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101100002" ]},
 		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おお！　久しいのぅお七。相変わらず息災かのぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ、陛下にあらせられましては、変わらずご健勝のようで何よりでござい \nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101100003" ]},
 		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おお、もちろんじゃ！　お主と二人で呑み明かした日が懐かしいのぅ……。 \nそういえばお主、あの話はどうなったのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あの話と申しますと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101100004" ]},
 		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「え～と、アレじゃよアレ……、ぬぅ、年のせいか最近もの忘れが激しくての \nう……なんじゃったか、ほらここまで出かかってるんじゃが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100005" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「陛下、思い出話はその辺にしていただき、本題のほうに入りたいのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100005" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ん？　ああ、すまんすまん。通信料金もバカにならんしの。で、なんじゃっ \nけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100006" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ムーンナイト殿を、特別超常部隊の隊長に出向させていただく件。ご了承い \nただけますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100006" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んん？　ああ、その件か。良きに計らってもらって構わんのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100007" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ、陛下！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんでだよ！？　なんでもう外堀が埋まってんの！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「無論、無条件とはいかぬ。グレート・ルナリアムの仕事も兼任すること」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100008" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "それすなわち、俺には休む暇がないってことでは！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そして、新たに発現した能力について解明をすること。ひょっとしたら、万 \nが一にも、奇跡がおきる可能性がワンチャンあるのであれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100009" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれば？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「最底辺の負け犬に与えられた力が貴重な戦力になるかもしれんのでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100010" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ひでえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、そういうことじゃよー。しっかり励めよ、カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100011" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ううう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「と言いつつ余は去る。そんじゃあの、お七。また近いうちに飲みに行こうで \nはないか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101100012" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「と、いうことですが。この話、お受けいただけますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010101100005" ]},
 		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……はい。ですが、あの……せめて労働条件を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「詳しくは後ほど書面でお知らせするが、ひとまず給与等については、社保完 \n備、手取り１７万ということでお願いしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010101100007" ]},
 		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい……勘弁してくれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "グレート・ルナリアムよりは給料いいけど……どう考えても割に合わねえ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、がんばって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101100002" ]},
 		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わたしたちも、協力は惜しみませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101100002" ]},
 		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。隊長の人選に不満はあるが……たしかに、機動力のある実働部隊 \nは必要だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101100002" ]},
 		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「姫様がそうおっしゃるのでしたら、我らにも異論はございません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101100002" ]},
