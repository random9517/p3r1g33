		{"command":[ "PLAYVOICE", "079_0103101" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ははっ……。なんだいなんだい。僕をこんな殺風景な場所に呼び出して……\nこんな部屋があるなんて、今の今まで知らなかったぞ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103102" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君も重々知っての通り、僕は毎日多忙でね……。余計なことまでしていられ\nないんだが……。折り入っての相談かい？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103103" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕にわかることなら答えよう……。と、ふむ。これはそういった話ではなさ\nそうだな……どうも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103104" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「うん。全裸の隊長、不完全ながらに密室……。そうか、これはそういうこと\nなのか？　……なんだって？　パイズリフェラ……をしろ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103105" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ぷ、ふふ、ふふふ……すまない。あまりに突飛なことを言うものだから笑っ\nてしまった。君、僕を性欲処理に使おうってのかい？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103106" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……へえ。そうじゃなくて、パワーアップのため……？　嘘もそこまで堂々\nと言えば、真実味を帯びてくるね。まあ……構わないか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103107" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「処女をくれというならお断りだが……胸と口、ねえ。それくらいなら体験し\nてみるのも一興かな。……で？　こいつを挟めばいいんだね？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103108" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「よ、と……。こうかな？　はは、おかしいね。僕のような風変りな女でもう\nこんなにしている。はいはい？　思ったよりバストのボリュームがある？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007901_01_01" ]},
