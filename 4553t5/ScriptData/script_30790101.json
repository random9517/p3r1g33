		{"command":[ "PLAYVOICE", "079_0103139" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……ごくっ……ごくんっ……。ぷは……！　やれやれ……これで満足かい？\n　だが、覚えておくんだね。僕の身体は支配出来ても……」", "NORMAL" ]},
