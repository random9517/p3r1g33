		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「パワーアップとやらを実感する意味でも……君の汚れは僕が処理してあげよ\nう。少しくすぐったいかもしれないが……我慢したまえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0103137" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ちゅぱ、ちゅぱ……れろっ……。ちゅ……ちゅっ、ちゅううっ…\n…ちゅ……っ、ん……尿道口と亀頭を舐め清めた後は……」", "NORMAL" ]},
