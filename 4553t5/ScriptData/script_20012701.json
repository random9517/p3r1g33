{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "──お亥様の導きにより、サムライテールとなった序・破・急の三姉妹。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今日も今日とて自分の成績と世界の平和を守るため、悪と戦う日々を送ってい\nた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だがしかし！　今日は苦戦の真っ只中にあった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ほ～～ほっほっほっほ！　今日は随分動きが鈍いな！　この私に臆したか？\n」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……はぁ、お腹空いたねー……最近、なんだか虚しいんだよねー。こう、日\n々の潤いが足りないっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021870001" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ホントそう。どうして貴重な青春を、災厄退治に費やさなきゃいけないの…\n…？　はぁ、超かったるい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021870001" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ほら！　つべこべ言わずに戦うです！　破！　悪者退治をしてなきゃ、補習\nや課題に追われる青春を送っていただけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870001" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うわっ、そういうガチな意見、今いらないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021870002" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「急！　終わったらファミレスに連れてってあげるです。だからもう一踏ん張\nり、気合い入れるですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870002" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……またファミレス～～～～……？　最近飽きて来ちゃったんだけど…\n…ま、いっか～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021870002" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「さあ！　ふたりともしっかりやるです！　私は……明日のテスト勉強で徹夜\nするので、余力を残す必要があるですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870003" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「普段から勉強していないから、一夜漬けなんてしなきゃならんのだ！　ええ\nい、真面目に戦う気がないようだな……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「ありませ～～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870004" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "1", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「はっ、やれやれだ！　だが好都合。これを機に、貴様ら三人をまとめて地獄\nに落とし、今後、楽に怪人活動をさせてもらうとしよう」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……は！　そんなことは、私の可愛い妹二人が許しません！　さあ、ふたり\nとも、しっかりと働くです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870005" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「はー……今、気分が乗らなくて……ほら、よく言うじゃない？　古人曰く…\n………あー、えー……ちょっと思い浮かばないけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021870004" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「う～ん、やっぱファミレスはちょっと……。ホテルのバイキングがいいな～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021870004" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、どう？　我らが妹達の本気を！　これに免じて、今日は許して\nあげるです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870006" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「はっはっは！　やれやれ……お前達との付き合いも、今日で最後になりそう\nだな……よし、みんな！　一斉にかかれ！！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……もう、仕方ない。やるしかないか……ほら、ふたりとも、そろそろ\nガチるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870007" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういいながら、三姉妹は各々刀を構え直す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "三人は本気でやる気を失っているが、若苗家の血の定めまでは忘れていない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「仕方ないなぁ……ってか、この人達、今日息の根を止めれば、あとあと楽に\nなるのは、あたし達の方なんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021870005" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「おねーちゃん、バイキングだよ？　絶対だからね……よーし、殺るぞ～～～\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021870005" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「戦闘開始！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021870008" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}