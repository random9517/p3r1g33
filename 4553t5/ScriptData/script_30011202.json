		{"command":[ "PLAYVOICE", "v2_001_1204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、うんっ、私もイクわっ……何回目かっ……わかんないけどっ！\n　ひぁっ、気持ちいいのっ……止まらなくてっ、イクっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「貴方も出してっ……熱いのっ……いっぱいっ、びゅくって……してぇぇぇっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「また中出しがいいのっ？　いいわっ……赤ちゃん出来てもいいからっ、この\nままっ……中にっ、オマンコの奥にザーメン出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃぃぃっ！　またっ……中っ……出てる……はぁぁ……中出し\n二発目……気持ちいいのぉ……ふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、また……出てるの……わらひ……潮吹きしちゃってる……\nやら……止まらない……力抜けちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁ、あぁ……オチンポがまだ中で震えてるのだけ……何となく\n分かるわ……いっぱいにされてる感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……ここまで来たら……ちゃんと出し切ってね……中途半端に残したり\nしたら承知しないわよ……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「は……ふっ……出した……？　はぁぁ……本当にいっぱいにされちゃった…\n…んっ……ふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ、お腹の中でオチンポがすごいことになってる……我ながら、\nよくこんなのの相手が出来たって思うわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「言っておくけど、今日のは本当に特別の特別で……いつでもこんなことが出\n来るなんて思ったらダメよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「来年！？　ま、まぁ……それは……そうね、一応……特別な一夜なら……間\n違ってはないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「別にそうじゃなくても、してあげ……な、何でもないわっ！　考えておくっ\n、それでいいでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今度はっ……からだっ……掛けたいのっ？　あぁっ、何でもいいわっ……ど\nこでも好きにしていいからっ、出してっ、精液出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁんっ！　出てるっ……掛かってる……熱いのっ、びゅく\nびゅくっ……飛んでるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ……すごっ……いいっ……わらひもっ……またお汁出しちゃってる……\nはひぁ……潮吹き……漏れちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、掛けてぇ……ドロドロの、全部肌に染み込ませてほしいのぉ\n……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「この匂い……んんっ、あぁ……ネバネバのとろとろぉ……はぁ……マーキン\nグされちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、出した……？　オチンポの先についてるのも……全\n部、なすりつけちゃいなさい……今だけ許してあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、こんなになっちゃうなんて……衣装にもめちゃくちゃ染み込\nんじゃったじゃない……クリーニングにも頼めないわ、こんなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「言っておくけど、今日のは本当に特別の特別で……いつでもこんなことが出\n来るなんて思ったらダメよ？」", "NORMAL" ]},
