		{"command":[ "SETIMAGE", "0", "still_00000112_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……そうなのね、私……こうなるようにされちゃったのね……\n貴方のオチンポで、悦ぶ身体に……なっちゃったぁ……あ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……いっぱい……お腹の内側から広げられていくみたい……何で、こ\nんなに大きいのよ……んぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私が大きくさせてるなんて……んっ、いつも調子のいいことばっかり言って\n……分かったわ、ちゃんと責任とればいいんでしょ？」", "NORMAL" ]},
