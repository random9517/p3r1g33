		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「別に分かってるわ。クリスマスだから特別とか……サンタの衣装だからそれ\nらしいこととか、何もないわよね……そうよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204102" ]},
