		{"command":[ "SETIMAGE", "0", "still_00000112_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「うんっ、あぁ……おっぱいも……触ってぇ……んぁ……乳首ぃ……んっ、指\n……転がしてぇ……そう、それ、あぁ……それぇ……」", "NORMAL" ]},
