		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね……確かに、いつもよりは優しい、のかしら……んっ……おっぱい…\n…それぐらいの加減で……ちょうど、いいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下の方も……？　うん……いいわ、指……入れて……あっ、はぁんっ……あ\nふっ、つぷって……来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……オマンコ……浅い所で……出し入れして……あっ、あんっ…\n…ク、クリトリス……転がしてる……はっ、んく……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
