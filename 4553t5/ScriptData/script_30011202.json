		{"command":[ "PLAYVOICE", "v2_001_1204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぅんっ……変な所で律儀なんだから……ぁっ……んぁんっ……ひぁっ、ん\nふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「か、感じやすいって……誰のせいだと思ってるのよっ……貴方が、しつこく\n弄って……んっ、そういう身体にさせたんでしょっ……は、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「で……い、いつまでこうしているつもり……？　も、もうそろそろ……よく\nない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「何がって……今更とぼけてどうするのよっ……分かり切ってる……んっ、く\nせにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……分かったわよ……ちゃんと言う、言うからぁ……ね……オ\nチンポ、入れて……ここっ、私のじゅくじゅくオマンコにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「欲しがってるの……分かるでしょ？　ここぉ……貴方に開発されて我慢でき\nなくなっちゃってる、スケベオマンコにぃ……オチンポ入れてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ……んぁぁぁぁぁぁーっ！　はぁんっ……入って来る……全部……ずぶ\nってっ、はぁんっ、あっ、ひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000112_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……入っちゃった……熱いの……んんっ、ぶっすり……オマンコに刺\nさってるぅ……んくぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こ、こんなに大きかったかしら……ひゃふっ、あぁっ……やだ、オマンコ…\n…ウズウズしてる……んんっ、何これぇ……」", "NORMAL" ]},
