		{"command":[ "PLAYVOICE", "v2_001_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あひぁっ！　オマンコっ、そんなっ……んぁぁっ、ぐちゅぐちゅっ……され\nてるっ、ひぃんっ、やっぱりオチンポいいのっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
