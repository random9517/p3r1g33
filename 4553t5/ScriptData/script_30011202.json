		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちゃ、ちゃんと優しくするからって……そういう意味で言ってるんじゃ……\nひゃっ、あぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
