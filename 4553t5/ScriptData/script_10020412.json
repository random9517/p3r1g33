		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「一人では出来ない事を、協力して……する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670049" ]},
