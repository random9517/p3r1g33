		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……侵略者たちのアジト、その片隅。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "侵略者のリーダーは、２人の円盤少女に左右からぐいぐいと腕を引っ張られて\nいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「ねーえー。今日は出撃しないの？　暇だし面白くない～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "1", "CENTER", "0" ]},
