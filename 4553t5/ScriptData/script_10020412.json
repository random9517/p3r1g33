		{"command":[ "SETCHARA", "0", "char_00016201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「この星のテレビ、面白いから好き～。何見る何見る～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670006" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しばらくの間、地球の映像に夢中になってかじりついていた円盤少女たちだっ\nたが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "束の間の平穏は５分ともたず、大きな歓声がアジトを包みこむ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「え～～～～～っ！　これいいな！　いいな！　食べたい食べたい～っ！」", "NORMAL" ]},
