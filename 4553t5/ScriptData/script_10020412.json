		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「自分がモタモタしている間に、どんどん店員が集まってきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670041" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "1", "CENTER", "0" ]},
