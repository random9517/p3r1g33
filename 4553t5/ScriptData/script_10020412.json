		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「なんかここ暑い～。冷房つけて～。リーダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「それからこのゴミ、ゴミ箱に捨ててきて～！　あと、おもしろいことやって\n！　退屈なの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「おトイレいくのめんどくさいから、代わりに行ってきて、リーダー！」", "NORMAL" ]},
