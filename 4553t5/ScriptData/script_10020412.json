		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦闘時に見せる冷たさとは裏腹に、アジトでの彼女たちは天真爛漫……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "手の付けられない暴れん坊に変貌し、なにかとリーダーに無茶な要求をしてく\nる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「私は多忙だ！　しばらくテレビでも見て二人で遊んでいろ！」", "NORMAL" ]},
