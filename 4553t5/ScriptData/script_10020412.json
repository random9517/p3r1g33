		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「レジ待ちの列も伸び、皆に見られてまた混乱して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670042" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "最後はわけもわからず、お金を払って店内から逃げ出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「コンビニスイーツ一つ買うことが、こんなに大変なことだったとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670043" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「自分は何もできないんだな……。これでは、確かによわよわリーダーだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670044" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "涙目になり、猫背になっての帰り道。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "嗚咽をこらえながら歩いていたリーダーは、通りすがりに見つけた学校から聞\nこえるにぎやかな声に顔を上げた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……あれは？」", "NORMAL" ]},
