		{"command":[ "SETCHARA", "0", "char_00016201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670001" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "円盤少女たちに毎日毎日、こきつかわれる生活……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "無邪気でわがままな円盤少女たち……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "戦力としては非常に頼りになる存在だったが、こちらをパシリ扱いにしてく\nるのには耐えられん……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「うりうり。うりうり。リーダーちゃんのほっぺたムニムニムニ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113670003" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……やめてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670004" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「なんで？　遊んであげてるんだよ。ねーつまんない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113670004" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「だっこしてー。それかおんぶー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670003" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「わたしはひざまくらがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113670005" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「ね～。髪におリボンつけてもいーい？　おままごとしたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670004" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「わたしは怪獣ごっこする！　ね～口からビーム出して、炎でもいいよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113670006" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「それいいなあ。ビーム！　ビーム！　ビーム！　びびびび！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670005" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「地球の生命を駆逐せよ～！　きゃははははは！」", "NORMAL" ]},
