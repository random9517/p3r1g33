		{"command":[ "SETCHARA", "0", "char_00016301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……ええい、面倒な！　完璧にお使いをこなせばいいのだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670018" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "売り言葉に買い言葉で、リーダーはアジトを飛び出していった……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「わぁい。これでおいしいおやつが食べられるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010113670023" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「もっとこの星の情報を集めなくては。せっかく地球に接触できたのだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670021" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「いずれ支配するこの土地の、楽しいことを知らなければだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113670022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0161" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……と、やってきたはいいものの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670019" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "リーダーは、いまだに見つけられずに無意味に周囲をウロウロするばかりだっ\nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「部下に渡されたスマホで検索しようにも、このっ……画面がうまくスクロー\nルできない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670020" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「それにどういうことなんだ、コンビニに様々な種類があるというのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670021" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「緑の看板のコンビニ、青い看板のコンビニ……ぐぬぬぬ。自分が向かうべき\nなのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670022" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「数字の書いてある赤いコンビニ？　それがどこにあるかわかれば苦労はせん\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670023" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……きちんと出かける前に、部下に情報を聞いていたというのに、なんたる体\nたらくだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「あいつらが言っていた通りにしているのに、うまくいかない！　ああ……イ\nライラする……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670024" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0111" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「え～？　コンビニスイーツの買い方ですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「この星のコンビニが、どういう形式なのかはよくわかりませんけど～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、スマホを貸してさしあげます！　それで調べたらいいと思いますよ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｂ" ]},
		{"command":[ "SETTEXT", "「うんうん。それはいい案ですね。スマホさえあったら、わかんないことなん\nか全部ググってすぐにポンって出ますから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ぐ、ぐぐる……？　よくわからんが……それをすれば解決するのだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670025" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「ええ！　すっごく簡単ですから！　もー、スマホがあれば大抵のことはわか\nりますんで！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「そういうものなのか……。うむ、では出かけてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670026" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｂ" ]},
		{"command":[ "SETTEXT", "「いってらっしゃいませ～！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0161" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「結局ぐぐる？　の意味もやり方もわからんっ……クソッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670027" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……自分は、こんなことすら出来ないのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「だから地球人に敗北し……こんな暮らしに身をやつしたのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "肩を落とし、自虐しつつ、慣れないスマホ相手に格闘する。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなリーダーを見かねてか、誰かが後ろから声をかけてきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「お主、何か困っているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……！　だ、誰だ！　貴様は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670030" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "警戒し、構えを取ろうとしたリーダーのその腕を掴み、あやしい仮面の女はぐ\nいぐい接近してくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「困っているなら、ぜひとも私に相談するといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「お主、どこから来た？　このあたりでは見ない顔だが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さっきから必死で何か探していただろう？　……よければ力になるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……コンビニスイーツを……探していて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670031" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふむ。どんな色で、種類はなんだ？　……ん、スマホがあるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「画面に映っているこれか？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670006" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「あ、ああ、たぶんそうだ。だが……私にはこれがどこにあるのかまったくわ\nからなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670032" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不安そうな顔をするリーダーの背を、仮面の女がバシンと叩く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「なんだ、それならこの店にも売っているはずだぞ。少々待つがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670007" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「え、え、え」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670033" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「店員よ、スイーツの棚はどこだ？　ああ、そっちか。見落としていたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670008" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほら。こっちだ。……これだろう？　お主の探していたスイーツは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……そ、それだ！　ああ、間違いない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670034" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「数は２つ？　ははっ、良かったな。ちょうど２つ残っていたようだ。他に欲\nしいものは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670010" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「あっ……オレンジジュースとサイダーが必要で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670035" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふむふむ。であれば飲み物はこちらにある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670011" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "仮面の女はテキパキと目的のものを選び出し、カゴに入れて手渡してくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「オールコンプリートだ、おめでとう。これでいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "にっこり微笑む仮面の女に、リーダーはこくこくとうなずいた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「であれば良かった。困った時は助け合い、だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670013" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「また何かあれば、人に頼れよ！　一人で悩み苦しんでいても、何も解決しな\nいからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020113670014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "格好つけて、颯爽と去っていく仮面の女。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670036" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "リーダーがぼーっとしていると、店員が声をかけてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "店員" ]},
		{"command":[ "SETTEXT", "「あのー、買うならレジにどうぞ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「あっ！　あっあっあっ、ではこれを、あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670037" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "店員" ]},
		{"command":[ "SETTEXT", "「袋はいかがなさいますか～」", "NORMAL" ]},
