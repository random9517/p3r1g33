		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「生クリームましまし、いちごほいっぷ……。じゅるり」", "NORMAL" ]},
