		{"command":[ "SETNAME", "店員" ]},
		{"command":[ "SETTEXT", "「ポイントカードはお持ちですか？　ストロー何本お付けしますか？　あたた\nめますか？　冷やしますか？　クーポンがでまぁす」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ま、待ってくれ……。一度にたくさん言わないでくれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670040" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
