		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「なんだ？　ボールをぶつけあっているのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670046" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "校庭で、敵と味方にわかれて何かの競技をしている女達……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見事なコンビ技をきめる二人の表情は明るく、汗はきらめいている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「……すごい威力だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670047" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだか威力が出過ぎている気もするが、球を操る彼女たちはとても幸せそう\nだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「助け合い、か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010113670048" ]},
