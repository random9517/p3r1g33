{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ああ……とうとう、この時が来てしまったですね……緊張してるか、ですっ\nて？　そんなの当たり前です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604101" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「もっと、こう……ロマンチックな状況で、初めてを体験したかったです……\nそれを、まさか大嫌いな水着姿とは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ええっと、それじゃあ初めましょうか。眼鏡は外した方がいいです？　つけ\nたまま……？　ええ、問題ないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604103" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ということは、水着は脱がずにこのまま……？　あ、やっぱり……まあいい\nですけどね……さあ、初めましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604104" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……想像はしていましたけど、いざとなるとやっぱり緊張してしま\nいます……こんなに大股開きになるなんて、生まれて初めてかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「というか、こうして改めてみると、ううう……随分大きいです。こ、これが\nウチの中に……？　や、やっぱり水着、脱がせてくれませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604106" ]},

		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「駄目？　ええ、そういうと思っていました。あなたの、その水着への熱いこ\nだわり……いったい何なんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……いやがるウチを見たいなら、何も水着でなくとも……え？　挿れる\n？　もうですか？　あ、あの、心の準備がまだ──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「うあぁ！？　ぐっ、あうぅぅ……は、入って、ぐる゛ぅぅぅ……はっ、はぁ\n……あああうぅ、い、痛い……です……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くぅ、うう……うあぁ……お腹が、破れちゃうぅ……はぁ、はぁ……ひぐぅ\n、んぎぃぃぃぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ま、待って下さい……っ、一旦止めて下さい……はぁ、はぁ……あいたたた\n……そ、想像してたより、キツいです……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ううう……ウチをいじめて、満足ですか？　本当に、あなたって人は……は\nー……はー……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふぅ……少しマシになってきました……。ウチは小柄なんです……つまりア\nソコも小さいわけで……無茶は禁物です……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふぅ……もう大丈夫です。痛いは痛いですけど、泣き叫んだりするほどでは\nありませんね。はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ええ、泣いてないです。そう見えるとしたら、ん、ふぅ……気の所為です。\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そろそろ動きたい？　ちょ、ちょっと待って下さい……少し心の準備をしま\nすから……はー……ふぅ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「眼鏡が吐息で曇ってしまいます……まったく、眼鏡ぐらい外させてくれても\nいいのに……じゃあ、動いてくれていいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん……んんぁ、はぁ……お腹の中で、おちんちんが動いてる……あ、ぐぅ、\nふぅ……痛いです……でも、これぐらいなら、平気です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん、んん……奥まで、入ってくる……少し苦しい……はぁ、はぁ……んぐぅ\n、あうぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……ふぅ……ウチなら、大丈夫です。このまま続けて、下さい……はぁ\n……はぁ……あ、あ、あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「やっ、駄目……なんだか、変です……んっ、くぅ……あ、あなた、何をしま\nした？　急に……あ、あ、あはぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「硬くて、大きなものが、お腹の奥を、えぐってる……ああ、膣内がどうなっ\nているのか、鮮明にわかります。こ、これが……セックス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んん、はぁ、あぁぁあん……！　痛くて、苦しいのにどうして、こんなにぃ\n……はぁ……はぁ……きゃうぅぅん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はへぇ……あはぁぁ……どうして、こんなに気持ちいいんですか？　うぐぅ\n、はへぇぇ……全身が気持ちいい……ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「スク水で締め付けられている所も、気持ちいい……あああ、あの忌まわしい\n水着が、こんなに気持ちよく感じちゃうだなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん、んんぁ、はぁ……あはぁぁ……も、もっと……もっと、激しくしてくれ\nて、構わない、です……んん、くぅ……ひぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くんくん……はぁ、あはぁぁぁ……微かに血の匂いがします……うう、胸が\n悪くなる……。でも、興奮しちゃいます……くんくん……はへぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おちんちんと、アソコと、血の匂いが入り混じって……あはぁ、鼻の中に染\nみ込んでくるぅ……くんくん……ああ、気持ち悪いですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　濡れてる……？　もう、いちいちそういうこと言わなくていいです…\n…はぁ……はぁ……そんなことより、もっと激しくして下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あ……あああっ、腰が、ぶつかってくる……おちんちんが、お腹の隙間、こ\nじ開けてくるぅ……っ」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひぐぅう！　ひゃひぃぃ！　だ、駄目ですっ、そんなにされたら、ウチ、壊\nれ、ちゃ……あっ、ぐぅ、んぎぃぃぃぃ……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んはぁ、ああぁぁぁ！　す、すごい……体が、お腹の中が、おちんちんで持\nち上がっちゃう、です……ひっ、あぁ、はぁ……はぁぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あぐ、んひぃぃ……おちんちんが、ビクビクしてるのが、わかります……も\n、もうすぐ、イク、ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あああ……ウチ、中に出されちゃう……初めてなのに、いきなり……こんな\n恥ずかしい衣装を着せられて……それなのに、興奮、しちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「イ、イク……イキ、ます……はぁ、はぁ……あっ、駄目ぇぇ……ふぐぅ、ひ\nやああ！　はぁ、はぁ……ああぁぁぁぁあん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひゃひぃぃぃ！！？　アソコの中で、おちんちんが震えてる……！　ビクン\nビクン弾んでる……はー……はー……はへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あああ……出てる……ドロドロが、お腹の奥まで染み込んでくるぅ……はー\n……はー……ひふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「これが、精液……あああ、おへその裏側で、塊になってます……熱い……お\n腹が溶けてしまいそう……はー……んひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てる……妊娠しちゃうぅ……ああ、でも……体が喜んでいるです\n……あっ、あっ、イク、また……イッ、くぅ…………ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……んへぇぇ……すごい……セックス……気持ちいい、ですぅ……はー\n……はー……あふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふぅ、それで？　もう満足してくれたですか？　え？　まだまだ射精したい\n……？　続きをする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「もう……ウチの意思を無視しないで下さい。ロストバージンしたばっかりな\nんですよ？　こんな珍妙な恰好をさせられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……うう、水着の股間の部分がドロドロで気持ち悪いです……でも、どうせ\n脱ぐなって言うんでしょう？　もう……何がそんなに気に入ったんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ああ、息をするだけで、気持ちいい……もっと気持ちよく\nしてくれるんですか？　楽しみです……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んんんっ、ひゃへぇぇぇ……おちんちん、気持ちいい……あっ、あっ、あぁ\nぁ……お腹の奥で、ずるずる動いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さっきと、感触が、全然違います……こ、これっ、精液のおかげ、ですか？\n　ああ、すごい……精液、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くんくん……すんすん……はへぇぇ……この変な匂い……あぁぁ、アソコが\n、熱くなっちゃうです……ああああ……駄目……感じ過ぎちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「これじゃ、またすぐ、イッちゃいそう……はー……はー……あはぁ……ひゃ\nふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ、あはぁぁ、おちんちんが、中で震えてる……またイキそうなのです？\n　ふ、ふふ……また精液で、汚されちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　嬉しそう……？　はぁ……はぁ……嬉しい、かも……精液の匂いと、\n感触……ウチの理性をとろけさせてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あ、あ、やだ……乳首がカチカチになって……水着の生地に擦れちゃう……\nはぁ、はぁぁあん……気持ちいいのが、どんどん大きくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん、んん、はあ……あぁあん、腰が、動いちゃうぅ……体が、子宮が、もっ\nとおちんちん、欲しがってるみたい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「お願いです……ウチをもっと、気持ちよくして下さい……はぁ……はぁ……\nあああ、駄目、自分で腰を動かしちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ひやあああ！！？　あぐぅ、きゃうぅぅ……ッ！　おちんちんが、ぶつかっ\nてる……ウチの気持ちいいところ、つっついてる……」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ゴツゴツする音が、響いてる……お腹から気持ちいいのが、全身に広がって\n……あぐぅ、んひいぃぃ！　ああ、駄目……おかしくなっちゃうっ」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウチ、自分で動いてしまいます……ああ、なんてはしたない……ウチ、そん\nな子じゃなかったのにぃ……はぁ、ふぅ……ひゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それも、これも……はぁ、ふぅ……水着を着させられたままでいるから……\nふぐぅ、ひゃうぅ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「全部、あなたの、せいでう……だから責任とって、いっぱいイカせて、下さ\nいですぅ……はぁ、ふぐぅ、ほら、もっと、もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「自分から、おちんちん、迎えにいっちゃうです……あああ、根本まで入って\nる……ウチの小さなアソコに、太くて逞しいのが、全部……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あひぃぃ……駄目ぇぇ……イク、もうすぐ、イクです……はぁ\n、はぁ……ああぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あへぇ……？　また、中に？　い、いいです……出して下さい……子宮がお\nかわり欲しがってる、です……はー……あはぁ……ん、んんんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「出して、出してぇ……おちんちんから、溢れ出す白いので、ウチのお腹、埋\nめ尽くしてぇ……あっ、あっ、ひぐぅ！　ひゃひぃぃぃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ！！　はひぃぃ！　きゃうぅぅぅぅ……っ！　はー……精液が、出てる\n……ウチの中に、染み込んでくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あはぁぁ……溢れてる……アソコの入り口から、出したてのドロドロが溢れ\n出して……あ、すごいっ……精液の匂いぃ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「駄目ですぅ……呼吸をするだけで、イキそうになるです……はー……んへぇ\n……あああ、イクのが、止まりません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「アソコが震えてる……おちんちん、ギュゥと抱きしめてるぅ……はへぇぇ、\nきゃうぅぅ……本当におかしくなっちゃいそうですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……はぁぁあん……精液が、たれてる……お腹の奥から、滴ってくるー\n……はへぇぇ……気持ちいいぃ……んひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……はふぅ……まだ、イッてる……子宮が、精液でうがいをしてるみた\nいです……はー……ふぅ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くんくん……ふぅ……あなたと、ウチの匂いが混ざり合ってるです……ふ、\nふふふ……一つに溶け合ってるって感じがするですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「このままくっついて離れなくなってしまいそう……はー……ああ、水着がビ\nチャビチャ……流石に着替えさせてくれますね？　はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……体にぶっかける、ですか？　あぁん……子宮に欲しいのに\nぃ……でも、でも……精液の匂い、ダイレクトに味わえるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ああああ、駄目ぇ……想像しただけで、イキそうです……早く、早く下さい\n……んっ、ん、出してぇ……ウチに全部、ぶちまけてぇぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「きゃうう！？　あひぃぃ……！　はぁ、はぁ……あぁぁぁ……せ、精液が、\nこんなに……あああ、すごいすごい……精液シャワーですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「体が、白く濁っていきます……あなたの体温が、体に染み込んでくる……は\nー……はふぅ……気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くんくん……はぁ、はへぇぇ……思った通り、です……ああ、この独特な匂\nい……匂いだけで、イッ、イク、です……んんん、ひぐぅぅ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウソっ、駄目っ、イッ、イって、ます……イクのが、止まらないぃ……あは\nぁ、ひゃうぅぅ……！　気持ち、良すぎですぅ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「うううっ、まだ出てる……白いのがどんどん溢れてる……水着が、真っ白に\nなっちゃうぅ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……はー……はふぅ……随分出しましたね。ふぅ、見て下さい……アソ\nコの中からも、こんなに精液が溢れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000506_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふぅ……水着が、グチャグチャになってしまいました……流石にこの恰好で\nいろだなんて、いいませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……え？　換えの水着が用意済み？　もう……本当に手回しいいんだから…\n…はいはい、わかったです……ちゃんと着替えておきますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0604410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}