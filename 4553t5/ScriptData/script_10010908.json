{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いまだ！　二人を取り押さえろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ……カツマ、どうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪いな。だけど、こうでもしなきゃ今のおまえたち、落ち着いて話を聞いて\nくれないだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どういうことですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「よくわからない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいから！　ひとまず、俺たちと一緒に来てもらうぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テロップ" ]},
		{"command":[ "SETTEXT", "「Ｘ月＠日　カグヤ、まりあ　身柄拘束」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_980109140001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「カグヤとまりあが戻ってこねえだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「ええ。それに、テーブルの上にこんなもんが」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「『採石場に行きます』だと？　なんであんなところに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まさか！　Ω（オメガ）組の連中がなんか企んでんのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「可能性はないとは言えんな。あそこは、人を罠にハメるにはうってつけの場\n所だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうなのか！？　って、なんでそんなこと知ってんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私にもいろいろあったんだよ！　いろいろな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そ、そうか！　ってことは、アレだな！？　とにかくカグヤとまりあがピン\nチってことだな！　おい、みんな！　今すぐ採石場へ行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ここまで来たらあとがねえんだ……あとが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "工事のお兄さんＢ" ]},
		{"command":[ "SETTEXT", "「ほむらのアネキ！　あれを！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「Ω（オメガ）組のヤツらだ！　やっぱりあいつらのしわざか！　よーっし！\n　行くぞ！　全員まとめてぶちのめしてやれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109140007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「ういーっす！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……！？　あそこにいるのは、セレーナとダイヤナか！？　むぅ……さすが\nに気まずいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109140003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「姐さん！　あれを！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ほむらたちかい……よくもまあ、ノコノコと顔を出せたもんだねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ｂ" ]},
		{"command":[ "SETTEXT", "「カグヤとまりあがいないようですが……もしかして、なにか企んでるんじゃ\n？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふん、私たちに小細工が通用するもんかい。おまえたち！　今度こそ奴らを\nぶちのめしておやり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109140002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おい、ダイヤナ。あれ……ルナテミス様じゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うわぁ……めんどくさいことになっちゃった。なーんか、やりづらいなあ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109140001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「先生たち、なにやってんです！　しっかりやってくださいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109140003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「しょうがねえ、やるだけやるかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんたち、どこで道間違えたのかしらねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109140002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}