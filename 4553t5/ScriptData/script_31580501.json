{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「チッ……どうして私がこんなことを……気持ち悪い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「確かに妖怪巫女パーツの妖力の制御に失敗して、アンタに妖力をぶつけちゃ\nったのは私だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「その影響でちんぽの勃起が治まらなくなったって、嘘じゃないでしょうね…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――分かってる、私が自分で責任を取ると言ったの。気持ち悪いし、うざい\nけど……アンタの言う通り、性欲発散に付き合ってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「手コキ……細かく説明されなくても知ってるよ――だ、誰がむっつりよ！　\nベースになったオリジナルの知識の中にあるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ほら、こうでしょ……っ……人間の男はこうして、皮ごとズリズリ扱かれる\nのが好きなんでしょ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ほんと、どうして私がこんなことに時間を割かないといけないのよ……うざ\nい……うざい……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んっ、ぁ……括れの部分、以外と指が引っかかるようにできてるんだ……ん\nっ……うわっ、先端がヒクついて……キモイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ぐにぐにしてる感触も気色悪いし……んっ、んふっ……いいから、出すなら\n早く出して……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――え？　全然なってない？　こんな手コキじゃ何時間やっても満足できな\nい、って……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「こ、コイツ、人が下手に出れば調子に乗って……マジうざい……ぶっ潰し\nたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「チッ……いいわ、アンタの指示通り手を動かしてあげる……ほら、早く指示\nを出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「リズミカルに……んっ、根元から先端まで、大きく動かして……んっ、んふ\nっ……こ、こうでいいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「くっ……気持ち悪い液体があふれてきた……ぐちゅぐちゅネバついて……指\nに絡んで……キモイ……んっ、うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「これを塗り広げろって……？　――アンタ、ほんとに後で覚えてなさい……\n指に絡めて……んっ、ぐちゅぐちゅ、広げて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「指先で裏筋……血管……んっ……笠の部分をなぞって……んふっ……力も制\n御……バランスよく圧迫して、離して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「チッ……キモいからちんぽヒクつかせるな……キモイ、ほんとキモイ……ん\nっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――こんな馬鹿げたことで褒められてもね……んっ、しょ……言ったでしょ\n、知識のベースはオリジナルのモノだって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「馬鹿みたいだけど……んっ、んふっ……人間の男を喜ばせる知識もインプッ\nトされちゃってるのよ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「指示に沿って微調整できたら、これぐらい、余裕に決まってるじゃない……\nもっと強く、早く……ぐちょぐちょ、かき回して……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んっ……これ、かな……親指と人差し指で、括れの部分を圧迫して……んん\nっ……捩じるように扱くのが、いいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「うわぁ……腰を跳ね上げないでよ……またおちんちんもビクついて……キモ\nイ……気色悪い…………けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、よく考えれば、これ、アンタの急所なのよね……脆い脆い、人間の\n急所……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「力を込めればいつでも潰すことができる……こうやって、じっくり力を込め\nていけば……んんっ……いつかは、ぶちゅって潰れちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「それを思うと、意外と悪くない気もするかも……んっ、しょ……私の手に反\n応して馬鹿みたいにビクつかせるのも、キモいけど素直で……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――何？　アンタ、もしかしてキモいとか言われるたびに感じてない　……\n？　え、嘘、ほんとに……？　うわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「言葉攻めも悪くないって……チッ……本当に死ねばいいのに……ほら、もう\nいいでしょ、とっとと精液出しなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「アンタの弱いところは全部把握したの……こうでしょ……んんっ……！　指\nの腹でズリズリひっかかりを擦られると、我慢できなくなるんでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ちんぽがドクドク脈打ち始めた……あと少し……んんっ、もっと先走りを絡\nめて……ぐちゅぐちゅ、広げて……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ぐっ……キモイ声出さないでよ――私の手が気持ちよすぎるのが悪い……？\n　チッ……うざい、そーゆーの、いいから……アンタは早く、出せばいいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、んんっ……！　リズミカルに、もっと早く……んっ……根元\nから先端まで、大きくしこしこ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「先端がヒクついてきた……やっと出るのね……んんっ……！　出せ、ほら、\n早く出して、みっともなく射精しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！　こ、これが精液……本物はデータ以上に酷い匂い、かも……\nんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――分かってるわよ、手を止めるなっていうんでしょ。やるからには最後ま\nで、搾り取ってあげるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「精液を指に絡ませて、ぐちゅぐちゅ、扱き続けて……んっ、んくぅ……ほん\nと気持ち悪い感触、だけど……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「やっぱり、私の思う通りにちんぽが反応するのは、ちょっと悪くないかも…\n…姉さんなら、いい玩具を見つけたって言うんだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んっ……射精終わった？　チッ……ボディにまで精液が飛んでる……キモイ\n……最悪……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――で？　なんでちんぽが固いままなのよ……まだびくびくしてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「一回じゃ治まりそうにない、ね……いいわよ、うざったいけど、最後まで\n付き合ってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――デレとか、馬鹿なの？　死ぬの？　潰すわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「別に……アンタを私の手で虐めてやるのも、ちょっと悪くないかなって……\n姉さんがうつったかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「もう指示はいらない。色々試して、適当に学習させてもらうから。ほら、ま\nた扱くよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んんっ……二回目だと、精液で滑ってちんぽに力を込めにくくなるんだ……\nでも、この程度なら。こうぎゅっとすれば……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ふふっ……痛い？　苦しい？　手コキをしろって言ったのはアンタでしょ、\n馬鹿みたいに呻いてないで、我慢して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「うわぁ、すごい音……ぐちょぐちょ、ぐちょぐちょって響いて……下品で、\n浅ましくて、気持ち悪い音……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……さっきは早く扱いたけど……ゆっくり焦らすように手を動か\nすのもいいって、オリジナルの知識にあって……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「なるほど、こうね……根元から絞るように力を込めて、先端に向けて、時間\nをかけて絞って、すり上げて……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「そのまま緩急をつけて、今度は早く、激しく……んっ、しょっ……ふふっ、\nちんぽが跳ねて……これがいいんだ、キモイ、ふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「これは確かに、いい玩具かも……んふっ、んっ……何、アンタも自分から腰\nを振りたいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、いいね、そのみっともないヘコヘコした動き。とっても惨めで、情\nけなくて……ふふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――命令するな、うざい。言われなくとももっと早くしてあげるわよ。いつ\nまでもアンタに時間を使うほど暇でもないしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ほら、ちんぽが壊れるほどの勢いで扱いてあげる……！　んんっ、しょ！　\nんんっ……！　キモイ声出しながら、また射精しなさいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ……ああ、ほんと、酷い匂い……嗅覚センサーきっちゃおう\nかな……んっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿じゃなの、アンタを手コキしたぐらいで興奮する訳ないじゃない…\n…キモいこと言うな、死ね、潰すわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「キモイ、本当にキモイ……！　調子に乗ってないで、いいから早く出して…\n…！　また裏筋を虐めてあげるから、早く出すの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　皮の付け根の部分を弄って、爪でひっかいて……腫れ\nあがった亀頭も、指で撫でまわして……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「先端がまたパクパクし始めた……さっきインプットした、射精の予兆……根\n元からゆっくり大きく扱いて、絞り上げて……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっ、んふぅっ……！　出すなら早く出して……！　気持ち悪くち\nんぽをヒクつかせて、射精するの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――私にぶっかけたいって……チッ、勝手にして、この面倒な手コキが終わ\nるなら、うざいけど見逃してあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ほら、これで終わり……んんっ……！　一気に搾り取ってあげるから、みっ\nともなくちんぽ跳ねさせて出しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「きゃっ、んんんんん～～っ！　ちょ、出し過ぎ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「二回目なのに、こんなに出るものなんだ……んんっ、んぁんっ……分かって\nる、手は止めないって……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「大きくしこしこして……んふっ……尿道の中の精液まで、一滴残らず搾り取\nって……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「許可は出したけど、どれだけ私のボディを汚したら気が済むのよ……うざい\n、キモイ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「さすがに、これ以上はでない、かな……ん……ちんぽも固さが抜けていく…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「はぁ……確かに、私の不注意でアンタの身体に変なエラーを出したわけだけ\nど……覚えておきなさい、私にこんな馬鹿なことをさせたこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――は？　途中から私もノリノリだった癖にって？　チッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「そこに新しい知識があるなら、試したくなる……文句があるなら私の設計者\nかオリジナルに言いなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ああもう、うざい、にやにやした目で見るな！　本気でぶっ潰すわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――次なんてあるわけないでしょ！　うざい、死ね！　ほら、早くその粗末\nなちんぽをしまって消えなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「す、すごい勢いっ！　顔にまで精液が飛んでっ、んんんんっ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「この匂い、ダメ……あまり嗅ぎすぎると、ムカつくエラーが出てっ……あっ\n、んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「わ、分かってるわよ、手は止めない……！　んんっ……責任をもって、アン\nタのチンポが小さくなるまで搾り取ってあげるわよ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「裏筋をこすって、尿道口をぐりぐり弄りまわして……んんっ……！　精液を\n絡ませて、ぐちょぐちょ扱いて……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ほんと、どうして私が人間の精液を頭から被ってまでこんなことを……うざ\nい、キモイ、死ね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「またちんぽがびくびく暴れまわって……んっ……これで全部、かな……流石\nに柔らかくなってきたみたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――チッ、キモいから笑顔でお礼なんて言わないで。私は自分の不始末を片\nづけただけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「は？　また溜まったらよろしくなって……あ、アンタ、まさか妖力で興奮が\n収まらなくなったってのは嘘で――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ふふふふっ……どうやら、随分舐めたことをしてくれたみたいだね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――いいわよ、とっととその粗末なちんぽをしまって逃げ出しなさい。私の\n全てを使って追い詰めて、愉しくぶっ潰してあげるわ、ふふふふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}