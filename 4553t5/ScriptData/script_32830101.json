		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んぷぁ……さっきより大きくなってるぅ……んっ、じゅぷっ、あぁ……んむ \nっ、オチンチン……太すぎてぇ……咥えきれなひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「もっと唾液をらひて……んふぅ……ヌルヌルにさせてへぇ……いっぱい動か \nすぅ……んりゅっ、じゅぷっ、むぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んふぅ……先っぽから、すごいにおいがしてるのぉ……んふぅ、むぐっ…… \nんんっ、はぁ……んむ、んっふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んはぁ……なんれ……んっ、無理やりされてるのに……じゅぷっ、んふぅ、 \nからだ……熱くなってるぅ……りゅぷっ……」", "NORMAL" ]},
