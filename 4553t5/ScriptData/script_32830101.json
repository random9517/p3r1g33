		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ちょっと脅されたくらいで言うことなんて……むぐっ！？　ふっ、んぐぅぅ \nぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふっ、んぶっ、んぐっ！　んふぅっ！　ひょっ、ひゃっ……めっ、むぐっ、 \nんむぅぅぅっ、ふっ、ぐっ、じゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「まっ、まひなひゃっ……ふぉんら、いきなりっ……むぐぅっ！　んっ、じゅ \nぽっ、じゅぷっ、むぐっ……んむぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んっ、むぐぅっ、ひゃめっ……らさいって……ひって……んぷぁっ！　はぁ \n、はぁっ、けほけほっ、けほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「い、いきなり何するのよっ！　何にも言わないで、オ、オチンチン突っ込む \nなんて、おかしいでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「おしゃぶりする気になったかって……なる訳ないじゃないっ！　絶対するか \nって思うに決まって……むぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ま、まひゃっ……むぐっ、んふぅっ、りゅぶっ、奥に……んんっ、突っ込む \nらんてっ、じゅぷっ、ふぐっ、むぐぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んぁっ、じゅるっ、ふ、太いのっ……こんら、入らなっ……りゅぷっ、んぶ \nっ、んふぅぅぅんっ！　やめへぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ぷぁっ、はぁっ、あっ、ふっ……ま、また、めちゃくちゃなこと……んっ、 \n本気で何考えて……ふぶっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んふぅっ、むぐっ、んじゅぷっ……ちゅぶっ……ひゃめぇ……ま、まっへぇ \n……むぐぅっ、ふぶっ……んちゅぷっ、わ、わひゃったから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「するから……すればいいんでしょっ、無茶させないでよ……あんむ……ぐぽ \nっ、ちゅぷぅぅぅ……んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぉら……こ、こんら風に……んじゅぷっ、むふぅ……んぐっ、舌を……伸 \nばひて……りゅぷっ、先っぽ……舐めるろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んんっ、し、してるから……んりゅぷっ……髪の毛……引っ張るのはやめへ \n……んっ、伸びちゃうから……じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「それなら……もっと気持ちを込めて……？　だから、ちゅぷっ、やってるじ \nゃない……これで何の不満が……んぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ、おぷっ、んりゅっ、じゅぷっ、んぐぅっ！　こ、こんらに……激 \nしくらんてっ……いきなり……無理らからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……！　んんっ、うぅっ、もっと……しっかり……すればいいんでし \nょ……れろ、ぴちゃ……ちゅぷっ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぉら……これで、ろう……？　オチンチン……頬張って、んりゅぷっ、唾 \n液……いっぱい絡まへて……んじゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「じゅぽっ……こういうのが……好きなんれひょ……りゅぷっ、分かってるん \nらからぁ……じゅぱ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぇっ、全然……？　んんぅぅっ！　はぶっ！　そんらにっ……深くっ、ん \nぶっ！　んむぅっ……ふ、ぐぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「こ、こんらの……息ができないって……できるわけ……んんんっ！　ま、ま \nた髪ぃっ……あぷっ、ま、まっへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「も……許して……ちゃんと……ふる……ふるからぁっ、オチンチン……気持 \nちを込めてしゅるからぁ……んふぅっ、じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぉら……んりゅぷっ……んぐっ、口の中れ……舌ぁ、くにくにしてぇ…… \nオチンチン……れろんってするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んふっ、じゅるって……吸ってぇ……気持ち……よくなってもら \nうように……ふるからぁ……りゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んんっ！　ご、ごめんなさいっ……歯が当たったのは……わざとじゃなくて \n、その……んじゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ホントだからっ！　んんっ、ちゃんと一生懸命するからっ、喉……届かせな \nいれっ……ふぐっ、りゅぷっ、んじゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぷぅ……ふぉら……くびれのトコぉ、いっぱい舌……押ひつけ \nてぇ……ちゅぷっ、オチンチンの先……キスぅ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んんっ、あぁ……んむっ、お汁……れてる……んんっ、ふぁひ… \n…お、美味しい……れふ……オチンチンの汁ぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「むふぅ……んんっ、もう少しれ……出る……のっ？　んんっ、あぶっ！　ふ \nぐっ、あっ、まひゃっ……腰……振って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んぐっ、おぷっ！　んんっ、が、我慢するっ……ふぇろぉっ……これぇ…… \nあぷっ、んむぅ……らめ、かもぉ……じゅぱっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「後……もう少しっ？　んんっ、んぱっ、あふぁっ……何とか……がんばれ、 \nそう……んぐっ、強く……吸って……んじゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「むぐっ……んうぅぅっ！　今の……いいのっ？　もう、せーえきっ、らすの \nっ？　あぷっ、んぶっ……んんんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んぐっ……ふぐぅ……こくっ、んくんっ……れて……る……んんっ、んく、 \nせーえき……いっぱい……んふぅ……じゅぷっ……んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「わひゃってる……れんぶ……飲むからぁ……もう引っ張らないれ……ちゅぷ \nっ、んんぐっ……れる……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ、はぁっ、はふぁ……あぁ……んっく……ぷぁっ……ぜ、全部飲ん \nだぁ……はぁ、はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「まだ、そこにも……う、うん……んちゅっ、ちゅぷぅぅぅぅ……りゅぷっ、 \nんちゅっ、ちゅるっ……はふっ、これで……いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「う、うん……素直に……なったぁ……もう、生意気なこと……言わないから \nぁ……ホントに……素直になるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「絶対……ちゃんと……言うこと聞くから……もう酷いことしないで……お願 \nい……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「え……ま、まだ満足できてない……？　そ、そんなこと言われても……スク \nルド、どうしたらいいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んぶっ……！　あっ、んぷっ、続きを……はぷっ、ちゅぷっ、わ、分かった \nから……んっ、頑張るから……無理にしないれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……ちゅぷっ、んふぅっ、じゅるっ、くぷっ、じゅぷっ、んっ \nぷ、じゅるっ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「こんら……感じでいい……？　もっと、しっかり？　んっ、うんっ……わか \nっら……ひまふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……あぁ……んふぅ……さっきの精液の味……まだ強く残ってる…… \nじゅぷっ、んちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「お、美味しい……れふ……んっ、あなたの……精液の味……美味しい……で \nす……ほ、本当れふ……いやいやじゃ……ない、れふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「んんっ！　ホント……だからっ……あっ、んぷっ、ごめんなひゃっ……また \n引っ張るのやめへっ……じゅぷっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00028301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「一生懸命……んっ、舐めまひゅ……んりゅぷっ、ぷぁ……オチンチン……気 \n持ちよくひゃへまふからぁ……えろ、れろぉ……」", "NORMAL" ]},
