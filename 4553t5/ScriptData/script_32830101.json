		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「生意気……？　ふふーん、残念でした。スクルドは、そう簡単に変わったり \nしませんから～」", "NORMAL" ]},
