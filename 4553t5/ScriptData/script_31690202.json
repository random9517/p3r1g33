		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はひっ、言いますっ！　ちゃんと言いますからっ、イク時にっ、オチンポさ\nれて、気持ちよくなってることっ、言いますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「だからっ、あぁっ、もっとメチャクチャに突いて下さいっ！　オマンコの中\nっ、ぐちゃぐちゃにしてっ、オチンポも一緒にイッてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、中で……ビクってしてるの分かりますっ！　あぁっ、イッて下さ\nいっ、私もっ、もうイキますっ！　オマンコッ……イキますからぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んくぁぁぁぁんっ！　中にっ……また出てますっ……ドロドロ精液でっ……\n種付けされてっ、またオマンコッ……イ、イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁ……一番奥に……オチンポがくっついてぇ……ビュッと出される\n感覚……んくぅぅ……気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁん……まだ止まらない……んんっ、流れ込んでくるの……止まらなくて\n……あふぁ……凄い……んくぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁ……溢れてしまいます……んんっ、オマンコ全部満たされて……漏れて\n……出てしまいそうで……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はふ……あぁ……終わり……ましたか……？　んっ、はぁ…\n…こうして両手足を封じられると、感じ方も全く違いました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あ……もちろん、もし本当に囚われてしまっても、鉄の意志で抗います。こ\nれはご主人がお相手だったからのなりきりで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ほ、本当です！　決して肉欲に溺れるつもりは……あんっ！　ご、ご主人…\n…乳首を悪戯するのはおやめ下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もう……この試みも、ご主人がどうしてもと仰るからしたのですよ？　ま、\nまぁ、私もイヤという訳ではありませんでしたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「確かに、初めて味わう快感でしたし……また、ご要望があるのでしたら……\nしないでもありませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「よ、予約！？　そ、そこまではっ……んぅ……その、お手柔らかにお願いい\nたします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁんっ！　あぁっ……精液出てますっ……びゅくびゅくっマーキング\nされてぇっ、あひっ、私もっ……一緒にイキますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁぁぷっ……顔にも……おっぱいにも……粘ったものがへばりついて……\nんぅ……オスの匂い……んぅぅ……吸い込んでしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ……まだ出てる……先程、あんなにも射精していたのに、ま\nだシャワーが続いてるように……んふぁ……あぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……ちゅぷっ、ねっとりしたコクのある味わい……あぁ……こうして精\n液漬けにされて……私は堕ちてしまうのですね……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あ……こ、こんな感じでよろしいでしょうか……？　はい\n、囚われて拘束されての行為は……背徳的な感じがしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「まだ……この状態のままなのも恥ずかしいですし……どこか気持ちいい感じ\nも残っていて……あぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「別に、この方がいいとかっ、そういうことではありませんよっ！？　これは\nあくまでも、ご主人たってのご希望でしたから仕方なく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あんっ……で、ですから動けないのにクリトリスは……はぁんっ、た、確か\nに……私も気持ちよくなっていましたぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……また続きを……？　あ……んんっ、わ、分かりましたっ……\n分かりましたからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ですが……確かに、この快感は癖になってしまうかも知れません……ただ、\nあの……足はそろそろ閉じさせて頂けると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}