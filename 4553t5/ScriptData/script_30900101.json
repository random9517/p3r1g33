		{"command":[ "PLAYVOICE", "090_0103101" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「隊長さん、お待たせしました。それで、わたしにしてほしいことってなんで\nすか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103102" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ご奉仕？　えっと……ボランティア活動……じゃない、ですよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103103" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「もしかして、女の子が男の人を気持ちよくするっていう、あっちのこと……\nです？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103104" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「そ、それは……まあ、いろいろ情報源ありますから。でも、それをわたしが\n隊長に……ってことですよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103105" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あっ、別にだめってわけじゃないです！　隊長さんにはいつもお世話になっ\nてますし、恩返ししたいなって思ってましたから」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103106" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「でも、その……知識では知ってるんですけど、実際にやってみたことはなく\nて……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103107" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「うまくできるか自信ありませんが、それでもいいなら……えっ、ほんとで\nすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103108" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「分かりました。わたし、頑張ってみます！　もし痛かったり気持ちよくなか\nったら、遠慮なく言って下さいね？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103109" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「それじゃ、失礼して……。こ、これが隊長さんのおちんちんなんですね。こ\nんなに大きくて、なんていうか生々しいです」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103110" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「すごい、こんなに血管が浮いてるんですね。それに、なんだかビクビクして\n可愛いかも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103111" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あっ、すみません！　観察してるだけじゃだめですよね。それじゃ、失礼し\nて……わ、すごく熱い！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103112" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「こんなに熱を持ってるのに大丈夫なんですか？　えっ、大丈夫じゃないから\nお願いした？　そ、そうですよね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103113" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「よし、それじゃ失礼して……んっ、ちゅっ、れるっ……はふ、ビクビクして\nる……んっ、れろっ、れるっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103114" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「なんだか、濃い匂いがします……んっ、れろっ、れるっ、ちゅっ、はふ、は\nぁっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103115" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「すごく、男らしい匂いですね……なんだか、体がむずむずしてきそうです。\nんっ、んっ、ちゅっ、ちゅぷっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103116" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「この、きのこの傘みたいなところ、気持ちいいんですよね？　れるっ、れろ\nっ、ちゅっ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103117" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……この裏側、敏感みたいですね。れろっ、ちゅっ、れるるっ…\n…きゃぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103118" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい。おちんちんがこんなに跳ねると思わなくて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103119" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「えっ、そんなに気持ちよかったんですか？　そうですか、わたしの舌で気持\nちよくなってくれてるんですね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103120" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっと気持ちよくしてあげますね。はむっ……んっ、ちゅぷっ、れ\nろっ、んむぅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103121" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んむっ、れろっ、くちゅっ、んんっ……隊長さんのおちんちん、すごく大き\nいですね。口の中、いっぱいになっちゃう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103122" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、はむっ、れるっ……れろろっ、ちゅっ、ちゅぷっちゅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103123" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ！　なにか口の中に苦い汁が……えっ、それが気持ちいい証\n拠？　そ、そうなんですね」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103124" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「それは知りませんでした……。そっか、実際にやってみないと分からないこ\nと、たくさんあるんですね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103125" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「隊長さん、わたしにもっといろいろ教えて下さい。んっ、ちゅぷっ、れろっ\n、ちゅむるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103126" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、ちゅぷっ、れるっ……もっと奥に飲み込むように、ですか？　\nわかりました、やってみます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103127" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、じゅぷっ……んっ、じゅるっ、じゅっ、じゅぶっ、じゅぶる\nっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103128" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んぐっ、んっ、ちゅぷっ、ちゅるっ、じゅるるっ……んんっ、じゅるっ、じ\nゅっ、じゅぷっ、はふ、あふ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103129" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「苦い汁で舌が痺れてくるみたいです。えっ？　舌で竿を舐め回すのがいいん\nですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103130" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「なるほど……こんな感じですか？　れろっ、れるっ、ちゅっ、じゅるっ、ち\nゅぷっ、じゅぶるるっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103131" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あ……苦い汁、たくさん出てきましたね。隊長さんが感じてくれてるの、わ\nたしにも伝わってきます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103132" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっと感じて下さいね。はむっ……れろっ、れるっ、じゅぶるっ…\n…ちゅっ、ちゅぷっ、ちゅぽっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103133" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んむっ、んっ、れろろっ……隊長さんの匂い……んくっ、もっと濃くなって\n、ふぁ、あ、んっ、んんっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103134" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、ちゅっ、ちゅぷっ、ちゅるっ……じゅぶっ、じゅっ、れるっ、\nれろっ、じゅるっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103135" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んぁっ、また大きく……ふぁ、あぁぁ……んっ、れろっ、れるっ、じゅるっ\n、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103136" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、じゅるっ、じゅぽっ、じゅぶっ……んっ、んぅぅぅぅぅぅぅぅ\nっ！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
