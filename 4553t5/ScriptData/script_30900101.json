		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「はぅ……お腹の奥も、疼いてきちゃいそうです……んっ、んっ、れろっ、ち\nゅっ、じゅるっ、じゅっ、じゅぽっ、じゅぐっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103216" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「隊長さん……んぐっ、じゅっ、じゅぷっ、んぐぅぅぅっ！　わたしに……精\n液、注いで下さい……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_07" ]},
