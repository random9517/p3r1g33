		{"command":[ "PLAYVOICE", "090_0103137" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んっ、んぅぅぅぅっ！　んぐっ、ごくっ、ごくんっ、ごくっ、ごくっ……ぐ\nふっ、げほっ、けほっ、けほっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103138" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ふぁ、ふぁい……大丈夫、れすっ……いきなり、口の中が粘液でいっぱいに\nなって、むせちゃいました」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103139" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あ……さっきのが精液だったんですね。そっか……隊長さん、わたしの奉仕\nでイッてくれたんですね」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103140" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「よかった、隊長さんのお役にたてて……んくっ、んっ、ごくんっ、ごくっ…\n…ふふ、また飲んじゃいました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103201" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんちん、まだ元気そうですね……。もう一回、ですか？　い\nいですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103202" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「隊長さんが気持ちよくなってくれるの、わたしも嬉しいですから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103203" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「はむっ……じゅっ、じゅるっ、じゅぶるっ……んっ、んぐっ、んっ、れろっ\n、れるっ、ちゅむるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103204" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「あふ……隊長さんの精液、すごく濃いです。ねっとりしてて、舌に絡みつい\nてきて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103205" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「舌が痺れてきますね。んっ、んっ、れるっ、れろっ、ちゅむっ……ちゅっ、\nじゅるっ、じゅぶるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103206" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「えっ、隊長さん？　わたしの頭を掴んで……んっ、んぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103207" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んぐっ、んっ、じゅるっ、じゅぶっ、じゅぶるるるるっ！　ちょ、ちょっと\n待って……んっ、んぐっ、んぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103208" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「激しいっ、んぁっ、んっ、あんっ、じゅるっ、じゅぷっ、じゅぽっ、じゅぶ\nるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103209" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっ、あぅっ、んんんっ！　口の中っ、何度も突かれて……んぁっ\n、れるっ、じゅるっ、じゅぶっ、じゅぐっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103210" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「口の中っ、精液まみれなのに、かき回されて……んぁっ、んっ、じゅるっ、\nれるっ、じゅぽっ、じゅぶっ、じゅぶるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103211" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ふぁ、んぁっ、すごい……まだ苦い汁が溢れてきて……んぐっ、んっ、ちゅ\nぷっ、じゅるっ、じゅぼっ、じゅぶっ、んんんっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103212" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「ああ……隊長さんのおちんちん、美味しい……れるっ、じゅるっ、じゅぶる\nっ、じゅぶるるるっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009001_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103213" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「乱暴に……んぐっ、されてるのにっ、感じちゃう……はふっ、んっ、んぐっ\n、れるっ、れろろろっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "090_0103214" ]},
		{"command":[ "SETNAME", "セラフィックスター" ]},
		{"command":[ "SETTEXT", "「おちんちんに溺れちゃいそう……れろっ、れるっ、ちゅっ、ちゅぷるっ、れ\nろっ、れろろろっ」", "NORMAL" ]},
