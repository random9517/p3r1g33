{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "メカカツマが俺に襲い掛かってきた。俺はそれを迎え撃つ。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「偽物のカツマを倒すぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうしたいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「これ、どっちが本物？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "激しい攻防を続ける俺とメカカツマを、ルナテミス達が困った様子で眺めてい\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "相手は俺より２２％性能が上だから、このままでは俺の方が不利だ。だから、\n出来れば援護して欲しいのだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だめ、見た目がそっくりすぎる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こりゃ、見ただけじゃ区別がつかないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115340001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おい、お前ら本気で言っているのか？　もしかして、催眠術抜きでも俺と偽物\nとの区別がついていないのか！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いったいどっちが本物なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……でも、どっちが本物だとしても、私たちの秘密をバラしたのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そして偽物の方は、ダイヤナちゃんたちの秘密を知っちゃっているわけだし\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「本物の方は、秘密をバラした罰でオシオキしないといけないわけだからねぇ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「つまり、ここで二人ともぶっとばせばいいってことだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115340002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「はぁっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なにを言っているんだ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お、おいお前ら、本気か？　正気か？　まだ、催眠術にかかっているんじゃな\nいか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、お前たちそこになおれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今回は許さないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんも、本気で怒っちゃうわよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「覚悟はできてるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「カツマ、避けるなよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115340003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長い付き合いだからわかる。本気だ。本気で俺の……いや、俺たちのことをぶ\nっ飛ばそうとしている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、まて。俺は偽物だ。まずはこっちの本物をぶん殴ったらどうだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「ふ、ふさけるな、俺が偽物だ！　こっちの俺が本物なんだよ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　さっきまで本物って言っていたんだから、本物のフリをし続けろ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「そんなことしたら、全身スクラップにされるだろうが！　お前が本物なんだ\nろ、だったらこいつらを何とかしろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんとかできるならとっくにしている！　おまえこそ催眠術で、ほら、お前\nが本物になれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「催眠装置は破壊されたし、ここで本物になったら俺が先にぶっとばされる！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0196" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どっちが本物だろうと関係ない！　いいから大人しくそこになおれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115340004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカカツマ" ]},
		{"command":[ "SETTEXT", "「あっ、逃げるな本物！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ついてくるな、俺の偽物ぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、カツマとカツマが逃げた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115340004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「逃げ足だけは本物も偽物もかわらないのかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115340004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "怒り狂った女幹部たちに、俺とメカカツマは追われる身となったのだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、逃げ足も２２％上回っていた偽物の方は、まんまと女幹部たちから逃\nげ切ったのである。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「つかまえたぞ、カツマ。最後になにか、言うことはないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115340005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち……ちくしょう……。俺は本物なのに、なんでこんな目に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こういうオチなのは、ご主人が本物だからですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115340001" ]},
