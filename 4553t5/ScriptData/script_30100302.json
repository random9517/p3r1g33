{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「うーむ、やはりこんな格好をしているからにはビーチに来ねばと思ったんだ\nが……なあ、おまえさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00001003_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「着いて早々だが、この美ボディ、好きにしてみないか？　なにを驚いた顔を\nしている。私はこれでもおまえさんのことを気に入っているんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00001003_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「それにせっかく若返った身体だ。そういうことも楽しまねば損だろう？　こ\nこで日の光を浴びていたらそういう気分になってな……どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！！　なんだ、おまえさんもやる気満々じゃないか。なに？　\n私を見て興奮していた？　ふふっ、そう言われると悪い気はしないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほら、おまえさんの好きにしていいんだぞ？　んんっ、ふっ、あっ、そんな\nがっつくな、私は逃げたりしない……あんっ、落ち着けと言っている！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「まったく、こんなババアにそれほど興奮してくれるとはな。女に飢えている\nわけでもないだろうに、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「分かった、分かったから落ち着け！！　女を抱くときはもう少しどっしり構\nえるものだ。そんなにがっついたら、女も逃げ出すだろうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、そうだ、ゆっくりとな……おまえさんのちんぽを私の中に入れてくれ\n……んんっ、ふっ、来た、男のチンポ……あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あくうっ、うっ、ああ……何百年かぶりのちんぽ……くおっ、あっ、んんん\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「なに、余裕がなさそうだと？　馬鹿なことを……私を何歳だと思っておる、\nそこらの小娘と一緒にするな……んっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んおおっ、おまえさんのちんぽがみっちりと……くおっ、これはもしかして\n、若返ったからまんこの具合も昔に戻っているのか……んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、あっ、くふううっ！！　それにおまえさんのちんぽ、妙に私と\nの相性が……んんっ、いっ、いいっ、いいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、こんな、こんなに気持ちいいなんて、久しぶりだ！！　ああ\nっ、ちんぽ、ちんぽもっと！！　奥まで突き入れてくれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふうううっ、あっ、ああっ、隊長、隊長殿、もっと、もっと奥まで、くうう\nっ、あんっ、ふうっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「声が大きいって、構わないだろう。私がおまえさんのものだと周りに知らし\nめたら、この身体を見て声をかけてくる男もいなくなる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「だからほら、もっともっとおまえさんのちんぽで私の中をいっぱいにしてく\nれ。久しぶりの男を味わわせて欲しいんだ……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、そう、そうだ！！　ふあああっ、隊長殿、んんっ、気持ちいいぞっ\n！！　隊長殿のちんぽ、私の奥までごつごつって、くああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、ああっ！！　んんっ、おまえさんのちんぽ、本当に気持ちいい\n……私の中を満たして、こすって……あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「隊長殿はいいか？　私の若返りまんこ、気持ちいいか？　んんっ、ふふっ、\n答えなくてもいい、顔がなによりの返事だ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、じゃあ、ほら、こうしたら……んんっ、もっと気持ちよくなるだろ\nう？　ふふ、まんこは戻っても、経験はあるからな……ほらっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんんっ、あっ！！　こら、そんな急に、ふあああっ、あっ、対抗意識なん\nか燃やさなくても、気持ちよくなっていればいいだろうに、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、だめ、だめだ、この身体だと、おまえさんのちんぽが気持ち\nよすぎて……こんなの初めてだ！！　あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あくうっ、もっと、もっと奥をごりごりって、ふあああっ、そう、それがい\nいっ！！　ひああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「たまらんっ、隊長殿のちんぽたまらんっ！！　ふうっ、ああっ、こんなババ\nアを発情させるなんて、本当に悪いちんぽだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、隊長殿のピストンが、腰にくるっ！！　ふあああっ、隊長殿\nの勃起ちんぽ、私の中をぐちゃぐちゃにしていく、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、あっ、カリ首の形も、壁をこそぐ音も、全部分かる……んんっ\n、おまえさんも、私のまんこの形が分かるだろう……あふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あんんんっ、いきなり激しく、んんんっ中がかき回されて……あんっ、あっ\n、くっ、ふあああっ、本当に、本当に気持ちいい……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「こんな気持ちいいの、久しぶりだ……あくっ、うっ、おまえさんのちんぽが\nよすぎて……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、胸が揺れてるのをじっと見ているな。ふふっ、いくらでも見ていい\nぞ。おまえさんだけの特権だ、んんっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、その腰を押しつけてぐりぐりとするの、いいっ、んんっ、私の中が溶\nけてしまいそうだ……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「この頭の中まで溶けていしまいそうな快感……久しく味わってなかったな。\nふふ、おまえさんのちんぽ様々だ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、でも私は奉仕されるだけの女ではないぞ……こうして、んっ、まん\nこを締めれば……あんっ、ふふっ、ちんぽが気持ちよくなるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、私の中でちんぽが跳ねてるのが分かるぞ。若返りまんこの中\nを埋めつくした極太ちんぽが、また膨らんでいる……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「イきそうなんだろう？　いいぞ、私の中でイって、たっぷりと精液を出して\nくれ。ふふ、久方ぶりの中出しだ……ぞくぞくしてくる……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んあああっ、今の言葉で興奮したなど、んんっ、初めてでもないだろうに、\nふあああっ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、イく、イくぞ隊長殿、おまえさんの雄ちんぽで、イっく、ん\nんんんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、中に、中にきたっ！！　隊長ちんぽの精液、きたあああっ、あ\nあっ、あっ、んっ、熱い……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっあっ、これが中出しの感触……んんっ、こんな濃厚な精液、一回で孕ん\nでしまう……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、たっぷりと出されているのが分かる……ふふ、私の身体で気持ちよ\nくなってくれたんだな、年甲斐もなく嬉しくなる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで注いで……ふうっ、うっ、んんっ、久方ぶりの交わり、気持\nちよかったぞ……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……まだ硬いな。ふふ、さすがは女泣かせのちんぽだ……どうする、\n私もまだ満足しておらんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んうっ、はっ、そう、そうじゃ！！　おまえさんも若いんだ、一回の交わり\nで終わらんよな。んんっ、あっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、真剣な顔、うっとりするほどいい男だ……私もまんこを締めがいが\nあるというものだな、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ、私とおまえさん、お互いに気持ちよくする、これが本当の意味\nでの交わりだな、んんっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、そう、私はカリ首でそこをこすられるのがいい……んんっ、\nおまえさんは、こうして締めつけるのがいいんだろう？　ほらっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「真剣な顔からそんな切なそうな顔になられると、ますます愛おしくなるな。\nこうして、腰を動かしながら締めつけたら……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「中でチンポが跳ねている……ふうっ、あっ、そんな意趣返しのように腰を動\nかすな……んんっ、おまえさんのちんぽのよさは、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ちんぽのよさはもう知ってるから、んんっ、ひあっ、あっ、あっあっあっ、\nそんな意地にならなくとも、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふっ、雄というものはこれだから……でも、悪い気はしないな。ふふ、そ\nれだけ私のことを求めてくれているということだからな。あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「私のまんこをおまえさんのちんぽで覚えて、もっともっと気持ちよくしてく\nれ。私もおまえさんをもっともっと気持ちよくしてやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんんっ！！　人が話しているときにちんぽを動かすな！！　まったく、ん\nっ、あっ、もう、がっついて、しかたのない男だ……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、んっ、また腰の動きが切羽詰まってきたな。ちんぽも硬く熱く\nなってきている。そろそろ限界が近いんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、くっ、うっ、私の中も蕩けて柔らかくなってきたのが分かるだろう？\n　さっき出されてから、男の味を思い出したかのようだ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あうっ、おまえさんのちんぽ、本当に相性がいい……亀頭も、カリ\n首も、竿も、全部私のために誂えられたようなちんぽだ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、あっ、ちんぽがまた膨れてきた、んんっ、出すんだな。いいぞ\n。おまえさんの好きなときに、たっぷりと出してくれ。あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、その顔、女を必死に求めるその顔、んんっ、隊長殿、好き、好\nきだっ！！　私のこと、もっともっと愛してくれっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ああああっ、来たっ、来たあっ！！　私も、私もまたイく！！　隊長殿のち\nんぽでまたイくうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「隊長殿もイってくれ、また私の中でイってくれ、んんんっ！！　濃厚精液、\n私の中でぶちまけてくれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あんっ、んっ、もう、もう限界、あああっ、イっく、ちんぽ\nで中をえぐられてイっく！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あああああっ、イっく、隊長殿の精液でイっくううううううううううううう\nううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あああああああ、あふうっ、んっ、出てる、二回目なのに濃厚な精液、私の\nなかにいっぱい出てるうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、射精の動きも全部分かる……最高のちんぽだ……こんなもの、つが\nいになるしかない……ふうっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「こんなに濃いのを二回も出されたら……確実に孕む、んんっ、ふあああっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっんっ、その奥をぐりぐりしながら最後まで出すの、好きだ……おまえさ\nんの愛を全て受け取ってるみたいで……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「竿にある残りはこうして、んっ、締めつければ……あっ、ぴゅって出てきた\n、ふうっ、んっ……一滴残らず、搾り取っただろ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、私の中全部、おまえさんの精液で塗り替えられてしまったな\nあ。ふふ、嫌なわけはあるまい。むしろ幸せだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「愛する男の子種を腹に受け入れる。女としてこれ以上の幸せがあるものか。\nこれが愛されているという証拠なのだからな。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふふ、私とおまえさんの子供はどんな子に育つだろうな……ん？　まだ孕ん\nでいるかも分からないって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おまえさんの精液なら、確実に孕んでいるさ。それぐらい力強い精液だ。ふ\nふ、狼の一族である私が言うんだから間違いない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「愛しているぞ隊長殿。子供ができても、またこうして抱いてくれると嬉しい\nな。ふふ、私はいつだってお前さんを受け入れるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んあああっ、なんで抜いて、ひあああっ、身体にぶっかけて、んんっ！！　\n熱いっ、ふうっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、うっ、ふあああっ、おまえさん、身体を孕ますつもりか……\nふうっ、ああっ、二回目だというのに、この量……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「肌の上から垂れ落ちない精液など、初めてだ……んっ、んんっ、熱いし、濃\nいし……力強い精液だ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「これをさっきは中に……ふふふっ、中に出されなかったのは残念だが、これ\nだけ私の中で気持ちよくなってくれたと思うと悪い気はしないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001003_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、最後の一滴までふりかけて…こんなマーキングで主張しなくと\nも、私はずっとおまえさんの女だぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「あんっ、今の言葉でまた精液を振り絞るとは……全く、独占欲が強い男だな\n。ふふ、ふふふふふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、ほら、私の隅々までおまえさんの匂いが染みついたぞ。ふふ\nふっ、これでおまえさんの女だと証明されたわけだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「んっ、これも悪くないが、私がおまえさんの女だとはっきりさせるにはもっ\nといい方法があるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「外じゃなくて中に出して孕ませることだ。私がおまえさんとの子供を産めば\n、誰だって私がおまえさんの女だと理解するだろうさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「だから……な？　これからも中も外も、全部おまえさんのもので染め上げて\nくれ。それが、私の幸せだ……愛しているぞ、隊長殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
