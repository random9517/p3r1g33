{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_002" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「くっ！　撤退だ！　下がれ！　下がれーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ふん！　尻尾巻いて逃げ出すのかい！　ざまぁないねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112070001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どうやら守り切ったか……だが、まだ安心はできんな。この程度で、奴らが\nあきらめるとは思えない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですね。もうしばらく、警戒を続ける必要があります。ほむら！　あな\nたも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ほむら？　どうしたんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いや……長官とグレート・ルナリアムの人ら、これに乗って帰ってきたんだ\nよな？　あんなに大勢で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、そうだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ってことはさ？　これを直せば、月に殴り込めるってことじゃねえのか？　\n大人数でよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、いえいえ、ちょっと待ってください。どの船も、かなりのダメージを受\nけています。修理には相当な時間が必要です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「直していては間に合わないということですか……惜しいですねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112070002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ちぇっ、ダメなのかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「残念ながら、このままでは……。都合よく、高度な技術を持った異次元の人\nたちが現れて、協力でもしてくれないかぎりは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ん？　　高度な技術を持った……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「異次元の人……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112070003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスク・ザ・ブルーとお七" ]},
		{"command":[ "SETTEXT", "「いた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112070004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00003301_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「え？　私……ですか？　それはもちろん、ご依頼があればご協力も可能です\nが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112070001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「『ですが』？　なにか問題でもあるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「保険の適用外ですので、有料となってしまいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112070002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「クリスタルかい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112070005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ、お支払いはクリスタルでお願いしております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112070003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「クリスタルか！　クリスタルがあればいいんだな！？　これだけあれば足り\nるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「長官！？　なんですか、このクリスタルの山！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070009" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「クリスタルを、こっそり貯め込んでたってことか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ！　こんなこともあろうかと経費をケチって――げふんげふん、節約し\nて貯め込んでいたんだ。これをすべて、今回の料金にぶちこむ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「なるほど……ちょっと拝見」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112070004" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ、これだけあれば充分です。では、宇宙船の特急修理、お引き受けいた\nします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010112070005" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「よろしくお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070010" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ははははははは！　さすが長官！　やるときゃやるじゃねえか！　ただの飲\nんだくれじゃなかったんだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020112070007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「わはははははは！　ひとこと多いぞ、ほむらたん！　わはははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_006" ]},
		{"command":[ "SETNAME", "襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あそこだ！　破壊せよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「おっと、また来た。しつこい連中ですねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010112070006" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「かまいません！　何度でも撃退します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010112070011" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「頼むぞ！　船を守ってくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010112070009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}