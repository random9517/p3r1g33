{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ……も、もう我慢できない……。はぁ、はぁ、悪いけど……私の気が済\nむまで、君のオチンポを使わせてもらうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っぅ……。何も、初めてのエッチというわけじゃないし……。私のオマンコ\nもぐちょぐちょに濡れていて、挿入するのに何の障害もない、のに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「どうしてかわからないけど……。少し緊張してるかもしれない……。月夜と\nいうシチュエーションのせい？　それともこの衣装の影響……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ほ……星空の下で、不幸の魔女である私が、こんなに幸せになれるなんて…\n…まだ信じられない。だから君が信じさせてほしい……。入れるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っんぅううっ……♪　ああああっ！　す、ごい……。なんて大きなオチンポ\n……♪　ん、ぁ、あ、中がミチミチ拡がっていくのがわか、るぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504105" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフフ、なぜかゆっくりと、時間をかけて……あんっ、初々しい感じでオ\nチンポを挿入して、しまったけど……。すごく、すごく気持ちがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君のオチンポでいっぱいに満ちているオマンコへの刺激……快感もそうだけ\nど、胸がいっぱいで……。なんだか泣いてしまいそうかも……。んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君は、この世界で唯一の……かけがえのない人物で。私の王子様で、私の旦\n那様……。今だけは、そううぬぼれてもいいかな……？　あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君を愛しいと思うだけで、オマンコの疼きが、うねりがまったく抑えきれな\nい……。あぁ、あっ、あぁっ、腰がウズウズする、今すぐ動きたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「動いていいよね……っ。はぁあっ♪　あぁっ、あっ……！　あぁ、すごい…\n…すごいぃ、太くて逞しい君のオチンポ……！　っあっ、はぁっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「この、ゴリゴリしたオチンポ、でっ……！　ぐちゅぐちゅに濡れたオマンコ\nをこするのが気持ち、いい……！　あああっ、うあぁああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ね、え……お願い、したい……っ。私も真剣に腰を振って、尻を揺らしてオ\nチンポを締めつける、から……。オマンコをガンガン突いて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「貫いて、突き上げて、ぐちゃぐちゃに掻き回してほしい……っ♪　ふっとい\n極悪な肉笠でぇっ、私のオマンコをぐりぐり刺激してほしいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん、あぁああっ♪　そう、そうやって突いて、やめないで、そのままずっと\n突いてぇ……！　あぁっ、あぁっ、いいっ、感じるぅ……っ、あっ！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっと……もっと続けて……！　んぁああっ♪　あぁ、い、今の……今の突\nき方はすごく、いい……っ。あっ、ぁっ、私の動きは、どう……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んんぅっ……！　一番奥に突き刺さって……ゾクゾクする……！　あ\nっ！　あっ、最高に幸せになって、きたぁ……んぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わ……私をお姫様にしてくれる、のは……君、だけ……君一人ぃ……っ、あ\nっ、あっ♪　す、き……好きぃ、君も、君のオチンポも好きぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ……！　手を繋ぎ合って、お互いを気持ち良くするために、腰を振って\n……こんなエッチを覚えてしまったら、ふ、不幸になれなくなるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……んんん！　ひぅううっ！　そこっ……奥ぅっ、強くずりゅっ、ぐっちゅ\nって突かれるの、気持ちいい……！　あぅああっ、ひ、響く、響くぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私の……赤ちゃんの部屋をコンコンノックするのは、やめておいた方がいい\n、よぉ……っ！　妊娠準備が完了、してしまう、からぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ、そ、そうだった……。避妊具も何もつけてないぃい……♪\nそれなのに、私……君を襲って、自分からオチンポ挿入して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_02" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「危ない、ってわかっているのに……ピストン、やめるつもりもない……！　\nうぁああっ、あっ、ぁっ、妊娠、妊娠希望しちゃってるっ……ふぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「王子様との赤ちゃん……身体が、オマンコが欲しがってるっ……♪　オマン\nコきゅうきゅう締まって、君のっ……オチンポに媚びてる、うううぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ッぁあああああ……っ♪　オチンポ♪　オチンポ絞っちゃいけない、のにぃ\nっ……生でザーメンを受け入れたら赤ちゃん、できちゃう、のにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「やめたくないぃ……♪　一番濃い精液、ドロッドロの生ザーメン、いつでも\n受け入れられるように……オマンコがうねってる、うごめいてるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っあ～～～っ♪　あぁあああ♪　頭が悪く、なっていくぅう……♪　んはっ\n♪　あぁっ、すき……好きぃ♪　あっ、そうだ、別に悪いことじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「最高の、最愛の旦那様……！　王子様のザーメンで着床して♪　妊娠するの\nはお姫様の……んんんっ、つ、妻のつとめぇ……♪　あっ、んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それなら……全力を尽くす、のみ……！　あっ……！　あっ、もうダメぇ…\n…、理性なんてとっくに溶けて消えてるっ、あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「今はぁっ……♪　君のオチンポの太さ♪　硬さ、長さぁああ……♪　この男\nらしい、感触に酔いしれることしかできない……したくないぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「は、ぁっ……ふぁっ、あっ、あッ……。王子様ぁ……♪　私がどう腰を動か\nせば、一番オチンポが燃え上がるのか、教えて……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「言う通りに、する……っ。命令して、私を好きなように、して……！　っふ\nぅううっ♪　い、いい……、私の、ことは、気にしないで……んぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私はちゃんと気持ちいい、から……！　あぁああッ……♪　せっかくっ……\nロマンチックなシチュエーションで、結ばれたんだから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「絶対一緒にイキたいっ……。ぜったいぃいっ、同じくらい気持ち良くないと\n、だ、め……っ。ふぅっ、こう……？　前後に揺らすのがいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そうしたら全力でっ……オマンコを締めて、……うぅっ♪　絞り上げ、る…\n…んんっ、……あ♪　オチンポが反応したぁ……♪　あっぁっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いい、よ……♪　このまま緩めたり、締めたりし続けるから……射精して、\nザーメンびゅるびゅる解き放って……！　イッてっ……注入してぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はぅっ！？　あぁっ……うぁああああっ♪　きたぁっ……きたぁあぁっ♪　\nオマンコの中にびゅぅうーっ、びゅぅううーって熱いのが上がってきたぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ……♪　子宮を狙って、そのまま……激しくザーメンを飛ば\nしてっ……んぅううううっ♪　入ってきてる、あったかい……！　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はうぅっ、んぅうううっ……！　びゅるっ、びゅるるって……一番奥に当た\nって……んああああっ♪　すごい……すごい、気持ち、いい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「イッてしまいそう……、あぁっ♪　イッてもいいっ？　あっ……イクっ……\nイク、イクぅうう……！　オマンコにザーメン注がれながらイクぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……。あぁっ、手を離さない、で……あぁっ、このままどこま\nでも繋がっていたい……！　あっ！　あっぁっああああぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はーっ……、はぁーっ、はぁああ……♪　オマンコの一番奥……。君のオチ\nンポから出た、大量のザーメンがしっかり溜まっているのがわかる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あり、がとう……。こんな私を……満たしてくれて、幸せに……してくれて\n……。でも……、んっ、これは我儘かもしれないけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君さえ良かったら、この最高の時間を……もう少しだけ、味わっていたい…\n…。つまり、……このまま、エッチを続けたいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……あっ？　い、今、君のお口じゃなくてオチンポが返事をしたね……。ん\nんんっ、出したばかりなのにムクムクと大きくなって……んぁっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「これは……このまま続けようって意思……だと思っていいのかな……。はぁ\nっ♪　だ、だから……！　オチンポをピクつかせて返事はダメぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……。も、もういいや……♪　もし君が万が一、エッチを続行\nしたくなくても……。っぁっ♪　私が勝手に続けてしまうよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ッ、ぁっ……♪　あっ、ぁっ、あっ、ぁあっ……！　ひゅ、ひゅごいぃい…\n…♪　君の出したザーメンが、ヌルヌルの潤滑油になって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「さっきよりスムーズにっ……うぁっ、君のを堪能できてしまうぅっ……♪　\nふぁあっ、あっ、あひっ、ニュルニュルで……気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっ、あぁううっ……！　えっ？　ザーメンだけじゃなくて……私\nの愛液の量がすごい、からこんなにぐちゅぐちゅなんだって……。はぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ♪　そ、それは……は、恥ずかしい……っ。んんっ……！　ここは一つ\n、お互いさまということ、で……んぁあっ、誰にも言わないでほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「二人だけの秘密……あっあっあっ……！　うれ、しい……うれひぃ……っ。\nそういうの、すごく興奮、する……！　二人だけの秘密ぅう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ♪　君と秘密を共有していると思うだけで……オマンコがきゅうきゅう\nと締まって、君のオチンポに甘えてしまう……あっぁっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ごめ、ん……っ。うねうね、してる……っ。勝手にっ、オマンコ、うねって\n君のに絡みついて……あっぁっあっ、甘えてごめんんんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……気持ち、いい……！　気持ちいいよぉおお……！　はぁっ\n、あぁああっ……！　ずっと永遠にこうして、いたいぃいっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、君とのエッチのことしか、もう考えられない……！　あっ、\nオチンポ……、王子様のオチンポ……！　硬くていいところに当たるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっと、もっと感じたい……！　あうぅうっ、い、いいの？　君からも突き\n上げてくれるの？　っあぁああああっ、幸せ、幸せぇえええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああっ、いいっ、いいよ……♪　二人で力を合わせて、腰を動かして……\nあああっ♪　どんどん、一緒に気持ち良くなっていけて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っンンンッ……♪　ねえ……またイッてしまいそうだ……っ。あぁっ、オマ\nンコをずりゅずりゅ突かれて、全身が痺れるみたいに気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ♪　さっきより……一度目の射精より大きく、長く絶頂できると思う、\nからっ……。その時に君もっ、君も一緒にイッてほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っふぁあああっ♪　んあああっ、あぁっ♪　あッぁっあああっ……！　イこ\nうっ……！　一緒に……一緒にイッてぇっ、王子様ぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ひぅううううっ……！　あ、くぅうっ……んくぅうううっ、イクぅううっ！\nイクッ……イクぅううううう～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「オマンコがっ、君の熱いザーメンでいっぱいぃ……！　あふっ、くふぅうっ\n♪　もっと！　もっと欲しい、まだ出してよ、まだ入るからぁあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あふぅううっ♪　んふっ、んひぃっ、ううううう～～っ……♪　ドプ、ドク\nッ、って中で……オマンコの奥で脈打って……ザーメン撃たれてるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そのまま……私を真っ白にするまで出し続けてぇっ……！　んっぉっ♪　お\nおぉっ、んふぁああっ、ああぁあああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いいよ……いいよおっ、あうっ♪　頭の中まで真っ白に染まってくぅ……！\n私のオマンコは、君のオチンポ専用だって証だよぉおっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あは……♪　最後までちゃんと絞り上げるから、見ててぇ……。んっ……ん\nんんっ、フフフフ……♪　これでスッキリできたよね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フ……フフフ、ずっと不幸を撒き散らしていた私が……こんなにも幸せにさ\nせられてしまうなんて、恐ろしすぎるよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも、せっかく……他の誰からも邪魔の入らない場所にいるんだし……。誓\nうのはタダだから、誓わせてもらおうかな。その……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え、永遠の愛ってやつ……。似合わないかな？　わかってる……わかってい\nるけど、ムードに流されたということで一つ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私は……君に永遠の愛を、ち、誓います……。どうか末永く……お慕いさせ\nてください。だ……旦那様……。フフフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぁあああっ、イクぅっ、イ……く……？　あっ！　ま、待って旦那様……\nっ。オチンポがずるんと抜けて……んぁんんっ！　ふぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「身体、に……ザーメンが……！　あぁあああ♪　んっ、フフフフ♪　これは\nこれで愛を感じるような……気も……？　あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「見て……、君の吐き出したザーメンに濡れて、まみれて、輝く私を……！　\nっぁっ、衣装が汚れてしまうかもしれない、けど……それでもいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君のための、愛を伝える衣装……だからっ！　君のザーメンなら喜んで浴び\nるよぉっ……。かけて……、うぁっ♪　ドロッ、トロって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「熱くて臭いザーメンが、私の肌をつたって……したたっていく……♪　んぁ\nんんっ、たまらない……。ザーメンシャワーなんて最高すぎる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああぁあっ……♪　ダメ、君に精液を塗りたくられた事実だけでイクぅっ\n……！　イクッ……、んぁあああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフフ……ぼーっと私を見つめて、どうかした……？　自分がザーメンで\n真っ白に濡らした相手を、ながめているのがそんなに楽しい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……私は……楽しい、よ……。うん。こうしてザーメンまみれにされると、\n君のモノなんだって主張されているようで……独占されてるって思えて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001805_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もちろん、ザーメンシャワーなんてされなくても、身体のすみずみ……オマ\nンコの中も、奥まで全部君だけの私だけど……。なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0504409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……恥ずかしいことを言ってしまうのも、月夜のマジック、なのかな……。\n旦那様……たまには、こういうのもあり……だよね……？」", "NORMAL" ]},
