		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁぁっ！　あぁっ、出てるっ……！　熱いザーメンっ……ぶっ掛け\nられてるぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404401" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふぅっ……中だけじゃ飽き足らず……んっ、身体まで汚すなんて……くふ\nぅ……やりたい放題にしてくれるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404402" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「けど……んんっ、このザーメン臭……んふぁ……間近で浴びると、やっぱり\n蕩けるぅ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「イク……んんんっ、続けて……イッてるぅ……サンタの服もヌメヌメにされ\nてぇ……気持ちよすぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404404" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……ふ……止まったみたいだね……ふふ……チンポが私のお腹の上にも\nたれかかってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404405" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「やれやれ、最初にいきなりザーメンを漏らした時は大丈夫かと思ったが、ど\nうにか立て直したようだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ぶっ掛けられたザーメンも、よーく伸びて、濃さも申し分ないし……ちゅぷ\nっ、うん、味も悪くないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「この調子なら、ちょっと休めば一気に回復して、またたっぷりと楽しめそう\nだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「何をきょとんとしているんだい？　まだ２発目なんだから、それで終わり\nなんて話にはならないだろう？」", "NORMAL" ]},
