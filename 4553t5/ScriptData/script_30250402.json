{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さぁて、お楽しみの時間の始まりだ。ここなら、もう邪魔も入らないし、じ\nっくりと楽しもうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら、時間はたっぷりあると言っても有限なんだ。グズグズしないでさっさ\nと脱いじまいな。そいつもだよ、全部脱ぐ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふふっ……さて、やっぱりこの形がしっくり来るね。男にのし掛かられる\nよりは、こうして上から見下ろす方が性に合ってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい、下から見上げる私のおっぱいは。この格好でいる時は、隙あらば\n盗み見してたようだけど、今なら堂々と見ていいんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404104" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「気づいてた？　ははっ、あれだけ露骨な視線を向けておいて、気づかないな\nんて鈍い話があるかい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら、顔を埋めさせてやろうか。大好きなおっぱいにプレスされるのはどん\nな気分だい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おっ……生意気にも、しっかりチンポが勃起して来てるじゃないか。オマン\nコの部分を押し上げるようにして……早くハメたいって催促かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さて……どうしようかねぇ、ハメさせてやってもいいが……簡単に飴をやっ\nちまうのは私の主義に反するからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「しばらくは、この素股で……んっ、じっくりチンポの準備を進めていくとこ\nろからだよ……こうして……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい、マイクロビキニの股間のところが、ちょうどチンポの先を擦るだ\nろう？　大事なところはガードされてるが、すぐ先が割れ目だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「この筋の部分を……こうやって動かせば……んふぅっ、これはこれでなかな\nかいい気持ちだね……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……欲しがりチンポがよく動くねぇ……おっと、下から突き上げようっ\nてつもりかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「けど、あまり暴れさせるつもりはないよ。ほら、お前はこのおっぱいの方に\n夢中になってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くくっ、口をモゴモゴさせて、何を言ってるか分かりゃしないねぇ。情けな\nい顔を見てやりたいがおっぱいに埋もれちまってるのが残念だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「なぁに、心配しなくても、ちゃんとチンポはおあずけにはしないよ。思いっ\nきり射精する瞬間までじわじわ気持ちいいのを積み上げてやるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はっ、んんっ……あぁっ……お腹の辺りに、熱い亀頭が当たっ\nてるよ……中で味わうよりもっと熱っぽく感じるもんなんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほうら、皮が擦れて……これはこれでいい具合だろう？　後ほんの少しで欲\nしいところに届くのに、もどかしい感じになるよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「まだだよ、んんっ、私も気持ちを高めていきたいからね……ズッポリハメち\nまう前に、オマンコもその気にさせてやらないとね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふっ、どうだい……ビキニが少し染みてきているのが分かるだろう？　私\nも楽しみにしてるからね……じわじわ濡れて来てるのさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こうして……おっぱいで挟み込んで……腰をゆっくりと回して……あぁ……\n奥からまた新しい汁が溢れちまうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……そっちの鼻息も荒くなってきたね……ずっと焦らして来たけ\nど、そろそろ限界が近いのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さぁて……どうしようかね。私も、大分その気になったとは言え、もう少し\n遊んでいたい気もするし……お前さん次第かねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうだね、当然おねだりさ。私をその気にさせるいやらしい奴を、自分の言\n葉で言ってご覧。そいつの出来次第だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くくっ……なるほど。欲望まみれのチンポをオマンコにぶち込みたくて仕方\nないと……７０点ってところかねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「合格かどうか？　そうだね……その返事は……こういうことになるかねぇ…\n…ふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　くふぅぅぅぅっ……まぁ、ギリギリ合格ってことにしてお\nこうね……私もそろそろチンポが欲しいとこだったし……くぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ずっぽり一気に根元まで入っちまった……はぁっ、んくぅっ……お待ちかね\nのオマンコだよ……んぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい、こいつが欲しかったんだろう？　んっ……さて、ここからどんな\n風に動いて……んっ、あぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あふっ……！　射精っ……我慢……出来なくてっ……いきなりっ、中にっ…\n…はぁぉっ、おぉぉぉぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……まさか、入れると同時に中出ししてくるとは思わなかったよ…\n…子宮に不意打ちで……ドプドプ出てぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ……！　イクっ……私までナマ中出しでっ……くひぃっ、あ\nっ……オマンコっ……イクっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くふぅ……んんっ、この不意打ちはやってくれたねぇ……問答無用で妊娠さ\nせようってつもりかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふん、狙ってやったって訳じゃなさそうだね……けど、許可なく出したこと\nへの落とし前はしっかりつけてもらわないとねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……決まってるだろう？　このまま続けてチンポを動かすんだ。もっと\n中出しして、私を孕ませるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そら……続けて動くよっ……はっ、んんっ、くっ、ふっ、んくっ、あぉっ…\n…ほぉぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……バキバキのチンポが奥に当たるぅっ……！　ちゃんと硬いままのチ\nンポっ……上等だよっ……くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、オマンコの中のザーメンが……ちょうどいい潤滑油にな\nってくれてるね……んふっ、んんっ、よく……滑るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404137" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はふっ、ほらっ……ここまで来たら遠慮しないで……お前も下から突き上げ\nるんだよっ……腰を振るタイミングを合わせてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうっ、んんっ、もっとだ……！　もっと、中をグチュグチュ音をさせてっ\n、オマンコ全体をかき回すようにっ……あひっ、おぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいね……止まらないよっ……くぅっ、私も腰が……自然に動いちまうっ…\n…はぁっ、んっ、くぁっ……ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、そうだね、ここからが本番みたいなもんだ……やっ\nとチンポが私のオマンコに馴染み始めて来て……かき回していく感じだよ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほうら……こうしてっ、おふっ……繋がった場所が擦れ合うと……じーんと\n痺れる感じがしてくるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「もっともっと、下品に腰を振っていくよ。ふんっ、あぉっ、ほぉっ、おぉん\nっ！　突き上げに合わせてっ、ヘコヘコ動かすぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっふっ、カリがちょうど感じる場所に当たってるよ……その出っ張った所\nだ……続けてすれば、私もメスの声が出ちまうからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んひっ！？　そ、そうそうっ……くくっ、いきなりやってくるその遠慮のな\nさ……それ位じゃなきゃ私の相手は務まらないからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おぉっ、あっ、あぉぉんっ！　ここぞとばかりにチンポをイキらせて……そ\nれなら私も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そぉら、お返しの締め付けだ……んんっ！　ふふっ、やんちゃに暴れる亀頭\nを、オマンコの肉でしっかり押さえ込む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「マン汁のシャワーをいっぱい浴びて先端が痺れるだろう？　あぁ……身体が\n火照る……おっぱいの谷間にも汗が滲んできたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふっ……いいよ、せっかくプレスしてるんだ……直接舐め取ってご覧……\nふふっ、どうだい、しょっぱいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「遠慮なく舐めるといい。代わりに私もお前のザーメンをいっぱい飲ませて貰\nうために、もっとチンポを味わうからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ほぉら、乳首もすっかり尖ってビンビンだ……直接吸ってみ\nたらどうだ？　それどころじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふぅっ！　ふふっ、おっぱいを吸いながら……一生懸命腰を振って……は\nんっ、あぁっ、その必死な動き……そそらせるねぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ、んぁっ、あぁっ……動かしながら、また一段太くなっていく\nみたいなっ……まだ本気を隠しているのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「これが精一杯？　ふん、どうだろうねぇ？　とにかく突いて突いて突きまく\nりなっ！　あぉっ、そうだよっ、オマンコもっとだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぐぅっ、チンポっ、擦れるっ！　くふぅっ、この好き勝手な動きっ……直\n接欲望をぶつけられる感じぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぉっ、くぅっ……あぁっ、いいね……ジンジンする感じが……また大きく\nなってきたっ……このまま、また私をイカせてご覧っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁぉっ！　そうだよっ、チンポで串刺しにするんだっ！　くぅぅんっ、あ\nぁっ、私の子宮が降りてっ、妊娠準備を整えていくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、またオマンコが近いっ……続けてイクよっ、はぁっ、お前\nも……また出そうなんだねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふっ、ここまで来たら……遠慮なんかするんじゃないよっ！　お前の欲望\nを……全部っ、やりたいようにぶちまけなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私もっ……はぁんっ、イクっ……あぁぉっ、さあっ、出しなっ……あぉっ、\nくぅぅぅんっ、ほぉぉぉんっ、イグぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404220" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃぃっ！　あぁぁおっ……中っ……出てるっ……！　２発目っ\n……続けてっ、ドプドプっ……出て……るぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404301" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……また、ナマでの中だしぃっ……本気で妊娠させる……本気の射\n精……あっ、おおぉぉぉぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「またイッてっ……続けてイッてるぅぅ……あぁ……オマンコ……いっぱいに\nさせられてぇ……まだ出続けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「熱い……んっ、ドロドロのザーメンがオマンコの中で泳いでいるよ……いっ\nぱいになって、溢れて来ちまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、終わったのかい……？　んっふ……あぁ、続けて何回イッ\nたか分からない位だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……いきなり入れて中出しされた時はどうなるかと思ったが……なんだ\nかんだで、しっかり満足させてくれたねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くくっ、それにしても遠慮なく出してくれたもんだ。これは、もう孕ませた\n責任を取るってことでいいんだろうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「なぁに、私は甲斐性なんてのは気にしないよ。いつ何時でもチンポを勃たせ\nることができるか。大事なのはそれだけさね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……今、オマンコの中でチンポが震えたね。全く正直で分かりやすいチ\nンポだ。これなら心配もいらないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404309" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ、少し休んだらまた続きだ。クリスマスの夜は長いよ……もっと楽しも\nうじゃないか……ねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0404310" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_02_10" ]},
		{"command":[ "WAITINPUT" ]},
