		{"command":[ "SETNAME", "マユミ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……さすがに、この人数を相手にするのはキツイわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_020021090009" ]},
