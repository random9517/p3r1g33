		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「はっ！　なんだよ、口ほどにもねぇな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090041" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「秘密の力が何処にあるのか教えなさい。そうすれば、これ以上危害は加えな\nいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090026" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「そーだよー。うちらも別に、喧嘩したくてしてるわけじゃないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090022" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうことだ。俺もその力って奴を見てみたいし、可能ならご相伴にあず\nかりたいんでね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　この学園に眠る力は私のものよ……！　誰にも渡さないわ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_020021090010" ]},
	{"command":[ "SETCHARA", "0", "char_00015902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "マユミ" ]},
		{"command":[ "SETTEXT", "「私の本気を見せてあげる……！　はあああああぁーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_020021090011" ]},
	{"command":[ "SETCHARA", "0", "char_00015902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだこの力……！　さっきとは比べ物にならないぞ……！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0129" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "眩い光が部屋中を駆け巡った直後、マユミの見た目は大きく変化していた。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00015901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「これが私の本当の姿……！　インペリアルマジックキャスター、ラー・サイ\nアムよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021090001" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「学園長の正体が魔導士だったとはな……！　おい、お前たち！　あいつを…\n…って、どうしたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "泉たちに目を向けるも、彼女たちは怒りに身を任せたような形相で、ラー・サ\nイアムを睨んでいた。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "-500" ]},
	{"command":[ "SETCHARA", "1", "char_00013901_01", "7", "CENTER", "0" ]},
