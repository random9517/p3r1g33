	{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「忘れもしない……！　お前、あの店のクソ店長じゃねぇか……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090042" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「その顔、その声……覚えてるわ……！　誤診をしたヤブ医者ね……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「こんなところに居たんだね……！　パパに借金を負わせた詐欺師の道場破り\n……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もしかして、お前らが言ってた復讐したい奴って……この女のことか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「わけのわからないことを言う子たちね……！　いいわ。私を本気にさせたこ\nと、あの世で後悔しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021090002" ]},
