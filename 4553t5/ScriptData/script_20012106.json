{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0156" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あぁん……駄目です、ここは暑くって……調子がでません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「もう、胸が重くて重くて……。よーく見てください、谷間に汗がびっしょり\nと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021710002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の左腕に、しっとりすがりついてくる獄門七重がいれば……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「色ボケ熟女にそそのかされている暇があったら、さっさと私の世話をしろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「た、隊長は私の部下だろう？　ならば……他の相手をしている暇はないはず\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "右肩に、冴島美鈴のあたたかな吐息を感じる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はまた何かを食っている鳳雛の目の前で、さっきから延々と……二人の熟女\nに迫り狂われていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いやはや。とびきりの美女に奪い合われて両手に花とは……隊長さんが羨ま\nしいなぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なかなか経験できることではないですよ？　ふしだらな極道の組長、真面目\nで堅物な長官の一騎打ち」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いや～。色男の特権だな～。僕が男なら、お金を出してもいいくらいですよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あ、でも鼻血が出ちゃうかもしれませんよねー。お二人とも、豊満でいらっ\nしゃいますし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だったら代わってもらっていいんですが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そーんな野暮なことはしませんよ。探偵は、あくまで隊長の影となり暗躍す\nる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それがプライベートアイズ、名探偵の宿命ですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ビシッ、とポーズを決めるなり、すたこらさっさと退散する。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "頼りたい時にだけいない迷探偵は、またしても俺を助けてくれなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「チクショー！　あいつ、いざこざをヒラヒラ避けることだけは一流なんだよ\nなぁああああ！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ハードボイルドに女難の相はお決まりですから。いちいち助けたりしません\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710007" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分だけ常に安全地帯だもんなー！　も、もう頼んねーぞ、絶対に！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はっはっはっはっ！　僕は推理が専門ですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一人でのびのびとスパを楽しむ鳳雛と比べて、俺は、俺は……とても窮屈でた\nまらない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ねーえ？　隊長さま？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021710003" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ここにいらっしゃる皆々さんに、私と隊長さまのあつーいバカンスを見せつ\nけてやりましょうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021710004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「組を一歩外に出れば……私とあなたは、ただの男と女……。たまにはいいじ\nゃありませんか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021710005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「スパってそういう場所じゃないっすよね！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「カツマ！　お前はそんないかがわしいことをしている暇はないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710003" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、やっと正論が……。そうですよね長官！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「貴様は私の世話をするんだ！　世話を！　私は一人で生きていかれんのだ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「毎日毎日仕事で重い責任を背負わされ！　一人で頑張り続けて疲れ果ててし\nまったんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はは、ははは……。そうみたいですね。マジで駄々っ子になっちゃってます\nし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「休みの日くらい甘えて何が悪い！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いやだいやだ私をもてなせ！　何から何までお世話してくれ……！　うああ\nあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021710007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「酒も抜けたはずなのに、欲望だだ漏れでどうしようもない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ここに更にほむらと氷華が追加されたら、ストレスでバカンスどころじゃなく\nなる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って……そういえば、ほむらと氷華が静かだな……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "きょろきょろと周囲を見渡すと、ザパーン！　とプールの方から飛び込みの音\nが聞こえてきた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうやら目を離した隙に、氷華とほむらは巨大プールで遊んでいるらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客１" ]},
		{"command":[ "SETTEXT", "「きゃーっ、素敵！　なんて綺麗な泳ぎ方なの？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客２" ]},
		{"command":[ "SETTEXT", "「オリンピック選手でも来てるのかしら……。見て、それにすっごいプロポー\nション」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客３" ]},
		{"command":[ "SETTEXT", "「モデルか？　ごくっ……それにしちゃあ、くびれと尻がエロすぎるが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客４" ]},
		{"command":[ "SETTEXT", "「女優さんかもよ！　お肌も真っ白で、人魚みたい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "優雅なスイミングを見せる氷華は、すっかりビーチの女神扱いだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ケッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「氷華はいつもああやって、どこにいたって目立つんだよな。オレが近くにい\nるってのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021710002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほむらだって運動神経はバツグンだろ。対抗して泳げば目立つんじゃないか\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「やーなこった。アイツに突っかかって得したことなんか一度もねえよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021710003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だけどさ……、対抗って案はいいな。ケンカは好きだぜ！　どうせなら……\n派手にやってやるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021710004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バッシャアアアン！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "荒々しく水面に飛び込み、猛然と泳ぎ出したほむらに一気に視線が集中する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客５" ]},
		{"command":[ "SETTEXT", "「か、かっけえええええ！　なんだアレ、人食い鮫か！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客６" ]},
		{"command":[ "SETTEXT", "「女であそこまでワイルドに泳げるのか。」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客１" ]},
		{"command":[ "SETTEXT", "「乱暴なおねえさま……。や、やだ……胸がどきどきしちゃう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "客２" ]},
		{"command":[ "SETTEXT", "「筋肉質なカラダもいいわぁ。鍛え抜かれた無駄のないしなやかな手足……ス\nテキ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……なんて下品な泳ぎ方」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はっはーん！　悔しかったら追いついてみな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021710005" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「今なんと？　私が先に泳いでいたんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021710002" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "水中で、取っ組み合いの喧嘩を始めた二人だったが……その戦いは、意外な声\nによって中断させられた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「あーあーあー、スパリゾートをお楽しみのみなさーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「随分と、楽しそうに休日をエンジョイしてるじゃないですか～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021710002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ですが！　楽しい休暇はここまでです！　戦闘員達！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021710003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はい！　怪人ハチ乙女さま！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「我らの実力を見せてあげてください！　一人も逃がしてはいけませんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021710004" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あいあいさー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「無駄な抵抗はやめてください！　私達の言うことを聞きなさーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021710001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「な、な、な、なんだぁありゃあ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021710006" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「むむっ！　事件の匂いですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021710009" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鳳雛の声を聞き、ほむらと氷華が同時にプールサイドにあがってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたたち！　ここは慰安施設です、その物騒な獲物をしまいなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021710003" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そういうわけにはいかないですよ！　我ら、怪人派遣組合！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021710002" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
