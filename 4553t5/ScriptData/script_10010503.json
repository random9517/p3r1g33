{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_010" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……捕まえたか！？　偽者どもを全員捕まえたか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そこにもルナテミスが！　まさかあれも偽者か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザーか！　偽者が他にもいるのか！？　いったいどこに――って、ちょ\nっと待て！　まさか私のことを言ってるのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「待ちなアナザー！　そのルナテミス様は、たぶん本物だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「体臭の成分から、本物である確率は５２％」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ！？　その微妙な確率は！　私は間違いなく本物だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だってさ、犬っころ。おまえの鼻からすると、どんなもんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わたくしがそこらの犬のように、臭いで人を見分けているとお思いでしたら\n心外ですな。わたくしは相手の人格を尊重し、その言動を――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかっちゃいたが役に立たねえな、おまえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「とにかく、そっちのルナテミス様はあとまわしだよ！　逃げてった偽者ども\nは――いた！　向こうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「向こうって――はぁ！？　まだあんなに偽者がいるのかよ！」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "LEFT", "-150" ]},
	{"command":[ "SETCHARA", "1", "char_00000101_01", "0", "LEFT", "150" ]},
	{"command":[ "SETCHARA", "2", "char_00000101_01", "0", "RIGHT", "-150" ]},
	{"command":[ "SETCHARA", "3", "char_00000101_01", "0", "RIGHT", "150" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「全員捕まえるしかなさそうだね！」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105050001" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうね。このままじゃ、ＥＤＯ本部がルナテミスで埋め尽くされてしまう…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「一人見つけたら、３０人はいると思ったほうがいいのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「二度と出てこないように、根こそぎやっつけなきゃだめだよな！　こういう\nのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って、お前ら！？　私のことをなんだと思っている！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様、落ち着いてください。偽者のことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それはわかっているが、しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さあみんな！　ルナテミスどもを捕まえに行くぞ！　あのクソ生意気なヤツ\nを徹底的にぶったたいて、ヒーヒー泣かせてやれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい！　本当に偽者のことを言っているのだろうな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105050008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}