		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んむうううぅ……！？　ちゅぱっ、じゅるるっ……！　また、熱いのが口の\n中にっ……！　ちゅぷっ、ぐちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んぐっ、ぐぐっ……！　こくっ……じゅる、ごくんっ……！　ドロドロして\nるから飲みづらいのに……どんどん精液が出て来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ううっ、んっ、んじゅるうぅ……！　本当に、溺れちゃう……！　陸の上で\n……精液で、溺れて……あぶっ、うぐうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はあ、あああっ……！　苦しいのに……またイッちゃうっ……！　精液飲ま\nされるの、嬉しくて……イッ、イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「じゅちゅ……ぐちゅ、ずちゅ……！　ごくんっ……！　あっ、うぐぐっ……\nんっ、あっ……ふああああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それにしても、すごい性欲だね……こんなに出るなんて、本には書いてなか\nったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「えっ……？　ボクのパイズリとフェラ、すごく気持ちよかった……？　また\nシて欲しい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そ、そこまで言われたら、応えないわけにはいかないね！　期待に応えるの\nも、天才の務めというものさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、でも……次は違うことがしたいかな……キミのために色々と勉強した\nから、それを披露してみたいしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
