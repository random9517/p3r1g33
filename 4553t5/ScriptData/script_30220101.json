		{"command":[ "PLAYVOICE", "v2_022_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、熱っ！？　ちょ、ちょっと……！？　なんで胸や顔に精液かけるのさ\n……！？　あふっ、んっ……んふうううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、はああぁ！　ドロドロのクサイ精液が……いっぱい広がって\nく……！　やっ、ああっ……こんなの、ありえない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ありえないのに……気持ちいいっ……！　ニオイも、熱さも……全部感じち\nゃう……！　オマンコ、イッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んはあああぁ……！　あっ、ダメ……！　またイクッ……あっ、あんんっ！\n　イクッ、イクぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふうぅ……精液まみれにされてしまったね……いやらしいニオイで、\n頭が変になりそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「でも、どうして口の中に出さなかったんだい……？　キミの精液なら、飲ん\nであげるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクの身体に精液をぶっかけて、マーキングしたかった……？　そ、そんな\n動物みたいなことを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いや、だが人間は哺乳類だし、ある意味では動物と言えなくもない……なら\n、マーキングも間違いじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それに、ボクもイヤな気分じゃないし……よし、いいだろう。次も是非、ボ\nクにいっぱい精液をかけて、マーキングしてくれたまえ！」", "NORMAL" ]},
