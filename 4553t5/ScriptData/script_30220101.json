{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はーっはっは！　見ろ！　これぞ、ボクの開発したロボが作り上げた新薬だ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「この薬を飲むと、自分が過去に経験したエッチなことを、誰かに話したくな\nるんだ。簡単にいえば、自白剤みたいなものだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それじゃ、さっそくキミで実験を……って、こらっ！　暴れるんじゃない！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いいから早く飲んで……！　なっ、なにをするんだい！？　これを飲むのは\nボクじゃなくて、キミの仕事で……んぐっ！？　うぐっ、ごくん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「キミが暴れるせいで、ボクの口に薬が入ったじゃないか！　どうしてくれる\n……んむっ！？　あっ、これ……ダメだ……！　く、口が勝手に動く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「よいっしょ、っと……こんな感じかな？　どうだい？　痛かったりする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「なんで急にこんなことをするのかって……？　そりゃ、キミに気持ちよくな\nってもらいたくて、色々と勉強したから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぼ、ボク的には、手でする方が効率的かなーって思ってるけど……！　その\n……こうすると、男の人は悦ぶって、本に書いてあったからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクのおっぱいを感じられて、すごく嬉しい……？　そ、そうか！　それじ\nゃ、もっと気持ちよくしてあげよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「えっと……胸でオチンポを上下にシゴきながら、先端を舐めたり、咥えたり\nすればいいんだったね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅ、ちゅぱっ……んっ、んんっ……！　オチンポ、熱くてカタ\nい……！　それに、変な味がするね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぐっ、ちゅぷっ……じゅるっ、ちゅちゅ……舐めながらシゴくのは、ちょっ\nと難しいね……でも、頑張らないと……んっ、ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……ぐちゅ、ぐぽっ……ぷはっ……！　オチンポの先っぽから、\n変な汁が溢れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「確か男の人が感じたり、気持ちよくなったりすると出て来る汁だっけ……？\n　ってことは、気持ちよくしてあげられてる、ってことでいいのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そ、そんな大げさに悦ばなくてもいいよ。キミが気持ちよくなってくれると\n、ボクも嬉しいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、きゃっ……！？　む、胸の中でオチンポが暴れて……！　少し落ち着\nきたまえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「キミはボクに身を委ねていればいい。は、初めてだから……上手くできない\nかも知れないけど……くちゅ、じゅるっ……ちゅぱっ、んちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ちゅぷっ……くちゅ、れろっ……んぶっ、うぐっ……！　はぁ、あ\nあっ……エッチな汁が、どんどん出て来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「塩気があって……じゅるっ、ちゅ……変な味なのに……もっと、舐めたいと\n思うなんて……くぷっ、ずちゅ、ちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……ふぇ……？　先っぽだけじゃなくて、もっといろんなところ\nを舐めて欲しいのかい……？　わ、わかった……ちゅ、じゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「くぽっ、じゅぽっ……んぶっ、ちゅ、ちゅるっ……！　このデコボコしたと\nころを舐めると、一段とオチンポが反応するね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ってことは、ここがキミの弱点なのかな……れろっ、ちゅちゅ……んちゅ、\nちゅぷっ……じゅっ、ぢゅぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、うぐっ……！　またオチンポが暴れて……んっ、あぐっ……！　胸か\nらこぼれ落ちちゃうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「言うことを聞かないオチンポは……こうして、もっと谷間で挟んで……！　\nんっ、あっ……ちゅぱっ、ちゅ、じゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　あっ、熱っ……！　強く挟めば挟むほど、オチンポの\n熱が肌に伝わってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それに、さっきよりも大きくなってるし……興奮しすぎだよ……ちゅぱっ、\nちゅ……んちゅ、ぢゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ぢゅちゅ……くぷっ、にちゅ、ぐちゅるっ……！　あぐっ、んんっ\n……！　口の中、エッチな汁でいっぱいだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「こんなに飲まされたら……人魚なのに、溺れちゃいそうだよ……んっ、あむ\nっ……ぺろっ、ぴちゅ……ちゅ、ぷちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅ……じゅっ、じゅるっ……！　オチンポの裏側にある、スジみ\nたいなところも……気持ちいいみたいだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「こうして……んっ、ぴちゃ……舌を当てると、キミの血が脈打ってるのを感\nじるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「もっとペロペロして欲しいんだね……いいよ……ボクの口で、いっぱい感じ\nて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅるっ……！　ちゅぱっ、じゅちゅ……！　にちゅ、ぐちゅ…\n…ずっ、ぢちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あぶっ、ぐっ……んぶうぅ……！　急にオチンポがビクビクして……ど、ど\nうしたんだい……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そろそろイキそう……？　イクってことは、射精するってことだね……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「うん……遠慮せずに出してくれ……！　ボクの口に、いっぱい精液……出し\nて……！　んっ、うぶっ……ぐむううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぐぷっ、んむっ……！　んっ、んあああっ……！　熱いの、感じるっ……！\n　んぐっ、じゅるっ……うぐうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「これが、精液……！　んぐっ……ごくっ、じゅるっ……！　ドロドロして、\n変なニオイがするぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それに……ちゅぱっ、じゅるるっ……！　苦くて……ま、不味いし……ちゅ\nぱっ、じゅ、ぢりゅ……ちゅぷっ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　でも、イヤじゃないよ……！　だって、キミの精液だ\nからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ほら……もっと、出して……んっ！　ボクの口を孕ませるぐらい……たくさ\nん、出して……！　うぐっ、じゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はあ、はあ……んぐっ、ごくっ……ごくんっ……！　精液って初めて飲んだ\nけど、すごく喉に絡んでくるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それにニオイも強烈で……息をするたびに、エッチな香りがしてくるよ……\nんっ、あっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……キミのオチンポ、まだカタくて元気なままなんだけど……どう\nいうことだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「一度射精したら小さくなるって本には書いてあったような……な、なるほど\n。こういうのは、個人差があるんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ……もう一回、してあげようか……？　その……ボクも、もっ\nとキミのを舐めたいし……んっ、わかった……じゅるっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぐちゅ……ちゅ、じゅるっ……んぶっ、あぶっ……オチンポの中に、まだ精\n液が残ってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「全部吸い出した方がいいんだね……じゅるるっ……！　ずっ、ちゅちゅ……\nぐちゅ、ずちゅ……ちゅっ、じゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……ごくんっ……残ってた精液も、ドロドロで濃厚な味だね……\nちゅぱっ、じゅるっ……ずぷっ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んぷっ……！　今度はさっきと違うところを舐めてみたいんだけど……キミ\nが感じるところって、どこかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「精子の出るところ……オチンポの先端を舌先でほじりながら、舐めてほしい\nんだね……やってみるよ……んっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぐりゅ、じゅるっ……んっ、あっ……オチンポはカタいのに、先端は柔らか\nくて……なんだか、変な感じだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「この状態を続けながら、胸でオチンポをシコシコすれば、もっと気持ちよく\nなるのかい……？　んっ、わかったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ずちゅ、じゅるっ……はぁ、ああっ……！　す、すごい……！　オチンポが\nさらに大きくなって、暴れてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「エッチな汁も止まらないよ……んちゅ、ずりゅ……！　何回舐めとっても、\nどんどん溢れてくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅ……ずちゅ、ぢちゅるぅ……！　んぐっ、ごくっ……ちゅぱ\nっ、ちゅ……んちゅ、れろれろぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はあ、ああっ……！　キミのを舐めたら、ボクのオマンコも熱くなってきた\nよ……！　弄ってないのに、イッちゃいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、あぐっ、んちゅるっ……！　んぶっ、ちゅちゅ……！　オチンポが、\nまたビクビクしてる……！　キミも、イキそうなんだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「出したいなら……遠慮しないで出していいから……！　ボクも、そろそろ限\n界だし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んふっ、じゅるるっ……！　んぐっ、ちゅぱっ……れりゅ、ぐちゅ……！　\nちゅ、じゅるるっ……！　ちゅぱっ、ちゅぴっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ずちゅ、ちゅぱっ……！　あっ、あんんっ……！　イクッ……！　イクぅ…\n…！　キミも、イッて……！　あっ、ああっ！　んはあああぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0103220" ]},
