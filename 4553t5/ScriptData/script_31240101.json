{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "124_0103101" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「……急な呼び出しだな。一体私に何の用だ？　なにか不測の事態でも起こっ\nたのか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103102" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「なに？　ご奉仕、だと？　フ、フフフ、フハハハハ。なるほどなるほど……\nフハハハハハ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103103" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ああ、聞いてるとも。隊長の特殊能力だろう？　そういったことをさせて、\n力を引き出すことができるらしいな。なるほど、それを私に……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103104" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「フフフフフ。いいだろう、やってやろうじゃないか。ただし……後悔するな\nよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103105" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「徹底的にやってやる。からからになって干からびるまで、隊長が泣いて謝る\nまで、一滴残らず搾り取ってやる。そら！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103106" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「なんだ、この貧相なイチモツは？　こんな命令をしてくるぐらいだから、は\nち切れんばかりに勃起させてるのかと思ったら、萎え萎えじゃないか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103107" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「それともまさか、私相手には起たないとでも言うつもりか？　だとしたら、\nとんでもない侮辱だぞ、隊長」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103108" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「そんなペニスに、私が奉仕してやる価値などあるか。いっそのこと、この場\nでこいつを噛みちぎってやろうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103109" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ハハハ。冗談だ、冗談。だからそんなに怯えた顔をするな、隊長。可愛すぎ\nて、思わず、本当にしてやりたくなるじゃないか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103110" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「それが嫌なら、さっさと勃起させるんだな。でないと、私だってご奉仕でき\nないだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103111" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ほら、起たせて見せろ。隊長の男を奮い立たせて見せろ。フフフ、ハハハ。\nそうだ。少しずつだが、膨らんできたぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103112" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「フフフ。やればできるじゃないか。ちゃんと立派に、がちがちにかたくでき\nたじゃないか。ハハハ、血管まで浮き出てるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103113" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「それにしても、勃起させろと命令されて、本当に勃起させるなんて……フハ\nハハハ。隊長はとんでもないドＭだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103114" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「違うだと？　フン。普通は、命令されたからってこんな簡単に勃起するか？\n　それができたってことは、隊長が命令されて喜ぶドＭだってことだろう」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103115" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「いいじゃないか、変態で。隊長にはお似合いだからな。ハハハハハ。でなき\nゃあ、こんな能力だって、備わってないだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103116" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「それよりも……さあ、始めるぞ。私のご奉仕、たっぷりと受け取ると良い。\nあーむっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103117" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ん、じゅ、じゅるぅ……んちゅ、ちゅうぅぅぅ。ちゅぶぅ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103118" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ンフフ。良い声で鳴くじゃないか、隊長。ペニスもぴくぴくと震えて、喜ん\nでるぞ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103119" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「じゅる、ちゅう、ぶぅ、ん、ちゅうぅ。じゅるる……ンフフ。そうだ、その\n泣き声だ。もっとだ。もっと聞かせろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103120" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「じゅるるるるぅ。じゅる、ちゅぶう、ちゅ、ん、ぶぅ。むぅぅ。んじゅうる\nうううぅぅぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103121" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ぷあっ。フハハハハハハ！　いいぞ、隊長。女の子のような泣き声だ。ゾク\nゾクする。ゾクゾクするぞ、その声。フフフ、アハハハハハ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103122" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んぶぅ、んんん、むぅ、んじゅ、りゅぶう、ちゅ、ぶぅ、ん、ちゅううぅぅ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103123" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んぷっ。はぁ、はぁ……だんだんと、匂いが濃厚になってきた。それに、ペ\nニスの震えも、大きくなって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103124" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ンフフフフ。そうか、イクんだな？　イキそうなんだな？　部下にペニスを\nしゃぶらせて、みっともなくイクんだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103125" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「アハハハハ。いいぞ、隊長のだらしのないペニスが、汚らしい白濁液を撒き\n散らすところ、見てやろうじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103126" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「そら！　イけ！　派手にイッてみせろ！　んじゅるぅぅ！　んぶ、ん！　ぶ\nぅ、じゅるるるるるるるる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103127" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「じゅぶっぅ、ん、ぷあっ！　アハ、アハハハハ！　いいぞ、その声……情け\nない悲鳴のような声……もっと聞かせろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103128" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「じゅるるるるるるるる！　んじゅるぅ！　じゅぶぅ！　ンフフ、なにがやめ\nてくれだ、ペニスがこんなに喜んでるじゃないか」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103129" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「びくびく、震えながら……じゅるる、ぶぅ、ちゅ……射精したそうに、穴、\nパクパク、させて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103130" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んんん！？　膨らんだ？　ペニスがまた、びくんて膨らんで……フフフ。と\nうとう、限界、だな！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103131" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「さあ、イケ！　射精しろ！　じゅるるる！　ぶぅ、じゅる、ぶちゅうぅ！　\nんぶ、んぶ、んぶ、んぶぅうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103132" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「そうだ、そのまま、イクんだ！　絶頂しろ！　んじゅるうううううううう！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103133" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んぶぅう！？　ん、むぅ……んんんん、んっ！　えほ！　えほえほえほ！　\nえほ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103134" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「はぁ……青臭くて、どろどろで、喉の奥に絡む。おまけにイガイガして、ま\nったく最低な感覚だな、こいつは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103135" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「だが、まさかこんなにたくさん出るとは……たまってたのか？　なんだ、他\nの女のご奉仕では満足できなかったのか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103136" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「なに？　私の口が想像以上に気持ち良かっただと？　フハハ。そんな安い追\n従で、私が喜ぶとでも思ったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103137" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「だがまあ、気持ち良かったのは本当か。でなければ、私の胸や顔がここまで\n汚れてはいないだろうしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103138" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「さて……それじゃあ二回戦を始めるぞ。休憩などさせるか。そんな暇はない\n。なにせ、カラカラになるまで、だからな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103139" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「言っただろう。一滴残らず搾り取ってやると。それともまさか、私に二言が\nあるとでも？　だとしたら、その甘い考えも含めて、教育してやる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0103140" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「フフフフフ。フハハハハハ。さあ、いくぞ。また良い声で鳴けよ、隊長。フ\nフフ、ハハハ。アハハハハハハハハ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}