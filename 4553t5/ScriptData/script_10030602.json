{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なんじゃと！？　女王様がいない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そうなのだ！　城の中をくまなく探したが、どこにも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115380001" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「兵士のコにも聞いたけど～、誰も見てないって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115380001" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いったいどこに行ったんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そんなのわかんないよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115380001" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お、おち、おちおちおち、おちち、おちち、おちんちん、おっぱい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ジェスタは慌てているのかふざけているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115380002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「でも、ジェスタちゃんがここまでうろたえているのってなんだか新鮮ね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115380002" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ちょっと落ち着いちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115380002" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こういう場を頓狂な動きで落ち着かせるのは、さすが道化師というところじ\nゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょっとぉ！　面白がってないでほら、ここにツッコミを入れて！　ボクの\n手を見て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ん？　手紙？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なになに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちょっと息子に会ってきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115380001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ええぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115380003" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「つまり女王様は、ひとりで地球に行っちゃったってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115380003" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「普段の女王様ならお忍びで出かけられても心配はしないが、いまの状態では\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115380003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「本調子じゃない女王様だよ？　下手したら地球の原住民に捕まっちゃうよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「白肌むっちりロリ巨乳ボディが原住民汁でぬっちょんぬっちょんにされちゃ\nう！　じゅる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「と、とにかく女王様を迎えに行かないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115380004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「地球の……きっと隊長のいるところよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115380004" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんたちも、すぐ行こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115380004" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おい、お前たち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「エファナティカ様、オレたちも地球に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょぉっとまったぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なんじゃ！　急がねばならぬというときに、まだなにかあるのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミたち、そのままの格好でいったら、女王を探す前に原住民たちに素性が\nバレちゃうでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たしかにそうだが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380006" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「目立った方が女王様も見つけやすいんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380005" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いやいや、ここは原住民に溶け込まないと……って、あのエルフたちにも伝\nえたかったんだけど、もう行っちゃったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「せめてキミたちだけでもちゃんと隠密行動、しよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こそこそするのは性に合わないのじゃが……まあ、今回の目的は女王様を見\nつけることじゃからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380007" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だな。だけど、どんな服があるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380006" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まあ、これを見て決めなよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380009" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よし、余はこの服でいく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380008" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレはこれだ。なんか“強そう”だからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380007" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいねいいねぇ、ふたりともにあってるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380010" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あれ、エファナティカ様、“腕輪”は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380008" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「腕輪は置いてきた。努力はしたが、この任務には連れていけない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380009" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……アレがあると、いやでも目立っちゃうもんねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115380011" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「とにかく、女王を見つけに行くぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115380010" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115380009" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}