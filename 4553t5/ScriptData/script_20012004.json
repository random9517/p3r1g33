{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まぁ、とりあえず何だ……これでも食って、一旦泣き止んでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「うぐっ、ぐすっ……何……これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640001" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「『居酒屋正義』特製のチョコレートパフェだ。うちのデザートでは、下手な\nパーラーより美味いって一番評判のやつだぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こんな……甘いものなんかじゃ……絶対騙されない……ぐすっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640002" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「騙すとか、騙さないとかはいいから、とにかく食べてみてくれればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぐ……は……あむ……んっ、はむ……あむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640003" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「…………どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっ、あむっ、はむっ……んんーーーーーっ、美味しい～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640004" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっ、そうかそうかっ、あ、もしよかったら、こんなのもあるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……これは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640005" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うちが取り寄せて、店で出してるプリンだ。１日限定２０食で、下手すると\n昼間のうちに売り切れちまう逸品だぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ぱくっ……んっ、んふぅぅぅーっ、んーーっ、甘ぁぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640006" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ちょっと甘すぎだったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んーんっ、そんなことないっ、これはこれ位の甘さじゃなきゃダメなやつー\n♪　はむっ、ぱくっ、んんーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640007" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そりゃ良かった。あ、そうだ……嫌いじゃなければ和風系のやつもあるぞ？\n　後は、老若男女大人気のポテト系も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021640008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んまっ♪　何、ここっ……天国？　次から次へと美味しいもの来てるんだけ\nど♪　どうなってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021640008" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれ……一時はどうなることかと思ったが、食い物で即落ちしてくれる\nとはな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「けど、これで何とか嵐は去ってくれたか……助かったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「いやぁ……良かったどすなぁ。これで改めて、ウチらもグリーンの話がとっ\nぷりと出来るというものどす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021640001" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「確かに……ブラックのことも、しっかり語り継いで行かないといけないな。\nなぁ、君もそう思うだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021640001" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ……？　って、いつの間にビールそんなに空けてるんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あら……ここは、そういうお店でありましょう？　お酒を嗜むことに何の問\n題が？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021640002" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、問題ってことはねぇが……ジョッキがもう４つ積まれてるって、\nペースってもんが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「これ位レディとしては、最低限の付き合い位なものだろう。おーい、こっち\n、もう１本つけてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021640002" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、そっちはそっちでメチャクチャ徳利空いてるな！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「いやぁ、安居酒屋と侮っていたが撤回しよう。置いている酒に間違いはない\n。つまみもいいモノが揃っていて実にいい店だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021640003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「然り。今日は気分がようございます。グリーンの凛々しい姿について、とっ\nくりと語り明かしましょう……そもそも、グリーンとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021640003" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「いや、待て待て。先に我が推しブラックの話をさせてくれよ。少し長くなる\nが、まずは彼女との馴れ初めから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021640004" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やべぇ……これはタチの悪い酔っ払いモードのやつだ……適当な所で\nフェードアウトしねぇと……", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640001" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「お前……今……どっか逃げようとか……してただろぉー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いっ！？　い、いやいや……そんな、ことは……別に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「なら……アタシの話を聞いてくれるよな？　分かるか？　目の前にブルーが\nいた時の気持ちぃ……アタシがどんな思いでいたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640003" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ど、どんなだったんですかね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「それだよ！　もうさ……何ていうんだ……？　ずっと離れ離れになった恋人\n同士がさぁ……何の前触れもなく、ふと出会った時みたいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「恋人……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁっ？　な、な、何言ってるんだよ？　アタシとブルーが恋人同士とかっ\n、誰もそんなコト言ってねぇだろっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640005" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、今自分で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640006" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何でもないっす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「とにかくぅ……追いかけても逃げてく蜃気楼って言うかよぉ……そーいう感\nじなんだよなぁ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640007" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "過去の因縁は知らねぇが、よっぽど思い入れがあるんだろうな……こ\nれ、また顔を突き合わせたらどうなることやら……", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あら、カツマさん……戻ってらしたんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021640001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ブ……ブルー……じゃないっ、氷華……な、何でここにっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「何でと言われましても、勤務時間は終わりましたし普通に飲みに来ただけで\nすが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021640002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ん……？　あんた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やべぇ……今、ここでまたブルーと顔を合わせたら……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こいつの知り合いだったのか。なぁ、ちょっと話聞いてくれないか？　酒な\nらあるからよ……付き合ってくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640009" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「お話ですか……？　ええ、私でよろしければお聞きしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021640003" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おいおい……いいのかよ？　こいつはオーヴァーハング四天王で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ、承知しています。が……今の私はオフですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021640004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おおっ、話せるじゃねぇか。まぁ、こっち座ってくれよ。おーい、この姉さ\nんに、ビール！　あ、ビールでよかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021640010" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「問題ありません、いただきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021640005" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジかよ……こいつら、どういうメンタルしてるんだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}