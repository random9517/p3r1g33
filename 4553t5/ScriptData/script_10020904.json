		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こうしちゃいられないわ。カツマちゃんにこのことを伝えないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080026" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そこに再び運転手の乗っていない車が行く手を遮る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080009" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もう！　貴方たちの相手をしている暇はないんだから！　そこを通しなさー\nいっ！」", "NORMAL" ]},
