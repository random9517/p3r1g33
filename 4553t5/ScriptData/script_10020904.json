		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、来ないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「追いかけてきてくれないのかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょっと、様子を見に行ってみようかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080005" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なにかしら、この車たちは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「さっきから私の後ろにぴったりとくっついてきて、なにが目的なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なっ、急に加速して、私の前に出るなんて危ないじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080008" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こんな狭い道で、危険な運転をしちゃダメでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「……というか、このまま前後にぴったりマークされていたら、帰るに帰れな\nいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょっと危ないけど、追い抜かせてもらうわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080011" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「……っ！？　私の加速についてきてる！？　この車たち、ただの一般車両じ\nゃない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「よく見ると、タイヤやサスペンションがこの山道に最適化されているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「この山道で走るためにカスタムされた車ってわけね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080014" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ロボットカーの私にレース勝負を挑もうっていうつもり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「フロントライトを点滅させて……それはつまりそういうことね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「いいわ。この私の走りを見せてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ＡＩ制御の私と同じ走りをするなんて。なかなかやるじゃない……って、あ\nれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080018" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「その時である！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……？　車に、誰も乗ってないじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080019" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なんで運転手のいない車が勝手に走ってるの！？　怖いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「さらに加速する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「車のオバケと追いかけっこなんてごめんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080021" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「急傾斜急カーブが繰り返される峠の下り坂を、タイヤ痕を残しながら下る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「このまま、一気に駆け抜けちゃうわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080022" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「順調に暴走車との距離を開ける。しかし、ここは山。自然の脅威が牙を剥く\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃぁあっ！　クマ～～～ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080023" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「クマが飛び出した！　このままでは追突してしまう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080006" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あ、危なかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080024" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「高速走行しながらの変形！　中に人がいたら間違いなく放りだされていただ\nろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080007" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「目の前で車が変形したことに驚いたのか、クマは逃げていく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114080008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なんなの……なにが起きてるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114080025" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
