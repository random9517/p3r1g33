{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふたりとも、落ち着いた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「すっきりしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃあよかったなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ふたりが暴れ、それを止めるために俺たちも対応し、教室はめちゃくちゃにな\nっていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この教室の惨状……明日楽や学園長にどう説明しろっていうんだよ、まったく\n……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そろそろ下校時間ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そうね。あ、ふたりはこの後も寮で勉強ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なんですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ええーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115820002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「当たり前でしょ。ふたりが暴れたから、今日の分の課題が進んでいないんだ\nから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「女子寮で続きをしましょう。私たちもお手伝いしますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115820002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つきみはどうするんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「私はお姉ちゃんに勉強を見てもらうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115820002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それなら私だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ルルーナは……帰ってエファナティカとか輝夜に勉強見てもらうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「う……。輝夜はともかく、エファナティカの教え方は厳しいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうだわ！　カツマが教えればいいのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、だから俺は教員じゃないからな！？　夜日楽と桃花から教わった方が\n絶対いいだろう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「じゃあ、カツマさんも寮に来るのはどうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115820003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そうね。教える側は多い方がいいかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして俺は桃花たちの部屋での勉強会に参加することとなった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「というわけで、この単語の意味なんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "桃花は教えながら、ちらちらと時計を見ている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「桃花、どうしたんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ううん、なんでもない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ルルーナはこの単語の意味、大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……さっぱりだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「頻出の古語だから、覚えておきなさいって先生が言っていたでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820007" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうだっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115820003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115820004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はぁ……。本当に１から教えないといけないみたいね……。とにかく、小テ\nストの範囲で出そうな単語だけでも覚えて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820008" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんなに一気に覚えさせて大丈夫でしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115820005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こうなったら覚えるまで繰り返すわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820009" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はやく今日の分は終わらせないと……。ゲームのデイリーミッションを進め\nられないじゃないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちょっとちょっと、そんな一気に覚えられないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115820004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ、少しずついきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115820007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あなたたち、そんなこと言ってる時間はないでしょ？　とにかく覚えて。覚\nえて帰って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820011" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "思った以上にスパルタで、桃花はマーガレットたちに勉強を教えていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「桃花さん、ちょっとペースを落とした方が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115820006" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だめ。追試までに教えないといけないことが山ほどあるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115820012" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおい大丈夫か？　またさっきみたいに暴れられたら……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ああもう、わっかんないわー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わからーん！　頭が破裂するー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ええいふたりとも！　また暴れるんじゃないわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115820001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だから言わんこっちゃない！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}