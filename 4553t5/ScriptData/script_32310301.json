{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もうっ、サンタ美少女をラブホテルに連れ込んで、いったいナニをするつも\nりなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……って、なに？　ボクがホテルに連れ込んだんだろうって？　いーじゃん\n、そんな細かいこと気にしないのーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなことより、今日はボクがクリスマスプレゼントをあげようっていうん\nだから、大人しくもらっちゃいなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ、いやがっても強制的にプレゼントしちゃうけどね～。だって、ボク\nはサンタさんなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほら。ラブホにいるんだから、ヤることっていったらひとつしかないよ\nね～。アツアツチンチンごかいちょ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふぃ～っ。やっぱり冬はペニス暖房にかぎるわい。こんな格好じゃ、ボクの\n大事なおっぱいも凍えちゃうもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00023103_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「というわけで、キミのチンポであったまろうねぇ。ほらほら、ひんやりおっ\nぱいどう？　気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「暖房のばっちりきいたホテルの一室で、美少女の冷やしおっぱいにチンポを\n包まれるなんて、なんて贅沢」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こんな素敵なひとときをキミにプレゼントするなんて、さっすがサンタさん\nだなぁ。表彰もんだよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だけどぉ、サンタさんのサービスはこんなもんじゃないよぉ？　ここからさ\nらに、チンチンをパイコキしちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほら、こうやってぇ……んっ、キミのチンチンをシコシコズリズリしち\nゃうよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……。すっごく熱い、チンポぉ……♪　んふぅ、おっぱいとろけ\nちゃいそうだよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのおっぱいマンコどう？　気持ちいい？　んっ、デカパイに挟まれてぇ\n、しごかれてぇ……あんっ、チンチン感じちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクは感じちゃってるよ？　キミのアツアツクソデカチンチンに、おっぱい\n犯されちゃってるんだもん、ふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのチンポから熱がうつって、ボクのおっぱいもだんだんぬっくくなって\nきたぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「エロ乳マンコで奉仕しながら、あんっ、どんどん身体が火照ってきちゃって\nるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのスケベエンジンにも火がついたかな？　もっとぎゅーっと、チンポを\nおっぱいで挟んじゃおうねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほら～。サンタさんのおっぱいマンコでぇ、キミのチンポをどんどん気\n持ちよくしてあげるね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キツキツ乳マンコど～ぉ？　ふふっ、チンチンがビクビクっておっぱいの間\nで暴れちゃってるじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もぅ、チンチンは正直だなぁ。いい子だぞ。グッドチンコだ。キミにはサン\nタさんからプレゼントをもらう資格がある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だからこうして、もっともっと激しくパイズリ～♪　チンチンズリまくって\n射精しちゃおうねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あははっ、気持ちよくって先走り汁もたれちゃってる。んっ、すっごく濃い\n匂い……ボクの乳マンコ疼いちゃうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あんっ、先走りでおっぱいヌルヌルになってきてるっ。はぁ、はぁ、それに\nぃ……おっぱいも汗ばんできちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「デカパイズリズリ気持ちいいねぇ♪　充血して、パンパンになってる亀頭…\n…んふっ、尿道パクパクしちゃってる～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なに？　どうしたの？　腰が震えてきちゃってるよ？　もしかしてボクのパ\nイズリでイッちゃいそうかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいんだよ～？　だって、今日のボクはキミにキモチイイことをプレゼント\nしにきたサンタさんなんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どうせこのあと、一人寂しくオナることになるチンポなんでしょ？　チンポ\n汁無駄撃ちするくらいならボクにだしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、チンチンまだおっきくなるぅ……っ！　んっ、ああっ、ビクンビク\nンって、もう……限界……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んじゃあ、思いっきり搾っちゃうっ！　チンポ、ズリズリしまくって……ん\nっ、ああ……ほらほら、射精しちゃえぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「勃起チンチンぎゅうっと、根元からしごいてたっぷり射精させてあげるから\nっ、んっ、それっ、それそれぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「思いっきりだしてっ、ほらほら、腰が動いてる、ボクの乳マンコにむかって\nヘコヘコってさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「プレゼントのお返しはザーメン払い♪　パイズリ気持ちいいんでしょ？　お\nっぱいにザーメンでお返ししてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんうっ！　あっ、あああぁぁぁああぁぁ～～～～っ！！　いっ、いきなり\nぃっ、おっぱいマンコに中出し……きたぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ん……すっごぉ……。チンチン、びゅるるっていいながら精液だしまくって\nるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ええっ、ちょっとまだでるのぉっ！？　こんなにたくさんの精液、乳マンコ\nに入りきらないよぉ。どんだけ溜めてたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それとも、こんなに射精しちゃうほど、ボクのおっぱいマンコが気持ちよか\nったってことかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふふっ、まあ言わなくてもいいよ。なんてったって、今夜のボクはサンタさ\nんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミが満足するまで、おっぱいマンコをオナホみたいに使わせてあげちゃう\nからねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっぱいから溢れちゃうくらい射精したのに、チンチンはまだ勃起してるね\nぇ。さすがだねぇ……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んじゃ、おっぱいもザーメンでヌルヌルになったし、２回戦といこっか♪　\nもっと搾っちゃうからね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ。ヌルヌル、ぐっちょぐちょのおっぱいマンコ～♪　さっきよ\nり、おっぱいが密着しちゃうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あはんっ、チンポでっかいまま、まだまだ精液だせちゃうぞって、\nボクのおっぱいおしのけちゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ザーメンまみれのおっぱい、ンッ、チンチンこすれて、気\n持ちいい……あ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっと激しくパイズリしちゃうね～♪　あはっ、谷間でザーメンかき混ぜら\nれて、ぐちょぐちょやらしぃ音してきたぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンチンも硬くなってるねぇ、アンッ、ヌルヌルおっぱいから逃げちゃう…\n…しっかり挟んでおかないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほら、逃がさないっ。いい子のチンポは大人しくサンタのパイズリでイッち\nゃえ！　射精しちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、エロ汁たっぷりの乳マンコ、んふっ、アツアツチンチンすっ\nごく感じるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「密着させてるせいで、ボクまでどんどん気持ちよくなっちゃうじゃないかぁ\n……あんっ、もっと……もっとだよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのチンチンを気持ちよくしながら、ボクも気持ちよくなるぅ♪　んっ、\nああっ、ズリズリ……って、もっと激しくねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、また腰が動いてるっ。ボクのおっぱいマンコでまたイキそうになって\nるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「また射精しちゃいそう？　ボクのおっぱいマンコに中出ししちゃうかな？　\nんふっ、我慢なんかさせないんだからねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ため込んでいる濃厚チンポ汁はぁ、サンタさんが根こそぎコキだしちゃうん\nだから。ぜーんぶ射精させちゃうよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、おっぱい気持ちいい……♪　ズリズリ、コキコキ、どんど\nん激しくなっちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ザーメンまみれのエロおっぱい♪　むにゅむにゅって、いやらしぃく揉みな\nがら、キミのチンチンしごいちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、すっごい……キミのエロぉい視線……♪　おっぱいますます火照っ\nちゃう。やらしぃ気分、盛り上がっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ、んふふっ、キミもどんどん素直になっているみたいで嬉しいよ。ボ\nクのおっぱいに夢中になってるんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいよ。いいよ～。そのまま、そのまま射精までしちゃおうねぇ。もいっか\nいドロドロザーメンぶちまけちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ、ボクもイッちゃいそうかも……。キミのザーメンでおっぱいをまたド\nロドロにされちゃうことを想像したら……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、イクッ、イッちゃう……！　ボクのおっぱいマンコもイッち\nゃう……キミのチンチンにイかされるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、だしてっ、だしてぇっ！　チンチンぎゅーってして、思い\nっきりしごいちゃう……からぁあああぁぁぁ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふぅうううぅぅぅっ！！　んぁっ、ああぁっ、あああぁぁぁああぁぁあぁ\n～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「またっ、またいっぱいぃっ！　おっぱいの中にっ、アッツアツのザーメン流\nれ込んでくるぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、乳マンコイクッ！　イッ、イクぅうううぅぅぅ……っ！　ああっ\n、まだ……まだ出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ザーメンがおっぱいからあふれるっ、ンッ、おっぱいがもっと、ドロドロに\nなっちゃって……ああ、熱いの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「乳マンコにめちゃくちゃ中出しされて……ボクもイッちゃったよ……。んふ\nっ、やっぱりすごいねぇ、キミ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「さてと、それじゃあ今度はなにをプレゼントしてあげよっかなー……って、\nなに、これで終わりじゃないのかって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なにいってるの。クリスマスの夜はまだまだこれからなんだよ？　パイズリ\nくらいで終わりなわけないじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミには、サンタさんのボクが用意したプレゼントをぜーんぶ受け取っても\nらうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それまで、キミのことは寝かせないから、覚悟してよね？　んふふっ、地球\nのクリスマスって最高だねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、こら、逃がさないよ！　逃げるなんて悪い子！　サンタさんから逃げ\nるなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！？　ちょ、ちょっとチンチン抜け……んっ、んぶっ！　ぷはぁっ\n、ああっ、あああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっぱいだけじゃなくて、顔にまでぇっ！　んぁっ、キミのドロドロザーメ\nンが、いっぱい……かかって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、熱いのっ、顔にぃ……っ！　んっ、イクッ、ぶっかけられ\nてイク……ッ！　あっ、あああぁぁぁああぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「濃厚チンポ汁ぅ……♪　んっ、すっごい、量……。んふぅ……鼻の中まで、\nザーメン臭に犯されちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「サンタさんの顔にザーメンひっかけてドロドロにするなんて、なんて悪いチ\nンチンなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……あ、でもボクはすっごくコーフンしたわけだし。いいチンチン？　ま、\nそんなことはもうどーでもいっかー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなことより、まだまだイけるよね？　キミのチンチンは勃ちっぱなしだ\nしっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「地球のクリスマスって、ぼっちにサンタがエロエロなことをするのがジョー\nシキなんでしょー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だったら、このあとももーっとボクが君のチンチンを気持ちよくしてあげち\nゃうねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふっ、ボクのゴホウシ、今夜はたーっぷり味わっちゃってよねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0303410" ]},
