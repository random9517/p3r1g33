		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「原因はわかっているが、考えるなと思えば思うほど考えて……余計に胸が苦\nし……くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903102" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく……一刻もはやく見つけて……。見つけて、どうする……？　それ\nはもちろん……ふふ……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903103" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……会いたくてたまらない……！　どこだ……どこにいる……！　そう\nだ、あの部屋なら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903104" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……やっぱり思ったとおりだ。ここにいると思っていたぞ。し\nっかり手をつなぎ、はなさないからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000129_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ……。こんなところで裸でいるなんて、ほかの幹部にオシオキしていた\nのか？　それともオシオキされていたのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、そんなことはどうでもいい。あなたに会いたくて仕方がなかったんだ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この姿になったせいか、あなたと離れていると、時間が経つにつれ頭の中が\nあなたのことでいっぱいになってしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そして、あなたとこうしたくて、たまらなくなってしまうんだ……。ふぅ…\n…少し、落ち着いたぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なあ……このまま、ずっと手をつないだままでいてもいいだろうか……。あ\nあ……あなたのオチンポを感じていたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……だんだんとオチンポが硬くなって……。私の谷間から、先端が顔を覗\nかせているじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。なんて大きなオチンポ……。私の胸に挟まれて、こんな\nに元気になってしまったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……。はからずもこの体勢、あなたにパイズリをしているようにな\nってしまっているのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……。しかしちょうどいいではないか。あなたに会ったら、こうやって\n奉仕したいと思っていたところだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポを、私の胸で挟んで、たっぷり気持ちよくしてやりたいと\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そんな思いで頭の中をいっぱいにしながら、さっきまであなたのことを探し\n回っていたんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こうやって、手をつないだままで……。ん？　もっと脇を締めて、胸を寄せ\nればいいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……しょ……。こうだろうか……？　胸の圧が高まって気持ちいい？　そ\nれはよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私も……あなたのオチンポを、谷間にはっきりと感じられるようになって…\n…。ん……んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま……動けばいいだろうか……。んはぁ、はぁ……。胸を寄せながら\n、身体をゆすって……オチンポを刺激して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。どうだ……？　私は……とても感じてしまっている……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱいに……あなたのオチンポがこすれて……。んふぅ……熱さと硬さで\n……胸が溶けてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……こうやってオチンポに触れているだけで……あなたへの愛しさが、\nどんどん膨らんでいく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと、オチンポが気持ちよくなるように、胸をぎゅっと……。ん……ふぅ\n……あなたも私の胸を、感じてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、オマンコのように、オチンポをぎゅっとするから……。ンッ、そうや\nって、腰を……ああ、んぁっ、はぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ガチガチの勃起オチンポがこすりつけられる……！　んぅ……はぁ……熱く\nて……硬いぃ……。んぁ、くふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この感触……たまらないんだ……。はぁ、はぁ……オチンポ……んふぅ……\n私も身体を動かして、しごくから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「たくましいオチンポを……んっ、ああ……あはぁ……っ！　すごく、感じて\n……どんどん、身体が昂って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……パンパンに膨らんで……ビクビクと暴れて……。んっ、ああ\n、イキそうになっている……んだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、イッていいぞ。たくさん射精してくれ。私は、あなたに射精して欲し\nいから……この胸で、いっぱいイッて欲しいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ああ……っ！　お、オチンポが跳ねて、んくっ、胸にいっ\nぱい、精液……が……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すごい、たくさん……。ドロドロの精液が、私の胸の谷間に、池ができてし\nまいそうなほどたくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……すごいにおいだ……。あなたの精液のにおい……。ん……ふぅ……\nたまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「胸にのったプルプルの精液ゼリーも……。ああ……肌にずっしりと重さを感\nじるほどだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……。こんなに射精したのに、まだまだオチンポは元気なようだな？　\nその……もっとしてもいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私は、もっともっと、あなたとこうしたくてたまらないんだ。あなたを探し\nて、ずっと歩き回っていたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やっと見つけたあなたを、はなしたくない……。身体の昂りが鎮まるまで、\nどうかこのままでいて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「い……いいのか……？　ありがとう、感謝する。クリスタルのせいでやっか\nいな身体になってしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが……。こうやってあなたと触れ合っていられる時間が増えたのは、私に\nとっては嬉しいことだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……。こうやって手をつないで、もっと私のおっぱいを味わってくれ。\n精液まみれで、ますますいやらしくなったこのおっぱいをな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……ああ……。また、おっぱいをつかって、オチンポを刺激していく……\nんふぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さっきの射精で、ヌルヌルになって……。んっ、ふぅ……さっきとは、また\n違った感触だな……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「精液のおかげで、胸が、あなたのオチンポにより密着しているように感じる\n……。んっ、ふぅ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まだまだ硬い勃起オチンポが……脈打つのを、感じて……。ンッ、私も……\nどんどん興奮して、しまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おっぱいが……精液のいやらしいにおいでいっぱいになっている……。はぁ\n……はぁ……あなたのにおい……たまらないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それにこうやって手をつないでいるせいか、とても安心する……。あなたの\nことをとても近くに感じて……嬉しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……ああ……。ヌルヌルおっぱい……オチンポにこすれるぅ……。ふぅ…\n…はぁ、ふぅ……気持ち……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポいっぱい感じる……。ンッ、もっと胸を寄せて……あなたにも、私\nのおっぱいを感じてもらわないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁ、はぁ……どうだ……？　精液をローション代わりに、パイズリ……\nんっ、気持ちよくなってくれている、だろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……先っぽから、先ほど放った精液の残りだろうか……？　胸でぎゅっ\nと締めつけているから、搾りだされたようだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……ああ……このまま、もっと……。オチンポを……刺激し続けて……ん\n……んふぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたにまた……いっぱい、射精してもらう……。たくさん精液を、だして\nもらうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたに……いっぱい気持ちよくなってほしいんだ……。わたしの……この\n胸で……たくさん射精して欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さっきみたいに……真っ白で、ドロドロで……いやらしいにおいの精液で…\n…私の胸を、汚して欲しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……そうだ……。我慢できなくなったら、いつでもいい……ど\nこでもいいからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903215" ]},
