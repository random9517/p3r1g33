		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。まずいな……。胸の高鳴りがとまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2903101" ]},
		{"command":[ "SETCHARA", "0", "char_00000129_01", "5", "CENTER", "0" ]},
