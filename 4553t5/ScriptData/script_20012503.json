{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0092" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおいおいおい、なんなんだよあれ！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「知らないわよ！！　今まであんなのはいなかったもの！！　結界にも反応は\nなかったし！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990001" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「今は女魔導士殿の術で逃げ込んだ二階の扉を防御しておりますが……それで\nもじわじわ浸水してきておりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ラー・サイアム、本当に心当たりないのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「……ないわね。私はここを予約したのは完全に偶然だし、来てからは滞在の\n準備と探索しかしてなかったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990002" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにかこう、探索中にサメの神殿を破壊したとか、そういうのもないのか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ないわよ！！　ていうかなによそれ、そんなの存在するの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990003" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この世界は俺たちの計り知れない存在がいくつでもあるからな。喋る犬とか\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「失敬な。この私の光る知性を化け物扱いとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、ラー・サイアム、今はあのサメの相手が先決だ。お前も力を貸せ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「え、ええ。分かったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990004" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とはいえ、対抗するにも相手の意図がわからないとどうしようもないぞ。な\nんであいつは襲ってきてるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「怪人だから本能のままに襲っている。あるいはご主人に個人的な怨みを抱い\nている。とかですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「サメに襲われるいわれはないぞ……ていうかお前、やけに落ち着いてるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「夏のコテージ、男と水着の女、そこに襲来した怪物……となればこの手の作\n品ではマスコット的な存在は概ね生き残れますので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、こいつ自分が無事だって確信してやがる！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ちなみに『イケメンは死なない』という法則もあるようですが、まあ、ご主\n人では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前なあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そ、その場合私はどうなるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990005" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「パニックホラーにおいてヒロインは大体の作品において生き残ります……が\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「が？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990006" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「生き残って無事に帰った後にまた襲われたり、ラストで無意味に食い殺され\nたりもしますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それに女魔導士の今の格好はお色気要員ですから、そういうキャラはむしろ\n即座に退場したりします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ダメじゃない！！　ていうか圧力が強くなってる。このままじゃ防護結界が\n保たないわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990007" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おいジュンジロー、とりあえず扉の側まで行って様子を窺ってきてくれ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、まさか私を生贄に差し出すとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前の言葉を借りれば、お前は無事に生き延びるんだろ？　だったら大丈夫\nだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにも扉開けて突っ込めって言ってるわけじゃない。近くまで行ってその自\n慢の耳と鼻でなにか探ってくれ。このままじゃ埒が明かない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……仕方ありますまい。ご主人、一つ借りですからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……どうだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエレ……ル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021990001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……カエレ？　カエル？　先程の言葉を繰り返しておりますな。それと扉の\n向こうで水量が増しているようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カエレ……？　さっき言ってたのも蛙じゃなくて帰るって言葉か？　だとし\nたらここから出ていけってことか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あれがここの所有者ってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990008" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「所有者というか、土地かもしれない。元はサメの墓場だったとか、なにか邪\n悪なものが封印されていたとか、逆にサメの聖地として祀られていたとか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「観光のために開発していたら、知らずに土地を荒らしていたというパターン\nですな。あるあるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……仮にあれをここに根付いているサメのなにかだとしよう。なら、離れれ\nば追ってこないんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「なるほど、守護している土地からは離れてこないってことね……問題は部屋\nを覆ってる私の結界だけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990009" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「私の結界は術式として中から外に出るのも防いでるわ。出るには解除しなき\nゃいけないし、扉の前にはあれがいる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……ここは二階だが、そう高くはない。下も草で柔らかい。まず窓\n際まで行って、ラー・サイアムが結界を解除する」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それなら飛び降りて逃げられるわね。方向は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここから見えている森のほうがいいだろう。海に逃げるとヤバそうだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そうね。じゃあ……皆窓に寄って。ベッドを足場にしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990012" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、行けるぞ。ジュンジロー、お前も行けるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お任せを。私の健脚でご主人たちを遥か彼方へと置き去りにしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前こそ主人見捨ててんじゃねえよ……ともあれ、いくぞ。タイミング合わ\nせろよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「いいわ……いち、にの、さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990013" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ、はっ、はっ、どうだ、ここまでくれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「姿も、気配も感じないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990014" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「助かった……のですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエレ……ル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021990002" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわああああああああああ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「普通に着いてきたあああっ！！　ていうかいつのまに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990015" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかも屋外に出た分、水を遮るものがありません。というか水かさが増えて\n私が溺れブクブクブク」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおい、しっかりしろ、せめて泳ぐ努力ぐらいしろ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、ご主人による抱っこ。柄ではありませんがなかなかよいものですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021990016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今はそんなセンチメンタルなこと言ってる状況じゃねえよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちょっ、この相手、私の魔導にも抵抗してきてる！！　効き目が弱い！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990016" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クソ……こうなったら人のいる方向だ！！　砂浜に逃げるぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「え……それは、いいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この中で一番火力があるお前の魔導が通用しないんじゃ、他の方法で対抗す\nるしかないだろ。砂浜に行けば誰かしらいるはずだ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「カエル……カエル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010021990003" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「行くぞ！！　ジュンジローは俺が担いでいってやる！！　これでさっきの貸\nしはチャラだ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰か……誰かいないか！？　サメに強くて、この窮地を救ってくれるような\n頼もしい奴は！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そんな都合のいい人、それこそこんな都合よく見つかるはずは……って水と\n一緒に移動してきてる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_010021990018" ]},
		{"command":[ "SETCHARA", "0", "char_00015903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なるほど、水と一緒に泳いでくるから音もなく一瞬で移動してきているわけ\nですな」", "NORMAL" ]},
