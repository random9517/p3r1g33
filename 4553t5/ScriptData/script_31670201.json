{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿……その、こちらへ……ここなら、誰かが来る心配もないと思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うん、たまにだが朝の参拝客も訪れるからな。ここなら境内からも死角だし\n、客が間違って入って来ることは万に一つもない筈だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、主殿のたっての望みであるし……私も、この姿でのご奉仕という\nことには、その……多少なりだが興味はあった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なので……今日は、その……お清めという形で……主殿のオチンポを手で\n扱かせていただく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「一応、予め手水舎の方で手は綺麗にしてきた。多少なりともご利益があると\nいいのだが……ふふっ、流石に水だけでは無理があるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00016702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「さあ、遠慮することはない。こちらへ……あっ……もうオチンポ……こんな\nに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016702_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「き、期待してくれていたということでいいのかな……うぅ……改まると、\n中々……は、恥ずかしいものがあるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いや、だが自分で決めたことだ。しかと、オチンポを……扱かせていただく\n……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……あぁ、すごいな……手の中でどんどん大きくなっていく…\n…あっという間に、こんなに勃起して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「皮のこの辺りで……問題はないだろうか？　んっ、ふ……あぁ……やはり、\n生々しいな……このオチンポが動く所は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「赤黒くて……先が割れて……ひくひく震えているこの感じ……自然に心臓が\n高鳴ってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ん……指の感触はどうだろうか……？　力加減は間違っていないと思うが…\n…ちゃんと気持ちいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ、清められている感覚がある？　そうだな、もしかしたら少し位は神様\nの力を感じてもいいかも知れないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、していることはオチンポをシコシコと扱く……手コキだ……こんな姿\nを神様が見ていると思うと……はぁ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ……そ、そうだな……少なからず興奮している……んんぅっ、あ……\n駄目だ……乳首が……んっ、固くなってしまっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「う、うむ、下には何も着けていない……その、主殿もその方が好きなのだろ\nう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいに決まっている！　このように、はしたなく乳首を浮き上が\nらせるなど……装束から透けて丸見えになってしまってるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが……んっ、余計なものは着けない方がいいと……し、下の方……？　\nそれは答えを控えさせていただくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私のことはいいから、とにかく……オチンポに集中してくれ。もうちょっと\n速く動かしていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……くちゅくちゅ鳴り始めた……ちゃんと気持ちよく\nなってくれているようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もっと強く握って欲しいのか？　分かった……んっ、これ位でどうだろうか\n……あっ、またピクって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「気持ちよくなっているんだな……分かるぞ……主殿が喜んでくれているのが\n……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……こんなのを見せられたら……私も身体が疼いてしまう……んっ、\nふっ……あっ、はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうだ……乳首を触っている……んっ、主殿のオチンポを見ているだけ\nで……こんなに興奮してしまっているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……布越しなのがもどかしい……んっ、ずらして直接……？　\nい、いや、それは駄目だ……今日はお清めなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だから、外からなぞるのは仕方ないが……直接は駄目なんだ……わ、笑わな\nいでくれっ……私は真剣なんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それに、こうして……乳首を刺激していると……主殿と一緒に高まっていく\n……そんな気持ちになれるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、右手で指を滑らせてシコシコして……左手はコリコリの先端\nをさする……はぁ、んっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「時々……ギュッと握り締めて、オチンポが跳ねるところを見ると……たまら\nなく愛おしい……指から幸せが伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もっともっと感じて欲しい……あぁ……今日は手が中心だから……ちょ、\nちょっとだけ……れろ……んっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「し、舌の刺激はあくまでもアクセントだ。フェラチオ奉仕は……また、別の\n機会に……今は手の動きを意識して欲しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はぁっ、あぁんっ……んちゅっ、い、今のは、ちょっと先端に\nキスしただけだ……本番は手で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んちゅ……あぁ……何でもいいっ、舌もっ、手も、どちらもいっぱい感じて\n欲しいっ……んっ、はっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……先走りが溢れて来ているっ……もうすぐ出るんだなっ？　なら……\nこの舌の上に出して欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿の朝一番の新鮮な精液を……直接味わってみたいんだっ……ほらっ、\nここにっ……あぁぁぁぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁっ！　出てるっ！　朝一濃厚ザーメンッ……ビュクビュク来てるぅっ…\n…んちゅぷっ、あっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ、このドロッとした感触……堪らない……んふぅ、口の中に広がって\nいくぅ……んっ、あぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……いっぱい出てるな……んんっ、手だけでこんなに出してくれるなん\nて……やはり主殿は絶倫だ……んちゅぷ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「え……舌も使った？　まぁ、それは……ちょっとだけだからな。い、いい\nじゃないか、別に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……んふ……少しだけ余韻に浸らせてもらおうかな……私だけが味わ\nえる、ちょっとした贅沢な時間だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……んふ……さて……主殿が一発で終わる男でないことは、もう重々\n承知の上だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それに、欲望の権化のようなこのオチンポ……到底清めきれたとは言い難い\n……ほら、まだビンビンに勃起したままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「出したばかりの先端はかなり敏感になっているからな……こうしてさすって\nやると、ふふっ……案の定腰がビクビクしてる……可愛いぞ、主殿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「れろ……ぺろっ……んっ、先端に精液の味が残っている……もっと出したい\nって言ってるみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かってる……もっと丁寧に繊細に……そして大胆に……はぁ……んっ、\n何度も竿を扱いていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ……な、何だか、また大きくなったような気がする……主殿のオチン\nポ……ど、どうして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「改めて……私の姿を見て興奮した……？　うぅっ、そ、それは……嬉しいよ\nうな気もするけど……すごく、は、恥ずかしいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「この巫女装束が……大胆過ぎるのは分かっている……あぁ……けど、こうし\nて視線を意識してしまうと……んっ、疼きが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……また、乳首コリコリになってしまう……はぁんっ、指が勝手に動い\nてしまう……先端、くにくに転がしてしまうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぅっ……我慢できない……また、先端も舐めてしまう……れろ、ちょっ\nとだけ……ちょっとだけだからぁ……ぴちゃ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、主殿のオチンポをお清めしながら……私……発情しているっ、いや\nらしくなってるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、袴の下のオマンコが疼いて……んっ、目の前のオチンポに釘付けに\nなって……あぁっ、おっぱいをこんなに揉みしだいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「全部……はしたない所を全部見られながら主殿にご奉仕しているっ……血管\nの浮き上がったオチンポをシコシコしているっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、また……汁が滲んで来た……ちゅぱっ、んちゅ……さっき\nより、もっと出そう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かった……気持ちよく解放してもらう為に……この玉袋も、いっぱいモミ\nモミするからぁ……んっ、あっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「身体の力が抜けていく……？　んふっ、主殿の弱点だからな……大丈夫、\n優しくするから……安心して身を任せて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そう……あぁ、オチンポが震えている……切なくなってるのが分かるぞ……\nもう出したくて堪らないんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「溜まってるものは全部吐き出してしまおう……主殿の欲望の塊……ドロドロ\nのオチンポザーメン……あぁ……掛けて欲しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おっぱいでもいい……顔でもいい……好きな所に出していいからっ……んっ\n、私の手コキで……指オナホールで……射精してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、いやらしいオスミルクをっ……全部……全部ぶち撒けて欲しいっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぷっ！　あっ……出たっ……顔にっ……精液っ、いっぱい出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、たっぷりの顔面シャワー……あぁ……浴びせて……ドロドロ\nの濃いのをもっと顔に染み込ませてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゅぷっ、あぁ……濃い……んっ、ちょっと舐めただけなのに……\n喉に絡みついて残る感じが……んくっ、堪らない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、また出た……オチンポから……ドロドロの精液がまた降っ\nて来る……んはぁぁ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……舐めさせてぇ……れろ、ぺろ……んっ、はぁ……んっ、駄目だ……\n精液舐めてるだけで……私も……イ、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぁ……はぁ……あっ、ふっ……イカされてしまった……んっ、主殿の\n匂いに満たされて、身体が幸せになってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これで最後の分？　あぁ、分かった……最後もしっかり顔に浴びせてくれ…\n…直接オチンポを押し付けて……頬に出してぇ……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、終わったようだな。待っててくれ、今、綺麗にするから……\nぴちゃ……れろ……ちゅぱっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「出来たぞ……朝からお疲れ様だったな、主殿。こんなに出してくれてありが\nとう。ご奉仕の甲斐があったというものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな……主殿がお望みとあらば……また、いつでも清めさせてくれ\n……もっと技を磨いておくから……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ！　あぁっ……来たっ……ぶぴゅってっ……熱い精液っ……おっ\nぱいに出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……神聖な巫女装束に……あぁっ、主殿の濃いのが染み込んでいって\nしまう……あぁ……私の方が……清められてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁん……もっと掛けてぇ……コリコリの勃起乳首にも直接精液浴びせて…\n…んんっ、あぁ、ヌルヌルの乳首弄るの気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あふっ……！　あぁっ、まだ出てる……凄い……元気なミルクがビュクビュ\nク出て……止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あっ、おっぱいが熱い……あふっ、イクっ……んんっ、新鮮ザー\nメン浴びて……おっぱいイッてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……後もう少しだけ出るのか？　分かった……ちゃんと扱いて\n搾り出すから……んふっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……こぼれそうなのは……ちゃんと舐めて受け止めないと……ぴちゃ、\nんちゅっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これでいい。最後に少しだけ後始末をして……ぴちゃ……んちゅ……あぁ、\nこれで朝のお清めはおしまいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00016702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それにしても、相変わらずの精液量だ……肌にねっとりと絡むこの感じ……\n私の方がお清めされた気分だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな……主殿がお望みとあらば……また、いつでも清めさせてくれ\n……もっと技を磨いておくから……な」", "NORMAL" ]},
