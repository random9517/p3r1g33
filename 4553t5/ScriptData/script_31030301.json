{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ふ～～……ねえ、隊長さん。ボク、泳ぐの飽きてきちゃった。もっと、\nこう……別の楽しいことしたいな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「へ？　セックスのことかって？　も～～、隊長さんったら、すーぐそういう\nこと言うんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「楽しかったら、エッチなことじゃなくていいんだけどね。けど……まあ、エ\nッチなことでもオッケーだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふう……水泳して疲れてるから、出来たらダラダラゴロゴロするのも悪くな\nいんだけどね……ふわあぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふえ？　おやつタイム？　大歓迎だよ。何食べさせてくれるの？　ええ？　\nソフトクリーム！　わぁあい、嬉しいな～──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「れろ、れろれろ、ぴちゃ……はぁ、ま、どーせこんなことだろうと思ってた\nけどね～……にゅる、れるん、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え？　別に嫌じゃないよ。食べ物を無駄にしたら、序お姉ちゃんに怒られち\nゃうしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ってかさぁ、食べ物で遊んじゃ駄目だよ。まあ、今回はしょうがないけどさ\n……れろ、れるれる、んちゅ、れろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んぁむ、れろれろ、あふぅ……けど、美味しいなぁ……ぴちゃ、ねる、れろ\nれろ、にゅるん……これ、大好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん？　おちんちんのことじゃないよ？　ソフトクリームのことだからね。っ\nと、グズグズしてると溶けちゃう……本気でいただきますしなきゃ──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「れる、れろれろ、ぬちゅ、ねるん……はぁ、冷たくて美味しい……れるれる\n、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あはぁ、舌が止まらないよぉ……れろ、ねろん、ぴちゃ、ぬるん……はぁ、\nおっぱいが邪魔で、ちょっと食べづらいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「くんくん……はぁ、バニラとミルクの香り……それと、おちんちんの匂いと\n、海の匂いが入り混じって……あふぅ、ちょっと気持ち悪いかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ、ちゅぬ、れるん……うぅん、やっぱり食べづらいなぁ……お\n皿に移してスプーンで食べちゃ駄目？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「えー、駄目ぇ？　う～～ん、隊長さんのイジワルぅ……れろ、れろん、ねろ\nねろ……あぁん、グズグズしてたら、溶けちゃうのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んぁむ、んちゅ、れるれる、ぬるる、にりゅん……はぁ、ふぅ……あぁん、\nおっぱいの中から、おちんちんが逃げ出しちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふえ？　もっとおっぱいを上手に使って……って、今それどころじゃないん\nだけど……れろ、れろれる、にゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても、暑い中で食べるソフトクリームって、最高……ねる\n、れろ、にゅるる、ちゅるん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「だんだんこうやって食べるのにも、慣れてきちゃった……ん、んん、れる、\nねろ、ぴちゃぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「だんだんおちんちんの匂いが強くなってきたよ……それに、微かなしょっぱ\nさが……はぁ、ふぅ……やだぁ、なんだか興奮してきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あぁん、今おちんちんがビクッてした……ねえ、隊長、気持ちいいの？　れ\nろん、ぬるる、ぴちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふ～ん、冷たすぎて、感覚がなくなっちゃってるんだ。で、生暖かい舌にビ\nックリした……と。へぇ、そうなんだね～……ねろれろ、ぬるん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん？　もっと温めて、感覚を取り戻して欲しい……？　もう、しょうがない\nなぁ……ぴちゃん、ぬるる、れる、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ぺろぺろ、れろ、ねろろ、にゅるぅ……んん、ふぅ、どう？　あったかくな\nってきたぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「もっと根本からしっかりと……？　ううぅん、難しいこと言うんだから……\nよいしょっと、ほらぁ、おっぱいでいっぱい抱きしめてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねるん、れろれろ……はぁ、あふぅ……どう？　ボクのおっぱい……ん、は\nぁ……ぴちゃ、れるん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「水着の感触が新鮮……？　柔らかいのに、ショリショリしてて、独特の触れ\n心地……？　ふ～ん、気にいってくれてるみたいでよかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「水着の内側はどうなっているのか、だって？　やだなぁ、サポーターがつい\nてるに決まってるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「でも、乳首が勃起したら、見えちゃうかも……え？　今？　もちろん、勃起\nしてるよ……どう？　見える？　れるん、ぴちゃ、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あぁん、おっぱいガン見してる……そんなに見られたら、興奮、しちゃうよ\nぉ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねる、れろれろ、ぴちゃぁ……はぁ、あふぅ……ソフトクリーム、なくなっ\nてきちゃったぁ……寂しいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ……もうすぐ、イキそうなんでしょう？　えへへ……やっぱ\nり？　だと思った……ぴちゃ、ぬるる、れろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「だってぇ、隊長さんの顔、すごくエッチになってるんだもん……それに、お\nちんちんもピクピク可愛く震えてるし……れるれる、ねろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んはぁ、れる、ねろん……はぁ、すごぉい……おちんちん、爆発しちゃいそ\nうだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うん、いいよぉ……出してぇ……ボク、全部飲んであげるから……んぁむ、\nむぐ、ぴちゃ、ねろ、れろれろんちゅぅぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んぶぅっ！　んぐっ、んはぁ……はぁ……んんん～～……ゴクン……はぁ、\nはぁ……酷い味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ、まだ出てる……んん、あむぅ、むぐ……んちゅ、ちゅるる……あ\nへぇ……バニラの香りと入り混じって……うう、気持ち悪い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んん～～……ゴクン……はぁ、はぁ……嫌な味なのに、ムラムラしちゃうよ\nぉ……はぁ、はへぇえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「やだぁ、まだ出てる……れろ、れるれる、んちゅ、ちゅちゅちゅぅ……ゴク\nン……はぁ、あふぅ……ごちそう、さまぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「むぐぅ、んん……あはぁ、まだ口の中に精液残ってるよぉ……んん、んぐ、\nゴクン……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、んふふ……精液の匂いが顔の周りに漂ってる……潮風が、精\n液風になってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んちゅ、れろ、ねるん……え？　まだ続けるのか、だって？　まだこんなに\nカチカチなんだもん……当然だよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ええっと、古人いわく、勃ってるものは──あー、えー……まあともかく、\nカチカチおちんちん、ボク結構好きだよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んちゅ、ねろん、れるる、ぴちゃぁ……精液、あんまり好きじゃないけど…\n…でも、あの匂いとか感触とか、興奮しちゃうんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……精液が溶けたソフトクリームと混じり合って……んん、ぴちゃん、\nれるん……ねっとりとおちんちんに絡みついてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「れろれろ、にちゃぁ……あはぁ、まだ甘い……精液の味も、いっぱい残って\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「谷間がニチャニチャする……水着の生地に染み込んで、変な匂いがする……\nはぁ、あふぅ……でも、ムラムラしちゃうよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁぁん……隊長さん、腰を動かしてる……おっぱいの中で、おちんちんが\n、ぐちゃぐちゃ音立ててる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「その必死になってる感じ……すごく可愛い……ねるん、ぴちゃ、れろれろ…\n…ふぅ、興奮しちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、れろ、ねるねる……んふぅ……じゃ、ボクがもっと気持ちよくして\nあげるね……んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んしょっと、はぁ……あふぅ……よっこいしょっと……ねえ、どうかな？　\nボクのおっぱい、気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んはぁむ、れろねろ、にゅるん、ぴちゃぁ……ねえ、おちんちんの先っちょ\nはどう？　この傘が広がったところの、溝になった部分は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねる、れろ、にゅるぬるる……はぁ、ふぅ、ねえ、隊長さん……透明なお汁\nが溢れてるよぉ……？　ほらほらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねろ、ぬるる……あぁん、ごめんなさい、痛かった？　ふぅん、大丈夫なん\nだ……じゃあ、もっと舌先で、先っちょの穴をほじってあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねるれろろ、にちゃ、ぬちゅぅ……はぁ、んふぅ……隊長さんの身体、汗で\nビチャビチャになってる……もちろん、ボクも汗だくだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「水着の下なんて、滝のように汗をかいてるよ……え？　アソコ？　うふふ、\nドロドロだよ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねろん、にゅるる、ぴちゃん……はぁ、ムラムラが止まらないよぉ……にゅ\nるる、ぴちゃん……はぁ、おちんちん、可愛い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はむ、ぬちゅ、れろれろ、にゅるる……あはぁ、まだ微かに甘いの残ってる\n……精液の味と匂いもこびり付いて……はぁ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あ、あ、あはぁぁ……おちんちん、また震えてる……イキそうになってるよ\nぉ……ねる、れろ、にゅるる、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んふふ、いいよ……隊長……お口？　ボクの顔……？　好きなところに出し\nていいからね……んちゅ、ちゅちゅれろ、ぬるずちゅぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んんんんっ！？　んぐっ、んはぁぁ……はぁ、あぁぁあん……いっぱい出て\nるぅ……んあむ、んちゅ、ねろれろ、ちゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んはぁ、はぁ……んんんぅ、ゴクン……はぁ、あふぅ……二回目なのに、こ\nんなに……ああ、濃いぃ……喉に引っかかるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ちゅる、ずるる、んんんぅ……ゴクン……んはぁ、はうぅ……精液を飲むと\n、喉がすごく乾いちゃうんだよね……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「くんくん……あふぅ、微かに残った甘い香り……はぁ、ソフトクリームが恋\nしいなぁ……うう、精液、変な味過ぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふぅ……もう射精はおしまいみたいだね……れろ、ぬる、ぴちゃん……ちゅ\nるる、ずるずぅ……ゴクン……あふく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はー……美味しくなかったぁ……うう、まだ口の中にこびり付いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あふう……息が精液臭い……。肺の中で妊娠しちゃいそうだよぉ……はぁ、\nんふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長……ボク、すっごくムラムラしてるんだよね……でも、ソフトク\nリームのお代わり、ある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「それと、かき氷が食べたい。あと、ボクの大好きなフルーツタルト……はぁ\n、お腹空いてきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「んー……なんだかお姉ちゃんの顔が見たくなってきちゃった……やっぱり今\n日はまっすぐ帰ろうっと。じゃあ、隊長さん、また遊んでねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひやぁぁぁん……ああ、はぁ……あぁぁああん……顔が、ドロドロでいっぱ\nいになってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あへぇぇ……すごぉい……これ、二度目の射精なのに……あうぅ、こんなに\nいっぱい……はぁ、はぁ……あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ん……はぁ、あぁぁあん……目の前が真っ白になっちゃったぁ……すごぉい\n……精液で目が溶けちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303403" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……んん、ずずっ、ずるる……んへぇ……息をすると、鼻の穴\nの中に入ってくる……精子が鼻の中を泳いでるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！？　きゃうぅ……まだ出てる……おちんちんから、白いの溢れて\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あ、ああ……だんだん勢いが弱くなって…………ああぁん、射精、終わっち\nゃったぁ……つまんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふう、少し苦しかったけど……でも、胸がドキドキしっぱなしだよぉ……は\nぁ、波の音が遠い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00010303_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ふぅ……隊長さん、ボク……ムラムラしてる……もっとエッチなことしたい\nな……でも、その前に……ソフトクリーム、もうないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「口の中が変な味だから、口直ししたいんだよね。ソフトクリームがないなら\n、ファミレスでパフェでもいいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「大好物のフルーツタルトも食べたいなぁ……ああ、お腹空いてきちゃった。\nもう我慢できない……隊長さん、ボクをファミレスに連れてって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}