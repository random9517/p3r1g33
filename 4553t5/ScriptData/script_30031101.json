{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、来た来た。いつまで私を待たせるんだい。せっかくご褒美をあげよう\nと思っているのにさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103101" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……フフッ、察しはついているんだろ？　最近、頑張っているようだからね\n……。たまにはあたしが優しくしてやろうってことさ。そこに横になりな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ？　運動場に尻をつくと汚れるぅ？　そんなこと、すぐに気にならなく\nなるよ。……ご覧。あんたがずっと眺めまわしていた下着さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「これが好きなんだろ？　良くないねぇ……神聖なる乱杰李威仏斗暴羅亜の衣\n装に興奮するなんてさ。これは戦うためのアーマーなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000311_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたはいやらしーい目つきでコレを見てた……。バレてないと思ったかい\n？　全部お見通しだよ。どうだい？　脱ぎたてのアーマーは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「メスの匂いがするだろう？　それに……あたたたかくって、じんわり湿って\nて……。変態にはたまらない仕上がりになってるはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「今日はこれで、あんたの精という精をあたしが搾り取ってあげる。……あは\nっ、言葉だけで感じたのかい？　チ○ポがビクビク脈打ったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなのがイイなんて、どうしようもないド変態だね。でも、……こんなも\nんじゃ終わらせないよ。泣き声あげるまで苛めぬくんだからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……ほら。ほら、ホラ……！　くしゃくしゃにした布を巻きつけて、絡み付\nけながら……あたし自身が手で刺激してやるって言ってるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ゾクゾクするだろ？　いつ、誰が来るかわからない運動場で……健康的なお\n日サマ浴びながら、ド変態のあんたはあたしのショーツに勃起してる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このバキバキの、臭くて汚いチ○ポを……さっきまであたしが履いてた生シ\nョーツに包まれた気分はどうだい？　きっと最高なんだろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……クシュ、クシュってパンツ握りながら……アハッ♪　あっつい極太チ○\nポをシゴいていくよ……。いち、にぃ……いち、にぃ……アハハハッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「すぐに出したりするんじゃないよ！　限界まで我慢に我慢を重ねて、苦しみ\n悶えながら精子を溜めるんだ。チ○ポが破裂しそうなくらいだよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このキ○タマに、肉棒に溜められるだけ精液溜めてさぁ……凝縮させて、あ\nたしがいいって言うまで射精しないでいられたら褒めてあげるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そーら……。いち、にぃ……いち、にぃ……♪　ふふっ……しょっぱなから\nこんなに脚をガクガクさせてもつのかねぇ？　ド変態チ○ポがさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もっともっとキツ～くシゴいてほしいっておねだりするみたいに腰が浮いて\nるよ。でも、ダメだ。まだジワジワと追い詰める時間だしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しっかりショーツの感触を楽しみな。アーマーにはさぁ、特別な素材を使っ\nているからね。肌触りも極上だろう？　あたしの股間にさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぴーったり張りついて、大事なところを今の今まで守っていてくれた素晴ら\nしい逸品さ。それが、あんたのチ○ポにご奉仕してるってわけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、あたしのながーい指も気持ちいいだろ……？　しなやかで、ヒンヤ\nリしている細い指……これを味わえる男なんて他にいないよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「光栄だろう……？　フフ……今だけは、たっぷり感じていいんだからねぇ…\n…。特別サービスをもらえる栄誉にせいぜい酔いしれな……それ、それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなの、今までしたことなかったけど……やってみると、意外に面白いか\nもしれないね。いちいち反応が楽しいし……観察しがいがあるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしのすることで、チ○ポのどこがよくなってるのか……じーっくり、手\nと目で視姦出来るし……。ハハハッ、参考になるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたのチ○ポの弱点をさ、熟知しておけばいずれ必ず役に立つだろ……？\n　ん……、あたしはあたし上位でするセックスが好きなんだ。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁ、そこを突破してくるような荒々しい男も嫌いじゃないけどさ……。っ\nて、アハ……！　ヤバすぎるだろう、このチ○ポ！　硬すぎだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「爪を立てたら弾け飛びそうなくらい膨らんでるよ！　っフフフッ……♪　こ\nんなのがいいのかい、こんなので感じるんだね……最低じゃないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いち、にぃ……いち、にぃ……♪　ホラホラもっと頑張りな♪　力を込めて\n耐えるんだよ♪　なかなかこんな素敵なご奉仕してもらえないよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いち、にぃ、いち、にぃ、いち、にぃ……アハハハ♪　布が絡んで、不規則\nな刺激を与えてくるのも面白いだろう？　普通じゃありえない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しっかし……おパンツ手コキでこんなに勃起しちゃうなんてねぇ？　ただの\n手だよ？　オマ○コでもあるまいし……。んん？　なんだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「聞こえないよ……。チ○ポの先走り汁がニチャニチャうるさくてさ。……え\n？　精液が出そう？　そのまま続けて？　アハッ！　上等だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おや……おやおやおやぁあ？　既に射精したくてたまらないってカンジだね\nぇ？　あたしの言いつけをやぶるのかい？　我慢しろって言っただろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ○ポが弾ける？　精液が爆発するぅ？　……知らないよ。あんたがどうな\nったって、あたしはこのまま手コキを続ける……苦しいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あー♪　あー、あー、あ～……♪　そうかいそうかい、尿道口から今にも精\n子が飛び出しそうかい。漏れてるだけじゃ気が狂いそうだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……それなら仕方ないね。許可をしてやってもいいよ。……そらっ、射精し\nな！　ショーツの中に、アヘ顔晒しながら精子ぶちまけな！　そらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アハァッ♪　出た出た……！　情けない声をあげて、情けない顔してさぁ！\n　みっともない精液がドッピュンドッピュン飛び出しているよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アハッ……アハハハハッ！　どういうことだい！　軽かったショーツの中に\nビュッ、ビュッ、びゅっビュッて……生地を貫通しそうな勢いで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「精液で重たくなってきてるじゃないか……！　へーえ……こんなに無様に射\n精して……。あんたって本当に見ごたえがあって面白いね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ドピュッ♪　ドピュッ、どぴゅどぴゅってさぁ……♪　自分でもよーく見え\nるだろ？　あーあ、可愛い布が台無しだ。こんなの二度と履けないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの精液の臭いがこびりついて……ショーツの生地に染み込んじゃって\nさ。子種一色に染め上げられたこの布を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしが履いたら、それだけで妊娠させられちまいそうだ♪　どれだけ洗っ\nても、精子がとれないよ。オタマジャクシがアソコに侵入して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしを孕ませにくるかもねぇ！　アハッ、アハハハッ……！　だって、あ\nんたの精液は特別濃くて、しつこくて臭い最悪な汁じゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「絶対に、洗い清められたりしないはずだよ……。ふふふふ、あはははっ、ひ\nゃははは……！　って……何……？　あっ、こ、これはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……あんたもしかして、射精しながら罵倒されてまーた興奮しちまったのか\nい！？　こりゃあ傑作だよ！　真性のヘンタイじゃないか、スゴいねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おパンツでシコシコぴゅっぴゅさせてもらっただけじゃあ満足できないって\nのかい！？　あーあ、そんな目であたしを見たってダメだよ……変態」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしのお慈悲をもっと期待してるって目だね……。はぁっ、はぁ……これ\n以上、どういじくってほしいのか言ってみな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「気分がいいから、聞いてやるかもしれないよ……。……ふぅん……。このま\nま、汁だくのチ○ポを責めてほしいって？　出したばっかなのに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まァいいか……♪　面白そうだし続けてあげるよ。あはっ……べちゃべちゃ\nになったショーツを、ローションがわりにして……こうだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こう、やってさ……。ニュルニュルさせながら、更に苛めていくのがイイん\nだろ……？　んっ……んっ……。あはっ♪　嫌だ、臭すぎるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「手を動かすと、精子の悪臭がショーツの隙間から滲み出してくる……。はぁ\nっ♪　いつもより精液が濃いんじゃないかい？　臭いも強いしさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ホントに我慢しまくって、それから解放したって感じだね……。いいよ♪　\nあたしに従うっていうなら可愛がってやってもいい。たまーにだけど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いじめられるのが好きだなんて……本当に変わってるね……。んっ？　あた\nしの下着だから？　さぁ、どうだか。別に、疑ってんじゃないけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ショーツを突き破りそうなくらい射精してくれちゃったお礼はさて……どう\nしようか。自分の精子まみれの下着で、もう一度……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「泣きながらイクまで攻め続けてやるしかないかねぇ……？　……ん……どう\nだい？　単純な上下運動から……。こうして、手首をひねってさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くにゅっ♪　ぐにゅぅってうねらせるのもいいよねぇ……？　疑似オマ○コ\nだろ？　うねうねうねうね、あたしの指が自在に動いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「アハッ、ハハハハッ……そうだよ♪　気持ちいいだろう……？　グリグリっ\nて亀頭も指先でいじめてあげるよ。強くつまんで……グリグリグリ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「指の腹で刺激しながら、時たま軽く爪を立てたりしてさぁ……アハハハッ♪\n　そのまま竿も同時にいじくる……。……はぁっ、こう、こうやって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「裏筋に人差し指をつつつーって添わせてさぁ……。……んん？　ちょっとぉ\n……。まーたチ○ポがバキバキに肥大化してきているじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まさか、またすぐに出したいのかい？　二回目はもう少し長くもつと思った\nんだけどねぇ……。たまには、早漏気味ってのもオツかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいよ……出してもさ。でも、あたしの手をわずらわせたんだから、たっぷ\nり量は出してくれなきゃキレるよ。質のいいのを出してくれなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……期待してもいいのかねぇ？　んん？　どうなんだい？　とびっきりの濃\nい精液が出せそうかい？　どんな女も孕ますくらいのやつさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「出せるんだったら……サポートしてあげるよ。あたしが本気を出せばこうだ\nよ……♪　ぐりぐりぐちゅぐちゅ、グチュグチュグチュって……そら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そぉらそらそらっ……！　出た出たっ……そのまま止めるんじゃないよっ！\n　あたしを悦ばせておくれっ……！　そらっ……もっと、もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まだまだこんなもんじゃないだろ……？　あんたの本気はさ……！　んっ…\n…フフフッ、そう！　ありったけ出しな！　ショーツ貫通するまでね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っふふ……！　ふふふっ、あははは、あはははは……！　精根尽き果てるま\nで、下着なんかに射精させられる気分はどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103303" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あーあぁ、もったいないねぇ……♪　これをあたしの中に出してりゃ、妊娠\nさせられたかもしれないのにさぁ……無駄打ちだよ、ははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも、あんたはそれでもここに出したいんだろう？　あたしの脱ぎたてパン\nツの中に……！　だったら本望だよね、しょうがないんだよねぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ンフフフッ……♪　ちょっと！　あたしの手にまで精子がかかっちまってる\nじゃないか……。どんだけ出してるんだよ、本当の変態だね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「キ○タマ空になるまで堪能できたかい？　あーあー、いやだ♪　腰をカクカ\nクさせながらショーツにびゅるびゅる発射しまくっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……ただのご褒美で始めたプレイだけどさぁ、これはこれで面白いかもしれ\nないね……。また、いつでもしてやってもいいよ？　クククッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ～あぁ、魂抜けただらしない顔しちゃって、まあ……。チ○ポついてない\nあたしにはよくわかんないけどさ、ヨかったんなら良かったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「これからも……まぁ、気が向いたら相手してあげるからさ。精液が溜まった\nら、すぐあたしに言うんだよ？　わかったね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　顔に出したい？　だったらもっと責めてあげるよ……いくよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしの長い舌で亀頭を舐め回しながら……れろっ、竿を手コキで容赦なく\n責めたてる……。ほらっ、ほら、ダブルで苛められると気持ちいいねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「れろっ……れろっ、れろれろ……ぴちゃっ！　ぢゅる……ぢゅるっ、ぢゅる\nぢゅる……。あはぁ……♪　精液の苦い味、最低な食感の粘り気ぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいよ……いいよ、いいよ……！　精液ほじくりだしてやるっ……！　ぺち\nゃっ、れろっ、れろ……レロっ、そら出しな、出しな出しなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしの舌で精液吸い上げられちまいなっ……！　ぴちゃっ……ぴちゃっぴ\nちゃっ……レロレロレロ……ぢゅううっ、おや、出すのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んッ、んぁううううっ……ふぁあああっ！　出たっ……！　出たけどさぁ…\n…！　ちょ、調子にのって顔全体にぶっかけてんじゃないよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103406" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぷっ……ンンっ……！　おぇっ……！　ちょっと……！　二度目なのに一\n度目よりヤバい量出すんじゃない……！　うぷっ、クサっ、苦ッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あ、あんたねぇ……！　あ、あたしがご褒美をあげるって言ったのが悪いん\nだろうけど……毎回毎回出しすぎなんだよ！　少しは遠慮しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000311_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はァ？　青い肌に精子の白がよく映えるから？　……う、うるさい……！　\nだからって、こんなに出して……。精液まみれになっただろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……とんだご褒美になっちまったねぇ……。満足出来たかい？　気が向\nいたら、次もしてあげるよ。気が向いたら、だけどねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}