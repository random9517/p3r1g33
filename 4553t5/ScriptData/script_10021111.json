{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "さて、列車の中のルナテミスたちはそんなことになっていたようだが、そのこ\nろ俺たちはというと――", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかし、時間城へのゲートっていってもなあ……いったいどこを探せばいい\nんだか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "相変わらず、翔生子の言う『ゲート』を探し続けていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「駅のまわりはくまなく探したはずだけど……この近くにはないってことかな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そのようですね……他の場所を探してみましょう。おじいさまから、出現確\n率の高そうな場所は教わっていますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それじゃ、その中のどこかに行ってみようか。翔生子ちゃんは、どこがいい\nと思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "などと相談していると、突然目の前に光の渦が現れた！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！？　これってもしかして時間城へのゲート！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「い、いえ！　違います！　ですが……これはワームホール！？　いったい誰\nが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「やあやあやあ～！　やっと見つけたよ。キミがカツマくんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440003" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さん、この人知り合い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、知らない……と思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だよねー。ここのカツマくんとは初めましてだよねー。ボクは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま、気を付けてください！　その人は、時間帝国の道化師・ジェスタ\nです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440004" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「時間帝国の！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「つまり敵かぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょっとー！　なんでキミ、邪魔するかなあ！　せっかくカツマくんと、\n楽しくおしゃべりできるかと思ったのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114440003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「でも仕方ないね！　気分壊したから、おしゃべりは中止！　いきなり実力行\n使に移らせてもらうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114440004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジェスタと名乗る道化師はニヤリと笑って、パチン！　と指を鳴らす。すると\n……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「時間帝国軍が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440005" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "重武装の兵士たちに続いて、その後ろから現れたのは――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「おい、ジェスタ！　こいつらか？　こいつらを好きにしていいんだな！？　\nへへへへへ、どいつもこいつも、エロい身体してんじゃねえか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「な、なんだぁ！？　この変態女！　どーでもいいが、えらくムカつくツラし\nてやがんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それ、小姉ぇが言っちゃう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……なかなか腕の立つ者もいるようだな。楽しませてくれそうだ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おぬしこそ、かなり使えると見たぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「えーと……もしかして、あの二人は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「は、はい。おそらく別次元のウタマロさんと、ニャンコ先生だと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440006" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、そういうことになるよなあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「べ、別次元のオレだとぉ！？　この変態女が？　ふざけんな！　オレは絶対\n認めねぇえええええ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114440003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「んだとぉ！　てめえだってオレのくせに、なにスカしてやがんだぁ！　\n服ひんむいて、本性むき出しにしてやらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ドーモ！　ワタクシ、ニャンコ先生デス！　イザッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「コレハ、ゴテーネーニ！　ワタクシ、ニャンコ先生デス！　ハイヤッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お！　さっそく本人同士がおっぱじめたねー。それじゃ他のみんなは……\n兵士くんたち！　お相手してあげて―」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114440005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵たち" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_924_010114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00092401_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00092501_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジェスタとかいう女の号令で、兵士たちがいっせいに撃ってくる！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべやべやべぇ！　みんな隠れろっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "慌てて俺たちは物陰に飛び込む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「って、隊長！　反撃しないと！　反撃！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってる！　わかってるけど、このレーザーの嵐の中でどうやって――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "時間帝国兵α" ]},
		{"command":[ "SETTEXT", "「う、うわああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_924_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00092401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん！？　なんだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「見て！　誰か来た！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114440003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「はぁあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "突然、時間帝国兵たちの背後に現れた黒い影が、目にもとまらぬすげえ動きで\n兵士たちを倒していく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵β" ]},
		{"command":[ "SETTEXT", "「だ、誰だお前は――ぐわああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_925_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00092501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチが誰かって？　そんなことは覚えていません。ですが――『ハルノブ』\nとでも呼んでいただきましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ハルノブ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ！　また誰か来た……って、あれは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114440003" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ハルノブ！　よくやったぞ！　拙者も負けてはおれんな！　グワハハハハハ\nハハハ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114440001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あの品のない笑い声は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114440004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「コイワイちゃ～ん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「本名で呼ぶなと言ったはずだぞ！　スゴイ・シツレイな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そっか、ごめん。マッポーサムライね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114440005" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「だから！　その呼び方ももう古い！　拙者は穏やかな心でハイッパー化に\n目覚めたもの……『ハイッパー・マッポーサムライ』だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114440003" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだったね。ハイパー・マッポーサムライ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114440004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
