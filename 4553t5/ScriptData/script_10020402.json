{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0127" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "普通科の生徒を怯えさせたことで、俺たちは学園長に呼び出されていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴方たち、今は仮にも防衛って名乗っているのに、一般人を怯えさせてどう\nするんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「子供のケンカじゃないんですから。いかにも悪人って態度で一般学生に接し\nてはいけません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113570002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……いや、悪人っていうか、悪の女幹部たちなんだがな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「カツマ先生、なにか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113570003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いえっ、なんでも！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「余計なトラブルを起こすと後始末が大変ですから。以後、しばらくは一般学\n生との接触を禁止します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113570004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "生徒たち" ]},
		{"command":[ "SETTEXT", "「はーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00001502_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「そんなことも、ありましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113570002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あの後、俺は一般学生への謝罪行脚へ行かされたのだった。なぜか俺一人で。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「以上の経緯から、今度の球技大会でも『試合なんてとんでもない！』と、止\nめられました。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ただし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113570002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ＆みんと" ]},
		{"command":[ "SETTEXT", "「ただし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001502_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「地球防衛科の学生と教師を２チームに分け、エキシビジョンマッチを行いま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113570003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「防衛科を……分ける……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「教師まで参加ですか？　だからウチたちまでここに呼ばれたと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「へえ、燃えるじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それで、カツマ先生。種目は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、種目はドッジボールだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ドッジボール？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ドッジボール……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113570002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだ、さっきまで食い気爆発だったセレインの様子がおかしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ばっちゃんが言ってた……。ドッジボール――すなわち闘球とは、すべての\n格闘技を超えたところにある格闘球技だって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113570003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「格闘家として避けては通れぬ道……やるしかないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113570004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……はぁ。仕方ないですね。セレインがそこまで言うなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060113570002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだかみんなやる気になってきたな。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というわけで、チームを決める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "チームのキャプテンはルルーナとみんとになった。ただ、そのチーム決めもす\nんなり決まるわけがなく……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「ドッジボールが格闘技なら、当然セレイン先生はこちらのチームへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113570004" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いえ、こちらのチームに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ＆みんと" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぬぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001502_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いやーまいっちゃうなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113570005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ところで、ご主人は参加なさらないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が入ったチームはエンブレム・シンテシスでバフがかかるだろ？　だから\n参加するなって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええい、こうなったら実力でセレイン先生を手に入れるまで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113570007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「いいでしょう。ここは普通科の生徒もいませんし、遠慮なくいきますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113570006" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}