		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「このまま進んだら、カツマちゃんがＭ．Ａ．Ｍ．Ａごと谷底に落ちちゃう！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120010" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「駆け落ちのうえに心中だなんて……でも、どうすればいいのよぉっ！」", "NORMAL" ]},
