	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そしてとうとう、Ｍ．Ａ．Ｍ．Ａに追いついた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114120001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そこのバス！　止まりなさ～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら、来てくれたのね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんとなにやってるの！？　いいから止まりなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それがね～、止め方がわからないのよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120002" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「どういうことよ！　貴方も私と同じでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120003" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ええ、そう言われても～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120003" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「このままじゃカツマちゃんをＭ．Ａ．Ｍ．Ａに盗られちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120004" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「暴走にかこつけて逃避行、駆け落ちだなんて許さないんだからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「また前！　なんだか道路の幅が狭くなってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａ、もしかして街から出ようとしてるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120006" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そうみたい～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120004" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「この先は山道だよ。Ｍ．Ａ．Ｍ．Ａで通れるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030114120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａは後発のＡＩカーだもの。狭い峠道でも速度を落とさず走れ\nるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120007" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「車体が大きい分、馬力も私よりずっと大きいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「しかたないから、後ろに下がるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114120009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「車体の大きいＭ．Ａ．Ｍ．Ａを風よけにしながら、対策を練ることにしたの\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114120002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0155" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「一方、ここはＭ．Ａ．Ｍ．Ａの車内」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114120003" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うわああああ！　こんなことなら、ちゃんと止め方を考えておくんだった！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114120001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「うるさいわね！　静かにしなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010114120001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅが追いついてくれたみたいだが、打つ手なしか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえばご主人、いい話と悪い話があるのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ。もったいぶらずにいっぺんに頼む」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いい話というのは、Ｍ．Ａ．Ｍ．Ａ殿がもうじき止まるということです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当か！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「……でも、悪い話っていうのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114120001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「止まり方が、台風で壊れた橋から落下という方法ということですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいふざけるな！　いくらＭ．Ａ．Ｍ．Ａでも谷底に落ちたらヤバいだろ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うわあああ！　もうだめだあああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114120002" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こうなったら、お前らみんな道連れにして、私は二階級特進だーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「大丈夫よ、リーダーさん。それにみんなも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａに乗っている以上、あなたもＭ．Ａ．Ｍ．Ａのファミリーな\nんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だから、絶対に守るわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ママぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114120004" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「よしよし、大丈夫だから、泣かないで。私にまかせて～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114120008" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ママぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114120005" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａ殿の母性に胸を打たれたのでしょうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
