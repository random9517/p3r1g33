		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「待っていたわよ隊長くん。ここに来たってことは、そういうことよね？　ま\nた若返って、かわいい『隊長ちゃん』になっちゃいましょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああぁん♪　本当にかわいいわね、隊長ちゃんったらもう……かわいすぎて\nどうにかなっちゃいそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「というか、もうなっちゃってる♪　マキママ、隊長ちゃんのかわいさにもう\nメロメロなんだからっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それじゃあ隊長ちゃん、マキママがオチンチンのお世話をしてあげるわね♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026201_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そこに仰向けになって……ふふっ、こうして足をもって、隊長ちゃんのこと\nひっくり返しちゃうわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「どうかしら。やってみたかったのよね、こういう種搾りっていうの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ちょっと苦しいかしら？　でも、ここはお仕置き部屋だし……そう、これは\nマキママのお仕置き、愛の鞭よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママのこと誑かしちゃう隊長ちゃんに、お仕置きなんだから。ふふっ、\n安心して、痛くはしないから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んん……ふぅっ、くぅうう～～～～っ♪　隊長ちゃんの、ミニミニオチンチ\nンがはいってくるぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「どう、隊長ちゃん？　マキママのオマンコ、すっごく熱くて、トロトロにな\nっちゃっているでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのことを待ちながら、隊長ちゃんのオチンチンを想像してオマン\nコを濡らしちゃっていたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、んっ、んんぅっ♪　さっそく、腰を動かしちゃうわよ。こ\nうやって……腰を、上下にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、ああっ、すっごく気持ちいい。隊長ちゃんのオチンチンがマ\nキママの気持ちいいところに当たってるの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、あはぁんっ、いいっ、すっごくいいの……っ！　オマンコどんどん\n気持ちよくなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、見える？　マキママのオマンコから、いっぱいいやらしいお汁\nがでているのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そして、隊長ちゃんのオチンチンのこと、ベトベトに濡らしちゃっているの\n。あぁんっ、すっごくいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんも、気持ちよくなっているみたいね♪　うふふっ、ここから、よ\n～く見えるわ。隊長ちゃんのかわいいお顔」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチン、悦んでくれているみたいね♪　マキママのオマンコにきゅうき\nゅう締めつけられて、しごかれて、ピクピクしちゃってるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、本当にかわいいわ隊長ちゃん♪　ゾクゾクしちゃう。そんな蕩けた\n顔でマキママのこと見つめちゃだめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、ああっ、ああっ、腰が止まらなくなっちゃう♪　隊長ちゃんに見\nつめられながら、興奮して……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ♪　はぁっ、はぁ……♪　興奮しすぎて、おっぱいからミルクで\nちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ、びっくりさせちゃったかしら？　マキママ、こういう体質なの♪　\n興奮すると、でちゃうのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁっ、んっ、あはぁんっ♪　母乳っ、で、でるっ、んぅうんっ♪\n　ミルクだしながら腰振っちゃうわぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んぅっ、隊長ちゃんっ、隊長ちゃぁんっ♪　マキママのこといっぱい見て、\nいっぱいオチンチン硬くしてね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ああんっ♪　オチンチン、とっても素直でいい子ね♪　オ\nマンコの中で、どんどん膨らんでる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああんっ、隊長ちゃんも、いっぱい興奮してくれているのね。マキママのい\nやらしいところ見ながら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンが……ますます……んんっ♪　ああ、ガチガチになって、熱くな\nって……っ♪　マキママもとっても感じるのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふぅ、はぁっ、ああっ、もっと激しくしちゃうわ。腰を大胆に動かして、\n隊長ちゃんのオチンチン感じるのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、ああぁんっ♪　いいっ、いいっ、ぐりぐりぃって、オマンコの中を\nこするぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、ああっ、ああっ、オマンコどうなってる？　すっごくいやらしく\n動いているでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママ、とっても興奮しているから。隊長ちゃんのオチンチンからいっぱ\nい精液を搾ろうとしているのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、そう……ミルクいっぱいだしながら、いやらしく腰を振って……あぁ\nんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのオチンチンからでる、男の子のミルク……♪　んっ、だして…\n…もらいたいの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふっ、隊長ちゃんも我慢できないんでしょ……？　マキママのオマンコに\n、オチンチンが射精したいよ～って震えているのが伝わってきてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん……だして……だして……♪　マキママの、オマンコの中に……\n精液っ、ちょうだ～いっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁ～～～～んっ！！　あっ、ああぁんっ、でてるっ♪　精\n液ぃ……き、きたぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンがビクンビクンって、んっ、んふぅっ♪　すっごい勢いで精液だ\nして、あっ、ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママも、オマンコ震わせながらイッちゃうのっ♪　隊長ちゃんに中出し\nされながらイクッ、イク～～～～ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……♪　隊長ちゃん……とっても上手に中出しできたわね……\n♪　ふふ……気持ちよかったでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「でも……もっともっと、隊長ちゃんのオチンチンから精液を搾っちゃうわよ\n……。だって、一応お仕置きなんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、もう一回、このままシちゃうわよ……。あぁんっ、敏感になってる\nオマンコで、また、イかせてあげる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はぁっ、ああっ、んっくぅ……っ♪　オチンチン、全然小さくな\nっていないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「元気なままのオチンチン……んっ、また、マキママの中でピクピクってして\nる……はぁっ、はぁ……んっ、ああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんも、イッたばかりですっごく感じちゃうでしょ？　マキママのオ\nマンコが、いやらしく動いているの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのオチンチンを、オマンコがぎゅ～ってしながら、うねうね～っ\nて動いちゃってるのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅっ、繋がっているところもいっぱい見て♪　隊長ちゃんのおち\nんちんが、ぱっくんって食べられちゃってるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふふっ、エッチなところをいっぱい見て、またオチンチンから精液でそう\nになってきたでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あんっ、マキママの身体もエッチになってるって？　乳首も勃ってるし、ミ\nルクだってとまらないし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんが、かわいすぎるからいけないんだから。そのせいで、マキママ\nは隊長ちゃんの精液がほしくてたまらなくなってるのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、だからまた、いっぱい腰を動かしちゃうんだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、んっ、あっ、あはぁっ、んっ、んっくぅっ♪　ほらっ、オマンコ\nいっぱい……んっ、オチンチン、しごいちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、さっき中出しされた隊長ちゃんの精液と、どんどん溢れてくるマ\nキママのオマンコ汁……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「混じりあって……すっごくエッチな音、立てちゃってるわ……ああっ、んっ\n、んん……あはぁ……ああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「もっと、もっとぉっ♪　隊長ちゃん、もう……マキママの方が先にイッちゃ\nいそうだわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
