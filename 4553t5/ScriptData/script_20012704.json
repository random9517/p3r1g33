{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "──若苗家のサムライ達が、己の信条を掛けて激しくぶつかりあっていく。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "片や、学業で楽をするために。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "片や、武家の魂を取り戻させるために。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ビックリするぐらい信条の重みに差があるが、それでも力は拮抗しあい、\n戦いは想像以上に長時間に及んでしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……はー…………ま、まだまだぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900001" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふぅ……訂正するでござる。流石長女、見どころがあるでござる！　だが、\nまだまだ若苗家のサムライとは呼べぬでござるな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900001" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "序も、虎之丞も、疲労のためだろう……動きにキレがない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが、『しんどいから』と言ってそうそうに戦線離脱した妹二人に比べると、\n流石は序と言うべきだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……別に今のままでいいじゃん。悪人は退治してるんだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021900001" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「だよねぇ……けど、もし今後強い敵が現れたら……ってことを考えたら、ち\nょっとぐらい向上心が必要なのかもーって、思うけどね、ボク」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021900001" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「う～～ん……修行とかしなきゃダメェ？　そういうのやだなぁ……何かのき\nっかけで急に強くなったりしないかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021900002" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "疲労しながらもブレない剣先と、ビュンビュンと風を切り裂く剣撃──。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "序のド根性と、虎之丞の『士道』を語るにふさわしい剣技に、妹二人はぼーっ\nと見てることしかできなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すると、傍らで見ていたアイナが二人にスススッと近寄った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「そんなあなた達に朗報です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021900001" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「え？　何？　バストアップの仕方、教えてくれるのー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021900002" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「これは遺伝です。諦めなさい。そんなことよりも、そろそろ、あなたのお姉\nさん、覚醒しますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021900002" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「え？　マジで？　やった……願ったりじゃん。あ、でも……誰かの死をきっ\nかけにしてってことじゃないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021900003" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「まあ、そういうのがあって然るべきですが……さすがにそれはね。ともかく\n、今後のことを考えて、サムライテールの強化は急務でしたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021900003" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「へぇ、じゃあお姉ちゃんを強くするために、わざわざ来てくれたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021900003" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「まあ、そんなところです。ですが、あなた達に、もっとピリッとしてもらう\n必要性はあるかと──あ、見てください、アレを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021900004" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "見ると、序の周りに白い光が満たされ始めていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……はー…………な、なんか、いい感じのエフェクトが出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900002" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ホントだ……なんか、こう……発動条件が整ったって感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021900004" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「すごい、お姉ちゃん……頑張って！　頑張って強くなって、ボク達をもっと\n楽にして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021900004" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「い、言われなくても…………ええい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900003" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「くぅ…………ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900002" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "剣圧に押され、虎之丞はかろうじて受け止めた刃に身体を流され、数歩退いて\nしまった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この戦いで、虎之丞が初めてみせる劣勢である。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「な、なんなんです！？　この力は……すごいパワーの強さ感じるです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900004" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "序の身体から鱗粉のような、不思議な光の粉が舞い散っている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……もう、明らかに、さっきまでの序とは違う。誰の目にも明らかだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「……力も、パワーも、強さも、だいたい同じ意味ですね。まあ、それはとも\nかく……どうやら上手くいったようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021900005" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アイナが豊か過ぎるバストをゆすりながら、二人の戦いを見守っている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "破も、急も、その膨らみを時折チラ見しつつ、姉の勝利を願っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……身体が……身体が熱い……これなら、行ける…………うり\nゃぁぁぁぁ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900005" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "災厄を払う太刀が、虎之丞をかすかに掠めた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "未知の力に追い詰められる虎之丞……だが、その表情に焦りは見えなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「やるでござる……だが、まだまだ力を出し惜しみしてるでござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900003" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……そんなこと言われても、どーしていいかわかんないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900006" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「ふむ、では、こうするでござる……これから、拙者……懇親の一撃を見舞う\nでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900004" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「…………ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900007" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「受けるか、かわすか……お主の自由。だが、そちらも本気を出さねば、切ら\nれて死ぬは必定……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900005" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……燃える！！　よ～～～し、ガチのマジの本気、出すです……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900008" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「その意気やよし！！　いざ、参る！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900006" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二人の間の空気が、緊張感で凍てついていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「…………ッッッ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900007" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "身体から溢れ出す光の粉がパッと散った瞬間、虎之丞の剣先が閃いた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「どりゃあああああああ！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900009" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "序はその虎之丞に、なんの芸もなく、技もなく、ただ無遠慮に剣先を叩きつけ\n──弾き飛ばした。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その力の衝突が、輝く光を更に輝かせ、序を金色に照らした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……緊張したー…………って、何、これ？　うわ、すっごくキレイ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900010" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "虎之丞" ]},
		{"command":[ "SETTEXT", "「……潜在能力の全てを引き出した瞬間の声としては、いささか雑でござるな\n……だが、お手前、見事でござった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_104_010021900008" ]},
		{"command":[ "SETCHARA", "0", "char_00010401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「すべてを引き出した……？　私が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900011" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナ" ]},
		{"command":[ "SETTEXT", "「苦悩を破る、精神の壁……それが潜在能力を開放させぬ蓋となったのです。\n序さん、それをあなたは……豪快にぶち破りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_105_010021900006" ]},
		{"command":[ "SETCHARA", "0", "char_00010501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……うん、私、悩んでた。けど……なんだかどうでもよくなってきたです…\n…あは、あはははははは！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900012" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……どうでもよくなっちゃ駄目じゃん。悩みの根本を絶たなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021900005" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……悩みったって、明日の補習テストのことでしょ？　ぎりぎり一点足りな\nかったこと、めちゃくちゃ不満そうだったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021900005" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うるさーい！　人が万能感に浸ってるですから、邪魔しないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021900013" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「いや、その……ああ、もう……姉さん……今日はもう帰りましょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021900006" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
