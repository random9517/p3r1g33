		{"command":[ "PLAYVOICE", "005_0104215" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「だから……もっといっぱい、可愛がって欲しいです……さっきみたいに、カ\nワイイって言ってほしいですぅ……！」", "NORMAL" ]},
