		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104407" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「でも、それでいいです……あふぅぅ、ウチはもう、主様のものですから……\n主様にオチンチン挿れてもらえるなら、もうそれでいいんですぅ……」", "NORMAL" ]},
