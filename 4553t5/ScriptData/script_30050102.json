		{"command":[ "PLAYVOICE", "005_0104132" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、熱々の、精液っ、ゼリーみたいな、固まりがぁっ、ぼぴゅうっ\n、ぼぴゅうっ、てぇっ、奥に当たってますっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104133" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁぁああっ、精液が、子宮のところ、びちゃびちゃって、かかってますぅ\nっ、ふぁあっ、中出し気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104134" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、またイくっ、イッちゃいます！　精液、中出しされて、\nイっちゃいますぅっ！　あっあっあっ、イくっ、イくぅっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104135" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、あぁっ、んあぁっ……！　まだ出てるぅ、ぷるぷるのザーメン、\n奥にぶぴゅぶぴゅってぇ……あっあっ、またイく、イっちゃうっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104136" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ……精液、すごいですぅ……はぁぁ、オマンコの中\nに射精されるのが、こんなに気持ちいいなんてぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104137" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんんっ、オマンコの奥にザーメンが、たっぷりとへばりついて……んふぅ\nぅっ、ジンジン、染み込んでいってます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104138" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「濃くって、臭くってぇ、ふぅぅっ、熱々の溶けたチーズみたいな精液が……\nあぁぁっ、ウチのオマンコが、精液、美味しいって言ってます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104139" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふぅぅっ……オチンチン、気持ちよすぎです、最高すぎですぅ、はふぅ、\nこんなのハマっちゃうに決まってますぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104140" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「生命の神秘です、女の肉体は精液をナマ中出しされると感じてしまうように\n出来てるのです、だからコレは、しょうがないのです……はふぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104201" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くんくん、くん……むはぁぁぁ、あなたの汗の匂いと、二人のエッチな汁の\n匂いが混ざりあってぇ……んうぅぅっ、たまらないですっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104202" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「すぅ、はぁ、すぅ……はぁぁっ……んあぁぁっ、身体がどんどん熱くなって\n、全然おさまらないです……まだまだ、セックスしたりないです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104203" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オマンコの奥がキュンキュンしてぇ……んぅぅっ、もっとオマンコ、こすっ\nてほしいですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104204" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あの……シても、いいですか……？　今度はウチが、んぁぁっ……このまま\n、動くので……ふぅぅっ、あなたはそのままで大丈夫、ですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104205" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、あっ、あっ、オチンチン、固くって、カチカチに反り返っててぇ\n……あふぅっ、あなたもまだ精液、出し足りないですか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104206" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いいですよ……もっといっぱい、出してください……んあぁっ、ウチのオマ\nンコでオチンチン、シゴいて、ぷりぷりの精液、出して欲しいですぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104207" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁああっ……！　オチンチン、太くて、長くてぇ……あっ、あっ、あっ！\n　カリ首がオマンコのナカ、擦って……んあぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104208" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「セックス、気持ちいいっ！　男性器と、女性器を、組み合わせてぇっ、ニュ\nポニュポっ、ズボズポぉっ、あふぅぅんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104209" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もっとシたいですっ、ふぁああっ！　エッチなところ、擦り合わせて、あふ\nぅぅっ、二人で一緒に、気持ちよくなりたいですぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104210" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あきゅうううっ！　ウチのオマンコに、あなたのオチンチン、なじませてほ\nしいですっ！　ウチを、あなたのものにして欲しいですぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104211" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「クンクン、クンカクンカ……むはぁぁ～～っ、あぁぁっ、これです、もうこ\nの匂い無しには、生きていけないですぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104212" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「他の男は全然いい匂いなどしないですっ、はぁぁっ、んはぁぁっ、あなたの\n匂いじゃないと、ダメです……興奮しないのです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104213" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くん、くんくん、すぅ、はぁ、すぅぅっ、はぁぁぁ～～っ、あぁぁ～～こん\nなのもう、イケないお薬です、女の子をダメにする匂いですぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104214" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチはこの匂いに堕とされてしまったのです……んぁぁぁっ……ウチはもう\n、あなたの……主様の、虜になってしまったのです……」", "NORMAL" ]},
