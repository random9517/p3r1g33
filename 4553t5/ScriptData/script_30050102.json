		{"command":[ "PLAYVOICE", "005_0104102" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……このオス臭いニオいを嗅ぐと、ふぅ、ふぅぅっ、ウチはもうそ\nれだけで、たまらなくなって、おかしくなってしまうのです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104103" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「道ですれ違うだけでアソコが濡れてきてしまってぇ、くぅぅっ、いっしょに\nいると、シて欲しくてたまらなくなるのです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104104" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、お尻に、固いのが、オチンチンが当たって……くふぅぅっ、あ\nなたも、興奮してるのですかぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104105" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの、こんな貧相な身体で興奮するなんてぇ、はぁっ、はぁぁっ、あなた\nは本当に、変です……奇特な、人ですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104106" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「か、カワイイなどと……はぁぁっ、あぁっ……！　また、そういうことを言\nってぇ……くぅぅっ、ウチのことを、からかって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104107" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたが、そんなことを言うからぁ、はぁっ、はぁぁっ、ウチは、おかしく\nなってしまうのです……ほ、本気に、なっちゃったのです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104108" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……！　もう、身体が熱くて、ふぅっ、ふぅぅっ、ガマンできない\nです……！　あなたの、挿れてほしいです……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104109" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「太くて、固くて、立派なこの男性器を、ウチの狭くてキツキツの女性器に、\n奥まで、挿入して欲しいですぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104110" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「トロトロに濡れそぼった膣の中で、あなたの陰茎を抜き差ししてぇ、はぁぁ\nっ、透明な愛液が泡立って白く濁るくらい、激しくかき混ぜてほしいです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104111" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁあああんっ！　あぁぁっ、挿ってきたぁっ……！　オチンチンが、ウチ\nのオマンコのナカを、かき分けてぇ、あふぅぅっ、入ってくるぅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104112" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、ウチのナカが、ペニスの形に押し広げられてぇ、んぁあ\nあっ！　先っぽっ、亀頭、太すぎますぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104113" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひぁああっ！　オチンチン、奥に当たってるぅ……はぅぅっ！　そこ、行き\n止まりですっ！　オチンチンもう、入らないです、全部はムリですぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104114" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ！？　さ、先っぽっ、ぐりぐりっ、ひゃあうううっ！　オチン\nチンねじ込んじゃダメですぅっ！　ひぅぅぅっ！　オマンコ弾けちゃうっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104115" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はひぃ、はひぃぃっ……本当に、全部入れちゃうなんてぇ……あぁぁっ、お\n腹のナカ、オチンチンでパンパンになってますぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104116" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、奥のところ、ぐりぐりっ、ひぅぅっ、子宮が押し上げられて…\n…ふぉおうっ、これだけで、おかしくなっちゃいそうですっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104117" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅっ、ふぅぅっ……いい、ですよ……動いて……ウチは、大丈夫なので…\n…ひうぅっ、オチンチンにも、気持ちよくなってほしいですから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104118" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あっ、抜けてくぅ……ひぅぅっ、カリのでっぱりが、あっ\n、あっ、オマンコのナカ、引っかきながら、抜けてっちゃいますぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104119" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、デコボコがいっぱい擦れてぇっ、あふぅぅっ！　オチンチン、ず\nるいですっ、女の子を気持ちよくする形になってますっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104120" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ！？　あっ、あっ……カリ首、オマンコの入り口に、引っかかって……\nあっ、ダメっ、抜けちゃいますっ、オマンコ切ないっ、抜いちゃダメですっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104121" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぉおおおんっ！？　おっ、ひぁっ、あっ、あっ……また、挿ってきたぁ…\n…んあぁっ！　奥まで一気にズン、ってぇっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104122" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁあっ、あっ、あぁっ、オマンコの中、ズリュズリュってかき分けてるっ\n、あふぅううんっ！　赤ちゃんのお部屋、突き上げてますっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104123" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んあぁああっ！　あっ、あぁっ！　出たり、入ったりぃっ！　オチンチンす\nごいっ！　オマンコ、ダメになるっ、ムリっ、ムリですぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104124" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんなので、オマンコ、ほじほじ、されちゃったらぁっ！　くぁあああんっ\n！　オンナのカラダが逆らえるはずないですぅっ！　ひぅうううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104125" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチン、ズルいっ、卑怯ですっ、あふぅうううんっ！　最低っ、極悪チ\nンチンっ！　女殺しの、オチンチンですぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104126" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ！　そこっ、気持ちいいぃっ！　もう学術的興味とか、どうで\nもいいですっ！　セックスっ、セックス気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104127" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっあっ、そこっ、いっぱいドチュドチュしてほしいですっ！　この凶悪オ\nチンチンでっ、オマンコいっぱい、ハメハメしてほしいですぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104128" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ！？　オチンチン、太くなってるっ！？　亀頭がパンパンになっ\nてぇ、カリもゴリゴリって、オチンチン、イっちゃいそうですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104129" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、イって、ウチと一緒に、イってほしいです！　オマンコの中に\n、たっぷり、あぁあんっ！　精液、注いで欲しいですぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104130" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　オマンコ、クるっ、キちゃいますっ！　ふあぁっ！　もうイく\nっ、イっちゃうですっ、イくっ、あぁぁっ、イっくうううううう～～っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0104131" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁああああんっ！！　ふぁあっ、あ、あぁっ！　出てますっ、いっぱいっ\n、オマンコの奥にぃっ！　んぁああっ！」", "NORMAL" ]},
