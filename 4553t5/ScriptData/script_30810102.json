		{"command":[ "PLAYVOICE", "081_0104122" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「死を司る、神……神なのに、すぐイッちゃってごめんなひゃ……ごめんなひ\nゃ、い……んうううっ！　んんん！　うううっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104123" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長、さ……隊長さん、隊長、ひゃ……たいちょうひゃん、イッ……イッ…\n…！　あひぃいっ！　イっ……！　イって、イッてるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104124" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「もうイッてるっ、な、なん、何回、も……ひぐぅううっ……！　あぐっ！　\nんぐぅっ！　んっうっ、んうううっ！　イッてる、ぅ、イッてるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104125" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「イジワルっ、し、しないでっ、息っ……息できないっ！　イキすぎて、息…\n…ひゅぅっ……！　呼吸、する余裕、ないぃ……あうっ！　あうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104126" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「た、隊長さん……っ、隊長、さん……！　ゆる、許して、許してくだ、さ…\n…ああああ♪　や、だ♪　やだ……っ♪　死、死んじゃ、う……っ♪」", "NORMAL" ]},
