		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104203" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっぁ……ッ！　や、や、ぁ……っ！　中で、精液……隊長さんの精液が、\nぐちゅぐちゅ……ぐちゅぐちゅ……な、鳴って……ひぐぅっ！」", "NORMAL" ]},
