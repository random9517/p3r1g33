		{"command":[ "PLAYVOICE", "081_0104107" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「触られる、の、す、すき……。隊長さんに触られるの、す、好き……。どこ\nだって触ってほしい、うう……。こうやっ、て……んぅう……♪」", "NORMAL" ]},
