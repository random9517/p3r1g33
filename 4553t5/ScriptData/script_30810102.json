		{"command":[ "PLAYVOICE", "081_0104111" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっ……！？　あっ！　おちん、ちん……おちんちん入って……あ……♪　\nそ、そこ……そこ、だから、穴、私の穴に、い、入れて、いれて……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104112" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あぁっ、あ……あぁ、あぐ、ぅ……んぐぅううう……！　大きい、身体、バ\nラバラになっちゃいそう……でも……でも、それでもいい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104113" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長さんのモノ、になりたいから、しょ、所有物になって……っ。死神には\n許されないと思ってた、い、命、作るエッチ……して……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104114" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「二人で……こ、殺す、んじゃなくて……新しい命、つ、つくろ……♪　隊長\nさん……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104115" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっんんん……！　お、奥……一番奥に届いてる……。はぁ、エッチ……す\nごい、目の前が、グ、グラグラ……クラクラ……」", "NORMAL" ]},
