		{"command":[ "PLAYVOICE", "081_0104127" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「冥界の門……に自分が連れて行かれちゃうっ……♪　あっ♪　あぁ……♪　\n隊長さんっ、隊長さんの言うなり、するなりに、な、なって……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104128" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「私……私、無限にイかされちゃ、う……！　ああああッ……♪　あぁ♪　お\n腹の中……どちゅどちゅっ、どちゅどちゅ、さ、れて……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104129" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「何もかも、どうでもよくなるくらいぃ……。おまんこ、おまんこをおちんち\nんで突かれて、突き上げられて……気持ち、いい……気持ちいい♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104130" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ、う……♪　あうっ、はふっ、あふ、あうっ……あううう♪　隊長、さん\n……隊長さん、好き、す、き……好き、あああああっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104131" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～ッ……！　え……わ、私も、動いて……？　う、うん……ん\nん……！　ん、ん……！　う、うまく、動け、ない……ん、んっ！」", "NORMAL" ]},
