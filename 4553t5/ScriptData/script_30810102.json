		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104132" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長さんみたいに上手に、う、動くにはどうした……ら、あ！？　あッ！　\nだ、だめ、だ、め……ずぶずぶしたら、だ、だめ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104133" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
