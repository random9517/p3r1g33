		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「わ、私、の中……気持ちいい、の……？　気持ちいいから、う、動きたく…\n…なっちゃった、の……？　だったら、だった、ら……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104120" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「い、いい……動いて、いい……。ただ……、っんぅううううう……！　私っ\n、わた、し、すぐイッちゃう、イッ……イッちゃう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104121" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んあああああああああッ！！　あひ、あひぃっ、イッ……あうぅうううっ！\n　ご、ごめんなさ……ごめんなさい、ひぃ、ひぃ……はぁっ、はぁっ！」", "NORMAL" ]},
