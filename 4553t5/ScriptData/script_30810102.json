		{"command":[ "PLAYVOICE", "081_0104116" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「おちんちん……、はぁ、はぁ……入っただけで、これ……なの、に……。ン\n……一つになれた、だけでこんなに痺れ、ちゃうのに……」", "NORMAL" ]},
