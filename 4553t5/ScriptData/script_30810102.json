		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104134" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「おまんこ痙攣しっぱなしで、あっ、私の中におもらししそう……？　うん、\n……うん、うん、い、いいよ、おもらしして……」", "NORMAL" ]},
