		{"command":[ "PLAYVOICE", "081_0104202" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あっ……あぁ！　も、もうイけな……いぃ、イけない、こ、れ以上は……ほ\n、本当に狂って……ああああっ……！」", "NORMAL" ]},
