		{"command":[ "PLAYVOICE", "081_0104108" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁあ♪　や……柔らかい……？　うん……隊長さんに触られ\nると……溶けちゃう、から……トロトロ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104109" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「食べごろ……だから食べて……♪　この体勢なら……隊長さんの目、見なく\nてすむ、から……。どんな顔してても、いいから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104110" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「私の、は、はじめて、はじめて……散らして。奪って……。私のこと……た\n、隊長さんの、お、女に……して」", "NORMAL" ]},
