		{"command":[ "PLAYVOICE", "081_0104204" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あぁ……はぁ、はぁっ……すごい、す、すご、い……かき混ぜられて……な\nすり、つけられて……あう……！　あぅう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104205" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ど、どうし……よう、目の前で、ひ、火花……チカチカ……。あっ、あぁ、\n隊長、さん……隊長さん……私のこと、だ、抱き、抱きしめて……」", "NORMAL" ]},
