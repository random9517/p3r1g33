		{"command":[ "PLAYVOICE", "081_0104206" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「どこにもいかないよう、に……、あっ！？　ンッ……押さえて、それで、突\nいて……あっ！　あっあっ！　あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104207" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「気持ち……いい、気持ち、い……！　あう……はぅうっ……！　今まで、生\nきてきた中でいちばんっ……一番っ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104208" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あっ♪　勝手に、こ、腰がくねっちゃう……っ、もっと隊長さんのおちんち\nん……感じたい、味わって……気持ち良くなりたい……っ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104209" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あぅうううう……！！　精液まみれのおちんちんが、わ、私、私の中、おま\nんこの中……ずんっずんして……んんんんぅ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104210" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「暴力的、にされ、されるの、す、すき……♪　すき♪　す、き……もっとし\nて……もっと、もっとひどく、して……あああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104211" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「私っ……わたひのっ……、アヌビスのおまんこ、隊長さんのだから……！　\n隊長さん専用の、えっち穴だから……遠慮、しちゃいや……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104212" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ひどいこと、いっぱいして……してっ。赤ちゃんの種……ぜんぶ中にいきわ\nたるように……塗り付けて……あっ！　染み込ま、せて……っ♪♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104213" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「もう、もう……いいの、もう神様なんかどうでも……いい！　ぜんぶの力、\nう、失っても……冥界の門、み、見えなくなっても、いい、いいから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104214" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長さんの生命の息吹を、か、感じたい、私の……アヌビスの全てで……あ\nっ……あああっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "081_0104215" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「隊長さん……隊長、ひゃん……感じる……？　私のおまんこ、ちゃ、ちゃん\nと、役にたって……る？　気持ち、いい……？」", "NORMAL" ]},
