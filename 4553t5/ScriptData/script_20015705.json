{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……とりあえず、お前らの何としても人気上位にいきたいという意思はくみ\nとった」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺は、３姉妹のはちゃめちゃな状況を食い止めるために……とりあえずのまと\nめを口に出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「それで、良い案は浮かびそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740001" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ティシポネーを叩く手を止めたメガイラに、できるだけ真剣な表情で話してみ\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは案というものでもないんだが、１つ前提として……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このままお前らが冥界にこもっていたら、今後の出番はないんじゃないか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「えっ……。そ、それはどういうことなのでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740001" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今まで俺も、冥界なんてものが存在することすら知らなかったし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこに誰がいて、どんなヤツかもわからないのに投票なんかできっこないだ\nろ？　だから現状をキープするのは悪手だと思ってな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「確かに。ってか、投票すべき名前すら知らないってことだもんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740001" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「当たり前みたいにここにずっといたから……基本のきの字がわかってなかっ\nた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740002" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あなた様は、まずは私たちの存在を知っていただくところから始めるべきだ\n、とおっしゃるのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740002" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。お前らはこの世界を抜け出して、外に出る。その時に、俺もついでに\n蘇らせてもらえたら……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ここぞとばかりに生き返らせてもらおうとする俺だったが、３姉妹の興味は初\nめての外の世界にすっかり向いてしまっているようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「外……、外っていうのは盲点だったな。いやー、冥界の外になんてさ。出た\nことねぇから緊張しちまうなあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740002" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「でも、すっごくドキドキしますわ。こんな簡単なことに気が付かなかったな\nんて……。私が愚かでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740003" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ぶっちゃけ楽しみで仕方ねえよ。外の世界って、景色がめちゃくちゃキレイ\nなんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740003" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「行ってみてぇ場所が死ぬほどあんだよな。どっから行きてぇ？　メガイラ！\n　お前の好きなとこにもあたしが連れてってやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740004" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「話をそらさないで……。って、普段なら拗ねるとこだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740003" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……うん。私も、行ってみたい場所……たくさんある、かも。買いたいもの\nとかも……あるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740004" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あらっ。でしたらショッピングも兼ねてというのはいかがでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740004" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「新しいお洋服、綺麗な宝石……。たくさんの本や雑貨、外にはなんでもある\nと聞いたことがありますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740005" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「いいねいいねぇ！　あ、食い倒れもしようぜ！　うまいモンとか多いんだろ\nうし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740005" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……アイスクリーム、食べてみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740005" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしは極厚の塊肉かなぁ。冥界の肉はどーもボソボソしてマズイからよぉ\n、じゅわ～っと肉汁がしたたるような肉が食いてえよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740006" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「マカロンやパンケーキ、キャンディにクリームソーダ……。夢がどんどん広\nがりますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740006" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あの～。観光も結構なんですが、その前に俺をですね～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「よっしゃあっ！　そうと決まればすぐ行こうぜっ！　ここでグダグダやって\nても時間の無駄だっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740007" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「いざ地上へ！　これから私たちの……本当の広報活動がはじまるのですね♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740007" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……こんなにワクワクする気持ち……。いつぶりかな……嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740006" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺を蘇らせてほしいんですけど～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「さあ！　参りましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740008" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "8", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？　んん！？　んんんんん！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "目の前でフッ、と搔き消えた３姉妹に俺は心底びっくりした。", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] },
		{"command":[ "FADEOUTCHARA", "1", "NORMAL" ] },
		{"command":[ "FADEOUTCHARA", "2", "NORMAL" ] },
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　マジかよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ど、ど、どこだ！？　みんなどこに消えたんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まさか、置いていかれるなんて思ってもみなかった。", "NORMAL" ]},
		{"command":[ "FADEINCHARA", "1", "NORMAL" ] },
		{"command":[ "FADEINCHARA", "2", "NORMAL" ] },
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ア、アレクト～、メガイラー、ティシポネー……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "うろたえてオロオロしている俺の足元に、うっすらと透けた影が見える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……も、戻ってきてくれたのか！？　って、違うな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この形は……。犬……？　あっ！　ジュ、ジュンジロー！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ぼんやりとした輪郭で現れたジュンジローが、だんだん色濃く、はっきりと見\nえてきた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEINCHARA", "0", "NORMAL" ] },
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご、ご主人……ここは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023740001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うあああああ！　お前までこっちに来ちゃってるじゃねえかあああああ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ここはとても暗い……ですぞ……。がくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023740002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「死ぬなーっ！　んでもって、当然俺も死にたくないいいいい！」", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺はぐったりしているジュンジローを抱えて持ったまま叫んだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、待ってくれ！　置いてかないで～っ！！」", "NORMAL" ]},
		{"command":[ "FADEINCHARA", "0", "NORMAL" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺の悲鳴だけが、冥界に広がって……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……それに答える声は、いつまでも聞こえてこなかった……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0194" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ん？　今誰かの声が聞こえたような？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740009" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "0", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……気のせい……。早くたくさんの人に、私たちを知ってほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740007" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "8", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ～あぁ♪　外の世界のやつらにどんな蔑みの目で見られるか楽しみになっ\nてきたぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740008" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ポ姉……。それはどうなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740008" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "4", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ああ……♪　ここはとても美しい世界ですね。ここに、エリニュスを愛して\nくださる方がいますように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740010" ]},
		{"command":[ "SETCHARA", "2", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「きっといるさ！　あたしらじゃなきゃダメだっていってくれるドＳのご主人\n様が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023740009" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……私はドＳじゃない、ご主人様じゃない人がいいけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740009" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "1", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私たち３人全員を、愛してくれる人がいますように……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023740011" ]},
		{"command":[ "SETCHARA", "2", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023740010" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "6", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
