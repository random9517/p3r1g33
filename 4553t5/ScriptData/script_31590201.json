{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……私のせいで、右手に怪我をさせてしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「お詫びといってはなんだけど、治るまで私が身の回りのお世話をしてあげる\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「遠慮なんかしないで頂戴。むしろ遠慮されると、罪悪感で心が苦しくなるか\nら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「右手が使えないから、代わりにおっぱいでオチンチンをシコシコして欲しい\n……？　そ、そんなこと……！　いえ、わかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「男の人は定期的にオナニーをしないといけないものね……私のせいだし、頑\n張っておっぱいでシコシコしてあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00015902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んんっ……ど、どうかしら……ちゃんとオチンチン、おっぱいに挟めてる…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「そ、そう。それならよかったわ……こんなことするの初めてだから、勝手が\nわからなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「どうして、服を脱がないのかって……？　そ、それはあなたにおっぱいを見\nられたくないからよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「確かに、あなたの怪我は私のせいよ……でも、そのことと素肌を見せること\nは違うというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「か、簡単に言えば恥ずかしいのよ！　誰が好き好んで、おっぱいを曝け出す\n人がいるというの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「オチンチンを挟むのだって、恥ずかしくてたまらないわよ！　でも、あなた\nが胸でシゴいてくれと言うから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「と、とにかく！　いいから今はオチンチンに集中しなさい！　いいわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「えっと……ま、まずは胸を上下に擦ればいいのよね……んっ、くっ……あっ\n、ううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「オチンチンって熱くて硬いのに、どこか柔らかくて変な感じがするわ……こ\nれが、男の人の生殖器なのね……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「それに、このむせ返るようなニオイ……すごくクサイのに、嗅いでると変な\n気持ちになってくるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んっ、はあぁ……あっ、くううぅ……！　頭が変になりそうだわ……ちゃん\nとオナニーのお手伝いしないといけないのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んくっ、ふあぁ、あっ、あはああぁ……！　な、なにこれ……！　オチンチ\nンを擦れば擦るほど、先端から変なお汁が出てきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「お、オチンチンの先端を咥えて、ペロペロして欲しいの……！？　こ、こん\nなモノを咥えて、舐めろだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「くっ……！　わ、わかったわよ……！　ちゃんとオチンチン咥えてペロペロ\nするから……その、あまり怪我のことを責めないで頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「私だってオチンチンの一つや二つ……な、舐めることぐらいできるんだから\n……あむっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「れりゅ、んじゅ、じゅぷ……ちゅぱ、れろっ、ぺろっ……！　うううぅ……\n！　ひ、酷い味とニオイだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「舐めれば舐めるほど……んっ、じゅぷ……！　け、血管が浮き出て、はち切\nれそうなぐらい硬くなって……ちゅ、じゅるううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ぷはっ……はぁ、はぁ……！　あなたの透明なお汁と私の唾液が絡まって…\n…んくっ……！　飲み込むと、変な味がするわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、ちゅぷ……れろっ、れりゅ、ずちゅ……！　オチンチンがビクビク\nしてるわ……この出っ張ってる部分が、気持ちいいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「そ、そう……カリ裏と言うのね……すごくエッチな名前に聞こえるわ……ん\nっ、れりゅ、ずちゅ、じゅぷ……！　ぺろっ、ぺりょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「じゅる、ぢゅちゅ、じゅぷ……んっ、んむうぅ……！？　先端部分を舌でツ\nンツンしたら、オチンチンがビクンってしてぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい……！　痛かったかしら……！？　つ、次は優しくするか\nら……んっ、じゅる、ちゅぷ、ずぞぉお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、あっ、んむっ、ちゅぱああぁ……！？　オチンチンが、さらにドク\nドクって脈打って、硬くなってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「カリ裏とオチンチンの先っぽをクリクリされるのが、気持ちいいのね……！\n　じゅぷ、ちゅ、じゅずっ、れりょ、じゅずゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あむっ、んっ、んんっ……！　オチンチンが暴れ回って……おっぱいでシコ\nシコされながら、口でペロペロされるの……たまらないのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「くちゅ、じゅぷ、じゅるぅ……！？　お、オチンチンが膨らんでる……！？\n　な、なにがどうなってるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んっく、んむっ、ちゅぱあぁ……い、イキそう……！？　つ、つまり、オチ\nンチンから精子が出るということね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「もっと激しくおっぱいを動かして、舐めればいいのね……！　あむっ、あぶ\nっ……ちゅ、じゅるっ……ぶばっ、んっ、んふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、れりゅ、れろっ、んじゅるうぅ……！　オチンチンが何度もビクビ\nクって跳ねてるわ……！　い、いつでもイッていいわよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ちゅぱっ、じゅぱあぁ……！　いっぱい、出して……！　あなたの\n溜め込んでる精子、全部……出してぇ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んぶううぅぅうぅ！？　あぶっ、ぐちゅ、じゅるうぅ……！　ぶほっ、んぐ\nっ、んんっ……！？　んくっ……んぐ、んぐっ……ふぐうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ドロドロの精子が、口の中にどぴゅどぴゅ出て……！　ちゅ、じゅるっ……\n！　ぐちゅ、ちゅ、ちゅぷううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「く、口から鼻に精子のニオイが伝わって……んんんっ！？　な、なによこれ\n……！　イカみたいなニオイがするわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「こんなの、飲み切れないわ……！　んじゅ、じゅるるっ、じゅぱ……！　ち\nゅ、じゅぷっ、ずぞっ、ぐちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ごくっ、ごくん……！　はぁ、はぁ……じゅ、じゅるるっ……ちゅ\n、んくっ、ごくん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ、ふううぅ……いっぱい出たわね……男の人って、一回のオナニ\nーでこんなにも精子を出すのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……まだ口の中に精液の味がするわ……喉の奥にも絡みつい\nてて、なかなか取れそうにないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「でも、これだけ出せば暫くオナニーしなくても……え？　まだ出し足りない\nの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「もっとおっぱいと口で精子を絞り出して欲しいって……ま、またあんなこと\nをするの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「わ、わかったわよ……！　ちゃんと胸でシコシコして、口でちゅぱちゅぱし\nてあげるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あむっ……んっ、ちゅ、ぐちゅ……ちゅ、ちゅぱっ、じゅる……おっぱいで\n擦って、口に咥えてあげたわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あれだけ出したのに……んっ、ちゅぱ、ぢゅる……まだ出したいだなんて…\n…あむっ、くちゅ、じゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁああぁ……またオチンチンの先端から、変なお汁が……クサくて、ヌル\nヌルしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「残ってた精液と混ざり合って、余計に変な味が……ちゅる、じゅる、くちゅ\n、ちゅ……じゅぷ、ちゅぷ、ずちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ……！？　んむううぅ……！？　ちょ、ちょっと……！　腰を\n押し付けないで……！　い、息が出来なっ……むぐううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅぱっ！　ちゅ、くじゅ、じゅずっ、じゅるっ！　んんむうぅ！\n　んっ、ぐっ……ずちゅ、じゅる、んじゅるううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ぶはっ……！　はぁ、はぁ……！　そ、そんな奥まで咥えられないわ……！\n　それに、おっぱいも擦りづらいし……あむうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ちょ、ほんと……やめっ……！　むぐっ、ぐううぅ……！　んんっ、うぶっ\n、じゅるぅ！　お、オチンチンが頬に……んっ、ひあっ、あぐ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「けほっ、けほっ……！　あ、あなた……いくら私に負い目があるからって、\nこんな仕打ちをしてタダで済むと思っているの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「私のおっぱいと口が気持ちよすぎて、もうすぐ出そうだからって……ば、バ\nカなこと言ってないで、早く精子を出しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、じゅちゅ、じゅ、じゅるっ……！　ちゅぱっ、れろっ、くちゅ…\n…んむっ、んっ、ぺろっ、れりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んむうぅ……！？　ま、またさっきみたいに、オチンチンがビクンってして\n……で、出そうなのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ちゅ、くちゅ……ずちゅ、じゅ、ちゅぱっ……大きく、膨らんでるわ……！\n　出したくて、たまらないって感じね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「いいわよ……んっ、ぐっ、じゅぱっ……はぁ、はぁ……また、さっきみたい\nに出しなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「あなたの精子……全部、受け止めてあげるから……！　んんっ、ぐちゅ、じ\nゅ！　じゅちゅ、ちゅぱっ、じゅる……じゅるううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「んぐっ、んぐうううぅ！？　じゅる、ちゅぱっ、ぐちゅうううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「じゅずっ、じゅぞっ……ごくっ、ごくん……！　す、すごいわね……さっき\n出したのに、またこんなに出て……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「味もニオイもさっきと同じぐらい濃くて……んっ、ちゅぱっ、じゅる、ちゅ\n、ぐちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「粘々してて、飲み込みにくいわ……！　ちゅぱっ、んんんっ、ごくん……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁ……ぜ、全部、飲んだわよ……これで、満足したかしら\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「まったく……こんなにも出すなんて、聞いてないわ……男の人って、みんな\nこうなのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「それとも、あなたが特別なだけなの……？　初めてだから、よくわからない\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「手慣れてる感じがしたって……し、失礼ね！　男の人のオチンチンを見たの\nだって、今日が初めてよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「それなのに、こんな……おっぱいでオチンチンを擦って、口に出されて、あ\nまつさえ精液を飲むだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「また明日もして欲しいって……あ、あなたって本当に絶倫なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「きゃあああああぁ！？　ちょ、ちょっと……な、なにするの……んぶううう\nぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「わ、私の顔になにかついて……！？　こ、このニオイと味……まさか、精液\nなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「なに考えてるのよ！　断りもなく顔にかけるだなんて……あぶっ、んっ！　\nちょ、やめっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てる……！　私の顔がぐちゃぐちゃの、ドロドロに……！　どれ\nだけ出せば気が済むの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015902_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……うううぅ……こんなに顔につけて……！　ニオイが染み付い\nたら、どうしてくれるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「私を自分のモノにできたみたいで興奮する……？　ふ、ふざけないで頂戴！\n　私はあなたのモノなんかじゃないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「た、確かに、暫くはあなたのオナニーの手伝いをするけど……それとこれと\nは、話が違うわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「自分のモノになれば、オマンコにもザーメンを注いであげるって……私は別\nにあなたの精子が欲しいだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「べ、別にオマンコを濡らしてなんかいないわ！　あなたのオチンチンで気持\nちよくなってなんか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "風祭マユミ" ]},
		{"command":[ "SETTEXT", "「うううぅ～～～～！　今日はもうこれで終わりよ！　後始末ぐらい自分でし\nなさい！　いいわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}