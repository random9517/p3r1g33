{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　今日も一段と激しい拘束ね……！　まったく、この子たちっ\nたら姫騎士を凌辱するのがすっかりお気に入りになったみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私はどちらかと言うと攻められるより攻める方が好きだけど、貴方たちのた\nめならどんなプレイにも付き合ってあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ほらっ……ちゃんと姫騎士になりきってあげるから、遠慮せずに犯しなさい\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「くっ……！　触手ごときにいいようにされるなんて、騎士としてあってはな\nらないことなのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、ひああぁ！？　拘束がより強くなってるわ……！　は、離し\nなさいっ！　私を誰だと思ってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「姫騎士である私にこのような恥辱を与えてくるなんて……！　触手相手に生\nき恥を晒すくらいなら、死んだほうがマシよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　あっ！？　な、なに……！？　触手がおっぱいを嬲ってきてっ…\n…！　やっ、やめなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　おっぱいだけじゃなくて、乳首も弄られてるぅ！？　そ\nれにオマンコの方にも触手が這ってきてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そこは私の大事なところなのに……！　ひぎっ、あっ、いあああっ！　クリ\nトリスにも触手が当たってるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルした感触がオマンコの周りに広がってきて……！　気持ち悪いにも\nほどがあるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ふっ、あああっ！　感じたくないのに、敏感なところを攻め\nられるせいで身体が勝手に反応しちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あひっ！？　あっ、んはぁ！？　ちょ、ちょっとっ！　何よそのオチンポみ\nたいな触手はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「まさか、それを私のオマンコに挿れる気なの……！？　やっ、やめなさいっ\n！　私のオマンコは神聖なものなのよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「やっ、イヤっ……！　お願いだから挿れないで……！　私の大切な場所に入\nろうとしないでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「は、話を聞きなさいっ！　今すぐその汚らわしいモノを引っ込めてっ……！\n　い、イヤあああああぁぁぁーーーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おほおおおぉ……！？　オマンコに触手が入ってきてるぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私の純潔がこんな醜い化け物に奪われるだなんてっ……！　こ、殺せっ！　\n殺せえええぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぎいいぃ！？　オマンコの膣内で触手がぐちゅぐちゅ動いてるぅ！？　ヒ\nダをえぐりながら、どんどん奥まできてっ……んはあぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いあああぁぁっ！　ヌルヌルした汁をまき散らしながら、オマンコズポズポ\nされてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「吐き気がするほど気持ち悪いのに、オマンコ感じちゃうぅ！　触手相手に気\n持ちよくさせられちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んっ、ひうぅっ！？　おっ、んぐっ……！　あああっ！　\nそんなに激しくズポズポするなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　無理やり気持ちよくさせられてるせいで、オマンコが\nヒクついてるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手を求めてるように腰がヘコヘコ動いて……！　オマンコの締まりも勝手\nに良くなってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ど、どうしてなのっ……！？　触手に凌辱されるなんて耐え切れないのに、\n身体が悦んで……！　あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はっ……！　そ、そうよ……！　こんなに感じるのは、きっとこの触手汁の\nせいよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「このエッチでいやらしい臭いをさせてる汁に媚薬みたいな効果があって、私\nを強制的に発情させてるんだわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「絶対そうに違いないわ……！　じゃないと、私がこんなに発情して、気持ち\nよくなるわけがないもの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　どこまでも汚い触手ね……！　反吐が出るわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぎっ！？　あっ、あああぁっ！？　な、なにっ！？　急に触手の動きが激\nしくなって……ひあああぁ！？　あっ、ああああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お、オマンコが思いっきりめくられてるぅ！？　触手のデコボコした部分が\n、オマンコを無理やり引っかいて……んひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　来るっ！　オマンコの奥から、凄いの来てるぅ！？　イヤ\nっ！　イキたくないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手相手に無理やりイカされるだんて死んでもイヤなのに、気持ちいいのが\n止まらないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひいいぃ！？　オマンコの膣内で触手がビクビク震えながら、大きく膨らん\nできてるっ……！？　まさか、何か出すとでもいうのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いっ、イヤあああああぁぁぁっ！　ぬっ、抜きなさいっ！　今すぐその汚ら\nわしいモノを抜いて……あはぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクぅぅぅっ！　触手にオマンコホジられながら、イッちゃうう\nうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「きゃあああああぁっ！？　オマンコの膣内に熱い汁みたいなのがどぴゅどぴ\nゅ出てるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ドロドロした濃厚な触手汁が、子宮に流れ込んできてる感じがするわっ！　\nこんなに出されたら、妊娠しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手の赤ちゃん孕むなんてイヤあああぁっ！　こんな醜い化け物の母親にな\nんてなりたくないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、あんんっ！　ま、まだ出てるぅ！？　オマンコに入りきらな\nいくらい、いっぱいびゅーびゅー出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もう出さないでぇ！　私の膣内に汚らわしい汁を注ぎ込まないでえええぇぇ\nぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うっ、んぐっ……！　辱められて純潔を奪われるだけでなく……触手汁を膣\n内に出されるだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手に孕まされて、苗床になるくらいなら……本当に死んだほうがマシだわ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「これ以上、無様な姿を晒すなんて耐えられないっ……！　くっ……！　殺せ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉ……！？　殺せと言ってるのに、どうしてまた触手がオマン\nコの膣内でうごめいてるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「まさか……あれだけ出したのに、まだ私を犯すとでもいうの……！？　やっ\n、イヤっ……！　もうやめてえええぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああああぁんっ！　あっ、あっ！　んっ、あはあぁ！？　またオマンコの膣\n内で触手がズルズル動いてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うねるようにグリグリされながら、ぶっとい触手がオマンコをズポズポして\nっ……！　いあああぁ！　さっきよりも感じるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手汁のせいで滑りもよくなってるから、もっと奥まで入ってくるぅ！　私\nの子宮口に触手の先端が当たってるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの部屋の入口をトントンされると、感じすぎちゃうっ！　気持ちよ\nくて、子宮口が開いてしまうわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お願いだからもうやめてっ！　これ以上、私の大事なところを触手でホジホ\nジしないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「さっきよりも激しくズポズポされたら、オマンコに溜まってる触手汁が全部\n子宮に流れ込んできちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そんなことになったら、子宮が全部触手汁で満たされちゃうわっ！　私の卵\n子が触手汁と合わさって、受精しちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「妊娠だけは絶対にダメぇ！　触手に孕まされたら、もう姫騎士でいられなく\nなるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　ダメって言ってるのに、触手の動きがさらに速くなってる\nっ！　本気で私のことを堕とすつもりなのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんな……こんなことって……！　姫騎士である私が触手に負けるなんて、\nダメなのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　気持ちいいのと気持ち悪いのが、交互に襲ってくるぅ！　\nこんなの味わわされたら、耐え切れないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「イッ、イクッ！　またイッちゃうぅ！　触手に嬲られて、辱められながらイ\nッちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひぃ！？　あっ、やああぁ！　触手の先端が子宮口にキスしながら、ビク\nビク震えてるわっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お願いっ！　もう膣内に出さないでっ！　今出されたら、本当に妊娠しちゃ\nうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ！　やっ、イヤっ！　イカないでっ！　何でもするから、触手汁を子宮\nに注がないでえええええぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひあああああぁぁぁ！？　ま、またオマンコに触手汁がびゅーびゅー出てる\nうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「今度はオマンコじゃなくて、子宮に直接注がれてるぅ！？　私の大事なとこ\nろが、穢れた汁でいっぱいになっていってるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんなの、絶対に妊娠しちゃうっ！　ボテ腹になって、触手を産むことにな\nっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んひいぃ！？　おっ、おほぉ！？　触手に孕まされることを想像したら、勝\n手にオマンコが締まるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私の身体、おかしくなってるわっ！　触手でメチャクチャにされて、完全に\n堕ちちゃってるのぉぉぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ……ああぁ……！　私……触手に負けちゃったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「無様にイカされ続けて……無理やり孕まされて……触手の赤ちゃんを産む、\n苗床になっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うっ、ううぅ……こんな惨めな姿、他の人に見せられないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「このまま触手が私を殺してくれないなら……苗床になるしか道はないのね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お父様……お母様……私はもう祖国に戻れません……触手のお嫁さんになっ\nて、死ぬまで触手を産み続けます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ！？　触手がズルズルオマンコから抜けていって……！　あは\nあああぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「きゃああああぁっ！？　全身にドロドロの濃厚触手汁がびちゃびちゃかけら\nれてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いやらしい臭いが身体に染みついちゃうっ！　エッチな臭いでいっぱいにな\nるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんな下品な臭いをさせる身体になるなんてイヤあああぁ！　殺してっ！　\nもう生き恥を晒させないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あああっ！　あっ、んっ、あはあぁ！　この臭いでまたイッちゃうっ！　気\n持ち悪い汁を浴びせられながら、イクぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……はああぁ……オマンコも身体も触手汁まみれだわ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……私をたくさん穢せて、触手たちも悦んでるみたいね。満足してく\nれたみたいで何よりだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「それにしても、いくら演技とはいえ貴方たちにはたくさん酷いことを言っち\nゃったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「お詫びと言っては何だけど、今度は姫騎士以外のシチュエーションで犯して\nくれていいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方たちが他にどんなプレイで悦ぶのか……凄く楽しみだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}