{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「休憩中の母を襲うとは、ふふっ、我が息子ながらなかなか大胆なことをして\nくれるではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それで、こうして母の胸にチンポを押しつけて……ンッ、パイズリでもして\n欲しいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいだろう。せっかく息子から母のことを求めてきてくれたのだからな。特\n別に相手をしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さて……っと、こうして、胸の間にチンポを挟んでやればいいのだろう？　\nンッ、もうこんなに硬くなっているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「このガチガチに硬くなったチンポを……しっかりと、母の胸で……んふっ、\n挟みこんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうだ母の胸は？　やわらかくて、気持ちいいだろう？　さあ、動\nかしてお前のチンポをしごくからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、んふぅっ、何度見ても、大きいチンポだな……。胸から亀頭がはみ\nでてしまうほどだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の胸だって、小さいわけではないのだぞ？　お前のチンポは、本当に立派\nだな……。こうして、しごきがいもある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら、胸をぎゅっと、締めあげて……お前のチンポに、ンッ、胸を密着させ\nて……んっ、んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、チンポの熱を、すごく感じるぞ……。はぁ、はぁ、谷間で、ビクビク\nとしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、母の胸は気持ちいだろう？　お前の腰も、震えてしまっているでは\nないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そんなかわいい反応をされたら、母はもっと、お前のことを気持ちよくして\nやりたくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうだな……この真っ赤になっている亀頭を舐めてやろうか……。こうやっ\nて……んっ、んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぷっ。ふふっ、舌での刺激もくわわると、ますます気持ちいい\nだろう……？　んちゅるっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「だが、あんまりすぐに射精してしまわないよう、耐えるのだぞ……？　ちゅ\nっ、ちゅぱっ、我慢するのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら、ここはどうだ……？　んれろっ、先っぽ……舌で舐めまわして……れ\nろれろっ、れろれろぉ～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ。こら、チンポを暴れさせて、私の舌から逃げようとしても無駄\nだぞ……？　んっ、そんなことするなら、こう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと、胸を使って、チンポをぎゅ～っと押さえつけてくれよう。ふふっ、\nチンポがますますパンパンになったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「亀頭が充血して……んちゅっ、破裂しそうなほど膨れているぞ……。れろ、\nれろれろ……べろぉおおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「れろれろれろぉ……っ！　んちゅっ、ちゅぷっ、ちゅぱっ！　チンポの熱を\n感じて、母の身体も火照ってきたぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「乳首もこんなに硬くなってしまっている……んふっ、お前のチンポが、あま\nりにもいやらしいからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「だがお前も、母のこのいやらしい姿を見てチンポを勃起させたのだろう……\n？　ふふっ、違うか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「チンポに溜まっている母への欲望を発散したかったのなら、そう言えばいい\nものを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母は、お前のことを拒むことなど決してないのだからな……。んっ、ちゅぱ\nっ。んふぅ……ちゅっ、むちゅぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅっ、れろっ、れろれろぉ～っ。ふふっ、こうして、もっとし\nごきながら、舐めてやるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、お前の望み通り、ンッ、ちゅるるっ。母の胸と、舌で、んはっ、\n射精まで導いてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「れろっ、れろれろっ、気持ちいいか？　んちゅっ、お前のチンポは、とても\n気持ちよさそうに震えているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、先端がパクパクして、ンンッ、先走り汁も滴ってきているではな\nいか……んふぅ、ちゅるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、この匂いと、味……。んちゅっ、ちゅるるっ、母もどうにかなってし\nまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前にパイズリしながら……んちゅっ、こんなにも全身を昂らせてしまって\nいるなんて……んっ、んちゅるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと激しく、ンッ、胸と舌を動かすぞ……んっ、んちゅぱっ！　お前のこ\nとを、いっぱい感じさせるために、な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、んちゅっ、ちゅるるっ！　れろれろれろぉっ、んふっ、れろんっ！\n　ちゅぱっ、ンッ、れろぉっ、べろぉおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「チンポが、暴れている……んちゅるるぅっ！　んっ、んちゅぱっ、もう限界\nか？　んれろっ、射精、しそうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうだな、いいぞ。ここまでよく我慢した。ちゅぱっ、母の胸に、射精して\nいいぞ……存分に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、ああぁっ！　ああっ、でてる……！　母の胸に、ねっとりとした精液\nがたくさん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。こんなにたくさん……ああ、すごい匂いだ……。ンッ、ま\nだチンポが、胸の中でビクビクしているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、こんなにも射精して……。それほど、母の胸は気持ちよかったか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「当然であろう？　なぜなら、私は母なのだからな。お前のことを誰よりも気\n持ちよくさせられる女だぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さて、母はまた休憩に戻りたいのだが……お前のチンポは、まだまだ勃起し\nているようだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母に甘えたりないのか？　ふふっ、みなまで言うな。母がもっとしぼりとっ\nてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さっき放った精液で、胸がすっかりぬるぬるになってしまっているな……ん\nっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さっきよりも、しっかりと……胸で、チンポのことを押さえつけてやらない\nといけないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ん？　どうした、お前が動くのか？　ンンッ！　胸の中を、チンポが出入り\n……あっ、あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「精液まみれの胸を、ンッ、チンポが、ああっ、こすって……んっ、んふぅっ\n！　アツアツの勃起チンポ……感じてしまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、んはぁっ、そんなに激しく腰を振って……んくっ、精液が、ぬちゅ\nぬちゅといやらしい音をたてているではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「チンポを使って、ンッ、母の胸に、お前の精液を塗りこんでいるのか……ん\nふぅ、お前の精液の匂いが、母の胸に染みつくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。まったく、いやらしいことを考えつくものだな……ンッ、\nそれなら母も、いやらしく応戦しよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅちゅぅうっ！　お前の、チンポに……ちゅぱっ、舌を、這わ\nせ続けてやるからな……んれろぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の胸で竿を、母の舌で亀頭を刺激してやる……んちゅっ、ンンッ、またお\n前のチンポが、ビクンと反応したな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、もっと、もっと動いてもいいぞ？　母の胸を、そのチンポで存分\nに味わうがいい。ちゅっ、ちゅっ、んちゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰の動きが、どんどん激しくなっているな？　んっ、もうイキそう\nになっているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「また、母に向かって、んちゅっ、精液を放ってしまいそうになっているのだ\nろう？　んふっ、いいのだぞ？　ちゅっ、ちゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の身体は、こんなにも昂って……んちゅっ、お前の精液を、欲しがってし\nまっているからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「この、んちゅっ、立派に育ったちんぽから放たれる精液を、もっと、もっと\n感じたい……ンッ、ちゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「だから、遠慮なくしゃせいしてしまっていいのだぞ？　私は何度でも、どこ\nででもお前の精液を受け止める……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら、またこんなにパンパンに膨らんでる。チンポが精液を放ちたいと震え\nているではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぱっ、ちゅっ、ちゅちゅちゅ……っ！　んふぅ、もう、射精\nしそうなのだろう？　もう我慢する必要などないのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前は、その欲望のままに、母に精液を放てばいい……んちゅっ、そのため\nにきたのだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さあ、いいぞ。チンポからお前がため込んでいる精液……んちゅるっ、いっ\nぱい、いっぱい放て……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
