{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あいたたた……。まったく、動物虐待ですぞ。犬の面の皮をなんだと思って\nおいでですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「思った通り、滅茶苦茶厚かったな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかし、どうしたもんか。まともなのが俺とおまえだけっていうのがなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや。このままこの世界に居座るのではないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あーん？　なんでだよ。こんなわけのわからん状況、元に戻したいと思うの\nが普通じゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえ、ご主人の事ですから、ここなら文句も言われないどころかチヤホヤさ\nれてラッキー♪　ぐらい仰るのかと思いまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「望めばハーレムルートも夢ではありますまい。ラッキースケベが連発でウハ\nウハな、永遠の学園生活が続くかもしれませんぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな訳あるか。こう……なんだ、とにかく落ち着かん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「立っているだけで睾丸が縮まるというか……爪先から浮いてるような感覚が\nずっとつきまとっているんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「理屈じゃないんだよ。ここは俺の居場所じゃないって感じが、ひしひしとす\nるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「んー……なんだかもったいない話ですねえ。順応してしまえば楽でしょうに\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「良いから早く、知恵を貸せ。この状況を元に戻すような、なんかヒントでも\nいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そう仰いましても……こうなった原因すらわからなくては」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ひとまずは様子を見るしかないのではありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっそお……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "確かにその通りなのが癪だ。目覚めたらいきなり、だったからなあ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その前に何かこう、明らかな異常があったならまだしも――。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマちゃ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマさーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うおっ！？　なんだなんだなんだ、３人揃って！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もうお昼休みになっているんだよ、チャイム聞こえなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくですわ。どこへ行かれたのかと思えばこんな所に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「目を離していると、おまえはどんな騒ぎを起こすかわからないのです。なの\nで常にウチらと一緒にいなければならないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "解放して欲しいなあ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0073" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お弁当要らないの？　今日もカツマちゃんの好きな物、詰め込んできたんだ\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108110003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私は専属シェフにお願いして、豪華フルコースをご用意しておりますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチ特製のスタミナドリンクとディストピア体験メニューがあるので、特別\nに食べさせてやってもいいのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっほー。これはこれは、聞きしに勝る状況ですなあ。本当にモテモテでは\nありませんか、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「黙ってろ駄犬」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「えっ！？　犬が……喋った！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ま……さか。空耳ですわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「興味深い現象なのです。遺伝子操作でも受けているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「え。おや。これは……何か、予想外の反応が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「良かったなジュンジロー、おまえにもモテ期が来たようで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というか、ただの犬だと思っていたのか、こいつら。みんな？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゅんじろうくんっていうの？　へえ～、すごーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「一体どういう血統の犬なんですの？　見た所、ドーベルマン？　それともシ\nェパード？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「自然発生的なものとは思えない……ぜひ解剖して研究したい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「痛いのは勘弁なのですぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「だーいじょーぶだーいじょーぶ、痛いのはきっと最初だけ……くふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ……オボロ、なんか、暴走し始めたか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "権謀術数を練るのに夢中な時……というか、策士が策に溺れる瞬間に似ている\nというか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「科学魔道部のみなさーん！　ここに絶好の実験体を発見しましたよ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「呼びました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030108110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000806_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「喚びましたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040108110001" ]},
		{"command":[ "SETCHARA", "1", "char_00000806_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「読んだんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050108110001" ]},
		{"command":[ "SETCHARA", "2", "char_00000806_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はっ！？　これは、学園モノによくある、怪しげな部活ネタなのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「オボロ様にマッドサイエンティスト属性まで付加されているとは……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「部費増額と部の存続を叶える為にも、その犬にはぜひとも我が科学魔道部の\n礎になってもらうのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なあに、その功績は永遠に語り継いであげるのです。科学に犠牲はつきもの\nなのですから……くふ。くふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……頑張れ、ジュンジロー。生きろよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ごごごご主人ー！！　助けて下さいよー！　唯一の味方を見捨てるおつもり\nですかー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カツマぁ？　まさか我が部の活動を妨害するつもりですか～？　それならば\nこちらも、活動の成果を披露するのにやぶさかではないのですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……面倒は正直、避けたいんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主じぃぃぃん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108110014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく、しゃーねえな！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}