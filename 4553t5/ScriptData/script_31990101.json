{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はーあ、隊長……。アンタの頼みとはいえさ、楽しい楽しい酒盛りの真っ最\n中に、緊急呼び出しとは野暮じゃないかい？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「よいしょっと。……勝手にベッドにあがったけど、いいよねぇ？　アタシら\nの仲だ。今更遠慮するもんじゃない。……そんで、何かい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「二人で晩酌でもするってのかい？　それとも……。せっかく布団があるんだ\n。ヤることヤっとくかい……。と、おやおやおや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「話が早くて助かるねぇ。なるほど。お口より先に、おちんちんがお返事して\nくれたよ。いーい子だねぇ、隊長のデカマラはぁ……。クククッ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んん？　パイズリで抜いて欲しい？　あは……可愛いこと言ってくれるね。\nちょっと酒臭いかもしれないが……いいよ。自分でズボンを脱ぎな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……そう。そうだ……。おお……♪　コイツは上物だけどさぁ……一体いつ\nから勃ちっぱなしだったんだい？　今夜はシたい気分だったんだねぇ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019901_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103106" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「それをほったらかして酒かっくらってたアタシにイライラしただろう？　声\nかけてくれて良かったのにさぁ……♪　悪かったねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はは♪　ブルンブルン震えてさ。チンポがアタシをせっついてるよ。早くお\nっぱいの中に入らせてーってね。あいよ。ちょっと待ちな。それ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……フフフ♪　どーだい……♪　奈羅苦ねえさんの筋肉おっぱいは♪　もち\nろん中身は脂肪だけどさ、鍛えているから他のヤツよかは硬いだろ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「引き締まってて……。隊長のゴッツい勃起チンポにも負けてねぇ。……んっ\n……。膨らみを……あはっ♪　上下に揺するだけで……重いだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ミッチリ中身詰まってるからね……。これでしっかりシゴいてやるから期待\nするんだね。……はぁっ……♪　はぁ、はぁ、はぁ……アハハ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長……。初めて見るけど、アンタのこれ……かなり長くてやんちゃでかぁ\nっこいいねぇ……♪　アタシの谷間からハミ出してるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「『お前のおっぱいも超ド級だけどな』？　ハハ、よく言われる……。でもさ\n、触れたのは隊長が最初で最後だよ。みんなコレを怖がっちまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ふわっふわでたゆんたゆんなおっぱいとは違うからねぇ。ズシン、バルンッ\nて感触だろ？　『それがいい』？　褒められちまったら仕方ない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「好きなだけ感じていいぜ……。ふぅっ……ユサ、ユサ、って前後に揺らすの\nがいいかい……？　それともこう……股間の上で弾ませて、……んぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ダイナミックにシゴく、方が、見た目にも楽しいかねぇ……？　ん、ふ……\nっ！　ンン……♪　はぁっ、はぁ、んん……んっんぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「『強そうなおっぱいなのに敏感そうだな』？　……クククッ♪　実はそうな\nんだよ……。あっ♪　それに、アタシは奉仕ってヤツが好きでねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長のチンポにご奉仕してお尽くししてるってシチュ自体にも興奮してる…\n…。ぁっ……だってさ、胸で挟んでぐーりぐり動かしてるだけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「きっもちよさそーな顔して、チンポも素直に痙攣してくれちゃって……もう\n、楽しくて楽しくて仕方ないよ。だからね……ん、んー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「今度は追加で、舌でも可愛がってやる……♪　んれろぉ……♪　ぴちゃっ♪\n　ぴちゃ、ぴちゃ……♪　アンタ、尿道攻めって知ってるかい……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「チンポの先っちょの、一番無防備で可憐な穴……。溜めに溜めこんだ精子を\nビュルっと発射するこの穴、を、チロチロ長い舌で舐め回す……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「表面だけじゃなくって、ちっちゃい穴の中まで、濡れた柔らかい舌でほじく\nるんだ。アタシの舌は、細くて尖っているから最適だろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「れろっ……ぺちゃっ、ぴちゃっ、ぴちゃ……チロ……チロっ、にゅぷ♪　ち\nぱっ、ちぱ……ちゅぱ♪　れろれろれろ……んんっん……んー……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ハハハ、チンポってのは変な味がするね……。でも興味あるよ。表面は……\nれろっ、しょっぱいような……。んでもって、中は……れろ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「透明なヌルっとした汁が詰まってる……。れろ、れろ……あぁ、こりゃ我慢\n汁ってやつかい……？　なら舐め取ってやんなきゃだね。……ちゅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ぺろっ、れろっ、れろれろ……アハ……♪　敏感なのはどっちだい……。ア\nタシの舌、気に入ってくれたみたいだねぇ……ちゅっぷっ、ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「舐めれば舐めるほど……んちゅ♪　汁がぴちゃぴちゃぴちゃ音をたてるよ…\n…♪　唾液と我慢汁とで、亀頭もすっかりテラテラにしちまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「愛おしいったらありゃしない……♪　れろっ……れろっ、ちゅ♪　ちゅぅっ\n……ちゅう♪　ぴちゃ、ぴちゃ……ちゅぷ♪　ぷちゅっ、ぷちゅっぷちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ん？　ん？　おちんぽの穴ちゅぽちゅぽ犯されて、竿をたーっぷり刺激され\nるのさ……。おぼっちゃんにはたまらないだろう……？　っちゅっチュッ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「は、ぁ♪　はぁっ……はぁっ、ちゅるっ、チュ……ちゅっ、ちゅっぷっ、ん\nん……♪　んっ♪　んっ♪　ちゅっぱっ♪　ちゅぅっ、ちゅぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「チンポにかかる乳圧……れろっ♪　先っちょをクニュクニュされて、快感だ\nけ与えられながらふさがれて……射精することもできないもどかしさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アハハっ、泣かずに耐えていられるだけでも大したもんだ……♪　アタシは\n隊長の、そういうところが好きなのさ……れろっ、れろ、れろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っんんんっ……！？　おぉ？　そっちからも腰を浮かせて、振ってくれるの\nかい……？　反撃だなんて、ますます可愛いよ……。どれ、勝負だ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アンタの腰振り、と♪　アタシのパイズリフェラ……んんっ、ンッ、んっ、\nんん……！　ぶつかりあう性欲の饗宴ってやつだ……んん、ちゅるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ちゅぅうううう……♪　ぴちゃっ、ちゅぷっ、チュルッ……ちゅぅうっ♪　\nちろ、ちろ……ぬぷっ♪　ぬっぷっ、くっちゅっ、くちゅっ、ちゅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「なんだい……、腰がひけてきてるよ♪　ガツンと来なっ……ぴちゃっ♪　ぴ\nちゃぴちゃぴちゃっ……れろぉ……♪　れろっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ぉっ……♪　ん、んんぉ♪　……ちゅぷっ、ちゅぷっ、ぺろっ、ぺろ……♪\n　はぁっ、はぁ、は、ぁ……はぁ……♪　くちゅっ、くちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「腰……早くなってきてるぜ……？　それに、チンコもパンパンだ……。こみ\nあがってきてんだろ、精子……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシがほじくり出してやるから……んっ、胸で絞り上げた瞬間に出しちま\nいな……いくぜ……。んーーーーっ……ん、んーーーーーっ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「れろれろれろれろ……♪　ぺちゃぴちゃぺちゃ、くちゅ、ちゅっぱっちゅっ\nぱっ……くちゅ♪　くちゅくちゅくちゅクチュ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おぉおお♪　おほぉおお♪　いいね、いいねぇええ♪　景気がいいね……デ\nカい花火みたいだ……♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103201" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「いいぜ、出せるだけ気持ち良く出しちまいな……♪　ビュッビュッ♪　ビュ\nッビュッ……ハハハ、こりゃあいいやぁ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシの青い肌に溜まってく、アンタの白いミルク……♪　官能的じゃない\nかぁ♪　ドップドプ勢い良く流れ込んできて……熱くて感じ入るぜ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「それ、それ……♪　胸で搾って、それくらいかぁ？　うんうん、まだ出るよ\nなぁ……そーりゃっ……♪　おっ♪　おっ♪　跳ねやがる……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁあああああ……♪　しっかり出せたじゃねえか……。アタシも少し、自\n信ついちまったよ。ふぅん……この胸と舌で、こんなにねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アハ、胸がどこもかしこもネチャネチャしてやがる……心地いいぜ♪　なあ\n……なあ、このくっさい汁……♪　気持ち良くて出したんだよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ンフフフ♪　色も濃いしよぉ、体内から溢れ出てきたっつっても、温度もス\nゲかったしさぁ……。随分質のいいタンパク放出してくれたもんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……粘り気の強い、ドロッドロの子種……。こういうの、見せつけられたら\nさ……女は本気になっちまうんだよなぁ……。続けるぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んッおっ♪　おっ……おぉお♪　ザー汁と汗とで滑る、スベるぅ……♪　ん\nはぁああ、ニオイもヤバい領域だぜ……。おっ♪　おっ、ぁっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「なあ……？　ザー汁まみれのチンポなんて、愛情なきゃあ咥えらんないよな\n？　今のこのチンポ、しゃぶるとか頭おかしいよな？　だからさ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あえて、アタシがやってやるよ。隊長……アンタへの忠誠と、愛情を誓うっ\nて名目さ……。よーく見てな……。かぷっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ん……ぢゅぽっ……ぢゅぽ、じゅっぽっ……ぢゅぽ……♪　くははッ、にげ\nぇ……マズい……♪　でも、わかるぜ……これがイイんだよなぁ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「てめぇの女に、ザー汁まみれの……んれろっ、チンポしゃぶらせて、んっ、\nんっ、デカイ胸歪ませて、パイズリさせて……。ん、ぁっ、んぁぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「見下ろして……堪能してくれよ……♪　ぢゅる……ぢゅるっ、ぢゅる……ぐ\nっちゅっ、ぐっちゅっ、れろ……ぢゅるっ、ぢゅっ♪　ぢゅぅうう♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「マズい……♪　マズい、エグい……♪　っはぁっ♪　あぁ、あぁ……♪　れ\nろ……れろっ、ぢゅる……ごくんっ♪　ゴク……レロレロレロ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ハハハ、舌がヌメる……気持ち悪い……♪　んっ、ん、ん、ん、んぅ……♪\n　ぢゅるぢゅるぢゅる♪　ゴクッ……胃もたれするし大変だ、ぜ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「口ん中蹂躙して、……げほっ、絡みついて……ぺろっ♪　でも、困難なら困\n難なほど……隊長に尽くしてるってカンジ、がして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ぢゅる♪　ぢゅる、ぢゅるぢゅるぢゅる……♪　おっ♪　おっ♪　れろ……\nレロ、れろっ、れろ、れろ……ぢゅっ♪　ちゅっ、ちゅっ、ちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んぁ……♪　太くなると舐めにくいっつうの……♪　ちゅぱっ、ちゅぱ、ち\nゅぱちゅっぱっ……ぢゅる……！　くっちゅっ、くっちゅっ、くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ん？　ん？　またブルッときてんのか？　……野暮を言うなよ、何度でも受\nけ止めてやんよ……奈羅苦様の胸はデカいからね……！　ぢゅるるるっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んんんんぉおおお♪♪　ぉおおおおお……♪　口めがけてぇ……連続発射ぁ\nああ……♪♪　おっ、おっ、オッ、おっ……♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_15" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103301" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おいおい、アタシの舌には……そんなにかからねぇよお……♪　ん、ぶっ…\n…♪　んぁっ……あぁ、あぁ……ぷぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おっ♪　おっ、おっ……♪　あぁあああ……♪　コ、コラぁ……舌先で拭く\nんじゃねえ、ぬぐうんじゃねえ……くせぇんだよぉおお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ん！　ん！　んっぷ……！　……はぁあああっ……♪　オイ、全部出た……\nかぁ？　遠慮なんかしてねぇ、だろうな……♪　アハハハ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_14" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「舌の色変わるくらい、めちゃめちゃ出してくれやがってよぉ～。アタシの舌\nがザーメン色になっちまった……。んで？　それで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「コレ……どうしてほしいんだよ？　何？　口を開けて……隊長に見せつけて\n……？　……お、おう……？　かまわねえよ？　……あーん……どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「見え、るか……？　うん。そんで、よーく味わってすすって飲んでくれだぁ\n……？　上等ォ……！　ン……、ん、れろぉ……ぐちゅ、ぐちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ゴク……ゴク……♪　っはぁああああ♪　何度飲んでも味なんかかわんねぇ\nし、マズいし苦いし最悪だよ……。でも、でもさ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_13" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「身体ン中がポカポカして……。アンタの味に変わってく感じして、嫌じゃな\nいよ……。アタシ、隊長に変えられたいんだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「だから今日だけじゃなくてさ……。この、なっがぁあい舌で舐め回されたく\nなったら……すぐに誘えよな♪　いつでもあけておくからよ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_14" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あはっ、あはははっ！？　今度は胸じゃなくって顔かい……！　あっ……待\nちなよ……あんっ♪　精液のシャワーじゃないか……アハハハっ♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_12" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103401" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んんっ……♪　ンンッ、んん～～～♪　目に入らないように、……あっ♪　\nかけたいとこをよーく狙って撃つんだよぉ……♪　……あっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「上手じゃないか……。……フフフ、そこがいいのかい？　額、頬、こめかみ\n……顔全体に、隊長のザーメンが撒き散らされて……すごいねぇ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あはっ……うぷっ……♪　精子の臭いしか感じないよ……！　ムワッとした\n嫌な匂い……。でも、隊長から出たものだからねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「好きになるしか、慣れていくしかないってこった……。……なんだい？　自\n分の色で染め上げたアタシの顔を、見るのがそんなに楽しいのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「盛大にさ、髪の方までぶちまけてくれたもんねぇ……。この貸しは高くつく\nよ？　なんて、ケチなことは言わないつもりさ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「愛しの隊長の、大事な場所から出た汁さ……。これで、味がもっと良ければ\n毎日チューチュー飲んでやるってのに……悔しいねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……んん？　アタシが隊長に甘すぎる？　ククク、アンタがアタシに甘える\nのがうまいのさ……。……可愛くってたまらないよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁっ……。精液、ねぇ……。一度に一か所しかもらえないのがミソってと\nころだね。隊長が何人かいてくれたんなら、顔だけじゃなくってさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシのありとあらゆるところにかけさせてやるし、どんな穴でも貸してや\nるってのに……。一つ、神様にお願いしてみちゃあどうだい」", "NORMAL" ]},
