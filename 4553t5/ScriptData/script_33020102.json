		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　あぁっ、オチンポ……外れてっ……カラダ……掛かって……\n！　最初から、そのつもりだったのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、ダメじゃないわ……あなたの精液を染み込ませてもらえるの…\n…考えるだけでゾクゾクするしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「その代わり……するなら徹底的にしなきゃダメよ？　ほら……ここにも、お\nっぱいにもドピュって出してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んふっ……元気、元気……　本当におっぱいに出せちゃうんだから……あな\nたもよっぽどよねぇ……んっ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ……！　今ので出し切り……？　まぁまぁ、頑張ったわね……ほら、こ\nの辺、あなたの精液でべっとべと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「中に出された分と合わせて……全身がイカ臭くなっちゃったわぁ……まぁ、\n好みのにおいだからいいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「やっぱり噂以上に素敵だったわ……いつの間にかすっかり本気にさせられち\nゃった感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あなたは楽しめた？　そう……それは何よりね。ふふ……これでも、それな\nりに殿方の扱いには長けているつもりなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「次はちゃんとご指名で……なんて、商売っ気を出すのは、あんまり粋じゃな\nいかもね……」", "NORMAL" ]},
