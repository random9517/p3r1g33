{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「さあ、中へどうぞ。あんまり慣れない場所かも知れないけど……別に怖い場\n所ではないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00030201_01", "0", "CENTER", "0" ]},	
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「何か飲む？　お酒も一通りのものは揃ってるから、好きなものを……んっ、\nふふ……もうそれどころじゃないみたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00030201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「本気にさせたことを後悔……？　んふ……期待しているわぁ　でも、あたし\nが満足するまで続けてもらうからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ……いいわ……脱がせて　代わりに、あたしがあなたのを脱がせてあげ\nるから……オスとメスの本能に従いましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「どう……？　あたしのカラダ……ふふ……出てる所はちゃんと出てるし……\nそんなに悪くないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「最高にエロい……？　んふふ……とりあえず褒め言葉として受け取っておく\nわ　でも、見た目だけじゃないかもしれないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほら、この……割れ目の所……どうなってる？　まだ全然触ってないのに…\n…ねとっとしてるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「こうしてスリスリするとぉ……ぷちゅっとオマンコ汁がオチンポに絡んじゃ\nうの……ふふ……それだけずっと楽しみにしてたからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「この勃起オチンポをずぶっと入れたくて……ん、ふふっ、ほら……もういつ\nでもいいのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「さあ……お互いに待ちきれなくなってるみたいだし……そろそろ入れてあげ\nようかしらぁ……ねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「じゃあ……跨っちゃうわねぇ……はっ、あぁぁぁぁっ、くっ、ふぅぅぅぅん\nっ……！　あっ、おぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、あふぅぅ……ほぉら……オチンポが埋まっていくぅ……んんっ、ずっ\nぽり簡単に呑み込んじゃうの……んくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ……硬さも太さも十分合格点ね……まあ、それだけで判断することじゃ\nないけど……でも、悪くないわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「後は、芯がしっかり通っているか……オマンコで試させてもらうわ……んっ\n、うんっ、あっ、んふぅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁ……ズリズリ……擦れるぅ……んんっ、気持ちいいところに、\nちゃんとオチンポのカリが食い込むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ、あぁんっ、んんっ……かなり存在感のあるオチンポだわ……こ\nれで、随分と女の人をヒィヒィ泣かせて来たんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、あふんっ……！　あたしも……今日、その仲間入りをするってワケね\n……あっ、ふっ、はぉっ、あっ、くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「逆……？　ふふっ、それはあなたが泣かされちゃうって意味？　それだけ、\nあたしの技を期待しているということかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「さて、どうなるかしらね……とりあえず……遠慮しないでよさそうなのは間\n違いないみたい……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はんっ、んっ、あぁ……オマンコ……回してあげるわね……ほぉら、ずりゅ\nずりゅ……中のマン汁……混ぜてくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、んふんっ……！　あぁ……ふふっ、聞こえるわよね？　あな\nたのオチンポとあたしのオマンコがちゅっちゅしてる音」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ヌチャヌチャって音がする度に……背筋がゾクってして……奥からまた、い\nやらしい汁が……溢れてきちゃうのよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あっ、ふふ……どう？　堪能してる……？　あたしのオマンコ\nの中……気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あふぅっ……それは、よかったわ……もっともっとオマンコ締め付けてあげ\nるからぁ……トロトロの中……感じてねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふんっ、んふっ、くぅんっ……んふふっ、やっぱり……目はおっぱいに行っ\nちゃうわよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「いいのよ、目を離さなくても。あたしのオマンコご奉仕はね、お客さんの目\nも釘付けにしちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「こうやってぇ、腰を回す度に揺れるおっぱいでぇ……みんな喜んでくれるっ\nてワケ……　んふ……ほら、もっと遠慮せず触ってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あっ、うんっ、あふんっ……んんっ、そう……んっ、ねっ……乳首も、コリ\nコリでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「摘まれながらでも……気にせず、腰を……振っちゃうからぁ……あっ、んっ\n、ふぁんっ、またオチンポ硬くなってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、はあっ、あんっ、んふんっ……！　あんっ、はんっ、あぁんっ、あぁ\nっ……どんどん激しく……するからぁっ……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……！　ここに来て、また膨らませてくるなんて……あなたのオチ\nンポが……深い所まで届いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　下からも突き上げられてぇっ……んくぅ……奥を、先っぽでずり\nゅって擦られるのっ……すごくいいわぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、んぁぁっ……これぇ……そろそろ出したくなってるでしょ\n？　中で、ビクビクしてるの……全部バレてるしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「いいわよ……んっ、後はもう……出しちゃうしかないもんねぇ……中出し…\n…しちゃおっか……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ガマンなんてしたっていいことないんだから……そう……オチンポ絞り込ん\nで……ほぉら……中に……ビュってしなさいっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んんんんんんんっ……！　んふぅうっ……あっ、ふっ……！　出てるっ……\nはぁぁんっ……なかぁ……いっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、熱いの……ぴゅっぴゅって……くふぅ……んっ、ゾクゾク\nするわぁ……濃いのでオマンコ……満たされてくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……んっ、ふふっ、ビクンってしちゃって……どうやらオチンポも\n、しっかり喜んでくれたみたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あたしも、イッちゃったわ……　こんなにいっぱい中出しされたら、そりゃ\nあ誰だってイクわよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あふっ……んんっ、隙間からこぼれて来ちゃいそう……　ちゃんと締め付け\nて漏らさないようにしないと……ねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はふぅ……一旦落ち着いた？　なかなかいいオチンポだったわぁ。私も、い\nつも以上に燃えちゃったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも……んー、まだオチンポは元気みたいだし、もう少し満足させてもらお\nうかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「もちろん……抜かずの続きって意味よ。どう……やる気の方は？　あんっ、\nあっ、はんっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んふっ……夜はまだまだこれからってことね　今度はあなたの方が積極的に\n動いてくれるのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、ふっ、んくぅっ……あぁっ、出したばかりでも……まだまだ、\n全然……やる気……あるじゃなぁい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「うんっ……！　強く……奥をコンコンされるのっ、やっぱりいいわぁ……　\nはんっ、んふっ、んんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「おふっ……やる気オチンポに合わせて……腰を振るぅっ……んっ、中に出さ\nれた精液っ……かき混ぜてくぅ……んっ、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「どうかしら……さっきより、もっといやらしい音が気持ちを高めてくれると\n思わない？　あたし……ドキドキしてるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あんっ……またおっぱい触りたくなっちゃった？　いいわよ……でも、もっ\nと腰を使ってくれないと……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んんんぅっ……！　そうっ……あっ、そこぉ　はっ、ふっ……やっぱり上手\nね……あんっ、あたしの弱いとこっ、バレてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でもぉっ、んっ、んふぅっ……ずりゅっと……濡れ濡れオマンコを絡ませる\nのは、あたしも……得意なんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はっ、んくぅっ、あふっ……んんっ、弱い所どうし……どっちが先に音を上\nげるか……勝負しちゃう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あら……一瞬で降参しちゃうの？　ふふ……どっちかっていうと、\nあなたは甘えたがりってことかしらね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、そういうことなら……んっ、任せてもらうわ……　オチンポが溶けち\nゃう位に……オマンコで蕩けさせてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はふっ、んふぁっ、はぁっ、んぁっ……あん　あぁ……いやらしいガニ股で\nの騎乗位っ……大好きぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「男の人が、気持ちよさそうな顔で、一生懸命イキそうなのを我慢してるの見\nてると……ゾクゾクして、たまらないわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ね、また出したくなってきてるでしょ？　んふっ、歯を食いしばっても無駄\nよ　後は、キュウって強く締め付けて、お漏らしさせちゃうから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……ぷるぷるっ、おっぱい揺らしてっ、後……もう少しよっ！　\n思いっきりっ、オチンポを吸い上げるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、あぁっ、オマンコにも気持ちいいの来てるっ！　このままっ\n、あひっ、もうすぐっ、あっ、あたしもっ……イクからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あぁぉっ、もっ……イクッ！　んひぁぅっ、このままっ、一緒\nにイッてぇぇぇぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104220" ]},
