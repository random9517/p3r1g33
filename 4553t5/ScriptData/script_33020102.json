		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁぁっ……あぁっ、んっ、また……中ぁ……びゅくびゅくっ……\nしてるぅぅ……んふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ほぉぉぉ……これは、効くぅ……んんっ、二回目の中出しぃ……はぁぁ……\nビュクビュクっ……出されてぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「はぁふっ……んんっ、種付けされてるの……熱くて……気持ちいい……素敵\nぃ……んふぅぅぅ……ぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「今度は全部出しきっちゃいましょ……ほら……キュンって締め付けるから…\n…んんっ、ねっ……あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あんっ……出た出た……今のもう一発……オマンコにずくんって……響いた\nわ……気持ちいいの……最高ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコからちょっと漏れてきてる……んんっ、しっかり締め付け\nておかないと……もったいないわね……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00030201_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ちょっと軽い遊びのようなつもりだったけど、途中からは仕事でも\nしないくらい本気にさせられちゃった感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「でも、お陰であたしも堪能できたし……お互いにいい思いができたってこと\nでいいんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「え……？　次回の予約？　ふふ……そうねぇ……あたしも、そんなにヒマじ\nゃないんだけど、どうしようかしらねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルナ" ]},
		{"command":[ "SETTEXT", "「なんて……あなたが相手なら、なるべく時間を見つけてお呼ばれするわ　だ\nから、また普段のお仕事も頑張って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_302_0104310" ]},
		{"command":[ "WAITINPUT" ]},
