{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まずは……協力感謝する。奇跡の星（ミラクルスター）からやってきた、マ\nム、だったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はい、皆さんがご無事でよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290001" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それもあなたの援護あってこそのものだ。それで……あなたはなぜ、ここに\n来たのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私は奇跡の星からの使者として、この地球へやってきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290002" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「使者？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ええ。友好の使者としてです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それは……あなた一人ではなく、その奇跡の星の総意と捉えてもいいのか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「その通りです。あなたがた、地球の人々と友好条約を結ぶために私が派遣さ\nれました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290004" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ですが、たどり着いてみれば地球の方々は侵略者たちから攻撃を受けている\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それに、私自身、この星での活動にかなりのエネルギーを消費してしまいま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エネルギーを消費ってどういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「サイズの違いによるものなのか、こうして姿を現して活動する時間に制限が\n生じてしまっています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「こうした短時間の戦闘や会話なら問題ありませんが、長時間の活動は不可能\nでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「この星に身体を最適化させていけば時間は徐々に増えるとは思いますが、そ\nれにも時間がかかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それに、身体のサイズの違いもあります。私がここで普通に過ごすには、い\nくらかの支障があると思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ただ、それでも友好を結ぶべきあなたがたが危機に陥っているところを見過\nごせずに介入してしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「突然横槍を入れる形になってしまい、もうしわけありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや……あなたの助けが無ければ我々は前線を維持できなかった。先ほども\n言ったが、感謝する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「長官の言うとおりだ。感謝こそすれ、謝罪されることなんてないって。それ\nに、格好良かったぜあんた！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「群がる敵をなぎ倒して、あの硬いやつとか素早いやつにも対応して。大活躍\nだったじゃねえか！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「そこまで褒められると、少し面映いですね。でも、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290013" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、なにやらいつもより興奮している様子」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、まあ、だって巨大ヒーローって燃えるじゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかもピンチに現れて助けてくれるとか。テンション上がらないわけがない\nだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それに、彼女の身体もご主人好みでしょうしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022290002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ばっ、お前、本人の前で変なこと言うなよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕、駄犬、お前ら後で特別訓練室に来い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほらこういうことになるじゃねえか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「無念」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『あの二人はいつもあんな感じなので、気にしないでくださいマム』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022290001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「……ええと、そういうわけで、今は限定的な接触しかできません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290014" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それでも、できればあなた方と友好を結びたいと思います。どうでしょうか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「我々は地球防衛機構EDOとして活動しており、地球全体の決定権を有して\nいるわけではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ゆえに、その求めに今答えることはできない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290016" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ただ、このことは上に良いように報告するし、個人的には私はあなたと友好\nを結びたいと思っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「今はそれしか言えない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。私もそれに賛成だ。力を貸して欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺も賛成だ。正式に友好が結ばれる前だけど、よろしくな！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「皆さん、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290017" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『あ……あれ、なんか意識が引っ張られてる感じがする』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022290002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "『なに、この感覚……もしかしてマム、制限時間が近づいているんじゃない？\n』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022290003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「残念ながら、今回はそろそろ時間のようです。ですが、あなた方が戦う時、\n必ずまた現れると約束しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290018" ]},
		{"command":[ "SETCHARA", "0", "char_00021001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「奇跡の星から正義のために、私、マムがそう誓います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ありがとう。これからも、よろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「消えた……本当に別の星の存在なんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あの巨体が一瞬で消えるというのは、活動時間というものも本当のようだな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それにしても……あの攻撃力は凄まじかったな。形態変化でどのような戦況\nにも対応できる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「彼女が味方でよかったと思うよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022290003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだな……さて、ひとまずは戦闘の後始末だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「全員で現場の整備を行うぞ。雄雌牙建設に連絡を入れて、作業員を送っても\nらうまで瓦礫の撤去と整地だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へーい。あー、巨人になれるならこういう作業も楽なのにな。瓦礫なんか指\n先で弾き飛ばせるだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「グチグチ言わずにさっさと動け。それと……さっき言った訓練から逃げたら\n、お前を瓦礫の一部にするからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、たまにマジで怖くなるよな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あれで一応グレートルナリアムの後継者ですからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「あの～……長官？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022290004" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「む、頼母木か。休んでいいといったのに来たのか……まあ、真面目なお前ら\nしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022290012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「ええ。えっと、戦闘に勝てたみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022290005" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、それそれ。危なかったんだけどな、突然光とともに巨大な女性が出現\nしてな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「バッタバッタと敵をなぎ倒してくれたんだ。格好良かったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの戦いを見られなかったのは残念だったな！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『むしろ誰よりも近くで見ていたのですけれどね』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022290020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。あの強さは頼もしかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……彼女がこちらに友好的で助かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022290004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「あ……あはははは。そうなんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022290006" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでもここからはるか遠くにある奇跡の星からやってきた異星人らしい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「侵略者と違って、俺たちと友好を結びたいんだと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

