		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「今までにない加速……これなら、追いつけるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「フルスピード！！　いけえええええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「並んだっ！！　Ｍ．Ｏ．Ｅちゃん、止まって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780002" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「止まらない！！　止まらないわ、このエキゾーストノートは！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780001" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ハイになってないで話を聞いて！！　隊長さんを助ける方法が分かったのよ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780003" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「聞こえるわ、命の鼓動！！　私とカツマちゃんは輝いて１つの命になってる\nの！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780002" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「分かったから、隊長さんにお薬を飲ませた後でいくらでも１つになっていい\nから、まず止まって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780004" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「怪しげな薬なんて必要ないわ！！　私がこの中で一生守ってみせる、カツマ\nちゃんの安全と人生を！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780003" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……一生はさすがにきつい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「仕方ありません……少し、乱暴にしましょうか。Ｍ．Ａ．Ｍ．Ａさん、もう\n少しだけ速度を上げて、一瞬でいいから先行してください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023780002" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「今も目一杯限界だけど……ソレイユさんの力があれば、はああああああっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780005" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「くおおおおっ、内臓が後ろに引っ張られるような加速Ｇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023780001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ははは、思い出すな、この感覚。崖から加速をつけて飛び降りたときとよく\n似ている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023780001" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もう少し……くっ……うっ、追い抜いた、先行したわっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780006" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ここでアクセル全開、ハンドルを右に！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃあああああああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780004" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐえええええええええええっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「な、な、な……バスの車体で道路を塞ぐなんて道路交通法違反！！　危険運\n転よ！！　許しません！！　お仕置きですっ！！　フルドライブっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780005" ]},
		{"command":[ "SETCHARA", "0", "char_00011101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うげっ！！　いきなり放り出さないでくれ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんは私が守護るっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780006" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「……こうなったらＭ．Ｏ．Ｅちゃんは止まらないわね。皆降りて。私があの\n子を止めるわ……フルドライブっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780007" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａさんが抑えてくれている間に隊長を保護しましょう……ニャ\nンコ先生？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023780004" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや、格好いいと思ってな。私も変身とかしてみたい。忍術でなんとかなら\nないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023780002" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「マシンニャンコ・ワゴンとかそういうのですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023780002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうそう。マシン忍術とか需要がありそうじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023780003" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「２人とも馬鹿なこと言ってないで、行きますよ！！　私とジュンジローさん\nは隊長を追うので、ニャンコ先生は薬の用意を！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023780005" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「了解ですぞ。ご主人様は少しばかり恐慌をきたしておりますからな。２人が\nかりで抑えましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023780003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「分かった。ええと、どこにしまったかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023780004" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふふ、交通違反者に容赦はしないわよ。覚悟はいいかしら……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780007" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「この戦いが終わる時、どちらかは生き残り、どちらかは死ぬ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023780008" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「望む所よ……フルドライブ形態、アターック！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023780008" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
