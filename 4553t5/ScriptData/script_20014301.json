{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「初めまして、女王様。若星マキです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990001" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「えっ、女王様どうしちゃったの？　こんな一般保育士さんなんか招集しちゃ\nって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……わざとらしい驚き方をするな、ジェスタよ。よく来てくれたな、若星マ\nキ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990001" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いや、操年魔術師。マキ・アーリスター」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ。だって、このまま元の世界にいたら大変なことになるらしいもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990002" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「いろいろ考えたけど、私はもっとこどもたちのお世話をしたいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あの～、女王様？　いったいどんな言葉でこの人を引っこ抜いてきたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「マキには元の世界にいたらどうなるのか、未来をみせてやっただけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990003" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「私はいずれ、私の世界にいる正義の味方に倒されちゃうの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990004" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ひどいわよね？　私はただ人々を若返らせて、私の保育園でお世話をしてあ\nげたいだけなのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「保育園で、永遠に子どものまま、家族や仕事を忘れるくらい私に甘やかされ\n続けるのよ……。ふふ、うふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990006" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょっと、女王様！？　この人、ガチの悪人なのでは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「まあたしかに、少々子ども好きがすぎるところはあるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990004" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「少々って具合かなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ところで私はなにをすればいいのかしら？　そこにいる道化師ちゃんを若返\nらせればいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990007" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、私のセンサーがビンビンいってるわ。道化師ちゃん、あなた若返っ\nたらきっと私好みの子どもになるわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「私の操年魔術がどういうものか、この場で披露するのにちょうどいいし……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　その、今回はパスで。各種素材が用意されていないので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あら残念」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990010" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「マキよ。お前には私の息子、カツマをここに連れてきてもらいたいのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990005" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「女王様に息子がいたなんて。息子ってことは……何歳？　どこ保育園？　て\nいうかＬ〇ＮＥやってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990011" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いや、保育園児ではない。もう大人だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990006" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990012" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「この人、子どもにしか興味ないんだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ていうか女王様？　カツマを無理やり連れてくるのはナシって言ってません\nでした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「い、一時的に顔を見たいだけだ。その……以前のように単独で地球に行くわ\nけにもいかんからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990007" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ……なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "ムスコニウム、足りなくなってるんだなぁ……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022990009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「というわけだ。マキよ、吉報を待っているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010022990008" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「まかせて。女王様に救ってもらった恩は、ちゃんと返すわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990013" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほら、カツマ。次はあの店よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいエファ、ちょっと待て」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ある日。俺は荷物持ちとしてエファに同行していた。せっかくの休みだっての\nについてねぇ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「今日はいろんなお店で安売りが重なってるの。この機会を逃すわけにはいか\nないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからってなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「あの～、すみませ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990014" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "チラシ配りをしている女性に声をかけられた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「こちら、今度新しくできる保育園のチラシでして～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990015" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へぇ、そうなんだ。でもなんで俺たちに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「えっ、ご夫婦ではないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990016" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カツマ、なにをしているの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、いやその……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「なんのチラシ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "少し先を歩いていたエファが、足を止めていた俺のところに戻ってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「保育園だってさ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夫婦と間違えられたことについては……まあ、言わなくてもいいか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふうん、あたしには必要ないわね。さあ、いくわよ。タイムセールは待って\nくれないんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっとは休憩させてくれよ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「……へぇ、あの子がカツマくんね。あんっ、センサーがビンビンだわ。絶対\n子どもにしたらかわいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990017" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隣にいた褐色の女性も、若返ったらさぞ素敵なようじょになるでしょうね…\n…ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、お仕事しますか……リジュヴネート！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010022990019" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「急に変な声をだしてどうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なにか違和感が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうなの……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえもなんて声だしてんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「う、うるさいわね。ちょっと立ち眩みがしただけよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022990008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って、エファはすたすたと先に行く。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "fALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "両手に荷物を抱えた俺はよたよたと後ろをついていき、貴重な休みが終わった\nのだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご、ご主人！　ご主人！　大変ですぞー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？　なんだよ朝から騒々しいなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てかジュンジロー、なんかお前デカくないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そんなのんきなことを言ってないで、まずは鏡をご覧ください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022990002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「鏡……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
