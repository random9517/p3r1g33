{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「ごきげんよう、隊長さん。お姉さんをこんなところに呼び出して、何をしよ\nうというのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00015501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「……言わなくてもわかっているわ。お姉さんに、ご奉仕……してもらいたい\nんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00015501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「ええ、それがあたしのパワーアップに繋がる。それは噂に聞いているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「そうね……海の平和を乱す地上の男なんて、興味がないのだけれど……でも\n、隊長さんは特別」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「いつもあたしたちを率いて頑張って戦ってくれているし……ご褒美に、たー\nくさん気持ちよくしてあ・げ・る。ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00015501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「あたしの足、この触手に興味あるんでしょう？　しょうがないわね……ちょ\nっとだけよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00015501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、隊長さんの生殖器、見せてちょうだい。……え、呼び方が堅苦\nしい？　チンポ……って呼べ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「もう、お姉さんにそんな恥ずかしいことを言わせて、それでビクビクと元気\nにふくらんでいるなんて……悪いチ・ン・ポね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「んぅ、先っぽからちょっと潮みたいな臭いが漂ってきているチンポ、ふふふ\nっ、嫌いじゃないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、こうして……どう、お姉さんの触手。いつもお手入れを欠かし\nていないから、スベスベでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「それにこの吸盤……ほら、パンパンにふくらんでいるチンポに、もうキュウ\nッて吸い付いちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「チンポにお姉さんの吸盤の跡がついちゃうかも？　ふふふ、他の子にも手を\n出しているのに、それはちょっとまずいかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「でも、イケナイことばっかりしているチンポには、これくらいのお仕置きは\nしておかないとダメよねぇ……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「こうして触手をうねらせて、ゆっくりと上下に……あら、吸盤が吸い付きす\nぎて、皮が引っ張られちゃってるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「でも、これくらいきつい刺激のほうが、隊長さんにはちょうどいいんじゃな\nいかしら？　ふふふっ、どう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「それに先っぽからイカみたいな臭いのお汁があふれてきていて……んぅ、も\nう根元のほうまでベトベト」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「これをクチュクチュ、まぶすように動いて……んぅっ、ほら、吸盤がちょう\nどいいくらいに剥がれてきたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「もう少し早く動かしても大丈夫かしら？　……ふふっ、大丈夫そうね。チン\nポ、もっと刺激がほしいってあたしにおねだりしてきているもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「しこしこ、しこしこ……あん、もう、チンポ、ちょっとビクビクと暴れすぎ\n。上手くしごけなくなっちゃうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「悪い子は、もっとぎゅーってきつく締めてあげないとダメみたい。ほら、根\n元も先っぽも、ぎゅーっ、ぎゅーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「あらあら、締められるのが感じちゃう？　チンポ、お姉さんの触手を押し返\nす勢いでふくらんできているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「特に先っぽ……ぷっくりとしてるところがパンパンになってる。……ここが\n特に敏感？　そうなのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「じゃあ、この出っ張りの裏側に触手を絡ませて……ぎゅっ、ぎゅっ……つい\nでに、吸盤も張り付かせて……弾くように……あはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「どうかしら？　地上の女には与えられない刺激……楽しんでもらえている？\n　あぁ、その切なげな顔、とってもいいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「見ているだけなのに、あたしまで胸が高鳴って……うっ、あぁ、お腹の奥が\n疼いてきちゃうの。はぁ、んんぅっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「もっと、もっとそんな顔を見て……エッチな声、聞かせてちょうだい。チン\nポの先からお汁、いっぱいあふれさせて……はぁ、あんんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「透明のお汁が段々白く濁ってきていて……スンスン……ふぁぁ……臭いも濃\nくなってるぅっ、はぁ、んんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「いいわよ、隊長さん。もう我慢できないでしょう？　お姉さんの触手にチン\nポいじめられながら、いっぱい射精してちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「触手にギュって締められたチンポ、可愛らしくビクビクさせて、真っ白なお\n汁たくさん出してっ、チンポ汁、出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「うんと強く締めたまま、先っぽへ向かって絞り出すようにしごいてあげるか\nら……ほら、きて、きてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「あぁ、チンポがビクビクして……先っぽが広がってるわ。出るのね？　いい\nわよ、お姉さんにいっぱいザーメンぶっかけてぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「きゃっ、あんんっ、凄い……出てるっ、熱くてドロドロの精液、いっぱいき\nてるぅっ、ふぁあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015501_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「んぅっ、あぁ……こんなに粘っこくて、臭いも強い精液……ふふ、エッチな\n隊長さんらしい、とっても素敵な精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「あんっ、その気持ちよさそうにうっとりしている顔、いいわ……全部、絞り\n出してあげたくなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「ふふっ、イッたばかりのチンポを刺激されると、くすぐったい？　でも、こ\nれもあたしが強くなるためだから、我慢して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「あらあら、お姉さんの触手もおっぱいも、精液でドロドロ……ふふっ、でも\n、この感触……嫌いじゃないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00015501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「いつも使っている乳液より、あたし好みの磯の臭い……ううん、それだけじ\nゃなくて、とても官能的な臭い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「こうして、隊長さんの臭いを染み込ませれば、強くなるかしら？　ふふふっ\n……見ていると、興奮しちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「あら、またチンポが元気になってきちゃってる。さすがはあたしたちを率い\nている隊長さん、とってもタフね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウルスラ" ]},
		{"command":[ "SETTEXT", "「ふふっ、気が向いたら、またお姉さんを誘ってちょうだい。楽しくて気持ち\nいい、パワーアップの特訓に……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_155_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}