		{"command":[ "PLAYVOICE", "008_0303132" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「な、なんですか……これは……胸の中でドクドクいって……あ、あぁっ……\n胸に、流れ込んでくるっ……うあっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303133" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はっあぁっ……それにすごい匂い……ここまで匂ってきます……隊長のザー\nメン……すぅ……んっ、ふぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303134" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ンンっ……ま、まったく……私の胸をこんなに……汚して……最悪です……\nはぁぁ……最悪に決まっています……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303135" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はぁ……はっ、はぁ……はぁはぁ……これで全部、ですか……どれだけ溜め\nてたら、こんなに出せるんですか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303136" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「それだけ気持ちよかったということ……ですか……まあ、そう言うことなん\nでしょうけど……んっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303137" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「な、なんですか……急にお礼など言って……こんな状況で胸を褒められても\n嬉しくもなんともないです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303138" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はあ？　照れてなどいません……！　当たり前です、必要だから付き合った\nだけで……他意はありません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303139" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「無理をするな？　いや、無理などしていませんが……はい？　い、嫌ならや\nめる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303140" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ぐっ……それは困ります……私には隊長が必要なんです……わかりました、\n次回もご奉仕させていただきます……」", "NORMAL" ]},
