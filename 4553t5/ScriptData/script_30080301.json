		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「……それで、私はどうすればいいんですか？　胸で奉仕をしろと……？　は\nぁ、くだらない……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
