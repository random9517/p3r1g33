		{"command":[ "PLAYVOICE", "008_0303102" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「いえ、不満などありませんよ。反抗するつもりはありません。ええ、隊長の\nおっしゃる通りにします……パワーアップのためですしね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303103" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「胸をはだけましたが……はい？　恥ずかしいかって……当たり前です、男に\n見られて悦ぶ趣味はありません」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303104" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「綺麗なおっぱい……？　大きい……？　意識したことがないので、わかりま\nせんが……やるなら早くしてもらえませんか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303105" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ジロジロ見られても不快なだけです。はあ？　これも奉仕の一環……？　バ\nカバカしい……これだから男は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303106" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「……ッ！？　は、はあ？　ちんぽを欲しがってるわけではありませんっ！　\nさっさと終わらせたいだけですから！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303107" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ですから、お望み通りではなく……いやっ、あぁっ……いきなり、そんなも\nのを押しつけないで……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303108" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「胸をもっと寄せあげろ？　わかりましたから……グリグリしないでください\n……こ、こうでうすか？　もっと強く……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303109" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「くっ……なぜ私がこんなことを……ほら、これでいいですか？　うぅ……言\nわれた通りにしてるんですから、早く出してください……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303110" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「あっ、くうっ……んんっ……ちょっと、なんで動く必要が……あっ、くっは\nぁっ……胸が、擦れて……んんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303111" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ち、乳マンコ？　ふざけないでくださいっ……私を侮辱するつもりですか？\n　それのどこが褒め言葉なんですか……あっ、ぐっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303112" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「確かに……隊長のちんぽは、とても熱くてガチガチに硬くなっていますが…\n…これが、感じている証拠……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303113" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「そうだとしても……こんな風に物のように扱われるのは……んっ、ふっ、ふ\nうっ……いい気分はしませんっ……ンっ、くぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303114" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はぁ、ンっんんっ……わ、わかりました……隊長が悦んでいるのは、わかり\nましたから……早く、イってください……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303115" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ええ、先ほどから……ちんぽの先端が、ヌルヌルしてて……すごく気持ち悪\nいです……んっ……ふっ、うぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303116" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「言われなくても、わかっています……はっ、んっくっ……はい、隊長のちん\nぽが……私の胸の中を出たり、入ったりしてます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303117" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「どうと言われても……んっ、んんっ……イヤらしいです……こんなことをし\nて悦ぶなんて、隊長は変態です……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303118" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「は、はあ……私が興奮？　なにをバカなことを……ンっはぁ……はっ、くっ\nうぅ……余計なことを気にしなくていいです……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303119" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「なんですか……乳首が勃ってきた……そんなはず、ありません……ですから\n感じてなどいませんっ……あ、あぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303120" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「隊長は……自分のことだけ考えて……早く、射精を……私だって恥ずかしい\nんですから……あっ、くっううっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303121" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「ひうっ！　はっ、はっ……あぁっ、なんですか……胸を擦りつければいいん\nですか？　はっ、うっ……こ、こう……ですか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303122" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……どんどんちんぽが……速くなって……はっあぁっ……あっ\n、ンっ！　くふっ……ん、んんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303123" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「こ、声は……違います、我慢などしていませんんっ、んぅぅ……あ、熱い…\n…隊長のちんぽが、擦れて……胸が熱くてっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303124" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……くっ、ふっふぅっ、ンン……ま、まだですか……いつまで\nこうしてればいいのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303125" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はぁはぁっ……な、なんですか……もう出そうに、なった……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303126" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「そ、それなら……早く出してください……は、早くっ……！　んっ、んんっ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303127" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「んふぅっ……い、いいですよ、このまま胸の中に……出していいですから…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303128" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「わかっています……ちゃんと、胸で受け止めますから……はぁ、はっ……は\nぁあっ……ンンっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303129" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「早く……ンっ……出して、ください、ってばぁ……あっ、ああっ……ん、ん\nっ……んはぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303130" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あっ、あぁ……ちんぽがまた大きくなって……あっ、ああ\nぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0303131" ]},
		{"command":[ "SETNAME", "ピースムーン エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「くっはぁぁっ！　んっ、んん～～～っ……はっ、あぁぁっ……うっ、ううっ\n……ぐっ、うっ、はっはぁぁっ……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000803_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
