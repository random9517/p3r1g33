		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こいつっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "謎の影" ]},
		{"command":[ "SETTEXT", "「！！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ！　ちょっとぉ！　逃げる気！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「このぉ！　待ちやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「セレーナさん、深追いは無用です！　罠かもしれません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうすんだよ！？　このままほっとくのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今は助けを待つんです。食堂に戻りましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「少しでも、事件の真相に迫れる手がかりを探したいところですが、それは夜\nが明けてからでもいいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうね……。もうダイヤナちゃん、怖いのイヤ……早く朝にならないかなあ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0123" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ねえ、セレーナちゃん。寝てる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……寝てねえよ。さすがに私も、神経ピリピリしちゃって眠れやしない。い\nつ、どこからあいつらが見てるかと思うと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120006" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうよねえ……オボロちゃんは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120005" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……オボロちゃん？　もしかして、寝てるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120006" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「寝てはいません。考えています。どうしてあいつらは、相手が一人のときに\nしか襲ってこないのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120005" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そういやそうだな。あの強さだったら、何人かまとめてでも相手にできそう\nなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120007" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そして、犠牲者があの順番だったのか。なにか、ウチは見落としているよう\nな気がしているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120006" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「見落としてるって、なにを？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120007" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「わかりません。それを、もう一度見直してみたいんです。明日、夜が明けて\nから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120007" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふあぁああ……結局、ぜんぜん眠れなかったぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120008" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんたちはね……。セレーナちゃん、なんだかんだ言って大いび\nきかいてたわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120008" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんなことはどうでもいいです。雨の後ですから望み薄ですが、タイヤの跡\nを探してみてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120008" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「タイヤの跡って、長官のか？　なんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120009" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「長官が本当はどこに行ったのかが知りたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120009" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いや、だって長官は警察に行ったんだろ？　あと、ＥＤＯ本部に連絡するっ\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120010" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いいから探してくださいバカ犬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120010" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ！　もしかしてオボロちゃん、長官が本当は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120009" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010106120011" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「まさか、長官！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120010" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いや、いくらなんでもそりゃないだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120011" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え！？　えええええええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120012" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カグヤちゃん！？　どうして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120011" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「エファナティカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120013" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010106120001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「エファさままで！？　い、いったいどうなってるのぉ！？　あ！　やだ！　\nダイヤナちゃんわかっちゃった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120012" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わかったってなにが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010106120014" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「この人たちもしかして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120013" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "カグヤとエファナティカ" ]},
		{"command":[ "SETTEXT", "「うがあああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010106120002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "-300" ]},
	{"command":[ "SETCHARA", "1", "char_00000301_01", "7", "CENTER", "300" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやぁあああああっ！　やっぱりゾンビになっちゃってるぅ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106120014" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
