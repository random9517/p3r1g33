{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0195" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジでどうするんだよお前ら。このままだと経費だけで倒産だぞ」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえば……立派なオフィスですな。家賃も高そうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「まずは形からと思って……この辺りで一番いいテナントを借りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330001" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからそれは業務内容決めてからにしろよ……いや、今はそんなことを言っ\nてもしょうがねえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まず決めることは、なにを売るかだ。そしてそれをどうやって売っていくか\nだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「なにを……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330002" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでもいい。食材、道具、技術、情報、人材。売れそうなものを見つける\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そしてそれを需要のある場所へ売りつける。経営の基本だろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「なるほど……眼から鱗です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023330001" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「眼から鱗じゃねえよ！！　基本だっつてんだろ！！　という突っ込みを我慢\nしているご主人の顔」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それ言ったら我慢してる意味ないんじゃないかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023330001" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ともかく、ともあれ！！　なんでもいいから考えろよ！！　お前らの会社だ\nろ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「それはそうなんですが……正直自分でもなにができるか把握できていなくて\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330003" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「今のところサキュバスが会社経営をしている、という物珍しさしかありませ\nんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023330002" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん……なんか、なんかないのか？　お前らの得意技とかそういうの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「恋愛映画に憧れるのは得意です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330004" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「本を読むのは得意です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023330003" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それ仕事に繋がんの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330005" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023330004" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だろうなあ。そういうのじゃなくて、実利に繋がりそうな得意技だよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、この際得意なことじゃなくても、金に繋がりそうなことならなんだっ\nていい。探し出せ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「言葉だけ聞くとまるで借金の取り立てのようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このまま放置したらそれこそ債権者が押し寄せるぞ。こいつらが債務取り立\nてに立ち向かえるとは到底思えねえし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そうですね～。だから長期的な視点も必要ですよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023330002" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ……ご主人、ならば一つ提案があるのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　食事がまだとか言ったら放り出すからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「食事は大切ですぞ。いやそうではなく、そういうことを考えると我々の知恵\nでは限界があるのではないかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人は中間管理は得意ですが、経営はそこまでですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあそうだな。とっかかりぐらいしか教えられねえな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ならば、ここは経営をよく知る方々にご教授してもらうというのはどうでし\nょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "「で、私たちが呼ばれたと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023330001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00003302_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「全く……緊急の用件と言うからなにかと思えば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330001" ]},
		{"command":[ "SETCHARA", "1", "char_00003302_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「忙しいだろうに悪いとは思ってるよ。けど、なんでかこの二人を見捨てられ\nなくてなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あの……お願いします。なんとなくで始めた事業ですけど、やる気はありま\nす！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330006" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「お二方にメンターになっていただければ、ｓｕｃｃｕＢｉも立ちゆくことが\nできると思いますので……どうかお願いします！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023330005" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、悪い奴らじゃないんだよ。多分。恐らく。きっと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「人を呼ぶ手段を選んで欲しいところではありますが、同意ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、二人のノウハウとかを教えてやっちゃくれねえかな。もちろん、教\nえたくない部分があればそこは隠していいから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ええ、私は構いませんよ。形は違いますが、これも教鞭を執るということで\nすしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023330002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「仕方ないですね……他ならぬ隊長さんのお願いです。一肌脱ぐことにしまし\nょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330002" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ただし、これはビジネスです。彼女らからのコンサルタント料はもちろんで\nすし、隊長さんからもなにか謝礼をいただきますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330003" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「か……金ならない！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人迫真の告白」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「別にお金じゃなくてもいいんですよ。隊長さんと私。男と女……なら、分か\nるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330004" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと……それは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、期待しておりますよ。さて、それじゃあ……まずはビジネスのイロハ\nからですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330005" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「二人とも……経営者たるもの、どんぶり勘定で先を見据えるんじゃあない！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330006" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ひええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330007" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "魅白" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_270_010023330006" ]},
		{"command":[ "SETCHARA", "0", "char_00027001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんたら二人が適当なら、そのしわ寄せは下の者にいくんだよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330007" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「もしも経営が破綻して、資金がショートしたとき……この子の賃金はどうす\nるつもりだったんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「まあ私は一応派遣会社の方から保障は出ますけど～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_020023330003" ]},
		{"command":[ "SETCHARA", "0", "char_00018202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「それは債権者が派遣会社に変わるだけさ。身内を債権者にするなんて、経営\n者からしたら恥でしかないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330009" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「厳しい言葉ですけれど、私も同意します。お金というのは、時にシビアな決\n断を強いられる要素ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023330003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「だからこそ、人の上に立つ経営者であれば厳格に扱わなければなりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023330004" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「起業するのはいいさ。その心意気はよし。けれど、だからこそ行き当たりば\nったりはダメだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330010" ]},
		{"command":[ "SETCHARA", "0", "char_00003302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「自分たちが稼げ、従業員の生活も潤わせる。全員が幸せになってこそ、経営\n者さね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_020023330011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「人の上に立つからには、その責任を理解しなければなりません。よろしいで\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020023330005" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「はい……分かりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_010023330008" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか……あの二人に上司になってもらいたい気が沸々とわいてくるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お二方であればご主人を単騎突撃させて後ろから撃ちまくってきたりしなさ\nそうですしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023330010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「雑務でこき使われたりもしなさそうだ……よしんば使われても、ちゃんと残\n業代とか支払ってくれそうだし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

