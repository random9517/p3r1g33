		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……そうだ……前に突き出してくれると……嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もう、こんなにビクビク……反り返ってるんだな……その、匂いを嗅いでも\nいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、すぅぅぅぅ……はぁぁ……ああ……やはり男の匂い……特に、股間は\n……よく効くな……んっ、乳首が……疼く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、もう……欲望を隠しても仕方ない……私に……奉仕させてく\nれ……キミのチンポ……しゃぶらせて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……んっ、はぷ……んっ、れろ……んっ、れろ……れろ、\nれろぉん……んちゅぱ、ぴちゅ……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、かなり……熟成した匂いがするな……ちゅぷっ、汗と……小\n便と……色々なモノが……織り混ざって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……済まない、悪い意味じゃない……好きな匂いだ……んっ、単純じゃ\nない……複雑に構成されたモノが……心地いいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「えろ、れろ……んっ、少しカスが残ってるな……待っててくれ、んっ、この\nカサのくびれの所……取ってしまうから……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……いや、不潔には思わない……んっ、泥水でも何でも啜って生き延\nびたこともあるんだ……ちゅぷ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んちゅぱ、ちゅぷっ……あぁ……んっ、もう、我慢はやめだ……んぅっ、は\nっ、あっ……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「いつの頃からか……戦いの後に、気分が高揚したままになって……そんな時\n、決まって……乳首が疼いたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「自分の指で……ぎゅっと摘むと……それが、信じられない位に気持ちよくて\n……感じるままに、指でするのが習慣になって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「一度スイッチが入ってしまうと……もう、オナニーが……止まらないんだ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「分かってる……ちゅぷっ、もちろんチンポを疎かにはしない。口だけで……\n少し、物足りないかも知れないが、続けさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ぴちゃ、んちゅぷ、あぁ……んっ、ちゅぷ……んっ、れろ、んち\nゅぷ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……先端がズキズキする……今日は……見られてるからか……普段より\n、もっと乳首が疼いている感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……乳房から押し出すように乳首なぞって……何度も、扱く…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、何度もやりすぎたから……他の人より……肥大するような\n、恥ずかしく勃起するような感じになってるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……こんな、はしたない乳首を見られながら……目の前のチンポを舐め\n回して……意識すればするほど……ムラムラする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んっ、もっと……深く咥えてもいいか？　キミのチンポ……咥え\nさせて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あ、ありがとう……では……はぁんむっ、こぷっ、んっ、くぷっ、りゅぷぅ\nぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んむふぅぅ……くぽっ、ふぐっ、あぁ……やっぱり太いら……んりゅぷっ、\nいっぱいに頬張らないと……んりゅぷ……入り切らない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んくぽっ、チンポ……口で扱くろ……んぷっ、おぷっ、くぱっ、んぷっ、ふ\nぷっ、んりゅぷんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んはぁ……あぁんむ……くちゅぷっ、じゅぷっ、りゅぷっ、じゅぷんっ……\n大丈夫か……？　ちゃんと……楽しめて、いる、らろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……そうか……良かった。もっと、するろ……んくぷっ、はぷっ、じ\nゅぽっ、りゅぷっ、んぷんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ここ……んふぅっ、チンポの血管が……りゅぷっ、んむっ、浮いてる所をな\nぞっていく……れる、えろ、れろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふっ……腰が震えたな……ちゅぷっ、今の……好きだったか？　いいぞ…\n…してやる……ちゅぷ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふっ、慣れてないが……それでも、私の奉仕で……キミのチンポが喜んで\nくれれば……私も嬉しいし……んっ、興奮も、する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、は……ふ……今日は、特別……乳首が疼く。あぁ……指が止\nまらない……はっ、んぅっ、気持ち良すぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ちゅぱっ、くぽっ、んじゅるっ……じゅぷぅっ……ダメだ、チンポ\nに集中しないとな……中途半端では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「な……乳首オナニーを……もっと見たい……な、何を言ってる。こ、これは\n……見せるためにしている訳じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「……だ、だが、キミがそう言うなら……少し、いや、かなり……恥ずかしい\nが……見てて、くれ……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ……見られながら、乳首転がすの……凄い……ちゅぷっ、くぱ\nっ、んふっ、フェラも……止まらないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あむっ、おぷっ、はむ……んりゅぷっ、あぁ……汁が溢れて来る……んじゅ\nぷっ、キミのも……出そうになってるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……んちゅぷっ、私も……もうすぐ……乳首でイキそうだ……んっ、だ\nが……ちゅぷっ、その前に……イカせてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「さあ……らせっ……！　んぶっ、ぐぽっ、じゅるっ、んじゅっ、ちゅぷっ…\n…んじゅっ、じゅるるるるるーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　ふぶっ……んぐっ……んくっ、こくっ、んぐっ、んくっ、んく\nんっ……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……んぷぁ……はぁ……んちゅぷ……凄い量だ……一度に飲みきれない\n位……んくっ、はふっ、んっ、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、私も……乳首で軽くイッてしまった……あぁ、いつも以上の\n快感だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「っと……精液が垂れて来たな……じゅるっ、ちゅぷっ……自分でも驚いてる\nよ。こんなしたがりの自分がいたなんてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……さて……勃起チンポは、まだまだ終わる気はなさそうだ……続け\nさせてもらうよ……んはぷ、くぷぅぅ……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「出したばかりの、んっ、精液が……まだついてる……れろ、これも、綺麗に\nしてやらないといけないな……ぺろ……ちゅぱ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そうだな……そう美味いとは思わないが……だが、イヤな感じは全くしない\n。ちゅぱ……身体の欲情トリガーになる味だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……ちゅぱ……んっ、私の唾液で光ってしまったな……んちゅぷ\n……どこか、して欲しい所はあるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「どこでもいいぞ……んっ、そうだな……亀頭ばかりでなく、この根元の方も\n……ちゅぱっ、した方がいいだろうな……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、チンポの味だ……ちゅぷ、んっ……あぁ、隅々まで舐めてい\nると……んっ、また、乳首が疼いてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んくっ！　あっ……済まない……また、指が止まらなくなって……んっ、は\nぁ……あっ、ちゅぷっ、フェラオナニー……してしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んぶっ、はぁ……クラクラする……チンポをしゃぶる程……身体\nが熱くなって……先端が疼いて……乳首押し潰したら……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「こんなに……よくてっ……また、チンポしゃぶりたくなるっ……はぷっ、ん\nむぅっ、深く……むぐっ、奥まへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「りゅぽっ、くぱっ、じゅぷっ、んっぷ……おぶっ、んんっ、ふぐっ、むふぅ\nぅぅっ……んっ、んぐっ、んぱっ、じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……口からも涎が溢れて止まらない……んんっ、チンポ……クセになる\n……んふぅっ、れる、れりゅぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんっ、尿道の所……んっ、舌先で突くのは大丈夫か……？　んんっ、あぁ\n……また、ジワッとカウパーが出てきたな……んちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふ……出る側から吸ってしまった……んちゅぷぅ……んふぅ……だんだん\n、好きな味になって来たかも知れない……ちゅぱ……ぴちゃ……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……乳首……感じる……また、イキそうになってる……んちゅぷ\nっ、キミは……どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぷっ、ちゅぷっ……近そうだな……んりゅぷっ、くぷっ、分かった……本\n気でするぞ……じゅぽっ、んじゅっ、ぐぷっ、じゅるっ、んじゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……何度も、チンポ扱いてっ……くぽっ、りゅぷっ、んふぅっ……\n射精っ……させるっ、じゅぱっ、ぐぷっ、んりゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁ……あぁ……乳首……また感じるっ……はぁっ、イキそうだ……んぁぷ\nっ、も、もうっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「くぷっ、りゅぷっ……あぁっ……チンポも震えてっ……んりゅっ、じゅぷっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……キミも……んんっ、次のが……出るんだな……んぷっ、分かる\nよ……このチンポの前兆……ちゅぷっ、いつでもいいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、出したい所に……出してくれっ……んふっ、私もっ……一緒に…\n…イクっ……んっ、くぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　おぶっ……んふぅっ……むぐっ……んっ、ふっ……んんぅぅ\nっ……んくっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぷっ……二発目も……濃いままだ……んぐっ、こくっ、飲むのも\n……一苦労する……んっく、こくっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんっ、んく……んっ、こくっ……んはぁ……はふ……んっ……少し落ち着\nいたみたいだな……待ってろ、奥に残った分を吸い出していく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んちゅうぅぅぅぅ……んぱっ、ちゅぷっ……んちゅぅぅぅぅ……ちゅぱっ…\n…んっふ……くぷっ……んこくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はふっ、あぁ……出し切ったみたいだな……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「その、忌憚なく……というのもおかしな言い方だが、私はちゃんと出来てい\nただろうか……？　どうか、厳しい目線で評価して欲しいんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そ、そうか。わ、分かった……それだけ力説しなくても、満足してくれたの\nなら何よりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私としても……色々と疼いたモノが発散出来て、良かったというべきか……\n余り、改まって言うのは恥ずかしさもあるが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「キミにフェラチオ奉仕が出来て……その、とても……良かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「うん……もし、また次の機会があれば……その時は、よろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　チンポ……抜けて……んぅぅっ！　あぷっ……顔にっ……あっ、\n出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぷっ……二発目も……濃いままだ……んぐっ、こくっ、飲むのも\n……一苦労する……んっく、こくっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ぶっ掛けたかった……そ、そうか……それは想定していなかったが……いや\n、大丈夫だ……浴びせてくれ……ん、ふっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、すごい粘りだ……元気な精子が粒になって……これはエネル\nギーの塊のようなものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「まだ出るのか……？　頼む、出し切ってくれ……全部……顔に……濃いのを\n浴びせてくれ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はふ……出し終わった……みたいだな。んっ……ちゅぷ……あぁ、私も……\nまた、イ、イッてしまった……こんな感覚は初めてだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それで……少しは役目を果たせただろうか？　正直、奉仕の経験はなかった\nから……自分でも拙いとは思うのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「大丈夫……だったか。うん、それなら良かった……改まって言うのは恥ずか\nしいが……私も、その、満足したというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「フェラチオで……こんな満たされた感覚を得られるとは……自分でも不思議\nな感じがするよ。だが、悪くない……そんな気分だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「うん……もし、また次の機会があれば……その時は、よろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
