		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「各クラスがなんらかのイベントに参加することになっており、それは地球防\n衛科とて例外ではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113420002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それでは、演劇コンテストの配役について決めていきたいと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「台本の方は、まりあさんが用意してくれたんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「その作者が欠席って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あはは、お姉ちゃんったら気合が入りすぎちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと、タイトルは『紅令嬢（くれないれいじょう）』、キャストは、ヒロ\nインの令嬢」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ヒロイン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あとは王子様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「まあ、相手がいるのは当然ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「のこりはモブ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "２人" ]},
		{"command":[ "SETTEXT", "「雑ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00002402_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「というわけで、配役を決めていこうと思うんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420006" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ヒロインなら私におまかせですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「は？　ヒロインといったら私でしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「え、えっと……。ヒロインは一人ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420007" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、ですから私が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私がやるわ。というか、この私にふさわしい役はヒロイン以外ありえないで\nしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私だってヒロイン以外の役なんてごめんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと、ヒロイン役を決めるのに時間がかかりそうなので、先に王子役の方\nを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420008" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、脚本にメモが。なになに、王子役にはつきみを……これはまりあさんか\nらのメッセージ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420009" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「指名があったので、つきみさんが王子役でいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420010" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えーっ！　わたしだってヒロインやりたいんだけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「つきみさんも、ヒロインに立候補しますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私と肩を並べようっての？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだよ。わたしもヒロインやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ、あの……。これ、どうやってヒロインを決めるんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「しらないわよ。いい加減さっさと決めてほしいんだけど。じゃんけんでもく\nじ引きでもいいからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、そうですね。くじ引きできめましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420011" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いやよ。ヒロインがいいもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ。ヒロインを逃したらモブなのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしもヒロイン以外はやりたくないな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「つきみさんは王子役に指名されているじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420008" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いつも男の子役なんだもん。たまにはヒロインをやりたいんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420005" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「とにかくくじ引きで決めるのは反対！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420009" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうです。そんな運任せで大事なヒロインを決めるなんて認められません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ええぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420012" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなた達、いい加減にしなさい。子供じゃあるまいし、なんの役でもいいで\nしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113420001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こうなれば、誰がヒロインにふさわしいか、実力で示すしかありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「のぞむところよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420010" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしだって負けないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420006" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「三人とも、先生の言葉すら耳に入ってないようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なーんでそんなにヒロインにこだわるかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113420002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、あんまり教室で暴れるのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420013" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ええい、先生の話を聞きなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113420002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なに？　明日楽先生もヒロインに立候補するの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113420011" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「たとえ先生だからって負けないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113420007" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、ヒロインは私ですからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113420011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そういうことではありませんが、そんなにヒロインをやりたいのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113420003" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「私を倒して勝ち取って見せなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113420004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113420014" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「かくして、ヒロインの座をめぐる乙女たちの戦いが、今、はじまるッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113420003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}