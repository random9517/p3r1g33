		{"command":[ "PLAYVOICE", "v2_175_0504219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムもっ、もっ、らめっ、イクの！　んあひっ！　チンポズボズボされてぇ\nっ、オマンコっ、イックううううううん！！」", "NORMAL" ]},
