		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「くふっ……んんっ、いいよぉ……出したい時に……出しちゃえばいいしっ…\n…ヤムのオマンコの中でもっ……ぶっ掛けでも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……！　ずりずりぃっ、こんなっ、太いチンポの往復っ、続\nけてたらっ、もう出したくなるのっ、当たり前だしっ……」", "NORMAL" ]},
