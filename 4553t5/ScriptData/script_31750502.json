		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「しょーがないじゃん、今のパパのカッコ、可愛いんだもん。オトナなヤムじ\nゃなくても、こんな感じになっちゃうでしょ」", "NORMAL" ]},
