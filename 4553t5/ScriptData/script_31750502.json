		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「しかも、まだまだ出て来るしぃ……ヤバすぎぃ……マーキングされまくりに\nなってるぅ……ふはぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、今更遠慮したって遅いし……もう、全部出してから考えよ？　ほら\n、あとちょっと……ドピュって……」", "NORMAL" ]},
