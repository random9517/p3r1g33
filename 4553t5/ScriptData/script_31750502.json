		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーらっ、つっかまえたーっと。はーい、今更じたばたすんなしっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504101" ]},
