		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちっちゃくなったパパが、オトナになったヤムに力で勝てるワケないんだし\nさ、それにぃ……にひひっ、我慢してもしょーがないじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ね、このチンポ……めちゃくちゃビンビンになって、反り返ってる……やー\nらしいチンポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「今、ヤムのどの辺にくっついてるのかなー？　ほらほら、言ってみなよ……\nねぇ、ねぇ、ねぇってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504104" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ……そうだよ……ほら、オマンコ……もう、あとちょっとで入っち\nゃうような感じだよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ね、入り口のトコ……もうヌルってしてるの、分かっちゃうでしょ？　この\nままずぶってしちゃったら、めちゃくちゃ気持ちーよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それでも、まだ我慢しちゃう？　こーして……割れ目のトコ……スリスリっ\nてしても……まだ耐えられる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ……はふっ、んんっ……んふっ……もうヤムが皮も剥いたげてるから\n、メチャクチャ敏感になってるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「空気の流れだけでも震えちゃうのに……ほぉら……後少しぃ……んっ、もう\nいいよね……？　はぁい……ギブアップってことで入れちゃいまーす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅぅぅぅんっ……！　はぁぁぁんっ、入っちゃうっ……んんっ…\n…チンポ……ずぶって中に……来ちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほぉらあっ……飲み込んじゃった……ふふっ、ぶっといチンポ……あっとい\nう間に、一番奥に届いちゃったし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅ……熱い……ね。パパのチンポ……ずっとビクビクしてたケド\n、こうしてオマンコで食べちゃうと、余計伝わってくる感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さー、ここから、このやんちゃチンポは、どんな風に動いてくれるのかなー\n？　ちょっとだけ頑張ってみよっかー、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、はぅんっ！　んふっ、そうそう……ヤムの中を、ずぶずぶって……か\nき分けてぇ……ヌルンとしてるトコ……擦ってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃ……んふっ……！　上手じゃん……ちゃんと、オマンコの感じるトコ当\nたってるし……んうっ、くんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、息が荒くなってきてるし……ヤムのフェロモンが、だんだん染み込\nんできたって感じかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、ヤムからも締め付けたげる……ここのとこ、きゅうんっ……て……あ\nふっ！　あぁっ、チンポの先っぽ……いい感じに擦れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほれほれ、気持ちいーでしょ？　もっとグリグリ……かき回しちゃっていい\nんだからね？　んっ、はぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふっ……！　いよいよ、その気になってきたみたいじゃん……ふふっ、そ\nうそう、もっとサカれ、サカれぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あんっ、んぁっ、ヤムの……トロマンコ……いっぱい味わっ\nて……メロメロになっちゃえ……あっ、はぁっ、んひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……何よ……結構……マジになって来てるじゃん……？　あふっ、その\n調子で……もっと腰振ってみたら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁんっ……！　んっ、あっ、いーよ……おっぱいも触って……ちっちゃい\nパパでも、おっぱいは大好きだもんねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……んっ、ぎゅーっと握って……むにゅむにゅ、揉みしだいてぇ……く\nふぅっ、あぁっ、いい、感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……一回始まっちゃったら、もう止まらないでしょっ。おサル\nさんみたいに……へこへこっ、腰振ってぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムのオマンコっ……奥まで突きながらっ……どんどん、その気になってい\nくのっ、はひぃっ、そう……その、調子ぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふっ、んんっ……！　生意気に……ヤムの、弱い……トコ……狙って来て\nるじゃん……く、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「けど……んっ、今日は、ヤムの方がおねーさんだからねっ……生意気オイタ\nはっ、許さないってコト……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、チンポがキュンってなって……ヤバいでしょ？　どーせ、もう漏\nらしちゃうしかないんだしっ……さっさとイッちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んくっ……！　そうそうっ、情けない声出してっ……カラダ、\nビクビク跳ねさせてっ、ほらっ、後、もう少しっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もちろんっ、中出しだからっ……！　奥の奥までっ……いっぱいっ、出しち\nゃえっ！　んっ、はぁぁぁぁっ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ふっ……！　んんんっ……出てるっ、中出しっ……始まってるしっ\n……んんんんっ、ドピュドピュっ……してるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふひゅぅぅ……見た目、こんな可愛いのに……思いっきり出しまくってくれ\nてるし……ヤバ……オマンコ、入りきれない……溢れちゃうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ……ふっ、んふぅ……シーツにシミができちゃってる……まだ出て…\n…んくぅぅぅぅぅん……ヤムも……あっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふ……あぁ……結局、ヤムまでイカされちゃったし……でも、それだけチ\nンポが嬉しかったってことだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「にひひっ、素直に頷いちゃって……パパも、かわいートコあるじゃん。よし\nよーし、いっぱい出ちまちたねー、なーんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504135" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それで……どうする？　ちょっと一息入れてゆっくりする？　って……チン\nポ……んっ、これ……どうなってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「すっとぼけてもダメだし。ヤムのオマンコの中で……んっ……また、ビクっ\nて膨らんできてるじゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「要するに……アレでしょ？　これ、もっとしたいってコト……でしょ？　ほ\nら……どうなの、パパ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504138" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あー、今……こくんって頷いたよね？　つまりぃ……まだまだヤムのオマン\nコが欲しいって認めたワケね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さぁーて、どうしよっかなー？　まぁ、今中途半端にお預けさせて？　また\nパパが変なモードに入っちゃっても困るし？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いーよ……ほら……んっ、しちゃお……チンポ……ズリズリして……ヤムの\nオマンコ……かき混ぜて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……んふっ！　また始まったぁ……あっ、くぅっ……そう、パ\nツンって……腰っ、すごく深いトコぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、んふんっ……いいっ、感じぃ……すっかり、ノリノリになっ\nてきてるじゃんっ……ほら、もっとチンポっ……頑張れぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ、んぁっ、そこっ……はっ、乳首っ！　指でっ、あっ、\nほじり出されてるのっ、ひぁっ、はぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「また……生意気なコト……してくれるじゃないっ……ヤムのおっぱい……無\n防備にしてるからって……油断も隙もないコトっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぅっ、んっ……あっ……乳首……出てきちゃいそっ……んんっ、ホント…\n…こーいうのはっ、上手いん、だからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃふっ！　あっ……カリカリ引っ掻いてくるのっ……あんっ、い、いいっ\n……うくぅっ……上手すぎぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふっ……！　一緒にっ、チンポもっ、あっ、動かしてきてっ……はひぁっ\n、本気で……ヤムのことっ、落としに……来てるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ならっ、これはっ……どうっ？　んんっ、くふっ……あっ、オマンコ肉の…\n…んんっ、二重締めぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「先っぽのとこと……根っこのとことっ……交互に……んっ、きゅんっ、きゅ\nんって……！　にひひっ……いい感じ……でしょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらほら、負けないでもっと腰を振って……チンポを動かさないと……先に\nお漏らししちゃうよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、うんっ、んくんっ……トロトロのオマンコ、まだまだかき混ぜちゃう\nんだからぁ……はっ、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017505_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくうううっ……感じるぅ……おっぱい弄られながら……オマンコ……こん\nな、突き回されてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ……ずっと鼻息がヤバいし……メチャクチャコーフンしてるの分かる\nしっ、はうん、んくっ、うくうん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0504214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「これ、ヤバいかも……ヤムもっ、はあんっ、また……続けて……あっ、イッ\nちゃうかもっ、んひあっ、ああっ、そこぉっ！」", "NORMAL" ]},
