		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ん？　まあ、一日くらいで戻るし、ま……性欲は戻らないっていうか、おっ\nきくてもちっちゃくてもヤバかったってことで」", "NORMAL" ]},
