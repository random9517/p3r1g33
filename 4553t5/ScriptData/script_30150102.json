		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ンっ……あっ♪　隊長っぴ……☆　待ってたよォ、ずーっと待ってたァ☆　\n全然呼んでくんないんだもん～。溜まっちゃったよォ～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシの身体に火ぃつけるだけつけて放置とかさぁ、ありえないからマジ～\n！　毎日さぁ、今日かなー、今日かなーって期待して待ってたぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……エッチ……してくれんだよね？　アハッ☆　しよっ、しよ～☆　もー、\nこっちの姿でまで真面目に待ってるの疲れちゃったよォ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……って、なんでもない。ニャハハ、ゴメンね～！　なんかさぁ、変身前の\n地味子の感情が残ってた！　みたいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「つーて、んなこと今は関係ないじゃん？　と、いうことでー……エロエロな\nエッチ☆　しちゃおしちゃお☆　見ててね～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ほら、足パッカーン……☆　ドーン☆　どぉーだー、アタシの未使用ヌルヌ\nルまんこ～☆　無修正だし、濡れて疼いてるのめっちゃ見えるでしょ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ん～よく見えなぁい？　だったら……くぱぁって広げて見せたげる……♪　\nピンク色でカワイイっしょ～☆　でも、オナニーばっかりしてたからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「クリがおっきくなってきちゃったかも……☆　どうかなぁ～……アハハッ、\n隊長っぴむっちゃ見るじゃん！　ガン見じゃん……ウケるぅ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……ヒクヒクしてる？　うん☆　愛液がトロトロって溢れてきてる？　……\nそれも、うん☆　そーだよ、この穴に……隊長っぴの入れてほしーのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「いいでしょ～？　……つか、隊長っぴのズボン、盛り上がっちゃってパンパ\nンだよ☆　目立ち過ぎ……派手すぎ、見せつけすぎだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、はぁっ……♪　元の姿だったらさぁ……絶対こんなおね\nだり出来ない……。でも、アルルカンはアタシの理想の姿……だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「恥ずかしいとか言い訳しないでハッキリ言っちゃう。隊長っぴ☆　オチンポ\nください☆　アタシのはしたない、欲しがりマンコにキッツイのちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「避妊とかしないで、生で入れちゃってよ☆　それがいっちばん、チンポのゴ\nツゴツとか、カタチわかるじゃん、そのえっぐいカリでマンコひっかいて☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「盛りのついたケダモノみたいな超セックス……しよ☆　ほらほらぁ☆　どー\nぞっ、どーぞ☆　オマンコくぱくぱしてウェルカム状態だよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んふぁっ♪　あぁーっあぁ～……♪　オチンポっ、オチンポ１本ご入場～っ\n♪　あッ♪　ヤバッ、思ってたより大き……んぁううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっンっ♪　ひゅご……いぃ……！　お腹の中身、上にせりあがるぅ……♪\n　なにコレなにコレぇええ……デカいだけじゃなくて長いじゃんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んぁッ☆　オマンコの入り口から子宮口まで串刺しィイイ……☆　っていう\nかっ♪　子宮、持ち上がってんだけど、チンポの力で……ハンパないっ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んは……♪　はぁっ、はぁ、はぁ、はぁああ……♪　極上ぉおお……♪　隊\n長っぴはどぉ？　アタシの中気持ちい？　ヌルヌルであっついっしょ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「焦らしに焦らされてぇ……すんっごい濡れ濡れだし、蕩けてうねうね蠢いて\nるっしょ……あっ♪　形……もいいカンジにぴったりだしぃ……んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「内側からチンポでオマンコ拡げられてるこの感じィ……想定外だよぉ☆　あ\nッ、あっ、ヤバイ……ヤバイ、入れただけでトんじゃいそ……んあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あああっ、ああああ～～～☆　にゅぐ、にゅぐ、ってオマンコの中うねって\n悦んでるう……これ欲しかったって白状しちゃってるぅ☆　んあああん☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「隊長、ぴ……っ、隊長っぴぃい……♪　あは♪　あはっ、ねえ、動いてぇ…\n…♪　アタ、シも一緒に動く、からオマンコとチンポ摩擦してっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ん……んんぅ、んんんぐぅ……んんん……！　あぁ……ミチミチミチって拡\nがるぅう……！　チンポが動くと、オマンコひっぱられるぅう……☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んでもっ、それがなんかっ、快感すぎておかしーのっ♪　あっ、あっ！？　\nなにコレぇ♪　ズブズブ、チンポ出し入れされ、ると♪　んひぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オマンコと関係ない脳みそが痺れ、て♪　頭真っ白になっちゃうっ、カラダ\nっ、身体全体ピンク色になって♪　あひぃっ、ひぃっあっ、んぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシの全部が♪　オチンポに集中してくぅううっ♪　オチンポ、喜ばすオ\nマンコホールだよぉ、これじゃっ……☆　あっあっ都合いいオナホール☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「でも……それがイイっ……☆　アタシっ、アタシこんなに気持ちくなれるな\nらぁ……♪　一生隊長っぴのオナホールでいいよっ、いい、いい、イイっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んっイイっ……イイッ、イイッ……ああああああああ♪　んぁああああああ\n～～～♪　やっぱ思ってた通り♪　だった♪　そうだと薄々思ってた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシ……天性のチンポ好き、エッチ好きなんだ☆　あっ、オナニーする数\nも、全然フツーのコたちより多いしっ、いつでもやらしーこと考えてて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「自分の武器っ、ステッキっ☆　ステッキにオマンコこすりつけてクリオナし\nたりしてたっ、でも……オチンポいれたらわかっちゃったぁあ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ♪　んぐっ、ぁ、ふぁっ、はぁっはぁっ♪　アタシ、発情期の\nメス犬みたいに交尾好きっ、オマンコにチンポ入れられるための存在っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んぃいっ♪　いいっ、いいいぃっ♪　んひぃいいっ☆　細胞全部が快感を欲\nしてる……隊長っぴのオチンポ、好きだって、叫びまくってるぅう☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ぅ、あ♪　あっ、あっ♪　ぃぁあっ♪　あぁっ♪　あっぁっあっ♪　気持ち\nイイ♪　気持ちイイっ……オチンポ大好きっ、大好きっ、美味しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オマンコ粘膜をぐちゅぐちゅかき混ぜて、ぁっ♪　快感でアタシの頭、バカ\nにしてくれちゃってる極太ガチガチオチンポに恋してるっ……ふあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「一生♪　一生してたいぃ♪　隊長っぴぃっ！　もうアタシのオマンコっ、オ\nマンコからチンポ抜かないでぇ！　んでもってずーっとズコズコしててぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ずぽずぽ♪　グチュグチュ♪　どっちゅどっちゅっ、ぬっちゅぬちゅ♪　ん\nぁああああ、サイコー……♪　頭どうにかなるぅ～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「もっと♪　もっと激しくしてぇ、隊長っぴぃい☆　アタシ、頑丈だしＨ好き\nだからっ、どんだけキッツくされても感じるエロ女だからっ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……うんっ☆　うんっ☆　もっとぉ♪　もっともっともっともっとぉおお♪\n　ああああっ♪　気持ちいい、気持ちいい、気持ちいぃ～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オチンポっ、オチンポオチンポ☆　入れて、抜いて、入れて……あんっ、抜\nいて♪　止めないでぇ☆　ぐっちゅぐっちゅぐっちゅぐっちゅ～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あーっ！　締まるぅ♪　オマンコイッてギューッて締まるよぉ☆　あーっ、\nあーっ、隊長っぴのイリュージョンすっごぉおおい、好きぃいいい☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あははぁあ♪　アハッ、アハハッ……♪　中っ……オマンコの中に精子ドク\nッ、ドクッ、ドクッて……ああああ、満ちてくぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「これっ☆　これっ、完璧ラリっちゃうんだけど☆　あーっ☆　あーっ☆　中\n出し……中出しってこーゆー……あーっ♪　満足感高すぎィイイ～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっ♪　おっ♪　ちょっ♪　やたらしつっこく出るじゃん、子種ぇ……♪　\n隊長っぴのオチンポもアタシのオマンコ大好きになってくれたぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシも♪　アタ、シも好き♪　……出してる時、ブルッ、ブルッてチンポ\n震えてさぁ……あっ♪　脈打つっていうの～？　それが、ヨくて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あッあッ♪　やっぱ永久にシてたいよぉ～……☆　隊長っぴ☆　隊長っぴ☆\n　勝手に二回戦始めちゃうねっ、だって、だってだって～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっひっ♪　お腹に精液入ってて☆　たっぷんたっぷんの状態でピストン☆\n　したら絶対イイもん……！　ほら！　ほらっ、ほらほらほらぁあ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「すっっっごぃいいい～……！　ヌルヌルヌルヌルして、あっ、脳がイカれる\nぅう☆　悪の波動っ、悪の波動、オマンコで高まるぅうう☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、きゃはっ、あっ、あぁん♪　アレ？　あれあれあれぇ～？　チ\nンポ、だんだんオマンコの中であったまってきたんだけど～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「出したばっかなのに硬くなってきちゃってるじゃ～ん……あっ♪　こっちと\nしてもぉ、望むとこだけど……回復力、神レベルで戸惑う～♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「う、うン……♪　いいよっ☆　アタシのザーメンまみれの淫乱オマンコでっ\n……チンポこすって、もっかいデッカくしてよ♪　使って、使ってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「このマンコ、隊長っぴだけは自由に使っていい……から、ぁ♪　……んぐっ\n♪　アハッ、とてつもなくない～！？　もう復活して、あっ、デカマラぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アタシの奥、に突き刺さってるよぉ～☆　どっちゅっどっちゅっどっちゅっ\nてぇ♪　ん～～～ザーメンいっぱい入れた後じゃん、もう入んないってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「際限なく超勃起してくるとか♪　隊長っぴのチンポ、天才のそれじゃんね♪\n　女孕ませ機じゃぁん……超、カッコイイ♪　みん、なの憧れチンポだよ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……あぁああ～☆　あぁあっ、あぁ～あぁ～☆　そう♪　そう、前後に揺さ\nぶって、アタシ全体を、オマンコホールとして使って、使ってぇえ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ああ～っ、イイ、イイッ☆　隊長っぴの精子、隊長っぴのオチンポで塗り広\nげられ、て♪　アタシの中、隊長の色に、真っ白に染まってく☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ひぅっ、あんんっ、んんん～～～ッ♪　ダメッ☆　意識もってかれるぅ☆　\nオチンポ強すぎて全部全部もってかれちゃうーーーっ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ゴメンッ……さっきよりド派手に絶頂キメちゃいそぉ☆　んぁ\nああ、デッカいのくるっ、クるっ、オマンコのぼってくるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「最強チンポの容赦ないズコズコピストンで、イキ狂うところ見てて☆　見て\nて☆　あっ☆　オマンコぎちぎち締まって……あーーーーーーーー♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「隊長ぴっ♪　キちゃったぁああ♪　キちゃったぁあ～～～♪　あっ♪　今♪\n　今、オマンコの奥♪　子宮のお口開いてる、開いてるしぃい☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ザーメン全部ゴクゴク飲むからっ、子宮口でちゅーちゅー吸い上げて、ぜー\nんぶ飲み干したげるから……ザーメンちょうだいっ、新しいの欲しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「っンンンンン～～～～☆　んくぅうううう☆　くぅううううううんん☆☆　\n中出しィ、中出し大好きィ☆　何度でも、何回でも出しちゃってぇ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「抜かずの二発目なのに、勢いマシマシになってんじゃん～☆　そんなことっ\nてあるぅ～！？　あはっ……嬉しすぎてイッてるし、イくっ、イクぅう☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んぁんんっ☆　あんんっ☆　んぅっ、んぅ～☆　ビチャッビチャッてアタシ\nの赤ちゃんの部屋、精子でノックされてるぅ……たまんないっ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「無尽蔵にっ、無限に射精されてるカンジっ……んはぁああ♪　オンナだった\nらっ、この喜び♪　幸せ、感極まって大絶頂確実でしょ～☆　んぁ、イクぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「派手に膣内射精キメられてイ……く☆　イくぅ、イ……くぅうう☆　あーっ\n、あーっ、虜になっちゃうでしょぉこの量はぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「フーッ……☆　フー……っ、ふぅううう～……☆　ッぁ～～～余韻だけでグ\nラグラしちゃうって……。まるで弾丸、ううん砲丸ブチこまれたみたい☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「赤ちゃんルームにがっつりぃ、百発百中でザーメンヒットさせてくなんて…\n…マジシャンのナイフ投げじゃないんだからさぁ、職人芸すぎぃ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「一生忘れられないサイッコ～のエッチありがとぉ……隊長っぴ☆　で・も～\n……アタシったらワガママで貪欲で悪い子ちゃんだから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「今回一回だけじゃゼンッゼン足りないよ☆　そこんところ……わかってるよ\nねぇ？　……って、あぁっ！？　ま、まだ抜かないで！　このままぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「オマンコにチンポでぐっぷり栓をされたまま……うっとりしてたいの☆　あ\nとちょっとだけ、そばにいてこうしてて……？　お・ね・がい☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あっンっ、ヌルッて……☆　あッ！？　う、ウソぉ～！！　一番イイとこで\nオチンポがボロンって抜けちゃったぁ……！　ッああああっ！？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「だめ～！！　だめだって～ぇっ！　わぷっ！　カラダじゃなくてオマンコに\n出してよぉ～！！　ふぁっあんッ！？　あんっ、あんっ、やだ～ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「んぁんんっ！　アタシの全部が……隊長っぴの苦いお汁でホワイトコーティ\nングされてるぅ☆　びゅっ、びゅってくっさいのが飛んでくるぅ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「せっかく、とんでもない量出してくれたのにカラダになんて……あッ♪　精\n液のニオイがあたりそこらじゅうに充満♪　して……んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「これはこれでイイ……☆　って、んもぉおおおお！！　ザーメンシャワー、\nあっ♪　気持ちイイけどっ♪　あっ♪　ここまでほとばしってるんだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「コレをぶちゅーって中に入れてほしかったよぉおお～……！　ぐっすん☆　\nいきなりおあずけ食らったオマンコが切なそうにヒクヒクしてるっしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001501_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「なのに……なのにぃ……。……なにィ！？　一回は中に出したから、次は外\nに出してフルコンプぅ！？　う、うぅう～そういう考えもあるけどぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「ぶーっ☆　隊長っぴ女心わかってなーい！　オチンポが有能で優秀でド名器\nなだけ～！！　……あーあー、全身ドロドロぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「隊長っぴのぬくもりに包まれてるこのカンジもイヤじゃないけど……。フィ\nニッシュは中のつもりでこっちもスタンバイしてたんだしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「……コレは、今度……責任とって連続生出ししてもらわないと気がすまな～\nい！！　ってわけでオチンポの予約よろ☆　リザーブしたかんね☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_0104410" ]},
