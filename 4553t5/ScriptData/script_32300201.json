		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ええ、これからも……色々と学びまして……ダーリンにお尽くし致します。\nそれが妻としての務めですから……♪」", "NORMAL" ]},
