{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さ……ダーリン。二人きりになれましたわ……今日は、ごゆっくりくつろい\nで下さいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、本日は妻として、夫にするべきというご奉仕を覚えて参りましたので\n、ぜひダーリンに味わって頂きたいと考えております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ダーリンは、そちらに……はい、そのまま仰向けに寝ていただければ大丈夫\nですわ……後は私がお導き致しますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ありがとうございます。それでは……ふふ……んっ……あぁ……これは……\nお見事なオチンポ様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もう、ビンビンに上を向いて……とても逞しい……オスの力を感じてしまい\nますわ……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「では、早速……れろ、ちゅぱ……んちゅっ……れろ……えろ……んっ、れり\nゅ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「最初は……軽くオチンポを馴染ませるところからですわ……ちゅぷ……ぴち\nゃ、んりゅ……れろ、んれろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁぁん……オスのフェロモンが満ち溢れて……んんっ、こうして舌で舐め\nるだけで……んんっ、気持ちが高ぶって参りますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、まだですわ……まだ最初は唾液で……じっくりとオチンポを\nぬめらせる準備から……じっくり落ち着いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ちゃんと緩急をつけないと……単調になってしまいますから\n……んっ、れろ……れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……唾液まみれになって……そろそろ、準備としてはよろしいみたいで\nすね……それでは、改めて……オチンポ頂きますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁんむ、くぽっ、じゅぽぉぉぉぉっ、んっ、じゅぷっ、んちゅぅぅぅぅぅ\nぅぅっーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅ……いかがれふかぁ……？　こうひて……口の中で……オチンポ\nを吸い上げながら……頬をぎゅっと……窪まへてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んじゅぷぅっ……りゅぽっ、んちゅぷっ……これを、世間れは……ひょっと\nこフェラというのれふよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、ろこで……こんなことを……？　はい……日々、夫を喜ばせる為の\n知識収集を行っておりまひて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「特に人妻ものというジャンルの動画による研究は……色々と……学ぶべきも\nのが多々あると判断いたひましたの……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、いかがでしょうか……オチンポ……きつくはありませんか？　んち\nゅぷぅぅっ、じゅるっ、じゅずぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「大丈夫のようですわね……んっ、では……たっぷりと吸い上げて差し上げま\nすわ……んっ、ちゅぅぅぅっ、じゅずっ、ずずぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……くぽっ……はぁ……んっ、ダーリンのオチンポの味……程よい\n塩分と、ツンとした酸味が……私の好みですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んちゅるるるっ、んちゅぅぅっ……吸い上げているうちに……ど\nんどん唾液が……溜まって……んりゅっ、くぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぁ……じゅぷっ……それを、また吸い直すと……んふっ、気持ちが高ぶ\nって……止まらなくなるのれふわ……んちゅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、くぽっ、んぶっ、んちゅぷぅぅっ……あぁ……ダーリンが私の顔を\nじっとご覧になっていまふ……んじゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「このように……顔を歪ませたところを……覗き込まれると……はぶっ、身体\nの内側から……燃えるような羞恥心が広がりまふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……んじゅっ、あぁ……いけませんね、私としたことが……んっ、こ\nうして……はしたない姿を晒して楽しんで頂くことも妻の務め……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっともっと、お喜び頂くために……奥までオチンポをくわえ込みませんと\n……んぶっ、くぷっ、んりゅうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んぱっ、んじゅっ……ふぐっ、んんっ、むぐぅっ、りゅぷっ……\nんっ、喉れっ……オチンポを味わいまふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ぐぽっ、んぁ……んふぁ……あぁ……おいひぃ……オチンポぉ……こうひて\nおしゃぶりしているとぉ……それだけで幸せな気持ちになってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅっ……喉の奥まで……オチンポ感じてぇ……りゅぷっ、んんっ、しゃ\nぶりつくのぉっ……幸せになってひまいまひゅぅ……んじゅぷっ、ちゅぷっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんっ、もっともっと味わいまひゅっ……オチンポぉ……あぁ、先\n端も……根本もぉ……どこを舐めてもおいひぃれふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はひ……んじゅぷっ、わらひは……ダーリンのオチンポが大好きれふっ……\n顔がっ……動くの……止まらないれひゅわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっともっとぉ……オチンポ、しゃぶらせてくらひゃいまへ……ふぐうっ、\nんぶぉっ、あぷっ、あぁ、よだれが……止まらないれふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ……ふぐっ、鼻息も漏れてぇ……あぁ……ダーリンに興奮して\nいるの……伝わってひまいまふぅぅっ……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっと激しく……あぁ、はひっ……このいやらしい口れ……オチンポ、上下\nしまひゅ……シコシコひまひゅ……お口交尾……ひまひゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぐぅっ、むふぅっ、れろっ、ちゅぷっ、んじゅるっ、ぴちゃ……んちゅぷ\nっ、ふぶっ、んぶっ、んぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……舌が自然にレロレロひまひゅっ……あぁ、ダーリンの前でオチンポ\nしゃぶる顔を見られてぇ……はぁ……んんっ、興奮ひまひゅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁぁ……あぶっ、オチンポもビクビクひて……あぁ……んじゅぷっ、出し\nたくなって……きてまひゅか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふぁひ……このまま……お口に……直接飲ませてくらふぁいまへぇっ……ん\nじゅぷっ、オチンポ、吸い上げますからぁ……んじゅうぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ！　ふぐぅぅっ……んぶっ、あぁ……れて……きまひたっ……ドロド\nロのぉ、濃いチンポミルクぅっ……れて……まふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぐっ、んくんっ、あふっ、んぷっ、くぷっ……こくっ、んんっ、んっく…\n…んんっ、んはぁぁぁぁぁぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ、濃厚なオチンポミルク……いっぱいごちそうして頂きまし\nた……んけふっ……ありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、ちゅぱっ……いかがでしたか……？　ご満足出来ていれば\n何よりですが……んっ、まだまだオチンポはビンビンのままですわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「やはり、一発出した程度では、到底ご満足には遠いですか……はい、それで\nはこのまま続けておしゃぶりをさせていただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「その前に、まずは先に残った精液から……んちゅるっ……舐め取って参りま\nしょう……んっちゅ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、直接口に流し込まれるのも素敵でしたが……こうして、残っ\nたものを舌先に集めて味わうのも……また格別……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ……人間としては、少しお行儀が悪い行為なのかも知れませんが……\nれろ……それがより美味しく感じさせるのかも知れません、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……んちゅぷっ……こんな風に味わっていくと……はぁ……身体が……\n自然にもっとオチンポを欲しがってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もう待ちきれません……んっ、改めて……はぁんむ……くぽっ、りゅぷっ、\nんふぅぅぅ……ぐっぽり咥え……ひゃいまひたぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んじゅるるるっ、ずちゅっ、じゅずっ……もっと、唇で亀頭を強く吸ってぇ\n……このまま、ずろろろろろろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「おぶっ、んふぅっ……縦に……オチンポをヒコヒコ……ひまふぅ……ふぶっ\n、んぶっ、ぐぷっ、おぷっ、りゅぷっ、んじゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、くぷっ……気持ちいいれふか……？　ふふっ、何よりです……もっ\nともっといたひまふから……くぽっ、んりゅぷっ、じゅぷぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「うんっ、ふぶっ、くぷっ……あぁ……口の周りが……ドロドロれふっ……お\n腹の回り……濡らしてしまって申し訳ありまふぇん……じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「後で……こちらも、綺麗にいたひまふので……オチンポだけ……意識をして\nいただけると……んじゅぷぅぅ……ちゅぷっ、んぽっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふんっ、んぐぅっ……もう、オチンポから次の先走りが滲んで参りました…\n…んちゅぷっ……しゅっぱい味が心地良いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、んちゅぅぅぅっ……射精はもう少しだけ我慢して下さい……なるべく\n溜めて……一気にした方が気持ちいいそうれふから……んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んじゅるっ、んちゅぅぅぅっ……んふっ……この吸い上げで……\n難しいれふか……？　ふふっ、もう少しの辛抱ですわ、ダーリン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んちゅぷぅぅぅっ……ふぉら……根本から……キュウっと……吸\nい付いて……んふぅっ、鼻息が漏れまふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、もっと、くぽっ……強くぅ……じゅぷっ、搾り上げて……\nあぁ、ビクビクしてるぅ……腰ぃ……んふっ、ちゅうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はひ……後少しですわ……んーっ、りゅぷっ、んりゅっ……もう、思い切り\n……解放していただいて……構いません……んじゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「このまま……お口の中れもっ……顔にお掛け頂いても……結構れふのれっ…\n…いっぱい……らひて……くらさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「じゅぷっ……んふぅっ、んじゅるるうっ……さあ……ご遠慮なくぅっ……ダ\nーリンのオチンポぉっ……いっぱい、らひてぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぶぅぅぅっ！　あぶっ……んぐっ、ふっ、んぐぅぅぅっ……こくっ、んぐ\nっ、んくっ……んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぁ……さっきよりも……れて……まふ……んぐっ、こくんっ……んんっ\n……濃いのいっぱい……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっふ……今度は、残らず全部吸い上げますわ……んじゅるるるるぅぅーっ\n……んぐっ、こくっ、んぐっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぱっ……はふっ……はぁぁ……あふっ、たっぷりとダーリンの精液頂きま\nしたわ……ご馳走様でした……んはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あっと……いけません、私としましたことが……ちゃんとオチンポをお清め\nするところまでがお務めだというのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……れろ、んちゅぷ……んちゅぷぅ……ぴちゃ……んちゅっ、れろ…\n…まだ、ちょっと残ってましたわ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……れろ、ぴちゃ……はい、これでよろしいです。スッキリされ\nたようで何よりですわ……んちゅ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「いかがでしたか？　何分、見様見真似ですから……至らないところもあった\nかと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうですか、ええ……確かにこれだけ射精していただけたので……\nご堪能頂いたのなら何よりでございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、これも妻として当然のお務めですので……ご遠慮なく、またいつでも\nお申し付け下さいませ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ひぁぷっ！　あっ……んんっ、はふっ……顔に……掛かっておりますわっ、\nんぁっ、はぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はふっ……さっきより、もっとたっぷり……濃いのが……溢れて……はぁぁ\n……顔面シャワーされていますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「いえ……嬉しいです……こうして、ぶっ掛けされるのも……動画にはしっか\nりと記録されておりましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「どうぞ、欲望のたけを……たっぷりと私に吐き出して下さい……んんっ……\nいい匂いです……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あぁ……後もう少しだけ……はい、オチンポをしっかりと\nくっつけて……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「終わりましたか……？　んふっ、お疲れさまでした。お待ち下さい……後は\n、ちゃんとお清めしてしまいますので……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、まだ……少しついてますから……この部分が……オチンポミ\nルクの中でも特に美味しいところなのですわ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、これでよろしいですわ……ふふっ、どういたしまして……少しでもご\n満足いただけたのなら良かったですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうですね……オチンポが何より正直に物語って頂いていると……\nはい、それはよろしゅうございました」", "NORMAL" ]},
