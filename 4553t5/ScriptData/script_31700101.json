		{"command":[ "PLAYVOICE", "v2_170_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んふぁ……匂いもすごくて……んぁぅ……あぁ、こんなの顔に染み付いたら\n……取れなくなっちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
