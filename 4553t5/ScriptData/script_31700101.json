{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「それじゃ、ちょっとジッとしててよね。んっ……くっ、こう……かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うわぁ……何か、どんどん大きくなってる……何だか風船が膨らんでいくみ\nたい……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103102" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「その……勃起で大きくなるのは仕方ないけど、とりあえず他の動きは我慢し\nて、ほら……これは、そのトレーニングの一貫だからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「だ、だからっ！　大きな動きでパイズリしたらっ、結構いい運動になるでし\nょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「それでっ……アンタも気持ちよくなれて一石二鳥じゃない……分かったら、\nそのままじっとしてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、そのままね……えと、最初は、こうやって左右から……ぎゅっと……\n挟む……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そしたら、確か……こうやって……スクワットをする感じで……うんっ、ふ\nっ、んっ、あっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「どう？　とりあえず、こんな感じでいいんじゃない？　ほら……この色の違\nう所……擦ってあげたらいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「どこで覚えたかって……それは、色々よ……姉さんの持ってた本とか、結構\n細かく書いてあったし……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「い、今の……内緒だからっ！　て言うか、細かいことはどうでもいいでしょ\nっ、ちゃんと出来てるかが大事なのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「もう少し……濡らして滑らせた方がいい？　唾液とか……あ……う、うん、\n分かった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えろ……れろぉ……どうかな……こんな感じ？　んっ、しょっ……ん、ふっ\n……あ……確かに、よく滑るかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んんっ、そっか、ちょっとくすぐったいけど……この方が、気持ち……いい\nんだ……んふっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えっ？　あたし……？　別に、あたしがどうかは……そんなに関係ないでし\nょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「違うの？　一緒に気持ちよくなる方が……もっと効果的……あっ、ちょ、ち\nょっと……、何動いて……ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……待って……んっ、そんなに、先っぽの方……あっ、んぁん\nっ、したらっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「待って……あっ、そこっ……あっ、あぁっ……出て来ちゃう……んぁっ、あ\nぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あ……だ、ダメ……見ちゃダメ……っ！　こんな……乳首、飛び出てるの…\n…あぁ……見ないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、だって……みんなと、違うし……埋もれてるのが、顔出しちゃうの…\n…恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そんなこと……ないの……？　あたしのおっぱい……変じゃない？　乳首…\n…これでも、いいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うん……分かった。とにかく、もっとやってみるね……時々、ここも……擦\nる感じで……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いち、にっ……いち、にっ……へ、変かな。ほら、スクワットする時……リ\nズム取るからさ、同じ感じで……してみようかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うん、ありがと。じゃあ、このまま、その……オ、オチンポ……するから…\n…んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いち、にっ、いち、にっ、か、顔が赤いって……仕方ないじゃんっ……や、\nやっぱり恥ずかしいものは恥ずかしいしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いち、にっ……はぁっ、あっ……はっ、んんっ……汗が、出てきちゃう……\nいち、にっ……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、めっちゃ見てるし……そ、そんなに乳首ばっかり……ここ、\nもっとオチンポに当てないと……ダメ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「分かったよ、やってみる……うぅ……ドキドキするけど……んっ、あっ、あ\nひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あ……や、やだ……何、今の……すごい、ジンジンした……あたしの乳首、\nこんなに敏感になっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「オ、オチンポの方もそうなの？　この部分が当たるの……気持ち、いいの…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「うぅ、そう言われたら……やるしかないじゃん……んっ、あふっ、んくっ、\nあぁ……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁ……こんな体力使うんだ、パイズリって……はぁ……はぁ……全身運動\nじゃん……それなのに、ビクってして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「オチンポも、震えてる……え……これ、もしかして、もう出ちゃいそうにな\nってるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ……いいよっ、好きに出してっ……このまま、するからっ、あ\nたしに……いっぱいっ、出しちゃってっ、はっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁんっ！　あぁっ……出てるっ……！　ドプって……射精……始ま\nってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あったかいのがビュクビュク……あぁ……これ、あたしのパイズリで……出\nしてくれたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、すごい……ドロドロになってる……うぁ……ま、まだ出てるよ……こ\nんなにぃ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「やっと……収まってきた……これで、とりあえず良かった……んだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そっか……気持ちよかったんだ……うん、それなら頑張ったかいが……あっ\nた、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「でも、確かに、パイズリって凄いかも……こんな、おっぱいで擦ってるだけ\nで、身体中ぽかぽかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「トレーニングとしては成功だったかな。えへへ、協力してくれてありがとっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「えっ……まだ、終わりじゃないの？　あ……た、確かに……まだオチンポ大\nきいままだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「で、でも、本だと普通に終わってたし……あっ、まだまだって……わ、分か\nったって！　続けるからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「とりあえず、このまま続ければいいんだよね？　あ……そっか……精液でも\nっと滑りやすくなってるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「じゃあ、改めて……いち、にっ、いち、にっ……んぁっ、ふっ、あっ……ん\nんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「な、なんでだろ……精液のせい？　何だか……さっきより、気持ち……いい\nような……んっ、おっぱいが敏感になってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「乳首だけじゃなくて……おっぱいの内側から……はぁ……ムズムズする感じ\nが広がってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「今……オ、オチンポ、ぐりぐりしたら……あっ、はぁぁんっ、あっ、すごい\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……音、んっ、鳴ってるぅ……ぐちゅって、あぁ……おっぱいとオチン\nポが擦れてぇっ……あぁっ、やらしい音……いっぱいするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、あぁっ、はっ……ウソ……あたしがしてあげてるのにぃ……\nこれぇ……あたしの方が……感じちゃってる気がするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ね……どうなのぉ？　ちゃんと、あんたも……気持ちいい？　パイズリオチ\nンポぉ……感じてる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あたし……すごいのぉ……はぁ、んっ、乳首……ギチギチにしてぇ……精液\nのヌルヌル……感じてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いち、にっ、いち、にっ……あぁ……おっぱいだけじゃなくて……からだ、\n全体が熱いかもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あっ……あんたも腰を振って来てる……あぁっ、これっ、お\nっぱい犯されちゃってるみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はひっ、んふぅっ、また乳首が当たってっ、あぁっ、気持ちいいトコっ、キ\nスしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、オチンポから……またじわって滲んで来てるっ……これ、新しい汁\nっ……また射精したくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「だよね？　このオチンポの震えっ……気持ちよくなってて……そういうこと\nだよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ、分かってる……あたしも、頑張るからっ……一緒に、気持ちよくなっ\nていこっ……はっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あぁっ……ずりゅずりゅって……あぁ、皮がっ、めくれてっ…\n…や、やらしいよぉ……これぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はっ、もう入り口のとこっ……ぷくって広がってる……もう、ホン\nトにすぐそこまで来てるの……分かるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あたしも気持ちいいっ、あぁっ、一緒にっ……イッちゃいそぉっ、あんたも\nっ……あぁっ、は、早くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103220" ]},
