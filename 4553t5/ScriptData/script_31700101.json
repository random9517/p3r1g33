		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「んっ……もっかい……おっぱいにっ、うんっ、いいよっ、出してっ……また\n、射精してっ！」", "NORMAL" ]},
