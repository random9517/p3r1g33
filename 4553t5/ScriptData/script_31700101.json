		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「その、それなりには、あんたとの絆も深まったのかなって……あははっ、何\nか似合わないこと言っちゃってるかな、あたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「え……今度は、もっと凄いこと……？　うん、えっと……まぁ……そだね…\n…か、考えとく……」", "NORMAL" ]},
