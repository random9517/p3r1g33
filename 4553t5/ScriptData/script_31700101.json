		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あふぁ……はぁ……はぁ……あたしも、おっぱい……イッちゃったぁ……ふ\nぁふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「やだ、んっ……谷間からこぼれちゃう……全部受け止めきれないよぉ……こ\nんなにぃ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「垂れちゃってもいいの？　また、出してくれるって……はぁ、これだけ出し\nて、まだそんなこと言うの呆れるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、終わった……？　ホント、すごい量……最初に思ってたのと\nは大分違ったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まぁ、でも……あたしも一応気持ちよかったし……ちゃんとトレーニングに\nもなったと思うし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103308" ]},
