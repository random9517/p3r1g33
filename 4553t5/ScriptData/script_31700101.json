		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ……今度は……か、顔にっ……？　はぁ、んっ、うんっ、何\nでもっ、何でもいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「全部、あんたの言う通りにするからっ、掛けてっ……いっぱい精液……オチ\nンポから出してぇっ、んぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ひゃふっ！　んんっ……！　出てるっ……べとって……顔に……は……んぁ\nふ……」", "NORMAL" ]},
