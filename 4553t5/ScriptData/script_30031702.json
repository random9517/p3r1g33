		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おい……起きろ……そろそろ、目を覚ますのじゃ……起きろ……起きろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「やれやれ、やっと目が覚めたか。全く、のんきに寝とぼけおって。せっかく\nの夜に、余を放っておくのはお主ぐらいのものじゃぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うん？　今の状況……？　くくっ、それはもう見ての通りじゃ。お主のチ〇\nポが見事なまでに勃起していたから使わせて貰っておるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……たっぷり搾りつくしても、少し寝たらすぐに回復する……まだまだ\n若さと性欲が漲っておる証じゃのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そんな訳で、遠慮なくこの勃起チ〇ポを、余のマ〇コが味わっておる……ふ\nふ、状況は理解できたようじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「では、分かったところで……んっ、ふっ、んぅんっ……！　チ〇ポを使わせ\nて貰うぞ？　んくっ、はっ、んむっ、んぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉっ……やはり、意識が戻るとチ〇ポにも芯が入るな。んふぅっ、さっき\nと同じ動きでも、マ〇コの擦れ方が段違いじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぉっ……ズリュズリュとマ〇コの肉がめくれ上がって……これこそが余\nの求めていた逞しいチ〇ポよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうじゃ？　こうしてっ、んんっ、下から見上げる余のお尻は……\n？　なかなかの絶景じゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主のチ〇ポをぱっくりと頬張って、割れ目が広がっているところ……全部\n丸見えになってしまっておるなあ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、冷静さを装っているのかも知れんが、チ〇ポがしっかり反応してお\nるからな。目もマ〇コに釘付けになって、つくづく分かりやすい奴よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほうれ……根元までずっぷりハマるぞ。んんぅっ……太いっ……余のマ〇コ\nの中が、押し広げられていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これで……ゆっくりと腰を持ち上げてぇっ……はぁぅっ、また……奥へっ…\n…沈めてぇっ……おっ、ほぉっ、ほひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くふぅっ、やはり起こして正解じゃ。その悩ましい吐息……漲りを強くさせ\nたチ〇ポ、人形を犯してもつまらんからのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、もっといい声を聞かせて貰うぞ？　特等席で余のマ〇コを見ながら、\nしっかりチ〇ポを硬くさせるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、くぅっ……おっ、ふっ……あぁっ、貫かれるぅっ……！　\n一番奥に届いて、チ〇ポの先が……Ｇスポットに当たってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、ビクビク跳ねるチ〇ポが堪らんっ……くぅぅっ、もっとじゃ……も\nっと扱いてやるからな？　しっかり勃起を維持しておくのじゃぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくぅっ、あふっ……あぁっ、お尻が勝手に動いてしまうっ……新\nしい汁を溢れさせながらっ、チ〇ポを貪ってしまうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅぅっ……どうじゃっ、じゅぷじゅぷ、いやらしい汁音がしておるっ、そ\nそらせるのうっ、ふんっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「動けば動くほどっ……汁がかき回されてっ、ぅんっ、くぅっ……もっとこの\n音をさせたくなるのじゃっ、おふっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、さあて、ただ上下に動くだけでは芸がないな。例えば、こう\nいうのはどうじゃ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……お尻で円を描くように……チ〇ポを中心に回して、くいくいっと…\n…こうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……！　こうすると……余のマ〇コの擦れ方も変わって、な\nかなか新鮮な気分が味わえる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、おお……チ〇ポもまた一段と震えが来ておる……ふふ、お主もこの\n動きに興奮しておるのじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉれ……好きなだけ見るがいい……はぁぁ……んっ、しっかりとチ〇ポを\n頬張り、絡みつくマ〇コぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今……マ〇コに力を入れるからな？　んふぅんっ……ふふっ、どうじゃ？　\nヒクついてるところはどうなっている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「マ〇コ肉が、チ〇ポをしゃぶり尽くすように動いてるところ……くふぅっ…\n…いやらしいじゃろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれほれ……しっかりチ〇ポを立たせて支えんと、もっとされるばかりにな\nってしまうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうじゃ……また射精したくなるまで、何度でもマ〇コを締め付けてやるか\nらな……ふぐっ、んんっ……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……強く締める度に、チ〇ポが脈打つのがよく分かる……！　もっと速\nく……いやらしく動かしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、太いチ〇ポが気持ちいいっ！　腰を回せば回すほどっ、中でぐち\nゅぐちゅしてっ、くぅんっ！　気持ちいいのが上がってくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、くぅぅっ……マ〇コが疼くっ……もっとズボズボしてっ、ふんっ、\nくぅんっ、こうじゃっ、あぉっ、奥ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、ふぁっ……このまま、もうすぐ……あっ、くっ、イクところまでっ、\n後少しじゃっ……はぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主も……いよいよチ〇ポが震えて、限界が近いようじゃな……？　さあ…\n…もう、余も待てぬ。このままマ〇コに中出しするがいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふっ、んふっ、はぁっ、奥じゃぞっ……中にっ……どっぷりと濃いのを流し\n込むのじゃっ、くぅんっ、余もイクからなっ……んんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅぅぅぅっ……！　始まったぞ……くぅぅっ、熱いのが……余のマ\n〇コの奥に流れ込んで来るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……これじゃ……この、生ザーメンで満たされる感触ぅ……これがい\nいのじゃ……はぁぅ、堪らぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もっと出してよいぞ……マ〇コを締め付けて……んんっ、搾り取ってやるか\nらのう……んふっ……また出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……うむ、満足じゃ。このこってりしたミルクが余の新たな血肉\nとなって、より強力な力を手にできる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふ……まだ、中でチ〇ポがうねっておる……この逞しさ……二度と手放せ\nるものではないのう♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……さて、なかなか堪能したが、まだチ〇ポが硬いということは……後\nもう少し……むっ、どうした……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主……一体何をするつもりじゃ……まて、そこは……お尻の穴で……はっ\n、あぉぉぉぅぅんっ！　は、入るぅっ点！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……このまま一方的にされると身の危険を感じると……それで、余\nのアナル責めをしようと……そういう魂胆か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、面白い……お主が本当に余を前後不覚のメロメロにできるのか…\n…確かめさせてもらうぞ？　んっ、あぉぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おぉっ、ほっ、おぉっ、おぉんっ！　いきなりっ……一番奥までっ、あぉぉ\nっ、ズボズボっ……来るっ、くぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あぉぉっ、これはっ……お主の本気が伝わるぞ……んんっ、気\nを抜くと、簡単にイカされてしまいそうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃが……んっ、そう簡単に思い通りにはさせんぞ……んふぅっ、余のケツ\nマ〇コ……逆にお主のチ〇ポを搾り取ってくれる……んぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まっ、待てっ、あぉっ、そこっ、そこはっ……おふっ、感じっ、やすいとこ\nろでっ、そんなにっ、するのはっ、はぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぉっ！　くぉぉっ、め、捲れるっ！　余のアナルがっ、おぉっ、ズボズ\nボっ……捲り返されるっ、くぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ひっ、くひっ！　つ、強いっ……！　はぉおぅっ……こんなっ、あっ、おっ\n……！　激しいのっ、突き回されてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁおっ、一瞬でチ〇ポに征服されるっ、余のケツマ〇コっ……あぁっ、支\n配されるっ……くぅっ、んぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「違う……んんっ、こんな筈では……ふっ、ひっ、余がお主をいいようにして\nいたのにっ、こんなっ、おぉっ、くっ、んふぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ダメじゃっ、あぉぉっ、イクっ！　チ〇ポ激しすぎてっ！　おぉっ、お尻の\n穴がイクっ！　ケツマ〇コイクっ！　ほぉぉぉっ、イグぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あぁっ……はぁっ、あっ、ぐっ、ふひぃ……はぁっ、はぁぁっ…\n…あへぁ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「イ、イカされたぁ……あぁ……余のアナル……こんなに広げられてしまうと\nは……んっ、んぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなっ、すぐに、またぁっ、イッたのにっ、チ〇ポっ……アナルっ……続\nけてズボズボされるぅっ、ほぉぉっ、おひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁぉっ……！　止まらないっ、またっ、続けてイクっ！　ケツアクメする\nっ、くひぃっ、お尻っ……馬鹿になるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、おぉっ！　中でまたチ〇ポが膨らんでっ……あぁっ、ま、\nまさかっ……このままっ、んぁっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今っ、出されたらっ……余も続けてイッてっ、ひっ、ふぁぁっ、おかしくな\nるのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「イグっ……おぉぉぉっ、イクっ！　あぁっ、はひおっ、イクっ……んぅぅぅ\nぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「くひぃぃぃぃぃっ！　中っ……あぁっ、出て、るっ……！　お尻の中にっ…\n…熱いザーメンっ……出てっ……いるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぉぉぉぉっ……熱いっ……アナルが燃えてしまいそうじゃ……くひぃぃぃ\nっ……まだ、まだ流れ込んできておる……はぉぉぉぉぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ケツ穴が震えてぇ……あぁ……ごくごく飲んでいるなどと……そんな\nことぉ……あふぁっ、くぅぅぅぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はふぁ……ぉぉぉ……ま、まだ出るのか……くふぅ……余の負けじゃ……完\n全にケツ穴をお主のチ〇ポに躾けられてしまったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ、くふぅ……やっと、止まったのか……？　まだ、ズッポリ埋\nまったチ〇ポが、小さく震えて……余のアナルを広げておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……抜くのは最後にしてくれ。今、引き抜かれたらザーメンがそのまま\n垂れ流しになってしまいそうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……十分過ぎる程に満足させてもらった。もう、これ以上搾り取るつも\nりはないから安心するがいい……はぁ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにしても、お主の本性……まだまだ底が知れぬな。追い詰められた時に\n発揮するその力……余の見立て以上にお主は凄い力があるのかも知れん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それが分かっただけでも、このハロウィンは収穫のある祭りじゃった。うむ\n、実に満足じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……また、その気になったらいつでも余のアナルを躾けてくれ。お主に\nなら、悦んでこのアナル……捧げようぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「んあぉぉぉぉぉっ！　お尻にっ……熱いザーメンっ、掛けられてぇっ……あ\nぉぉぉぉぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、気持ちいいっ……チ〇ポ抜けてるのにっ……まだ、ケツ穴が……\nムズムズしてぇ……イッてる感覚が続いてぇ……あぉぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　イクっ……おぉぉぉっ……続けてイッて……はぁぉぉっ\n、身体……震えるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……温かい精液が、ドロリと尻に粘りついて……チ〇ポで塗り込められ\nておる……このヌルヌルがたまらんのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ……分かった、余の負けじゃ……もう無茶に搾り取るようなことはせ\nぬ……お主のチ〇ポに分からされてしまったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、んはぁ……あぁ……射精……終わったのか？　んんっ、まだお\n尻の穴が閉じない……ぽっかり口を開けてしまっておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000317_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はふぅ……いやはや、お主を本気にさせるとこんなことになるんじゃな……\n余も少し油断しておったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃが、一方的にするばかりでなく、こうして責められる感覚……思った以\n上に気持ちいいものじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それが分かっただけでも、このハロウィンは収穫のある祭りじゃった。うむ\n、実に満足じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1704409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「また夜通しのまぐわいを楽しめればよいな……余は、お主の誘いをまってお\nるぞ？」", "NORMAL" ]},
