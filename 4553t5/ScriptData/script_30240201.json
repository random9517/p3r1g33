{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「過去のエッチな体験談を教えて欲しいだなんて……あなたと私の仲だから話\nしてあげるけど、そんなの聞いてなにが楽しいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私のことを知れるのが嬉しい……？　ふーん。男の人って、みんなそんな考\nえなのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「まあいいわ。ただし、あなたもちゃんとエッチな体験談を話すこと。それが\n条件よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どうして自分も喋るのかって……？　そんなの、私だけエッチな話をするな\nんて不公平だからよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「別にどんな話でもいいのよ。例えば、今から私がする話みたいな感じでも…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ。オチンポこんなにおっきくして……我慢できないって感じね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002402_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「軽く触れるだけで、ビクビクって跳ねてるわ。そんなに、私の手でオチンポ\nシコシコされたいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「早くシゴいて欲しいだなんて……どうしようかなー？　私はもう少し、オチ\nンポの感触を味わいたいんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あはっ。その切なそうな顔、最高よ。もっと近くで見せて頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら……遠慮しないで、唇を近づけて……そうしたら、オチンポシコシコし\nてあげる……んっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くちゅ、ちゅぷ……ちゅ、れろっ……ちゅぱっ……！　もう。私はキスして\nいいだなんて、一言も言ってないわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私の可愛い顔が近くにあったから、我慢できなかったの……？　そうなんだ\nー。我慢できなかったんだー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「素直に可愛いって言ってくれたから、ちゃんとオチンポシゴいてあげる……\nその代わり、キスで私を満足させてよね……んっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅちゅ……ぐちゅ、じゅるっ……れろっ、ちゅちゅ……はあぁ……\n唾液が絡まって、いやらしい味がするわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オチンポかりゃも、エッチなお汁が出てひてりゅわ……もっとシコシコして\n欲ひいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……ちゅぱ、じゅちゅ……くちゅ、ちゅうぅ……！　あっ、\nんんっ……！　オチンポがすっごく暴れてりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「しょんなに動かひたら、上手く擦れないりゃない……ちゅ、じゅぷっ……れ\nりゅ、れりゅ……ぬちゅ、くちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……ぷはっ……はぁ、ああっ……オチンポの熱で、私の手が\n火傷しちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ。こうやって、裏筋を撫でられるのがいいのよね……オチンポの弱点\nなんて、すぐにわかっちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どう？　オチンポ気持ちいい？　気持ちいいなら、キスして答えて……んっ\n、んんっ……！？　ちゅ、くりゅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ずちゅ、りゅちゅ……にちゅ、くちゅ……！　れろっ、ちゅぷぷっ……あぶ\nっ、んっ、うぐっ……！　ちゅぱ、にちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ぷちゅ、ぐちゅ……！　はぁ、ああぁ……ちょ、ちょっと……！　さすがに\nがっつきしゅぎよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「気持ちいいのはわかったかりゃ……！　少し落ちついて……んちゅ、ちゅぱ\nっ、じゅぷっ、ずりゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「もう……！　エッチなことになりゅと、いっつも暴走すりゅんだから……！\n　れろっ、ぐちゅるっ……！　にちゅ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「シコシコすりゅ手の動きに合わへて、舌をペロペロしなしゃい……！　じゃ\nないと、シャセーしゃせてあげないから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゅちゅ、にちゅ……れろっ、ぺろっ……！　んちゅ、れりゅ、くちゅ……\n！　いいわ……その調子よっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ちゅちゅっ……！　んっ、あふっ……！　オチンポがどんどんカタ\nく、熱くなってりゅわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私の手……オチンポから出てくりゅエッチなお汁でベトベトになってりゅ…\n…！　んっ、ちゅぶっ……！　くちゅ、じゅじゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　口も、手も……汁まみれで……んんっ！　あっ、あ\nふっ……しゅごく、気持ちいいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オチンポを手でシコシコしにゃがら……ベロチューしてりゅだけにゃのに…\n…！　んっ、うぐっ……！　イッ、イッちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！？　オチンポもビクビクってしてりゅ……！　いっぱい\n、私の手の中で暴れてりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅちゅるっ……！　んっ、うぐっ……！　私の手に……びゅる\nびゅるセーエキ出したいのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ……いいわよ……気持ちよくしてくりぇたお礼に、出させてあげりゅ…\n…！　ちゅ……ぐちゅ、ずちゅ……！　れろっ、くちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私の手をオマンコだと思って……いっぱい、出して……！　セーエキ、全部\n受け止めてあげりゅから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅちゅちゅ……！　にちゅ、くちゅ……！　んっ、んんっ……！　\nあっ、あんんっ……ちゅぷうぅぅぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ、熱いの手にかかってりゅっ……！　ドロドロのザーメ\nン、たくさん出されてりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、はああぁ……！　オチンポがビクン、ビクンって跳ねにゃがりゃ……\n先端から、びゅーびゅーして……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　もっと出していいかりゃね……！　溜まってるセーエキ\n、全部吐き出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私の手を妊娠しゃせて……！　真っ白に染め上げて……いっぱい汚ひてっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ちゅ、ぐちゅ……！　れろっ、にちゅ……！　ああっ、んああぁ\n……！　ぐちゅ、ずちゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅ……！　んっ、はああぁぁ……本当にたくさん出したわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら、見て……私の手、真っ白になってる……くっさいザーメン、たくさん\n撒き散らされちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ベトベトのドロドロで……変なニオイが漂ってくるわ……嗅いでるだけで、\nオマンコが疼いちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ん？　どうしたの？　えっ……まだ出したい？　これだけ出したのに、まだ\nして欲しいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「全部出してって言ったのに……！　言うことを聞かないオチンポには、オシ\nオキが必要ねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら、シコシコしてあげるから、舌を出して……んっ、そうよ……くちゅ、\nじゅるるっ……！　ちゅぱ、れりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今度は……さっきみたいに、優しくしにゃいわよ……思いっきり、シゴいて\nあげりゅんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くちゅ、じゅる……ちゅぱっ、れろれろっ……こうひて、指をオチンポのデ\nコボコしたところに引っ掛けて……んっ、ちゅちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「撫でりゅようにしながりゃ、ズリズリシゴけば……んっ、ぐちゅ……！　ほ\nりゃ、簡単にオチンポが跳ねりゅでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「イッたばかりなにょに、刺激が強すぎりゅ……？　しょんなこと言ってる割\nりに、随分と気持ちよさそうに喘ぐじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほりゃ……シコシコすればすりゅほど、先端かりゃセーエキの残り汁が出て\nくりゅわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「にちゅ、ちゅちゅ……じゅる、ちゅぱっ……！　ちゅ、じゅりゅ、ちゅちゅ\n……！　ふふっ。まだまだオチンポの中に、セーエキが残ってりゅわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「遠慮しないで、全部出し切りなしゃい……！　私の手で、みっともなく搾り\n出さりぇなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅ……ずちゅ、れりゅ……！　残ってりゅセーエキだけじゃな\nくて、先走りのエッチなお汁も出てきたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そりぇに、またオチンポビクビクしゃせて……んっ、ちゅぱっ……れろれり\nゅ……にちゅ、くちゅ……イキたいのかひら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「イキたいなりゃ、思いっきりキスして……もっと、激しくベロチューして…\n…！　んっ、んちゅ！　ちゅぱっ、にちゅちゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！？　そ、そうよ……！　いっぱいキスひて……！　私の唾液\n、たくさん飲んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぶっ、ちゅぱっ、ちゅりゅちゅ！　くちゅ、ちゅぷっ、ちゅぴっ！　はぁ\n、はぁ……！　そりょそりょ、限界みたいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「出したいなら……出していいわよ……！　シャセーを許可してあげりゅ……\n！　ほらっ、イキなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ずちゅ、にちゅ！　ぺろれろっ、ちゅ、ずちゅるっ！　にちゅ、ちゅぷっ！\n　んっ、ああっ！　出してっ！　セーエキ、出して！　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぶううぅ……！　熱いのが、また手の中でいっぱいはじけて……！　にち\nゅ、ちゅぱっ、ちゅぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「れろれろっ、ちゅ……ぴちゃ、ぷちゅ……！　あんんっ……！　オチンポが\n脈打つ感じが、手のひらから伝わってくりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　んぐっ……！　シャセーの勢いが強しゅぎて、全部受け\n止められないじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どれだけセーエキ溜め込んでりゅのよ……！　んっ、ちゅちゅ……れろっ、\nちゅぱっ！　ちゅ、ぷちゃ、ぴちゃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　今度こそ、全部出し切りなしゃい……！　私の手をド\nロドロのぐちょぐちょにしていいかりゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ……くちゅ……はぁ、はああぁ……セーエキ、ちゃんと出せたかしら…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「首を縦に振ってるけど、本当に出せたの？　まだオチンポ大きくて、カタい\nままなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「これ以上シゴかれても、もうセーエキ出ない……？　ふーん。本当かしら…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「試しに、もう一回シコシコしてあげるわ。それでシャセーしなかったら、許\nしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ？　なにイヤがってるのよ。マーガレットちゃんがシてあげるって言っ\nてるんだから、素直に喜びなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぐっ、んぶっ……！　ちゅぱっ、ちゅちゅ……！　私の手から……セーエ\nキ溢れてりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……！　しょんなにオチンポ暴れさしぇないで……！　変な\nところにセーエキ付いちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「れりゅ、ちゅぱっ……！　にちゅ、くちゅ……！　あっ、ふあああぁ……！\n　セーエキのニオイが、染み付いちゃうからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ……！　エッチなニオイでイッちゃうっ……！　気持ちよくなっ\nちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「やっ、あっあっ……！　んちゅ、ちゅぱっ……！　やっ、やめっ……！　こ\nんな状態でキスしないで……！　んっ、んむううぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ちゅちゅ……あっ、あああぁ……キスしながら、イッちゃった\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002402_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「セーエキのニオイと、唾液のニオイが合わさって……すごくいやらしい香り\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いろんなところを汚されたから、洗うのが大変だわ……まったく。少しは加\n減ってものを憶えてよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「エッチなニオイのする私も可愛い……？　またそんな調子のいいこと言って\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、悪い気はしないわね……ふふっ。これからもっと、もーっと、マーガ\nレットちゃんの魅力を教えてあげるわ。覚悟しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}