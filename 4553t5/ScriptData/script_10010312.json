		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……まあ……俺の方こそ……っていうか、アナザー！　お前、怪我\nしてるんじゃないか！　無理するな。誰か、手を貸してくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
