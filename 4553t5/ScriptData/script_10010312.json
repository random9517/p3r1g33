		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「昨日は、私が言いすぎた。すまなかった、だが、帰ってきてくれて、本当に\n嬉しいぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103120003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺のほうも、カッとなって飛び出したりして……その……悪かった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私たちには、隊長が、お前が、必要なんだ！　これからもよろしく頼むぞ、\nカツマ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103120004" ]},
