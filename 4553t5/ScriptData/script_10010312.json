		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「よく戻ってきてくれた……！　ありがとう、ありがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
