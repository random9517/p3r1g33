{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あ、隊長。来てくれたんですね。ふふ、嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203101" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あのですね、今日は隊長にお礼を言いたくて……私を、今の姿にしてくれた\nことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ただのピースムーンだった私が、隊長のおかげでソレイユになれて……今も\nこうして隊長の隣にいられる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「え？　今日はやけに素直じゃないかって？　ふふ、私だってたまには隊長に\n甘えたくなるときがあるんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「素直ついでに、もう一つ。ソレイユと名がついていても、私はあなたの部下\nであるピースムーンの一人です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、今日だけは。今だけはピースムーンという集団ではなく、私個人を…\n…ピースムーン・ソレイユを見てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ……隊長はじっとしててください……今日は私が全部やってあげますか\nら……あんっ、いつもながら、大きい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000812_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、どうですか私のおっぱい……知ってるんですよ。隊長って私たちに指\n示を出すとき、おっぱいとかお尻とか見てるって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ピースムーンの皆、全員知ってるんですから。でも、隊長がこうやっておっ\nぱいで挟まれるのが好きなのを知ってるのは、私だけ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、私のおっぱいの中で、隊長のがぴくぴくしてる……可愛い。\nあんっ、だめです隊長、動いちゃだめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「覚えてますか、まだ私が普通のピースムーンだったころ、隊長は任務の失敗\nとかミスで、いっぱいエッチなことしてきましたよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「おしおきだって称しておっぱい揉んだり、お尻触ったり……色々、色々して\nきましたよねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だから……今日は私が隊長におしおきです。今までやられたエッチなこと、\nやり返してあげますから。隊長は動かないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、ふふ、隊長、気持ちよさそうな顔してますね……でもまだまだいっ\nぱい気持ちよくしてあげます……んんっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長のおちんちん、私のおっぱいの中で熱くなってきてるのが分かります…\n…硬くなって、おっぱいの中で暴れてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんんっ、あっ、だめ、だめですってば。動いたらだめ、隊長。まだまだお\nしおきは続いてるんですから。次はほら、えいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふふ、んんっ、ほら、どうですか？　おっぱいで挟んだまま、おち\nんちんをごしごしって……気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふっ、隊長の腰、動いてますよ。おちんちんでおっぱいをめちゃくちゃに\nしたいんですね？　でもだめ。まだだぁめ。待てですよ隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ほら、隊長のおちんちんなら私が動いてあげますから。こうして谷間で挟み\nながらしごいたら……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長の顔、凄く気持ちよさそう……そんなに私のおっぱい好きなんですか？\n　おしおきの時、ずっと触ってましたものねえ。やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んむっ、んっ、ぎゅってしたら匂いも凄くて、ねばついて……おっぱいの中\nが隊長でいっぱいです。あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふうっ、んんっ、ふっ……隊長、切ない顔してる……ふふっ、大丈夫\n、いっぱい愛して、いっぱい気持ちよくしてあげますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、私のおっぱいも熱くなってるの、分かりますか？　おちんちんとおっ\nぱい、一緒に熱くなって溶けちゃいそう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んむっ、うっ、んんっ……隊長、密着したままこねられるのと激しく動かす\nの、どっちが好きですか……？　んうっ、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「え？　どっちも好き？　んふっ、仕方のない人ですね隊長は。じゃあ、素直\nに答えたご褒美に、両方してあげますね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ほら、おっぱいでぎゅってしながら……こねこね、こねこね、んっ、ふうっ\n、はっ、どうですか隊長、気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、返事しなくてもその顔だけで分かりますよ……それにおちんちんも\nますます硬くなって、びくびくして……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「じゃあ次はおっぱいでごしごししごいて……んっんっんっ、ふっ、うっ、あ\nはっ、隊長、こっちも気持ちよさそう……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、イきそうですか？　でも、まだだめですよ。忘れたんですか、これは\nおしおきなんですから、勝手にイっちゃだめです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ほら、我慢、我慢、我慢してください。隊長のおちんちん、頑張って我慢し\nて……おっぱいの中で、抱きしめてあげますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふふっ、隊長のおちんちん、すっごく膨らんでます……出したい、出した\nいって……でも、まだだめ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、んっ、ふふっ、おっぱいで抱きしめてあげるたびにおちんち\nんがびくって跳ねて……可愛い、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「イくのを我慢してる顔も可愛い……んっ、隊長、全部可愛い。好き、隊長、\n好き、大好き……んんっ、んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ほら、私のおっぱいも隊長のおちんちんを好きって、ぎゅっ、んっ、むっ、\nふうっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、もう我慢の限界ですか……？　じゃあ、いいですよ。出していいです\nよ。私のおっぱいに、隊長の精液いっぱい出してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、ひあっ、ああっ、凄い……おっぱいの中でおちんちんが暴れてる…\n…ふあっ、ああっ、熱い……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ……匂いも凄くて……隊長の精液で、おっぱいが妊娠しちゃいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふっ、ふうっ、んっ。えへへ、気持ちよかったですか、隊長？　私のおっぱ\nいでごしごしされておちんちん気持ちよくなりましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「凄く良かった？　それなら嬉しいです……大好きな隊長のために、一杯ご奉\n仕しましたからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ……まだおちんちんが幸せそうにぴくぴく震えてる。私も……気持ちよ\nかったですよ、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長……まだできますよね？　エッチなおしおきをしてくるとき、一回じゃ\n終わらなかったですものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こうして、イったばかりのおちんちんをおっぱいでこねこねしてあげたら…\n…あはっ、また硬くなってきましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「いい子、いい子。隊長のおちんちんはとってもいい子……んっ、復活しまし\nたね。ふふ、精液で谷間がべちょべちょですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「覚えてますか、隊長も昔、任務に成功したとき、よくやったっていっつも褒\nめてくれたこと……んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「失敗したときはエッチなおしおきをしてくるような人ですけど、成功したら\nちゃんといっぱい褒めてくれて……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私みたいな下っ端でもちゃんと見ててくれるんだな……ってエッチでどうし\nようもない人だけど、同じぐらい優しくて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だから……好きになったんです。本気で、心から隊長のことを好き……だか\nらこんな風に愛してあげられるんですよ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ほら、にっちゅにっちゅって、おっぱいの中で隊長の精液と私の動きが混ざ\nり合って、いやらしい音がいっぱい鳴ってる、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「さっきよりぬるぬるになって、隊長のおちんちんもにゅるにゅるって動いて\n……あんっ、私のおっぱいの中で暴れてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、うむうっ、凄い匂い……だけど隊長のだって思えば好きになれ\nる……んっ、んふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふっ、隊長のおちんちん、またぴくぴくしてきました……先っぽもねばね\nばして……また出したいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でもだめ。まだだめですよ。さっきもできたんだから、今回もできますよね\n。ほら、またおっぱいでごしごししてあげますから。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「もうちょっと、もうちょっと我慢して、たっぷりと濃い精液を私のおっぱい\nにかけてください。んっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ほら、想像してください。隊長の精液で、私のおっぱいを染め上げるのを。\n私のおっぱい全部に、隊長が自分のものだってマーキングするんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「やんっ、ああっ、隊長のおちんちんもその気になってきた……顔も凄い。そ\nうですよ、私はもう、全部全部隊長のものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「頭の先からつま先まで全部、隊長のもの。隊長のことが大好きで、愛してい\nて、愛されたいって思ってるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だから、ね。出すときは濃いのをたくさん出して。隊長のしるし、おっぱい\nでも顔でも、どこでもいっぱいつけてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あはっ、隊長の顔、凄くなってる。そうですよ、私は隊長のもの。隊長の女\nです。だから、いっぱいいっぱい、愛してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「顔も、おちんちんも凄い……いいですよ。そろそろ出して。おっぱいで愛し\nてあげますから。んむっ、ぎゅっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「出して、いっぱい出して！！　私に、隊長の精液、消えないぐらいにいっぱ\nい出して！！　あんっ、あっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああああああっ！！　来たあっ！！　隊長の精液、私の胸の中にい\nっぱい来たあっ！！　あんっ、ああっ、ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「熱い……おっぱいがやけどしそう。おちんちんでどろどろに溶かされちゃう\n……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「まだ出てる……んっ、隊長のおちんちんがどくどくって脈打ってるのが分か\nります……ふあっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「本当に、おっぱいが妊娠しちゃいそう。ほら、私のおっぱいが真っ白になっ\nちゃってます……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、こうして出してるときも動かせば、最後の一滴までぴゅっぴゅって\n出せますよね。んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ……全部出ましたね。隊長、気持ちよかったですか？　ふふ、\n返事しなくても、その顔だけで分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私も気持ちよかったですよ……大好きな隊長におっぱいでご奉仕できて、身\n体中が熱くなっちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長が私のおっぱいが好きだっていうのが、おちんちんからずっと伝わって\nきてましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それにこんなにいっぱい出してくれたんですから……隊長が私のことを好き\nっていうのも分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長。これからもずっと、いっぱいいっぱい愛しあいましょうね。隊\n長……好きです。愛してます、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「やんっ、あっ、動いたらだめっ……あっ、おちんちんがおっぱいから出ちゃ\nう、あっ、ああっ、だめっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふああああっ、私の顔に、んんんっ！！　ああっ、凄い、熱いっ、あううっ\n、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「顔が……顔が隊長のでぬられて……んんんっ、匂いも、熱さも凄い……ふあ\nっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「おっぱいも、顔も隊長に染められてる……んっ、口の中も……んくっ、おい\nし。ふふ、隊長の味ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひゃん！？　最後にこんな勢いよく……え？　私の顔がエッチだったから？\n　もう、エッチなのはどっちですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふっ、どうですか？　隊長の好きなようにされた私の顔とおっぱい……あ\nはっ、隊長の顔を見ただけで分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「凄い匂い……こんなの身体中につけられたら、洗っても隊長の匂いだってば\nれちゃいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、その方がいいかな。だって、私が隊長のものだっていうのは当然のこ\nとですから。ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、またいっぱいいっぱい気持ちよくしてあげますから、次もこんな風に\n隊長のしるしをたくさんかけてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「大好きです、隊長……ふふ、恥ずかしいですね。でも本気ですから、私。こ\nれからもずっと、愛してます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}