		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ、あひぁっ、またっ……主様もっ……出したくなってますかっ\n？　あぁっ……ウチのイキ顔で興奮してくださって……！」", "NORMAL" ]},
