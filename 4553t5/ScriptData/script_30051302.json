		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁひぃぃぃんっ！　また……中にっ……あちゅいのっ……れてまひゅっ！\n　主様のトロトロ子種っ……出てっ……まひゅぅぅっ！」", "NORMAL" ]},
