{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……主様……ようやく二人きりになれました……ウチはずっと待ってい\nたんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「でも、もう邪魔するモノは何もありません。今日は特別な夜……たっぷりと\n愛の契りを交わしましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ああ、主様は楽になさっていて下さい。ウチが全て万事滞りなく進めていき\nますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ほら……もうオチンポも我慢出来ないですよね？　分かりますよ……ウチの\nオマンコがすぐ近くで……早く味わいたいって先っぽを濡らして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、この入り口同士でキス……んんっ……どうですか……もうちょっと\nで入る位のこの感じだけでも……悪くないですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「濡れてる……？　ええ、それはもう……今日はもう朝から、主様のオチンポ\nをいただくことばかり考えていましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのオマンコはずっとぐしょぐしょ……心臓もドキドキして……あぁ……\n本当にどうにかなってしまいそうなんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あぁ……主様のオチンポも先っぽが震えて……ふふっ、もうハ\nメたくて仕方ない……そんな風ですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……かくいうウチも、もう我慢の限界です……焦らす余裕なんか全然な\nくて……はぁぁ……ダメです、もう挿れちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁぁぁんっ！　あっ、オチンポっ……ぶっすりっ、あぉっ、入っ\nて……来ますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……ほぉら、オチンポ……オマンコがぱっくり食べちゃいましたぁ\n……ここぉ……ズッポリハマってるの……見えますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの割れ目がいやらしく広がって……んっ、オチンポに吸い付いてるとこ\nぉ……あぁ……ゾクゾクするいやらしさですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっく……こうして、ズッポリハメてるだけで……もうイキそう……でも、\nそんな勿体ないことは出来ません……気をしっかり落ち着けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、これで大丈夫……さあ、本格的に動いて参ります……ウチの、いや\nらしい……淫らでスケベな腰使い……たっぷり味わって下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、おっ、おんっ、あぉっ、ほぉっ、おんっ、あっ、あぉっ、おんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁっ……ずりゅずりゅっ……擦れるのが……気持ちいいっ！　くぅ\nぅんっ、オチンポッ……ヒダをっ、いっぱいに広げてますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……本当に凶悪なオチンポです……いやらしい形でウチを誘って……\nいざ入ったら、この気持ちよさ……悪魔的ですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……ウチのオマンコの方がよっぽど……ですか？　そうですね……この\nぬめり……締め付け……全部主様の為にしてますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「今まで味わって来たどのオマンコよりも感じるように……ぴったりオチンポ\nに馴染ませて行きますよ……ん、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ、はっ、リズムよくっ……上っ、下っ……グラインドぉっ…\n…はひっ、あふっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……この硬さ……んくぅっ、ウチのオマンコを押し広げようとする意志\nをビンビンに感じて……うっとりしてしまいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……こうして、ズボズボすると……ウチのいやらしいマン汁が、はし\nたない音をさせて……はぁうん……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「なのに、あぁ……止まらない……んんっ、こんな下品な音をさせてると思う\nとぉ……興奮しすぎてぇ……止まらないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁっ……主様……ウチのことを舐め回すように見てます\nね……？　んふぅっ、どこがお気に入りなのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「いつもと違う……ハロウィン衣装……でも、やっぱりそれ自体より……おっ\nぱいと……やっぱり、オマンコが気になって仕方ない感じですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「え……顔……？　あ……ウ、ウチがオチンポをズボズボして……感じてる顔\n……はぁぅ……そ、そんな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……やっぱり主様は油断ならないお方……そんなことを言われて、\n改めてまじまじと見つめられたらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、は、恥ずかしいっ！　主様に……オマンコ感じてるとこぉ……見られ\nてぇっ……あひっ、あぁっ、感じ……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、ですが……言われっ放しのウチではないですっ……主様の余裕がな\nいのも……ウチのオマンコはちゃんと分かっていますからね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ほら……んんっ、このキュウっと……オマンコを締め付ける時……主様の鼻\n先がピクって動くんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「これ……我慢してる時のやつですね？　とぼけても無駄です……んふっ！　\nほらっ、今もピクってしましたよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「どうやら、ウチのオマンコが良すぎて、オチンポも余裕がなくなって来まし\nたね……ククッ、ここまで来たらうちのペースですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「悪い顔をしている？　今頃気付いたのですか？　ウチは、裏の存在……例え\n主様でも、遠慮なく搾り取る女です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、さあ……観念して……このドロドロのオマンコの中に……ありった\nけの子種を全部注ぎ込んで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの本気のオマンコピストンッ、存分に感じてっ……そうですっ、このま\nまっ、中出しぃっ、はっ、あぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　出たっ……出てますっ、主様の……濃厚な子種汁っ……熱\nいのっ……種付けされて……ますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁんっ……熱い……どぷどぷ来てる……子宮に届いてっ、おっふ\nっ！　イクッ……あぉぉっ、ウチのオマンコもイキ、ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……はぁっ、はぁっ、あっ、ふっ……はぁぁぁぁ……あ、んぁぁ\n……すご……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……あぁ、身体がピリピリしてます……串刺しのまま、全身に気持\nちいいのが広がってぇ……ウチの細胞が全部変わっていく感じです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……素晴らしいオチンポでした……主様……ウチはこれからも、主様\nと……このオチンポに尽くして参ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はふ……さて……一旦射精も落ち着かれたことですし……そろそろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はい、続きをしてもよろしい頃合いかなと思いまして……え？　何を驚かれ\nているのです。ふふ……オチンポはまだまだ元気ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの身体もまだ疼きを持て余して……んんっ、もっと欲しいと感じている\nのです……あっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ……流石は欲望に忠実な主様……みるみるオチンポが硬さを取り戻し\nて……本当に頼もしいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「お任せ下さい……こんな風にさせた責任は、ウチの腰振りで……ちゃんと取\nりますからぁ……あんっ、はんっ、いちっ、にっ、いちっ、にっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁん……さっきとは、違う動きで……変化を与えてぇっ……あっ、おぉん\nっ、あぉっ、おふっ、はぉぉぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、腰を回すのっ……ぐりぐりっ……あぉっ、いいっ……！　あ\nふぅっ、ウチのオマンコっ……喜びのよだれ……止まらないですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁぉっ……おふっ……あぁっ、主様からの突き上げも……来てぇ\nっ……あぉっ、はんっ、あぁっ、そこっ、効きますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ずりゅって……あっ、一番深いところを抉られるのいいっ！　あぁっ、主様\nの本気のオチンポっ、気持ちよすぎますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……また……ウチのいやらしい顔を見てるんですか……？　\nあぁ……自分で分かってても、緩んじゃうんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「このだらしないよがり顔ぉっ……あぁっ、絶対主様以外には見せられない、\nスケベ顔ぉぉっ……でも、見て……下さいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あひっ、はひんっ、あぁっ、激しいっ、ずりゅずりゅ……オマンコ擦れてっ\n……さっきの精液が……染み渡ってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁぁんっ、いいっ、オチンポ気持ちいいっ！　あぉんっ\n、もっともっと激しくしますぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、ふっ……あぁっ、駄目です……こんな、気持ちいいのっ……ず\nっとしてたらっ、またウチのオマンコッ……すぐイキますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁぁぁっ！　あっ……イッ……イクッ……はぁぁっ、オマンコッ\n……ビクビクしてっ……あ、ひぃっ……蕩けますぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……しゅごい……主様のオチンポ……止まらなくてぇ……はぁ、あん\nっ、はっ、ウチ……ずっとイッたままなのにぃ……」", "NORMAL" ]},
