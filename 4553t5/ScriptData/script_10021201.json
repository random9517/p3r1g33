		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だよねー。ここのカツマくんとは初めましてだよねー。ボクは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114440002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま、気を付けてください！　その人は、時間帝国の道化師・ジェスタ\nです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114440004" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「うむ、決まったな！　我の旗の下で、我とともに戦え！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "海賊たち" ]},
		{"command":[ "SETTEXT", "「あんたのじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114460003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00013601_01", "7", "CENTER", "400" ]},
