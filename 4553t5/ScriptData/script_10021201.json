		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「今回の『悪の女幹部ペリジーニュームーン』は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114480002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "襲来者の大艦隊に、フィルとシャムの海賊戦艦は殴り込んだ。そして……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「状況を報告しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙海賊Ａ" ]},
		{"command":[ "SETTEXT", "「シールド、８５％に低下！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙海賊Ｂ" ]},
		{"command":[ "SETTEXT", "「３番砲塔の照準ユニット、Ｃ１２Ｄが不調！　まあ、カンで調整できます！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ワイはいま忙しいねん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「忙しいのはこっちだよ！　邪魔しないで、プラモでもつくってな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114480002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「しょぼ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114480002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うわあああ！　レーダーちゃんに、また敵艦ちゃんの反応が！　敵が七分に\n宇宙が三分よぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうするんだい！？　このまま突っ込むのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「いまさら迂回なんかできないよ。弱みを見せたら、尻尾をつかまれるだけさ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114480003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「それに、宇宙軍から通信が入った。敵艦隊の背後で、大規模な量子変動を観\n測したって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ワームホールか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「その公算が大きいって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114480002" ]},
		{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「だとすりゃ、ますます退くわけにはいかないね！　はははっ！　どんどん面\n白くなってくるねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114480004" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「『面白い』ではすまなくなってきたような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114480001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「こまけえこたぁいいんだよ！　全艦、対ショック対光学兵器防御！　突っ込\nむよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114480003" ]},
		{"command":[ "SETCHARA", "0", "char_00013601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "と、シャムたちが突撃をかけようとしたとき。戦闘宙域に謎の宇宙船が現れた\n。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「あたしゃ～宇宙の～～♪　あたしゃ宇宙のトラッカ～～♪　っと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114480001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んん？　前方通行止め？　艦隊戦による交通規制だぁ？　なんでぇなんでぇ\n！　面白そうじゃねえか！　見物させてもらうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114480002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「どけどけどけ～い！　あたしのフネは誰にも止められねえ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114480003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}