		{"command":[ "SETNAME", "ルナテミスＧ" ]},
		{"command":[ "SETTEXT", "「こ、こんなときにか？　こんなときにキスなのか！？　だが、しかし愛する\nお前がそういうなら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_070105090001" ]},
