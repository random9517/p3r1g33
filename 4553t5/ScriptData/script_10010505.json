{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_010" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3", "4", "5", "6"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ……どうやら、偽者は全員捕まえたようだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＡ" ]},
		{"command":[ "SETTEXT", "「だから！　本物まで捕まえてどうする！　放せっ！　放せーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「何を言っている！　本物は私だ！　私を放さんかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＣ" ]},
		{"command":[ "SETTEXT", "「違うっ！　私だっ！　私が本物だっ！　早く放せーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_030105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「うえええええーん！　あたちが本物なのに、みんながいじめるぅ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_040105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうやら、本物も一緒に捕まえちまったようだねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まあ、どう考えても偽者、というのも大勢いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「とにかく、ひとまず本物の可能性があるルナテミスと、明らかな偽者に分け\nましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったく、手間かけさせてくれるぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "というわけで、ルナテミスを２グループに分けてみた。まず、あきらかな偽者\nグループ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「カツマお兄ちゃーん！　あたちが本物なのよぉ～っ！　びええええ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_040105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＥ" ]},
		{"command":[ "SETTEXT", "「違う！　本物はボクなんだ！　カツマさん！　エファさん信じてくださいっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_050105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＦ" ]},
		{"command":[ "SETTEXT", "「わ、わ、わ、わ、わたっ！　わたしっ！　わたしが本物ですっ！　ですった\nら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_060105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……ああ。こいつらは違うねぇ。どう考えても、ルナテミス様じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だろ？　まあ、こいつらはまとめて営倉にでもぶちこんでおくとしてだ。問\n題は本物っぽいグループだよなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だなぁ……１０人ぐらいには絞りこんだけど――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＡ" ]},
		{"command":[ "SETTEXT", "「いいかげんにしないかお前たちっ！　私が本物だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「違う！　私が本物だ！　早く私を解放しろ、このボケナスビどもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＣ" ]},
		{"command":[ "SETTEXT", "「何をやっているのだ貴様らっ！　私が本物だと、一目見ればすぐわかるだろ\nう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_030105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うーん……さすがにこれは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、ぜんぜんわかんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「つきみ、あなたはどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うーん……ルルーナちゃんの姿ならわかると思うんだけど、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「無理もないね。あたしらでさえ区別がつかないんだからねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスたち" ]},
		{"command":[ "SETTEXT", "「区別をつけろぉーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "LEFT", "0" ]},
	{"command":[ "SETCHARA", "1", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "SETCHARA", "2", "char_00000101_01", "7", "RIGHT", "0" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そう言われましても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか、いい方法はねえのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「というか、どうして急にルナテミスの偽者たちが現れたんですか？　やっぱ\nり、別の次元のルナテミスとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、そうではないようだ。詳しいことはまだわからないが、どうやらワー\nムホールに何かを仕掛けられたらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ワームホール？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ。実はさっき、ルナテミスが出張から戻ったときのことなのだが――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「空間転移完了」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス、出張ご苦労だった。カツマたちが待っているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……帰ってきて早々、暑苦しいヤツの名前を出すな。報告しなければならな\nいことぐらい、貴様に言われなくても――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_080105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス" ]},
		{"command":[ "SETTEXT", "「やぁ～ん！　早くカツマに会いたぁ～い！　カツマに会って、ちゅっちゅし\nてあげるのぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_080105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　なんだぁ！？　ルナテミスがもう一人……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、な、な、ななな、なんなのだ貴様っ！　それに貴様、カツマに何をする\nだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマぁ～～～～待ってて～～～！　ルナちゃんが、ただいまのキスしてあ\nげるぅ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_080105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、お、お、おいっ！？　貴様いったい何を言っている！　そんな恥ずかし\n――馬鹿げたことを本当にするつもりか！　待て、こらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お、おい！？　ルナテミス！？　どこへ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス２" ]},
		{"command":[ "SETTEXT", "「なんだ！？　カツマだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_090105090001" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0060" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス３" ]},
		{"command":[ "SETTEXT", "「カツマ先輩！　今行きますから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_100105090001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス４" ]},
		{"command":[ "SETTEXT", "「私が帰ってきたのに、出迎えにこないとは！　どういうつもりだカツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_110105090001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス５" ]},
		{"command":[ "SETTEXT", "「どうしよう！　ルナテミス先生がいないと、カツマが死んじゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_120105090001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミスたち" ]},
		{"command":[ "SETTEXT", "「カツマぁ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_090105090002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんだ……なんだ……！？　今のは、いったい……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090008" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミスが……ルナテミスがいっぱいだぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090009" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……と、いうわけだ。その後も、しばらくワームホールはルナテミスを吐き\n出し続けてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090010" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａジュンジロー" ]},
		{"command":[ "SETTEXT", "「１２分３２秒後に消失した。それまでに出現したルナテミスは、おそらく３\n００人以上」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_040105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さ、さんびゃくにんっ！？　一人でもウザいのが３００人以上だとぉ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが、なぜそんなことに？　ワームホールに何か仕掛けられたとかおっし\nゃっていましたが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。今の時点では、あくまでも仮説でしかないのだが……ワームホールを\n通過するときに、ルナテミスがコピーされたのではないだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090011" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ルナ様を……コピー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなことができるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私は科学者ではないので、詳しいことはわからないが人間の構造を原子のレ\nベルまで解析し、人工的に再構成できれば――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090012" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「外見はもちろん、記憶も、性格も同じ人間をもう一人作り出すことができる\n。つまり、人間をコピーできるのだとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そして、その解析を行うのはワームホールを通過している時が最適だとか、\nそんな研究をしている科学者が、どこかの宇宙にいるらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なるほど。どうやったかは知りませんが、外見はそっくりに再現できていま\nすね。性格の再現は……まだまだ不確実なようですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも～？　性格までそっくりにできちゃってるルナさまたちもいるし、そっ\nちは面倒よ～？　どうやって見分けるの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105090002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そうですね……。実は、アナザーさんのお話を聞いて考えたことがあります\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いい手があるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090015" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい。本物を見分けるのに、カツマさんを使っては？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？　ちょっと待ってくれよ。おまえらに見分けがつかないもの、俺にだっ\nて――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「見分ける必要はありません。ルナテミス様にキスをするだけでいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「えええええええーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090016" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000601_01", "3", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00001201_01", "9", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00001401_01", "3", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「キ、キキキキキ、キスッ！？　口づけ！？　接吻！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どういうことですか！　どうしてカツマさんのキスでルナテミスを見分けら\nれるんですか！？　納得のいく説明をしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090006" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　どういうことなのだ！？　わかるように説明しろ今すぐっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090017" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「アナザーさんまで動揺してどうするんですか。まあ、本当にキスする必要は\nありませんね。ふり、だけで十分だと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090008" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あとは、ルナテミス様の反応で見分けることができるかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか。いや、すまない。私としたことが……しかし、キスのふりで、\nどうして本物を見分けられるのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090018" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「先ほどのアナザーの話を聞いていると、コピーのルナテミスはなぜか、みん\nなカツマさんに好意を持っているようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090010" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はっ！　そういえば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090007" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_010" ]},
		{"command":[ "SETNAME", "偽ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ！　そうだ！　あたし、ちょっと用事を思い出しちゃったぁ！　ごめんね\n、みんな！　それから、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_080105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "偽ルナテミス" ]},
		{"command":[ "SETTEXT", "「あとでね？　ちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_080105090005" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0053" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そういえばこんなことが……こんなことがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090008" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふひっ！　フヒヒヒヒヒッ！　そうだった……！　誰！？　あのときのルナ\nテミス様は、この中の誰……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「姉ちゃん！　カグヤ！　落ち着いてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105090003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、そうね！　カグヤ、落ち着きましょう。まずは、本物のルナテミスを、\nそして、さっきの偽者をこの中から見つけ出すのが先！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090009" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大丈夫。キスは『ふり』だけ。『ふり』だけだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そう……カツマは、本当にキスなんかしない。私がさせない。キスのふりだ\nけ、ふりだけ……フフフフフフフフフフフフフッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。私たちがきっちりとガードし、カツマの貞操――ゲフンゲフン、\n身に危険が及ばぬようにだな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090019" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの……皆さん？　なんか俺の意志は置き去りなまま、不穏な方向に話が進\nんでやしませんか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたを使って本物を見つけ出すことには、皆さん賛成のようです。あきら\nめてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105090011" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まあ、オトリにされたり盾にされたり、書類仕事を全部押し付けられたりする\nのに比べりゃ、数段ましか……うん……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「では、始めよう！　まずは、一番右端にいたルナテミスを連れてきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090020" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "RIGHT", "0" ]},
	{"command":[ "SETCHARA", "1", "char_00000101_01", "0", "LEFT", "0" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「了解しました。では、カツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090011" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "言われるままに、縛られたルナテミスの肩に手を置き……。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＣ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　下僕！　私にいったい何をするつもりだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_030105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0054" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETTEXT", "顔を近づけていく――", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＣ" ]},
		{"command":[ "SETTEXT", "「そうか、カツマ。お前はわかってくれたのだな。私が本物だと。カツマ……\nお前との愛の絆は、どんなときでも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_030105090005" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0056" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はいそこまで！　これは偽者！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げふっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミスはこんなことを言わん！　まりあ、営倉へ連行しろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090021" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい！　さあ、キリキリ歩きなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090012" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＣ" ]},
		{"command":[ "SETTEXT", "「なぜだ！？　なぜだぁ～！　いいところだったのにぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_030105090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "「なぜだ！？」と叫びてえのはこっちだ！　なぜか今、俺が殴られたぞ！？　\n偽ルナテミスのほうじゃなく！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ、時間がもったいない！　キリキリ行くぞ！　誰か！　次のルナテミス\nを連れてきてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090022" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おいーっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスはあと９人……。なんだか、とてつもなく嫌な予感がしてきた……\n。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0054" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETNAME", "ルナテミスＡ" ]},
		{"command":[ "SETTEXT", "「あああ、カツマ！　私を抱きしめてくれ！　そして熱いキスを――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_010105090004" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0056" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はい偽者！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
