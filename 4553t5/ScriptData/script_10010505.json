		{"command":[ "SETIMAGE", "0", "sbg_0056" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ぶちこめ、カグヤ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぎっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げふうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「むう……これでもう８人か。なかなか本物は見つからんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090024" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうして……？　どうしてみんな、カツマにキスされたがるの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090008" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうして……？　どうして毎回俺が殴られるの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ですが、これで８人が偽物だとはっきりしました。本物は、残り二人のどち\nらかです。がんばりましょう！　カツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090013" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とほほほほほ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本物が見つかる前に、俺、死ぬんじゃねえかな……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「よし、セレーナ！　次のルナテミスを頼む！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090025" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はいよぉ～！　ほら！　キリキリ歩けって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「ふん！　最初から私が本物だと言っているではないか！　それがわからんよ\nうな貴様らが尋問など――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はいはい、その余裕もいつまで続きますかね。カツマさん、お願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090014" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はいはい、わかったよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0054" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ下僕。なれなれしく人の肩に手など置いて、どうするつもりだ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん～、ちゅぅううう～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「ん……？　口をそんなにとがらせて、何の物まね……って！？　ま、まさか\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そのまさかだよ～だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「な！？　な！？　なななっ！？　き、貴様いったい何を！？　おい！　よせ\n！　やめろ！　いやらしい汚らわしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090009" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090015" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0055" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「何をするつもりだこのボケナスビぃ～～～っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほげっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「頭突き！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「今までにない反応！？　まさか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「貴様、貴様っ！　貴様のような下僕が！　便所コオロギがっ！　こともあろ\nうに私にキキキキキ、キスなどとっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げふっ！　がふっ！　ふぐぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「縛られたままで頭突きのラッシュだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「何を考えているっ！　何を考えているのだっ！　このっ！　この変態っ！　\n変質者っ！　性犯罪者っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぐっ！　ひぐっ！　ごほっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「体重の乗ったストンピングの嵐！　この反応は、まちがいありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090017" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「本物のルナテミス！　よかった！　見つかった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090027" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「って！？　そろそろ止めないとカツマが危ないんじゃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090011" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0055" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミスＢ" ]},
		{"command":[ "SETTEXT", "「このっ！　このっ！　このこのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_998_020105090011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あああああ、そうでした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　そこまでだ！　止めてくれーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマを殺さないでーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんか、遠くから、カグヤたちの声が聞こえる……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ、なんか大きな川ときれいな花畑が……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あは、あは、あははははははは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_010" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……ひでえ目にあった……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090013" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫に見えるか、これが！　渡っちゃいけない川を渡るとこだったんだぞ\n！？　あとちょっとで！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく！　偽者をあぶりだすためとは言え、あのようなハレンチなことを\nするからだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "好きでやったわけじゃねえよ！　まったく！　いや、それはそうと……？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「偽者は、あと一人いたはずだよな？　そいつはどうなった？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「倒れているカツマを見たとたん、すがり付いて泣き出したからすぐに偽物だ\nとわかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105090029" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「即、営倉入りです。今ごろお仲間と一緒に、反省会でもしてるんじゃないで\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105090019" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマが動けないのをいいことに、あんな触り方するなんて……許さない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105090014" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "怖ぇ……。こいつら、なんか、マジ怖ぇ！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなことより、偽のルナテミス様はまだ２５０人以上いるはずだよ！　さ\nっさと全員捕まえないと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いた！　あそこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105090004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なに！？　……はぁあああ！？　なんだ！？　あいつら、いったい何をして\nいる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほほう。数人のルナテミス様がコンビニ前にたむろって通行人を威嚇してお\nりますな。まるでウン十年前の田舎の不良のようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010105090001" ]},
	{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あいつら……！　私の姿で、そんな恥ずかしいことを……！　\n捕らえよ！　奴らを全員、今すぐ捕らえよーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あれではご近所で、私の評判がガタオチではないかーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105090008" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
