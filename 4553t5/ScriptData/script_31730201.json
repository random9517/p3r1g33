{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああ、良かった。そこにいたのね。あなたに一つ聞きたいことがあって探し\nていたんだけど……今、時間あるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「『メイドはご主人様に尽くすもの』であると本に書かれていたのだけど、尽\nくすとは具体的にどういう事？　今まで経験したことがないからわからないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンのあなたなら詳しいんでしょう？　こういうこと……。ええ。『ご\n主人様の命令に背かず、全てにおいて肯定すること』……ふぅん？　そう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「服従の真似事？　そうすることで何かしらの利益がある？　わからないけれ\nど……今の私はメイドなのでしょう？　であれば、命令したらどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……そんな偉そうなメイドがいるかって？　……本当にわからないのよ。実\n践で教えてくれるかしら。ほら。ほら、ご奉仕とやらをさせてみなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……授乳手コキ……？　また、私の知らない言葉が出てきたわ……。ねえ、\n本当に……ニンゲンのご主人様は、こんなことで喜ぶのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そうよ。なんでも命令しろと言ったのは私よ。でも……ちょっと想定をはる\nかに超えていて……困惑しているのは確か。ペニスを手で握って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「手を上下に動かして、コく……。シゴくのが手コキで合ってる？　それから\n……授乳……。これは母親が、子どもに乳を与える時のポーズよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……。もう既に、あなたをご主人様にした自分のことを後悔してるわ…\n…。なんなの、授乳手コキって。意味がわからない。戸惑いしかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「で、も……。ご主人様がしろと言ったことをするのがメイド……。フン、ま\nだ納得もできていないが、一度口にした約束を守るのがメガネエルフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「いいだろう。メイドとして、完璧にやりとげてみせよう。まあ、そう難しい\nことではないだろう。私は楽器を常に奏でている。指は器用だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……言い換えれば、楽器を演奏するための大事な指と手なのだが……うぅん\n……。こればっかりは、選んだご主人様の命令次第だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「まぁいい。さっそくメイドの仕事に励むとするか。……って、ま、待て……\n！　な、なぜ私の乳首を、胸を吸う！？　な、舐めるっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「授乳とは、私が一方的にっ……乳をのませるだけのことで！　そちらからの\n行動は許していないぞ！　……っ、な、なんだと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「母乳が出るわけでもないのだから、黙ってオッパイをしゃぶらせろ……っ？\n　くっ……！　こ、これだから卑しいニンゲンは……！　んっ、あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「せ、せめて優しく吸え……っ！　メガネエルフの胸は敏感なのだ！　っぅ…\n…っ！　し、しかも、乳首だけではなく乳輪や乳房までしゃぶってくるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そ、その上……乳首を甘噛みしたり、舌で転がしたりぃ……っ！　バリエー\nション豊富に愛撫するのはや、やめ、ろぉ……くすぐったい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「これでは手コキに集中できんだろうっ……！？　な……何？　気にせずやれ\n？　奉仕の心でやれ？　こ、こんなにメイドが大変だとは……ぶつぶつ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「わかった！　ご主人様の命令であれば仕方ない！　や……やるぞ。……ん…\n…。ん、ん……。こ、こう……か？　ペニスに指を絡めて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「上下にシゴく……。んっ……。力加減はどう、だ……？　これくらいでいい\nのか……。んッ？　もう少し強く……？　こ、これくらいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「っふ……っ。音をたてて胸を吸うな……集中力が途切れ、る……んんっ……\n！　ち、違う。感じているからではなく……。っんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「乳首が硬くなってきているだと？　わざわざ報告してくれなくていいっ……\n！　舐められすぎて条件反射でそうなっているだけ、だ……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「別に……っ、はぁ、はぁ、き、気持ちいいわけではなくて……。あンッ！？\n　い……今の声は忘れろ。ペニスに集中しろと言っているだろうっ……あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あ……あ……、うぅ……っ。ふ、うぅ……っ。乳首をじゅるじゅる吸われて\n、舐められて……。こっちの指先が痺れてく、る……んっ。ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「負けるか……！　ご主人様を感じさせるのは、ご奉仕するのはこちらの方だ\n！　メイドの手コキでメロメロに腰砕けになるがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「っはぁっ、はぁっ、はぁ……。シコ、シコ、シコ……。ぐに、ぐに、ぐに…\n…んんんっ。お、おい……ご主人様。なんだ？　このペニスは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「手の中でどんどん熱く、硬く、長く成長しているぞ……。ふぅうっ♪　ニン\nゲンのくせに生意気な強いペニスだ……。悔しいくらい……。んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「メイドを従えるからには、逞しくそそり勃つ、強靭なペニスを持つご主人様\nである必要があるということか……？　まだまだ知らないことばかりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んっ……。し、しかし私の手コキも少しずつうまくなってきた、だろう……\nっ？　ちゅるちゅる乳首を吸われながら、しているにしては……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ねっとりとペニス全体をシゴきあげて……んっ♪　裏筋を人差し指でなぞり\n、カリ首を親指で刺激し……っ。はぁ、はぁ、根元から先端まで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「隙間なく密着させた手のひらで甘くシゴいているのだからな……！　んっ、\nもしや私には……天性のメイドの才能があるのかもしれんぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ふぅっ、ふぅうっ……ふぅ……。少し暑くなってきたな……。んっ、胸を吸\nわれて身体が火照っているからだと……？　う、うるさいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様……早くペニスから精液を射精してください……。っふぅっ、あっ\n、うう……んんっ、こ、こちらにも性感というものが、ございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「胸ばかりそのように、ご主人様の口で攻め続けられます、とぉっ……！　あ\nっ、こちらも、もちません、ので……早くイけっ……は、やくぅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「イけっ……イけぇっ！　あっ！　こ、こっちも……こっちも、もうっ！　あ\n、ぁ、あああああっ……！　しゃぶるな、吸うなぁあああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んッ！？　あっ……あっ、ああああぁああっ……！　なんということだ、胸\nだけで勝手にイかされてしまって……あううっ、ううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「だが、こちらも手コキで同時に射精っ……あああ、精液を絞り出している、\nのだから……お互いさまだ、それでいいなっ？　あっ……うぅっまたイクっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ……ッ！　ご、ご主人様の逞しいペニスから、大量の精液が\n噴き出して、あ、溢れていますよ……！　そんなに気持ちいいですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「メガネエルフメイドの授乳手コキっ、き、気に入っていただけて光栄……で\nす、んっ、くぅっ……！　美味しい、ですかメイドの胸は……っ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「す、すごい……。こんなに何度も精液が飛び出すなんて……。あっ！　あっ\n、手にかかるっ……垂れてくる……。なんて濃い臭いなんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……何？　私の手コキが巧みだったから、メイドの才能があったからこんな\nに出た、だと……？　そ……そう言われれば悪い気は……しないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「少し気に入らないのは……その。こちらはさんざんに胸でイカされてしまっ\nたというのに、あれだけ射精しても……ペニスが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あなたのペニスが萎えてこない……。つまり、まだ満足していないというこ\nとだ。いくら口先で褒められても、現実、ペニスが昂ったままとなると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……ん？　射精自体はちゃんとできた？　嘘をつくな！　ならどうしてペニ\nスがこんなに……。ん！？　まだしてほしかったから！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「な……なんということなの。射精して即座に復活した、と？　本当に？　だ\nって……最初よりも……太くなっているし……。熱い。硬いし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「御託はいいから早くシゴけ！？　私をなんだと思っているんだ！　……あ、\nメイドか……。そうは言うが、こちらはまだイッた余韻が……。って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んっぁッ……！？　ま、また胸でイカせるつもり！？　んんんっ……あんっ\n！　んんっ、や、やめ……ああああっ！　わ、わかった、からっ」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「授乳手コキを続けるからっ……そんなに強く吸わないでちょうだいっ……！\n　……あぅううっ♪　はぁっ、あぁ、うう……き、気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ！　あっあっぁっ……！　こっちは疼きが収まっていない、のに……す\nぐにそんなに激しく吸って……！　っあっ、ま、またすぐイキそうになる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あぁっ……ああ、い、いじわるぅ……。でも今は、私はメガネエルフメイド\n……。ご主人様の、はぁ、命令は、はぁ、絶対……従うべきぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ご主人様……っ。いかが、ですかっ……あなたのメガネエルフ\nメイドの胸の味は……っ、んんぅっ、ペニスの具合、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「た、大変よろしゅうございます……ッ。あれだけ精液を放っておいて、……\nあふっ、一瞬で全力全開になられて……ガッチガチです、……んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「舌使いも慣れてきて……あっ♪　私の乳首をねぶるやり方も、吸引する力の\n強さもぉおおっ……！　あうっ、ぜ、絶妙で、素晴らしい愛撫です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ん、ひっ……！　んふぅっ、ぅうううっ……！　いやらしい声が漏れてしま\nいます、卑猥なメイドで申し訳ありませんんっ……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「乳首、もっと吸ってくださいっ！　下品に水音をたてて！　あっ、ペニスの\n先端から透明な液体が滲み出してきていますよ……んんっ、いいですねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「この汁をペニスに指で塗りたくって……溢れた精液も使って、潤滑油にして\n……。ぬちゅぬちゅっ、くちゅくちゅっ、シコ、シコ、シコッ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……♪　ご主人様……私の手の動きに合わせて、腰をヘコヘコ動\nかしておいでですね……♪　ご堪能いただけているようで何より、です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「さあ……このままっ、このまま共に高みへとのぼっていきましょうっ……、\nんっ、あっ、あぁっ、あなたが私の胸を吸う力が強く、なってっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私も、それにつられて……指に力がこもる……♪　んぁ……、ご主人様。び\nゅっびゅしてください、射精するところを見せてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「も……もちろん、私も共に果て、ますぅっ……！　あッ……あああっ、チン\nポが膨らんで……太く、熱くなって……イクのですねっ！　あぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんっふぅううっ♪　ふぅううっ……ビュクッ、ビュクッと溢れて……飛ん\nで……♪　二度目の射精なのに、なんて元気なのっ……驚くわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、いやだ……♪　抑えきれないっ……、あんっ。手のひらで精\n液を食い止めようとしても、指の間からこぼれちゃう……ウソでしょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あぁんんっ、熱い雫がドポドポ手の中に……♪　それ、にぃいっ♪　私の胸\nっ、精液に反応してずぅっとビクビク痙攣してるっ、あぁっあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「乳首っ、吸われすぎて伸びるぅうっ……♪　でも、離さないで……吸って、\n吸い続けて……！　ッあっ♪　イクっ、また乳首でイクぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ♪　噛んで♪　甘噛みしてっ……！　私も最後まで……ご主人様の……\nっ、あなたのチンポをシゴき続けて精液絞り上げるからぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「っはぁああっ♪　あぁああっ♪　いいっ、いいわっ……！　メガネエルフメ\nイドの極意……習得できたかもしれないっ……！　んふぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あ……♪　あ、ぁ、あ……♪　ご、ごめんなさい……。あまりに夢中でチン\nポを握りすぎていたわ。こんなに力をこめていたら血が止まってしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そしてあなたも……！　私の胸をいつまで吸っているの！　もうっ……。あ\nなたはご主人様で、赤ちゃんじゃないのよ？　わかっているのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ん……。そ、そんなに美味しい……？　そ、そう……。それなら……また時\n々吸えばいいじゃない。メイドの時でも、そうじゃなくても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そのかわり、またわからないことがあったら教えるのよ。それが交換条件だ\nから。い……いいわね？　わかったと素直にうなずきなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　か、顔まで飛んでくるなんてっ……。ご、ご主人様？　照\n準が随分高く……、っあっ！　熱っ……んっ、ぷぁっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「メ、メガネに……！　メガネにとんでもない量の精液が……んんっ！　こび\nりついて、垂れて……ああぁ、しっかり跡が残っていくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ……んふっ、ご……ご主人様、いくらなんでも出しすぎです…\n…！　んぷっ！？　んぅっ、す、すごい臭い……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「頭がぼうっとする……♪　ご主人様の精液、濃厚すぎて……っ。臭いで呼吸\nができま、せん……。あっ……あっ、全然止まらないぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私の胸も、精液に反応して……ずぅっとピクピク震えてる、感じ過ぎて硬く\nなりすぎてるぅ……！　あぁっ、も、もう十分です、ご主人様ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「これ以上顔にかけられたら……んんんぁっ！　この臭いを忘れられなくなっ\nてしまう……。んっ、口にも入って……あ、ぁ、に、苦いぃ……おう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁあっ、はぁああ……。よ、ようやく出し終わったのか……。一度出した\nすぐ後に、これだけの量を出せるなんて……ご主人様の才能がありすぎる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんないやらしいご主人様に、毎日誠心誠意お仕えするとなると……。はぁ\nっ♪　メイドの方も、相当なスケベにならざるを得ない、でしょうね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……ちょっと。何を悲しそうな顔をしているのよ。私はそれが嫌だなんて一\n言も言っていないわ。私がいなくちゃあなたはダメだと言っているの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ふぅううっ……。こんな卑猥なご主人様の相手ができるのは、有能な私だけ\nだわ。だから、その……好きなだけ、勝手に頼ってきたらいいでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0203410" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}