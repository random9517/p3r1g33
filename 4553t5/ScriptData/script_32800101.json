		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「うぅ……生臭い……んっ、りゅぷっ……舌に、んむっ……苦味が……じゅぱ \nっ、ちゅぷっ、んっ、ふっ……」", "NORMAL" ]},
