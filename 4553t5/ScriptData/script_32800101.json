		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「全部……飲め……これ、を……んんっ、んっく……あぷ……あぁ……この量 \nを……ぜ、全部……んっ、ぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「こくっ、んふっ、んっくっ……んくんっ……んふぅ……ぷっ、ぁっ……はぁ \n、はぁっ、げほっ、けふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「の、飲んだぞ……うぅ……美味い訳がないだろう……ずっと喉に絡みついて \n……最悪だ……むぐっ、ふっ……」", "NORMAL" ]},
