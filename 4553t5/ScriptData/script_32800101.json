		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「わ、私の口で咥えろと言うのか……！　っく……どこまでも調子に乗って… \n…！　うぅ……屈辱だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103104" ]},
