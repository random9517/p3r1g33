		{"command":[ "SETIMAGE", "0", "still_00028001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ちゅぷぅ……最後の吸い出しまで……ぴちゃ、んちゅぷ……ちゅぱ……れる \n、はぁ……はぁ、はぁ……これで、いいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「とにかく……もう、満足しただろう……十分に気持ちよくさせた筈だ。な… \n…ま、まだ全然……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「た、確かに勃起はしているが……っく……そんなものは、貴様が勝手にさせ \nていることでキリがないではないかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「も、もう一回出すまで……くっ……それ以上はないからなっ……！　はっ、 \nんむっ、ちゅぷっ……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……精液の味と臭いが……べっとりとこびりついたままだ… \n…んちゅるっ……ぴちゃ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「これを……はぁ、んっ……もう一度するなんて……じゅぷっ、あぁ……どう \nして、こんなに勃起が大きいままなのだ……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「な……私の舌がいやらしい……じゅぷっ、バカなことを言うなっ……こんな \nもの、才能でも……りゅぷっ、なんでもないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ、私は……仕方なく……これを、しているだけで……ちゅぱっ… \n…早く終わらせる為に……れろ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「だから……一生懸命にしているだけで、じゅぱっ……心から奉仕をしたいな \nどと……んふぅっ、思っては……な、ない……勘違い……するなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ……んちゅぷぅ……もう、弱いところは分かっているからな…… \n例えば、ここだ……ちゅるっ、ぴちゃっ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「見ろ……こんなに、分かりやすく……先端を震わせて……ちゅっ、んちゅっ \n……この割れた場所を……舌で押し込む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はぁ、んむっ……あ、あまり動かすな……んっ、手を使えないんだ……舐め \nにくいだろうが……ぺろ、れろ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ……大人しくしていろ……れろ、ねるぅぅ……れる、れろぉ、れ \nる……んっ、れろぉ……れる、れりゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「し、舌先が……いやらしい……だ、だから……おかしなことを言うなっ…… \nくぅっ、覚えていろ……いつか、後悔させて……んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はぷっ、んふぅっ……ひゃめ……ろっ……んぶっ、また深く……押し込むら \nんて……んぶっ、ぷぁっ、はっ、んふぅっ……！」", "NORMAL" ]},
