		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「それから……れる……れろ、皮の捲れた部分を……ついばむように舌先で… \n…くすぐって……やる……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そうすると……んっ、あぁ……こ、これが震えるから……そこを、また舐め \nていく……ちゅぷ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「こ、これというのは……だから……オ、オチ〇チ〇……だ……うぅっ、何度 \nも言わせるなっ……下品な……ことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、んちゅぷっ……んふぅっ……そ、そろそろ……咥えて……んぅ…… \n頬張れと……んりゅぷっ、くぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「むふぅ……く、くそっ……大きすぎる……！　んぅぅ……口から……唾液が \n……んふぅっ、垂れてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ふぐぅ……んんっ、気にせず垂らせ……そう簡単に……言うなっ、じゅぷっ \n、ちゅぽっ……んりゅぷっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「何とか……頬に入れて……んんっ……！？　ま、まだ大きく……んふぅっ、 \n勃起が……こんらに……ん、むぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ、じゅぽっ、んぐっ……んふぁ……少しは落ち着かせること \nができないのか……ぐぷっ、この……オチ〇チ〇は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「とにかく、す、するから……慌てるな……んちゅぷっ、ぴちゃ……んふっ、 \nりゅぱっ、はぷ、んちゅぷぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……口をいっぱいに開かないと……とても頬張れない……んふぅ……こ \nんな浅ましい姿を、晒すなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んぅ……み、見ないでくれ……りゅぷっ、あぁ……んちゅぷっ、こんらに… \n…オチ〇チ〇を咥えている顔を……んぷぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はぷっ、んふっ……もっと、前後に……激しく……？　んぅぅ……こ、こう \nいう……ことか……？　ふぐっ、んっ、あぷっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んりゅっ、あぁ……私は何をしているんだ……じゅぽっ、こんな奴 \nの言いなりになって……りゅぷっ、オチ〇チ〇を唇で扱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、い、今のが……気持ちいいのか？　んりゅぷっ、そ、そうか…… \n確か……こんな、感じだったか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……んんっ！　ビクッとさせている……んふぅ……りゅぷっ、そん \nなに感じるのか……は、ぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ならば……じゅぽっ、んふっ、もう少し、繰り返して……はぷっ、んぶっ… \n…少しずつ、速く……んふぅ……させるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……ん、りゅぷっ……はぁ、んちゅぷっ、何故だ……オチ〇チ〇を…… \nしゃぶっていると……自然に、唾液が湧き出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、じゅぱっ、んぁぁ……させたくないのに……いやらしい音がしてし \nまう……じゅぽっ、りゅぷっ、んじゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ち、違う……今のは、溢れそうになったのを啜っただけで……わざと鳴らし \nた訳では……じゅぱっ、んちゅっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……じゅぷ、慣れてなんか……はぁ、んりゅぷっ、あぁ、オチ〇チ〇が \nまだ膨らんでいる……も、もうすぐ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んっ、りゅぷっ、もういいから……んっ、出すなら……さっさと出せぇ…… \nどうせ……このまま……んりゅぷっ、するんらろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ならっ……もうっ、焦らすなぁっ……じゅぷっ、れんぶっ……らへぇっ、ん \nじゅるるっ、ちゅぷぅぅぅっ！」", "NORMAL" ]},
