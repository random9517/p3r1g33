		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ちゃんと……挨拶から……うく……い、今から……私は……あなたの、オ、 \nオチ〇チ〇を……舐めさせていただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「つ、拙い奉仕になるかも知れませんが……こ、心を込めて……オチ〇チ〇を \nしゃぶりますので……どうか、ご、ご堪能ください……ませ……」", "NORMAL" ]},
