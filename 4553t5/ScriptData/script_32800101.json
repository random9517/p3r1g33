		{"command":[ "SETTEXT", "「くぅぅ……んちゅぷっ……んくぅ……わらひが、逆らえないからと……オチ \n〇チ〇を乱暴に……むぐぅ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「だが……んっ、りゅぷっ……やり方は分かっている……口を上手く動かせば \n……じゅるっ、自然な感じにできる……じゅるっ、んちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ、ちゅぱっ……んはぁ……あぁ、また……味が……する…… \nちゅぷ……んっ、これは……何か、滲んでいるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……先走り……汁……んっ、つまり……また、射精が近づいていると \nいうことだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、ちゅぷっ、じゅるっ……忌々しいが……もう出すならば、早く… \n…出してしまえ……じゅるっ、んちゅうぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「今度こそ……終わりにするからな……んっ、残っているのをっ、じゅるっ、 \nちゅぷっ、全部……出し切れっ……んっ、ちゅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅぅんっ……！　んぁっ……ぷっ、また……あっ、りゅぷっ……出 \nて……んんっ、まだ……こん、らにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「こくっ、んぐっ、けふっ……んぷぁっ……待ってくれ……一度に出されたら \n……溢れてひまふ……んんぅ……んっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ゆっくり……んっ、飲むからぁ……こくっ、んっ、く……んくっ、んくん… \n…んっ、は、ふっ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ま、まだ……出るのか……どこまで欲望まみれなのだ……貴様はぁ……は、 \nんむぅ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はっ……ふっ……はぁ、はぁ……んんっ……止まった……のか？　出し切っ \nたな……？　終わりで……いいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ならば……後は、もう……ちゅぷっ……れろ……んりゅ……ちゅぷっ、はふ \n……このオチ〇チ〇を綺麗にすればいいだけだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……もう、大体飲んだから……後は、ちょっと吸い出すだけ \n……んちゅ……ちゅぅぅぅ……ん、はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「さあ、これで文句はないだろう。ちゃんと掃除も済ませたからな……な、何 \nだそのニヤついた顔は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「頼んでもないのに綺麗にした……そ、それはっ……いつも、そうやって終わ \nらせていたからで……進んでした訳ではっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「違う……違うのだ……私は……本当は嫌で……なのに……あぁ……何をした \nいんだ……私は……う、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁっ！　なっ……オチ〇チ〇……離れて……顔に……んんっ、掛かっ \nて……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「待て……んぷっ、何の前触れもなく……勝手に掛けるなんて……せめて、先 \nに言っておけっ……んぁぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……うぅっ、粘った汁が……あぁ、まとわりついてくる……髪の毛に \n付いてしまう……んんっ、なすりつけるなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「くぁ……この臭い……強すぎる……あぁ、染み込んで取れなくなったらどう \nするんだ……はぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……出し終わったのか……もう、これで……全部出したな？　後からま \nだ出るなんてことはないな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　くっ、き、汚いものをつきつけるなっ……後始末をしろと言 \nうのか……全く、貴様は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「れろ……ぴちゃ……んぅっ……こんな不味いものを……んっ、誰が……病み \nつきになど、なるものか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅっ……これで、文句は言わせんぞ……全部舐め取ったんだ \nからな……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「じょ、上手になど……なっていないっ……そんなことで褒められて嬉しいわ \nけがあるかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_01_11" ]},
