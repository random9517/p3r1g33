		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「くぅ……こんな口上まで……屈辱だ……んっ、な、舐めればいいんだろうっ \n……あっ、ん……ちゅぷっ……」", "NORMAL" ]},
