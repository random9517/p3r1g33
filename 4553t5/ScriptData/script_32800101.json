		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　ふぶっ……んぐっ、んぅぅぅうんっ……！　ふぁぁ… \n…れて、るっ……んむぅ……んぐっ……」", "NORMAL" ]},
