		{"command":[ "SETIMAGE", "0", "still_00028001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「う、美味いわけがないだろうっ……こんなモノっ……ちゅぱっ、んっ、ぴち \nゃ……んちゅっ、れろ……んりゅっ、れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「丁寧にしているのはっ……好きでしている訳じゃないっ！　貴様が……命令 \nするから……仕方なくっ……ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、んぷっ……それに、じゅぷっ……これは……何度もさせる \nから……覚えたことだ……れろ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「この先端の部分を……よく唾液で濡らして……滑りを、ぴちゃっ……んふっ \n、よく……させる……」", "NORMAL" ]},
