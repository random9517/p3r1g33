		{"command":[ "PLAYVOICE", "v2_212_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、はあああぁん……！　オチンチンの奥から、どんどんザーメ\nンが込み上がってきてるの感じるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
