{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さん。わざわざガレージまで来てもらって悪いわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「なんの用かって？　今日は一生懸命働いている隊長さんを、私のボディで癒\nしてあげようと思ってるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「不安そうな顔をしなくても大丈夫よ。ちゃんと気持ちよくマッサージしてあ\nげるわ。ほら、服を脱いで横になって頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。私のおっぱいで、いーっぱいマッサージしてあげるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ……！　大丈夫だから、そんなに暴れないで……！　ほら、いつ\nもの装甲より柔らかいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私の胸部は特殊なポリマー素材で作られてて、カタさを自由に調整できるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「だからほら……人間の女の子と変わらない感触がするでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら……隊長さんのアソコ、すっごく大きくなってきたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「全身マッサージをしてあげようと思ったけど……ここが一番凝ってるみたい\nだから、重点的にほぐしてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いいのよ……遠慮しないで。隊長さんのためなら、全然イヤじゃないわ……\nだから、もっと私に身体を委ねて頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……！　隊長さんのオチンチン、とっても大きくて熱いわ……\n！　私のおっぱいで、興奮してくれてるのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もっと寄せてあげた方が隊長さんも嬉しいわよね……んっ、んっ……！　ど\nう？　痛かったりしない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。いいのよ……私は隊長さんのだらしない顔も大好きだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「お母さんのおっぱいマンコで、いーっぱい気持ちよくなってね……あっ、ん\nんっ……はぁ、あっ、んふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　エッチなお汁がどんどん谷間に溢れて……エンジンオイ\nルよりヌルヌルしてるわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら……もっと激しくして欲しいの……？　わかったわ。それじゃあ、たく\nさんシコシコしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　あっ、んんっ……！　これくらいの強さで上下に擦れば\n……はああぁ……！　オチンチン、ビクビクしてるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「いっぱい感じてくれてるのね……Ｍ．Ａ．Ｍ．Ａとっても嬉しいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さん……この胸部装甲を今より柔らかくしたら、オチンチンがも\nっと気持ちよくなれると思うの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「どう……？　オチンチンだけじゃなくて、全身で私のおっぱい……味わって\nみたくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんが気持ちよくなってくれることが、私の悦びだもの……素直になっ\nてくれた方が嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。わかったわ……それじゃあ、もっと柔らかくするわね……んっ、\nあはぁ……あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あはあぁ……！　隊長さんをおっぱい全体で感じるわ……！　ズブズブと埋\nまっていって……あああぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「おっぱいに触りたかったら、好きなだけ触っていいわよ……！　私も、隊長\nさんのオチンチンをいっぱい触るから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あっあっあっ……！　オチンチンを上下にシコシコすると、す\nごく反応してくれるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「エッチなお汁もどぴゅどぴゅ出て……谷間から、すごい香りがしてくるわ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はああぁん……！　そんなに強くおっぱいを揉むなんて……んっ、あっ！　\nそんなにお母さんのおっぱいが気に入ったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……！　いいわよ……好きなだけ触って、揉んで頂戴……！　\n私の胸部装甲を堪能してっ……ああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そんなにいやらしい触り方されたら、エンジンに火が付いちゃう……！　私\nのおっぱいから、お汁出ちゃううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　隊長さんのオチンチンがもっと熱を帯びてきて……あっ、\nはあぁ……！　さっきより大きくなってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それにシコシコする動きに合わせて、オチンチンがビクビクしてるわ……そ\nろそろイキそうなのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「我慢は身体によくないわ……射精したいと思ったら、出してスッキリした方\nがいいもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「遠慮しないで、いっぱい出していいのよ……隊長さんの濃厚ザーメン、好き\nなだけぴゅっぴゅっしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ、んんっ！　出して……！　私のおっぱいマンコに、いっぱい\n精子注ぎ込んで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ああああっ……！　私のおっぱいもイクから……！　一緒にイッて……！　\nんっ、あっ……！　あああああぁん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はあああぁ……！　隊長さんの精子、びゅーびゅー出てるわ……！　すごく\n熱いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「それに私の乳首からも特製ミルクがぶちゅぶちゅ溢れて……！　あんんっ！\n　こんなの始めてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「た、隊長さん……！　いっぱいシコシコするから、もっとおっぱい揉んで頂\n戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そ、そうよ……！　もっと特製ミルクを出させて……ああっ\n！　はぁ、あんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんのミルクも……もっと出して……！　私のおっぱいマンコ、ザーメ\nンまみれにしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「うふふっ。いっぱい出たわね……私のおっぱい、隊長さんの精子でヌルヌル\nになってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「これだけ出せば、オチンチンの凝りもほぐせたわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あら……まだ熱源センサーに反応があるわ……出したばっかりなのに、オチ\nンチンがまた大きくなって……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「すごいわ……もうこんなに大きくなってるのね……そんなにお母さんのおっ\nぱいマンコが気に入ったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「なら、もっとシコシコしてあげるわ……今度はさっきよりも激しくしてあげ\nるから、痛かったら言って頂戴ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……んあっ、んふうぅ……！　隊長さんの精子と私の特製ミルク\nのおかげで、すごく滑りがよくなってるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ほら……さっきよりも強くシコシコされてるの、わかるでしょう……？　ん\nっ、あっ……くふうぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、はあああぁん……！　またＭ．Ａ．Ｍ．Ａのおっぱい弄って……！　\nそんなに触りたいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ううん。イヤじゃないわ……隊長さんに触れられると、おっぱいが悦ぶから\n……遠慮しないで、もっと触って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……！　もっと強く揉んだりしていいから……！　くっ、はああ\nぁ……！　隊長さんの手、あったかいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ダメっ……！　私の馬力もどんどん上がって……あっ、あっ！　オチンチン\nをシゴく手が止まらないのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00021202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　こんなに速くシコシコされて、痛くない……！？　大丈夫\n……！？　痛いなら、もっとおっぱい揉んでいいのよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「これくらい激しい方が気持ちいいだなんて……！　隊長さんって、私が思っ\nてた以上にエッチな人なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「大丈夫よ……私は隊長さんがどれだけエッチな人でも、大好きだから……あ\nあああぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ひくっ……！　はああぁ……！　ま、また……オチンチンがビ\nクンって大きく跳ねて……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私のおっぱいも、強くぎゅってされてるっ……！　ダメっ……！　このまま\nだと、また特製ミルクが溢れちゃうわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「エッチなミルクをもっと出して欲しいの……！？　わかったわ……隊長さん\nのお願いなら、悦んで出してあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
