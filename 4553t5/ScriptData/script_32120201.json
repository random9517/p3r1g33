		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あはああぁ……！　隊長さんのザーメンと同じくらい、特製ミルクが溢れて\nくるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
