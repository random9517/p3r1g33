{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0050" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「今日もティータイムにお付き合いいただき、ありがとうございます。それで\n、あなた様からのお願いというのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「えっ、ほ、奉仕ですか！？　わたくしが、あなた様に……？　そ、それはつ\nまり……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしが、あなた様の……お、オチンポに……？　ああ、やはりそうなの\nですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「そ、そうですわね……たしかにわたくし、あなた様の下半身に興味がありま\nすわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしとは全く構造の異なるあなた様の下半身……。機会があれば、よく\n見せてほしいとは思っていましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「なっ！　そんなに勢いよく服を脱いで……す、好きなだけ見てもいい……の\nですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「で、では……失礼いたします……。な、なるほどこれが……人間の、下半身\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「覆いかぶさるような、感じで……？　こうでしょうか……ンッ、胸に硬いモ\nノがあたっていますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様のオチンポなのですね……んぁっ、ビクってしましたわ。わ、わた\nくしのおっぱいに当たっているから、ですの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……人間のオチンポ……。はじめて見ましたわ……。こんなに\nも、立派に硬くなるのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「すんすん……なんていやらしい匂い……。ああ……なんだか胸が高鳴ってし\nまいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「えっと……そうですわね、見てばっかりではあなた様も満足なさらないでし\nょうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、んむぅ……こうで、どうでしょうか……？　んふぅ、口に……あなた\n様のおひんぽをぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「咥えて……んちゅぶっ、おしゃぶり、いたしますね……。んっ、んちゅぶっ\n、ちゅるるうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、これが人間のオチンポ……んちゅっ、ちゅぶっ、変わった味\nがしますわ……じゅぶっ、じゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、んちゅっ、病みつきになって、しまいそうな……じゅるるっ、んふっ\n、ちゅっ、ちゅぶっ、味ですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んむっ、すごく熱くて……ンッ、口の中がやけどしてしまいそうな……んじ\nゅるるっ、んぶっ、オチンポ……跳ねて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わ、わたくしのおしゃぶり……ンッ、気持ちいい、ですか……？　んじゅる\nっ、じゅぶっ、でしたらもっと……がんばります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、んっ、んふっ、じゅぶっ！　オチンポにいっぱい、んじゅる\nっ、吸いついて……んっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「口の中……んじゅるっ、じゅるるっ、舌を、動かして……んぶっ、あなた様\nのオチンポ……舐めまわして……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オチンポが、ますます膨らんで……。んっ、んじゅぅっ、人間のオチンポは\n、気持ちいいとこうなるのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「それに、ンッ、先ほどから口の中に、なにやら苦い味が広がって……あなた\n様の、オチンポから溢れているようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「先走り汁、というものですわね……？　んっ、んちゅっ、なるほど……じゅ\nるっ、このような味なのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくし……先ほどよりも身体が熱くなってまいりましたわ……。んじゅっ\n、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様におしゃぶりしながら……じゅぶっ、じゅるるっ、興奮してしまっ\nているようです……んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オチンポもっと……ンッ、お口でいっぱい、気持ちよくしますね……んじゅ\nるっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こうしてしゃぶっていると、じゅぶっ、どんどんよだれが……んじゅるるっ\n、あふれてきてしまいますわ……じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「勃起チンポ……んっ、んじゅっ、じゅぶっ！　とっても、美味しいですわ…\n…んじゅるるっ、じゅぶっ、ンッ、じゅちゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こんなに……ンッ、熱くて……パンパンになって……今にも破裂しそうな…\n…んじゅるるっ、んっ、んっ、じゅぼっ、じゅぼっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様の腰も、ンッ、動いてしまっていますね……じゅるるるぅっ！　こ\nうやって吸いつかれるのが、いいのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「精液が、吸いだされそう……？　んじゅるっ！　ええ……射精したいのなら\n、どうぞ……かまいませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「人間の……あなた様のオチンポからでる精液の味……。じゅるるっ、じゅる\nるるぅっ！　わたくしも、興味ありますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぶっ！　ど、どうぞ……わたくしのお口にオチンポつっこみながら……ん\nじゅるっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「射精……射精して……じゅぶっ、じゅぶっ！　わたくしも……あなた様の精\n液……じゅずずぅっ！　吸い出し……ますぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んんんぅっ！　んぶっ、んっ、んんんぅううっ！　んじゅるるるっ！　じゅ\nっ、じゅちゅちゅぅっ、ちゅずずずぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「で……でてる……。わたくしの糸に負けないくらいネバネバした精液……ん\nっ、んん……んくっ、んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「これが……人間の、精液ぃ……。んじゅるっ、じゅずずっ、まだ、口の中で\nオチンポがビクビクとして……射精していますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、全部……んじゅるっ、飲み干しますわね……んふぅ、出され\nたものを残すのは、優雅ではありませんもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「じゅるるるぅっ！　じゅぽっ！　んふふっ、あなた様のだされた精液、みん\nな飲み干してしまいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「こんなに苦くて、変な味がするというのに……不思議と、嫌な気分になるも\nのではありませんわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「それで……あらあら、あなた様のオチンポはまだ勃起したままですわ。これ\nは、わたくしにおかわりをくださるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしの唾液でヌルヌルべっとり……オチンポがますますいやらしくなっ\nたように見えますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしに、もっと口でしてほしいのですか？　ええ、わかりました。わた\nくしもあなた様の精液がほしいので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んむっ、じゅぶっ、じゅるるっ！　また……咥えます……んふっ、じゅるる\nぅっ、じゅぶっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、オチンポ……じゅるるっ、じゅぶっ、とってもおっきく……じゅるる\nっ、口……いっぱいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、じゅちゅっ、ンッ、じゅぶじゅぶっ！　先ほどのよう\nに……んじゅっ、激しく……いたしますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「じゅずずっ！　オチンポに、吸いついて……んぶっ、唇で、じゅぶっ、オチ\nンポ……しごくように……んっ、んっ、んじゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぶっ、んぶっ、じゅぶっ、じゅぶっ！　んっ、じゅぶっ、じゅるるっ、ん\nっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様のオチンポに、夢中になって……ンッ、じゅるるっ、はしたなく、\nがっついてしまいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ、んふっ、ンッ！　あなた様の腰が浮いて……んぶっ、わたくし\nの口に……オチンポ突っ込んで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぶっ、んじゅぶっ、ンッ、ぐぶぅっ！　オチンポが口の中で……暴れまわ\nって……んっ、じゅぶっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様のオチンポを……じゅるっ、じゅぶぅっ！　口全体で……ンッ、じ\nゅぶっ、感じてしまって……んっ、んぶっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オチンポ……ンッ、あなた様のオチンポ……ッ！　じゅぶっ、じゅぶっ、と\nっても美味しいですわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「クセになりそうな、ンッ、味に……匂い……！　んじゅるっ、これが人間の\nオチンポなのですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしもう……お口が止まりませんわ……！　オチンポ……しゃぶるのが\n、やめられない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んじゅっ、んっ、じゅぶっ、あなた様……だしてぇ……！　また、わたくし\nに……あなた様の精液をぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「また、射精なさるのでしょう？　オチンポこんなに膨らませて、じゅるるっ\n、ビクンビクンさせていますもの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んぶっ、んぶっ、じゅるっ、じゅるっ、じゅるるぅっ！　オチンポ当たるっ\n、わたくしの口……犯して……んじゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様、どうぞ……どうぞ……！　じゅぶっ、じゅるるっ、お射精……ン\nッ、また濃いの……いっぱい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしに……んじゅるるっ、じゅぶっ、だして……！　じゅるるっ、じゅ\nるっ、じゅずずずずぅううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんぅうううぅぅぅっ！　んふぅうううぅぅっ！！　んぐっ、んぐ\nぅううう～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「でてっ、でて……っ！　口いっぱいぃ……っ！　あなた様の……精液ぃ……\nんっ、んぐっ、んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「じゅずっ、じゅずずぅ……っ！　また……とっても濃厚な……んぐっ、喉に\n張り付くような、粘り気で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んくっ、んくっ、飲みこむのも一苦労な……精液……。んふぅ、ですがとっ\nても……美味しいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んふぅ……また、たくさん射精いたしましたね……。んふふっ、人間の射精\n……大変素敵でしたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はぁ……こんなにも美味しい精液を出すのですね、人間は……。お姉様や妹\nたちが夢中になるのも納得ですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あの……もし、あなた様がよければなのですが……。これからもわたくしに\nこの精液をくださらないでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様の精液……わたくし、大変気に入ってしまいました……。とっても\n、美味しかったので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「も、もちろんタダでとは言いませんわ！　お礼は必ず致しますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「……考える時間が欲しい？　そうですか……。では、よい返事をお待ちして\nいますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　ああっ、あなた様のオチンポが口から抜け……んっ、ああぁあ\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様の精液ぃっ！　んっ、んぶっ、顔に……ああんっ！　いっぱい……\nああっ、かかって……んっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ネバネバを相手にかけるのは、蜘蛛であるわたくしの十八番ですのに！　あ\nんっ、あなた様にこんなにかけられては」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「わたくしの方が、このネバネバにがんじがらめにされてしまいそうですわ…\n…！　んっ、ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。やっと射精が収まりましたわね……。ああ……脈打つと\n先端から精液が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00018601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「二回目の射精だというのに、人間はこんなに粘度の高い射精をするのですね\n……。ひとつ、学びましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「それに……先ほど口の中で味わった精液を浴びるというのも……不思議な感\n覚です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「あなた様の精液に顔を汚されて、こんなに興奮してしまうだなんて……。わ\nたくし、なにかに目覚めてしまいそうですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「本来ならこれが、わたくしのオマンコに注がれるわけですわね……。こんな\n、ねっとりとした精液が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「それを想像したら、なんだかお腹が疼いてしまいました……。そうですわ！\n　あなた様、今度はわたくしの下半身を教えて差し上げますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_0103410" ]},
		{"command":[ "WAITINPUT" ]},
