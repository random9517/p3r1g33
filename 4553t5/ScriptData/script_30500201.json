		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「急に呼び出すだなんて何事かと思いましたが……。そうですか。つまりは私\nに、あなたの性処理を行えと言っているのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「正確には違う？　パワーアップの一環？　……百歩譲って本心からそう思っ\nていたとしても、するべき行為は同じなのでしょう？　無意味な言い訳です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……はぁ……若い男はこれだから……。ですが、わかりました。私も正義の\nプロフェッショナル。世界を救う可能性が１％でも上がるのならば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「己の身などいくらでも捧げる覚悟は既に出来ています。それで？　あなたに\n何をすればいいのです？　……パイズリ、フェラ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……。おそらくは、パイズリだけでもフェラだけでも可能な儀式なのでしょ\nうが……。ここはあなたの算段に、引っかかったフリをしておきましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……？　何をモタモタしているのです。人に頼んでおきながら、モタモタと\n……。早く股間をお出しなさい。そうたいしたものでもないでしょうに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「で……これがあなたのご自慢のペニスというわけですか……。ああ……そう\nですか……。これに、幹部全てに力を与える力が秘められていると？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「相当に自信過剰ですね。見なさい……。ん……私が乳房で挟み上げただけで\n、情けなくビクビクと痙攣しているこのペニス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こんなもので女が、そして正義の味方が屈服すると思っているその心根。私\nが厳しく律してさしあげましょう。悪を正すもまた正義……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それでは粛正を始めます。……っ……ふぅ……ふぅ、ふぅ……。胸でペニス\nを揉みこみ、ながら……亀頭をペロペロと舐めます……れちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フン……。造作もないことです。くだらなく、つまらない性行為……。ぴち\nゃっ……こんなことの何が楽しいのか……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ああ、独り言です……。何か不満でも？　するべきことはしているでしょう\nに……。ほら、胸の……谷間、で……ペニスを刺激して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……口でも亀頭を中心に、カリ首や尿道口……たっぷり唾をつけ\nてねぶっていると思いますが？　これの何が不満なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「よく見ていなさい……。ねろぉ……ぺちゃっ、ぴちゃ、にちゃ……ちゅる…\n…ぷちゅっ……ぺろっ……れろ……ねろ……れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「この程度では満足できませんか？　そうですか……であれば、胸の方を激し\nくしてみますか……。っんっ！　んっ、ンッ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フフ……たぱたぱ、たっぷたっぷと巨大な乳房が挟む様は見ごたえがあるで\nしょう……？　男など、視覚と触覚の生き物……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ネロネロと性器を舐められ、キツいくらいに乳房で肉竿をしごきたてられれ\nばすぐに精を吐き出す、単純な生き物です。そうでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「出来れば自分で性欲を処理していただけると嬉しいのですが……それすら出\n来ないというのですから。何もかも女まかせで腹が立ちます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「その怒り、憤り……全てこの下品な肉棒にぶつけてさしあげましょう。ぢゅ\nっ　ぢゅっぽっぢゅぱっぢゅぷっ……んじゅぷっぢゅっぷぢゅっぷぷっじゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ンンン～？　吸われたり甘噛みされたりするのがいいのですか？　かぷ……\nぢゅるるるる……ぢゅるるるる、はぁ、はぁ……ねちょ、にちょ、ぬちょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ！　ぢゅるるるっ！　ぢゅるぅううう……レロレロレロ、んれるぅ\nうう……ぢゅるっ、ぢゅるるる……ぢゅるるる、ぢゅるぅうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「む。陰嚢が上昇してきましたね。これで正解ということれひょうか……。ぺ\nろ……玉袋も丁寧に舐めしゃぶり……ぢゅぱっ！　ぢゅぱっぢゅっぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んむ……まだ口の中で大きく……なるのでひゅか……。面妖な……。れろぉ\nぉれるんれるん……ぢゅるっ、ぢゅるるっぢゅる……じゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「汁気の多い男根、ですね……。次々に先走り汁が溢れてくる……。う……そ\nれになんです、この悪臭は……きちんと風呂に入りなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「汗臭い、男くさい、青臭い……。わざと汚いペニスをしゃぶらせて喜ぶ変質\n者ですね……。とんでもない男……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、んっ……ぐぷっ！　ぐちゅっ！　かぽっ！　かぽっくぽっ！\n　ぢゅるるるっ、ぢゅるるる……ぢゅるっ、ぢゅるっぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ぐっちょぐちょっ、ぬちょ……はあああ……♪　ねちょっ、ぬちょぐっちょ\n……レロレロレロレロ……あーーーん……れろぉ……ねろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ぬちゅ、ぬちゅ、ぬちゅ、ぬちゅぷ……べろぉお……ぢゅるぅう……！　ぐ\nちゅっ、ぢゅぷっぷぢゅっ……ねろねろねろ……。ああああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フ、フフ……私のような女に罵られながらしゃぶられて、こんなにペニスを\n硬くして……あなた、マゾの要素でもあるんじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もっと強くしてほしいのなら、ちゃんとおねだりしてくださいね……。ほら\n……どうなのです？　ねろ……汚い精液で陰嚢をパンパンにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「この瞬間にも、新しい精液をドクドクと作っているのでしょう？　なんて浅\nましいのでしょう……。ええ、ええ、わかりました。イかせてあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「食らいなさい……。ぐぷっ！　ぐっちゅぐっちゅぐっちゅぐっちゅっ！　フ\nフフ、一気に仕留めますよ……胸も口も全力で使って……れろぉおお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ほらっ！　ほら！　おイキなさい！　イクの！　あなたは私の舌と乳房に\n屈しておびただしい量の精をぶちまけるのですっ……ほらっ、ほらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ！　ぢゅるるるっ！　ぢゅるぅううう……レロレロレロ、んれるぅ\nうう……ぢゅるっ、ぢゅるるる……ぢゅるるる、ぢゅるぅうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んんんっ、出るのですか？　出すのですか？　いいでしょう、来なさい……\nっ！　んむっ！　ぢゅるるるっ！　ぢゅるるっ、ぢゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「っんんん……！！　んあっ！？　アッ、ぁっあっ！？　な、何を……！　よ\n、予告もなく顔に出すなんて……仕返しのつもりですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「き、汚い……っ！　くさい、なんということを……！　う……！　うぷ……\n。むせかえるような若い男の性臭……眩暈がします……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「よ、よくもこの私にこんな屈辱を……。この恨み、必ず返しますから……！\n　ああ……ベタベタして、とれない……。最低……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「は？　すごく良かったから暴発してしまった……ですって？　それが謝罪す\nる態度ですか！　……ですが……そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……認めましょう。次にこんな無礼なことをすれば、許しませんから。\nそれだけはよぉおっく肝に銘じておきなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はー……ふぅ……それで？　これでお仕舞いですか？　だとしたら、とんだ\n期待外れですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「この私にこんなふるまいをした無礼は許せませんが、まあものはついでです\n。このまま無礼を尽くすことを許します……ふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ああ、もうなんと汚らしい……汚物をこんなに撒き散らし、あまつさえ、ま\nだこんなに大きくさせているとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「本当に男というものは……いえ、あなたという人は度し難い生き物です。あ\nあ、汚らわしい……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んぁぁむ、もぐ、もごもご……んちゅ、れろれろ……ちゅるる……はぁ、何\nをしているのか、ですって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「決まっているでしょう……悪は是正されねばなりません。れろ、れるれる、\nもぐ、もご……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「見たところ、まだあなたには更生の余地が大いにあります……んん、むぐも\nご、ちゅる、ぴちゃん、れろれろ……ぢゅずるるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ゴクン……んふぅ……ああ、チンポ汁、まだいっぱい残っていました……ま\nったく……キレの悪いペニスです……もっと真面目に射精して下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……れる、れろれろ……胸の中で、こんなにペニスを弾ませて\n……恥ずかしくないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フン、どうせ恥を恥と思っていないのでしょう？　まったく……胸と口で弄\nばれ、罵倒されながらも、こんなに大きくさせるだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んぁぁむ、んちゅ、ちゅぬる、れろ、れろれる、ちゅぼじゅるぅ……はぁ、\nふぅ……谷間が汚汁でドロドロです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00005002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「なんと気持ちの悪い……なのに、あなたはそんなに気持ちよさそうにしてい\nるだなんて……善悪の区別が付いていないようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……なんです？　このペニスは……あむぅ、じゅる、ぴちゃ、れ\nろれろ……ぬるる、くちゅぅ……全然萎まないじゃありませんか」", "NORMAL" ]},
