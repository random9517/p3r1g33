		{"command":[ "PLAYVOICE", "v2_050_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んはぁむ、れろ、れろれる、んちゅ、ねろぉ……え？　美味しそうにしゃぶ\nってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こうした方が、んちゅ、ねろん……早くイクでしょう？　視覚による快感へ\nの補助です……れろ、ぬるる、ちゅちゅ、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
