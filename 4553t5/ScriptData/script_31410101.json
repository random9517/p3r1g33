{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「隊長様……。なんですか？　この部屋は……。こんな場所があるだなんて、\n聞いたことがありません。ここは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00014101_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……戦士のパワーアップを行う特訓場？　そうなのですか？　ベッドが置い\nてありますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ああ、気になさらないでください。昔から、細かいところが気になる性格な\nのです。寝具があるのなら、寝るのだろうかと思っただけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……はい？　寝るのではなく、性的なことをする？　……申し訳ありません\n。性的なこととは……なんでしょうか。その方面には疎いのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はい。隊長様の股間にある突起を。はぁ……、手で触ったり、口で舐めたり\n……？　そんな行為があったのですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00014101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「お恥ずかしながら、まったく知りませんでした。それをするために、私はこ\nこに来たのですね。ですが、どうすればいいのかも見当がつきません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ですので……。逐一教えていただけるのでしたら、その通りにいたします。\nええと……床にひざまずいて？　ええ。これを舐めるのですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00014101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……。一つ疑問なのですが。男性の股間、このでっぱったモノは口につけて\nいいものなのでしょうか？　どうも、形がグロテスクですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103108" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「普通は喜んで舐めるもの……？　なるほど。形がデコボコしている方が舐め\nて楽しいからこうなっている……？　隊長様は博識ですね。わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「でしたら、おっしゃる通りに。ぺろ……。こうですか？　もっとまんべんな\nく、何度も……？　そういうものですか。ぺろ……、ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ん……。しょっぱいですね。味がするのは、皮膚ですから当然ですが……驚\nきました。ん、れろ……れろ、れろ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んん？　なんでしょう。舐めると突起が動きます。それに……太さが増した\nような……。勘違いでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ、ぴちゃ、ぺろ……。ぺろっ、ぺろ……ぺろ……。それで、これが\nなんなのです？　股間を舐めて何が楽しいのでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……もっとやってみなければわからない？　そうかもしれませんね。はい。\n次はこの袋ですか？　袋を手で揉んで……股間を舐め続ける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んん、ぴちゃっ、ぴちゃ、ぴちゃ……。ぺろ、ぺろ、れろ……ぺろ、れろ…\n…れる……。ぴちゃっ、ぴちゃ、ぴちゃ……ぺろぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「全体的に？　ああ……色んな部位を舐めるのですね。袋は優しく？　舐め方\nは大きく？　……わかりました。れろっ、れろ、れろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「れろれろれろ……っ、ぴちゃっ！　ぴちゃ、れろっ、れろ、れろ……！　れ\nろれろれろ……。先端を咥える？　はい……こんな風に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「もぐ……。んん……んん？　そ、それれ……ここからは？　ふぁい……頭を\n前後させれ……？　歯を立てず、に……。もごっ、もご、もぐ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ぐちゅ……ぢゅぷっ！　じゅぷっ、ずぷぷぷ……ずぷ！　ずぷ……じゅぷぷ\nぷ……。んん……あ、顎が外れる……。ぐぷっ、ぐちゅ、ぐちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「く、苦しひ……。も、もういいれふか……？　続けろぉ……？　うう……。\nぐぷ……ぐぷぷっ、ぢゅるっ、ずぷぷぷ……ぢゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「おえっ……！　喉奥を突かないれくだひゃ……んぶぅっ！？　んんんっ！？\n　んーっ、苦ひいれふ……！　苦ひい……んぐぐぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んぶっ、ずちゅっ、ずにゅ……！　ぐちゅっ、ぐっちゅっ、ぐちゅっ、ぐち\nゅっ……ううっ、く、口の中れ動いて……！　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「わ、わたひのよだれが、口からこぼれ……！　んぐぅううっ！　やめっ、や\nめれくだひゃ……！　んんっ！　んっぶっ！？　んんんっんぢゅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ううううー……！　て、抵抗ひゅるな？　受け入れた方が楽になりゅ……？\n　はぁ、はぁ、変に拒むから苦ひいだけ……？　あ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「力を抜いれ……受け入れりゅ……。しょ、承知ひまひた……。んん……！　\nぐちゅっ！　ぐちゅぷっ！　じゅぷ……じゅぷぷっ、うう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、あ、ほ、ほんろれふ……。受け入れら方が、苦ひくありまひぇん……。\nはい、ひゃいい……。舌を絡めて、指を動かして……わかりまひた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んん、んんう！　ぴちゃっ、ぴちゃ、ぴちゃ……。ぺろ、ぺろ、れろ……ぺ\nろ、れろ……れる……。ぴちゃっ、ぴちゃ、ぴちゃ……ぺろぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ぐちゅ……ぢゅぷっ！　じゅぷっ、ずぷぷぷ……ずぷ！　ずぷ……じゅぷぷ\nぷ……。んおおお……。ぐぷっ、ぐちゅ、ぐちゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「おふ……っ！　んんんぶっ……！？　ぐぷっ！　ぐちゅっぐちゅっ！　れろ\nっ……れろれろっ！　じゅぷっぶちゅっ！　ぐちゅぢゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「じゅっぷっじゅっぷっ！　ぢゅるっ……はふ……れろんっ、れるんっ、れろ\nれろぉ……ぢゅるっ！　じゅっぷっじゅぷっ！　ずちゅっ、ぢゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「こ、こんにゃおかしなことぉ……本当に皆がしているのですか……っ！？　\nあうっ！？　何！？　口の中れ突起が大きくなっれ……んああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んぶぅっ！？　げほっ！？　げほっ……んんぶぅうううっ！？　変な汁がっ\n！　汁が出ました！？　えっ……何ですかこれは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「苦ッ……臭いっ！？　えっ！？　んんんんっ！？　変な白い汁がっ……うあ\nあああっ、ああああっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……ごほっ！　ごほっげほっ！　こ、この汁……口に入って大丈夫だったの\nでしょうか。毒のような味がするのですが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「へ！？　大抵の女性はこの味が好き！？　この苦味が美容にいい！？　しか\nもこれを飲めば戦力もアップする……？　そ、そんな、ことが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……わ……私は今まで何も知らずに過ごしてきたのですね……。そうなので\nすか、こんな臭い汁が……た、為になります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「皆はこれを飲んでいるから、あのように強かったのですか……。でしたら、\n私も毎晩これを飲めば……。そういうことでしたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「で、ですが、どうしてでしょうね。なんとなく……。り、理由はないのです\nが、これを飲むことに抵抗があるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「だから、私は強くなれない？　ああ……やはりそうなのですね。隊長様、教\nえてくださってありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「次こそは……次に機会をいただいた時には、喜んで飲めるよう、覚悟をして\nおきます。もっと、もっと強くなれるように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え？　はいっ！？　いえ、『次の機会をいただいたら』とは言いましたが、\n今すぐとは言っておりません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え？　続けてやると効果が上がる？　前に飲んだ分との相乗効果で？　その\nようなものなのでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「わかりました。そういうことでしたら、もう一度舐めさせていただきます。\n隊長様の突起を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……隊長様？　まだ、先ほどの臭い汁が先端からしたたっておりますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え？　まだ残っているから吸い出してくれと？　しょ、承知しました。それ\nでは、やらせていただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ちゅっ、じゅっ、じゅううっ、ちゅううう～っ、ちゅっ……んっ。な、なる\nほろ、けっこう、残っているものれふね……じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「じゅっ、じゅる、じゅるるるるる……ちゅっ、ちゅっ……ふぁあ……隊長様\n、あらかた吸い出したようですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はい。二杯目の汁が出るよう、頑張って舐めるのですね。れろ、れろ、ぺろ\nっ……ちゅっ、ちゅううっ、じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ん……慣れてたきたせいは……いろいろなことが、わかってきまひら……。\nこの突起……思っていた以上に複雑な形れふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ぺろ、ぺろ、れろぉ……んん……？　ろうひました？　突起がビクンと震え\nまひたけろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「感じう……？　つまひ、ここを舐めるほ、気持ちひいほ、いうことれすは…\n…？　べろっ、れろれろっ、じゅるるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ぺろ、ぺろ。れろ、ちゅううっ、じゅるるるっ……んんっ……じゅるるっ、\nじゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んふ……？　もっと奥まれ、くわえこむのれすか……？　承知しまひた……\nん、ん、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んんっ……んっ……ちゅっ、ちゅうっ……ちゅるるるっ……じゅるるっ……\nれろ、れろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んっ……ふぁ……れろ、れろ、れろっ、じゅるっ、ちゅぱ、ちゅぱ、ちゅぱ\n、じゅるるっ……ふぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「じゅる、じゅっ、じゅるるるるるるるるっ、ちゅうっ、れろれろ、れろ、れ\nろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んんんっ！？　突起が、さらに大きくなってきまひ……これは、あの臭い汁\nが出てくるのれすね……！？　じゅる、じゅるるるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「もっと激しく……？　首を、前後に動かすのれすか……？　こうれふね……\n？　んっ、ん、んっ、んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、んんっ！　れろ、れろれろ、ぺろ、ちゅっ、じゅぷぷぷぷっ…\n…じゅるるるるる～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んん！？　突起が、ピクピクしてきまひら……隊長様、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103220" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「んんんっ！？　んぶっ！？　ん！　んんんんんん～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ん！　んっ！　んんんんっ！　こほっ！　ごほっ！　けほっ！　こほん！　\nんんんん……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「あ、相変わらず、毒のような味です……とても、パワーアップができるなん\nて信じられない味です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「疑わずに、口の中に残っている分も全部飲め……？　は、はい……ん、んん\nんん……んっ……ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ど、どうにか飲み切りましたが、本当に飲みづらいですね\n、味や臭いもそうですが、この粘っこさが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え？　その粘りがいい？　体にいい食べ物や飲み物は、だいたいネバネバし\nている？　そうなのでしょうか？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「はあ、隊長様がそうおっしゃるのでしたらもちろん信じます……ん？　んん\nんんっ！？　これは！　どうしたことでしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「体の奥から、力が湧き上がってきます！　これはもしかして！　隊長様の臭\nい汁の効果！　本当にパワーアップできたのですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ありがとうございます！　隊長様！　素晴らしい効果です！　ありがとうご\nざいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「……え？　なんですか？　どういうことですか？　『そこまで素直だと逆に\n心配になってくる』というのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ふぁあああっ！？　ど、どうしたのですか？　どうして急に抜いてしまうの\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え！？　あっ！　あああっ！？　きゃぁああっ！　か、顔に隊長様の汁が…\n…っ！？　こ、これはいったいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ああああっ！　隊長様のねばねばした汁が、顔ばかりか胸にも……ああああ\nあっ！　髪もべたべたに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「こ、これはひどいです、隊長殿っ！　どうして急にこのようなことを……ご\nほっ！　ごほごほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「相変わらずひどい臭いです……この臭いを、いったい何と表現したらよいも\nのか……とにかく……ごほごほっ！　吸い込むだけで息苦しくなります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「え？　『なにもそこまで言わなくても』？　隊長様、いじけていないで答え\nてください！　なぜこのようなものを、私に浴びせたり……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「パワーアップの効率を高めるため……ですか？　飲むだけではなく、皮膚か\nらの吸収も効果がある？　……本当ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00014101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「それでこのように全身に……なるほど！　そういうことだったのですね！　\nそれで納得がいきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ふふふっ、こうやってお肌にすりこんでみると、美肌効果もありそうですね\n。なんとなくクリームのようでもありますし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ユール" ]},
		{"command":[ "SETTEXT", "「ありがとうございます、隊長様！　これできっと、私もパワーアップできま\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_141_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
	{"command":[ "EXIT" ]}
	]
}