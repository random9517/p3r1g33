{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「は、話します……！　ちゃんと私のエッチな体験談を話しますから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「うぅ……セックスしたときの話なんて、お姉ちゃんにもしたことないのに…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「なんでって……あ、当たり前じゃないですか！　エッチな話なんて、姉妹で\nするわけありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに、もしこの話がお姉ちゃんの耳に入ったら、なにを言われるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「わかってます……ウソなんてつきません。ありのままをお話させてもらいま\nす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ、あぅぅ……こんな格好でエッチするなんて、聞いてません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「動物の交尾みたいで興奮するだろうって……私は興奮なんてしてませんから\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　やっ、あっ……！　ダメですっ……オチンチン擦り付\nけないで……はあぁぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「擦るたびに、オマンコからエッチな汁が溢れてきてるって……ちっ、違いま\nす……！　オマンコを濡らしてなんていません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それは私の汗です……！　オチンチンを擦りつけられて、熱がこもってるだ\nけです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ！　ああぁっ！　挿れないでくださいっ！　まだ濡れてないので、オチ\nンチン入りませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　ダメぇ……！　先っぽが、オマンコに入ってきてるっ…\n…！　濡れてるのが、バレちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すぐバレるウソをつくなって……だ、だって……！　こんなエッチな体勢で\nシたくなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああぁ……！　ご、ごめんなさいっ！　ウソですっ！　本当はすごく興奮し\nてますっ！　オマンコ濡れてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「正直に言ったから、せめて普通の体勢で……あっ、あっ！　きてるっ……勃\n起したオチンチンが、オマンコに入ってきて……はあぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あぐっ、あっ……んくうぅ……！　そんな……本当にこんなエッチな体勢の\nまま、オチンチン挿れられるだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「くっ、あぐっ……！　ふぐっ、んんっ……！　あっ、あんっ！　ゆっくり奥\nまで入ってくるの、感じますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「このままじゃ、私のオマンコのカタチが変わっちゃう……！　このオチンチ\nンのカタさや大きさを、身体が憶えちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それにこの体勢だと、オチンチンが根本まで入ってきちゃいそう……！　は\n、早く抜かないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んひっ、あっあっ！　ダメっ……ダメですっ！　奥まで挿れないでください\n……！　あっ、あぎっ、んふうぅぅぅ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ひあぁぁぁ……！　あっ、あひっ……オマンコの奥まで、オチンチン入って\nきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチンのデコボコしたカタチが……あっ、あっ……！　はっきり感じ取\nれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ……い、今動かれたら……！　んひっ、あぐっ！　ひっ、あふっ！　あ\nっ、あんんっ！　はぁぁぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「イヤぁぁぁ！　そんなに動かれたら、オマンコがもっと濡れちゃいますっ…\n…！　エッチなお汁、止まらくなっちゃいますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「エッチな声を出して、ヨガった方が可愛いって……そ、そんな……！　こん\nな動物みたいな交尾で、気持ちよくなりたくなんて……あはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、くぅ……あふっ、ひっ、んふうぅぅ……！　こ、声……我慢できませ\nん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オマンコの奥をズンズンって突かれると、勝手にエッチな声が出てきます…\n…あっ、ひぎっ、うくぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ、ああぁん……！　赤ちゃんの部屋のところ、感じすぎますから……！\n　もう少しゆっくり、優しく突いてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そんな乱暴にズンズンって小突かれると……私の大事なところ、どんどん開\nいちゃうので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「子宮口が開いた状態で膣内出しされたら、妊娠しちゃいますっ……！　制服\n、着られなくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに、お姉ちゃんに気付かれちゃうっ……！　私がセックスして、膣内出\nしされたこと、バレちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んんっ……！　そんなのダメだってわかってるのに……オマンコが悦んで…\n…あんっ！　あっ、ああっ！　精液欲しがってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「思い切り膣内出しして欲しくて、子宮が疼いて……あはぁぁぁ！　オマンコ\nが蠢いてきてますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あぐっ、ああっ！　オチンチンがビクビクしてるっ……！　膣内出ししたい\nって、主張してきてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「奥はダメですっ……！　せめて浅いところに出して……！　くっ、あふっ…\n…はぁ、あああっ！　んはぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅ～～～……！？　奥に……子宮口に押し当てられながら、膣内出\nしされてますっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ど、どうしてっ……！　私、出すなら浅いところでって言ったじゃないです\nか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「孕ませたかったって……そんなこと言われても……！　んっ、はああぁ……\nま、まだ出て……ふくぅぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「妊娠したことがお姉ちゃんにバレたら、殺されちゃうかも知れないんですよ\n……！？　それでも、いいんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それでも孕ませたいんですか……！？　そんな……私が悦ぶようなこと、言\nわないでくださいっ……あっ、ぐっ、あっ……！　ああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁ……ふっ、んんっ……！　あっ、くぅ……たくさん子宮に精液を流し込\nまれちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……はぁ、はぁ……全部奥に出さたので、さすがに苦しいです\n……お腹の中、パンパンな状態です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それに早く出さないと、本当に赤ちゃんが出来ちゃいます……あの、そろそ\nろオチンチンを抜いてもらっていいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ……？　まだ終わりじゃない……？　今度はオマンコをしっかり擦って\n、精液を馴染ませる必要がある……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「まっ、待ってください……！　いま動かれたら、イッちゃうっ……！　あっ\n、あああっ！　んんんんっ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　ふああぁぁ……！？　イッてる最中なのに、オマンコ\nズポズポされてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それにさっきよりも激しく、奥を突かれて……！　本当に精液が馴染んじゃ\nいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いま精液をオマンコから出せば、まだ間に合うかも知れないのにっ……！　\nこうやって動かれたら、もう間に合いませんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああっ……！　はぁ、くふっ、あひぃ……！　きっ、気持ちいいっ……！　\nオマンコ精液まみれにされて、気持ちよくなってますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「もっ、もういいですっ！　膣内出しでもなんでも、好きにしてくださいっ！\n　私のこと、好きにしてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「別に怒ってるわけじゃありません……！　こんなにオチンチンで責められた\nら、諦めるしかないじゃないですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そ、それに……こうやってオチンチンをズポズポされるの、気持ちよくて好\nきですし……！　妊娠もイヤじゃありません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんのことだけ、なんとかしてもらえれば……！　ああっ！　や、約\n束ですよ……！　ちゃんと、説得してくださいね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ひぎゅ、あっ、んふっ……！　あっ、ああっ……！　もっとオマンコ締めま\nすから、いっぱいぐちゅぐちゅしてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私のこと、オチンチンでメチャクチャにしてください……！　このオチンチ\nンのカタチを、しっかりオマンコに刻みこんで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んひっ、はっ、くふうぅぅぅ……！？　いっ、いいです……！　もっと奥を\n弄って……！　気持ちよくしてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ！　んっ、はぁぁぁ……！　イクッ……イッちゃいますっ……\n！　動物の交尾で、イッちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「は、はい……！　出していいですから……！　膣内でも外でも……好きなよ\nうに精液出してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あああっ……！　オチンチンが震えてるの、ちゃんと感じます……！　あっ\n、イクッ……！　イキますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　はぁ、はぁ……あっ、ひぎゅっ……はぁ、あああっ…\n…！　ひぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ～～～っ！　ま、また膣内に……！　赤ちゃんの部屋にびゅーびゅ\nー出てますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「熱いの、奥まで流し込まれて……かっ、感じます……！　子宮の中、いっぱ\nいになってるのわかりますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「気持ちいいですっ……！　こうして膣内出しされると……幸せな気持ちにな\nってきますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……！　くっ、ああぁっ……ま、まだ出てるっ……！　さっき\nよりも、射精が長いですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はい……遠慮しないで、全部注ぎ込んでください……！　私のオマンコ、精\n液で染めてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、んんっ……！　こんなに出されたら、妊娠してなくても、お\n腹が大きくなっちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えへへ……もし精液で大きくなったお腹を、お姉ちゃんに見られたら……ど\nんな反応するんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっと、そうですね……間違いなく、ボコボコにされるとは思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ですが、お姉ちゃんを説得してくれるって、さっき言いましたよね……私、\n信じてますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「大丈夫です。殺されそうになったら、ちゃんと助けてあげますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅ～～～！？　オマンコからオチンチンが抜けて……あっ、んあぁ\nっ、ふっ、あぁぁぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、熱いっ……！　身体中にドロドロした液体がかかってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「これ、もしかして精液ですかっ……！？　どうして膣内じゃなくて、外に…\n…ふあぁぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やぁぁっ……！　精液まみれになるの、気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「全身が精液まみれになってると思うと……あっ、あっ！　ダメっ……またイ\nッちゃいますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んんっ……私の身体、精液でベトベトになっちゃいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「変な感触ですが……別に不快なわけじゃありません……どちらかと言うと、\n嬉しいという気持ちの方が強いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「なんていうんでしょうか……支配されたとか、マーキングされたみたいな感\nじがして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すっ、すいません……こんなこと言うと、変態みたいですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「でも……動物みたいなエッチをしたので、私たちはもう十分に変態なのかも\nしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0104410" ]},
