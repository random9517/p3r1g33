{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ん～っ！　たまには浜辺もいいねぇ。このスカッと晴れた空！　吹き抜ける \n風！　悪くないよ……。隣には隊長もいてくれるし、最高さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……はぁ？　これから二人で何をするかって？　そんなこと、悩むまでもな \nいだろう。夏の浜辺で、男と女が二人きり……といえば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ヤることは１つっきりさ。ねえ、隊長も……そのつもりで来たんだろう？　 \n他のやつらの目の届かないところで、こんな風に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……そうだ♪　アタシを思いっきり砂の上に押し倒して、存分に好きにもて \nあそぶのさ……♪　クククッ、もちろん、こっちもそのつもりで来てる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019902_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長はモテるからねぇ、なかなかアタシの番が回ってこなくて大層ヤキモキ \nさせられたもんさ。でも、ここまでもちこんじまえばアタシの勝ちだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……今日の隊長の性欲、劣情、ムラムラした欲望は、ぜーんぶアタシに…… \nこの奈羅苦ねえさんにぶつけてくれるんだろ？　期待してるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っはぁっ♪　なんて、煽るまでもなさそうだね……。なんだいなんだい、そ \nのとんでもなくデカいチンポはぁ……よだれが出ちまいそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ねえ。もったいぶってチンポをチラつかせてないで……早く入れておくれよ \n。こっちの準備は、もうとっくの昔にできてるんだ……。っん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長とヤれるかもって思っただけで、身体が熱くてたまらないんだ。もう、 \n自分でもだいぶ濡れちまってるのがわかるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「面倒な前戯なんていいからさ、ズブっとそれを……。はぁっ♪　はぁ、猛り \n狂った隊長のチンポ、太くて硬い……そいつをアタシの中に入れてくれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んふぁああっ♪　おっ♪　んぉおっ！？　おっ♪　おぉおおお……！　ひゅ \n、ひゅごい……しゅごいぃっ！　一気に根元までっ！　おっおっおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長ぉおお……♪　アタシん中、いきなりチンポでいっぱいになっちまった \nぁああ♪　あッ♪　あっ、これっ、これひゅごいぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシの指や、オモチャなんかとは比べ物になんないよっ……！　あぁっ♪ \n　んぁあっ♪　これが……ホンモノの隊長のチンポ、欲しかったチンポっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ア、タシのデカい身体をもってしても……んぁっ♪　ギリギリでしか受け止 \nめきれない、とんでもないサイズの極太チンポ……すごすぎるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「わ、わかるかいっ？　アタシん中、チンポでミチミチに拡がっちまってるん \nだ……！　あっ♪　あっ、隙間無く埋められて、子宮の口まで貫かれて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁああっ♪　入ってるだけでものすごい満足感だよ……さすがだね……っ \n。ああ、誰にも邪魔されたくない。誰にもここに来てほしくない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長……わかるかい？　アタシの中、マンコのヒダが喜びでうねりまくって \nるのが。愛液もドパドパ溢れ出てきて止まらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「どうかこのまま、アタシをめちゃくちゃにしておくれ……！　あっ♪　焦ら \nさないでおくれよぉ……限界なんだ、火照って仕方ないんだよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ……、こっちから腰を揺らす、から……そっちも好きなタイミングでマ \nンコ、えぐって突き上げておくれ……！　い、くよ……は、ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……！　デ、カいぃい……っ！　マンコにズンッ、ズンッ、て \n響くよ……♪　男にも名器ってぇのがあるのかどうかは知らないが……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あ、はっ……♪　あるなら隊長のコレがそうだ……！　女をぉ……ううんっ \n、メスを狂わせる魔性のチンポ……！　あぁっ、あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「どんなメスでも自分から股を開いて、妊娠させてくれ、孕ませてくれって泣 \nきながら懇願させられちまうような最強で最高のチンポだよぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「う……ッ♪　あっ、ぁっ♪　うぁああっ♪　あっぁっ♪　少しピストン…… \nされただけで、マンコからドパドパ愛液が溢れ出すぅ……っ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「もっと！　もっとキツく動いていいんだよっ！？　……あああ、違う！　も \nっと激しく動いてほ、しい……。っああっ！　こ、これもまだ違うっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んああああっ♪　お願いします、隊長っ……！　どうか！　このザコザコマ \nンコの奈羅苦ねえさんを、隊長のチンポでハメ殺してくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……あひっ！　んひっ、ひぃいいっ！　もっと！　もっとだよっ！　中途半 \n端な腰使いじゃあアタシは満足なんてできないんだっ！　……もっとぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んぁああああああ♪　マンコ壊れるくらいっ、体重かけて挿入して、ずるぅ \nううって引き抜いて！　エグい肉笠でアタシのマンコひっかいてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「えぐって！　一番奥の奥ぅ、子宮の入口を押し上げとくれぇえええっ♪　ん \nはぁああっ♪　あはッ♪　んんっんぉおおっ♪　おおおおっ、おぉんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こんなにケモノじみた喘ぎ声をあげていたら誰かが来る、だって？　アハッ \n、知るもんか……むしろ見せつけてやりたいくらいさ！　……あぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「奈羅苦ねえさん、を♪　こんなガンギマリのチンポ狂いにできる、のはっ♪ \n　あ～～っ♪　この隊長だけなんだって、このチンポだけなんだってさぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こんな風におかしくなってチンポっ、チンポのことしか考えらんなくなるく \nらい……具合が良くて、腰が止めらんないってさぁ、教えてやりたいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あ～～っ♪　あっぁっあっ♪　最高だぁあ♪　隊長……！　隊長のチンポ気 \n持ちいいよ、イキそうだ……！　あッ♪　イッて、いいかいっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ううん、イカせとくれ……！　アンタのチンポで無理やりっ、アタシのマン \nコを絶頂させてよぉっ♪　ガッついて、子宮口こじあけてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「奥に精液注いでくださいって、言わせとくれぇっ♪　んあああっ♪　そうっ \n、そこだ、そこを突きまくって、……んひぃっ、いいカンジだよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁあああっ♪　粘膜を串刺しにするチンポ……んあああっ♪　そこから精 \n液っ……絞りあげてイキたいっ……あああっ、イクっ！　イク、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んおぉおおおっ♪　おほっ♪　おぅっふっ♪　んぉおおおっ……♪　出てる \nよっ……隊長の、特濃精液打ち込まれてるっ、子宮に当たってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ……！　射精が終わるまで、絶対に離しやしないよ……！　んッ……♪ \n　アタシのマンコがギュッと締まっただろ……そら、捕まえた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あるだけ出しなっ……！　んあああっ♪　出し終わる、までっ……！　チン \nポは逃がさない……！　っふぅうううっ♪　子宮で飲み干してやるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っぉっ♪　いいねぇ……♪　アタシの中で爆ぜる熱い精液の、この勢い…… \n！　あっ♪　ぁっ、超一級品だよ……いくらでも注いどくれぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「マンコに中出しされながらイクぅっ……！　ほぉおっ♪　おほっ、んほぉお \nおっ♪　からっぽだった子宮が、白いドロドロで満たされていくぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっああぁ……ああっ、あぁああ……♪　はぁああっ……♪　……ああ、ゴ \nメンゴメン。いつまでも、しつこくマンコで締めつけたままだったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あんまり気持ちが良かったもんだから、我を忘れて快感ってやつを貪り尽く \nしちまったよ……。ああ、今も余韻がすごくて頭がクラクラしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長は本当にスゴいね……。フフフッ、奈羅苦ねえさんをチンポ一本で従順 \nにして、イかせてよがらせるなんて普通の男にはできないことなんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……と、せっかく褒めてやってるのに、腰を引こうとするのはナシだよ。言 \nっただろ？　全部出し終わるまで逃がさない、って……ククク」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「どうせ絶倫の隊長のことだ。１回くらいの射精で全部、精液を出しきってる \nわけないと思ってね……。そうさ、このまま続けてヤってもらおうか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ンッ、ぁ……♪　アハハ、なんだい……そっちもとっくにその気だったんだ \nね。はぁっ♪　いいよ、マンコはずっと締めつけたままでいるからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そのままっ……あっ♪　突いとくれっ……♪　んふふふっ、やっぱり隊長は \nスゴいねぇ……あはっ♪　あれだけ精液出したすぐ後にコレだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「萎えるってことがなくて怖いくらいだよ♪　んっ♪　それとも……奈羅苦ね \nえさんのマンコと相性が良すぎて、次々勃起しちまうのかい？　っうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「これだけギチギチにマン肉で締めつけて、も……負けずにチンポで応戦して \nくるんだから……っ、あっ♪　本当に、男の中の男さ、惚れ直すよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アンタみたいな豪快な男に抱かれるのは、女として最高の栄誉さ……んぁっ \n♪　強い、男の強いチンポ……強い子種、大量の精液……あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「わ、かりやすい大胆なチンポが好き、だよ……♪　んんっ！　は、ぁっ♪　 \n女の弱いところ……っ、あっ♪　知り尽くしてるズルいチンポぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こんなの突っ込まれてアンアン言わされちまったら、もう他の男なんてどう \nでも良くなっちまうっ……あっ♪　アタシですらそうなんだ♪　んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「女の子らしい女の子なんて、きっと１回ハメられただけで……あぁうっ♪　 \nこのチンポの虜になっちまうんだ、ろうね♪　気持ち良すぎるんだよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っあああああっ……♪　んぁあああっ♪　あああああっ♪　あっ、ぁっ、こ \nのチンポはアタシのだっ、絶対誰にも渡さないぃ……！　っあっぁっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「その、ためになら悪の女幹部だろうがなんだろうがなって、やるよ……だか \nらっ！　だからもっと犯してくれッ、マンコ突いて、突いてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んひぃいっ♪　ひぃんんっ♪　あっぅっ♪　ううううっ♪　アタシの愛液と \n、隊長の精液が混ざり合って……もうマンコの中、ぬっちょぬちょだよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！？　完全に子宮降りてきちまってるっ……♪　今、射精され \nたら確実に孕むぅうっ♪　でも、それが……それがいいんだっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、孕ませとくれ……ッ！　隊長の強い子種、最強の精液、アタ \nシん中に……マンコにもう一度注入して、受精させてほしいんだっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んあぁああっ……！　嫌だって言ったって絞り取ってやるぅっ♪　あッ…… \n♪　わかるだろ、マンコのヒダがチンポにがっつり食らいついて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204219" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっぁっ精液をめぐんでくれっておねだりしてるよっ♪　っああっ！　隊長 \n！　隊長、出しとくれっ、奈羅苦ねえさんを救うと思ってさぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぅああああっ♪　んあああああっ♪　いいねっ、いいよっ……！　コレだ \nよっ、熱い精液っ……！　二度目の注入だ、粘膜にしみるよぉっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あああっ♪　なん、で、一度目よりも多く出してるんだいっ……！　えっ？ \n　奈羅苦ねえさんのマンコが気持ち良すぎたからって……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「射精しながらそんなこと言うのは野暮っ、だろぉっ……！　あ～～～っ♪　 \nイッちまうっ♪　出してる最中に甘い言葉を囁くんじゃないよぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっぅっ♪　ううッ♪　んぅうっ♪　ううっ……！　だ、めだ……あああっ \n♪　隊長の精液で子宮が喜んでる、溺れるくらい注ぎ込まれて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「目の前まで真っ白になっちまうくらい♪　ビュブビュブ無限に叩きこまれて \n……！　あっ♪　どうにかなっちまう！　イクっ、イッちまうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ああああああああっ♪　アタシのマンコですら受け止めきれないくらいの量 \n、出しやがってぇっ♪　んひぃいっ、あああっ、最高に気持ちいいよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……あは……。なんだろうね、久しぶりに誰かと外でなんか会ったりしたか \nら……アタシも、ムードってやつに流されちまったのかもしれないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ああ。少々乱れすぎちまった自覚はあるよ……。わ、悪かったね。まさかこ \nんなに、自分が盛り上がっちまうタイプだと思っていなくてさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……え？　たまにはハメを外した奈羅苦ねえさんもいいって？　……フフッ \n、隊長はホントに器がデカくて助かるよ。でも、だからなのかねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ついつい甘えて、他のやつらには見せられない顔も姿も見せちまう。ま、こ \nれからも……たまにはそういうカンジで頼むよ。隊長……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あッ……♪　って、た、隊長っ！　アンタ、射精の勢いが強すぎて……あっ \n♪　奈羅苦ねえさんのマン肉の圧力からも抜けだしちまったのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、ぁっあっあっ！　なんてこった……！　せっかくの２発目の \n射精を、無駄撃ちさせちまうなんて……！　あっ、い、いやだよっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「身体になんかかけないで、マンコの奥に出してくれなきゃ……！　……んん \nっ！？　なんだって、この服と、アタシの身体にかけてみたかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そ、それなら話は別だろうっ……それを早く言いな！　隊長がそうしたくて \nそうしてるんなら……いいよ！　アタシも、それでいい、かけなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「クククッ……♪　アタシの肌に撒き散らされた隊長の精液……♪　自分の色 \nに奈羅苦ねえさんを染めた感想はどうだいっ……♪　っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシはすごく気持ち……イイよ♪　精液……熱いのがドロドロ肌にまとわ \nりついて……まるで日焼け止めクリームさ……♪　んぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「フッフフフ……♪　いつも隊長にはしてやられるよ。アタシの予想を覆す、 \nたった一人の男……。不意打ちの仕方が斬新すぎて笑っちまうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「可愛げのある他の女たちならともかく、アタシみたいな相手に精液撒き散ら \nして、マーキングして、支配した証を見せつけるなんて……愛しいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そんな風にわざわざ見せびらかさなくても、アタシは……奈羅苦ねえさんは \nとっくに隊長、アンタのモノさ。だからこうしているんじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アッハハっ……それにしてもこのぶっかけっぷり。どんだけ精液が溜まって \nたんだい。ま、いつでも解消してやるから一番にアタシに頼りなよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
