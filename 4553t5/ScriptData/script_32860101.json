{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……このあたしを……ティシポネーをこんな夜中に呼び出すなんて、怖いモ\nノ知らずもいいとこだな。気合入ってんじゃねーか。あぁん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしが怖くないのかよ？　はぁ？　怖い女には慣れてる、だぁ？　ぷっ…\n…くくくっ、随分と肝の据わったヤツだな。おもしれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしを前にして、ビビらずにドンと構えていられた男は初めてだぜ。しか\nも、イチャイチャしたいだぁ？　……はっ、気に入った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「お望み通り、うんと仲良くしてやってもいいぜ……？　っと……、もうチン\nポをこんなにしてやがったのか。大した度胸の持ち主だ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「どぉ～れ……。じっくり腕試し……。いや、チンポ試しといこうじゃねえか\n。いいんだろ？　あたしがコレ、好きにしちまってもさぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……って、それにしても、なんだこりゃ。デカすぎるな……。興奮してるか\nらか？　それとも……普段からこんなサイズぶら下げてんのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「さぁて、どうやって遊んでやるかなぁ……。はぁ、はぁ、はぁ……。……はぁ？\n　なんだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしがチンポをガン見して、めちゃくちゃ嬉しそうにニヤついてるぅ？　\nおぉ～？　言ってくれるねぇ。興味があんのはご指摘の通りだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「でもなァ、実際しゃぶって見たら激弱の、見掛け倒しなヘナヘナチンポかも\nしれねえだろ？　強気でいられんのも今のうちだぞ？　……ほぉーら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「れろっ……！　ぴちゃ……！　ンフフフ、どぉだ……？　あたしは他の女み\nてぇに、お上品にチロチロ舌先でフェラするなんてもったいつけはしねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「最初っから全力全開で、チンポの先から根元まで舐め回しまくってやるぜ。\nあははっ、泣きべそかくんじゃねーぞ！？　んれろっ、れろっ、レロッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ちゅぷくちゅちゅぷじゅるっ……！　れろれろれろっ、ぴちゃっ、ぴちゃ…\n…れろぉお……♪　ん……硬さと太さは合格点だな……んれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「先走りの汁の量も……ぴちゃっ、悪くねぇ。舌にまとわりつくこの臭い、熱\nさ……。はぁん？　なかなかだが……感度はどうだ？　れろっ、れろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んんっ……！　よっくわかんねぇぞ……腰引くんじゃねえ！　ぴちゃっ、ぴ\nちゃ、くちゅ……！　んん、ビクビク震えてなかなかイイ感じだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「そしたら……んれろっ、チンポの先から根元まで舐め下ろして……れろれろ\nれろっ！　すぐさま今度は反対に舐め上げる！　んれるっ、れるれるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……ん！　おいおいおい♪　まだこっから硬くなんのかよ……。たっまんね\nえなぁ……♪　どれ、小手調べはここまでだ。次は本番……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「じゅっぷっ！　ぐちゅっ！　本気フェラ、つまり……奥まで咥えて、しゃぶ\nりフェラいくぞ！　んっ、ぐちゅっ！　じゅっぷっ！　じゅぷっぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「オラッ……！　おらっ、感じやがれ！　このティシポネー様がおクチでご奉\n仕してやるなんて、めったにあることじゃねえぞ、感謝しなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ん、ぐちゅっ！　じゅぷっ！　じゅっぷっ、ぐちゅっ……！　ぢゅるるるる\nっ！　じゅるっ……じゅっぷっ！　んっ！　んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「と、とんでもねーデカマラじゃねえか……っ、咥えがいがあるぜ！　んぐち\nゅっ……ぐちゅっ、じゅっぽっじゅっぷっじゅぷっ、ぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　なんだ？　口いっぱいにチンポしゃぶってっと、身体が熱くな\nってきやがる……。なかなかイイチンポ、だな……じゅっぷっじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぁああ……この反り返り……♪　男らしすぎだろ、んん……♪　よだれが\n溢れてくる、ぜ……。……ん？　おい、な、何やってんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぐぅうううっ！？　んむぅううっ？　んぷぅうっ！？　ンンッ……！？　\nイ、イラマだと……！？　んっ、ぐちゅっ、い、イラマヒオ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「っんはっ♪　お、おもしれぇ……！　真っ向から勝負しかけてきやがったっ\nてことか……。んぅっ！　んふっ……！　主導権は渡さ、ねえ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……あぁ？　な、なんら？　あたひが……、あたしがイラマされて感じる、\nだと……？　んぐっ、じゅぷっ……ふ、ふざけてんじゃねえ、ぞ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んっ……！　は、ぁ……っ？　マンコが濡れてきてる……？　み、見るんじ\nゃねえよ、んぁっ、股間のシミが広がって……？　ん、ぁ、あ、あ、ぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……あ、ああそうだよ！　認めるっ、認めるよ……！　そうさ、あたしは…\n…んじゅぷっ、この時を待ってたんだ！　っじゅぷっ、ぐっちゅっぐちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「人を怖がらせているあたしを……！　こんなあたしを無理やりに犯してくれ\nる最強のご主人様を探してた！　っんぅ、無茶苦茶にしてくれる男、を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……なあ♪　もっと、もっと激しくしてくれよっ……あぁっ♪　あたしのク\nチ、オナホにして道具みてぇに犯しまくってくれぇっ……じゅぷぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「い、いや……！　エラそうにしてる場合じゃねえな！　お願いひまひゅ……\nっ、ぐっちゅっ♪　あたしをご主人様のオナホにひてくだひゃいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「お願いひまひゅぅうっ♪　……んんん！　んんんん～っ♪　んっ、じゅぷっ\n！　ぐっちゅっ！　ぐっちゅっぐちゅっ、んんん、たまんねぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「もっと！　もっとヒドくひてくれぇええ♪　……んむぅううっ♪　ぐっちゅ\nっ！　ぐちゅっ！　じゅっぷっ！　じゅぷぷぷっ、ぢゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ♪　あっ♪　ごひゅじんひゃまぁああ♪　ごひゅじんひゃまのチンポ美味\nしいぃいっ♪　もっとしゃぶりたいっ、んむっ♪　んむ、じゅるっじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぁっ、んああっ♪　ドマゾのドスケベなクチの中にっ、容赦なく精子ブチ\n込んでくださいっ！　便所がわりにしてくだひゃいぃいっ♪　ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んっ、んぉっ♪　ぐちゅっ！　じゅるっ、精子ぃ♪　精子欲しいれひゅぅう\nっ、くだひゃい！　ぐっちゅっ、ぐちゅっぐちゅ……んんんんーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んむぅううううう～っ♪　むぅっ、むぅうう～っ♪　んぶぅううっ♪　んん\n～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ごくっ……！　ゴクッ、ごくっ……！　あ、ぁ、あ……！　迷わず飲み干し\nちまうくらい濃厚な精子がこんなにぃいい……ありがとうございまひゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「感謝してゴックンさせていただきまひゅぅっ♪　ぢゅるっ、ぢゅるっ……じ\nゅるっ、あぁあああ……♪　ごくっ♪　ごくっ、ごくんっ、ごくっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「すっげぇっ……♪　とんでもねえ勢いで、ビュッビュッ出てくるっ……！　\n信じられねぇよぉ♪　ごくっ♪　ごくっ♪　美味いぃ、もっともっとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んんんぁあ……♪　口元がだらしなくゆるんじまうぅ♪　こってり口内射精\n♪　あたしのご主人様の射精、スゴすぎぃいい……♪　たまんねぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……ん、は……♪　す、すみません……♪　感動しすぎて息すんの……忘れ\nてました。はぁっ……♪　はぁ、はぁ♪　最高のイラマと射精でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「やっぱり、ご主人様と認めたのは間違いじゃなかった……！　……え？　尿\n道に残った汁まで全部飲み干せ？　あぁ……望むところです……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ、じゅるるるっ……ごくっ、ごく、ごくっ……♪　ん、はぁああ…\n…♪　ヤッバイ……っ。興奮で頭クラクラするぅ、最高ぉおお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「なぁ、ご主人様ぁ……♪　あたし、ご主人様に無理やりイラマされてる時の\n感覚がどうしても忘れらんねえんだ！　もう一回お願いできますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はい……♪　一度経験したら、病みつきになっちまって……♪　自分のクチ\n、好きに使われんの、マンコがゾクゾクして止まんないくらい好きです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「だから……また、頭ガッチリつかんで力任せに……。んむぅっ♪　んううう\nっ♪　キたぁああ……♪　そうです、コレっ、コレ、コレぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んんっ♪　イラマっ♪　イラマしゅきぃい……♪　ごひゅじんひゃまぁあ♪\n　ごしゅじんひゃまの逞しいチンポ好きぃ♪　ご奉仕させてくだひゃいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……っじゅぷっ♪　じゅぷっ、じゅっぷっ、んんんッ♪　そう、喉奥まで全\n部貫いて……んむぅううっ♪　ぐちゅっ！　ぐちゅっ、クチん中丸ごと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「チンポこすりつけて、あたしのベロを絡みつかせてぇ……じゅっぷっ！　ん\nん～っ♪　ヌルヌルの、動くオナホとして……あっあっ！　ぐっちゅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ヤッバっ……！　んんんっ！　イクっ……！　イキそっ……ああっ！　っじ\nゅぷっ！　ぐっちゅっぐちゅっぐちゅっ……！　イクッ、イグッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ご主人様のチンポスゴすぎぃいっ♪　気持ち、イイ……んじゅぷっ、じゅぷ\nっ！　イラマ、イラマっ……♪　夢にまで見たドMご奉仕ぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「もぉ、こんなんされたら……イラマ中でもしゃぶり倒しちまいますぅうっ♪\n　んれろっ……れろっ！　ぐっちゅっぐっちゅっ、んん、すっごぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしのクチと♪　ご主人様のデカチンポ♪　協力しあってぶつかりあって\n……！　エグい摩擦生まれてるぅっ！　っじゅっぷっ、れろっじゅっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んっ！　んっ、んっんんっ……！　ふぐっ……んぐっ、うぅ♪　先走りの汁\nが……クチん中にじゅわっと滲んで……んじゅるっ、じゅるっ、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ♪　ごひゅじんひゃまのチンポが暴れてりゅっ……！　んじゅぷっ！　\n頬の裏、舌の上ぇ……♪　んぶっ♪　じゅぷっ、喉の奥ぅう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ガン突きで攻めてきますっ……！　んっ！　んっ、や、やめないれくだひゃ\nいぃ……！　そのままっ、そにょまま突いて、掻き回ひて……んっうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んじゅぷっ！　じゅっぷっ……！　じゅぽっ！　ぐっちゅっぐちゅっぐっち\nゅっ……！　んんん～っ……♪　ンン……っ♪　ぐっぽっぐぽっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「えふっ……！？　ごひゅじんひゃま、チンポが膨らんれきまひたぁ……♪　\nじゅっぷっ、ビクビク痙攣ひて……あっあっ、精子出そうれひゅかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「それならあたひのクチで吸い上げまひゅからっ……！　奥まで遠慮なく突き\n込んでくりゃはいっ……！　ぢゅるるるっ！　じゅるっ、ぢゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ん、ぁふっ♪　精液っ……精液欲ひいれひゅっ！　流しこんれくらひゃいっ\n……！　じゅるぅうっ！　じゅるっ、ぢゅるるるっ！　じゅるっ！　ぢゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_09" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んんんんん……ッ♪　んんんぅっ、んんんんんーーっ……♪　んぶっ……ん\nふっ？　い、一度に飲みきれないくりゃい溢れてくりゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぁっ、んおっ、んぷ……っ！　息ができないぃ……っ。んっ、ゴクッ……\n！　ごくっ、ごく……！　ぷぁあ……勢いが衰えなくてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたひが飲むスピードより、精液の方が何倍も早いぃ……！　んんんん！　\nごくっ……ごくっ、ごくっ……。んっ……！　ンッんっんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぷぁあ……♪　なんって濃い味の精液なんれひゅか……！　ネバネバがベ\nロにまとわりちゅいて……。んっ、飲みづらい……んぁうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ほとんど固形みたいな、とんでもない精液が……んんぅっ！　クチいっぱい\nに溜まって、……んんっ、顎が外れそうれひゅ……！　っごくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「れも……！　こぼすのはもったいないから……っ。ありがたく全部いただき\nますっ……。ごくっ……ごく、ごくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ぷ、は……っ♪　ごちそうさまでしたぁあ……♪　あぁ……♪　ご主人様の\nチンポ、ホンットデカすぎて……まだクチん中痺れてます……フフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「こんだけ強いチンポに屈服させられると……やっぱりご主人様を選んで良か\nった～って心の底から思います。ずっと、こうしてくれる人を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「気の強いあたしですら、容赦なくか弱いオンナにしちまえるくらいの強靭な\nチンポを待ってたから……。あはっ、諦めなくてマジで良かったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「この、天才的なチンポと……その持ち主であるご主人様にだけ、本当のあた\nしを知ってもらえた。今日襲われて……すっごくドキドキしましたよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぷぉおおおっ！？　あっ……！　すんませんっ……！　イキそうになって\n、クチ……思わず離しちまって……！　あっ！　あっぁっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤバイっ……！　あたしのクチん中じゃなくて、か、顔っ……顔にかか\nってる！　せっかくのご主人様の精液がっ……ごめんなさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぷ……！　ぷぁ、あぷ……！　うう……！　あっ！　あっぁっ……！　チ\nンポが跳ねまくって、く、クチに戻せねぇ……！　あうっ！？　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ……♪　お仕置きですか？　お仕置きに顔に精子を塗りたくって……ブッ\nかけてくださってるんですか！？　あっ、あぁ……それなら良かったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はい♪　はい！　あたしはフェラチオもまともにできないダメマゾ犬です！\n　こんな駄犬には、顔射がお似合いです！　もっとかけまくってくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んっ……！　あぁあ、ご主人様の臭い……♪　うっとりしちまうよ……っ。\nヌルヌルのタンパク質で顔をたっぷりパックされて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　はぁ、はぁ、はぁ、はぁっ……♪　もう一生、顔洗いたくない…\n…♪　このままご主人様の精子浴びたまま暮らしたいぃ……♪　はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……へ？　さすがにそれは汚いからやめてくれって……。ヤだなぁ、ご主人\n様に汚いとこなんかないですよ。……え？　それでもダメですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……フフ、ぷくくくっ……♪　さすがにずっとこのままってのは冗談です。\nでも……一秒でも長く堪能したいってのもガチの本音っていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……ご主人様は、ドＭ女の喜ぶやり方をよーく知ってらっしゃるんですね。\nこれからの調教が、待ち遠しくて仕方なくなってきましたよ……♪」", "NORMAL" ]},
