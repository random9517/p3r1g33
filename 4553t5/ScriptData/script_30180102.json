		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ん？　いつも不幸、不幸って言うけど、今まで幸せを感じたことがない\nのかって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……私はアンハッピートリガー・グリムロックだよ……そんなことあ\nるワケ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ……い、いや……幸せを感じたことは、なくもない……かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「どんなときって……そ、それは、その……！　はじめて、セックスをした時\nで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「で、でも……あれは、幸せと不幸せが入り混じった結果だから……！　半分\nは不幸せだから、セーフだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……こんなにおチンポを勃起させて……準備万端みたいだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001801_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ……はあぁ……これが、今から私の膣内に……おマンコに入って、は\nじめてを奪うって思うと……あっ、ああんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「絶対、痛いんだろうね……フフフ……苦痛の中で、おマンコをズポズポされ\nていくんだね……ああっ、私、なんて不幸なんだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「べ、別に……怖くなんかないよ……むしろ、不幸を感じられるって思うと…\n…は、発情して、おマンコが疼いちゃうぐらいだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「身体が震えてるって……？　こ、これはおチンポがおマンコに擦れて気持ち\nいいからであって……決して、怖いわけじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ……そんな……恋人みたいな手の繋ぎ方をするなんて……フフフ……優\nしいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ああ、そうだよ……柄にもなく、怖いと思ってるんだ……でもね……発情し\nてるのは本当だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ほら……私のおマンコ……グチャグチャに濡れて、エッチなお汁が垂れてき\nてるの……わかるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ……私も準備万端だから……挿れるね……？　太くてカタいおチンポで\n……私の処女膜……貫いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「大丈夫……一気に来て……！　あっ、んっ……！　んんんっ、んぎっ、あっ\n……んうぐぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フ、フフフ……私のはじめて……奪われちゃったね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　はああぁ……すごい……本当にセックスしてる……お\nチンポとおマンコで……一つに繋がってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「痛くないのかって……？　フフフ……実は思っていたより、痛くはないよ…\n…むしろ、すぐにでも動いて……感じさせて欲しいぐらいだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だから……私のおマンコ、いっぱいメチャクチャにして……！　不幸を感じ\nるくらい、たくさん突いて……犯して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私を穢した責任……取って……あっ、あっ……！　んっ、ああっ……！　ひ\nうっ、んぐううぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「すごい……！　奥、ズンズンって突かれてる……！　子宮口におチンポが当\nたるの、感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「やっ、あああっ……！　こんなに気持ちいいの、はじめてっ……！　今まで\nこの快感を知らなかったなんて……不幸せすぎるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ……！　それ、好き……！　おマンコグリグリされるの……すごく感\nじるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっとおチンポでかき回して……！　私のおマンコ……いっぱい、ズポズポ\nしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「壊れるぐらい……使ってくれていいから……！　おマンコがおチンポのカタ\nチになるぐらい……好きに動いていいからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んくっ、ふひっ……！　はぁ、あひいいぃ……！　は、はじめてなのに……\n！　私、処女だったのに……こんなに、感じるなんてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はあ、はあぁ……そういえば、知ってる……？　魔女狩りがあった頃……魔\n女は処女じゃないって言われてた話……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……私、処女だったのに……魔女って呼ばれてたんだよ……今思うと\n、おかしいよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも……処女を守り続けて、よかったって思ってるよ……だって、こうして\n好きな人に処女を捧げられたからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　ど、どうして……！？　急におチンポがビクビクして、膨\nらんで……んっ、あああっ……！　お腹、苦しっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「可愛いこと言うから、射精したくなった……？　じゃあ、この膨らみは……\n射精の合図ってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うん……！　い、いいよ……！　出すなら、私の膣内に……！　処女と一緒\nに……はじめての膣内出しも奪って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いっぱい、ザーメン出して……！　無責任に膣内出しして……赤ちゃん、孕\nませてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフ、フフフ……！　無責任って言うと……好きな人が相手なのに、なんだ\nかすごい不幸せなことみたいだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えっ……ちゃんと、責任は取るって……やっ……！　急にそんなこと言われ\nたら……お、おマンコが悦んで……んんっ……！　んふうううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！？　ザーメン注がれてるっ……！　私の子宮に、どぴゅど\nぴゅ出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ、熱いの……奥まで流れてきてるよぉ……ああっ……！　んっ、うふっ…\n…くっ、あああぁ……！　す、すごい嬉しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「このまま赤ちゃんできるなんて……不安なはずなのに……！　不幸なはずな\nのに……！　どうして、こんなに幸せなの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ……！　んああぁ……！　ひぐっ、うくううぅん……！　ダメっ……お\nマンコ、イッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「イクッ……！　イクッ……！　あっ、あんっ！　膣内出しされながら……赤\nちゃん孕まされながら、イクぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んぐっ……ふああっ……！　んっ、くふっ……はあ、あはあぁ……！　す、\nすごい……いっぱい……出してくれた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら……絶対妊娠してるね……フフフ……私もとうとう、お\n母さんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いっぱい……いろんな魔法を教えてあげないと……ああ、なにから教えよう\nかな……アレも、コレも……多すぎて迷っちゃうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「幸せそうだって……？　そ、そんなことないよ……！　不安だらけで……不\n幸だって思ってるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「じゃあ、もう一回セックスして……不安を和らげてあげるって……？　そ、\nそんな……イッたばかりなのに、二回戦だなんて……あああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「やっ、あふっ……！　んぐっ、っああぁ……！　おチンポ、カタいままで…\n…また、私のおマンコえぐってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「さっきより激しく、奥をトントンされてる……！　うぐっ、んんっ……！　\nザーメンがヌルヌルしてて……奥まで、簡単におチンポ届くぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あぅぅ……！　か、感じすぎちゃう……！　このままだと私……おチンポの\nことしか考えない、スケベな子になっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「魔法じゃなくて、エッチなことが得意だなんて……ふあああぁ……！　それ\n、すごく不幸だね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ねえ……！　私がエッチなこと大好きになっても……一緒に、居てくれる…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「スケベで……ずっとセックスしたがる、淫乱な魔女になっても……側に居て\nくれる……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「寝ても覚めても……ずっと子作りセックスばっかりする……そんな幸せと不\n幸せが入り混じるようなことになっても……愛してくれる……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああっ……！　そんな……応えるみたいに、ぎゅっと手を握るだなんてっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「好き……大好き……！　もう絶対に、離したりしないからね……！　ずっと\nこのまま、繋がっていさせて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「二人で、堕ちよ……？　魔女とか、人間とか……まどろっこしいこと、全部\n忘れて……二人で暮らそ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「たくさん子供を作って……私たち家族だけの世界で、生きていこ……！　大\n丈夫……どんな問題も、私の魔法で解決してあげるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……！　おチンポも悦んで、ビクビク暴れてるね……！　いいよ……\n出して……！　私たちの不幸せな未来に、応えて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「膣内でも膣外でも……！　どっちでもいいよ……！　私もイクから……！　\n一緒に、イッて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「たくさんイッて……壊れよ……！？　一緒に、不幸せな未来を作ろ……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ああっ……！　好きっ……好きぃ……！　幸せと不幸が入り混じるの……た\nまらないっ……！　あっ、あっ……！　イクッ……イクぅぅぅん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「くあああぁ……！　あっ、また……熱いザーメン、膣内に出されてるっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「お腹の中……苦しいぐらいにザーメンで溢れてて……！　あっ、んぐっ……\n！　これ。絶対に赤ちゃんできてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフ、フフフ……！　でも、まだだよ……！　もっと……もっとザーメン頂\n戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私の子宮が完全に精子で満ちるぐらい……いっぱい、膣内出しして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ひぐううぅ……！　あっ、あっ……！　気持ちいいっ……！　ザーメン出さ\nれるの……たまらないぃ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はあぁ……あああぁ……！　入りきらなかったザーメン……おマンコから溢\nれてきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……でも、問題ないよね……だって……これからは、ずっとエッチな\nことし続けるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ご飯のときも、お風呂のときも……一つに繋がりっぱなしな日々だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おマンコに飽きたら……お尻やお口でエッチさせてあげる……私の身体、全\n部使わせてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だから……もっと、堕ちよ……？　私と一緒に……幸せで、不幸せな日々を\n……ずーっと、送っていこうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ……あっ……！　おチンポ、抜けて……！　んっ、あふっ……！　ふぎ\nゅっ、んふううぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「熱いの……！　全身にかかってるっ……！　濃くてドロドロなザーメンで、\nマーキングされてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ああ……！　嬉しい……！　おマンコだけじゃなくて、身体の外まで染めら\nれるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こんなの、幸せすぎておかしくなっちゃう……！　おかしくなるって、不幸\nなことなのに……幸せだと思っちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ダメっ……！　理解が追い付かないよ……！　私、もう……\nイキすぎて、ダメになるっ……！　あっ、ああああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフフ……はじめてのセックスで、ここまで狂わされるなんて……思っても\nみなかったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「魔女にとって、エッチってすごく大事なことだったんだね……魔宴（サバト\n）の大切さが身に染みたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「どうしたの……？　さすがに二回連続で射精して、疲れちゃった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「なら、このまま……おマンコにおチンポ挿れたまま……眠っていいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00001801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それで、起きたらまたセックスしようね……これからずっと、幸せで不幸せ\nな生活を楽しもうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
