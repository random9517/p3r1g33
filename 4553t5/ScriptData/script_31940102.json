{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「どこだ？　どこに逃げた？　ワタクシの愛しい貴方……。ああ、そこで震え\nていたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「今夜はワタクシが訪ねてゆくから空けておけと命じておいたはずだろう。ま\nったく……貴方はいつまでも、ワタクシの物である自覚が足りない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「今日の予定を空けさせた理由？　ぷっ……ククク、ははは……！　それを聞\nくのか？　決まっている、この肉体の疼き、熱を取り去ってもらうためだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……なんだ？　嫌だとでも言うつもりか？　ははぁん……そうか。ワタクシ\nの威厳に怯え、勃起することすら出来なくなったか？　惨めなモノだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「良い良い。貴方は何もしなくても……。ぺろっ……♪　ワタクシが全部して\nやる……。黙って目を閉じ、身を任せよ……。んッ？　な、なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ！？　何か……今何かをワタクシの口に注ぎ込んで飲ませたな！？　何\nをした！　吐けっ……あ、あああ！　や、やめろ、羽交い絞めにするな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104106" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「うっ……うううっ……！　ちょ、調子に乗りおってぇ……？　ボ、ボニュー\nデマクール？　それは……あの、母乳が出るという薬ではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104107" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「な……なぜそんなものを飲ませた。そんなことをしなくとも、ワタクシは既\nに発情して……。うっ！？　ま、まずい……胸が、胸が熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「意識、が崩れる……。ああ……ッ、な、何もかもが曖昧に……。はぁっ……\nはぁ、はぁ……セ、セックスのことしか思い浮かばなく……なって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「くぅうう……！　ふぅうう……！　あ、貴方は知らないかもしれないが！　\nワタクシは魔力を使うと、それだけで身体が火照り、欲情する体質だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だからっ……ああ、その上こんな、媚薬のようなものを飲ませられたら……\n。常識も理性も粉みじんに吹き飛んでしまう……やめろ、やめろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ……。はぁっ、はぁ、はぁああ……！　全身が、もうあらゆる場所が…\n…熱くて熱くてたまらない……！　この始末、どうつけてくれる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104112" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ぅ……。う、ううう……！　た、頼む……限界だ！　ワタクシを、ワタ\nクシの身体を一刻も早く慰めてくれ……どんな風に扱ってもいいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104113" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「セックス……セックスをしないと、気が狂ってしまう……っ。はぁ、あああ\n……！　母乳が、母乳が胸に集まってくる……アソコが熟れて蜜が滴る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「おね……がいだ、ワタクシを……ワタクシを抱いて、くれ……。いいや、犯\nして……レイプしてくれぇ。ああっ、ああ、一刻を争うのだぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「セックス……セックス、交尾がしたい……！　母乳をぶちまけて、……あっ\n、おまんこを太いチンポでズコズコえぐられたい……。くぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっ！？　ううぅ……。な、なんだ？　急に後ろから優しく抱きしめて……\n。え……？　してくれるのか？　貴方が？　セックスを？　あ、ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104117" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019401_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ、い……いや……。そうだ。確かにワタクシはそれを望んでいる。のだが\n……、ぁ……ま、まだ……貴方に告げていない真実が１つ、ある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「わ……ワタクシ、は……その……。こんな年増になって、これだけ威厳あら\nたかに振る舞ってきておいてなんなのだが……その、未経験……で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ずっと、一人で昂る身体を抑えつけてきた。だから……セックスの知識はあ\nって、それに憧れてもいるが……。し、したことは……なくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……嫌ではないか？　と、年上のダークエルフが……。こんな熟女が、雌丸\n出しで迫ったあげく、しょ、処女……だなんて……。気持ち悪いか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……それでもいいのか？　あ、ああああ……♪　ありがとう……、ありがと\nう……！　それならば、早く助けてくれ。ずっと、ずっと我慢してきたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方の身体と、両手……そしてオチンポで、ワタクシの飢えを！　無限の渇\n望を満たしておくれ……！　んんっ……み、耳元で甘く囁くのはやめろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そん、なことをしなくても……。見てくれ、もう股のあたりがずぶ濡れで…\n…。大洪水になってしまっている。あ、愛液の量が多い方なのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「い、やぁ……♪　胸を、胸をまさぐるなぁ……っ。そんなことをされたら…\n…あっ♪　すぐに出るっ、母乳出るっ、出るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あ～～～～～っ♪　ああああっ……！　いやっ、あぁ……♪　ああっ、母乳\nがはしたないくらいに飛び出して……！　あっあっあっあぁ～～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あたりそこらじゅうを濡らして……！　あぁあっ♪　こ、これを見ればわか\nるだろう、ワタクシの肉体はもうどこもかしこも熟しているぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁんんん……！　ぴちゃぴちゃと……レロレロと、あ、貴方の舌がワタク\nシの首筋を這い回って……ああ、ね、熱が出そうだぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「や……優しくなどしなくていい……！　もう、もう……オマンコがきゅうき\nゅうとヒクついておかしくなりそうだ……。入れて、入れてほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっ……チンポを入り口にあてがって……。そのまま！　そのまま腰を突き\n出して……！　あぁっ！？　おほっ、これが……これがセックス、挿入っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっ！？　あぁ、そ、想像とまるで違う……！　こ、こんなにも！？　こん\nなにもヌルヌルして……！　あっ！？　あっあっあっ……中が広がって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぅっ！　ま……まだ、オチンポが入った快感に慣れていないのだっ……！\n　まっ……、待ってくれ、動くのはまだ……！　あっ！　あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そんなっ、身勝手なピストンをして……！　あぁッ！　チンポを、チンポを\nいきなり膣奥に叩きつけ、子宮を突き上げて……ああ、凄まじい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふぅううっ！　犯してくれとは言った、が……！　ああっ、初めてだとい\nうのに……最初からトップスピードで……あ！　あ、あ、あ、あッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ま……待ってくれ、痛くはない……気持ちいい、気持ちいひ……っ。だが、\nだが……避妊もなしに挿入したら、……あっ、赤子が、赤子が出来るっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「赤ちゃん、が出来てしまう……あぁ♪　あっ、だめ、だめだぁ……。ああっ\n……！　赤ちゃん出来たら、い、妹たちに、女王にバレて……ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「な、なんだ？　今、チンポが膨らんで……？　も、もしや射精するつもりか\n！？　だめだっ……膣内射精は、孕む……孕むから、あぁ！　孕むぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んひぃいっ……！　ひぃいっ……ああ……！　ああっ……これが、これが膣\n内射精なのか……！？　あっ……注がれている、はっきりとわかるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「熱い濁流が、ワタクシの子宮めがけて押し寄せてきて……あっ♪　い、今…\n…子宮の中に侵入してきた……！　あっ♪　これが、本気のセックス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「うぁ……ああっ、あぁああ……っ！　いけないこと、なのに……バレてはな\nらぬのに、なぜだ！　身体が、肉体が狂喜乱舞しているぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「精液っ、精液を粘膜に注ぎ込まれることが何よりも……嬉しい、幸福で……\nやめてほしくない……！　ワタクシはどうにかなってしまったのかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「え？　嫌なら抜く？　今すぐ外出しにシフトする！？　い、いやだ……この\nまま、このまま最後の一滴まで絞り出してくれ……！　あっあっあぁあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「一番奥を塞いだまま……ッ、こぼれぬようにチンポでオマンコに栓をして…\n…！　ドク、ドクと……あぁ、あはぁああ……気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「セックス……セックス、中出し交尾……。信じられないくらいに良かった…\n…。ああ……♪　一生忘れられぬ快感で、壊されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……んっ？　どうせなら、全てのセックスを経験してみろとは……どういう\nことだ？　セックスなら今、オマンコで成し遂げたではないか……。え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「アナル……？　あなるとは……。あっ、もしや……尻の穴でもすると申した\nのか？　そ、それはワタクシにはまだ早い……。あっ！　む、無理だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これだけ肉体が男を求め、敏感になっている時ならば大丈夫？　え……、あ\n……で、でも……。あっ！　あふっ、ご、強引に入れてはならぬ、ならぬ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふぁああああっ……！？　ああっ！？　ウ、ウソだ……！　あっ……、あ\nぁ、そ、そうか……。膣内射精の精液が、チンポに残っていたからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それを潤滑油の代わりにして……アナルに！　んぁあああっ……し、信じら\nれぬ！　ワタクシの、クロートーの尻の穴に男根、が……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ほ、誇り高きダークエルフにとっての屈辱……のはず、なのに……んうう…\n…！　身体にこみあがってくるのは……あっ、あっ、か、快感……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワ、ワタクシは……尻の穴にチンポを挿入されて感じているのか……っ。み\n……見ないでくれ、恥ずかしい……あぁ、こんな、こんな……ああっ」", "NORMAL" ]},
