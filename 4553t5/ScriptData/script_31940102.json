		{"command":[ "SETIMAGE", "0", "still_00019401_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ちょ……腸内でビクつくペニスを、チンポを完全に受け入れてしまった……\n！　ワタクシは……ワタクシは、これを知る前には戻れない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んふ……！　ああ、大丈夫、大丈夫だ……。ちゃんと精液は、尻穴で絞り取\nってやるから……。ふんっ……！　んんんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あはぁああ……♪　ち……力を込めると、精液がドッと撃ち出される……ぅ\n。ワタクシのお腹はもう、精液でタプタプに満たされてしまったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……はぁぁ……♪　はぁ、はぁ、はぁ、ああああ……♪　処女を捧げるだけ\nだったはず、が……後ろの穴まで奪われるとは……笑止千万」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019401_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「全てを知り尽くしたと豪語していたワタクシにも、まだまだ知らないことは\nある……のだな。とても……とても勉強になった……。そして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これからも、貴方にはこうして２つの穴を……。オマンコと尻穴を、両方満\nたしてもらわなければ……。はぁ、はぁ、頼りにしているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシは……もう貴方の男根でなければ嫌なのだ……。これからも、ワタ\nクシと共に悠久の時間を刻んでおくれ……。淫らな時を……♪」", "NORMAL" ]},
