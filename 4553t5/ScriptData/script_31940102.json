		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぁッ……♪　んぷっ……んんむっ……ううううう……♪　な、生意気なこ\nとを言ったから罰を与えてくださったのです、か……！　違う……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「尻穴で屈服して、精液をねだるワタクシの顔がエロかったから……顔にもた\nっぷり従属の証を注いでやりたかった？　っあああ、それなら良かった！」", "NORMAL" ]},
