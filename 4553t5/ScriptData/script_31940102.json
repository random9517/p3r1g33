		{"command":[ "SETIMAGE", "0", "still_00019401_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ぜ、絶対に埋まらないと……鎮まらないと思っていた肉欲が、こんなに簡単\nに貴方のオチンポで癒され、治ってしまうなんて……♪」", "NORMAL" ]},
