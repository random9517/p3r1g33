		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あぐっ……♪　んぐぅうっ……ふぅううッ……！　あっ、あぁ……！　尻穴\nが、尻穴が排泄するための穴でなくなって……性器に変わっていくぅ」", "NORMAL" ]},
