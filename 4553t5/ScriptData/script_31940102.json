		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「どうか……尻の奥に出してぇええ！　っん！？　ま、待って……あぁっ！　\n抜かないで、いやだっ……ああっ！　うううう～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「顔っ……んぷっ！？　んんっ……！　それに胸に射精……！？　ど、どうし\nて……！　あっ！　ワ、ワタクシが卑しくも命令をしたからっ……？」", "NORMAL" ]},
