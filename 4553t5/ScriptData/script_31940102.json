		{"command":[ "SETIMAGE", "0", "still_00019401_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はいっ……はい……♪　ワタクシは、どこに出されても……射精精液をあり\nがたがる変態ダークエルフです♪　かけて……ありったけかけて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あふっ♪　あぁあっ……あ～～～～♪　生臭くて、トロみがあって……最高\nのご馳走です。感謝をしながらいただきます……。ンンン……♪」", "NORMAL" ]},
