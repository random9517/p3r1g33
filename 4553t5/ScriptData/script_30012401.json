		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……やっと二人きりになったな……ずっと待ち遠しかったぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403101" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今日一日、ずっと精液を飲みたくて飲みたくて……それを我慢し続けたんだ\nからな……喉がカラカラだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、服を脱ぐのももどかしい……とにかく早くベッドに……ダメだ……我\n慢できない……早くオチンポを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……！　おお……ふふっ、これはこれは……私ばかり気が逸ってるのだ\nと思っていたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000124_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このガチガチの勃起オチンポ……ふふ……あなたも、ずっと楽しみにしてい\nたと……そういう訳だな？　んっ、くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……このオスのにおい……んっ、こうして吸い込むだけで顔がにやけて\nしまいそうだ……はふぅ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、ちゅぷっ……んっ、汗臭い……あぁ、いや、決して不快では\nないぞ。この蒸れた加減が、またいいのだ……これでいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、ふぅぅ……ダメだ……待ちきれない……オチンポのにおいだ\nけで、発情が深まってしまう……はっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……指が勝手にオマンコに伸びて……んっ、中がグチョグチョになって\nいる……聞こえるか？　このくちゅくちゅという音……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポのにおいで発情して……オマンコから恥ずかしい汁が溢れ\n出しているんだ……んっ、はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ここの……おっぱいも……あっ、ウズウズして……ちょっと指で弄ると……\nほら……乳首がどんどん立って来ている……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……あなたのオチンポも一段と反り返って……私の浅ましい姿で興奮し\nたんだな……？　分かっている……ちゃんと責任は取るからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ、んっ、くぷぷぅぅ……んちゅぷっ、りゅぷっ、んじゅっ、じゅぽっ\n、じゅぱっ、んじゅぷっ、んふっ、んりゅぷぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんむ……いきなり、贅沢に頬張ってひまった……んふぅ……おいひぃ…\n…蒸れたオチンポの味ぃ……最高らぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、くぷっ、れろ、りゅぷ……待っててくれ……まずは、ちゅぷっ、亀頭\nから……カリのところから……れろ、満遍なくしゃぶっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、んれるぅ……じゅぷっ、れろぉ……えろ、れろぉ……んふぅ……舌が\n見えるか？　ふふ……ちゃんとオチンポに押し付けるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んりゅぅ……んっ、こうひて……唾液を乗せて……ペロペロひてぇ……ふふ\nっ、可愛らしく震えているな……じゃあ、今度は裏筋を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「れる、りゅぷっ、える……れるぅぅ……どうだ……んっ、継ぎ目の辺りを舐\nめられるの……気持ちいいらろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……私も……今、同じような場所を一緒に触ってる……ちゅぷっ\n……割れ目に指を入れて……ちょうど力が抜ける……敏感な所だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「自分の恥ずかしいオマンコを弄りながら……夢中でオチンポをしゃぶって…\n…はぁぁ……興奮する……もっと味わいたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ちゅぷぅぅぅ……んふっ……！　りゅぽっ、くぷっ、んじゅぷっ\n……じゅるるっ……んぁっ、ふぐっ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、ふぁぁ……口の中がオチンポれいっぱいら……じゅぷっ、エッチな\n味が……広がるぅ……りゅぽ、じゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くぷぅっ、ふぶっ、むぐっ、んぁぷっ、おぷっ、んりゅぷっ……！　んっ、\nおいひぃ……オチンポの味……好きら……大好きらぁ……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ずっと舐めてたい……じゅるっ、くぷっ、れろぉんっ、ぺちゃっ……この尿\n道口のとこ……んっ、えろっ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、ほじくられるの……大丈夫か？　痛くしてないつもりだが……んふ\nぅ……敏感なところだからな……慎重に……んちゅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……！　あぁ……ビクビクしてる……んふっ、ちゃんと気持ちいいんだ\nな……？　よし……それなら、もっと……んじゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、あっ、はぁっ、んくっ、あっ、はっ……あぁ……指の方も止\nまらない……オマンコジンジンして……あっ、ちゅぷっ、んむっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「触りたい……？　ふふっ、そうだな……それは、また後で……今はとにかく\n、リラックスして……私の口を楽しんで欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ……もっと、強く吸っていいなら……していくぞっ、じゅるっ、んじゅ\nっ、ずずっ、んふぅっ、じゅるっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぁ、んっ、オチンポから……汁が出て来たぞ……ちゅるっ、ん\nふっ、ちょっと塩気のある……先走りだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んぱっ、ふぁぁ……これを味わうだけで顔が緩んでしまう……り\nゅぱ……じゅぷっ、れろ、ぺろ……えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁん……んふっ、あぁ……今、すごい勢いで……ザーメンが発射する準備\nを整えているんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「この張り詰めたオチンポから……もうすぐビュクビュクって……あぁ、んっ\n、待ちきれない……んふっ、もっと咥えるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「くぽっ、じゅぽっ、んっ、さあ……私の方はいつでもいいろっ……あなたの\n……濃くて栄養たっぷりのオチンポミルクぅ……飲ませてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んじゅぷっ、じゅるるるっ……このまま……直接っ……喉の奥に\nぃ、流し込んでぇっ……じゅぷっ、んじゅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぶっ……！　んぁぷっ、ふぐっ、んはっ、あっ……れたっ……濃いの、ん\nぐっ、射精……ひてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んっく……こくっ、んふうぅっ、あぁ……美味しい……私の力の源に\nなる……ザーメン……んっ、好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、はぁ、はふっ、あぁ……一気に飲み干してしまった……私とした\nことが、欲望を抑えきれずに……ちゅぱっ、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁ……でも、本当に美味しかった……んちゅぷっ、ぴちゃ…\n…まだ、少し味が残ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、はふっ……気持ちよかったか？　それなら良かった……サキュバス\nの面目躍如だな……ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……さて……お掃除も忘れないようにと思ったのだが……このオチン\nポは、まだまだ精液を出し足りないみたいだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……奇遇だな。実は、私ももっと飲みたいと思っていたところなんだ…\n…それなら、もう遠慮することもあるまい……んちゅぷぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……んっ、りゅぷっ……！　あぁ……このままフェラチオを続けるぞ…\n…私の口マンコ……存分に楽しんでくれ……りゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んじゅぷっ、んっ、りゅぷっ、ぴちゃ、んちゅぷっ、んっ、精液の味が……\n濃く残ってるから……さっき以上に美味しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「口の中からよだれが溢れて止まらなくなりそうら……じゅるるっ、んふっ、\nこのお行儀悪く頬張る感じがたまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「むふぅ……んっ、あぁ……すごい……オマンコもジンジンしている……んり\nゅぷっ、いっぱいザーメンを飲んで、身体が疼いてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、下の口のよだれも……トロトロに溢れて……はぁぅっ……感じ\nすぎてるぅ……ちゅぱっ、ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、でも……ここも……オチンポからのよだれも……んふぅ……すぐに\n漏れて来るんじゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと出しやすくなるように……キンタマもマッサージしよう……ほぉら…\n…ここだ……れろ、ふふ……弱いだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん、優しくさすって……ぐにぐに転がして……あふっ、オチンポがビクビク\n跳ねてる……ダメだぞ……ちゃんと捕まえるからな……はむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、くぱっ、りゅぷっ……んふぅ……咥えたままぁ……マッサージぃ\n……むぐぅっ、りゅぷっ、もみゅ……もみゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ……今……色っぽい吐息が漏れたぞ……？　んふっ、男でも……やは\nり弱い所を続けてされると余裕がなくなるんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、その声……もっと聞かせて欲しい……んっ、あっ、ふっ……私も\n……感じるままに……声を、出す……からぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、くぷっ、じゅぷっ……ぷぁっ、はぁ……んっ、あぁ……オチン\nポ美味しい……やっぱりこの味が……大好きだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、えろ……んちゅぷっ……今度出すときは……私も一緒にイクからな…\n…あぁ、んっ、オマンコが……ジンジンしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、見えるか？　指に……汁が絡んでくちゅくちゅしてるとこぉ…\n…もうすぐイキそうになってるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、じゅぷっ……オチンポも、もうすぐだろう……？　んじゅぱ\nっ、分かっている……この震え……もうすぐだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、思いっきり出していいからな……じゅぱっ、ちゅぷっ……我慢なん\nかさせないぞ……じゅぽっ、んくぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぉら……全部ぶち撒けてひまえ……ありったけのオチンポミルク……ドピ\nュドピュ出してっ……んじゅぷっ、ちゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わらひもイクっ……んふぅっ、オチンポおしゃぶりしながらっ、オマンコっ\n……んんっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぶぅっ！　んっ、んぐっ、むぐぅっ、れたっ……またっ……んっ、濃いの\n……れたぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こくっ、んくっ、ちゅぷっ、んはぁ……ダメだ……病みつきになる……こ\nの味ぃ……おいひぃ……チンポミルク好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、オマンコ痺れてるぅ……はぁ、ちゅぱっ、こくっ……んっ\n、はふぅ……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、んぱっ……はぁ、んちゅぷっ……まだ奥に残ってるな……？　待って\nろ、一気に吸い出すから……んちゅっ、ちゅぷぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、終わったか……あぁ、たっぷりご馳走になった……こんなに気\n持ちいいオナニーをしたのも久しぶりだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「っと……ちゃんとお掃除を忘れてはいかんな。ちゅるっ、んちゅぅぅっ、ぺ\nろ……オチンポ……綺麗にするからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、ぴちゃ……んふっ、ここにも精液が残ってた……ちゅぱ、んちゅっ…\n…うん、これでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さて……んふっ、たっぷりと栄養を摂取したところで……身体がツヤツヤし\nてきた……ふふっ、やっぱり新鮮な精液に限るな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「というわけで……軽く一休みしたら、このオチンポにはもう一働きしてもら\nわなくてはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……まだまだ夜は長い。今日はお泊まりになっているし……私の腰がガ\nクガクになるまで……期待しているぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ！　はぷっ……あぁっ、顔にっ、いっぱいっ……ぶっかけっ……され\nてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、あぁ、掛けてくれぇ……チンポミルクぅ……あなたの濃いので、\nいっぱいマーキングして……においを染み付かせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、はぁぁ……んっ、２発目なのに濃い……味も好みで……んふぅ…\n…浴びながらオマンコ弄るの気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁん……れろ、ぺろ……んふっ、直接飲むのもいいが……こうし\nて、ついた精液を舐め取るのも乙なものだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷ……あぁ、止まったか……んふ、満足だ……オナニーも気持\nちよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000124_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「後は……オチンポを清めなくてはな……少し待っててくれ……ちゅぷ、ぴち\nゃ、んちゅっ、ちゅぷぅぅ……んっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、これで大丈夫ではないかな。ふふ……まだ少し勃起したままだな……\n本当に逞しいオチンポだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私もたっぷり精液を飲んで、かなりのエネルギーを貰ったな。サキュバス冥\n利に尽きるというものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「という訳で……一息ついたら、また続きといこうか。もちろん、これで終わ\nるオチンポじゃないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……まだまだ夜は長い。今日はお泊まりになっているし……私の腰がガ\nクガクになるまで……期待しているぞ？」", "NORMAL" ]},
