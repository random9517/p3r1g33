		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかった！　行くぞ、ドラグソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザーの号令に、ドラグソードが咆哮で応え巨大な剣を構える。", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0094" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「月龍剣！　遠点新月斬り！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090113010002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「月龍剣！　遠点新月斬り！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00000201_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00000501_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00001302_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、ドラグソードが剣を一気に振り下ろすと、刀身からまばゆいエネルギ\nーの塊が放たれた！", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「あああああっ！　うわぁああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010113010003" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのエネルギーをまともに受けた円盤女は悲鳴を上げ――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……消えた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「やったのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いや、撤退しただけだと思う。でも、あれだけのダメージを与えたんだし当\n分は出てこられないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「君たち、幸運だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助かったのか、俺たち……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そのようだ……とにかく、礼を言っておこう。おかげで命拾いした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090113010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そうね、思いっきり感謝してくれていいわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか。まあ……それはさておきだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「強いな、貴様たち……どこかの組織の者か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113010003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ブラックメルヘン。九姉妹（ナイン・シスターズ）のメンバーだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「九姉妹（ナイン・シスターズ）の！？　それにしちゃ、知らない顔が多いね\nえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ブラックメルヘンは『秘密作戦』に従事しているため、連絡不能と聞いてい\nたが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「簡単に説明すると、襲来者（インベーダー）とあの円盤女たちが、僕らの本\n拠地にちょっかいを出してきてね。いろいろ大変だったんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なるほど……そんな事情があったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「別次元の学園長が、あんな姿になってたとはねえ……ボクの優秀な頭脳でも\n、さすがにアレは想像できなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そ、その話はまずいですって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113010001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうかしたのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「い、いえ！　なんでもないです！　とにかく私たち、あの円盤の人とは何度\nも戦っていますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「それで攻略法もわかってたってわけ！　すごいでしょ？　尊敬してもいいの\nよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010113010002" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか。いや、あの戦いぶりには、素直に敬意を表したいと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090113010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「でしょ？　私たちが帰って来たからには、もうなにも心配ないわ！　襲来者\n（インベーダー）なんて、チョチョイのホイよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010113010003" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まあ、この子の言うことはともかく。ようやく本来の次元に戻ってこられた\nことだし、以後は九姉妹（ナイン・シスターズ）の一員として――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113010003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ＥＤＯとの共闘体制に復帰させてもらう。今度ともよろしく頼む、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113010004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当か！？　そりゃ助かる！　こちらこそよろしく頼むぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この強い連中が味方に付いてくれるのか……これからの戦い、少しは希望が持\nてるかもしれないな。襲来者（インベーダー）を追い出して、そして……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113010004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナルバース女王の……ルナテミスの母親の仇を、とってやれるかも知れない\n！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……と、俺はこのとき、本気でそう思っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}