		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「チャンスである！　あのロボに攻撃命令を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113010001" ]},
