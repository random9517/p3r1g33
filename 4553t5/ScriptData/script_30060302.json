{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「や、やだぁっ……最強になったはずなのに、ダイヤナちゃん……ムーンナイ\nトちゃんなんかに捕まって……ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「イ、イタズラはここまでよ……！　これ以上しないなら、許してあげるけど\n……指一本でもあたしに触れたら許さないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「叩きのめしちゃうんだから！　だ……だから離して……解放してぇ……。こ\nんな格好ひどすぎるわ、お股丸出しにされて拘束だなんて……卑怯よぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ねえ！　聞いてるの！？　って……、ぁ……な、なあに……？　ダイヤ\nナちゃんのオマンコ、まじまじと見つめて……。い、いやぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「か、顔を近づけないで！　息がかかるのよぉ！　あっ……ダメ、匂い嗅いじ\nゃイヤ……！　あっ、ぁっ……そんなにじっくり観察するなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そんな風に見てたって、何にもないわよぉ……。え？　ピンクで、綺麗で、\n美味しそう？　やっ……。ヘンな目で見ないでよ、こ、困るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……はぁっ……。はぁっ……。な、なんだか妙な気分になってきちゃう……\n。視線を感じるところが熱くて……ジンジンして……。はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ！　愛液が……エッチなおツユが垂れていっちゃう……。あぁん、見な\nいでぇ……！　オマンコ凝視されたら、あたし……あたしぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひっぅっ！？　きゃぁんんっ！　な、何っ……なによぉ！？　突然お股に顔\nを突っ込んで……！　あっ！　お、オマンコの調査……！？　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だ、だめよそんなのっ……！　んぁああっ！　お口を割れ目につけないでっ\n！　舌でぺろぺろしちゃだめぇ！　ク、クンニなんて絶対だめぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……んっ……！　ど、どんなに舐めたって、今のあたしが……シルバスター\nダイヤナちゃんが感じて喘いだりするわけないでしょ……？　ん、く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「へ、平気だもん……。これくらい……今のあたしは最強、だから……。んん\n……！　やっ！　舌先……中にもぐりこませないで！　やぁっ、ンンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「舌先でオマンコの中っ……粘膜の敏感なところこすらないでぇ……！　あっ\n！　あっあっあっ、む、無理ぃ……感じちゃう、ぬ、濡れちゃうぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「すっごく我慢してるのにぃ……！　き、気持ち良すぎておかしくなっちゃい\nそう、喘ぎ声出ちゃう……！　あんっ、あんっ……あぁんっ、はぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ね、え……ねえっ、き、聞こえてるんでしょ……ダイヤナちゃんの声。だっ\nたら……ちょ、ちょっとだけ止めて、クンニ……やめて、もうしないでぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このままレロレロされ続けたら……あたし……！　んんんぁっ！　ますます\n強くするのだめぇ！　ぢゅるぢゅるおツユすすらないで、……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んッ！？　ふぁああああああ♪　ああああ♪　ダメっ、イッちゃ……あああ\nあっ！　敏感なとこっ、舐め舐めされてイッちゃうぅうう……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んはぁああっ！　ああ～っ！　ああああっ！　ひぁあああっ♪　恥ずかしい\nお潮がびゅっびゅって出ちゃうのっ、愛液いっぱい出るっ、あああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふぁあああ♪　気持ちいいいい……っ！　オマンコちゅぱちゅぱされるの\n好きぃいいっ♪　あぁっ、イクの止まらないぃ……いやぁああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　あっぁっ……♪　うそぉお♪　あたしヒーローになったの\nに、クンニされたらすぐイッちゃって……んぁあああ……♪　ひぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、もうダ……メ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ンッ！？　ふぅうううっ！？　や、やだっ、今意識を失いかけて……！　失\n神してたら股間にぶっといオチンポが入ってきて……あっあっあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「い、意識が呼び戻されちゃったけど……！　今はそれより……あっ！　オチ\nンチン！　オチンチンずぬううって一番奥に突き刺さって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「これは……限度を超えてるわ！　ムーンナイトちゃんっ……！　正義のシル\nバスターを生のオチンチンでレイプするなんてありえないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「抜いて……今すぐ！　あッ……♪　さ、さすがは悪の組織の構成員ねっ……\n！　ゴムもつけずに、ダイヤナちゃんのオマンコを味わって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「今すぐぎったぎたのめっためたにしてあげるんだからぁっ……！　お仕置き\nよ！　って……んんんん！？　どうして腰を使うのぉっ、深いぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……ッぁっ♪　あぁんっ！　き、亀頭を……！　オチンチンの先っちょをぐ\nりぐり奥に押し当ててくるぅ……！　あっ、ピストンも速く、なって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやぁあっ、あぁっ、あぁっ……あぁあっ♪　ぐちゅぐちゅやらしい音が聞\nこえてくるぅ……！　中、えぐられて……犯されてすごく濡れちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あたし……！　感じてるの！？　卑劣な挿入されて……あぁあっ、甘い\n声あげて、オマンコの奥まで受け入れちゃって……っ。んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やめてほしくなくて、腰、揺らしちゃってるぅ……。あっ……、あっ、だめ\n、だめよぉ……！　屈しちゃだめ、オチンチンなんかにぃい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だめなのに……なんでこんなに気持ちいいの、ぉ……！　あっ♪　このオチ\nンチン、あたし好みのカタチで……長くてぇ、子宮口に当たるのよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　強引にズンズン来るところも好きぃ……っ！　って、屈してない\nからぁっ！　平気だもん、こんなの……。んっ？　な、何か言った？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「な、かだし……？　ひゃんっ！？　中出しするって……本気！？　だめっ…\n…今子宮が、完全に受け入れ体制に入っちゃってるの！　だからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このまま中に出されたら妊娠しちゃう……！　あ、赤ちゃんできちゃうっ…\n…そんなのだめ！　ダイヤナちゃんは愛する人の赤ちゃんじゃないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「らぶらぶなだんな様の赤ちゃんじゃないと嫌なのぉおっ！　あぅうっ♪　お\n、お願いぃ……！　出さないでぇ、中はダメ、外に出して……あっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダメって言ってるのにぃいいいい～～～っ！　あああああっ！　やぁだぁあ\nああ～っ！　あああんっ！　熱いの中で出てるっ、出てるぅうんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひぃんんっ！　あぁっ、あああっ……！　またイカされちゃうっ……イクッ\n、イクぅう……！　オマンコの中が真っ白に染められてく……ぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたし、あたし……！　ザーメンにオマンコを支配され、て……快感で言う\nこと聞かされちゃって……こんなの正義の味方って名乗れないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも……負けないんだからっ……！　いっくら精液を注がれたって、ダイヤ\nナちゃんは最後には勝つのっ！　卑劣な罠になんか負けないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……あっ！？　お、お腹に力を入れたらオチンチンを刺激しちゃったぁ。ま\nたビュルッて……ドクドクって精子流れ込んでく、るぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んはぁあ……お腹いっぱい……。じゃなかった、さ、さんざん嬲ってくれち\nゃったじゃない。もう満足したでしょ？　今すぐに解放して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なによ……。本当は気持ち良すぎてもっとして欲しいんだろう、ですって？\n　もっとたくさんザーメンが欲しいんだろうって？　……そ、そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えっと、だ、ダイヤナちゃんはそんなことこれっぽっちも思ってな……い、\nう、うん、そうよ。そんなことまったく考えてないし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そ、そりゃあ確かに気持ち良かった……かもしれないけど！　敵に媚びると\nかありえないし！　……敵じゃなかったら……してほしい、けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「う……。あ、あのね……？　軽蔑しないで聞いてくれる……？　あとちょっ\nとだけ……し、してほしい、かも。誰にも言わないって約束するなら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「したい……かな。ん……。それには条件がある？　お……おねだりしろ？　\nしたくなるように？　ん、んんんっ、あ、足元見てくれちゃってぇええ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……し、したいの。もう一度オマンコにその強いオチンチン入れて欲しい…\n…。それで、ぐちゃぐちゃになるまで犯してもらって、最後には……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんの欲しがりメスオマンコに赤ちゃんの種！　子種、精液……\nっ、ザーメンどぴゅどぴゅ注入してほしいっ！　中出し、中出しして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっあぁああんっ♪　オチンチンっ……またピストンしてくれるのねぇ♪　\nうれしいぃっ……あっあっ♪　一回目より太くなってるぅう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたが悪いのよぉっ……！　ダイヤナちゃんの気持ちいいところばっかり\nこすって、えぐって、強制的に感じさせてきたんだからぁああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　あんっ、あんあんっ♪　あなたのオチンポ美味しすぎるのよぉっ\n……！　あぁ♪　それなのにじれったくしたり、いきなり突き上げたりぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「テクニシャンで、すっごく素敵……っ！　はぁああっ♪　気持ち、いい……\n気持ちイイ♪　中出し直後の即レイプ気持ちイイ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんも自然に腰を振っちゃう、お尻フリフリして誘っちゃうっ…\n…！　もうダメ、正義の味方するよりエッチの方が気持ちいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁあっ……！　あひぃいっ、ひぃんっ♪　ひぃいっ……いいのっ、夢中に\nなっちゃうっ……！　憎い敵に犯されるのってすごく気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　あぁんっ、あんっ、あぁんんっ！　あなたも同じでしょおっ？\n　ダイヤナちゃんのキツキツオマンコから離れられないのよねっ、はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いくらザーメンでヌルヌルにしたって、あたしのオマンコは膣圧が強いんだ\nからぁ……！　それでいてうねって、まとわりついて……あっあっあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「とにかくオチンチンから精液絞り取るのに最適なのぉ……！　はぁっ♪　き\nゅっきゅってたくさん締めてあげる……♪　あはっ、ピクッてなった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ね……今度は一緒にイキましょうね……♪　あぁ♪　いけないのに♪　こん\nな風に敵さんと濃厚に絡み合うなんて良くないのに……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「どうしてもやめたくないのぉっ……！　はぁぁっ、突いて……突き上げて、\n子宮の入口をくちゅくちゅ刺激してぇん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「一番イイタイミング、で……♪　一緒にイクのぉっ……！　あッあっあっ♪\n　オマンコ受け入れ態勢OKよ……！　来てっ、きてきてぇえ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ♪　ひぃいいいいっ♪　ひぃいいんっ♪　来たわっ、新鮮なミルクっ…\n…！　できたてザーメンがあたしの中に……ああぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「シルバスターなダイヤナちゃんにっ♪　思う存分白濁液を注ぎ込む気分はど\nうっ？　あッ……！　正義の味方を屈服させて、支配して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「自分の色に染め上げちゃうなんて……まるで全ての男の子の夢みたいよぉ♪\n　あぁんんっ、ダイヤナちゃんも気持ちいい……！　ずっとイクぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　とんでもない量出してくれちゃって……♪　でもまだ終わら\nせなぁい……もっともっと絞り取るのぉ……！　締めるわよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　ふぅうっ、んん～～～っ♪　熱くてピチピチのザーメン\n……ヒーローマンコで吸い上げるのぉ……！　あぁんっ、んん～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん、はぁあああ～～～……♪　最後まで拒むつもりだったのにぃ……結局お\nいしくザーメンごくごく飲み干しちゃったぁ……。お腹いっぱいよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなに気持ち良くなっちゃうんなら、捕まるのも悪くないかもぉ……。あ\n、これはもちろんオフレコよぉ？　でも、見てぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんの正義オマンコの中に、うようよ精子が泳いでるわ……。こ\nれ、すごぉくイキが良くて、元気で……粘膜にべったり貼りついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もう絶対ダイヤナちゃんを孕ませるつもりよ……。わかるでしょ？　この量\n、この熱さ、この濃い臭いぃ……栄養たっぷりの赤ちゃんの種……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんな快感知っちゃったら、オチない女ヒーローなんて一人もいないわ…\n…♪　あなたって、と～っても悪いヒトなのね……最高よ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁああっ♪　イッちゃうぅう……！　ってあらっ！？　な、なぁに！？　\nオチンチン逃げていっちゃって……あ～ん待ってぇ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オマンコはそっちじゃないわ、ここよぉ……！　んッ！？　んんんっ……！\n　もぉおっ、どうして外に出すの……もったいなぁいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　んぁああ……♪　ダイヤナちゃんのお顔にも、お腹にもおっぱ\nいにも……精子が飛び散って、エッチ……♪　いやぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000603_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのこと、ドロドロに汚して自分の色に染めたいだなんてぇ…\n…！　あっあっ♪　その執着心、嫌いじゃないわよぉ……！　でもぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「かけすぎぃい……！　二回目なのにこんなにイカ臭い精子どぴゅどぴゅぶっ\nかけるなんて、あたしのオマンコに興奮しすぎだからぁっ！　あ～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダメぇええ♪　ダイヤナちゃんの美貌に精液ぶちまけるなんてぇ……！　熱\nいのっ、ザーメンシャワーでベタベタになっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁああああ……♪　も、もう全部出た……？　出せたぁ……？　\n精液、あのままオマンコの奥にドクドク注ぎ込んでも良かったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「どうして外に出そうと思ったのぉ……？　でも……。はぁ♪　はぁっ♪　外\n出しぶっかけザーメンシャワーって、凌辱されてる感があってイイ、かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「どうしてもダイヤナちゃんを自分の精液でドロドロにしたかったんでしょ？\n　自分のモノだって、独り占めの証……つけたかったのよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「フフッ♪　どうしようもないドスケベなんだから……♪　いいわよ、また証\n……つけたくなったら襲いにきてね♪　待ってるわ……♪」", "NORMAL" ]},
