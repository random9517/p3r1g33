{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0002" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_006" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「…………さて、と」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "PLAYVOICE", "007_010101110001" ]},
        {"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "地球との通信を終えた女王は、普段の様子とは異なる訝しげな表情を浮　\nかべていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "お付きのピースムーン達もめったにおきない現象に対し、何事かとざわざわし　\n始める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "部下の様子に気づいた女王は片手を軽く振りながら人払いの仕草を見せた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「妾は疲れたのでしばらく休む。一人にするのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "いつものように振る舞う女王の様子に安堵したピースムーンたち。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "だが、それは自分の内心を悟られぬよう、無理をして振る舞っていることに　\nこの時点で気づいた部下は誰一人いなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はっ。それでは女王陛下、失礼いたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "008_090101110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETTEXT", "経験上、こういう雰囲気の女王に目をつけられたらろくなことはない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ピースムーン達は我先にと出口へ足を運ぶ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女王ルナルバース１３世の指示で、お付きのピースムーンたちは全員玉座の間を　\n退去してしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "後に残ったのは閑散とした大広間と女王のみ。普段よりもひときわ静かな空間が　\n広がっている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女王は誰もいない空間を一時見つめた後、玉座のひじ掛けの裏にある隠しスイッ　\nチを押した。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "すると、玉座の背後の空間から重厚な機械音が鳴り響く。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……行ってみるかの。たまにはの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "女王は玉座から立ち上がると、裏に開いた秘密の入り口へと入っていく。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "秘密の入り口の中にあるのは、彼女以外誰も存在を知らないエレベーターだっ　\nた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "エレベーターに乗り込んだ女王は操作パネルに何らかの数列を打ち込み、秘密　\nの昇降機を作動させる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "操作パネルに表示された階数は「B666」、それはすなわち、この宮殿の地下深　\nくには何かが眠っていることを示唆している。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "およそ数千メートルほどの距離を降下することになるわりには、あっというまに　\n目的の階に到着するエレベーター。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "Ｇがかかるほどの高速移動したような負荷は一切みられない。そこにはグレート　\nルナリアムの叡智を秘めたテクノロジーが存在するというのだろうか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0022" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "思案げな女王を乗せたエレベーターは月面の地下深く潜り、女王を広大な地下　\n通路へと導いた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "広い通路には巨大な柱が立ち並び、ここが地中深くだと思えないほど煌々と明る　\nく照らされている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "本人の吐息や足音以外、物音一つしないだだっぴろい空間を迷いなく突き進む　\n女王。どうやら彼女には目的地がわかっているようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そして、通路の奥へと歩を進めたルナルバースの目の前に現れたのは――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0100" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101110004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "巨大なクリスタルだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "それは小柄な女王の何倍もの大きさで、紅く輝きながら空中に鎮座している。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "よもや月面王国の宮殿・ルナパレス２１の地下にこんな物体が存在するなど、ル　\nナテミスたち女幹部は知るよしもなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ムーン・クリスタルよ。我が一族の礎よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101110005" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「恐れていたことが、ついに始まってしまったようじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "007_010101110006" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "女王が口にしたムーン・クリスタルとは一体？　そして彼女が恐れていたこと　\nとは……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "これからカツマ達を待ち受ける運命とは……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}