{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「お待たせしました。今日のお呼び出し……どういった感じのご用件でしょう\nか？　なんて……ふふ、少し白々しいですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら……以前に甘やかされたプレイが忘れられなくて……？　また、そうい\nう感じのをお願いしたいと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504102" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、すっかりハマってしまわれたみたいですね。確かに、私もいつでも\nどうぞと言いましたけど、これでも今の私はサキュバスなので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504103" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「これ以上となると、もしかしたら引き返せなくなるかも知れませんよ？　そ\nのお覚悟があってのことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「なるほど……そこまで仰るなら、私としても望むところです……じゅるっ…\n…今日も、私のこと……ママサキュバスと思って甘えて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504105" ]},
		{"command":[ "SETCHARA", "0", "char_00002605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「じゃあ、もう邪魔なお洋服は脱がしちゃいましょうね。全部ママがやってあ\nげますから……よい、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あらあら、よっぽど楽しみにしてたのね……オチンポ……何もしてないのに\nビンビンに勃起しちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「そうね……今日は、おっぱいよりももっと気持ちいい場所……オマンコで、\nオチンポをトロトロにしてあげましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もう私の中もジュクジュクで、準備できてるし……はぁぁんっ、入っていく\nわ……あっ、おぉっ、はぁぁぁぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふぅ……どうでちゅか？　ママのオマンコの中……とってもあったかいで\nしょう？　んっ、おふっ、んくう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「これから、とっても元気でやんちゃなオチンポを、いーっぱいよしよしして\nあげまちゅからねぇ……楽しみにしててね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ、まず……軽くナデナデするところから……ねとねとの、ヒ\nダヒダで……先っぽを擦ってあげるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁぅ……んんっ、どう……？　ママのオマンコのヒダ……ヌルヌルして、\n擦れると気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「すっごく感じやすい、オチンポの先……ヌルヌルのお汁まみれにしちゃいま\nしょうねぇ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「これで滑りやすくなったところで……次は、上下に……んっ、出し入れをし\nていくわよ……？　はっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほぉら……どう？　ゆっくりとオチンポがオマンコから抜けていくところ…\n…よく見える……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もう貴方のオチンポ……ママのマン汁で、ドロドロになっちゃってるわね…\n…あぁ、もう少しで全部抜けちゃいそう……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ！　はぁい……また、根元まで食べちゃったわぁ……ママの欲張りオ\nマンコが、オチンポぱっくんってしちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「またずるって抜けて……オチンポ見えてぇ……んふぅっ、根元まで戻ってぇ\n……だんだん速くなっていくわよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、あふっ、あぁん……エッチな音ぉ……ぐぽぐぽ鳴りながらっ、\nオマンコスクワットしちゃってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、やっぱり……貴方の勃起オチンポは最高ね……ママの感じると\nころ……しっかり硬いので届けてくれるもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もっとエッチに腰を回してもいい？　ほら……こんな感じよ……ほぉっ、お\nぉぅっ……んふぅんっ、おっぱいを揺らしながらっ、かき回すようにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁぁんっ、いいわぁっ……オチンポっ……きゅうんって締め付け\nちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら……んふふっ、ちょっと強すぎちゃったかしら？　ごめんなさい、逞し\nいオチンポだからついママも張り切りすぎちゃったみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「でも……この調子なら、緩めなくても大丈夫そう？　こんなに元気なオチン\nポだもの……男の子だし耐えられるわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ、ふんっ、はっ、あぉっ、おんっ……！　そうね……少し激しい位が…\n…このオチンポにはちょうどいいわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「もっと吸い付けるわっ……貴方も好きなように腰を振っていいのよ？　あぉ\nっ、そっ、そうっ、その突き上げぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいわっ、そこっ、そこよぉっ！　あぁっ、ママのＧスポットっ、\n沢山オチンポ突かれてっ、はぁぁおっ！　声が出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁ……オマンコいいわぁ……オマンコ感じるのぉ……いやらしい汁\nがどんどん溢れてぇ……シーツに染みを作っちゃうわぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「けどっ、もう止まらないっ……もっと欲しいものっ、いっぱいオチンポズボ\nズボされてぇっ……くふぅっ、顔が緩んじゃうわぁ……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「くひぃぃいっ！　あぁっ、奥っ……コツコツ当たるぅっ！　んんっ、太いの\nで押し付けられるたびにぃっ、オマンコ幸せになってくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あんっ……中でビクビクし始めたわ……いっぱい頑張ってくれたけど……そ\nろそろ、出ちゃいそうかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「いいのよ、出したくなっちゃったら、このまま出しちゃっていいんだからね\n？　んふっ……そうね、もちろんオマンコの中に……直接よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「貴方の、男らしい精液……いっぱい流し込んで欲しくて、ママのオマンコは\nウズウズしているの……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……私も待ちきれないわっ……腰をフリフリしてっ、締め付けるからっ\n、ほらっ、いっぱい出してっ……ザーメンっ、出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ……！　来たわっ……貴方の元気いっぱいのミルクっ……いっぱ\nい出てるのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁぁんっ、ママもイクわっ！　中出しでイクっ、オマンコイクのっ、はぁ\nぁぉうっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁ、いっぱい出せて偉かったわね……本当にいい子……んふっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504138" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「子宮に直接浴びて、受精したかもって震えてるわ……あぁ……この感じ……\n病みつきになっちゃいそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「どう……？　ママのオマンコ……よかったかしら？　ふふっ、そう……それ\nはよかったわ……ママもいっぱい感じちゃったの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「さ……少し一休みできたかしら。ママ……ちょっとお願いしたいことがある\nんだけど……聞いてもらえる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「その……貴方のオチンポ……本当に気持ちよくてね、いっぱい出してくれた\nのも嬉しくて……それでね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「また、ママのオマンコ肉がしたいしたいって……疼いてきちゃってるの……\nママのオマンコ……助けてくれる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あんっ、嬉しいわっ♪　だって、まだママの中でオチンポもビンビンのまま\nだもの……これで終わるのは勿体ないわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んっ、ママ……頑張って腰を振るから……よかったら、一緒に合わせて動い\nてちょうだい……はっ、んんっ、あんっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁ……いっぱい出たザーメンが……ぐちょぐちょ混ざってるっ……硬いオ\nチンポのヌルヌルがすごくいいわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ、はんっ、あぁっ、いいのよ……ママのおっぱいを触っても……この\n身体は、隅々までぜーんぶ貴方のものなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほら……乳首……ぷっくり盛り上がってるでしょ？　オチンポと同じで、興\n奮するとこうなっちゃうの……今、すごく敏感なんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぅんっ、そう……コリコリさせてぇ……あぁんっ、我慢出来ない\nわっ……私も……貴方のおっぱい触っちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ、どう……コリコリでしょ？　この敏感になってる場所を触りながら\n……一番いやらしいところをズリズリしましょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ほらっ……ここぉっ、あっ、あひっ！　感じるわっ……Ｇスポットとっ……\n亀頭のキスっ……堪らないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっと……奥に来てっ……根元深くまで繋がってっ……そう、その\nまま腰を回すようにしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぉっ！　おぉぉっ……！　いいわっ……硬くて熱いオチンポがっ、ママの\nオマンコかき回してぇっ、腰が止まらないのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁうっ、いやらしくおっぱいプルンって揺らしてっ、ベッドのバネをギシ\nギシさせてぇっ、ドスケベダンスが止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はひぃっ！　下からも突き上げ……来てるっ！　貴方のオチンポが本気でマ\nマのスケベマンコをズンズンしてるっ！　くぅっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504215" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁっ……またイキそうっ、はぁんっ、ダメェ……ちゃんと一緒にイクまで\nするからっ……オマンコ締め付けるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふぅっ……！　どうっ？　イキたいのっ？　ママとの本気セックスでまた\n射精したくなっちゃってるのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504217" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ええ……もう止まらないわっ……このまま最後までイッちゃいましょうっ？\n　ママも一緒にイクわっ、もうオマンコ我慢できないのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁんっ、中がいいっ……？　掛けてもいいわっ、何でもママは受け入れる\nからっ、何も考えないで気持ちよくなってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504219" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「熱いのっ……ドピュドピュ出してっ！　あぁっ、もうダメっ、ママはイクわ\nっ！　あひぃんっ、オマンコっ……イクのぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……！　また、どぷんってっ……オチンポ出てるっ！　オチンポミ\nルクっ、中出しされてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁぁん……子宮に来てる……あぁ、元気なザーメン……受精しちゃう……\nママなのに、また赤ちゃんが出来ちゃうわ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「けど……これが最高なのぉ……サキュバスが一番欲しい……新鮮な濃いザー\nメン……はぁぁ……オマンコに染み込んでいくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あっ、ふぁぁ……後、もう少し出せそう……？　待ってね……今、キュンっ\nて締め付けて搾り取ってあげる……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ、最後のお汁……今、来たわ……ふふ、分かるわよ……これ\nでもママはサキュバスなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「全部搾り取っちゃったわ……これで５歳は若返った気分……いっぱい出せて\n偉かったわね……よしよし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ふふっ、お疲れ様でした。もう少しママの余韻に浸った方がよろしいですか\n？　やっぱり、いっぱい出すと我に返っちゃうみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「私も、このプレイがこんなに興奮するとは思いませんでした。もうすっかり\nハマってしまった感じです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ええ……もし、またお望みでしたら、いつでもママとしてお出迎えいたしま\nすよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「だから、僕ちゃんのオチンポも……また逞しいところ……見せて下さいね…\n…♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},	
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「きゃあっ！　あふっ……今度は身体にっ……熱いのいっぱいぶっ掛けされて\nるぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んぁぁ……トロネバ精液が……お腹にも、おっぱいにも掛かってぇ……んく\nぅん……ママもまたイッちゃってるのぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はぁ……気持ちいい……もっと出して……サキュバスの栄養……濃厚すぎる\nオチンポミルクぅ……シャワーしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504403" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「んんっ……お股で擦ってあげたら、もう少し出そう……？　いいわ……最後\n、ドピュって出しちゃいましょ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あふっ……最後のお汁も飛んだわね……これで、いよいよ出し切っちゃった\nかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「いっぱい出せて本当に偉かったわね……ママもとっても気持ちよかったわ…\n…いい子ね……よしよし……」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002605_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「あら……もうよろしいんですか？　ふふっ、そんなに恥ずかしがらなくても\n。そういうプレイだったんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「でも、私もここまで夢中になるなんて思いませんでした。ザーメンも中にも\n外にも出して貰えましたし……ちゅぷっ……美味しい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「はい。また機会があるなら、今度は私からお願いしたい位……ママプレイは\n素敵でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0504409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "古賀道子" ]},
		{"command":[ "SETTEXT", "「ええ、今度はもっと甘やかして……身も心もトロトロにさせちゃいますから\n……楽しみにしてて下さいね……♪」", "NORMAL" ]},
