{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "この星が危機にさらされている、と言って本当に信じてくれる人はどれだけ\nいるだろうか", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "異星人が襲撃している、というのはもう周知の事実だ。けれど、それを本当\nの危機として感じている人はどれだけいるのか", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "一般市民はまだ、どこか日常の延長のように異星人の襲撃を感じているよう\nな雰囲気がある", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "でもたとえばこの地球防衛機構、EDOが曲がりなりにも今まで敵対してい\nたものたちが利害を超えて所属している組織であり", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "そんな彼女たちがまとまって異星人に対抗している", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "そんなことは、今まではなかったことだ", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "そう言ったのなら、少しは危機感を持ってくれるだろうか", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「説明したとおり、我々は主力部隊の側面から火力で援護する。ただ、援護と\nはいえ押し込めるときは一気に押し込む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その判断は私がするが、そのときは迷わず突撃しろ。ただ、あくまで主目的\nは援護ということは忘れるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「援護。そう、援護だ。私がやるべきこと。やれること）」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "私はヒーローじゃない。ヒーローにはなれない。どれほど真面目に訓練を積\nんでも、主力部隊になれるような力はない", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "ヒーローになりたかった。ヒーローを目指した。それでも、なれなかった。\nそれが私", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "だけど、それでもやれることはある。ヒーローになれなくても、誰かを助け\nる正義の味方にはなれる", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "私が主力を助ければ、それだけで救われる人がいる。それでいい", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「頼母木、君は今回が初陣だ。私とは別働隊で緊張するだろうが、訓練で学ん\nだことを思い出しながらしっかりやれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「はっ、了解です！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250013" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「良い返事だ。期待しているぞ。よし、それではEDO援護部隊、出撃だ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "それが私が地球防衛機構であるEDOに所属する、たった一つの理由だ", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くうっ、こいつら、今日は妙に押しが強いぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「怯むなっ！！　ここを抜かれれば街の中心部が破壊される！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「分かっている、だが！！　おい下僕、なんとかならんのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「援護は要請している！！　なんとか踏ん張ってくれ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、朗報です。今まさにその援軍が到着したようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022250001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「こちら頼母木、指定ポイントに到着しました！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250015" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「よし、こちらも位置についた。各員、攻撃開始、全弾を侵略者に撃ち込んで\nやれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「了解っ！！　攻撃を開始します！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250016" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「む……敵が揺らいだ……が、思ったほど崩れんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、これ以上は限界だぞ。突撃して崩すしかない！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て、待て待て待て！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今突撃しても押し返される！！　長官、なんとかならないか！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「見たところ、奴らは突出力は強いが、そのせいで孤立しかかっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「背後からも攻撃を仕掛けられれば今度こそ崩せるはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そこをルナテミスたちが攻撃をすれば殲滅できる。しかし、そのための部隊\nが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「私が行きます。位置的に長官より私たちの部隊の方が迅速に背後に回り込め\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250017" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「頼母木……しかし君は今日が初陣だ。やれるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「背後から急襲して相手を倒そうっていうわけではないのでしょう？　かく乱\nぐらいならこの人数でもできます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250018" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「そのために訓練を積んできたんですから！！　主攻にはなれなくても助攻な\nら務めて見せます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「ただ、人数が少ないので攻撃は長官の部隊とタイミングを合わせます。それ\nでいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……分かった。無理はするなよ。相手が向かってきたらすぐに撤退しろ。合\n図を待つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「了解です！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250021" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くおっ、一時は弱まったが、また盛り返してきてるぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「我慢、我慢だぞ姫様。ステイ、ステイだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、まるで名ハンドラーのごとく、姫様を操っておりますな。さすがご主\n人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022250002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……駄犬と下僕、後でお仕置きだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで俺まで！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「馬鹿をやってないで攻撃を続けろ！！　相手にこちらの意図を悟られるな！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「分かってる！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くううううう、こういう戦い方は性に合わん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、もう少しだ。仲間を信じろ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「……こちら頼母木、位置につきました。敵はこちらに気づいていません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250022" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「よし……こちらもいける。いくぞ、1、2の3！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「攻撃開始！！　撃てーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250023" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おお、背後からの攻撃で敵が崩れたぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「好機だ、カツマ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「分かってる！！　全員突撃ィッ！！　姫様、ＧＯＧＯＧＯ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「敵を突き崩す！！　一気に打ち破れっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私に続けっ！！　はああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「よし、よし！！　いける、いけるぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「敵が撤退を始めたぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まだだ、攻撃の手を緩めるな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「むっ、頼母木、敗走する敵がそちらにむかっている、急いで撤退しろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「っ！！　了解です、撤退します！！　援護をお願いします！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250024" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「分かった。各隊、指定ポイントに攻撃！！　頼母木の撤退を援護しろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250014" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ、あいつら最後っ屁とばかりに撃ち返してきやがった！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「狙いもつけず、四方八方に砲撃しているな。逃走の足止めだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022250007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん、こんな抵抗で止まる私たちではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022250010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや、いかん！！　あの方向には頼母木の部隊が――！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022250015" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「いけない、皆、逃げて――きゃあああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022250025" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}