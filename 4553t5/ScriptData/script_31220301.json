{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「それじゃ……行きますね？　よいっ、しょっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「うわ……もう、めちゃくちゃ大きくなってるじゃないですか……そんなに楽\nしみにしてたんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303102" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「わ、分かりましたから、そんなに何度もこくこく頷かないでいいです。でも\n、まさか……足……しかも太ももで、おちんちん擦るなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303103" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「隊長、知ってますよね？　足が太いって……私のコンプレックスになってる\nこと……なのに、わざわざこれなんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「魅力的な足……それは……まぁ、口では何とでも言えるでしょうけど……い\n、いや、そんないい所を力説しなくてもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「もう……そこまで言うなら、とにかく今日は特別です……どれだけ上手く出\n来るかは分かりませんけど……一生懸命やってみますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「えっと……とにかく、ここに力を入れて……おちんちんを……挟むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「あっ……また、ちょっと膨らんでませんか……？　んっ、すごく熱を持って\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「それだけ期待してるってこと……みたいですね。とりあえず……上下に動か\nしてみますね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……はっ、ふっ、こ、こんな……感じで……どうでしょうか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「下半身だけ持ち上げて……また……落として……これ、普通にトレーニング\nしてるような感じなんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「あ……でも、いい感じ……なんですか。確かに……おちんちんが、ちゃんと\n反応してるように見えます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「この調子で……もっと、ズリズリ……してあげればいいんですね？　んっ、\nちょっと速くして、みます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、はっ……こうすると……んっ、皮が……ちょうど捲れる感じ\nになって……やっぱり、いいみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「けど、これ……思った以上に……体力いりますよ。身体、鍛えてるような気\n分です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「うぅ……これで、また足が太くなったら隊長のせいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「そりゃあ……気にしますよ。メンバーのみんなとも一緒にトレーニングしま\nすけど……間違いなく私が一番太いんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「健康的ですか……まぁ、ものは言いようですよね。でも、この太いのが役に\n立つのなんて……んっ、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「こうして……おちんちんを……ぎゅっと押し込む位しか……あっ……今の…\n…んっ、いい感じですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「もう一回……ぎゅって……んっ、柔らかいような……硬いような……ぐにぐ\nにして……でも、熱いのは確かで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、かなりぎこちないと……思うんですけど……それでも、いいん\nですか……これが……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「きゃっ！　も、もうっ……そんなにピクピクさせないで下さい。気持ちいい\nのは分かりましたから……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「もっと……しっかりプレスして……ぎゅっ、ぎゅって……してあげれば……\nんっ、ふっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「な、なんか変なうめき声が聞こえたんですけど……結構痛かったですか？　\nでも……これ位は大丈夫なんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ふふ……何だか不安そうな顔しちゃって……そうですよ、隊長のおちんちん\n……今は私の気分一つでどうにでもなるんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「密着した太ももでギュッてされて……余裕ないのに、されるままになっちゃ\nって……ふふっ、ここからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あっ、ほらっ……激しくズリズリしちゃいますからっ、あんっ\n、おちんちんからジワって滲んできましたよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「太ももで挟まれて……興奮してるんですねっ？　私の前で……こんな恥ずか\nしい格好で……おちんちん見せつけてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「我慢できないって……お汁漏らしてっ……変態丸出しでっ……はっ、んっ、\nどうなんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「またっ、んくぅっ、ビクって震えて……射精したいんですね？　正直に言う\nんですっ、ちゃんと言わないと……お預けですよっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「出したいんですねっ？　んふっ、よく言えましたっ、ええっ……特別に許し\nてあげますっ、射精っ……いいですよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「あぁっ、んっ、はいっ……どうぞっ、お好きな時に身を任せてっ……遠慮な\nく出しちゃって下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「いやらしいっ、太ももコキでっ……おちんちんっ、思いっきりっ……射精っ\n、してぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ……出たっ！　精液……んんっ、足に……いっぱい掛かって\nる……こんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ホントに太ももだけでおちんちんイッちゃった……気持ち、よかったんだ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んぁ……こんなに……足がヌルヌルですよ……本当に遠慮なく出しますよね\n、隊長の趣味が……ちょっと分からなくなって来ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「んっ……落ち着きましたか？　物足りなかったんじゃ……あ……すごく満足\nですか……それは、まぁ……よかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「まさか、太ももで挟んで擦るだけで出ちゃうなんて……確かに刺激を与えれ\nば出るって理屈では分からなくもないんですけど、うーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「そうですね、全くコンプレックスがなくなった訳じゃないですけど……でも\n、少しは自分らしさってことで、自信はついたような気がします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "利奈" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、どうしてもって言うなら……次の機会も、考えなくは……ない、\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0303140" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}