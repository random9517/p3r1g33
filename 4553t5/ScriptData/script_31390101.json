		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、あぶっ！？　ちょ、ちょっと……あ、熱っ……！？　か、顔になにか\nかかって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「こ、これ……精液！？　顔にザーメンを出すなんて、聞いてない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あうううぅ……！？　ま、まだ出てる……！？　か、顔中精液まみれで……\nベトベトするわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……あっ、あっ！　はああぁ……！　やっ……やっと、出し終え\nたのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「そんなに、私にマーキングしたかったの……？　自分の所有物だって、知ら\nしめたかったのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「別にイヤじゃないわよ……言ったでしょう……？　道具のように扱われてた\nのに、気持ちよかったって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「私はもう、あなたのモノになったのかも知れないわね……シたくなったら、\nいつでも言って頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「えっ……ま、まだするの……！？　あれだけ出したのに、どれだけ元気なの\nっ……！？」", "NORMAL" ]},
