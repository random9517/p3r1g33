		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「げほっ、けほっ！？　ぐっ、あむううぅ！？　じゅる、ずちゅ！　ちゅぱっ\n、じゅっ、れりゅ、ずぞおおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んんん～～～～～っ！？　ち、チンポがビクビクしてええぇ……！？　イッ\n、イクのね……イキそうなのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
