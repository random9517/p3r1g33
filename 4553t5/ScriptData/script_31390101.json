		{"command":[ "PLAYVOICE", "v2_139_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んじゅ、じゅるるっ！　じゅぷっ、ぢゅぷぷっ……！　んちゅ、ちゅ、じゅ\nるるっ、ぐちゅうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あっ、あああぁ……！　チンポが跳ねてる……！　だ、出して……！　好き\nなところに、いっぱい……！　ザーメン出してええぇ！！」", "NORMAL" ]},
