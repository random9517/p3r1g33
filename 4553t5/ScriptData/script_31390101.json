		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ごくっ……んくっ、んぐっ……！　ずちゅ、じゅぱっ……じゅぞろおおおぉ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「全部、飲んだわよ……あなたのザーメン、身体の中に入ってしまったわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「お世辞にも……美味しいとは言えないわ……でも、あなたの精液なら……変\nな味でも、耐えられるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ふふっ……またチンポの中にザーメンが残ってるのね……いいわよ。吸いだ\nしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
