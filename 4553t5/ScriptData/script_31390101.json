{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「別にあなたの事を嫌っているわけじゃないわ。ただ、なにを話せばいいのか\n……よくわからないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00013901_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「出来ればもっとあなたと親睦を深めたいわ。なにかいい方法はない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「パイズリ……？　それはどういった行為なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00013901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あたしのおっぱいで、あなたのオチンチンを擦る……そう。随分とエッチな\nことを言うのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00013901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「別に構わないわ。それであなたと親睦を深められるなら……ほら、早くしま\nしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……あはあぁ……こんな感じでおっぱいに挟めば、いいのかしら\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「それにしても、オチンチンからすごいニオイがするわね……こんなの、今ま\nで嗅いだことないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「オチンチンじゃなくて、チンポ……？　そ、そう呼んだ方がいいのね。わか\nったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、擦るわね……初めてだから、痛かったら言って頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……くっ、はああぁ……なかなか、難しいわね……おっぱいを\n動かしても、チンポが上手く滑らないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「それに、擦るたびにチンポと素肌がずりゅずりゅして……肌が燃えてしまい\nそうなぐらい熱くなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「これで本当に親睦が深まるのか、わからないのだけど……でも、エッチなこ\nとはお互いが深い関係にならないとできないことだものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「大丈夫よ……私に、任せて……んっ、はああぁ……くっ、あふうぅ……んっ\n、あぐっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ……！？　ち、チンポの先端から変な汁が……それに、チンポ血管が浮\nかんできてるわ……もしかして、興奮してるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「この透明な汁は、チンポが気持ちよくなると出てくるものなのね……じゃあ\n、もっと気持ちよくしてあげるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、ふううぅ……チンポがおっぱいを往復するたびに、私の汗とあなたの\n汁が谷間で絡んで……ぐちゅぐちゅって、いやらしい音がしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「胸の谷間を擦られてるだけなのに、変な気持ちになってくる……こんな感覚\n、初めてだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はあぁ、ああぁ……えっ……？　チンポに吐息が当たって、気持ちいい……\n？　そのままチンポを舐めてくれって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「こ、これを舐めるの……！？　いやらしいニオイと汁が出てる、ガチガチの\n勃起チンポを……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、くうぅ……わ、わかったわ……あなたの頼みだもの。それに、舐めた\n方が滑りもよくなりそうだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ……れろっ、れりゅ……んむ、ふぐっ……ちゅっ、ちゅうぅ…\n…んっ、あむっ……じゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はああぁ……口の中に透明な汁の味が広がってくるわ……あむっ、りゅぱ、\nじゅぱっ……れろっ、れりょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「チンポが舌や歯に当たって気持ちいいから、もっと吸い付いて欲しいのね…\n…わかったわ……んっ、んむっ、あむうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「じゅる、じゅぱ……ちゅ、ちゅる……んっ、れろっ、れろぉ……じゅぱ、く\nちゅ、ぐちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「すごいわ……！　チンポがビクビクし続けて、さっきよりも大きく、硬くな\nってる……んっ、んんっ、ううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「胸と口を同時に犯されてるみたいで……はああぁ……！　わ、私も……なん\nだか気持ちよくなってきてるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「おっぱいに負けないぐらい、オマンコの奥が熱くなって……んんっ！　エッ\nチな汁が……出てるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あっ……ご、ごめんなさい……私じゃなくて、あなたが感じないといけない\nわよね……じゅ、ちゅぱ、じゅる、れりょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、ちゅぷ、ちゅぱぁ……！　もっと、奥まで咥えこむの……？　わ、\nわかったわ……やってみるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あむっ……！　じゅぷ、じゅちゅ、んじゅうぅ……！　れりゅ、れりょっ…\n…ちゅ、じゅぷ、ぐちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はああぁ……蒸れたチンポから、オスの香りがまた一段と濃くなってきて…\n…鼻の奥を犯すように突き抜けてくる……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「じゅちゅ、じゅぱっ、んじゅるうぅ……！　それに、チンポが何度もビクビ\nクって小刻みに跳ね続けて……変な挙動をしてるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「いっ、イキそう……？　ひょっとして、精液……ざ、ザーメンって奴が出る\nの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「いいから咥えてしゃぶり続けろだなんて……！　そ、そんな命令みたいなこ\nと……！　でも、あなたが悦んでくれるなら……あむうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「じゅううぅ、ずりゅ、じゅちゅ……んっ、んんんぐっ……ふぎゅっ、じゅる\n、んっ……んんんんん～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あぶっ！？　んっ、んむうううぅ！？　んく、んくっ、んぐっ、んんっ……\nくふぁ、あっあっ……んっ、ちゅばぁ……ごくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……んっ、はぁ、はぁっ、ああぁ……粘っこくて、ドロっとした液\n体が口の中に……ごくっ、ごくん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「イカのような香りが、口いっぱいに広がって……ひ、酷いニオイがするのに\n……い、イヤじゃないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「思わず飲み込んでしまったけど……これが、あなたの精液……赤ちゃんのモ\nトなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「まだ……チンポの中に残ってるみたいね……いいわよ。全部、吸いだしてあ\nげる……ずっ、ずりゅっ、じゅぞおおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ……またビクビクしてるわね……出し足りないということなのかしら…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「もっと口マンコを使わせろですって……？　な、なにを言ってるの……ここ\nは、あくまでも口であって、オマンコじゃないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……そんな無理やり、押しつけないで……！　ちゃ、ちゃん\nと咥えてあげるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「こんな無理やりな感じで、本当に親睦が深まるのかしら……でも、不思議と\nイヤな感じはしないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、もう一度咥えるわね……んっ、あむっ……ちゅぱ、ちゅ、じゅ\nぱっ……んむっ、れりゅ……じゅる、ちゅぷうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ずちゅ……ぴちゃ、れろっ……あむっ、んっ、んむっ……ちゅぱあぁ……！\n　先端から、汁が溢れ続けてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「そんなに私の口が気持ちいいの……？　んぐっ、んんんっ、あっ、じゅるっ\n……れろっ、れろっ……ぴちゃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ！？　そ、そんな……急に腰を振らないで……！　チンポが\n口の奥まで……あむうううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ずちゅっ！　ぐちゃ、れりゅううぅ……！　けほっ、けほっ……！\n　く、苦しいわ……！　もう少し、優しく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あむうううぅ……！？　んっ、ちょ、ちょっと……んぐううううぅ……！？\n　口の中、チンポで……いっぱいに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、れろっ、ずじゅっ、んぐうううぅ……！　はぁ、はぁ……んんん\nっ！　ぐっ、ふあああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「あなたのチンポ……感じる……！　口マンコが、あなたを欲して……口内を\n犯されて、気持ちよくなって……んぐうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「ずちゅ、じゅちゅ、じゅぷううぅ……！　はぁはぁ、はぁ、はぁ……私を犯\nすのが、そんなに好きになったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「私も……嫌いじゃないわ……道具のように扱われてるのに、気持ちよくて…\n…！　オマンコ、すごく感じてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「だから……もっと、して頂戴……あなたのチンポなら、いつまでも咥えてあ\nげ……んんんんん～～～～～っ！？」", "NORMAL" ]},
