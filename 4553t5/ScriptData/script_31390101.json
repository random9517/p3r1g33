		{"command":[ "PLAYVOICE", "v2_139_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「それにしても、本当に不思議ね……おっぱいでチンポを擦ったら、親睦を深\nめられたのだもの……身体を重ね合うって、大切なことなのね……」", "NORMAL" ]},
