		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「うぐぐっ……す、すごい……！　げほっ、けほっ……！？　じゅる、ちゅぱ\nっ、ちゅ、じゅるうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「さっき出したのに、またこんなに出して……！　ちゅぱっ、じゅ、ぐちゅ、\nじゅりゅうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00013901_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "南野サキ" ]},
