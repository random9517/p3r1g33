		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "南野サキ" ]},
		{"command":[ "SETTEXT", "「えっ……！？　な、なに……！？　ち、チンポが口から抜けて……あんんん\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_0103401" ]},
