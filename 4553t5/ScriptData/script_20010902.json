		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「市街地に謎の空間が発生！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021170001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「謎の空間？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、謎の空間……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021170002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「謎の空間ってなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「謎は謎なんです。中の様子がさっぱりわからなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021170003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ？　こんなときに下僕は何をやっている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021170003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さあ……。連絡しても応答がないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021170004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく、肝心なときに使えない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021170004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "一方、市街。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「はぁっ！　やぁっ！　てぇいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021170001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわ、めちゃくちゃ強いな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすが伝説の戦士。一人で敵をばったばったとなぎ倒していきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ブリキ２は相手の攻撃をいなしてカウンターを決めるタイプ。燃費も良く、\n一対多の長期戦に向いているスタイルですからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021170002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、お前なんでそんな詳しいんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "倒れたソルダー兵が山のように積み重なっていく。そこへ、新たな敵が現れる\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ずいぶん手こずっていると思ったら、憎きアマルガメイトがこの世界にも現\nれていたのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「えー、ブリキ２じゃーん。なになに、私と遊びたくって追いかけてきてくれ\nたの～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい。なんだか偉そうなやつがでてきたぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あれは……まさか幹部クラスが現れるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021170003" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知ってるのかジュンジロー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやぁ、あの偉そうな雰囲気はどう見ても女幹部ではありませんか？　ご主\n人、わかるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021170004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、言われてみれば確かに、みるからに女幹部って感じだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_010" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぶぇーっくし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021170005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕め。どこかで油を売っているばかりか私の噂までしているのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021170006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「クラッドにトタン。やはり貴女たちの仕業でしたか。まさか、そちらの方か\nら出てきてくださるなんて。探す手間が省けましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021170002" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「それはこちらの台詞。我がソルダー兵を使っておびき出したのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170002" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あれ？　そうだっけ？　アマルガメイトが出たのが予想外で、慌てて飛び出\nしてきたんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「と、トタン！　余計なことは言わなくていい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170003" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ちょっとソルダー兵に破壊工作させればあっさり侵略できるだろうとか舐め\nた作戦を組んだのがバレるだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170004" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、あいつ意外とたいしたことないんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「メッキがはがれるのが早すぎでございますな。戦隊ヒーローの追加戦士でも\n一月は保ちますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021170005" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「まあいいや。せっかく来たし、私が遊んであげるね。雑魚兵士だけじゃ相手\nにならないもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170003" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「貴女との決着もつけないといけませんからね。いいでしょう。かかってきな\nさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021170003" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「トタン、気をつけるんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170005" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「うん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170004" ]},
		{"command":[ "SETCHARA", "1", "char_00012101_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「危なくなったらすぐに後退するように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「わかってるわかってるー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「怪我をしないように。装甲が凹んだらすぐに撤退だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021170007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「そんなヘマしないってばー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだあのでかい方、過保護なのか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「上司と部下という感じではありませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021170006" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「来るなら早く来なさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021170004" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ほらー、ブリキ２が待ってるでしょー。いってきまーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021170007" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
