		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ここまで苦戦するなんて思ってもみなかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150009" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「ふふっ。貴方達のカツマちゃんへの想い……確かに受け取ったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150026" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、カツマさんを解放してくれるんですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150018" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　待ってくれ！　俺はまだ納得してないぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「安心してください。例えＭＯＥちゃんから降りたとしても、私たちはご主人\n様の味方です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150035" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご奉仕の頻度は減るかも知れないけど……身の回りのお世話や、仕事の手伝\nいはちゃんとするから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150032" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「本当はずっと乗ってもらいたいけど、身体を動かすことも必要だもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150027" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、お前ら……！　わかった。いつまでもお前たちに甘え続けるワケにはい\nかないからな……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、カツマさんが車から降りてきましたよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150019" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お帰り、カツマ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150010" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今回は迷惑かけたな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まったくですぞ。しかしこれにて一件落着ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150031" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、基地に戻ろう……って、どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150011" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なんか外めっちゃ熱いし……やっぱり快適なＭＯＥの中でゴロゴロし\nながら、ロッテとクララに甘える方がいいなーって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　車に戻ろうとしないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150020" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん……！　やっぱり私の中がいいのね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150028" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　ご主人様が望むなら、仕方ないですよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150036" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お帰り、ご主人様……短い間だけど、居なくて寂しかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150033" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！　いい加減にして！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021150012" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カグヤさん！　やっぱりこのロボットたち、一度スクラップにするべきです\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021150021" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「またやると言うんですか！？　いいですよ、相手になります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010021150037" ]},
	{"command":[ "SETCHARA", "0", "char_00015701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人様のためにも、絶対に負けないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010021150034" ]},
	{"command":[ "SETCHARA", "0", "char_00015801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ" ]},
		{"command":[ "SETTEXT", "「ふふっ。私も本気を出そうかしら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010021150029" ]},
	{"command":[ "SETCHARA", "0", "char_00011101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150032" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや……乙女心というのは、ロボットも人間も関係なく怖いものですな\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150033" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし本当に怖いのは……ここまで好意を向けられているのに、気付く気配\nのないご主人の鈍感さかもしれませんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021150034" ]},
