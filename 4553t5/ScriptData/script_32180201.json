		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁっ……亀頭が震えてっ……また出ますねっ？　出して下さいっ、また…\n…お好きな場所にっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私の……おっぱいでもっ……他の所でもっ……ご主人様のお望みのままにっ\n、あぁっ、オチンチンずりずりしてっ……ひぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私もっ……またイキますっ、あひんっ、おっぱいっ……イキッ……ますぅぅ\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「きゃふっ……！　あぁっ……乳首っ……熱い……ですっ！　また、おっぱい\nに……精液っ……こんなに……っ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……どくどく……溢れ出して来ています……ねばねばした精子\n……生命力に満ち溢れています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あぁ……もっと掛けて下さい……オチンチンに付いている分も、全部……私\nのおっぱいに擦り付けて下さい……あぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ、射精しながらオチンチン……押し付けられて……私、興奮\nしています……身体に染み込む感じ……素敵です……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ……！　もう一回出て来ました……あぁ……全身が精液に浸されたよう\nな感覚です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「射精……終了しましたか……？　はい、少しずつ私の各部位も波が収まろう\nとしています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私のようなドールが、おこがましいことを……そんな風に思うこともありま\nしたが……ご主人様は正面から向き合って下さいました」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「そんなご主人様だからこそ、お願いしてよかったと思いますし……私も、得\n難い経験が出来たような気がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「その、もしご主人様さえよろしければ……また、使っていただけますか？　\n次は、もっと喜んで頂けるように……頑張りたいと……思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい、ぜひ。ふふっ……ご主人様……ありがとうございます」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んぁうっ……！　あっ……私の顔に……精液がっ……いっぱい……んぁっ…\n…！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「いえっ……大丈夫です……少し驚いただけです。構いませんから、私の顔に\n……いっぱい掛けて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んふ……べとっとしています……あぁ……このぬめりに生命が宿っていると\nいうことなのですね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私にも、それを感じることが出来てます……このヌルヌルが……何とも言え\nず、心地いいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あっ……まだ出るのですか……？　はい、顔面シャワーというものですよね\n……？　どうぞ、お続け下さい……あふっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_12" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「んっ……最後の一滴まで残さず……射精して下さい……あぁ……オチンチン\n……直接押し付けて塗り込めて下さい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_13" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はふぁ……終わりましたか……？　ありがとうございます……私の身体でも\nお役に立てたでしょうか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021802_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「良かった……我ながら無茶なことをお願いしましたが……やはりご主人様の\n懐と守備範囲は無限の広さをお持ちのようです……ふふ、冗談です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「その、もしご主人様さえよろしければ……また、使っていただけますか？　\n次は、もっと喜んで頂けるように……頑張りたいと……思います」", "NORMAL" ]},
