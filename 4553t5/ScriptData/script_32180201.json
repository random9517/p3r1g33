		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「勿論、ご覧の通り……外見は人間同然の姿とは程遠く、この世界で言うラブ\nドールの方が近いかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
