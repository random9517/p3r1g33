		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んなっ……！？　まさか、また我をオマンコを使う気か……！？　だ、ダメ\nである……！　もうやめるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304409" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_15" ]},
