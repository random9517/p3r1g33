		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが……膣外に出したのは僥倖であるな……これで我はまだ、そなたに屈し\nてなどいないのである……！」", "NORMAL" ]},
