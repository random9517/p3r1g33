		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、あぐっ、んくうぅ……！　こんなに熱いのを身体にかけれたら、ニオ\nイが染み付いてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それにザーメンのニオイもすごく感じて……！　あああっ！　ザーメンを感\nじて、イクのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我がイカされるなど、あってはならないのに……！　オチンポとザーメンに\n負けてしまいそうであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　イッ、イクッ……！　ひぎっ、んくっ……あああぁ！　んはあ\nああぁぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはぁ……ザーメンを身体にかけられて、イッてしまったの\nであるっ……」", "NORMAL" ]},
