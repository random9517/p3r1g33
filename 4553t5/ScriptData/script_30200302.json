{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、くふっ……！　このようなポーズを取らせるとは……！　そなたは我\nのことを、犬かなにかだと思っているのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「犬ではなく、発情したメス犬だと……！？　ちっ、違うのである……！　我\nは別に発情などしていないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ウソではないのである……！　オマンコが疼いているのは……そ、そう！　\nメンテナンスのミスである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我はマシン故にウソなどつかぬ……！　んっ、あっ……！　あぐっ、んふぅ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ウソをついてるか、確かめてやるだと……？　な、なにをする気であるか…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304105" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！？　こ、これはなんであるか……！？　オマンコの気持ちい\nいところにあたって……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「このバイブで感じなければ、発情していない証明になるだと……？　そ、そ\nんなのムリであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「今の状態でオマンコを感じさせられたら、気持ちよくなりすぎてしまうので\nある……！　あっ、ダメである……や、やめるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひいいいぃ！？　あっ、あっ！　バイブ強すぎるのであるぅ！　んひっ、\nあふっ、んんっ！　あっ、やっ、あはあぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「マシンファラオである我が、こんな小型のメカ如きに翻弄されるなどあって\nはならないのであるっ……！　ひぐっ、んふうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「素直にならないなら、バイブの振動を強めるだと……！？　ダメであるっ！\n　そんなことされたら、感じすぎてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「正直に言うのであるっ！　だから、バイブを離すのだ……あっ、うぐっ、ん\nはぁ！　んぎっ、あっ、んくううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたの言うように、我は発情していたのであるっ……！　卑しいメス犬と\nなって、オマンコを濡らしていたのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「正直に言ったのである……！　だからバイブを離して……あひっ！？　んひ\nいいいぃ！？　ど、どうして振動を強めるのであるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ウソをついた罰として、オマンコをしつけてやるだと！？　そんな……！　\n我は正直に話したのに……あはああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、あっあっ！　やっ、あああぁ！　バイブ感じるのであるっ！　オマ\nンコ気持ちいいのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「振動がクリトリスにあたって……子宮が疼くのであるぅ！　あっ、んんっ！\n　こんなに感じさせられたら、オチンポ欲しくなるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポが欲しいなら、ちゃんとおねだりしろだと……！？　くっ、ううう\nぅ……そなた、王である我になんという命令を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だがこのままお預けされると、オマンコが切なくて頭が変になりそうである\n……！　くっ、うううぅ……！　仕方ないのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そ、そなたの太くてカタいオチンポを、我のオマンコに挿れて欲しいのであ\nる……！　奥まで突き挿れて、ズポズポして欲しいのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「たくさん締め付けて気持ちよくするのである……！　だから……我のヌレヌ\nレオマンコに、オチンポを突き入れっ……んくうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ……あっ……！？　まだ、おねだりの途中なのに……！　一気に奥まで\n挿れるとは……！？　ひぎっ、んひいいぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我慢できないから動くだと……！？　だ、ダメであるっ……！　挿れられた\n快感で足腰が痺れているのに、いま動かれたら……あはあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　んはああぁ！？　ピストン激しすぎるのであるぅ！　オチン\nポが子宮口にあたっているの、感じるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あはああぁんっ！　子宮口の周りをグリグリするの、ダメであるぅ！　気持\nちよくなりすぎるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ひぎっ、んっ、あんんっ！　こんな……無理やり感じさせら\nれるなんて……！　これでは犯されているみたいであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「メス犬のポーズで後ろからオチンポをパンパン突かれるなど……！　王とし\nての威厳がっ……！　あひっ！？　あっ、んっ、んくううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「発情したメス犬に威厳もなにもないだと……！　そんなこと、ないのである\n……！　我はマシンファラオ……王の中の王である……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「人間に犯されて、感じさせられるなど……あってはならないっ……ひぐっ、\nあっ！？　んっ、くっ、あああぁ！　んはああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そんなっ、オチンポで教育するようにオマンコを突くなんて\n……！　我が従順になるまでしつけるというのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「確かにオチンポを求めたのは我の方だが……！　こんな調教まがいなやり方\n……！　んんっ、ひぎっ、あっ、んふううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　んっ、あっ！　このまま、膣内出しするだと！？　やっ、あっ\n、あああぁ！　そ、それはダメであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オマンコに出されたら、妊娠してしまうのであるっ！　人間に赤ちゃん孕ま\nされてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああっ！　んひっ、あっ、うぐっ！　くっ、んんっ！　あっ、あひぃ！？\n　お、オチンポが膨らんでいるのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ダメであるぅ！　膣内は……膣内に出すのだけは……！　ひっ、あああぁ！\n？　んはああああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぎいいいぃ！？　オマンコの奥にザーメン出されているのであるぅ！？　\n熱いのが子宮に届いて……んふっ、おほおぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「びゅるびゅる出てるの、感じるのであるぅ！　発情オマンコがザーメンを悦\nんで受けいれて……ひぎっ、んっ、んくうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ！　こんなに出されたら、本当に妊娠してしまうのであるっ\n！　それはダメなのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んくっ、ふぐっ、くううぅ……！　ダメなのに感じて……！　この妙な背徳\n感と気持ちよさで、イッてしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　来るっ！　オマンコの奥から気持ちいいのが来るのであるぅ！\n　ああっ！　イクッ！　イクのであるうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……はぁ、んんっ……！　人間にしつけられて、イッてしまっ\nたのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「しかもこんなにザーメンをオマンコに出されるなど……あってはならないの\nである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ……んんっ……！　早くかき出して、ドクターにメンテしてもらわなけ\nれば……んっ、くうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あれ……？　オチンポが抜けないのである……！　オマンコが勝手に\n締まって、オチンポを咥え込んでいるのである……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ち、違うのである……！　これは物足りないとか、そういうことでは……！\n　うぐっ、んんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んふっ……そのまま腰を引いて、オチンポを抜いて欲しいのである…\n…！　そう……その調子で……！　んひいいいいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なっ、なんでまた動くのであるか！？　抜いて欲しいと言ったであろう！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「一度出したくらいでは満足できない……！？　それに、我のしつけもまだ終\nわってないだと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そんな……！　あれだけ出したというのに、まだ満足していないというのか\n！？　くっ、あっ！？　ひぎっ、んんっ、あはあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉ……！？　また子宮口にオチンポの先端があたっているので\nあるぅ！？　あっ、はひっ、んくうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それに今度はオマンコの浅いところにもオチンポがあたって……！　そこを\n擦るのは、反則であるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の弱点を交互に突くのはダメであるぅ！　そんなに刺激されたら、オマン\nコがそなたのオチンポに屈してしまうのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　王としての威厳がなくなってしまうのであるっ！　このままで\nは、スレーブたちにも見放されてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、あひっ、んひいいぃ！　このままでは、我はそなたのモノになって\nしまうのであるっ！　愛玩マシンにされてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「性処理道具として使われるなど、あってはならないのに……！　あっ、うぐ\nっ、おっ、おおおおぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「頭ではダメだと理解しているのに、我の身体がそなたのオチンポを求めてや\nまないのであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたのオチンポで支配されて、メス犬にして欲しいと思ってしまうのであ\nるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、あぎっ、んひいぃ！？　またオチンポがビクビクしているの\nであるっ！　イッ、イクのであるかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「このまま膣内に出されたら、本当に我はそなたのモノになってしまうのであ\nるっ！　それだけはダメであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「出すなら膣外に……！　膣内はダメであるっ！　これは命令であるっ！　膣\n内に出すのはやめるのであるうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んあああああああぁ！？　あっ、あっ！　ひああああああぁぁぁぁぁ～～～\n～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ら、らめっ！　出てるのであるぅ！　濃厚なドロドロザーメンが、オマンコ\nの奥に注がれているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の子宮に入りこんできて……あっ、ひぎっ、あぐううぅ！？　熱いっ！　\nオマンコ焼けそうであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「膣内で出すなと命令したのに……！　あっあっ！　ザーメンでオマンコ感じ\nすぎるのであるっ！　我もイクのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああっ、あっ、ああああぁっ！　イクッ！　イクッ！　イクうううううぅ\n～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ……あっ……！　んっ、はああぁ……膣内出しされて、オマンコが悦ん\nでいるのであるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の身体が……そなたのオチンポに屈している……もう、王として君臨でき\nないのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これからはそなたに支配されて生きて行くしかないのであるな……んっ、あ\nふっ……あっ、はああぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたの好きなときに身体を差し出し、使われる存在に……スレーブになる\nのであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00002003_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これからもたくさんしつけてやるだと……？　我はもうそなたのモノなのだ\n……好きにするがいい……」", "NORMAL" ]},
