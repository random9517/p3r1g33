		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ！？　あはああぁ！？　ザーメンが身体にかかって……んふっ\n、くうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0304401" ]},
