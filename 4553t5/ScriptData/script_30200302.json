		{"command":[ "SETIMAGE", "0", "still_00002003_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「えっ……？　まだしつけは終わってない……？　ここから本番だと……！？\n」", "NORMAL" ]},
