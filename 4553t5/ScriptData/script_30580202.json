		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ！　おっ、んおぉっ……奥ぅっ……チンポが当たって、イイク\nっ……もうイクっ！　イクよっ……あんたも、きてっ！」", "NORMAL" ]},
