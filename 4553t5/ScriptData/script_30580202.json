		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ひぃああぁあぁぁぁっ！　あっ、あんっ……んっあぁぁぁぁ～～～～っ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204301" ]},
