		{"command":[ "PLAYVOICE", "v2_058_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ、はっはひっ……なん、だい……この量は……こんなに出されたら\n、妊娠しちまうよぉ……はっ、あぁっ……」", "NORMAL" ]},
