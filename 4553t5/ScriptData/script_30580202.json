		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「出てるっ！　あんたのザーメンが、あたしの中にっ……ドクドク出てるっ！\n　ひぃあっ、あっ……あっはっあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
