{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁっ！　おっ、奥にっ……当たって……！　くひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「どうしたんだい……今日はやけに激しいじゃないか……んっ……ああぁっ…\n…あんたの、チンポ……すっごく大きくて、硬くなってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204102" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「くはぁっ……んっ、ああっ……お、おお、きい……中が、いっぱいになって\nて……擦れるぅ……ひぃ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「な、なに？　水着……？　あたしの水着が、エロいから……いつもより興奮\nしてるって？　それは嬉しいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあっ……あ、あんっ！　いい、いいよ……あんたのチンポも……\n最高だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「こうやって、あんたに喜んでもらえるなら……水着、着てきてよかったよ…\n…んっ、はあぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……んっ、あたしもすごく興奮してる……あんたに見られてると思う\nと意識しちゃって……全身が火照ってくるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……気持ちいいよ……いつもより感じる……なにって、あんたの\nチンポに決まってるだろ……くっ、あっうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「それにしても……水着を着ただけで、こんなに違うもんなんだね……ちょっ\nとびっくりだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「似合ってるかい？　ふふっ、もちろん嬉しいさ。あたしもたっぷり楽しませ\nてもらうからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、あんたも好きに動いていいから……さっきみたいに激しく突いてちょ\nうだい……んっ、ンンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ！　あっ、あぁぁっ……そ、そうっ……そこぉ……奥っ、チンポが当\nたって……押し上げられるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んっあっ！　はぁぁぁっ！　はぁ、はぁっ、熱い……チンポ、熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「い、いぃっ……いいよぉ……あたしの中を……んっ、あんたのチンポで、か\nきまわしてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ！　すごいっ……奥、えぐられてるっ……！　こ、こんな感覚\n初めてで……あっ、はあうぅっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、頭がおかしくなりそうだよ……ひぃぐっ……んっ、あぁっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あ、あんたは……どうだい？　ちゃんと……感じてるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ああ、わかるよ。あたしの中でビクビクいってるのが……それだけ興奮して\nるってことだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁあっ……う、嬉しいよ……もっと動いて、あんたの好きなよ\nうに……あたしのオマンコを味わってちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁあぁぁっ！　は、はぁンっ！　そ、それ……すごいっ！　身体が、飛び\nそうで……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ンっ、ふぅうううっ！　腰が、勝手に動いちゃう……ひっ、ひぃああっ……\n！　あんっ！　あはぁぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「くっ、ひぃいっ……んっあっ！　だ、だめ……このままじゃ、あたしだけ…\n…イ、イク……先にイッちまうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あんたも、イキそうなら……はぁっ……ンっ、早く……んっ、ンンっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっと強くするって……今でも、十分……ひぃうっ！　はっ、はひ\nぃっ！　ひっ、ひぃああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「む、無理無理っ！　こんな……耐えられないって……！　すぐイッちゃうか\nら……気持ちよすぎっ……んっ、んぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、あっ、はぁっ！　あ、あんたも……もうすぐかい？　もうすぐイキそ\nうなのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ、このままっ……中にっ！　あたしの中に出してっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっあぁぁっ！　あ、あんたのチンポが……また大きくなってるっ！　中が\nっ……お、奥がっ……いっぱい、でぇっ……ひぃぐぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　いいっ、気持ちいいっ……！　も、もうイクっ……！　ダメっ\n、我慢できない……あっあっ……ひぃあっ、あぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「イクイクイクぅぅっ！　チンポで子宮グリグリされながら、イクぅうぅぅぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あひぃいっ……！　だ、出してっ……あんたもイッて！　あたしの中\nに、ザーメン出してぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「んひいぃぃぃぃっぃぃぃっ！　はっはぁあっ……ひぃ、ひぃぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はぁぁっ……出てるっ……熱くて、ドロドロしたザーメンがぁ……あ\nたしの中に入ってくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あ、あぁっ……子宮まで、ザーメン注がれて……アソコが熱くって……んん\nっ……気持ちいいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅっ……んっ、あぁっ……あんたのチンポが中で暴れて、ドクドクいって\nるのがわかる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあ……ま、まだ出てる……なんだい、この量は……はっ、ンっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あ、あたしを孕ませるつもりかい……一応、訓練なんだろう？　でも、まあ\n……相手があんたなら悪い気はしないけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「……んっ、そろそろ終わりかい？　それにしてもたっぷり出たねぇ……お腹\nがパンパンになってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「だけど……あんたのチンポ……まだ硬いままだね……？　満足できなかった\nのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「逆？　いつもより興奮してるから、もっとヤリたい？　ははっ、いいよ。な\nら、このまま二回戦といこうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ！　い、いきなり……すごいじゃないか……頼もしいねぇ……んっ、\nンンっ……出したばっかなのに、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「本当に好きものだね、あんたは。あたし、そういうの嫌いじゃないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そういうあたしも……人のこと言えないね……はっ、うぅんっ……こうやっ\nてチンポ咥え込んでよがってるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そういうとこがエロい？　ははっ、ありがとよ……そういってくれると嬉し\nいよ……子宮がうずいちまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっ、ううぅっ！　ひぃうっ、んぁあぁぁっ……だめ、声が……我慢できな\nい……あっ、あんっ！　あんっ！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「もっと、かわいい声……聞かせろって？　からかうんじゃないよ……かわい\nい声なんて……ひぃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「もうっ、意地が悪いねぇ……んっ、ああっ！　わかったよ……変に我慢はし\nないよ……というか、我慢できない、から……ひぃあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……！　あたしの中を、あんたのチンポがゴリゴリ擦っていく\nっ……んっ、ぐっううっ……強烈すぎるよ、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はあっ……あ、あたしの腰使いもなかなか？　ありがと……でも、こ\nれ勝手に動いてるの……あんたが激しくするからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ひっ、ひぃいっ！　ほ、ほらぁ……そうやって、ガンガン突き上げるから…\n…勝手に腰が跳ねてぇっ！　ひあっ！　あはぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はっはひっ……あぁっ！　すごいっ……さっきよりチンポ硬いよ、んっ……\nそれに熱いし、どうなってるんだい……ンぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「こんなチンポで突かれまくったら、またイッちゃうよ……はひっ、ひぃいっ\n……あぁ、はぁぁんっ！　ら、らめぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はひっ……ひぃぐうっ！　あっ、あぁっ……なんだい、ザーメン欲し\nいかって？　そりゃ欲しいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あんたにもイッて欲しいんだよ……どこに出してもいいから、は、はやく……\n！　んっ、あああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あ、あたしだけ……イッても意味ないんだよ……あんたと一緒にイキたいん\nだよ……あっ、ひぃあぁぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はっあっ……！　あぐっ、んっ……ひぃいいっ！　イ、イキそう？　\nあんたも出そうなのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00005802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「だ、出してっ！　あたしで……イッて！　あんたの精液が欲しいっ……さっ\nきみたいにぃ……うぅん、さっきよりもっと欲しいの！」", "NORMAL" ]},
