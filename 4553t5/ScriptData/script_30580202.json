		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……熱いし、クサいし……濃厚なザーメンだね……せっかく着てきた水\n着も、あんたのザーメンまみれだよ……」", "NORMAL" ]},
