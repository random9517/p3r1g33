		{"command":[ "PLAYVOICE", "v2_058_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「水着？　そうだね、これも着て正解だったみたいだしね。また着て欲しいの\nかい？　もちろんいいよ」", "NORMAL" ]},
