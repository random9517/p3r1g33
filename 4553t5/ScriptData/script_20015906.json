{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「前回までのあらすじ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「くすっ……張り切っていらっしゃいますね、ヒルダお嬢様」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あっ、レイアお姉様っ……はい、しっかり説明をすることが皆さまにも分か\nりやすいかと思いまして……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「どの皆さまかはともかく、今までの状況は整理しておきたいところですね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい。事の始まりは、時間帝国のジェスタさんが作り上げた怪しい発明品に\nよるものからでした」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「今の次元と、私たちが住むミッドガルドの次元を繋いでしまったところから\n始まったんですよね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「その通りです。それで、フレイヤ様とフェンリルさんが、こちらの世界に呼\nび出されました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「その時、私たちは彼女たちとミッドガルドの方で戦っていましたが……やは\nり、近い場所に飛ばされてしまいました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「そこで出会ったのが、今私たちがお世話になっている、ＥＤＯの皆さんたち\nです」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「私たちの次元から一緒に流されてきた魔族たちを共に撃退したことで、何と\nなく意気投合したと言いますか……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「結果的には、共通の敵ができたというのは大きいのかも知れませんね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「とは言え、私たちもずっとのんびりしているわけには行きません。元の世界\nに戻るためにも次元の裂け目を調査する必要がありました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「ミッドガルドの街は素敵でしたね！　活気があって、とても華やかで……食\nべ物も美味しくて……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「もう、ヒルダお嬢様ったら……だけど、そこで私たちが出会ったのは……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい。時間帝国の人と行動を共にするフレイア様やフェンリルさんでした」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そこで初めて、私たちは自分たちが大きな陰謀に巻き込まれていることを知\nったのです」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「戦いになって……時間帝国のもっと怖そうな方が現れて……人質も取られて\n危ないところでしたが……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そこで、今まで姿を見せていなかったスクルドが突如現れて、人質を解放し\nてくれました！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「突如って……あはは……。でも、そこから先は正々堂々とした戦いです！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そうですね、再び厳しい戦いになりましたが、急に私たちの力が元に戻って\n……何とか勝利を収めることができました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「さて、これから私たちの運命はどうなってしまうのか！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「引き続き、私たちの活躍をご覧ください！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}