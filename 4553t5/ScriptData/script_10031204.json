		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もうこうなったらなんでもいい！　こっちが有利なのは確かなんだ！　この\nまま一気に押し切れ！」", "NORMAL" ]},
