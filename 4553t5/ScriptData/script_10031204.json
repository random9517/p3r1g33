		{"command":[ "SETNAME", "時間帝国兵Ａ" ]},
		{"command":[ "SETTEXT", "「エファナティカ様！　やれますよ！　勝てます！　アナ（ピ～～）グ忍者も\n、さすがに見慣れてきましたし！」", "NORMAL" ]},
