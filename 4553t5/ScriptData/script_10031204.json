		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "SETTEXT", "そして、俺の目の前ギリギリでドリフトして停車したデコトラ宇宙船の中から\nは――", "NORMAL" ]},
