{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0139" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………はっ！　ここは……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "大戸岐学園の保健室……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0227" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ああ、落ち着いてください。焦ることはありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、焦ってないけど。なにやってんだお前」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あなたにお話があります。いいですか？　どうか落ち着いて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あなたはここ最近の寝不足と、EDO本部でのドタバタによる精神的な混乱\nのせいで、気絶していた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりそういうことか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ええ、ええ、わかってます。どれぐらいの長さか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「２時間ぐらい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あなたが眠っていたのは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにをもったいぶってんだよ。もしかして、もうちょい長かったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「２時間です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「正解じゃねえか！　だからなんでそうもったいぶる必要があんの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いいじゃないか。ちょっとぐらい付き合いなよ。これがやりたくって、わざ\nわざ保健室に運んできたんだからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116420007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら最近、ネットミームに影響され過ぎじゃねえのか？　まあいいや、そ\nういうことなら帰って仕事しないと――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って――あれぇっ！？」", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "書類がみんな片付いてる？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「隊長代理！　街のパトロール終わりました―！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116420001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「ご苦労さま。あと３０分でつきみは勤務終了ね。いちおう待機していて、な\nにもなければ帰っていいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116420001" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「りょーかい！　……って、あれ？　カツマさん！　もう大丈夫なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116420002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　よかった、元気そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……ちょっと疲れが溜まってただけらしくって……。っていうか、これ\n、どういうこと？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いやぁ……あんたが急に倒れちゃって、その間、隊長不在もまずいってこと\nでさ。昴に代理を頼んでみたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116420001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「新人にいきなり！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、私も心配だったんだけどねえ。本人はできるっていうし、試しにやら\nせてみたら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116420002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みたら、この状況ってことですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その通り！　あんたがため込んだ書類なんかあっというまに片付けちゃって\nさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116420003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジすか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "並大抵の量じゃなかったぞ、あの書類！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それを見たら、さっきまで文句言ってた連中も黙るしかなくなっちゃって！\n　驚いたね、あれは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116420004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いやぁ～いい新人が来てくれて助かったわ。おかげで仕事も片付いたし、私\nゃこのへんでドロンさせてもらうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116420005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「また飲みに行くんですか。まあ、いいけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「んじゃ、そういうことで。皆さん、お先～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116420006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。昴殿の仕事ぶりに感心されているのはわかりますが、もう少しその\n顔どうにかなりませんかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いつものアホ面が、さらにアホ面になっておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへー！　お前に言われたくねえよアホ犬！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}