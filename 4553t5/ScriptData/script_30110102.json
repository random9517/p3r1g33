{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁ、あのっ、にいさま……？　す、すごく恥ずかしいんですけど、この格好\nじゃなきゃだめですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまも裸だから恥ずかしくないだろうって……そんなわけないじゃない\nですかあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふわぁっ！？　あ、にいさまのおっきく……なってます……。こ、こすり\nつけちゃやあ、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こんなに熱くなってる……は、早く入りたいって……そんな、んうっ、擦り\nつけてくちゅくちゅしないでえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「えと、おっぱいは……その、あんまり大きくないからっ、ひゃあっ、触りや\nすいからいい？　うぅ……あ、ありがとう……ございます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「くぅんっ、さきっぽ、とんとんってしちゃっ、ふぁあっ、んきゅっ、押し込\nむのもえっちでっ、やあです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「つっ、つまむのも……くりくりするのも、ぜんぶえっちなんですっ！　もう\nっ、にいさま、からかってますね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　緊張ですか？　あ、とけてますね……。にいさま、ありがとうござい\nます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……はい、にいさまの好きなようにしてください。さっきから、熱くってど\nくどくして、中に入りたいって言ってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、おちんちんのさきっぽっ、わたしの中に……ぐって入って、きつ、い\nっ、けど……だ、大丈夫……です……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、ぎ……っ、ぃ、たぁ……っ！　熱くてっ、固っ、いのが……ぎちぎち\n……ってっ、入ってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「だぃ、じょう……ぶっ、ですっ、ゆっくり……なら、んぅっ、んくっ、ふっ\n、あぁああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぅっ、ふぅ……っ、にいさま、そんなに心配そうな顔、しないで下さい…\n…。わたし、嬉しいんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまの、どくどくって、脈打って……んっ、わたしの中ぁっ、いっぱい\n、にっ、んくっ、んうう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぅっ、ぁ、あたま、撫でてもらえると、痛いの少し、おさまって、きゃぅ\nっ、ふぁっ、んんん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「奥、とどきました……か？　嬉しい、にいさまと１つになれた……。にいさ\nまも嬉しいんですか？　良かった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ゆっくりなら、動いていいですよ……？　動かないとダメなんだって、その\n、本で読みましたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃふっ、んんっ、にいさまの、動いてます……っ。わたしの中、全部ごり\nごりって、削ってる、みたい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んきゅぅっ、一番奥ぅっ、とどっ、いてっ、ます……っ！　あかちゃんの部\n屋、とんとんしてるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「えっ、上を向いて……で、んっ、ちゅっ、れろ……ちゅぷ……っ、ちゅるっ\n、んっ、ぷぁっ、キス……されちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おっぱいも触るんですか……？　気持ち良くなると痛いのも少しは収まるか\nら……？　じゃあ……いいです……よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁんっ、ちくび……気持ちいいっ、です、んふっ、ぁあんっ、指ではさん\nで、されるのいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あれっ、どうして、おなかの奥っ、熱くなってきてっ、ふしぎなかんじ、し\nます……っ！　これっ、なに、にいさまぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「背中ぞくぞくってしてっ、声っ、出ちゃいます……っ！　ふぁんっ、ああっ\n、おちんちん、気持ちいいです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んふっ、ああっ、首筋にキス、強くしたらっ、跡がついちゃう……っ！　ひ\nめさまに見つかったら、そんなのっ、だめえ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おなかの奥っ、とんとんってぇっ、にいさまのが叩いてるぅ……っ！　でん\nきっ、走ったみたいになっちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまの熱い……っ！　ぞりってこすってきてっ、おなかの裏側っ、へん\nな気持ちになって、んふっ、あっ、ああぁぁあ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぁっ、足っ、広げちゃっ、見えちゃ……にいさまのっ、わたしの中に入っ\nてるの見えちゃいます……っ！　ふぁっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「乳首くりくりしながらぁっ、かきまわしちゃだめえ……っ！　んきゅっ、ん\nぁっ、ふぁあっ、あああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んきゅっ、ふぁあっ、ぁあんっ、腰、勝手に動いちゃう……っ！　身体ぁっ\n、全然言うこと聞いてくれなひっ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「やだあっ、あそこにぃっ、にいさまのが、出たり入ったりしてっ、じゅぷじ\nゅぷってえっちな音しちゃってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまもっ、気持ち……っ、いいですか？　わたしでちゃんと気持ち良く\nなれてますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「目の前っ、ちかちかします……っ！　こんなのっ、こんな気持ちいいのっ、\nおかしくなっちゃっ、ふぁっ、きゃふっ、んきゅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「だめぇっ、ふわふわして、こわいっ、にいさまぁっ、ぎゅって、ぎゅってし\nててくださっ、ふぁっ、んぅっ、きゃふっ、あっ、ああああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぁあっ！　にいさまの精子がっ、おなかの奥に当たってますっ！　熱いっ\n、凄い勢いでえっ、びちゃびちゃって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「まだ出てる……どくどくってするたびに、奥に当たってる……。にいさまの\n、わたしの中で出しちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……ちゅむ……ちゅる……れろ……ぷぁ、キスされると、おなか\nきゅうってします……ぁ、また……出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさま、動かしちゃダメです……じゅぷじゅぷ音しちゃう……。恥ずかし\nいです……いやあ、足、広げないでえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁ……止まっ……た？　にいさま、終わり……ですか？　わたしの中、気持\nち良かったですか……？　変じゃなかったですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁ……にいさまの、あふれてきちゃってます……。どろどろであったかい…\n…やだ、ごぽごぽって音してるよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……ぇ、あの……にいさま、まだ……全然、おっきい……まま、ですね？　\nまだ、足りなかったりするんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あの、にいさまが足りないって言うなら、わたしは……その、まだ頑張れま\nす……よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「けど、ええと……頭撫でてくれたら、もっともっと頑張れると思うんです。\n……えへへ……にいさまの手、優しくて好きです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んくっ、にいさまのが、わたしのに擦りつけられてる……。精子がぐちゅぐ\nちゅ音立てて、すごくえっちです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、さきっぽ、飲み込まれてくの見えちゃう……。わたしのが、にいさま\nの食べちゃってるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁっ、んっ、にいさまの精子と、わたしのでぬるぬるだから、すぐに奥ま\nで来ちゃいました……。痛みも、ほとんどない、かも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁあっ！？　に、にいさまっ、そんなっ、激しく……！　最初か\nらそんなに強くされたらっ、わたしっ、どうなるか……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃぅっ、子宮……っ、そんなに叩いちゃっ、声が出ちゃっ、んっ、ふぁあ\nっ、んきゅっ、んん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぅっ、おなかの上から、奥のところっ、刺激したらあっ、あたまっ、気持\nち良くってっ、ばちばちってしちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぁんっ、んきゅっ、んんっ、くぅん……ッ！！にいさまの、気持ちいいで\nす……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「くぅんっ、おなかの中っ、にいさまのおっきいのがいっぱいで、何だか幸せ\nな気持ちです……っ、ふぁっ、んんっ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んきゅっ、ちゅ……ぷぁっ、キスされながら、動いてもらうの、好きです…\n…ちゅっ、んふっ、れろ……っ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁあっ、んっ、乳首、いじめないで下さい……っ、へんに力が入って、お\nなか、きゅうって……んきゅっ、あっ、ああぁああ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「身体あっ、びくびくってしちゃいます……っ、やぁっ、んんっ、くぅん……\nっ！　にいさまぁっ、わたし、にいさまぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「指っ、口に……ちゅ、れろ……ちゅぅ……っ、はむっ、れろろ……。にいさ\nまの指……ふやけちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んぁあっ、きゃうんっ、にいさまっ、腰っ、早いっ、です……っ！　わ、わ\nらひのなかっ、にいさまでぜんぶっ、いっぱいで……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまぁっ、じゅぷじゅぷって、恥ずかしい音っ、たててぇっ、わらひっ\n、わらひぃ……っ、もう、んきゅっ、きゃぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひぁっ、にいさまのが、ぷくって膨らんできて……そろそろ、ですか？　は\nい、下さい……わたしの一番奥、赤ちゃんのお部屋に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「きゃぅんっ、ああっ、んきゅっ、赤ちゃんの部屋っ、こんこんって突き上げ\nてっ、にいさまのっ、すごい……ふぁっ、あああぁ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「にいさまっ、にいさまぁ……っ！　わらひ、もうっ、らめぇっ、ふぁっ、イ\nク、イッひゃいます……っ！　あぁっ、んふぁっ、ああぁああ――っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ぁああああ……っ！！　出てりゅうっ、にいひゃまのっ、せーしぃ、　わひ\nゃひのにゃかっ、どくんどくんって、いっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あかちゃんのへやに、びゅーびゅーってあたってまひゅ……。にいさまの…\n…あかちゃん……できるかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、あふれてきちゃう……にいさまの……せいし……。ちゅるちゅるって\n……えっちな音してます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「まだ……出てるんですね……とくんとくんって脈打つたびに、精子がとぷと\nぷって奥に当たります……あったかい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁあっ、奥に押しつけちゃ、んっ、あ、赤ちゃんの部屋に入ってくるの分\nかっちゃいます……んっ、ふぁっ、また入って……くぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「おなか……いっぱいになっちゃってます。ほら、おなか、ちょっとぽこって\nなってませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こんなに出るものなんですね……ふえ？　にいさまはちょっと特別？　やっ\nぱり隊長になるくらいだから、すごいんですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んん……っ、にいさまのが内側を引っ掻いて……精子かきだして抜けていっ\nちゃう……あ、シーツに精子こぼれちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……。すごい……まだこぽこぽってあふれてきてます……。に\nいさま、たくさん出したんですね……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　またエッチしたい、ですか？　……はい、わたしも……にいさまとし\nたいです。だから、いつでも言って下さいね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あっ、どうして抜いちゃ……あっ、んふぁっ、んん……っ！　ずるずるって\n、にいさまの熱いの、中掻き分けてっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！　？　にいさまのっ、精子……顔にかかって……熱い……。びち\nゃびちゃって顔に当たって……あ、胸元にこぼれちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁ……んっ、にいさまに染められてく気分です……。すごい、びくんびく\nんってして、まだ出てます……きゃっ、ぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「髪も胸元も、精子でべたべたです……。こんなに出るなんてすごいですね、\nにいさま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001101_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　手でしごくんですか？　ひゃぁんっ、まだこんなに出て……顔がドロ\nドロです……。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「手のひらにもこぼれちゃいました……。んっ、ちゅぅ……れろっ、じゅる…\n…んっ、ぷぁっ、ふふっ、にいさまの味です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ふぁ……んっ、にいさまの精液でシャワー浴びたみたいになってます……。\nすごく、にいさまのものにされたみたいな気分がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「んぅ……やっとにいさまのが小さくなってきました……。すごく出ましたね\n……精液の匂いでむせかえるみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「……また、一緒にシャワー浴びますか……？　こ、このままじゃ部屋にも帰\nれませんし、キレイにしないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はい、じゃあ一緒に入りましょう。……えっちなイタズラはダメですからね\n？　……少しならいいですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
