		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「もう、おうち帰るぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「そうかそうか！　帰りたいか！　だったら帰してやろうじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ハイパー・ルナテミスが叫ぶと、アルティメット・ドラグソードの手の中に巨\n大なバットが現れた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「え！？　ちょっと待ってなにすんの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010116370002" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「やめてやめてやめて～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010116370002" ]},
		{"command":[ "SETCHARA", "0", "char_00016302_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0224" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「逆転満塁！　ドラグソード・ホーーーーーームラン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アルティメット・ドラグソードが力強くバットをスイングすると、円盤少女た\nちは宇宙空間に快音を響かせてすっ飛ばされていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「もう！　もう！　もぉーーーーーっ！　あんた、ほんとに大嫌いーーーーっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010116370003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「もうちょっとだったのにーーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010116370003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "固唾をのんでその様子を見守っていたインクレディブル・スクワッドの面々は\n――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やった！　やったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さすがです！　ルナテミス様……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お見事ですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「終わったんなら、早く船返せーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ハイパー・ルナテミスは、歓声を上げる仲間たちを見てニヤリと笑う。しかし\n――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あれ？　ちょっと待て？　どうやって元に戻ればいいんだ？　おい、アナザ\nー！　アナザーはどこいった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「『どこいった？』って……融合してるんでしょ？　だったら、そこにいるん\nじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ！　そうだった！　それじゃ下僕！　カツマはどこ行った――って、\nまさかカツマも私の中か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマがルナテミス様の……な、中ですって！？　どどどどどどど、どうい\nうことっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「落ち着きなカグヤ！　そういうことじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「カツマなら、さっきからあっちの岩陰でひっくり返ってっぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116370002" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと！？　おい、カツマ！　起きろ！　なにをのんきに寝ているんだ起\nきろっ！　私とアナザーを分離させろ―っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370005" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「無理を言うなルナテミス。カツマはフュージョンを媒介して、力を使い果た\nしたんだ。当分は起きないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370006" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだとぉっ！？　それまで貴様と合体してなきゃならんというのか！　冗\n談じゃないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370007" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「おいカツマ！　起きてなんとかしろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「だから無理だと言ってるだろうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370009" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんに無理させないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116370001" ]},
		{"command":[ "SETCHARA", "0", "char_00001499_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさーいっ！　カツマ！　カツマ早く起きてくれぇ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_250116370010" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やれやれだ……ルナテミスは、ハイパーになっても相変わらずだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010116370002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「結局ルナさまはルナさまなのねぇ……」", "NORMAL" ]},
