		{"command":[ "SETIMAGE", "0", "still_00001703_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、いえ……別にイヤなわけじゃありません……むしろ、すごく嬉しいで\nす……」", "NORMAL" ]},
