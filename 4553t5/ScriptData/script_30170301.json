		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「熱いの、気持ちいいですっ！　もっとかけてっ！　私のこと、穢してくださ\nいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふあぁ、あっ、んふぅ……！　あっ、あっ！　気持ちよすぎて、頭の中が真\nっ白になっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「なんだか……正義が悪に染まるみたいで……ひあっ、あああぁ……！　たま\nりません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お、お願いします……！　レイジョーベビーを……！　正義のヒロインな私\nを、悪のヒロインに染め上げてくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふああぁ……おっぱいの中、ザーメン塗れでヌルヌルしてる……はああぁ…\n…たまりません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふふっ……こんなにされたら、レイジョーベビーは本当に悪のヒロインにな\nっちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっ……？　別に正義でも悪でも、どっちでもいい……？　私があなたのヒ\nロインであることが、一番大事……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、そんな……！　わ、私なんて……ゴレイジョーの中では、一番下ってい\nうか……なんていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「で、でも……嬉しいです……私のことをヒロインって思ってくれるのは……\nあなただけですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　か、顔に精液がかかってますっ……！　い、勢いよく射\n精しすぎです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303401" ]},
