		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ゴレイジョーの私も、普段の私も……どっちも、あなたのモノにしてもらえ\nたみたいで……」", "NORMAL" ]},
