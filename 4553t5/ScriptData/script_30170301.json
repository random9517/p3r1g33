		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あはあああぁんっ！　また、おっぱいの中にザーメンがどぴゅどぴゅ出てる\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303301" ]},
