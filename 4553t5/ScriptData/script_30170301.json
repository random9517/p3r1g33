	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーベビーの衣装って、よく見たらちょっといやらしいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00001703_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、でも……こういった衣装を着たら、あのひとは喜んでくれるのかな…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00001703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「興奮してくれて……この姿のまま、あんなことや、こんなことしたりとか…\n…あううぅ……！　へ、変な妄想が止まりません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00001703_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001703_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、はああぁ……！　そんな、無理やりオチンチン擦り付けるなんて……\n！　んっ、くふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はひっ、ふっ、あぐっ……！　お、おっぱい……そんなに強く揉まないでく\nださい……！　衣装が、破けちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあ……あっ、はうぅ……そんなに、このレイジョーベビーの衣装が気に入\nってくれたんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　お、オチンチンがまた大きくなって……！　んんっ……！\n　こういうの、好きなんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「男を誘惑するような悪い生徒は、お仕置きと教育が必要……？　私、そんな\nつもりじゃ……ああんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふくっ、う、ぐうぅ……！　はぁ、ああぁ……！　おっぱい揉みながら、オ\nチンチンをスリスリしないでくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、ダメ……あっ、ううっ……！　ふぎゅ、くああぁ……！　そんなにさ\nれたら、感じちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ち、乳首も……どんどん大きくなってきて……！　ああっ！　やっ、んっ…\n…！　浮き出てきちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんなの、エッチすぎますっ……！　あひっ、いっ、ああぁ……！　み、見\nないでくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「誘惑してたことを認めるかって……？　み、認めます……！　認めますから\nぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わ、私は……こんなエッチな衣装を着て、男の人を誘惑する悪い鬼です……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ですから、あなたのオチンチンでいっぱいお仕置きして、これ以上男の人を\n誘惑しないように、教育してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふああぁ……！　あっ、あっ！　さっきよりも、オチンチンが激しく動いて\n……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私のおっぱい、オチンチンでいっぱいになってます……！　デコボコしたと\nころが、擦れてますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、んっ、あっ……！　熱いのが肌と触れ合って擦れると、すごく感じち\nゃうっ……！　あああっ、き、気持ちいいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「太いオチンチンが出たり、入ったりするの……見てるだけで、オマンコ感じ\nちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んんっ……あぐっ、んあああぁ……！　オチンチンから、エッチな\nお汁がどんどん溢れて……ふきゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、はあぁ……！　エッチなお汁、私のおっぱいに塗りたくられて……ん\nっ、ああぁ……！　エッチな染みが拡がってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やああぁ……！　ローションみたいにヌルヌルで……ぐちゅぐちゅって、い\nやらしい音がしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はひっ、んんぅ……！　あふっ、ふくうぅ……！　オチンチンが擦れる音で\n、気持ちよくなるなんてっ……あああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それに、オチンチンの先っぽから……蒸れたニオイもしてきてます……！　\nすんすん……ああっ、とっても濃いニオイがします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「このエッチで、濃厚な香り……大好きです……！　あなたのオチンチンのニ\nオイ……すごく感じちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「もっと……！　もっといっぱいスリスリして、感じさせてください……！　\n私のおっぱい、好きに使ってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「エッチなお仕置きと、エッチな教育……たくさんしてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあああぁん……！　あっ、あっ……！　おっぱい、握りつぶされて……！\n　あああっ、そんなにされたら、乳首が潰れちゃいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あああぁ……！　パイズリされながら、乳首押されるの……気持ちい\nいです……！　子宮が疼いちゃいますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んぐっ、あっ、はうぅ……！　くあっ、んふっ……！　お、オチンチンが、\nいっぱいビクビクしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そろそろ……出そうなんですね……！　は、はい……遠慮せずに、出してく\nださい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私も……あなたの精子が欲しいって思ってます……！　クサくて、熱い精子\n……出して欲しいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私の胸に……！　おっぱいの谷間に、あなたの精子……たくさんかけてくだ\nさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、ひあっ……！　オチンチンがおっぱいの中で激しく暴れて……！　あ\nっ、あっ……！　うぐっ、んくううぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「来てっ……！　来てぇ……！　ドロドロの精子、いっぱい出して……！　射\n精してください～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふひっ……あっ、あっあっああぁ……！　出てますっ……！　熱いの、たく\nさんおっぱいに出されてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ネバネバしたザーメンが、私の肌にいっぱい……！　ああっ、火傷しちゃい\nそうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あひっ……！　んっ、はああぁ……！　そ、そんな……射精しながら\n、動くなんて……はあああぁあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんなことされたら、おっぱいに精液のニオイが染み付いちゃいます……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひああっ、ふぐっ、んふううぅ……！　ああぁ……！　わ、私の身体……精\n液のニオイでいっぱいになっちゃいますぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、はああぁ……私のおっぱい、すごくドロドロしてる……ふふ\nっ。たくさん出してくれたんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……は、はい。私……いっぱいオチンチンでお仕置きされて、教\n育されました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「でも、まだ足りません……もっとエッチなことして欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いつもより、エッチな気がする……？　ふふっ。だって今の私はレイジョー\nベビー……悪のヒロインじゃなくて、正義のヒロインですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「正義のヒロインは、エッチなことが大好きなんです……だから、もっとして\nください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ……ふああぁ、あぅ、ひあああぁ……！　また、おっぱいの中\nでオチンチンが動いて……！　はんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひぎっ、んあっ、やあぁ……！　精液のヌルヌルが加わって、滑りがよくな\nってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「擦られるたびに、おっぱいがひしゃげて……あっ、あっ！　私のおっぱい、\nオチンチンのカタチになってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それに……エッチなニオイも濃くなって……すん、すんすん……！　とって\nもクサイです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ……！　でも、いっぱいオチンチン感じられて……すごく嬉し\nいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「オチンチンのデコボコしたところが、おっぱいに引っかかって……んっ、ん\nんっ……！　また乳首が大きくなってきちゃいますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あああぁ……！　また、そんなに強くおっぱい揉むなんて……！　本\n当に、おっぱいが好きなんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふふっ……私もおっぱい揉まれるの、好きです……！　だから、もっと揉み\nながら……オチンチン、スリスリしてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひふっ、んんっ……！　あっ、うぐっ……はぁ、はああぁ……！　いい……\nおっぱい、気持ちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あああっ、あっあっ……！　んひっ、いいいっ……あっ、ううぅ……んくう\nぅ……！　やっ、ダメ……感じすぎるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんなのイッちゃいますっ……！　オマンコ、気持ちよくなって……あああ\nっ！　もう我慢できません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、あなたもイキそうなんですか……！？　なら、一緒に……一緒にイッて\nください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「レイジョーベビーを……穢してください……！　正義のヒロインを、あなた\nの精子で真っ白にしてくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　オチンチンが膨らんで……！　あああっ、来るっ……また、\n精子きちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あふっ、んんっ！　い、イクッ……！　あっ、イクッ……イクイクイ\nクッ！　イクぅぅぅぅ～～～～～！！」", "NORMAL" ]},
