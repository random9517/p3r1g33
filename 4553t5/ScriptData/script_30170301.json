		{"command":[ "SETIMAGE", "0", "still_00001703_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あぶっ、んんっ……！　あふっ、んふうぅ……！　く、口の中にザーメンが\n入っちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んちゅ……あっ、あっ……！　身体の外だけじゃなくて、中も白く染められ\nるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんなの、正義とか悪のヒロインじゃなくて……あなただけのヒロインにな\nっちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あああっ！　ダメ……！　そんなの、嬉しくてまたイッちゃいます……！　\nあっ、んああぁ、ふああああぁぁぁんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いろんなところが……精液まみれになっちゃいましたね……」", "NORMAL" ]},
