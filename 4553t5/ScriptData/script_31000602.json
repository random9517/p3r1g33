		{"command":[ "PLAYVOICE", "v2_100_0604305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……残念だが時間切れだ。アソコに挿れるのは諦めてもらおうか」", "NORMAL" ]},
