		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああぁ……！　だがその情けない感じがいいっ……！　必死に私を犯し、孕\nませようとしたその姿勢……！　そしてこの精子……最高だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あっ！　気分が高まるっ……！　ダメだっ……イクッ！　\nまた潮を吹いてしまうっ……！」", "NORMAL" ]},
