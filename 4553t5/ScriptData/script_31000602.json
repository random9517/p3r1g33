		{"command":[ "PLAYVOICE", "v2_100_0604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならば今ここで宣言しろ……私はあなたの性処理奴隷です。いつでもどこで\nも、命令されるがままにペニスを差し出します、とな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604308" ]},
		{"command":[ "WAITINPUT" ]},

