		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ペニスを抜いてアソコに出していいと言ったのに、ケツ穴\nに出すとは……んっ、はああぁ……！」", "NORMAL" ]},
