		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ！　ほらっ！　どうした！？　ペニスを抜いていいんだぞっ！\n？　んっ、あっあっ！　くっ、んふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
