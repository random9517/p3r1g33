		{"command":[ "PLAYVOICE", "v2_100_0604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のケツ穴で射精して……！　精子のムダ打ちをしろっ！！」", "NORMAL" ]},
