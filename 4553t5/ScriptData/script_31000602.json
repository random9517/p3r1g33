{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら、どうした……もっとチカラを込めて私を支えろ。じゃないと、挿れさ\nせてやらんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……せっかくこうして、日頃の恨み、つらみを返す機会を与えてやっ\nたんだ。頑張らないと損だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……ふふっ。おまえのカタいモノがケツ穴に当たって……はああぁ……\n！　これはたまらないな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっあっ……！　オナニーをする手が止まらなくなってくる……！　私のア\nソコが、ペニスを挿れてと疼いているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっと……残念だが、今日はこっちの穴は使わせないぞ。おまえは私のケツ\n穴にペニスを挿れるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604105" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「普段と違う穴の方が、仕返しするには丁度いいだろう……？　ふふっ。ほら\n……挿れたければ、さっさと挿れてみろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……んふっ……！　おい。いつまで焦らす気だ？　まさか、入ら\nないとでも言うんじゃないだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぷっ……！　あははっ！　そうか、私のケツ穴の締まりがよすぎて入らなの\nか！　そんな無様にヘコヘコ腰を振って、情けない奴めっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604108" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この様子では、せっかくの機会が台無しになってしまうな……しょうがない\n。私からペニスを挿れてやるとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「オンナのケツ穴も満足に貫けられないお粗末なチンポに、引導とご褒美を与\nえてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　おっ、おおおぉ……！　ずっぽりと奥まで入ったな……！\n　これがケツ穴へのペニスの挿れ方だぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……！　あっ……！　どうした。挿れてやったんだから、さっき\nみたいにヘコヘコ動いたらどうだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「腰を振るしか能のない猿なんだから、せめてピストンくらい満足にこなして\nみせろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああっ、あっあっ！　いっ、いいっ！　体勢のおかげで、腸の奥にペニス\nが突き刺さるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このゴリゴリと抉られるような感覚……！　やはりケツ穴セックスは最高だ\nな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　アソコからもどんどんエッチな蜜が溢れてきている……！　\nもうヌレヌレだぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んひっ、あっ、おおおぉ……！　ペニスが子宮の裏側をトントン叩いてくる\nっ……！　なんだ、そんなにアソコに挿れたいのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ならば私のケツ穴を満足させてみせろっ！　そうすれば、前の穴にも挿れさ\nせてやらんこともないぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、んおっ！？　おっ、んほおおぉ……！？　急に動きが激しくっ……！\n　おおおおおぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「カリの部分が腸を抉ってくるっ……！　それに、肛門がズルズル擦れて……\nあっ、んひっ！　気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「その調子でもっと腰を振れっ！　私への怒りをペニスに集中させて、もっと\n大きくさせてみろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んひっ、んくうううぅ……！　ペニスが一回りほど大きくなっ\nて……！　おおおぉ……け、ケツ穴広がるぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604122" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んおっ！？　ぐっ、おっ、おほぉ！？　肛門がズポズポされて、何度も引っ\n張られるっ……！　ケツ穴がめくれ上がりそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だがこの快楽こそ、私が求めていたものだ……！　いいぞ……！　これで私\nのオナニーも捗るというものだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんんっ！　あっあっ、ふっ、くふうううぅ……！　クリトリスも\n大きく勃起して……！　軽く触るだけで、快感が止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このいやらしい音が聞こえるか……！？　私のアソコとケツ穴が感じている\n証拠だぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604126" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぐっ……んっ、あっ……！　また一段と動きが激しくっ……！　ふふっ…\n…今の音で余計に興奮したようだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私も興が乗って来たし、少し手伝ってやるっ……！　しっかりと身体を支え\nていろよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ、んんんっ！　ぐっ、あっ！　はああああぁんっ！　どうだ、ペニスの\n動きに合わせて、ケツを動かされる気分はっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうやってグリグリと……円を描くようにしてやれば……あははっ！　面白\nいくらいにペニスが跳ねるなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　このビクビクした感覚が子宮にも伝って……！　ああっ、\nたまらないっ！　すごく感じるぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これなら、もうすぐイケそうだ……！　おまえもイッていいから、もっと速\nく動いてケツ穴をズポズポしろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっおっおっ！？　んふっ、ぐっ……おほおおおおぉ……！　くっ、くるっ\n……！　アソコの奥から、すごいのくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえもイキそうなんだな……！　ああ、遠慮せずに出せ……！　私のケツ\n穴に、びゅるびゅる射精しろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私のケツ穴を孕ませるくらい、熱くて濃いのをいっぱい出してみろっ……！\n　あっ、あっ！　イクッ！　イクッ！　イクうううううぅん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあああああぁ……！？　あっ、あっ……！　ケツ穴に精液流し込まれなが\nら、潮吹きしているぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああぁ……！　おしっこしているみたいで、たまらないっ……！　こんな\nの、何度でも潮を吹いてしまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ……あっ、くううぅ……！　ケツ穴も焼けるように熱いっ……！　や\nはりおまえの精子は格別だな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスと精子、あと腰使い以外はまるでダメだが……ふふっ……！　私とし\nては、これさえあれば文句はないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほらっ……もっと出せっ……！　溜まっているザーメンを全部吐き出して、\n私を屈服させてみせろっ……！　んっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「中々の射精だったが……まだ物足りんな。それにおまえももっと、私に仕返\nししたいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なに？　腕が疲れてきた？　もう限界だと？　ふふっ……ならば、腕もペニ\nスも元気になる言葉をくれてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お願い、カツマ……もっと私のザーメンまみれのいやらしいケツ穴、いっぱ\nいズポズポして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「カツマの精子で、ケツ穴が孕みたがってるのがわかるでしょ……？　もっと\n動いてっておねだりしてるの、感じるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから私のエッチで淫乱なアナル……もっとほじほじして……？　いっぱい\nぎゅ～～～って締めてあげるから……ね、お願い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっあっ！　ふっ、あああっ！　あはっ！　あははははっ！　どうやらやる\n気になったようだなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あんな生娘のような言葉に惑わされて腰を振るとは……おまえはつくづく情\nけないオトコだなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、その性欲に素直で情けないところ……私は大好きだぞ……！　んっ、\nくっ……好きすぎて、もっとイジメてやりたくなるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほらっ……約束通りいっぱいケツ穴を締めてやるから、もっと腰を動かせっ\n！　ふぐっ、んんっ……んっ、んんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くっ、んふううぅ……！　ケツ穴を締めれば締めるほど、アソコが疼くぅ…\n…！　おっ、オナニー止まらなくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「指がもうエッチな汁でドロドロになって……あっ、ひっ、あっ！？　アソコ\nからどぷどぷ溢れて止まらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　奥の方もぬちょぬちょのぐちょぐちょで……！　ねっとり\nした糸が指先に絡みまくっているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ここにペニスを挿れたら、絶対に気持ちいいだろうなぁ……！　ふふっ……\nそう思わないか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっ、んほぉ……！？　ペニスがビクビク跳ねて……！　あははっ！　言葉\nではなく、ペニスで返事をするとはなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、あっ、くああぁ……！　ケツ穴だけでなく、アソコにも挿れ\nたいという想いが伝わってくるぞっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「子宮の裏側を執拗に突いて……！　そんなに私を孕ませたいのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……ならばペニスをケツ穴から抜いて、アソコに挿れてみせろ……！\n　これは仕返しする機会なんだ。遠慮しなくていいぞ……！」", "NORMAL" ]},
