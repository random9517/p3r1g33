{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「……来ましたね。私の部屋に呼ばれた理由、理解しているでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「とぼけた顔をして……お前、妹に……うららにいかがわしいことをしている\nでしょう。していないとは言わせませんよ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「本来ならこれ以上うららに手を出せないよう、文字通り手足を斬り落として\nついでに股間も斬り落とすべきなのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「不可解ですが、うららはお前に想いを寄せている様子。お前だけのゲスな好\n意なら、処して終わる話なのですがね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ゆえに、遺憾ながら……非常に遺憾ながら、私が先手を打つことにしました\n。さあ、覚悟してもらいましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00027502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ほら、大人しくしてください。暴れないで……暴れるなっ！！　そう、大人\nしくおちんちんを出せばいいんです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「こんなに大きいの……いえ、なんでもありません。こんな、こんなグロテス\nクで大きいものをうららに……やはり許せません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「もう二度と、うららに手を出さないよう、私が精を吐き出させてあげます。\nうららに会う前に、毎回毎回……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「それでは……んむっ、れるっ、れろっ……ちょっと舐めただけでがちがちに\nなってるじゃないですか。やはり、誰でもいいのですね……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんっ、ふむうっ、んっ、んんっ、苦っ……こんな味……やっぱり、こんな\nことをうららにさせるわけにはいきませんね……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んぐっ、んっ、ふうっ……ふふっ、だんだん分かってきましたよ。この段差\nになってるところを舐められると……れるっ、ほらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「おちんちんがびくってなってますよ。こういうのが好きなんですね。では、\nこういうのはどうですか……んっ、ちゅっ、ちゅうっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「これでも反応してるじゃないですか……結局なんでもいいんじゃないですか\n？　ほら、こんな風に、んむっ、れるっ、ちゅっ、んふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふうっ、先っぽからお汁が出てきましたよ……知ってますよ、これ、我慢\nしているときに出てくるって……んっ、れるっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「これも苦い……んっ、ふうっ、ふっ、んむっ、れろっ……ふふ、顔も切なそ\nうになっていますね……気持ちいいんでしょう？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「やっぱり、うららじゃなくても興奮してる……誰でもいいんでしょう？　だ\nから私が搾り取ってあげます、んむっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっ……私だから興奮してる？　そっ、そんなこと……誰が信じるものです\nか……私じゃなくても、うららじゃなくてもいいんでしょう、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「そんなお世辞は言わずとも、きちんと搾り取ってあげます。うららに手を出\nすなんて考えないように……れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ほら、先端からまたあふれ出てきましたよ……んっ、ふうっ、ふふ、顔もお\nちんちんもびくびくしてる……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「気持ちいいですか？　出したいですか？　でもダメです……簡単には出させ\nてあげませんよ。んっ、ふうっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「焦らせば焦らすほど、濃くて多いのが出るのは知ってますからね……一回で\nもううららに手を出せないぐらい、出してもらいますから……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふ、ここからこうやって咥えこめば……んっ、んむっ、んぐっ、んんんっ\n、ちゅぶっ……ふうっ、さっきよりもおちんちんが震えていますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「今度はこうして全体に唾液をまぶすように舐めて……れろっ、れるっ、れり\nゅっ、んっ、ふうっ、ふっ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「最初とは比べものにならないぐらい大きくなりましたね……んっ、むっ、ん\nぶうっ、んっ、ふうっ、ふっ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぶっ……では、そろそろ本格的に口の中に……あー……むっ、\nんっ、んんっ、んふうっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふうっ、んっ、口の中でおちんちんが暴れてますよ……出したいんですね\n。顔もそんな表情になってます……んむっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ぷはっ……でも、まだダメです。まだ、おちんちんの中でずっとずっと貯め\nて、限界まで溜めてください。でないと出させませんから……あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ、んむうっ、んんっ、じゅぷ、じゅるっ、れるっ、ちゅっ……ふ\nふっ、頑張って溜めてますね……んんっ、んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「じゃあ、次はこうやって……舌先で先端の筋をぐりぐりって、んっ、れるっ\n、れろっ、ちゅっ、んんっ、れろれろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰が跳ねてますね……そろそろ我慢の限界ですか？　そうですね、\nここまできたら濃いのが出そうだし、いいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんっ、んぐっ、れるっ、ちゅっ、ちゅぶっ、ちゅっ、れろっ……準備は整\nいました、それじゃあ、んっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「射精まで、三……んっ、んんっ、んむっ、れろっ、ちゅっ……ふうっ、んぐ\nうっ、んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「二……れるっ、んむっ、んっんっんっ、一……ふっ、うっ、んむっ、じゅる\nっ、ちゅっ……最後のカウントダウン、いきますよ……あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ゼロッ……んんんんっ！！　ふうううううっ、あっ、凄い……大量の精液が\n……んんんっ、あっ、ふうっ、んうっ、熱いっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あうっ、んっ、ああっ、どれだけ、出すんですか……あくっ、まだ出てる…\n…んっ、ふうっ、ふっ、あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんっ、んぐっ、んっ、んむうっ……ふうっ、口の中からあふれ出て……ん\nっ、匂いも味も濃くて……んっ、んくっ、こくっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふうううっ……んんぐっ、ごほっ、ごふっ、んふううううっ！！　全部、全\n部吸い出さないと、またうららが……んっ、ちゅっ……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふうっ……ふっ、んっ、んぐっ……はっ、どうですか、全て飲みこんであげ\nましたよ。これで今後うららには……ってなぜ私の頭を撫でるのですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「そのような事は不要です……感謝の気持ちって、そんな顔で言われたら……\nもう……そんな風にしてうららも口説いたのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「でも、そうですね……少しだけ、悪い気はしません。誰かに感謝されるとい\nうのは、久しぶりですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「その素直さが貴方の美点なんでしょうね……私も、そういうのは嫌いではあ\nりません……いえ、好きですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「きゃっ、あっ、またおちんちんが……今の好きは男女の好きではないですよ\n……あんっ、んっ、もう、違うって言っているのに……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふっ、それじゃあ、お互い好きだと想いあって、もう一回、してみますか\n？　おちんちんはまだ硬いままで、このままじゃうららが危険ですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「好き……好きですよ、あんっ、またおちんちんが、分かってます？　ごっこ\nだって言ってるのに……好き、好～き、んっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「貴方のおちんちんは私のことを好きだ好きだってびくびくしてますね。私の\n口も、貴方のおちんちん……好きですよ。れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふ、嬉しそうな顔をして……じゃあ好き同士、キスしましょうか。ちゅっ\n、んっ、んむっ、れるっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、またお汁がいっぱい……ちゅっ、んくっ、んっ……じゃあ、口の中\nでも、あー……んっ、んっ、んむうっ、んっ、んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、ぷはっ……ふふ、よだれと、お汁と、先ほどの精液で、おち\nんちんがべとべとですね……んむっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んぐうっ、んっ、んんっ、ふっ……んっ、一回出したのに、もうがちがち…\n…一回じゃ足りませんでしたね。でも、そんなところも、好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ！？　またおちんちんが跳ねて……ふふ、おちんちんへの告白だから\n、これが正しいって……そうかもしれませんね。じゃあ、口で……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んむっ、んぶっ、れろっ、ちゅっ……ふふ、好きですよ。おちんちん、好き\n……んっ、んむうっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「おちんちんも口の中で好きだって応えてますね……んっ、んむっ、んぐうっ\n、れるっ、ちゅっ……んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んふうっ、口とおちんちんがキスするたびに、先っぽからお汁がどくどくっ\nて……ふふっ、またいっぱい溜めているんですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「さっきも凄い勢いで出たけど……次もそれぐらい出そうですね……んっ、ど\nれだけ溜まっていたんですか……れろっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「私がこんな熱心にしてくれるからって……ふふ、そう言われて悪い気はしま\nせんね。私も、素直なおちんちんは好きですよ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅっ、ちゅぶ、んっ、じゃあ、そろそろ出してもいいですよ。限\n界までぐつぐつに溜めた精液、いっぱい出してもいいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「さっきと違って、貴方の好きなタイミングで、好きな場所に出していいです\nよ……顔でも、口でも、胸でも、どこでも、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ほらっ、ちゅっ、れるっ、れろっ、私の唇で好き好きってしてあげますから\n、それとも、あー……むっ、んっ、んうっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「口の中の方がいいですか？　どっちでもいいですよ、んっ、んむっ、れるっ\n、じゅるっ、ちゅっ、んむうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ほら、イって。イって。おちんちんから、精液いっぱい出してイって。私に\nいっぱい出して……んんんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んうううううううっ、んんっ、んぐっ、んむぶうっ、んっ、んんっ、んっ、\nんぐううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんっ、んんぐっ、んむうっ……はっ、あっ、二回目なのに凄い……さっき\nよりも出てませんか……？　そんなに私の口が好きなんですね、ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んぐっ、ふっ、んっ……んんっ、飲みきれない……量も多いし、粘っこくて\n、喉に絡んで……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「もう一回出させておいて正解でしたね……こんなものを溜めたままうららに\n会わせたらどうなったか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、んふうっ……ふっ、全部、飲みましたよ。まだ舌に味が残っ\nてる気がします……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「まったく、今までうららにこんなものを注いでいたなんて……まったくもっ\nて度し難いことです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「これは、やはり私が身をもって管理しなければなりませんね。うららにこん\nな精液を負担させるのは勿体な……危険ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ですので、これからはうららに会いに行く前に私の所にくるように。拒否権\nはありませんよ。私はあの子の姉ですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「その代わりに私が貴方の溜まったものを全部吐き出させてあげます。今日み\nたいに、すっきりと。そうすればうららとも健全な関係になるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふ、なんなら今からもう一回でもいいですよ？　あの子に邪な想いを抱か\nないように、たっぷりと……してあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「あんっ、おちんちんが……んっ、ふあああっ、あっ、顔に、精液が……ふう\nうううっ、あっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んんんんっ、凄い匂い……んんっ、顔が、貴方の精液でべとべとに……んっ\n、ふううっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「まだ……出るのですか、んっ、くううっ、んっ、ふうっ、まるで精液で化粧\nされているみたいです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「ふふっ、全部出ましたか……？　なら、よかったです。これでうららに出そ\nうなんて気はなくなったでしょうしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「それで……なぜまだおちんちんを硬くしているのですか？　ぶっかけられた\n私の顔がエロいからだって……かけたのは貴方でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「まったく、本当にいやらしいことばかり考えていますね、貴方は。これは、\n今後も監視が必要です。ええ、うららのためです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「だから、今後溜まってきたら私の所に来るように。今日みたいにしっかりと\n、たっぷりと抜いてあげますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「その後でなら、うららに会うことを許可しましょう。しかし、この約束を破\nったときは……分かりますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「その代わり、いつでもどこでも、私に溜まったものを吐き出していいですか\nら。悪い話ではないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00027502_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "静夜" ]},
		{"command":[ "SETTEXT", "「んっ、またおちんちんが反応してます。それじゃあ、約束ですよ……？　私\nは、いつだって貴方に応えてあげますから、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}