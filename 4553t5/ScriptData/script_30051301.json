		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁんむっ、くぽっ、んっ、ちゅぷっ、んりゅぷぅぅ……あもっ、んっ、ふ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303107" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あぁ……とっても逞しいオチンポ……んちゅぷっ、ん……やっ\nぱり大きいれふ……んくぷぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぽっ、ちゅぷっ、お口の中でオスのにおいが……広がって……ん\nりゅぷぅっ、んもっ……はぷっ、ふごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んちゅぷぅ……慌てず……んっ、まずは……りゅぷっ、亀頭から\n……しっかり、丁寧に舐めていきまひゅ……ちゅぱ……ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んれろ……れろぉ……んれる……れりゅぅ……割れた部分に……ねろねろと\n……舌先を這わせてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、唾液を……まぶしたら……んちゅぷっ、今度は……裏筋のとこぉ\n……ぴちゃ……ちゅぷ……んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふふっ、オチンポがぴくんってしましたね……今の場所……弱いですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「いいれふよ……もっと、いっぱい舐めていきますからねぇ……れろっ、れろ\nぉっ、えろっ、れろっ、れろぉんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁぷ……少し……汚れが残ってます……ダメですよ？　どんな時でも……\nオチンポは清潔にしておきませんと……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「今日のところは……ちゅぱっ、ウチが綺麗にしてあげますから……んちゅぱ\nっ、はぁぁぁ……んんっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「いえ……ちょっとクラクラしただけです……ちゅぷっ、ウチの好きなにおい\nなのです……んんっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……ダメです……もうちょっと我慢しないとと思ってましたが……止ま\nりません……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……ごめんなさい……オマンコが……疼いてしまって……手が勝手に、\n大事なところ……弄って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、オチンポへのご奉仕は続けますから……ちゅぱっ、はい……あむ\nっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「今度は……ちゅぷっ、もう少し深く咥えて……んっ、皮を……りゅぱっ、お\n扱きしまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふぶっ、むぐっ、んっ、うんっ、んふっ、うんっ、りゅぷっ、くぷっ、んふ\nぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……大きい……口の端から……よだれが……こぼれひゃいまひゅ……ん\nんっ、おっきいの……りゅぷっ、ふごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んじゅぷっ、くぷっ、んりゅぷぅぅ……あぁ……指も、はっ、ん\nんっ、動きまひゅ……んっ、オマンコ……ジンジンするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あんっ……あぁっ、駄目です……そんなに、オマンコばかりじっと見ないで\n下さい……んんっ、は、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ハロウィンの衣装を見てるだけ……？　嘘です……今までそんなこと殆ど言\nったことないじゃないですか……か、可愛いなんて……そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……ずるいですっ……今……そんなこと言われたら……ウチはチョロ\nいって思われちゃうのにっ……嬉しくなってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぷっ、んちゅぷっ、そんなことを言うなら……んりゅぷっ、もっとオチン\nポっ……しちゃいまふれふっ……んちゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ほら……んんっ、ここは気持ちいいれひょう？　んふっ、オチンポの震え方\nでバレバレです……ちゅぷっ、ウチの舌でメロメロになればいいれふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「れろっ、んれろぉっ……ここの筋のところぉ……カリのとこもぉ……んっ、\nちゅぱっ、弱いとこだらけれふねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ、オチンポプルプルさせてるの可愛いれふ……はぁんっ……\nウチの指も……んっ、オナニー止まらないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、お汁……滲んできちゃう……んちゅぷっ、あぁ……オチン\nポからもお汁……浮いて……んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、りゅぷっ、ウチのいやらしい姿を見て……興奮してくれてる……ん\nふっ、嬉しいれふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「このまま……我慢しないで、出してくらさいっ……熱い……精液っ、びゅる\nびゅる……らひてっ、ウチに飲ませてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んじゅるるるっ、ちゅぷぅっ、んちゅっ、ちゅうぅぅぅぅぅぅっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ！　んぷぁっ、あふっ、れてまふっ……んんっ、元気な精液っ……\nいっぱいっ、らされてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっくっ、こくっ、んくんっ、んふぁっ……あぁっ……濃いれふ……んんっ\n、喉に残る……んんっ、んくぅ……こくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、はぷっ、ちゅぱっ……あぁ……ドロドロの新鮮な精液……ちゅぷ\nんっ、おいひぃ……んちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はふぁ……たっぷり出ましたね……んふぅ……ちゅぱっ、素敵でし\nた……れろ、ぺろ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……腰が抜けそうでしたか？　はい、お祭りの夜は特別です……お見せ\nしたことのないウチの姿……お楽しみ頂けたなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「さて……気持ちよく射精されたとは言え、まだまだオチンポは満足されてい\nないようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「こんなにビンビンに勃起したままで取り繕うことはありません。ええ、ウチ\nにお任せ下さい。まだご奉仕はこれからです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はんむ、ぴちゅっ……まずは、奥に残ってる精液を……綺麗に吸い出すとこ\nろかられふ……んちゅっ、ちゅぅぅぅっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……ふぉら、残ってました……ちゅるるっ……これを味わってる時…\n…ウチは幸せを感じます……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ、あぁ……オマンコまた……ムズムズします……んっ、指ぃ……\nしちゃいます……あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、気持ちいい……手が止まらないです……んっ、あふっ……\nんちゅぷっ、あっ、んむっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふっ……また、じっと見られてる……ウチのオナニー見て…\n…あむぅ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふふっ……さっきより勃起が大きくなってるですね……あんなに出したの\nに……本当に欲望剥き出しのオチンポです……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「でも、だからこそ……あぁんむ……んりゅぷっ、こうしてウチを狂わせる…\n…んちゅぱっ、本当に罪作りなオチンポ……れろ、んえろっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……んむっ、血管が脈打ってすごいれふ……ちゅぷぅ……んぱっ、あむ\n……れろ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、気持ちいいですか？　よかった……んちゅぷっ、ウチも…\n…気持ちいいです……ちゅぷっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「でも、今日のお触りはなしですよ……？　ふふ……生殺しですか……？　で\nも、ウチのご奉仕の日なのですから……我慢です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、その代わり……余計なことを考えられない位……ちゅぱっ、んち\nゅぅぅぅっ、きもひよく……ひまふからっ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あぁんむっ……んくぽっ、じゅぽっ、このバキュームが……んふぅっ、オチ\nンポに効くれひょう……？　んじゅぅぅっ……ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチの……んっ、持てる限りの技を……全部オチンポに注ぎ込んで……はぁ\n、んむっ、ちゅぷっ、またお汁滲んでます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はぷっ、んふっ、くびれのところが……ビクンってしてっ……ちゅるっ、し\nょっぱい味が広がってまひゅっ……オチンポおいひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ、はい……ウチのオマンコも……どんどんお汁が漏れて……止まらな\nい……あぁ、んむっ、指だけで……イキそうでふっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「はむっ、あっ……あなたと……一緒にイキたいですっ……もうすぐれふよね\n？　オチンポ……んっ、ビュクビュクッ……いっぱい射精してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あむっ、んちゅぷぅっ……ウチもオマンコイキますからっ……んぁぷっ……\nあぷっ、んんっ、オチンポもっ……早くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぱっ、りゅぱっ、じゅぱっ、じゅるっ、んじゅるるるるるるーっ！　んっ\n、じゅるるるうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ！　あぶっ……んんっ、れたっ……！　おくひにっ……まらっ\n、せーえきっ……れてまひゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000513_01_08" ]},
