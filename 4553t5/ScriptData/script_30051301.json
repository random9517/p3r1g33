		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んはっ……はい、後は……最後のお掃除だけしてしまいまひゅね……れろ、\nぴちゃ……んちゅぷっ、ちゅぅぅ……んっ、これで大丈夫です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
