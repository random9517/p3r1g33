		{"command":[ "SETTEXT", "「んぐっ、んっ、こくんっ……んっ、んふっ……あぷっ、あぁ……ん、ちゅぱ\nっ……はぁ……はぁ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1303302" ]},
