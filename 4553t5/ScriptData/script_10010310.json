		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ、それでいい。少しは貴様も役に立ってみせろ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010103100001" ]},
