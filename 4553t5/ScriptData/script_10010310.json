		{"command":[ "SETTEXT", "って！　あいつら思いっきり俺を見殺しにしようとしやがったじゃねえかぁ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だあああああっ！　どう考えてもあいつら、仲間じゃねえーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ど、どうしたんですか！？　急に怒り出して――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "まりあの携帯から着信音が鳴り響く。こういうセンシティブな時は電源切\nっておけよ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「っ！？　つきみ……！」", "NORMAL" ]},
