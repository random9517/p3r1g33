        {"command":[ "PLAYBGM", "BGM_004" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっかしいなぁ……カグヤ、そっちはどうだ？」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "さっきまではそこそこ拾えてたんだけどなあ……急に実入りが悪くなったなぁ\n……。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……これは？　さっき、カツマがいった大穴じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにっ！？　……って、こりゃ第３レースじゃねえか。かすってもいねえよ\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、いいけどよ。もうちょっと気合入れて探してくれよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "でないと、晩飯代も稼げねえ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、いいかげんにあきらめてください！　舟券を拾って生活するな\nんて、そんなの無理です！　無茶です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえなあ、だったら俺にどうしろってんだよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「帰りましょう、本部へ。みんなもきっと、喜んで迎えてくれます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなわけねえだろ、あの冷血女どもがよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大丈夫です！　きっと、アナザーさんもルナテミスも今ごろ後悔してますよ\n。言い過ぎたって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ないない！　それこそ絶対にねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ごめん……私もちょっと、それはないとおもう。アナザーはともかくルナテ\nミス様は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カグヤ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だろ！？　さすがにカグヤはわかってるよなあ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも……私も、帰ったほうがいいと思う。さすがに、これで生活なんて無理\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な！？　いきなりの裏切りかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「裏切りなんて、そんな……！　私は、カツマのためなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、いいよいいよ！　そんなにフォローしてくれなくてもよ！　だいたい\nお前ら、無理して俺に付き合うこたぁねえんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「二人だけで本部に帰ればいいだろ。そもそも、なんでお前らそんなに俺にか\nまうんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんでって、それは、その……だって、その……カツマが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ん？　なにをもじもじしてんだ、カグヤのヤツ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは、あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "おいおいおい？　なんか、まりあまで挙動不審だぞ？　いったいどうなってん\nだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「え、えーとですね？　やはり、私たち、カツマさんを置いて帰るわけにはい\nきません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、なんで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だって、それは……以前はいろいろありましたけど、今はやっぱり……仲間\nですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「仲間？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そ、そう！　まりあも、ルナテミス様も、みんな仲間……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「仲間ねえ……あいつらがねえ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETTEXT", "まあ、仲間と言えば、仲間、なのかな？　特に、グレート・ルナリアムでずっ\nと一緒に戦ってきた連中は……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ん……？　待てよ？　そういえばあいつら……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
