		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もしもし？　つきみ？　ごめんね？　わたし、今、カツマさんを説得してい\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100011" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん！？　ああ、よかった……！　お姉ちゃん、あのね！　こっち、\n今大変なことになっちゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103100001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大変！？　何があったの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103100012" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え、えっとね！　いったん電話を切って、動画を送るから！　詳しいことは\nそれを見て！　それじゃ！」", "NORMAL" ]},
