		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっ、ぐ……ううう！！　き、貴様ぁ……！　この俺を捨て駒にする気か！\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「冗談じゃねぇ！　お前らの言うことを素直に聞くと……思った、か！　ぐ、\nうううおおおおおお～～！！」", "NORMAL" ]},
