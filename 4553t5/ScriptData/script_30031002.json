{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やっと目を覚ましたか。ちょっと退屈でねぇ、お主のチ○ポを使わせてもら\nっておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうやって、余のマ○コをお主のチ○ポに擦りつけてな……。ふふっ、寝て\nいる間にもうガチガチじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、チ○ポがビクついたのう。じっくりと余の身体を見るがよい。せっ\nかくだから、サービスしてやろうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「見てよいと言ったとたんに、ギラついた視線で余を凝視しおって。この変態\nめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれほれ、チ○ポには余の素股を味わわせてやろう。竿に、裏筋に、余の\nマ○コを感じるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くくっ、それにしてもいやらしいチ○ポじゃなぁ。素股だけでビクンビクン\nしおって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、お主の視線も……。余の身体を舐めまわすような……サカった獣\nみたいだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「このチ○ポを、余のマ○コにぶちこみたくてたまらないといった感じかのう\n？　どうじゃ？　図星か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ○ポは嘘をつけないみたいだよ。ほらほら、こんなに火照って、亀頭も\nパンパンに膨れておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぶちこみたいか？　余のマ○コにこのチ○ポをハメたいか？　ちゃんと言わ\nないと、ずっとこのままじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれほれ、チ○ポをどうしたいのか、はっきりと口に出しておねだりするん\nだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……そう。そうかい。じゃあ、お望みどおりに余のマ○コにチ○ポをハメて\nやろうな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああぁぁぁっ！　焦らしただけあって、最初っからフル勃起\nチ○ポ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余のマ○コが、お主のチ○ポでいっぱいにひろげられておる……！　ああ、\nなかなか、よいモノじゃのう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしたのじゃ？　苦しそうな顔をしおって。余のマ○コの締め付けがキツ\nすぎる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これくらいで音を上げるとは情けない。お主の望み通りハメてやったのじゃ\nから、文句を言うな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて、余はこのチ○ポを愉しませてもらうとするかな。んっ、ああっ、本当\nにぶっといチ○ポじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「マ○コの中にみっちりと詰まっている感覚……ああっ、たまらないねぇ……\nんっ、あっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「中のヒダが、んくっ、お主のチ○ポにひっかかれてるのを感じるよ……んっ\n、ああっ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この快感……んっ、肉バイブとしては、あんっ、合格点じゃな……んっ、\nんふっ、よいぞ、お主のチ○ポ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、お主はこういう状況が好みらしいしな。女に跨られて、好き放題に\n腰を振られる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主はただの肉バイブとしか扱われない。それで興奮して、ますますチ○ポ\nを勃起させておるじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ！　中でチ○ポが暴れておる……。んぁっ、よいぞ、その調子で肉\nバイブとして余を悦ばせよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、お主も快感を得ておるようじゃな。その表情、射精を耐えておる\nようじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余のマ○コに、精液を搾り取られそうになっておるのだからなぁ。ふふっ、\nその必死の形相、ゾクゾクするわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主は肉バイブなのじゃからな、余の許しなく、勝手に射精したらどうなる\nかわかっておるよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しっかり我慢するのじゃぞ。ほれ、もっと激しく腰を動かすからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あっ、ああんっ！　射精我慢チ○ポ……んっ、んくっ、中で\nビクビクしてる……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よい、よいぞ……んっ、んっ、ああっ、チ○ポが膨れて、んくっ、ますます\n余のマ○コを満たす……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、どんどん腰が、ンッ、激しく動いて……ああんっ、お主の\nチ○ポをマ○コでしごいてしまうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、なんじゃ？　もう限界か？　んふっ、激しくされたらすぐに射精しそ\nうなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「仕方ないのう。もう射精しか考えてないような顔をしているし、射精を許可\nしてやろうかねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらっ、射精しなっ！　せっかく余が射精を許可したんだから、半端な射精\nじゃ許さんぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そらっ、そらっ！　射精しなっ！　思いっきり搾りとってやるからの！　\nんっ、ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あああぁっ！　ああっ、ああぁぁっ！！　来たっ、来てるっ！　お主の精液\nが、余に、中出し……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ、凄い勢いだね……。子宮に、精液の塊を打ちつけるみたいな射精を\nするなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにっ、んんっ、中で脈打って、まだまだ射精し続けてるよ……。んっ、\nお主のチ○ポ……やはり、よいのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、やればできるではないか。子宮を揺さぶられるような射精……この\n感覚、癖になりそうじゃのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もっとお主の射精を味わいたくなったわ。ほれ、まだまだ続きができるで\nあろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主のチ○ポは、余の中でまだまだ勃起したままじゃからなぁ。そして、\n余はまだ満足しておらぬぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「じゃから、このまま続きといこうではないか。んっ、ほれっ、ほれっ、また\n余のマ○コで、射精させてやろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はぁっ、ああっ、あれほど射精したというのに、まだまだチ○ポ\nは硬いままじゃのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余に、こうして肉バイブ扱いされるのが気に入ったのか？　んっ、んはぁっ\n、余も、この肉バイブが気に入ったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、単純な上下運動だけでなく、んくっ、こうして腰をくねらせるのは\n、どうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ○ポが余の肉襞にもみくちゃにされて……んふっ、ああっ、勃起チ○ポが\n暴れておるのぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ！　すごく、擦れて……んっくぅっ、よいところに、ごり\nごりと当たる肉バイブじゃ……んはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふぅっ、腰がとまらなくなりそうじゃ……ああっ、マ○コをかき\n回されて、蕩かされてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、お主からも動いたらどうじゃ？　余にばかり腰を振らせて\nいるでない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「肉バイブらしく、余をイかせるような腰振りをしてみたらどうじゃ？　お主\nにそれができればの話じゃが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……んくっ！　あっ、ああっ！　安い挑発に乗りおって……んふっ、必死に\n突き上げてきおる……あっ、ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よ、よいのう……んっ、んんっ！　一人で動くより、深くまでチ○ポが届い\nて……んっ、ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、んふっ、必死になって腰を振るお主の顔のなんとそそることか……\nんっ、ああっ、見ていると高ぶってしまうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、余も腰をもっと振ろうかのう！　中出しされて、ぐちょ\nぐちょのマ○コをもっと締めて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、んんっ、はぁっ、はぁっ！　よいぞ……よい……！　膣奥に届く、\nお主のチ○ポ……んっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「このまま、射精まで導いてやろう。んっ、ああっ、お主にまた、好きなだけ\n射精させてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それ、それっ！　また、きゅうとマ○コでチ○ポを締めつけっ、肉襞蠢か\nせて精液を搾りとってやるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁっ、ああっ！　膨らんだチ○ポ、ンッ、ビクビクしてまた\nイキそうだねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余も、イキそうだよ……。んっ、ああっ、お主にイかされそう……んっ、\nんふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「でもね、タダではイかないよ！　そらっ、お主もイッてしまえ！　射精して\nしまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ！　だせっ、だせっ、だしちまいなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああっ、ああぁああぁぁぁっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「思いっきりっ、また……中にお主の精液が注がれて……っ！　んふっ、熱い\n精液で、中が満たされていく……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。この感覚、よいのぅ……。たまらないねぇ……。ンッ、\nマ○コがきゅんきゅんするよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「二度目だっていうのに、こんなにたっぷりと射精するなんて、お主の性欲は\nサル並みか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まあ、肉バイブとしてはそれくらいがちょうどいいかねぇ。もうちょっと\n躾けないといけないかもしれないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ。それにしても、いつまでマ○コの中で勃起させているんだい？　\nもしかして、二回じゃ足りないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「仕方のない肉バイブだねぇ。まあ、余もお主のチ○ポをもっと堪能したいと\n思っていたところじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ネバつく精液を、たっぷりと中出ししてくれたチ○ポ……しっかりと余の\nものだと調教しなくてはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、光栄に思うがよい。お主は余の肉バイブ第一号なのじゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「一生コキ使ってやるから、覚悟するのじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ああっ、あはぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ○ポがっ、ンッ、抜けてしまったではないか……っ！　んっ、ああっ、\n精液が身体に……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「二度目だというのに、なんじゃこの量は……んっ、ああっ、ネバネバした汁\nが、こんなにも肌に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、臭いも強烈じゃ……んっ、はぁっ、鼻の中まで犯されてるような\n気分だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、余の身体に無断でぶっかけるとは、肉バイブの分際でいい度胸し\nておるなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「このような粗相をして、いったいどんなお仕置きをしてやろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、二度とぶっかけられないように、チ○ポの中の精液を全部搾り取っ\nてやろうかのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000310_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……と、脅したところで、お主のチ○ポは喜んでいるかのようにビクついて\nおるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、大した男よ。こんなふうに扱ってもチ○ポを勃起させられるの\nじゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やはり余の目に狂いはない。お主は肉バイブ第一号にふさわしい男だった\nようじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1004410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}