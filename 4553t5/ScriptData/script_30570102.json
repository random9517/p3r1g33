{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "057_0104101" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あはーん、隊長さん、御指名ありがとぉー！　橋元鳳子、参りましたーん！\n　あー、二人きりで会えるの、待ち遠しかったわぁー。フフフッ」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00005701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104102" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あんまり楽しみで、走ってきてもうたよぉ。……あ、そうやね。廊下は走っ\nたら駄目やね。うちとしたことが浮かれてしもて、お恥ずかしいわぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104103" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「さてさて、今日は何の御用なん？　……え？　うちの目、期待している？　\nそ、そそそそそそんなことないよぉ？　ちょっとワクワクしてるだけ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104104" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ服脱ぐね？　……なんや、嫌やなぁ。うちがっついてるみたいやん？\n　はしたない女やって思われたくないからね。ちょいと後ろ向こうかな」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104105" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ふあぁぁん！　ちょっとぉ、隊長さん……う、うちまだ……全部脱いでない\nよぉ？　もぉー、がっつかんといてよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104106" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ふぇ？　……あぁ、そうか。うちもがっついてたんやった。……じゃあ二人\n仲良くいやらしいことしたがってるってことで、いいよね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104107" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、隊長さんの手でおっぱい触られるの……好きぃ……。あはぁ……もっ\nともっと、強く揉んで……むにむににしてくれていいんよぉ？　はぅん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104108" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「このたっぷんたっぷんのおっぱいはぁ……隊長さんのものやからね。いっぱ\nいいーっぱい好きに弄んでいいんよ？　うちのおっぱい蹂躙してぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104109" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ！　ち、乳首も、そんな……あはぁ……や、やぁん。硬くなんて、な\nってないよぉ……もし、もしもやけど……硬くなってるんやったら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104110" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んううぅうん……た、隊長さんがぁ……弄るからそんな風になるんよぉ？　\nうちがエッチだからじゃないからね？　……あはぁ、聞いてるのぉ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104111" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「隊長さんやって……うちの乳首みたいに、オチンチン……硬くなってるやな\nん。……分かるよ、見てなくても。お尻に硬くて熱いの、当たってるもん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104112" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「やぁん、あはぁ……もぉ……お尻をオチンチンでツンツンせんでよぉ。フフ\nッ、すべすべのお尻気持ちぃの？　でもうちはじれったいよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104113" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「うちはさぁ、お尻じゃなくて……隊長さんのオチンチンに焦らされて焦らさ\nれて、涎垂らしてるオマンコを、ツンツンしてほしいんよぉ。駄目ぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104114" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　……あー、いやぁ……そりゃー、ツンツンだけじゃ……ちょっと物\n足りんかなぁ？　ズコズコだったりガツガツだったりしてくれた方が、うん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104115" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あぁん、してくれるのぉ？　そんなん、嬉しいやん！　……じゃあ思い切り\n、うちのとろっとろマンコ、隊長さんの熱ぅい勃起チンポで掻き回してぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104116" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んきゅぅぅううぅううぅうっぅ！　き、来たぁ！　隊長さんのオチンポぉぉ\n！　はぁぁん……そ、そんな……おおぉぉ、一気に奥までぇぇえぇ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104117" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「おっ、おひぃいぃぃ！　がっつき過ぎやわぁ……いきなりずっぷし……えぇ\n？　うちのマンコがぬるぬるやから滑ったぁ？　そ、そんなぁ、意地悪ぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104118" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「おほぉぉおぉぉ！　ぐっちゅんぐっちゅんいってるぅぅ！　ああぁ、違うん\nやってぇ……このマン汁はぁ、うちがエッチやなくてぇ……くぅん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104119" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「隊長さんがぁ……あはぁぁん、隊長さん……好きやからぁ……このマン汁は\n、うちの好きの気持ちなんよぉ！　どんどん滲んで溢れてくるのぉおぉお！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104120" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「こんな、恥ずかしい……犬みたいな格好でパコパコされてるのにぃ……好き\nぃ……！　隊長さんが、好きなのぉ……！　隊長さん、大好きぃいぃい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104121" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んくぅぅん、隊長さんのオチンポが……あはぁ……熱くて、オマンコ蕩ける\nぅぅ。ますますマン汁滲み出るぅうぅ……！　音、恥ずかしいのぉぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104122" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「後ろから腰叩きつけられて、オチンポで奥まで抉られる度に……ああぁ、オ\nマンコ、すっごい音してるぅうぅ！　んおおぉ、隊長さん、聞かないでぇぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104123" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「し、仕方ないんよぉ……隊長さんのオチンポ……はぁぁ、うちの子宮口に当\nたってるからぁ……おほぉ！　こんなの、マン汁止まらないよぉおぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104124" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んおおぉぉ！　うちのマンコのヒダヒダがぁ……隊長さんの太っといチンポ\nにいっぱい擦られて……はぁ、はぁ……頭真っ白になるぅうぅうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104125" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「気持ちぃんおぉ……マンコぉ……。隊長さんのチンポにズコズコされてぇ…\n…わ、分かるやろぉ？　きゅんきゅんって、マンコ締まってるのぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104126" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「隊長さんのオチンポ、もっと締めたい！　きゅぅぅうぅうって、大好きぃぃ\nいぃいって、マンコで隊長さんを抱き締めたいのぉおぉぉ！　んほぉぉお！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104127" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んひぃぃ！　隊長さんのチンポ、凶悪やわぁ……！　入れた時よりも、今の\n方が……大きいなってるの分かるぅ！　オマンコいっぱいになってるのぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104128" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ！　あーーーっ……そ、それぇ！　隊長さんのオチンポの\n先っぽで子宮をぎゅぅぅって押されるの……す、凄いぃいいぃ！　気持ちぃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104129" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「おほぉおおぉ！　子宮が歪んで、んくぅうぅ！　オマンコがぁ……びっくり\nしてるぅ！　気持ち良すぎてぇ、ブルブルしてるよぉおぉ！　んほぉぉおお」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104130" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ねぇ、隊長さん……気持ちぃ？　ねぇ、気持ちぃ……？　うちばっかり気持\nち良くなってない？　うちは、隊長さんを気持ちよくしたいのにぃぃ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104131" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「あはぁあぁ！　隊長さんのオチンポが……え？　どうしたん？　びっくんび\nっくん暴れてるよぉぉ！　あはぁ、うちのマンコがもっと震えるぅうぅぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104132" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「イくん？　隊長さん……うちのマンコの中で、イくんやね？　はぁん、いい\nよぉ……。うちの中でぇ、たぁーっぷりザーメン出していいよぉ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104133" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「うちの奥でぇ……出してぇ。……子宮の壁に、ザーメンいっぱいぶっかけし\nてぇ。　うちのオマンコに、隊長さんのザーメンの味を覚えさせてぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104134" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「中出ししてぇ！　隊長さんのザーメン、うちのオマンコでごっくんごっくん\n、全部飲み干すからぁ。……ああぁ、好きぃ！　隊長さん、大好きぃぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104135" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「んほぉおぉお！　で、出てるぅうぅ！　隊長さんのザーメン、うちの子宮に\nドクドク流れ込んでるの分かるよぉぉ！　……熱くてドロドロのザーメン！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005701_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104136" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「嬉しい、中出しされて嬉しいよぉおぉ！　うちのオマンコ悦んでるぅぅ！　\nああぁ、ザーメン浴びた悦びマンコが、イくぅ……！　イきまくるぅうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104137" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「おおぉおおぉお！　隊長さん、イってるよぉおぉ！　うちも隊長さんのオチ\nンポと一緒にぃ……イってるぅうぅ！　うちのマンコ、イってるのぉおぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104138" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「……んひぃいぃ！　気持ちぃいぃい……！　オマンコ、気持ちぃ……あはぁ\n……た、隊長さんのオチンポと一緒にイけるの、嬉しいよぉおぉ……んくぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104139" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……すっごい気持ちよかったぁ……。ああぁん、まだ抜かんで\nよぉ。隊長さんの中出しチンポ、もうちょっとオマンコで感じてたいのぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "057_0104140" ]},
		{"command":[ "SETNAME", "橋元隊員" ]},
		{"command":[ "SETTEXT", "「ああぁん……隊長さん、このまま……また大きく、硬くなってもいいんよ？\n　そしたら、またしよ？　うちの中でタマタマ空になるまでイきまくって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}