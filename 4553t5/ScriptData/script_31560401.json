{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あの……ちょっといいかな？　なんか、用が他にあるならいいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あ、大丈夫か？　……その、さ……。この前、おまえにコンビニで買っても\nらった雑誌に……気になることが書いてあってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「それを少し試してみたいんだ。付き合ってくれるかい？　う、うん……えっ\nと。何かっていうと……このページなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「『男を喜ばせるラブ☆ラブマッサージ』……あ、いや、こ、こっちの世界で\nはこーゆー情報がセキララに雑誌に載ってんだなァって。あはは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403104" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私は隊長しか男を知らないし……。ぶつぶつ……この世界で一番喜ばせたい\nとか思うのはおまえだけで……だから。わ、悪いんだけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「実験体になると思って協力しておくれよ。たぶん……おまえも男だから気持\nちいいはず、だし……。お願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「それじゃあ、失礼して……。んんっ……ああ……いつ見てもスゴいね。おま\nえのオチンポは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015604_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私の胸からはみ出して、それでもまだ足りないってくらいに顔を突き出して\nきてる……。あっ、や、やめな……私の顔を小突くんじゃない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「こ……こんなに大きなモノが、いつもアソコに入っているなんて……信じが\nたいよ。だって……絶対サイズが合っていないし。太すぎるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「でも……こいつがいつだって、私を喜ばせてくれているんだもんな……。う\nん……い、いつもありがとう……チンポさん。少しだけかもしれないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「感謝の気持ちを伝えたいから……マッサージさせてもらうね。お礼っていう\nか……いつも凝ってて可哀相だしさ。だから、ま、ゆっくりしててくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁ、はぁ……。まずは……パン生地でこねるみたいに、チン\nポ全体を揉みほぐす……。んん……、ふぅ……こうかな？　んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私の肌のぬくもりを……胸の形を、重さを、……っん……♪　記憶してもら\nって……。私の身体が気持ちいいって思って、もらって……はぁっ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「たくさん好きになっておくれよ……？　はぁっ……はぁ、んっ……。あぁ、\nこうか……。こうやって、上半身全部でこすりあげて……。ふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「うんうん。喜んでくれてるみたいだ……。あっ、す、少しペタペタしている\nな……。これは汗か？　オチンポから透明な雫が出てきて……。そうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んむっ……ちゅぅっ♪　こ、これはこうひて私の口で舐め取ればいい……♪\n　もごっ……もごもご、結構汗の量が多いから……。むぐ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「くぷぷぷ……♪　こうやっれ……。唇全体で吸い上げて……。ぴちゃっ、口\nの中れ……。ぢゅっ……。舌で巻き取って……。ちゅぅうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ん……、んっ、んっ、ん……。んん……？　あれ……、おかひいな……？　\n咥えて舐めれば舐めるほど、汁の量が増えているような……んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「何？　これは股間の汗ではなくて我慢汁という汁なのか？　カ、カウパー…\n…？　男が感じると滲み出してくるという、あの……。そうだったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「それなら分泌されるのは悪いことではないんだな。良かった……。うん、気\nにするな。良いものならたくさん出してくれ……全部舐めるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んー……。くぷっ……♪　くぷぷぷ……ちゅぅうう♪　くぷっ……ちゅぅ…\n…♪　ちゅぅうう……くぷっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ♪　私の唾でヌロヌロになったチンポが……ゴチゴチに硬く反り返って\nくる……♪　この巨大な亀頭と肉竿に、もっと唾液を垂らして……あ～～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ！　チンポ全体をぉ……一度に刺激ひゅるのはどうら？　ぐっちゅ\nっ……！　ぐちゅっ、グチュっ……！　水音を、たてながら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「乳房でチンポを圧迫ひて……♪　ぐちゅっ……♪　ぐちゅっ、ぐちゅ……ン\nン……♪　ぬぷっ……くぷっ！　ぐちゅっ……ぐっちゅうぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んんん……♪　だいぶやり方がわかってきたぞ……。あふ……♪　こぼれそ\nうな唾は、胸ですくいあげて……更にチンポに塗っていくぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「唾、をローションがわりにして、くっちゅくちゅ乳房でチンポを摩擦しなが\nら……口も同時に動かせば……どうだ？　ぢゅるっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「すっごく派手でいやらしい音が響くだろう？　チンポにダイレクトに伝わる\n快感……♪　んふふふっ……思ったよりすごい音がする、けれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「でも……おまえが嬉しそうだし、気持ちよさそうだからやめない……♪　ん\nむっ……こうか？　この角度で舐めるといいのか？　こっちか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ちゅっ……ぢゅっ……！　ぢゅるっ、ぢゅるるるるっ……ぐちゅぅうぅうう\nっ♪　あっ……！　今、お口の中で震えて……♪　フフフフ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私の胸が、口が……おまえに尽くせているのがうれひぃ……♪　拙い技巧で\n、感じてくれているのが……♪　んむ、むぅ……ぢゅるっ、ぢゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「はぁっ……ふぅううっ……ふぅ……っ、ふぅうう……♪　むぅ……♪　ぐち\nゅっ……！　じゅぷっ、ぷじゅっ！　ぐっちゅっぐちゅっ……んーーー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「えへっ……へへへっ♪　こういうのって、なんかちょっといいよね……♪　\n恋人にご奉仕ひてるみたいれ……。れろっ……ぢゅるっ、ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「なんか……やる気が出るよ。もっと感じてる顔見たい、感じさせたいって…\n…前のめりになってご奉仕しちゃうっていうか……。ん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あはははっ……。急におかしなこと言ってゴメン……。でも、今の台詞……\nチンポは嬉しいって思ってくれたみたいだね……。ほら……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私の頬、突き破りそうなくらい張りつめてる……。いいよ、こん中に……口\nの中にビュルビュルって出して……。んむっ……ぐぷっ、ぐっちゅっぐぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んぁ……んむっ……！　ぐっちゅっ……にちゅっ、ぬちゅぅううっ……ぢゅ\nるっ……！　ぐちゅっ！　ずっちゅっ、ぬちゅっ、ぬっちゅっ……んぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んッ……！？　んむぅうううっ……んぷぅうううっ……！　あふっ……ふぁ\nあっ、出てる……出て……。んっ、ぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あ……いいんだ、全部飲むから……。ごくっ……あふっ！　の、飲もうとす\nるとまた新しいのが溢れてきて……！　んぷっ……んんんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「わ、わかった……！　先に全部出しきっれくれ……！　わたひも精子を吸い\n出ひゅから……！　ぢゅーーーーっ……ぢゅるっ、ぢゅるるるる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んんんん……！　息が出来な、い……♪　精液で溺れるぅ……じゅるっ……\n。じゅるるるっ……ぢゅぅううう……ぐちゅぅううう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ん、ぷ……。やっと、やっと出終わったぁ……。んぁ……舌にネットリ絡み\nついて、喋り、にくい……。えふっ、ものすごい悪臭だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「とんでもない量を放ってくれたものだ……。で、も……。約束だから、飲ま\nせてもらう……。んん、口の中で転がして……唾と混ぜてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「飲みやすく、ひて……。ごく……。ンン！？　けほっ、けほっ……す、すま\nない。少しむせた……。これっ、精子……ひゅごいぞ、粘着力が……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「う、ぐ……。むむ……。んん……ごくっ……ごく……。はぁっ……♪　ま、\nまだ口の中に精液が残ってはいるが……大体は、飲めたはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私のテクニックも……以前よりあがってきているだろう？　ん？　お、おっ\nぱいでパイズリしたからこれだけ出た？　そ、そうか……胸か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「わかった。胸でしながらしゃぶるとたくさん出るのなら……両方駆使して頑\n張ってみる。さっきよりもテクニカルに……。リズミカル、に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ……。精液を出して柔らかくなりかけているチンポを丁寧に刺激して…\n…。っはぁっ、磨き、あげて……硬くして……。おお、いいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「徐々に力を取り戻していこうとしているところを……舌で舐めまくる……。\nんぁ……れろぉっ、れろっ、れろ……れるれるれる……れろぉおお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ……まだ精液の味が残って、る……。ぺろっ……この独特の舌ざわり…\n…。あむっ……普通だったら絶対飲めないような味、なのに……ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「なぜか舐めるのがやめられ、ない……。ぺろっ、れろっ……あふ……♪　こ\n、こういうの……。残った汁をお掃除するのって、あ、愛……なんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっちゅっ……ぢゅるっ……れろっ、くちゅ……ぢゅる……。ふぅ、\nふぅ……っ。綺麗にしてみせるから、楽しみにしていて、くれ……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ぐっぷっ……！　ぐっぷっ、ぐちゅっ……ぢゅるるる……！　ずっちゅっ、\nぷっちゅっ、ぷちゅっ……ぬちゅ……。あっ、ンンンっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「に、肉笠が大きすぎて時々喉にひっかか、る……。うぷっ……！　んん……\n！　こらっ、暴れるな……私の胸で捕まえていてやる、から……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ほら……めいっぱいしゃぶり尽くして吸い上げるぞ……！　あーん……ぐち\nゅっ！　ぢゅるるるるるっ！　ずちゅるるるるっ……じゅるるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ん……バキュームフェラ、と言うのか？　これを……。バキューム……。む\n……唇をすぼめて、チンポにまとわりつかせて……吸い尽くすぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んんんんんん～～～♪　ぢゅるるるっ……じゅるるる……っ。はぁっ、はぁ\n……れろれろれろ……んちゅっ……ぢゅるるるるっ、じゅるるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　わたひ、も……ヘンな気分になっれきた……。口の中、お\nまえの味でいっぱいで……。あ、ぁ、おかしく、なりひょうら……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「もっとカウパー……先走り汁、我慢汁を舐めさせてくれぇ……。飲ませて、\nくれ……。じゅるっ、ぐちゅっちゅるっ！　じゅぷっ、ぷちゅっ、むぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「また出ひたくなっれきたのか……？　本当に、おまえのオチンポは最強だな\n……。しゃぶっても、口が疲れるらけなのに……なんでらろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403219" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「また、精液を出してもらえるって思ったら、すごく……♪　ンンンっ……あ\nあ、くれ……。私の熱烈なおしゃぶりで精子を吸い上げられてひまえ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んむぶぅうううっ！？　ぷぅうううっ……！？　んぷぅううっ、ううううう\n～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んぉっ！？　ぷぅっ……！　頬袋いっぱいに……んむぅうっ！　爆発ひゅる\nみたいに、精液が……精液が……！　んぷぁああっ、むぷぅううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ま……負けるものかぁ……。私はおまえの精液ならいくらでも……。って、\nなん、だ？　チンポを口の中にねじこんでくるな……っ。うむぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「しゃ、しゃぶったまま飲んでほしいのか……？　汁だけで大変な量なのに…\n…。ン……。でも……それが望みなら……わ、わかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「甘えん坊め……。このまま飲んでいくから、よく見ていろ……。んむ……飲\nむ、ぞ……。ぢゅる……。……ごくっ……ごきゅ、ごく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んく……。んくっ、ごきゅ……。ごくっ、ごく……。ど、どうら……？　上\n手に飲めたらろう……？　……何？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「心の底から美味しそうに飲んでいた？　美味くは……ないぞ、別に……。た\nだ……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私は隊長に求められると、何でもしたくなってしまうだけだ。それに……せ\nっかくの精子を、他の誰にも渡したくなくて……それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「……くぅううっ！　こ、これ以上は言わせるな！　……今、私が言ったこと\nは誰にも話すなよ！　まったく私のキャラじゃない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「も、もうっ……。おまえといると本当に、私は妙な気分になってしまう……\n。自分で自分が恐ろしいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んぷぁああっ！　あっ……！　い、勢い余って……顔に、頭に……！　んぅ\nううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あっ……あっあっ……！　く、口で受け止めるつもりが、頭に……。すまな\nい……！　やっ……！？　精子、精液が飛びかかってくるっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あふ……。目をまともに開けていられない……。な、なんだこの量は……っ\n。さっき出した量以上で……、溺れてしまいそうだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「んんんん……！　何……？　顔に出されるのは嫌か……？　い……嫌なわけ\nがないだろうっ……た、ただ……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「理由はわからないけれど、……酔う、んだ……。おまえの精液は……。こう\nして盛大にぶちまけられると、頭が……ぼーっとして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「なぜか身体が熱くなって……。もう私はおまえの女なんだ、この精液でしっ\nかりマーキングされてしまったんだって……自覚してしまうんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私は一生、この精液の奴隷なんだって……♪　え？　だからっ……嫌じゃな\nい！　むしろ……う……嬉しいが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「ただ……。んっ……髪についた精液はなかなか取れないんだ。洗っても洗っ\nても、肌にも頭にもずっとこびりついているみたいで……はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「……べ、べつに興奮しているわけじゃ……♪　ああ……たっぷりかけられた\nこのヌルヌル……。この臭いに包まれて、しばらく陶酔していたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403409" ]},
		{"command":[ "SETIMAGE", "0", "still_00015604_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「私はヘンタイ女になってしまったんだろうか……。こんなこと、ＥＤＯの皆\nには……地球の人々には、絶対絶対明かせないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
