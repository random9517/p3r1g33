{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「おお、婿殿！！　旦那様！！　よう来たよう来た！！　さあさあ、まずはこ\nちらに来るがよい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、会いたかった。会いたかったぞ。一日千秋という言葉があるが、待っ\nていた時間はまさにそれじゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「神である妾が旦那様を待つ時間……本当に来てくれるのか、不安じゃったが\n……旦那様は来てくれた。嬉しい、嬉しいぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「そして、来てくれたということは、これはもう妾と旦那様は夫婦ということ\nじゃ！！　ならば、契りを交わすべきじゃ！！　そうじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「というわけで……旦那様、失礼するぞ。ふふ、旦那様は動かずともよい。妾\nが全部奉仕してやるゆえな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んふっ、旦那様のチンポ……相変わらず逞しくて、熱くて、硬くて……これ\nが今から妾の中に入ると思うと……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「それだけでお腹が切なくなるのう……んっ、それでは、旦那様のチンポ……\nんふうっ、んっ、入って、来た……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304107" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「これが……これがまぐわいか……旦那様と出会ってから、何度も何度も夢見\nていた……んんっ、旦那様のチンポ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「チンポが妾の中にあるのが分かる……んんっ、これが、幸せというものか…\n…ふうっ、ふっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304109" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様、旦那様も妾の中を感じておるのじゃろう……中でびくびくって……\n妾のお腹を刺激して……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304110" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んふうっ、旦那様も乗り気で嬉しいのう……これで子種を出してもらえば、\n妾の中に旦那様との子が……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうすれば、名実ともに妾は旦那様の妻じゃ。ふふ、二人とその子供たちで\n神社をもり立てていこうではないか。のう。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304112" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、こうして、腰をゆっくり動かして……んっ、ふうっ、ふっ、\n旦那様、どんな動きがよいのじゃ？　こうして、回すような動きかの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「それとも、こうして上下に動かす動きかの？　速いのも、遅いのも、旦那様\nの好みを言ってくれればそうやって奉仕してみせるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304114" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妻となったからには、妾は旦那様の女じゃ。旦那様の望むまま、思うがまま\nにこの身体で気持ちよくしてやるからの……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304115" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「こうして、お腹に力を入れれば……んっ、チンポが締めつけられているのが\n分かるじゃろう？　ふふ、妾の中で跳ねておる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふっ、ふうっ、ふっ、男と交わるのは初めてじゃが……んっ、それが旦那様\nであると思うと、全身が幸せになるのう……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304117" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、あんっ、んんっ、旦那様、旦那様は気持ちいいかの？　んっ\n、そうか、妾の中が気持ちいいといってくれるのか、嬉しいのう。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304118" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「今まで、男女の交わりをそれほど気持ちいいのかと思っておったが、こうし\nて愛しい人と繋がった今なら分かる……ふっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様と一つになるというのは、これ以上ない幸福じゃ……んっ、あんっ、\nふっ、んっ、旦那様、好き、好き、好きじゃ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304120" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様の全てを愛しておる、んっ。顔も、身体も、チンポも、心も……ふふ\nふっ、旦那様の全てと繋がっていたい……ふうっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304121" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あっ、んんっ、旦那様、そんな急に下から……あんっ、んっ、\n奥、奥をごつごつって叩かれたら……あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の中が、蕩けて……んんっ、じんじんして、もっともっと旦那様のことを\n好きになってしまう……んっ、んふうっ、旦那様っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304123" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様も、妾のことを……？　嬉しいっ！！　相思相愛じゃな！！　旦那様\nっ！！　んふふふっ！！　妾は旦那様の妻じゃっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、じゃあ、旦那様、妾は旦那様との子が欲しい。子さえいれば、旦那\n様が留守にしていても一人きりではなくなる……だから、の？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304125" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の中に、旦那様の子種をたっぷりと出しておくれ……妾に、子を孕ませて\nおくれ……あんっ、はっ、んっ、ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「急に、動きがっ、んんっ、妾の言葉で興奮したと……んんっ、ふっ、嬉しい\n、旦那様も妾を孕ませる気になったということじゃな……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふうううっ、妾の中で旦那様のチンポが膨らんで、カリ首がごりごりってこ\nすって、んんっ、ふううっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304128" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「竿も、妾の中でみっちりしながら動いて……んっ、奥、そんなに突かれたら\n、もう完全に子を孕む準備が整って……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様のチンポで催促されてっ、んんっ、孕むっ、孕む準備ができてるっ！\n！　ふあああっ、あっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304130" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ、下からそんなにかき回されたら、妾の中、中がどろどろ\nに溶けて、かき混ぜられてしまう……ふああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304131" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、あっ、イく、もうイく、旦那様のチンポで、イっく！！　ん\nんっ、ああっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様、旦那様もイって、妾の中でイって、一緒にイくのじゃ……！！　ん\nっ、あっ、あふうっ、中でチンポが……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304133" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「暴れ回って、膨らんで、子種を出す準備をしておるんじゃな……よい、よい\nぞ、出してくれ。妾の中を旦那様の子種で満たしてくれっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304134" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あんんんっ！！　あっ、んっ、くうううっ、来たっ！！　旦那様の子種来た\nああああああっ！！　んんっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304135" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、分かる、旦那様の子種が注がれているのが分かる……ふあっ\n、あああっ、幸せ……あんっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304136" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「溶かされてる！！　妾の中が旦那様のチンポで溶かされてる……ふあっ、あ\nあっ、まだまだ注がれてる……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304137" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「子が育つところに、旦那様の子種注がれてる……んふうっ、ふっ。ふふっ、\nこれで、旦那様と妾の子が……あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、入りきらないのがもったいない……んっ、あっ、ふうっ……こんな\nに注がれたら、育っていないのにもう腹が膨らみそうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304139" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「腹の中だけではない……心も、旦那様と繋がって満たされた……ふふっ、幸\nせ……こんな幸せを妾が感じるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304140" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「でも……旦那様、妾はまだまだ足りぬ。子種も、旦那様からの愛情も。だか\nら……の？　もっともっとしよう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の中も、旦那様のチンポもその気じゃし……初めて繋がったんじゃ。一回\nきりなぞ寂しいじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304202" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、中がきゅっきゅって同じことを言ってるのが分かるじゃろ？　あんっ\n、ふあっ、んっ。ふふふっ、旦那様のチンポも同意見じゃ。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「こうして腰を動かせば……んっ、ふっ、旦那様も動いてくれて……あんっ、\nんんっ、チンポもまた硬くなってきておる……あふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304204" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、さっきので動きを覚えたからの、こうして、締めつけながら動けば…\n…あふうっ、んっ、旦那様のチンポが悦んでいるのが分かる。んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あんっ！！　んっ、旦那様も妾の弱いところを覚えたって……ふあっ、ああ\nっ、んっ、あくうっ、そこ、上をこすられるの……んんっ、好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様にされるのなら、なんでも好きじゃ……あうっ、んんっ、ふうっ、ふ\nっ！！　妾の中を、好きにして……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「この顔も、おっぱいも、中も、全部全部旦那様のものじゃからな、んっ、は\nああっ、あうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304208" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「だから、好きにして、好きに使っていいのじゃぞ！！　ふうううっ！！　妾\nは、何をされても旦那様を愛することはやめぬ……ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304209" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「誰もが悪神と蔑み、忌み嫌った妾を、旦那様だけが見てくれた……信じてく\nれた……そんな旦那様を愛しておる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「たとえこの先旦那様が妾をどう思おうと、妾のこの気持ちは変わらぬ……こ\nの存在が果てるまで、旦那様への愛は消えぬ……ふうっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304211" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「だからの、旦那様……妾と一緒にいるときだけでもよい。そのときだけでも\n、妾と夫婦になって、愛してくれ……あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾を、妾をひとりぼっちにしないで！！　側にいてっ！！　ふうっ、あああ\nあっ、んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304213" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああ、んっ、そんなの当然じゃと、ああっ、そんな、そんなこと言われたら\n……言われただけで、イっく、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304214" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あふうううっ！！　イってるのに、軽くイってるのに、動かれたら、あんっ\n、旦那様の意地悪っ、ふああっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、イってるのに奥ごりゅごりゅって、そんなことされたら、ふ\nあああっ、妾の中全部、チンポで蕩けちゃうんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304216" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あくうっ、うっ、ふあああっ、も、もう、旦那様もイって、チンポから子種\n出してっ！！　妾の中にいっぱい出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304217" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「子作りのために、いっぱいっぱい出して、満たして、旦那様っ、旦那様っ！\n！　あくうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、イく、イく、またイく！！　旦那様のガチガチチンポで、またイっく\n、んんんっ、ふうっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304219" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああああああっ、イっくううううううううううっ！！　ふああああああっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304220" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！！　また、また中にびゅるびゅるって注がれて……さっき\nのと混ぜ合わされて……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の奥で、特濃の子種と子種が混じりあって……こんなの、絶対に孕む……\n元気な子を孕む……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304302" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、妾の中が悦んで子種を吸いこんでるの、分かる、ふあああっ！！　\nあっ、子種出されてるだけで、またイっく、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304303" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、まだ、まだ出てる……あくうっ、ふうっ、旦那様のチン\nポ、凄い……もう、妾の中が溺れきってしまった……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_10" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふっ、旦那様も満足してくれたのじゃな……気持ちよさそうな顔を見れば\n分かる……妾の中でそうなってくれたんじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304305" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、妻として、女として、務めを果たせてよかった……ふふっ、もちろ\nん妾も気持ちよかったぞ……想像以上じゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304306" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「こんな気持ちいいことをして旦那様との子が作れるなら、世の男女が交わり\nを求めるのも当然じゃのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_09" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「もちろん妾も、これからも何回も旦那様と愛しあいたいと思っておるぞ。旦\n那様となら、いつでもどこでも歓迎じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304308" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ところで旦那様、妾は九尾の尾を持つ……つまりは子に九つの権能を分け与\nえることができるのじゃ。それがどういうことか、分かるじゃろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_10" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「つまり、最低でもあと九回は……もちろん旦那様が望めばもっともっと、子\nを成そうぞ。愛しておるぞ、旦那様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あんんっ、あっ、なんでチンポを抜いて……ふああああああっ！！　妾、妾\nの身体に子種がっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、身体中に旦那様の匂いと熱さが……ああっ、どろどろねばね\nばで……これが旦那様の気持ちよさの証……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304402" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「あふうっ、ふっ、妾の身体から、染みこんでくるようじゃ……中がよかった\nが、身体にかけられるのもわるくないの……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304403" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「んふうっ、こんな大量の子種を、先ほどは中にたっぷりと出されたのじゃな\n……んんっ、そう思うだけで、中が震えてしまう……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_13" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「中も外も、旦那様の愛で染め上げられてしまった……ふふっ、これが女の幸\nせというものなのじゃな。初めて理解したぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304405" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「旦那様のおかげじゃ。女神としても、女としても……これ以上ないものを旦\n那様は与えてくれた……感謝しておるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304406" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「もちろん、愛してもおる。ふふ、この顔と身体を見れば分かるじゃろう？　\n旦那様から与えられたものに、全身で悦びを感じておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_12" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「人間に対してこんな風に感じるなど、思ってもおらんかった……旦那様は罪\n作りな男じゃのう。ふふふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304408" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「身体中を旦那様の匂いに包まれて……これが幸せというやつじゃのう。妾の\n全身が旦那様で満たされておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304409" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "Ａ稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、妾がそうされたように、今度は旦那様を妾で満たしきりたいのう。だ\nから、の。これからももっともっと交わろうぞ、旦那様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0304410" ]},
		{"command":[ "SETIMAGE", "0", "still_00024103_02_13" ]},
		{"command":[ "WAITINPUT" ]},
