{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "時は、学園祭前日にさかのぼる。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「大変だよ！　グルメコンテストでなにをするかぜんっぜん決まってない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「演劇コンテストのことで頭がいっぱいだったもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いいから、なにかを作って屋台で売らないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「でも、なににするの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうですね、今から作れるものといっても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おーい、教室に残ってなにをしてるんだー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「セレイン先生！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「実は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナたちは現状をセレインに話した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なるほどー。そういう時は、定番のものでいいんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「定番のもの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうそう、カレーとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カレーかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、カレーの屋台ってほかのクラスでも出しているんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね、その中で優勝するには、ただのカレーじゃいけないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いや、ただのカレーでいいと思うけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ですが、材料にこだわる時間はもうありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゃあ、各自家にあるものを持ち寄るっていうのはどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、それいいかも！　そうすればほかのクラスと差別化できるね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「よし、決まりね！　当日はカレーで勝負よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「おー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980004" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00000403_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "そして学園祭、グルメコンテスト当日。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「クラスの皆さんに連絡した通りです。防衛科のクラスはカレーで勝負します\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「持ち寄った材料を入れていくよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980005" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ばっちゃが言ってた……。カレーはすべてを包みこむ、母親のような料理だ\nって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鍋に各々持ち寄った具材を入れていく", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ジャガイモ、切ってきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしは、玉ねぎを炒めて持ってきたよ。夜日楽はニンジンを入れといてっ\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ゆで卵をもってきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980006" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「紅茶の葉よ。カレーには風味が重要ってネットで見たわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「チョコレートを隠し味にするといいらしいですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのほか、味噌、キムチ、ピーマン、柚子胡椒、カツオ、中華まん、砂糖と塩\n、ヨーグルト、ニンニク、ＤＨＭＯ……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鍋の中に全員分の具材が投入された。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……ねえ、なにこれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980005" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「カレーって、こんな色だっけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ほかのクラスのカレーとは全然違うね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980007" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「というか、誰かルーを入れましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラスメイトたち" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00001205_01", "1", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00002402_01", "1", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00002802_01", "1", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "危険な沈黙。カレー作りに暗雲が立ち込める。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いや、市販のルーなんか使ったらほかのクラスと一緒の味になっちゃうよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980009" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうですわ。スパイスから作ったカレーなら、ほかのクラスに負けない味に\nなるはず！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もしや失敗では？　という空気を吹き飛ばしたのは、料理を主導していた三人\nの言葉だった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "三人寄れば文殊の知恵という。ならば、クラス全員が集まれば文殊を超えるの\nは至極当然。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「カレーのスパイスらしいものも入ってない気が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980007" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「胡椒や唐辛子は入りましたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ワサビやからしもいれたから、スパイス成分は足りてるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980010" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「シナモンや片栗粉もスパイス……だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980008" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「で、でも……これはさすがに……うぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113980008" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「な、なんだかめまいがしてきたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113980009" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「桃花さん！？　マーガレットさん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとルルーナさん、これ以上は危険……あうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113980007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "混沌とした色の鍋から刺激臭が立ちのぼり、周りのクラスメイトが気絶してい\nく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113980009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「みなさんどうしたのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113980010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「気絶しちゃってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113980011" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「大げさだなぁ。ねえ、出来上がったところで味見してみようよ」", "NORMAL" ]},
