{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ブルーが倒れてから数日後。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「という訳でオーディションを行う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつもいつも、なにがというわけなのか分からないんですが……とりあえず\n説明をしてください」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。先日のブルーの体調不良、それでも出撃せざるを得なかった状況。そ\nれはつまり――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「人手不足だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ……まあそりゃ仮面戦隊マスカレードって言っておいてあいつ１人だし\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ブルー殿は生真面目だから必死に務めていましたが、怪人協会の人数を考え\nると破綻するのは自明の理でしたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ。まったくもってその通り。ゆえに、マスカレード新規隊員募集オーデ\nィションだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、戦力が増えるのはいいことですから反対はしませんけど。どうせなら\n事務仕事も手伝ってくれて俺に好意的な子がいいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、願望がダダ漏れでございますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お前が乗り気でよかった。なら、次の水曜日に公園に来るように。オーディ\nションの審査員を務めてもらう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……水曜って貴重な祝日なんですが……ちなみに、断ったりは……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「正午開始なので、１時間前には現地に来ているように」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの……俺に拒否権は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「特に必要な持ち物はないが、戦力の見極めということを念頭に置いて体調を\n整えておくように。何か質問はあるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「休ませてもらうことは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なければもう行っていいぞ。私は別件でいないが、くれぐれも遅れるなよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023590008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、ご愁傷様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふ……ふふふ……さよなら俺の休日」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "SETTEXT", "オーディション当日。", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「雨が降ったら中止とかあったらよかったのにな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「遠足ではないのですから……むしろ長官は雨天決行とかするタイプではない\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言うなよ、さらに辛くなるから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいおいなんだシケた面してんなあ。審査する側の人間がそんな顔してたら\nいい人間も来ないだろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590001" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "8", "CENTER", "1500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "MOVECHARA", "0", "CENTER", "-400", "NORMAL" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "400", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「声がでかい！！　ていうかなんでほむらがここにいるんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「長官から１杯奢った代わりに審査員やれって頼まれたんだよ。借りは返さね\nえとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590002" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それに引退したとはいえ、後輩になる奴を選ぶんだ。ナヨッとしたやつじゃ\nなくてビッと気合いが入った奴を選ばなきゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590003" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……いるよな。こういう、卒業したのにやたら顔見せて現役生をしごく\nみたいなＯＢ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「学生は縦社会だから、煙たがられてもなにも言われずに口出ししつづけるよ\nうなＯＢですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1"]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ＯＢじゃなくてＯＧだろ！！　ぶっとばすぞコラ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590004" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「突っこむところそこかよ……まあ元マスカレードなら選ぶべき人員は理解し\nているだろうし、おかしな審査はしないだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ、フライア！？　なんでここに……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「オーディション会場はここですよね～？　私も冴島さんからオーディション\nの審査をするように頼まれまして～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ……怪人にヒーローの審査を……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ほらほら～、敵を知り己を知ればなんとやらっていうじゃないですか～。そ\nれですよきっと～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590003" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「絶妙に使いどころを間違っているような気がしますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私としては太陽を使える子とかいいですね～。戦いながら光合成できるし～\n。じゃあ隣失礼しますね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まあいいか。言ってることも一理あるし」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「フライア殿の胸に視線が釘付けでなければ少しは説得力もあるのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「男って好きだよな～でっかい胸」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ゴホン。まあ文句を言ってても仕方ねえ、オーディションを始めよう。ジュ\nンジロー、応募者を案内してきてくれ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「了解ですご主人……エントリーナンバー１の方、どうぞこちらへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「スバルよ。ヒーローを求めていると聞いて、応募したわ。どうぞよろしく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "8", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「スバルか……聞いているぜ。元時間帝国で現在、ＥＤＯの処遇待ち……身の\n置き場でも探しに来たか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ええ、ココで見せ場を作って、私が来た！　って事を分からせてあげなきゃ\nね！　いざ、ストライダータイムッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "", "NORMAL" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEINIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEOUTCHARA", "0", "VERYFAST" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノストライダー・昴" ]},
		{"command":[ "SETTEXT", "「クロノストライダー・昴……見っ参！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "7", "CENTER", "0" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "FADEOUTIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEINCHARA", "0", "VERYFAST" ] },
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ……すげえな。強そうだし格好いいじゃないか。なあ、これいいんじ\nゃないか？」", "NORMAL" ]},
		{"command":[ "DISPIMAGE","1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「太陽の力がないのは残念ですけど、私も強そうだと思います～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「確かに実力はありそうだ……そのスーツの出力も高いのが見ただけで分かる\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノストライダー・昴" ]},
		{"command":[ "SETTEXT", "「そうでしょう。私の力を持ってすれば、怪人など即座にデッドエンドよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「殺されるのは勘弁願いたいですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590006" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「戦力としては申し分ないだろうな……だが、ダメだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノストライダー・昴" ]},
		{"command":[ "SETTEXT", "「なっ！？　どういうことですか。私の何がダメだと……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010023590003" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今回募集しているのは戦隊だ。そしてお前はライダー……分かるな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノストライダー・昴" ]},
		{"command":[ "SETTEXT", "「へ……？　え、なんですかそれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ライダーと戦隊は両立できねえんだよ。同時に主役がでるのは、とある限定\n的な特別な場合だけなんだ。お前も大人なら理解しろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノストライダー・昴" ]},
		{"command":[ "SETTEXT", "「え？　え？　え？　本気で言ってるんですか？　嘘でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか……すまん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そういえば、私たちもマスカレード相手とライダー相手は部署が別れていま\nすしね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590007" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ジュンジロー、帰りの案内をしてやれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はっ。そういう訳ですので、昴殿、こちらへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノストライダー・昴" ]},
		{"command":[ "SETTEXT", "「終わり？　これで終わり？　私まだメインでも活躍してないし、なんなら結\n構深い過去があるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010023590006" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それはまたの機会に……それでは、次の方どうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "鈴＆葉金" ]},
		{"command":[ "SETTEXT", "「よろしくお願いします！！」", "NORMAL" ]},
