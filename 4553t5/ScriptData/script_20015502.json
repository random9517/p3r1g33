		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「これはエレメントフォーム。風の力が使えます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590007" ]},
		{"command":[ "SETCHARA", "0", "char_00013105_01", "7", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「グリーンとかぶるな。他は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590021" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……これはナイトメアフォーム。月の力が使えます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590008" ]},
		{"command":[ "SETCHARA", "0", "char_00013106_01", "7", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「パープルの奴と一緒だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590022" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいやおいおい待て待て。イエローとかグリーンとかパープルとか初耳な\nんだが？　ほむらや氷華みたいなのが他にもいるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そりゃあ、戦隊なんだからいるに決まってんだろ。２人だったらコンビとか\n言うだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590023" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ……そいつら、どこにいるんだよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590024" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「無言で笑うなよ！！　なんか怖いぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あの……それで私は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590009" ]},
		{"command":[ "SETCHARA", "0", "char_00013106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ？　他にねえなら没だ。帰りはあっちだ。ジュンジロー、案内してやれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590025" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そんなあ……こんなにフォームがあってこの扱いは……ぐすん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590010" ]},
		{"command":[ "SETCHARA", "0", "char_00013106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご愁傷様です。帰りはこちらになります。お気をつけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「泣かないで～。飴ちゃんあげるから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590011" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「次だ！！　ってもう最後か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590026" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これ、決まらなかったら俺が長官に怒られるやつじゃないのか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ、あの……よろしくお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_010023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590027" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
