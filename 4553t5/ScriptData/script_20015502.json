		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっ、元気いいじゃねえか。そういうのは好きだぜ。で、お前らは何ができ\nるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アタシは伊形鈴っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしは轟琴葉金」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "鈴＆葉金" ]},
		{"command":[ "SETTEXT", "「２人はブリキワ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010023590003" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ダウトダウトダウトーーーーーーーーーー！！　却下だ却下っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ええ……そんな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしたち、赤にも青にもなれますのに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だから戦隊とそっちは両立できねえつってんだろ！！　お前らはお前らの枠\nでやれ！！　ジュンジロー、帰りの案内だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ささ、お二方、こちらへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしたち活躍できる日を心待ちにしているのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「劇場版でも待て！！　次っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか……もう全部ほむらが仕切ってるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「まあまあ、楽でいいじゃないですか～。はい、お茶どうぞ～。私から生えた\n葉を煎じたお茶ですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590008" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「フライアから生えたお茶……なんかエロいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あらあらカツマさんたら～。ふふふ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590009" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「クリスです。よろしくお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590001" ]},
		{"command":[ "SETCHARA", "0", "char_00013104_01", "8", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ふむ……今までで１番ナヨッとしてんな。そんな身体で戦えんのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590016" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふふ……侮ってもらっては困ります。マスカレードの特色は色……ならば\n、私のこの能力はまさにふさわしいと言えます。とくとご覧ください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590002" ]},
		{"command":[ "SETCHARA", "0", "char_00013104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「まずはこれがベースフォーム」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590003" ]},
		{"command":[ "SETCHARA", "0", "char_00013101_01", "7", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ふむ。それで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590017" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「これがファイヤーフォーム。炎の力が使えます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590004" ]},
		{"command":[ "SETCHARA", "0", "char_00013103_01", "7", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「赤で火って、俺の能力とかぶるなあ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590018" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほむらはもう卒業してるじゃねえか。あと赤って火とか太陽以外になんかあ\nるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「激辛とか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_010023590010" ]},
		{"command":[ "SETCHARA", "0", "char_00027401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「激辛で戦うヒーローはシュールですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023590012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺のポジションは永久欠番だろ。他にねえのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023590019" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「では、こちらを――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590005" ]},
		{"command":[ "SETCHARA", "0", "char_00013103_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「これはライトニングフォーム。雷の力が使えます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_010023590006" ]},
		{"command":[ "SETCHARA", "0", "char_00013102_01", "7", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「イエローの奴とかぶるなあ。他は？」", "NORMAL" ]},
