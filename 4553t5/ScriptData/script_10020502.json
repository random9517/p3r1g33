{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あなた達のヒロインへの執念……しかと見せてもらった……がくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「これでライバルは一人消えたわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね。あなたも降りるならいまのうちよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「誰が降りるもんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たちなぁっ！　ほかの教室からうるさいって苦情が来ているんだが！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "最近は平穏な日々が続いていると思ったが、またうちの連中が面倒を起こして\nいたらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カツマ先生っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ニューチャレンジャーかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「たとえあなたが相手だろうと、ヒロインの座は譲りませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なにを言ってるんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "教室に入った途端、妙に血気だった三人に出くわした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナはさておき、ほかの二人もこんなに熱くなっているのはめずらしいな\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやまて、ヒロインってなんだ。なんの話だ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと、それについてはわたしから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜日楽から説明を受けた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうやら、学園祭の配役について揉めに揉めていたらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "もう朝のホームルームの時間はとっくに終わって、一時間目が始まっているの\nだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、たかが劇の配役だろ。適当にくじ引きで決めていいんじゃないか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "３人" ]},
		{"command":[ "SETTEXT", "「よくなーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "-500" ]},
		{"command":[ "SETCHARA", "1", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00002402_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおぉっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「総ツッコミですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそも、なんでそんなにヒロインにこだわるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「女の子は誰しもヒロインに憧れるものよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ。まあ、私は生まれ持ってヒロインだけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「私はここでヒロインにならないと王子役になるところだったんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113430003" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいじゃないか、王子。主役だろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でも、王子役って大変なんだよ。ちょっと台本を見てよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113430004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なになに……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "シーン１、高層ビルから飛び降りる王子。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "シーン５、時速８０キロで走る車に追われる特訓する王子。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "シーン８、揺れる鉄球の中を目隠しをして通過し、ヒロインに会いに行く王子\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわぁ、無茶苦茶な」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "王子のかっこいい（？）シーンが目白押しだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この脚本はまりあが書いたらしいが、これは深夜テンションで勢いのままに書\nいたな？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ところで、もしもつきみ様がヒロインになったら、王子役はどなたがなさる\nのですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい駄犬。話をかき回すな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はて、私は当然の疑問を投げかけただけですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね、王子役……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「王子役こそ、くじ引きで決めたらいいんじゃないかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら、自分の役以外はどうでもいいのかよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「でしたら、さきに王子役の方を決めたらいかがでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そ、そうですね。だれか王子役への立候補は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "静まり返る教室。まあ、この台本を聞いた上で、そしてヒロイン候補もこの三\n人となると、なぁ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あうぅ、り、立候補がいないなら、本当にくじ引きで決めちゃいますからね\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だから、もう適当に決めちゃっていいってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020113430001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「恨みっこなしですよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というわけで、即席でくじが作られた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「王子様くじー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「いえーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00001205_01", "8", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00001702_01", "8", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00002402_01", "8", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「くじの結果はー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ぜったーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00001205_01", "8", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00001702_01", "8", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00002402_01", "8", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「合コンかっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さて、ご主人も一本どうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいやなんで俺が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "といいつつ、思わず引いてしまうと……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「先が赤いのだが？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「カツマ先生、それ、当たりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430008" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ということは、王子役はご主人ということになりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、俺は教師だぞ？　生徒の出し物に参加するのはおかしいだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、明日楽先生もヒロインの座を狙っていたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430009" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんはそういうつもりじゃないと思うけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113430009" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、くじの結果ということで。ご主人は王子役ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113430009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、ないだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうですよ。だいたい王子役に先生を巻き込むなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113430008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "めずらしくルルーナがまともだ。そうだよな。俺はここでは警備員兼教師なん\nだからな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なら、降りる？　私は王子役が誰であってもヒロイン役から降りたりしない\nわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113430010" ]},
