{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_01" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「くふぅっ……お尻に、固いのが当たってる……はぁ、はぁ……外でするのは\n、少し恥ずかしいけど……でも、ココなら誰にも見られないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404101" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私が見つけた、とっておきの穴場だからな……むこうのビーチからは岩しか\n見えないし……なんでもヤりたい放題だぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私とおまえの、二人きりだから……おまえのその、固いのを、早くぅ……身\n体が熱くて、アソコもジンジンして……おかしくなっちゃいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、こらぁっ、変なとこ、擦りつけるなぁ……！　くふぅんっ\n！　弱っちいくせに、私を焦らすなんて、ナマイキだぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「は……？　な、なあっ……！？　そ、そんな恥ずかしいこと、私に言えって\nいうのか！？　このポーズだって、もう十分恥ずかしいのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「オニ、アクマ、鬼畜野郎！　……わわわっ、ま、待って、ヤメないでくれ…\n…！　うぅぅっ……わ、わかったよぉ、言う、言うからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うぅぅっ……！　こ、こんなの……おまえ以外なら、絶対、許さないんだか\nらな……！　お、おまえだけだぞ！　特別なんだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅっ……わ、私のはしたないメス犬オマンコに……あ、あなたの、\n太くて固くてリッパなオチンポを、いっぱいハメハメしてほしい……わんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「きゃふぅううううっ！！　オチンポ、入ってきたっ……！　あっ、あっ、ゴ\nツゴツして、太くて、固いぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あふぅぅんっ……！　私の、オマンコのナカ、ぐりぐり押し分けてぇっ……\nくふぅんっ、あぅううんっ……！　奥まで、入ってきてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひあぅうっ！　オマンコの一番深いとこっ……あふぅうんっ！　オチンポの\n先っぽ、ぐりぐりっ……ひぅうううっ、押されてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぐふぅううんっ……！　ま、待って、それ以上、ムリ、もう入らないから\nぁっ……んひぅうううっ！　上から体重かけちゃ、ダメだってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、くふぅううっ……オマンコのナカ、おまえのオチンポで、\nいっぱいになってる……はぅぅっ、セックス、しちゃってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「こんな犬みたいな格好で……あふぅぅっ、交尾みたいな、セックス……うぅ\nぅっ、おまえとじゃなかったら、絶対しないんだからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私にこんなことできるのも……んふあうっ、こんな格好、見せるのも……全\n部、おまえだけなんだぞ……くふぅんっ、光栄に、思えよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よ、よし……あぅんっ、わかれば、いいんだ……んくふぅっ……！　ふぅ、\nふぅ……そ、そろそろ……動いても、いいんだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぅううっ……！　あっ、あっ、オチンポが抜けてく……！　私のナカ、\nひっかいて……あふぅううっ！　んくぅううっ、太すぎるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……ま、待てっ、それ以上は、オチンポ、抜けちゃうっ……ダメ\n、ダメだっ、抜かないでっ……んぎゅぅううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「い、いきなり、奥までは、卑怯っ……あっあっ、また、抜けてっ……ふぐぅ\nうううっ！　また、奥うぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あんっ、あっ、あっ、ダメっ、激し、過ぎるぅっ……！　あくぅ\nああんっ！　お尻、パンパン、鳴ってっ……音、響いちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んぐふぅうううっ……！　奥っ、ぐりぐりぃっ……！　ひぅうううんっ……\n！　赤ちゃん作る部屋っ、あぁあんっ、イジメるなぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、入り口のとこ、あぁんっ、ぶっといカリ首でくぽくぽ、しな\nいでぇっ……！　あふぁああんっ、足に力、入らなくなるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んぎゅうっ！　あひっ、くひぃいんっ！　体重かけて、パンパンっ、ヤメっ\n……あひぃっ！　お腹の奥っ、ズンズン、響いちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっあっ、あひぃいいんっ！　あふぅううんっ……くひぁあっ！　全部同時\nは、ダメぇっ！　きゃふぅうんっ！　オチンポ、強すぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひぁあんっ！？　オチンポ、太くなってるっ！　きゃふぅううんっ！　オマ\nンコもう、オチンポでいっぱいだってばぁっ！　あひぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひっ、あっあっ、カリ首、太すぎるよぉっ、あひぅううっ！　オマンコの\nナカ、ぜんぶひっかいてっ、ひぃいんっ！　おかしくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぉおんっ！　おぉんっ！　亀頭も、どちゅどちゅっ！　おひぃんっ！　オ\nマンコの奥っ、イジメないでぇっ！　もうダメになっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっあっ、オチンポ、ナカでびくびくっ！　ひぁああんっ！　もう、イくの\nか？　あふぅうんっ、私のオマンコに、ナカ出し、しちゃうのかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひぃいっ！　いいっ、出してぇっ！　あふぁあんっ！　私のオマンコで、\n射精してっ、あひぃんっ！　精液っ、ナカ出し、してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひっあひっ！　オチンポ、激しいっ！　私もクる、キちゃうぅっ！　オマ\nンコ、イくっ、お外で種付け、イっちゃうぅっ！　あひぃっ、イくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「きゃうぅううううんっ！！　精液、ナカに出てるぅっ！　ふあぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふあぅうっ！　あうっ、あふぅうんっ！　オチンポが、ビクビクすると、ド\nロドロのザーメン、オマンコに、どぴゅどぴゅぅっ……ひあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぅううっ……！　そんな、深いとこで出すなぁっ……！　あふぅうんっ\n！　あっあっ、赤ちゃんの部屋に、当たって……はうぅううんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あっ、あっ……まだ、出てるぅっ……んくぅううっ、そんなに出さ\nれたらぁっ……あっあっ、またイくっ、オマンコ、イくぅううっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はあっ、はぁ、はぁ……はふぅぅっ……いっぱい、イっちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んぅぅっ、オマンコのナカ、精液でたぷたぷする……奥までたっぷり入って\nて……はふぅ……温かくて、ポカポカするぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「くぅ……こんな、犬みたいなポーズでイかされて、悔しいはずなのにぃ……\nなんでこんなに、嬉しくなっちっゃうんだよぉ……くそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「むううっ、お、おまえこそ、どうだったんだよ……？　私の、オ、オマンコ\n……ちゃんと、気持ちよかったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふ、ふーん、そっか……えへへっ。まあ、こんだけ出したんだからな、そり\nゃあ良くないはずないよな！　えっへっへー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「てことは、この勝負は引き分け……いや、私の勝ちだな！　だって、こんな\nに出したんだし、イくのもおまえがちょっとだけ早かったしな、うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「きゃふうっ！　お、おい、急に腰を動かすなよ……あくぅんっ！　あっ、あ\nっ、あひぅぅっ！　なんでまた、オチンポ大っきしてるんだよぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あんっ、あぅんっ！　も、もしかして、もう一回、シたいのか？　あひぅう\nっ！　ま、まったく、しょうがないヤツだな……んくぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そんなに、私のオマンコが、気持ちよかったのか？　あふぅうんっ、あ、わ\nかったぞ……私に負けたのが、悔しかったんだろ？　そうなんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひいんっ、あふぅんっ！　ま、まぁ、何回やったところで、私がおまえの\n弱々オチンポに負けるはずなんて、ないんだけどな……きゃふうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「どうせ、ココには誰も来ないしな、いくらでも相手になって……ふえ？　え\n、人……！？　ど、どこっ！？　う、後ろっ！？　あわわわっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょ、ま、待った、一回、ストップ……きゃふぅうんっ！　こ、こらぁっ、\nなんでまだ、動かして……あふぅううんっ！　だから、ダメだってばぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「オチンポ、出し入れヤメぇっ、あふっ、あふぅうんっ！　動かすなぁっ、あ\nっ、あっ、バレちゃうからぁっ、セックスしてるの、見られちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぉおおおんっ！　おんっ、おひっ、あひっ！　奥っ、それ、強すぎるぅっ\n！　おひいっ、あひっ、おふぅうっ！　変な声、出ちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、そ、そこも、ダメっ、あふぅんっ、入り口のとこ、ほじほじ\nっ、あぁあんっ、オマンコ、疼いちゃうっ、切なくなっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んぐぅうっ！　おひっ、あひっ！　らめっ、入り口から、奥まで、どちゅど\nちゅっ、激しすぎるっ！　あひぃいっ！　気持ちよすぎるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひっ！　あへっ、あひぃいんっ！　オチンポっ、出し入れだめっ、おひっ\n、あひっ、あへぇっ！　激しくジュポジュポ、ダメぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「全部、見えちゃうからぁっ！　後ろからっ、オマンコ入ってるとこぉっ、あ\nひぃいんっ！　セックスしてるの、見られちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「パンパン、音鳴らしちゃダメぇっ！　やぁああっ！　オマンコじゅぷじゅぷ\nも、らめぇっ！　恥ずかしいのぉっ、聞かせないでぇっ、ヤダぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひっ、あひっ、あひぃいっ！　ダメぇっ、見るなぁっ、こんな、あひぃい\nんっ！　犬みたいな、せっくしゅっ、見りゅなあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひぎゅぅうっ！？　オチンポ、ナカで大っきくなって、あひぃいいんっ！　\nあんっ、あひっ、あひっ、オマンコ、ごりゅごりゅ、こすれるぅっ！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んひぃっ、あっあっあっ、あふぅうんっ！　オチンポ、速いよぉっ！　激し\nいっ！　それダメぇっ、キちゃうっ、私また、イっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、あっ、あひっ、オチンポ、ビクビクしてるぅっ！　ダメッ\n、今はダメっ、射精しちゃ、ダメぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひっ、あひぃっ！　オチンポでイくとこっ、見られちゃうっ！　あへぇっ\n！　犬みたいなカッコで、射精されてイくの、見られちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、やらっ、だめっ、らめぇっ！　イかせないでっ、あひっ、あ\nひぃっ、あなた以外に、せっくしゅでイくとこ、見せないでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひぃいんっ！　らめらめっ、イくっ、イっちゃうっ、やらぁっ！　イくと\nこ、見ないれぇっ！　あっあっ、らめぇええっ、見ないれぇええええっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっひぃいいいいいんっ！　あっ、あっ、でてりゅっ……！　せーえき、ど\nぴゅどぴゅっ……！　オマンコにいっぱい、でてりゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「みにゃいれっ……あっ、あっ、オマンコ、イってるとこっ……んひぃっ！　\nしゃせーされてイってるとこ、みにゃいでぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　オマンコ、いっぱいっ……！　あひぃんっ、もう、出さにゃ\nいでっ、せーえきもう、はいりゃないからぁっ……あひゅんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひあっ……！？　あっあっ……りゃめっ！　おくっ、はいってりゅうっ……\nんきゅうっ！？　赤ちゃんのおへやっ、せーし、はいってりゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっあっ、らめらめっ、せーえき、出しちゃらめぇっ、はきゅっ！？　じゅ\nせーしちゃうっ、赤ちゃん、できちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひいんっ、あっ、あっ、らめっ、またイくっ、じゅせーしながらっ、子作\nりせっくしゅ見られながら、イくっ、あっあっ、イくぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はっ、はっ、はっ……はへぇっ……見られ、ちゃったぁ……うぅ、セックス\nしてるとこ……イってるとこ、見られちゃったよぉ……ひぃいいんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「は、え……？　ウソ……？　え……ど、どこから……？　ぜんぶ……？　じ\nゃあ、誰もいない？　見られてない……？　お、お……おまえーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うわあああんっ！　ホントに誰かに見られたと思ったじゃないかあっ！　お\nまえ以外の誰かに私の恥ずかしい姿、見られたと思ったんだぞぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うううっ、許さないぞ、絶対、許さないからなぁっ！　……もう一回。……\n今度は優しくシてくれたら…………許してやっても、いいぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},


		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あふぁああんっ！？　オチンポ、ヌけれ……んひぁあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あひぃんっ！　あちゅいぃっ！　せーえきいっぱい、かかって\nりゅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あひっ、あひっ……！　オチンポから、どぴゅどぴゅっ、でてりゅっ……ん\nふうぅっ……せーえきのニオイ、しゅごいぃっ……くふぅううんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふあっ、あっ、あっ……からだじゅう、どろどろになっちゃうっ……あふ\nぅうんっ、ぜんぶ、あなたのせーえきのニオイになりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「もっとぉ……いっぱい、せーえき、かけてぇ……わたしのぜんぶ、あなたの\nニオイにぃ……あなたのモノって、しるしをつけてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふあぁっ、あっ、あっ……クるっ、またイきゅっ、せーえきかけりゃれて\nっ、マーキングされてるとこ見られて、イくっ、あっあっ、イくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はひ、あへ、あへぇ……イっちゃったぁ……んひぅぅ……せっくしゅ、見ら\nれて……んぅぅ、せーえきでニオイづけされながら、イっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……オチンポ、きもちよしゅぎるぅ……メスイヌみたいに、イかさ\nれてぇ……あひぅぅ……オチンポに、負けたとこ、見られちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「もう、いい……見られても、いいからぁ……もっと、オマンコしてぇ……あ\nなたのしゅごいオチンポで、もっとハメハメ、してほしいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0404409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000404_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わたしのぜんぶ、もうあなたのモノだから……だから、あなたのオチンポで\n……わたしのナマイキなメス犬オマンコ、もっといっぱい躾けてぇ……！」", "NORMAL" ]},
