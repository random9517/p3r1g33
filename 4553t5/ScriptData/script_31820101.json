{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あのー、来ましたけど……こんな時間にどうしたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「まあ……おっぱいで、ご奉仕ですか？　ええ、いいですよ……やっぱり気に\nなりますよね、このおっぱい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「驚かないのかって……？　ふふっ、わたしがいくつだと思ってるんですか、\n処女じゃないんですから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "4", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「こういうことろに入ったんですから、これくらいのこと……予想してました\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「では、始めますね。ズボンと下着を脱がせますので……失礼します」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あら、ご立派……もう、こんなに大きくしちゃって……うふふ、これは楽し\nみですね……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そうですね。しばらくぶりですね、男の人のコレを見るのは……欲求不満？\n　ええ、そうかもしれません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「飢えてるだなんて、そんな言い方しないでください……あぁん、身体が火照\nってきちゃいますから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「それでは、さっそく……このおっぱいで、ご奉仕させていただきますね」　", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「……どうしました？　服は着たままですか？　あら、お若いのにマニアック\nですね……いいですけど」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「では、あなたのお望み通り、少しだけ裾をめくって……ここから、中へ……\nんっ、んぅふぅ……あぁ、熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ふふっ……ガチガチ……すっごく硬くなってますね。それに熱いですよ……\nんッ、男らしくて素敵ですよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっ、ンンっ……こうやって、挟んで……ぎゅって、して……うふ\nぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「……こんな感じでいかがですか？　んんぅ……すっぽり、おっぱいで包んじ\nゃいましたよぉ……あなたのチンポ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「このまま続けて大丈夫ですか？　はい、わかりました……最初は軽く、しま\nすね……んっんっ……ふぅ、んぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あんっ、さすが若いだけあって……とても元気……胸の中で、ガチガチにな\nって存在感アピールしてきます……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、ふぅ……こんなに硬いと、んんっ……扱きがいがあるってい\nうか……あんっ、興奮しちゃう……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あなたも興奮してるんですね……ええ、わかりますよ。おっぱいの中で、ビ\nクビクいってますから、このチンポが……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ほら、先っぽから我慢汁が出てきてる……表面がヌルヌルしてきて、滑りが\nよくなってる……感じますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「こうやって、もっと強く押しつけて……ふぅ、うんっ……はっ、はあっ……\nあんっ……気持ちいい、ですか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わたしも人妻ですから、パイズリくらい……経験ありますしね……でも、上\n手いって言ってもらえると、嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あんっ、そんなにチンポ震わせて……ヒクつかせなくても、お世辞じゃない\nって、ちゃんとわかってますからぁ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁあっ……こんなにたくましいチンポ、おっぱいで擦ってたら、アソコに\nも欲しくなっちゃう……やぁん、淫乱とか言わないでぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですよ、今はパイズリ……ですよね？　しっかりおっぱいで気持ちよ\nくしますから……安心して、楽しんでください……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁ、はっふぅ……大きいでしょう？　ここには……もっと大きい人もいる\nみたいですけど……でも、自信あるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「そうですよぉ……普通なら、爆乳っていいサイズですから……あんっ、あふ\nぅ……町を歩いてたら、男の人はみんな見てきますし……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んんぅ、そんなエロおっぱいの……パイ圧具合はどうですか？　ええ、聞か\nなくてもわかってますけど……教えて欲しいんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「イキそう……ですか？　ふふっ……はぁい、よく言えました……じゃあ、こ\nのままおっぱいで搾り取ってあげますからねぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「遠慮なく、わたしのおっぱいまんこに中出ししてください……んっ、はっ、\nあはぁ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はっ、はふぅ……そうでしょう？　揺れまくって……エッチでしょ……？　\nんっ、んふぅ……もっと揺らしてあげますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁっあぁ……あんっ……！　中で、また大きくなってます……出ます？　\nもう出ちゃいます？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ぎゅっぎゅうって……押しつけながら、はっ……んッ……おっぱいで、擦っ\nて……んっあっ……はぁ、はぁっ……あぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「いいですよ、出して……全部、わたしのおっぱいにください……あなたの熱\nいザーメン……ドクドクって、出してくださいぃ……んんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっ……あっんんんんっ！　すごいっ……ドクドク出てるっ……くっ、ふぅ\n……ンっ、あぁ……熱い……はぁあっ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ホントすごい……です……まだ出てる……夫と全然違う、若いチンポすごい\n……ああっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はふぅ……たくさん出ましたね……ちょっとびっくりしちゃいました。でも\n、それだけ気持ちよかったってことですもんね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「もちろん嬉しいですよ。久しぶりに男の人から求められて……女としての自\n尊心が取り戻せました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あら、どうしました？　ふふっ……すみません、ちょっと意地悪しちゃいま\nした。もちろん気づいてますよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「若いんですから、一回で満足するわけないですもんね……ちゃんとお世話し\nますよ、あなたが満足するまで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ええ、わたしのおっぱい……たっぷり楽しんでくださいね……んっ、あぁっ\n……チンポも喜んでるぅ……あ、あふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はぁあ……出したばかりなのに、全然萎えない……むしろ、さっきより大き\nくなってないですか？　んんっ、素敵です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱいが気持ちいい、から……？　ふふっ……嬉しいこと、言っ\nてくれますね……もっとサービスしたくなっちゃう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はっ、んっ……もっとおっぱい揺らして、チンポをむにむにって…\n…してあげますからね……はぁ、あっあっ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あん、すごぉい……チンポがまたビクビクいってますよ……んっ、んんっ…\n…ザーメンがヌルヌルしてて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はあっ……くうっ、うぅんっ……どうですか、さっきより、もっと気持ちい\nいですよね……？　んふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうですか……気持ちいいですよね？　さっきから、腰が動いてま\nすもんね……あっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「いいですよ、あなたのザーメンでドロドロになったエロパイに……このチン\nポ、好きなだけ擦りつけてください……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅっ……なんですか？　わたしも乳首勃ってる……さあ、どうで\nしょうか……ふふっ、知りませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わたしのことはいいですから……ほら、んっ、んんっ……早く、イッてくだ\nさい……また出そうなんでしょう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「もっと強く……ですか？　わかりました……んっ、ふうっ、ちょっとおっぱ\nいが滑るので……待ってくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ……これくらい、簡単ですよ……あっ、んぁあっ……でも、こ\nんなに元気なチンポは初めてかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「嬉しいです、こういうオスを感じられるチンポに求められて……わたしもキ\nュンキュンしちゃいます……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ……あんっ……あぁ熱い、本当に熱いです……んん、それにヌチ\nャヌチャって、イヤらしい音がして……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ほら、あなたも聞こえますよね？　んっ……こうやって、強く擦ると……あ\nっ、あふっ……んっあっあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「またイキそうですか？　大丈夫です、むしろそれだけ気持ちいいってことで\nすから、わたしは早く出してもらったほうが嬉しいです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んっ、ンはあっ……！　それで……また中に出しますか？　それとも……は\nんっ……ぶっかけますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「もちろん、好きにしてください……どちらでも、ちゃーんと……おっぱいで\n、受け止めますから……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ほ、らぁ……はやくぅ……んっ、んふぅ……どうしたんですか？　変に我慢\nしないでください……ねえ、んっ……ねえ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「もっと楽しんでたい？　あら……そういうことですか……安心してください\n、いくらでもご奉仕しますから、いっぱい出してください」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「お若いんですから、二回や三回くらい余裕ですよね？　ほら……ほらぁ……\nわたしのデカパイに……んっ、んんっ……ザーメンくださいっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……んんんぅぅぅっ！　はっああっ、あぁあぁぁぁ……はあぁぁ\nっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んっ、ンンっ！　すごいっ……またこんなに……あぁあっ……んっ、たくさ\nんっ……はぁ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「さっき出したばっかりなのに……ドクドクいってるっ……あんっ、あぁぁぁ\nっ……あ、熱いぃ……はぁんっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁっ、やっぱり若いって素敵……んふぅっ……あんッ……ネバっこくて、\nドロドロのザーメンがいっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はあはあ……はんっ……匂いもすごい……ここまで、匂ってくる……ザーメ\nンの濃厚な香りが……あ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「これだけ出して、まだ硬いなんて……本当に元気ですね……あんっ！　胸の\n中で、ビクビク跳ねてるぅ……生きてるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ふぅ……いかがでしたか？　わたしのおっぱいご奉仕は……ご満足してもら\nえましたか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「うふふ……ですよね？　こんなに射精してくれたんですもの……でも、改め\nて言われると嬉しいですね……女としての自信がよみがえってきます」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「またですか？　ええ、もちろんいいですよ。こんなに悦んでもらえるなら…\n…わたしも、もっとサービスしたくなりますから」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「はい。いつでもこのおっぱいでご奉仕しますね。ヌキたくなったら、いつで\nも呼んでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁっ！　ま、ってっ……あっあっ……はぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ！　ひゃぁ、ああっ……胸に、かかって……ひゃあっ……う\nぅっ、うふぅ、うぅんっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫です……ちゃんとおっぱいで、受け止めますから……出して、く\nださい……んんっ……あぁっ、すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……す、すごい量ぉ……鼻にくる、匂い……濃くって……はあぁぁ\nっ、あっあふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_14" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「おっぱいが、ザーメンで……ドロドロぉ……あんっ……さっき出したばっか\nりなのに……こんなにぃ……んっ、んぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ひゃあっ……おっぱいで、って言ってるのに……顔にまで……んっ、んぶっ\n……あぁっ、あぁぁあっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_12" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「ど、どんだけ溜めてたら……こんな出るんですかぁ……あふっ……ンン、す\nごっ……いぃ……ひぃうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「いっぱい、出してもらえて嬉しいですけど……顔も胸も、ぐちょぐちょにな\nっちゃいましたぁ……あぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_13" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「うぅ……ま、またですか？　そんなにわたしのおっぱいが気に入ったんです\nか？　そこまで言われたら、断れないじゃないですかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「わかりました。またいつでもおっぱいで、ご奉仕しますから……んっ……楽\nしみにしててくださいね」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018201_01_12" ]},
