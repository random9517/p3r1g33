{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉおおお～っ！　焼肉ぅ～っ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「つ、強い！　いつものカツマ様じゃないぞ！　まさかこれが、肉欲の力……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000807_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「カツマ様、そんなに焼肉食べたいんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000805_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あったりまえだぁあああ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「あ、バナナの皮が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふげっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「うわ、後頭部がもろに電柱に！　痛そ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000807_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぎゅぅううう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「あれ！？　ちょっと！？　カツマ様！？　カツマ様ー！　って、気絶しちゃ\nった……。どうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「まあ、いいんじゃない？　しばらくの間、ほむらさんたちの味方につけなく\nすればいいわけだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「そだね。任務完了ってことで。それじゃカツマ様、お先に失礼しまーす！　\nおやすみなさーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030109090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000807_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ、終わったようですな。いちおう、ご主人の様子でも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こ、これは！　なんということでしょう！　……ご主人！　ご主人ーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "テロップ" ]},
		{"command":[ "SETTEXT", "「×月▼日　夜　カツマ　失神」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_980109090001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお……ご主人。しんでしまうとはなさけない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010109090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　勝手に殺すな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「カツマ、負傷につき欠勤。その知らせは翌朝、本人によってメールでＥＤＯ\nに伝えられ、一部の女幹部を動揺させた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109090001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「具体的に言って、彼女のことである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109090002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「…………誰？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……カグヤ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そしてもう一人。まりあもまた、カツマの負傷に動揺していた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109090003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どこへ行く気？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマに怪我をさせたのは、ダイヤナのピースムーン。さっき、クッキーを\nもって謝りに来た……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええ。わたしのところにも。なぜかはわからないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109090003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あの子たちは命令で動いただけ。悪いのはダイヤナとセレーナ。それに……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「Ω（オメガ）組ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109090004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だから、ほむらのところに行く。ダイヤナとセレーナに反省させるには、そ\nれが一番」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……そうね。いい考えだと思うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109090005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……行きましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109090006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109090007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ダイヤナの行動は、カグヤとまりあの怒りを呼んだ。以後、二人はほむらた\nちと共同歩調を取ることとなる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109090004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「カグヤとまりあが正義（まさよし）に赴く数時間前。もう一人の女幹部がル\nナテミスのもとを訪ねていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109090005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　いいかげんにバカな真似はよせ！　これ以上、任務をおろそ\nかにするな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッドの任務に支障は出ていないはずだぞ。非番の\nときになにをしようが私の勝手だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そういう問題ではない！　騒ぎが大きくなりすぎだと言っているのだ！　お\nかげで、カツマまで怪我をしてしまったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕が？　ははは！　なにをしでかしたのやら。おおかたバナナの皮でも踏\nんづけて、後頭部を電柱にぶつけたりしたのだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なぜ知っている……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ホントにそうなのか！？　冗談のつもりだったんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109090003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「冗談を言っている場合か！　とにかく、これ以上カツマに迷惑をかけるな！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさい！　だいたい貴様はカツマカツマとうるさいんだ！　こちらの世界\nのカツマは、おまえになんの関わりもないだろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109090004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「関わりがないことはないだろう！　カツマは我々の仲間だぞ！？　その仲間\nが怪我をしたというのに、貴様はタダ飯のほうが大事だというのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあまあ、アナザー。少し落ち着きな。ほら、お茶でも飲め」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109090001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「むぅ……そうだな、いただこうか……ずずっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………………飲んだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109090002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん？　ああ、飲んだが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109090005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0079" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「――っ！？　なんだ？　このお茶、いったい……んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ううっ！　腹が……っ！　貴様、さては……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0080" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あははははは！　そうさ！　一服盛らせてもらったよぉ！　この超強力下剤\nをねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109090003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふふふふ……その下剤は効くぞぉ？　効きすぎて、３日は家から出られ\nんだろうなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109090006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おのれ……っ！　卑怯な真似を……！　貴様ら、そこまでして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109090010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、そうさ！　そこまでして飲む価値はあるのさ！　ここのマスターがた\nめ込んでいた、秘蔵の銘酒コレクションはねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109090004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
