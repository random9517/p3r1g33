		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んぅうううっ……♪　ああああぁあっ♪　ありがとうっ……ありがとぉおっ\n……！　届いてる、チンポから精子届いてる、子宮に入ってくるっ！」", "NORMAL" ]},
