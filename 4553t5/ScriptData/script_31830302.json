{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「フフ……今更、私とラブホテルに来たことを後悔しているの？　そんなハズ\nないわよね。そんなに股間をパンパンに腫らしておいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「クリスマスにこんな場所に来るカップルは、盛りがついてヤることしか頭に\nない……。私もあなたも同じ。そうでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ねえ、早くこっちにきて。もう待ちきれないの……はぁ、はぁ、んもう、服\nを脱ぐのももどかしいわ……。さ、ベッドに上がって……あぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「じゃぁーん……♪　フフフ、私がこんなに大胆なポーズをするだなんて想像\nしたこともなかったんじゃないかしら。でも、いいのよ。今夜だけは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018303_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「クリスマスなんだから、うんといやらしい自分になろうって決めたの。……\nえ？　理由？　し、知っているでしょ。……そうよ。夫が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「私をこうなるまで放っておいたから。こんな大事なイベントの日にまで、仕\n事を優先して帰ってこないから。だから、ずっと辛かったのよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あ、あなたが気にすることじゃないわよ。人妻には色んな事情があるの。特\nに……私の場合、熟れた身体を持て余しているっていう事情がね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ど、どうかしら？　この年で、こんな服を着て……淫乱ポー\nズしている私って……最高にスケベで下品で、どうしようもない女でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ラブホテルに若い男を連れ込んで……。これから浮気セックスするんですも\nの。理性も常識も全部捨てたわ。それでもいいから、シたいの。お願い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……あっ……♪　こんなに脚を広げているのに、まずはオッパイ？　んっ、\nふふ……あなた、本ッ当に私の胸……好きね。大きいのがいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「いっつも手の跡がつくまで……。あんっ！　そうやって、ぐにぐに揉みまわ\nして……。あっ♪　形を歪めて、力いっぱい揉みしだくじゃない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……ンッ♪　も、もう……だめぇ……♪　オマンコの準備、とっくに出来上\nがってるのに……あんっ。オッパイばかり……。っあっ！　あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ち、乳首を指でクリクリしないで……♪　も、もう充分硬くなっているから\n……。はぁっ♪　い、今から刺激しなくてもコリコリになってるからっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……こ、こらぁ♪　敏感になってる胸の先……転がして遊ばないで。焦らさ\nないでよぉ……！　んぁっ、あぁ、オマンコ、オマンコ触ってったらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んッ！？　えっ……お、おっぱいを吸うの？　……あっ♪　乳首を舌でレロ\nレロして……？　あっ♪　も、もういやぁ♪　甘えん坊のつもりぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、んっんっ、んん～……！　アソコがびしょびしょになってるの、\nわかってるくせに胸いじりばっかりぃ……！　んぁっ、あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「も、もういいの！　おっぱいは……あぁっ！　アソコ、アソコ触って！　…\n…んぅっ！　そうよ、指を入れて……掻き回して……！　っんんぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～～っ……！　ね？　すっごくトロットロでしょ……あんんっ\n。だって、ずっと濡らしていたんだもの。んぁんんっ、指、指気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「にゅぷにゅぷって入れたり出したりしてぇ……♪　ッあぁああっ！　いいの\n、あなたの手マン好きっ……！　もっと音を立てて、深くいじってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ッんーーーーっ！？　っふぁっ……♪　わ、わかった？　今、私が軽くイッ\nてしまったこと……。ええ、中がうねうねして締まったでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「濡れてシロップたっぷりのここに、オマンコにオチンポ入れたら気持ちいい\nわよ。約束するから、入れて……あっ。そう、その大きいオチンチンっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「私に食べさせて……。っあああああああっ！　あぁっ！　あぁっ♪　入って\nきた……ぁ♪　チンポ、夫とは違うデカチンポ、カリ高ゴツチンポっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「やだ……やだぁ♪　気持ち、イイ……あああっ！　入れられただけで、一突\nきで意識がトんじゃう！　なんて男らしい長いチンポなのよぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んぁっ、んあっ！　いやっ♪　もうイキっぱなし♪　イクの止まんない！　\n……え？　私が腰を揺らしてる？　自分から求めてる？　だってぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「欲しかったんだもの……コレが♪　あっ♪　あぁっ、ねぇえ♪　あなた、ま\nたチンポが成長したんじゃない？　前より太くなってる気がするぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ッあぁっ♪　あぁああ……！　こんなに美味しいチンポねじこまれて♪　腰\n振らない人妻なんていないわよぉお……！　あっ♪　中毒になっちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「勝手に♪　オマンコうねうねさせながら……んんっ！　腰揺らしちゃう、オ\nチンポ味わっちゃう……！　っあっ♪　太い♪　大きすぎ、かたぁいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「突いて……あなたも突いて♪　ずっとオマンコイッてるから……っ！　ビク\nビクしてて気持ちいいでしょ？　あっ……痙攣がおさまらない……ぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「イクぅ……！　イクっ♪　んぁああっ……！　チンポが気持ちいいところ、\nぐっちゅぐちゅこすってくるぅ……ああっ、そこ、そこ感じるのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「Gスポットに……ちょうどでっぱりが当たって♪　ゴリゴリされてる♪　あ\nぁっ♪　あっ！　あっ！　こんなチンポ、反則よ……おかしくなるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっあっ♪　若いコの……力強くてたくましいチンポ……♪　愛液\nが溢れちゃう……んぁあっ、アソコが熱くてのぼせるわ……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あぁああっ……！　どうしてあなたのチンポってこんなにすごいのぉっ……\n！　浮気、なのに本気イキしちゃう、だめ、なのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「このチンポしか愛せなくなっちゃうわ……！　……っん！？　やっ♪　あな\nたも興奮してるのね♪　今チンポが大きくなった……それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あっあっ♪　腰の動きがせわしなくなってるわよ♪　フフっ、イキそうなの\n？　ねぇ～？　このまま、人妻のオマンコに生で中出しするつもり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……いいわよっ♪　そういう無茶な男、好きだから……あぁっ♪　きて♪　\n避妊無しの生中出し♪　一番奥で種付けしてよ、早く、はやくぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「っあぁあああああああぁッ♪　はぁあああっ、あぁああああ……！　あぁあ\nああっ……！　バ、カ……♪　本当に中で出すなんてぇええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あひっ♪　んひぃっ♪　ホントに……！　ホントに妊娠しちゃうからダメよ\n、中で出すのはダメ……！　あああっ♪　ダメって言ってるのにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「私がダメって言うたびに奥で出てる量が増してくぅ……！　あっあっ！　私\nっ……種付けされちゃって、る♪　熱い精子注がれてる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「危険日なのに、避妊もしないで……コスプレしながら、若い男のチンポにし\nっかり種植えられてる♪　っああああっ♪　ドクドク出されてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「どぴゅどぴゅされて……はしたなくイッちゃう……！　あ～～～～ッ♪　イ\nッグっ……♪　イグぅっ！　んん～っ！　ずっとイッてるのぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「っあ……♪　あ……、ご、めんなさい……。イキすぎてぼうっとしちゃって\nたわ……。オマンコの中、あなたの精液でいっぱいで、熱くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「身体の芯からあたたまって、すごくいい気分なの……。っン……♪　これっ\nて、何度も本気でイかないとならない状態、なんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「頭がぼーっとするわりに、アソコの感覚だけは研ぎ澄まされて敏感になって\nいて……。精液がたっぷり入ってるのがわかるわ……。って、ンッ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「な、なんでまた腰を動かすの……？　え？　これだけ大量に射精しておいて\n、まだ、まったく萎えてないの？　むしろ、硬さが増してるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「や、だ♪　無理よ……♪　いくら戦闘員してるからって、あなたのチンポの\n体力に私のオマンコがついていけないわ、……あっ♪　だめ♪　だめなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　突かれると……やめたくなくなっちゃう。このままし続けたくな\nっちゃう……っ！　あっ♪　あっ、そんなにがっつかないでよぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「わかったわ、するからっ……二回戦していいからっ！　少しは優しくして…\n…って、あぁッ！？　んあああっ！　激しすぎるわよぉっ！　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あっ！　あっ、ああ……！　中出ししたてのヌルヌルの膣内を\n、オチンポがむちゃくちゃに貫いて……んぁっ♪　なにこれぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018303_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ぐっちょぐっちょってすっごい音しちゃってる♪　あっ……恥ずかしいわよ\nっ……あぁんっ！　私、またすぐイッちゃうし……やだぁ♪　あっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぅっ……！　ううっ♪　身体をよじって逃げても……あンッ！　チンポが\nデカすぎて全然逃げられ、ないぃ♪　あひっ！　だめ、強すぎるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あん！　あん！　あぁんっ！　子宮が、オマンコの粘膜があなたのチンポに\n屈しちゃう……！　あなたのチンポを愛しちゃう、好きになちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
