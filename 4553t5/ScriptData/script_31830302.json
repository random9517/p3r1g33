		{"command":[ "PLAYVOICE", "v2_183_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あっあっ♪　いじわるしないでちょうだいよぉおお♪　私に♪　\n淫乱人妻の濡れ濡れオマンコに♪　不倫中出しして、いっぱい出して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0304220" ]},
