		{"command":[ "PLAYVOICE", "v2_183_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「逃げ場がなくなるくらい、どぴゅっ、どぴゅっ、ドクドクって中に注入され\nてる……っ！　あぁっ、嬉しいわ……最高の不倫セックスよ……っ」", "NORMAL" ]},
