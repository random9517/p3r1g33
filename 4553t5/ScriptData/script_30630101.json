{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_01" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "063_0103101" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「こ……こんな時間にお呼び出しされて何かと思えば……な、なんてことをさ\nせるのですかぁ！　うあぁ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103102" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「は？　……これは戦闘時の能力を向上させる、為……？　そう、だったので\nすか。すみません、私、てっきり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103103" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「いや、だって……ほら、いきなりその……胸を出せとのことだったので……\nエッチな、ことかと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103104" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それだったら納得、です！　私の胸に……た、隊長さんの……アレが挟まっ\nているのも、納得、ですね！　アハ、ハ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103105" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「は、はわわ……。胸というか……おっぱいに、こんな用途があるとは……学\n校では教えてもらえませんでしたよぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103106" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「い、嫌じゃないです。嫌とか、そんな問題じゃなくて……ううぅ……頭がパ\nニックなんです！　ううぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103107" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長さん！　あんまりじろじろ見ちゃ駄目です。今私、すっごく恥ずか\nしいんですよ？　だから見るなら……薄目でお願いします。薄目でね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103108" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「え？　これだけじゃなく……舐め、る……？　何をですか？　……はぁ……\n隊長さんの、コレを？　はぁ……って……はぁ？！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103109" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「い、いえ……隊長さんの力には、皆頼り切っています。だからパワーアップ\nするなら是非とも協力したいです、が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103110" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「……違いますって、やります！　やりますってばぁ！　ちょ、ちょっと……\nびっくりして、ちょっと……怖いだけです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103111" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ぺろっ……うぅ、変な味……。ぺろっ……れろぉ……はぁぁ……。生臭くて\n……熱いよぉ……ううぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103112" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あうぅ……そりゃー、怖い……ですよ。だって、こんなの……初めて、見る\nし……じゅるぅ……れろれろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103113" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「見るの、初めてなんだから……舐めるなんて……初めてに決まってます！　\nだからほら、この拙い動きも、納得でしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103114" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ちゅぱぁ、れろぉ。んちゅぅぅ……れろれろぉ……はぁ……すみません……\n。これでいいのですか？　あってます？　ううぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103115" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「どうすればいいのか、さっぱり分からないんです……。れろぉ、んちゅぅぅ\n……はぁん！　今これ、ビクってしたぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103116" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　舐めるだけじゃなくて……咥える、の？　はぁ、そうすればいいの\nですか。了解、しました……はぁむ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103117" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んぶぅ……じゅぷぅうぅ……はぁ、れろぉ……んじゅるぅぅ……はぁ、はぁ\n……息が、苦しくなりますね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103118" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「でも、これで隊長さんが……パワーアップするのなら……！　よし、れろぉ\n……ちゅぱぁ……ちゅぅううぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103119" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「さっきより、大きくなってる……れろぉ……ちゅぱぁ……。血管も、浮いて\n……はぁ……硬い……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103120" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ……口の中で、はぁ……隊長さんのが、ビクビクするから……はぁぁ\n……舐め辛い、ですよぉ、大人しくて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103121" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるぅぅ……れろれろぉ……はぁ、ちゅぱぁぁ……はぁん。さっきより\nも、生臭いのが……強く、なってるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103122" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるぅ……れろぉ、はぁ……隊長さんの先っぽから……はぁ……透明な\nお汁が、出てきましたよ？　れろぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103123" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「何これ？　んぅぅ……変な味、するぅ……。分かってますよ、これも、舐め\nるんですよね？　れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103125" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、ちゅぱぁ……れろぉ……はぁ……んうぅ、舐めても舐めても……溢れ\nてくるぅ……はぁ……とろとろのお汁……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103126" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それに、このオチンチン……さっきより熱くなって……ふひゃ！　オチンチ\nン、とか言っちゃった！　ああぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103127" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいよぉ……もぉ……。そうだ、任務！　私は任務に集中しちゃ\nいます！　んじゅるぅぅ……れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103128" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ちゅぷぅぅ……じゅぷぅ……はぁ、隊長さん……私の、おしゃぶりで……は\nぁ……パワーアップ、して下さい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103129" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んぅぅ……口の中が、隊長さんのオチンチンの味で……いっぱい。あはぁ…\n…エッチな気分になるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103130" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ぺろぉ……じゅろおおぉぉ……んじゅるぅぅ……落ち着い、て？　んぅ？　\nん？　んぐううぐぐぅぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103131" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ぷはぁ！　ああぁ……なっ！　ひっ……ええぇ？　んひゃああぁあぁぁ……\nっ！　こ、こんな！　こんなのぉ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103132" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あはぁ……あっ、これって……ええぇ？　隊長さん、これは一体……ふわぁ\nぁ……このお汁、あ、熱いよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103133" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ……と、止まらない……！　まだ出て……あはぁ……お汁、止まって\nぇぇ……もぉ、飲みきれないっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103134" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「こ、零れちゃう……隊長さんの、オチンチン汁……ふあぁぁ……。ご、ごめ\nんなさいぃぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103135" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、後から後からいっぱい出てきたから、沢山零しちゃった。お行儀悪\nいですね、本当にごめんなさい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103136" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「これ、零れたものは、ちゃんとお掃除しますから。……え？　気持ち、良か\nったんですか？　ええぇ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006301_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103137" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それで、こんなにいっぱいお汁が出たと……そ、そうなのですか。じゃあ、\nじゃあ私……任務果たせたんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103138" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「……そっかー。あ、アハハ！　それは嬉しいです！　良かった。初めてだっ\nたから……本当に夢中で必死で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103139" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「どうですか？　パワーアップ出来そうですか？　……もう、してる？　わぁ\n、それは良かった！　ばんざーいです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "063_0103140" ]},
		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「これでいいのなら、是非にまた手伝わせて下さい。次も全力で……その、隊\n長さんのオチンチン舐めるの、頑張りますので！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}