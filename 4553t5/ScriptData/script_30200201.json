{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そんなにジロジロと我の身体を見つめて、どうしたのであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「いつもと違うボディだから気になっていると……ふむ。確かにこのボディは\n、色々と便利なのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「随分とエッチなことがしやすそうな身体をしているだと？　まったく……そ\nなたの思考は、いつも卑猥なことだらけであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「だが、その発想は間違っていないのである。このボディを用いたパイズリは\nとても好評であったし、いい思いもさせてもらったのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「その時の話が聞きたいのであるか？　別に構わないのであるが……そなたが\n聞いても、あまり面白くないと思うのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「機械の身体でもパイズリは出来るが、やはりこのボディだと、人間っぽさが\nより際立つのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002002_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「柔らかさなどは人の胸と変わらないようにしてあるし、胸の大きさもそれな\nりであろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「これだけ大きければ、そなたのチンポなど、簡単に挟めてしまうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「……ん？　そんなにしょげた顔をしてどうしたのだ？　なに？　チンポが小\nさいと言われたみたい、であるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「人間の男は生殖器の大きさを、ステータスにするのであるか……変わってい\nるのであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「正直なところ、我はそなたのチンポ以外見たことなどない。故に、大きいか\n小さいかの区別などできないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「んんっ……！　急にオチンポが跳ねて、元気になったのである……！　そん\nなに暴れられると、挟めないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我がそなた以外のチンポを知らなくて嬉しいのであるか……？　ふむ。人間\nの男は、独占欲が強いのであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「だが、これはあくまでも我にチカラを授けるための行為である。だ、だから\n、決して……恋愛的な意味ではないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「と、とにかく、はじめるのである！　そなたは我の胸に身を委ねておけばい\nいのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　随分とカタくなっているのだな……先ほどのやり取り\nで、興奮したのであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そんなにもはっきりと言わなくていいのである……だが、素直なのは良いこ\nとであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「褒美といってはなんだが、思い切りシゴいてやるのである……こうして、一\n気に胸を上下に擦り上げれば……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「チンポのデコボコしたところが、胸に擦れるのである……！　カタいのに、\n妙に柔らかくて……なんだか、クセになる感触であるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「このデコボコしたところを刺激されると、気持ちいいのであるか？　ならば\n、ここを重点的にシコシコしてやるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……くっ、んはあぁ……！　ただ上下に胸をシゴいているだけ\nなのに、随分と元気に飛び跳ねるであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「これでは、擦りにくいのである……もっと胸を寄せて、いろんな方向からシ\nコシコするのである……んむっ、あっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「チンポの動きに合わせて、我の胸がいやらしくカタチを変えるのである……\n熱い感触が、胸全体に広がっていくのであるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、ああぁ……！　チンポの先端から、いやらしい汁がドクドク\n溢れてきているのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「確かこれは、尿道球腺液……我慢汁という名であったな……人間の男が快感\nを憶えると、チンポから溢れ出る汁であるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そなたは我がこうして胸でチンポをシコシコするほど、強い快感を得ている\nのであるか……ふふっ。嬉しいのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ならばもっと感じさせて、たくさん我慢汁を吹き出させてやろう……！　ん\nっ、あっ、あぐっ……はぁ、ああっ、ふぐっ、くふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あんんっ……！　我慢汁がチンポから垂れて、我の胸を汚して\nいるのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「まったく。王の身体を許可なく汚すとは……本来であれば、不敬罪で神罰を\n下すところであるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「だが、このボディは戦闘用ではない……争いには不向き故、此度の我慢汁は\n不問に処すのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あふっ、くっ……あっ、あっあっ……！　な、なに？　我慢汁だけでなく、\n精液も出そうであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「パイズリをすれば、ザーメンが出ることは必然であるからな……よかろう。\n射精を許可する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ただし、顔にはかからないようにするのである……！　そなたのザーメンの\n味を憶えたら、ずっとメモリーに残ってしまいそうであるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あひっ、んあんっ……！　さあ、早く出すのである……！　我の胸に、そな\nたのザーメンをいっぱいかけるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……！　ふっ、ひぐっ……！　あっ、あっ！　チンポがよりい\nっそう暴れているのである……あっ、んああっ、ふあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ああっ……！　熱いザーメンが、チンポから吹き出しているのであるぅ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ザーメンから生命のチカラ強さを感じるのである……！　これが人間の精子\nなのであるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ひゃううぅ……！　びちゃびちゃといやらしい音が、我の\n胸から響いてくるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「こんなに出すなんて、予想外である……！　我のデータでは、射精というの\nはもう少し大人しく、量も少ないはずである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　百聞は一見に如かずとは、まさにこのことであるな…\n…！　んっ、くふっ、んふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我の胸をここまで汚すとは……よほどこのボディによるパイズリが気に入っ\nたのであるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「もっとパイズリをして欲しいのであるか……？　そ、そう言われても困るの\nである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「これ以上するのは、行き過ぎというか……する場合は、もっと親密な関係に\nなってからというのが、我のデータ的な常識である……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「えっ……わ、我と親密な関係になりたいと申すのであるか……？　だが、そ\nなたは人間……我は機械であるからして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そもそも、これは我にチカラを授けることが目的であって……！　ああ、も\nう！　わかったのである！　もう一度、パイズリをしてやるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「んむっ……はぁ、あああぁ……！　チンポとザーメンの熱が、どんどん体内\nに染みわたっていくのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「それにこうしてチンポを擦るたびに、摩擦による熱も加わって……んっ、あ\nっ、あぁんっ！　どんどん変な気持ちになるのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「回路だけでなく、胸の奥まで熱くなってくるのである……な、なんであるか\n、この今までにない感覚は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「もしや、これが感情というモノであるか……？　だが我は機械である……そ\nのようなモノ、あるはずないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ああっ……！　んひっ、んっ……あふぅ……！　チンポが胸の中で擦れるた\nびに、熱いモノを感じるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「これがチンポの熱なのか、ザーメンの熱なのか……もうわからなくなってき\nたのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「で、でも……これだけはわかるのである……！　我はそなたを欲しているの\nである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そなたの気持ちだけでなく、チンポも、ザーメンも……全部欲しいのである\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ……くううぅん……！　我の言葉に、チンポが反応しているの\nである……！　ビクビクと脈を打っているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そんなに跳ねさせないで欲しいのである……！　上手くパイズリできなくて\n、そなたを感じられないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「はぁ、あふっ、んふうぅ……！　エッチなニオイも濃くなってきているので\nある……！　クサイのに、不快感はないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あっ、ひぐっ……！　んっ、あっあっ……！　気持ちいいのである……胸で\nチンポをシコシコしているだけなのに、感じてしまうのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「やあっ……！　あひっ、んんっ、うぐっ、んきゅうぅ……！　このままでは\n、イッてしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「そ、そなたもイキそうなのであるか……！？　ならば、一緒に……一緒にイ\nキたいのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「王である我が許可する……！　我と共にイクのである……！　あっ、ああっ\n！　イッ、イクッ……んっ、んくううううぅ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あふううぅ……！　また我の胸の中に、いっぱいザーメンがかかっているの\nであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「まるでオマンコに出されているような……そんな感覚を憶えてしまうのであ\nる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　もっと出して欲しいのである……！　そなたのザー\nメンを、もっと感じさせて欲しいのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「んっ、んふううぅ……！　まだこんなに出るとは……本当にすごいのである\n……！　あっ、あひっ、んはあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我もまたイク……！　あっ、ひああぁ……！　ザーメンをかけられながら、\nイクのであるぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ふぅ……あはぁ……とても心地よい時間であった……こ、これで我も、チカ\nラを授かれるはずである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「それに、その……我と親密な関係になりたいというそなたの気持ちも、じゅ\nうぶん伝わったのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「で、では……親密な関係になる証として、指輪の交換をするのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「古代エジプトでは、この円の形が永遠を表すとして、指輪を永遠のシンボル\nとしていたのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「指輪交換は結婚の誓い……つ、つまり、指輪を交換したら、我らは夫婦とい\nうことであって……ああっ！　回路の熱暴走が止まらないのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　んひっ、はああぁ……！　我の身体に、そなたのザーメン\nが降り注いているのであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「谷間だけでなく、胸全体を汚すとは……！　そんなにも、我を欲していると\nいうことであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ！　だ、ダメであるぅ……！　そんなに熱い想いを伝えられ\nたら、身体が壊れてしまうのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「記憶回路にもいろんな情報が一気に届いてきて……ああっ！　もうなにも考\nえられないのであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「エラー音がずっと鳴り響いて……あっ、んああっ……！　もう限界であるぅ\n～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁ……んっ、ふくぅ……全身のチカラが抜けていくのである……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫である……別に壊れたわけではない……少しばかり、身体の冷却\nが必要なだけなのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「ただ、チンポやザーメンの熱が残っているせいで……上手く冷却機能が働か\nないのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002002_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「いつもの我であれば、すぐに胸からチンポを離し、ザーメンを拭き取るのだ\nが……何故だか、そうしたくないのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「もっとそなたを感じていたい……そう思ってしまうのは、身体が熱で暴走し\nているせいなのであろうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
