{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ばぁ～んっ♪　トリック・オア・トリ～トぉ～♪　……なんっちゃってぇ。\nさっきも来たのに、また来て驚いた？　ふふふ、口がぽかーんって開いてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん～？　おっぱいとお口とでぇ、たっくさん精液を堪能して、今夜はこれく\nらいで許してあげようかな～なんて思って自分の部屋に帰ったんだけどぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……もらい忘れたお菓子がまだあったなぁって思って♪　……んふふっ♪　\nあなたもわたしを見て、また勃起してるみたいだし……いいわよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ここからは大人のハロウィンよぉ♪　期待しているいけないおちんぽを、吸\n血鬼さんが下のお口でいただいちゃう……。ふふ、こわい～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「怖くったってもう、満足するまでは帰ってあげないんだから～♪　あははは\nっ、イタズラの延長戦……もちろんうけてくれるよねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304105" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「わぁっ……♪　ね～え、ちょっとちょっとぉ～♪　わたしがこのお部屋に戻\nってこなくてぇ、朝まですやすや眠っていたらどうするつもりだったのぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「まだまだこんっなに精力が余っていたのなら、気軽に声をかけてくれてよか\nったのにぃ～♪　ふふふ、わたしが疲れちゃったと思って遠慮した？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そうねぇ～♪　お仕事だったら遠慮してくれるのは大・歓・迎なんだけど♪\n　……エッチなことは別腹だから♪　そこは頼ってほしいなぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……んん♪　最高にエッチなおちんぽぉ……♪　天井を向いてぇ、わたしの\n濡れ濡れおまんこを狙ってる♪　入れたい～？　え？　わたしはどうって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もちろん欲しくてたまらないに決まってるでしょ～♪　大好きなの♪　あな\nたのおちんぽ……特に、限界まで勃起してる時が最高……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ね～え？　これ、ちょうだぁい？　他の子に入れるのは他の日にしてぇ……\n？　今夜だけはわたしの……吸血鬼ラケシスさんに譲ってぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしのおまんこ、期待でもう奥までヒダヒダがぬるっぬるなの～♪　熱く\nなってるしぃ、粘膜がうねうねうねってるしい……。わかるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おちんぽ入れたら♪　絶対ぜったい気持ちいいよぉ？　溶けちゃうよ？　ト\nロットロにしてあげるからきてぇ♪　はぁっ、おちんぽちょうだ～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あっ♪　い、いいっ♪　この……ずぶぅううって入る瞬間っ♪　おちん\nぽの一番ぶっといところが♪　おまんこの入口を広げるこの瞬間んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁあああんんんっ♪　わたしの腰を持ち上げて、男らしく一突き\nに挿入だなんて、かっこよすぎて感じちゃうぅうう♪　あ～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「きゅんきゅんしちゃって、乳首も反応しちゃってるぅっ♪　うんっ、そうだ\nよぉ、また飲んできたの♪　追加のボニューデマクール♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「甘い母乳が出てくる方がぁ、あなたが興奮するって知ってるから♪　えっち\nなわたしはお薬だって使っちゃう……。っあっ♪　突き上げちゃだめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいんっ♪　母乳が噴き出しちゃうぅううっ♪　あぁんんっ♪　も\nぉっ♪　もぉ、あなたってわたしの喜ばせ方を世界で一番わかってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「最初っから最後まで、ずぅ～～～っと♪　一番強い快感だけが欲しいの♪　\nだってわたし……淫乱なんだもん、淫乱吸血鬼ちゃんなんだもぉん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　んぁああっ♪　ピストンされるたびにぃいいっ♪　おまんこぐち\nゅぐちゅこすられるたびに、おっぱいがっ、揺れて母乳出ちゃうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「そう、なのぉっ♪　激しくすればするほど♪　おちんぽねじこんで、子宮を\n突き上げて、わたしのおっぱいが跳ねるくらいに腰を打ちつけるたびにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「母乳っ♪　ママミルクがびゅぅううっ♪　ぴゅぅうううって噴き出しちゃう\nからぁあっ♪　撒き散らされちゃうから、楽しいよぉ♪　……あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わた、しもっ♪　あなたの動き以上に、腰をくねらせてぇええ♪　おまんこ\nうねらせて、うごめかせておちんぽを刺激しまくっちゃうからぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「二人で協力してぇ、い～っぱい母乳出しちゃお～っ♪　あんっ、あんっ♪　\n嬉しいな……っ♪　あなたと絡み合って、えっちなことできて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ビッチなわたしでも満足しちゃうくらいぃいいっ♪　強いおちんぽでどっち\nゅんどっちゅん種付け交尾してくれるのなんてあなただけだもんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ハロウィンに♪　セックスできてしあわせ～っ♪　あっ！　あっ！　いいよ\nぉ、壊れちゃうくらい激しくして♪　んふふ、壊れないから安心だよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あっ♪　んぉっ♪　でもぉおっ、あなたのおちんぽにだったら……壊さ\nれちゃうのもいいかなぁ～♪　それくらい気持ちいいのっ、あ～～～んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「腰っ、止まんない♪　男の子みたいにヘコヘコさせちゃうぅ♪　あっ♪　あ\nっ、欲望全開でごめんなさいねぇえ♪　えっちな吸血鬼でごめぇんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「でもぉ……っ、あっ♪　あなたも好きでしょぉ？　えっちなおねえさん♪　\nビッチでえっちな吸血鬼のおねえさん、の、トロトロおまんこ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　安心してねぇ♪　すっごくいっぱい濡れてるけどぉ……締まりは\nと～ってもいいんだから♪　試してみるぅ？　ほ～ら、きゅ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁんっ♪　おまんこ締めたら、おちんぽ嬉しそうに反応してるよぉ？　も\n～っとしてあげる♪　おねえさんおまんこで絞り取ってあげる……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んん～っ♪　んぅっ♪　ん～～～っ♪　これくらぁい？　もっと～？　……\nんんっ♪　ニュルニュルしてて、熱くて気持ちいいでしょお～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あれ～♪　反応がどんどん激しくなってきてるけど～……もしかして、\nそろそろぴゅっぴゅしたいお時間かなぁ？　んっ♪　中出ししたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしのおまんこの一番奥でぇ♪　赤ちゃんできちゃうえっちなお汁を……\nびゅびゅぅ～～～って気持ち良く発射しちゃいたい？　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……出したくなくても出させちゃう～♪　え～い♪　ビッチのおまんこが本\n気になったらぁ、もうぜ～ったい逃げられないの♪　出ぁ・しぃ・て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふぅうううううっ♪　んぁああああぁあっ♪　射精、しゃせいぃ♪　びゅー\nびゅーおちんぽぉおおっ♪　熱い精液に満たされてぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしもイッちゃお～っと♪　……はぁんんっ♪　気持ちいい～っ♪　イク\nっ……あぁんんんっ♪　あなたのくれる絶頂って本当に心地いいのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ♪　やめないでっ……！　そのまま出してぇっ♪　あぁんんっ♪　いい\nのっ、わたしの中に精液がどんどん入ってくるっ……気持ちいいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　ね～ぇっ♪　精液を出すたびに、ビクンッ、ビクンッてお\nちんぽが脈打つから……出てるのがよ～くわかってドキドキしちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っあぁあああっ♪　いつまでも絶頂の余韻がひかないわ……！　あんっ♪　\nそれどころか、ずぅ～っとイキっぱなしのあがりっぱなしぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぅんんっ♪　ふふ……♪　いっぱい出せたかしらぁ？　……とか聞いちゃ\nったけどぉ、精液の量と粘り気は、注入されたわたしの方がわかってるかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あのね……♪　す～っごくドロドロでネトネトの精液がぁ、わたしのおまん\nこの中を埋め尽くす勢いでびゅるっびゅる出てたよぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「半端じゃない量でぇ♪　ふつーはこれだけ中出ししちゃったら、三日間は復\n活しないだろ～って思っちゃうくらい、たっくさん出してくれたんだけどぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あなたのおちんぽってどうなってるの？　へにゃへにゃになっちゃうこ\nともなくて、まだ……硬いしぃ♪　わたしにもっとぉっておねだりしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん～～～♪　どうしよっかなぁ♪　わたし、さっきの射精でイケたからなぁ\n～……なんて、もったいつけると思ったぁ？　続けてするに決まってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「だって、まだまだ夜は長いし……♪　硬くなってるおちんぽを放っていなく\nなれるような、節度のあるおまんこしてないのよねぇ♪　残念ながら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……んっ♪　むしろ、さっきより激しいのがした～い♪　ケダモノみたいに\nぃ……♪　モンスターみたいに、がっついて、お互いを貪り尽くすのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「私が精液を食べる吸精鬼ならぁ、あなたは満月の夜のオオカミさん……♪　\nね？　おまんこ犯しまくりたいでしょ？　欲望のままに腰を振って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あッ♪　そうっ、そうやって！　我を忘れて本能で突いてぇっ♪　あは\nっ、んぁあっ♪　楽しいぃっ、気持ちいいぃっ！　またイキそうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁんんっ♪　イッちゃうわっ♪　中出しされて絶頂して♪　敏感になって\nるおまんこグチュグチュ貫かれて、ピストンされて！　イクっ、イクイクぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　わたしまでおかしくなっちゃうぅうっ♪　オオカミさぁん\n♪　食べて、わたしのこと……残さず全部味わってぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁッ♪　あっぁっあっ♪　すっごいぃっ♪　全身がガクガク揺れてるぅう\nっ♪　すごいよぉっ♪　おちんぽだけでわたしの身体揺らすなんてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あひぃいっ♪　感動してっ……！　快感で母乳溢れちゃうっ、あっ！　びゅ\nるっ、びゅるってミルク出ちゃうっ！　おっぱいもおまんこも悦んでる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふふふふっ♪　あっ♪　元々身体の相性がすっごく良いって思っていたけ\nど……すればするほど、もっと良くなってくなんて反則よぉ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしの身体……あなたに完全に攻略されちゃったぁ♪　見て♪　見てぇ♪\n　おまんこ突かれるたびに、乳首がどんどん硬くピンって尖ってく♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「クリちゃんも乳首もぉ♪　指でつまめるくらいコリコリになっちゃってるぅ\nう♪　あっ♪　あなたのおちんぽで、どんどん恥ずかしい身体にされちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「このままじゃっ……、あっ♪　日常生活がまともにおくれなくなっちゃうぅ\nっ♪　あなたを見るたび、発情して、えっちな気分になっちゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んんっあぁ、だめよぉ、これ以上したらわたしっ……♪　あなたに本気にな\nっちゃう、あなたのおちんぽしか使えなくなっちゃうぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……んっ♪　それでもいいのっ？　わたしにマーキングっ、してくれるのっ\n？　あは……♪　それならおねがい♪　出して、あなたの精液出して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304219" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしをぉおっ♪　精子でモノにしてぇっ♪　あんっ！　イクっ……イッち\nゃうからぁっ！　わたしがイッて油断した隙に……出してぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304220" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
	
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁんんんんっ♪　きたぁああっ♪　大好きな精液♪　あなたの精子がびゅ\nびゅぅ～って出てるぅうううっ♪　あっ、止まらないぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304301" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　おまんこの入口から子宮の奥までぇっ♪　あがってきてるっ\n、精液あがって……あぁんっ♪　しっかりわたしに種付けしてるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あふぅっ♪　お返しに……イキながら母乳を噴くところっ、何度でも見せち\nゃうねぇっ！　あっ、あぁっ！　出して出されて……もうめちゃくちゃぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「お部屋の中が、母乳の甘ったるい香りと……ひぁんっ♪　精子のくっさい臭\nいでムワムワしてるよぉ……っ♪　なんて淫靡なニオイなのぉっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あんっ♪　他の子が遊びにきたらっ♪　あっ♪　気付かれちゃうねぇっ♪　\nわたしとあなたがぁ、母乳と精液を交換して交わってたことぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ♪　バラしていいから全部出してぇっ♪　っああああああっ♪\n　イカせてっ！　中出しでイクぅっ！　イッちゃう果てちゃうぅううんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んん～♪　あ～、最高に気持ち良かったぁ～♪　ハロウィンって本当に素敵\nなイベントねぇ。何度でも男の人を……あなたを襲っていいんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「え？　本来はそういうイベントじゃ……ない？　またまたぁ♪　そんなこと\n言って、な～んにもなかったら、さびしくてベソをかいちゃうくせにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……わたしはね？　あなたを襲う理由ができるから、イベントがあるのは大\n歓迎かな～♪　さすがに、なんでもない日に襲うのは迷惑かな～って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「え？　そうでもない？　そうなの～♪　じゃあ、毎日誘いにきちゃおっかな\nぁ。朝でも、昼でも、夜でも……わたしはいつでもOKだからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ん！？　ふぁっ……♪　あはぁっ♪　身体にかけたいのぉ～？　あんっ、ん\nんっ♪　いきなりだったから驚いちゃったけど……こういうのも好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304401" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おまんこの中で感じる射精おちんぽもぉ♪　身体全部で精液を浴びるザーメ\nンシャワーも、どっちも好きすぎて私には選べなかったからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたが♪　あんっ！　こうやってぶっかけっ♪　精液ぶっかけしてくれて\n嬉しい～っ♪　色んなところにかけてっ、できるだけ広い範囲にっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふっ♪　あったかい……！　もっとかけてぇ……♪　あぁ……っ♪　お口\nにもおまんこにも出して欲しかったけどぉ、それは今度のお楽しみぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「今はこのヌルヌルを……♪　肌に広がる真っ白な精液をうんと楽しまなくっ\nちゃ損よねぇ……♪　っあっ♪　この、肌にへばりつく感触ぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うっとりしちゃう……♪　はぁっ、はぁっ……♪　わたしのおまんこ、高評\n価だったみたいねぇ♪　精液の量でわかっちゃう……♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「すごぉい～♪　芸術的な撒き散らし方だねぇ♪　わたしの肌に、かけたいだ\nけかけて……えっちな白い絵を思う存分描いて遊んじゃって～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019503_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これぞ男の本懐～ってカンジかなぁ？　それとも、ガウガウ狼モンスターと\nして、当然の結果……？　うふふ、どっちでも別にいいよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「悪い吸血鬼のおねえさんとしてぇ、あなたを獲物にするつもりだったのに…\n…いつのまにか、わたしが獲物にされちゃっててワクワクしたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「来年はぁ……どうしよっかぁ？　姉妹の誰かを呼んで……とかもアリ？　そ\nれともやっぱり二人っきりがいい？　もう、今から待ちきれないねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
