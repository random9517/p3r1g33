		{"command":[ "PLAYVOICE", "146_0103101" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「あの……こ、これ本当にトレーニングですの？　何だか違うような……。え\nっ、やっぱりウソ？　じゃあどうしてこんな……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014601_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103102" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「わっ私とエッチなことをしたかったから！？　あの……えーっと……エッチ\nなことってなんですの？　え？　本気で言ってますわよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103103" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "え、えええ……こ、子作りですって！？　これで子供が出来てしまいますの！\n？　えっ、そうではない？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103104" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「ううう……仰る通り、私は性的な知識はわざと教えられてきませんでしたの\n。姫は知らなくて良いと言われてきましたから」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103105" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「あなたが教えて下さるんですの？　いいですわ……教えて下さいまし」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103106" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「あなたのこと信じていますもの。ひどいことしないって。だから……あなた\nがして欲しいことを言って下さいまし」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00014601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103107" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「こうやって……おっぱいを動かす？　ふあぁぁ……！　私ったら、なんてこ\nとをしているのでしょう」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103108" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンもこんなに大きくなって……えっ？　興奮したら大きく\nなるものなのですか？　私が可愛いから？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103109" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「も、もぅ……誉めたって何も出ませんわよ？　ええ、こうすればいいのでし\nょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103110" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「おっぱいが大きいのは、周りを見ていて気付いていましたわ。でも何の役に立\nつものでもないと思っていましたのに……はあぁっ、はぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103111" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「好きな人に悦んで貰えるのでしたら、大きくて良かったですわね……んんっ\n、うぅん、えっ？　な……舐める！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103112" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「オチンチンを舌で舐めろと仰るんですの？　しかも……く、咥えてしゃぶる\n！？　汚くないのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103113" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「うぅ……いいですわ、他人のでしたら断っているところですが、他ならぬあ\nなたの頼みですもの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103114" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「こ、こうでしょうか……ちゅる、ちゅるる、ちゅっ。お口に咥えて……？　\nはっ、はい。こう……ですか？　あむっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103115" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅるる、ちゅむ、ちゅむむ！　んんぅ、オチンチンがお口の中で\nビクビク跳ねてますわよ……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103116" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「き、気持ちイイんですのね？　あぁ良かった……あなたが悦んでくれるなら\n、んちゅ、ちゅるりゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103117" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「ちゅむむ、んふあぁ、私が……高貴な私が、おっぱいでオチンチンなんて挟\nんでお口に咥えてるだなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103118" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「まったく考えられませんわ、んっ、んん、ちゅるりゅ、んふぅ、ちゅむ、ち\nゅうぅ、ちゅっ、ちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103119" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「んっ……あぅぅん！　あぁ、乳首、つままないで下さいまし……んあぁ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103120" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「あぅ、あっ、ああぁぁ……！　そこ触ると変な感じになるんですの……はあ\nぁ、ちゅるる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103121" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「わ、私の方も気持ち良くしてくれるんですの？　んあぁ、はぁぁ、えっ……\n？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103122" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「その代わりにオチンチンもっと奥まで咥えて欲しい……！？　もっとって…\n…ちゅる、ちゅるりゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103123" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「んむぅ、ちゅむむ……ちゅぶぶ！　じゅむ、じゅむむぅ、んちゅ、ちゅるっ\n、んんぅ……もっと？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103124" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「でも、これ以上って……んんぅぅ！！？　ぢゅむ！　じゅっぷ！　じゅぷっ\n！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103125" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「じゅるる、じゅぷ！　じゅむみゅ、んぅ、ん～～っ！！　けふぉ！　えほっ\n！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103126" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「くっ苦しいですわ、喉までオチンチン咥えるだなんて……ええっ！？　でも\nそれが気持ちイイ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103127" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「もうちょっとで満足できそうだからお願い……？　んもぅ、仕方ないですわ\n、じゃ、じゃあ頑張ってみますのよ……あむっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103128" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅるる、じゅぷっ、んっ、んんぅ、じゅむ、じゅるりゅ、んふあ\nぁ……んんぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103129" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「じゅっぽ、じゅぽっ、んあぁ……お口の中でオチンチン跳ね回ってますの…\n…！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103130" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「んっ、ん～～～っ！！？　じゅむみゅ、じゅっぷ、じゅぷぷ、んんぅ……来\nる？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103131" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「来ますの？　何が……んっ、んんぅ！　分かりましたわ、あなたを満足させ\nてみせますの……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103132" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「じゅぷぷ、じゅっぷ、じゅぷ！　ちゅぷぷ、ちゅるる、じゅぷ！　んんぅ、\nん～～！！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103133" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「んああぁぁ～～！！！　ふあぁ！？　なっ何ですのこれ……んじゅ、じゅる\nる、ごきゅっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103134" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「まさかお漏らしするだなんて聞いてませんわよ……？　えっ、オシッコじゃ\nない？　ふあぁ……確かに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103135" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「ネバネバしてて、とっても臭くて……んっ、んんっ！　苦くて、ふあぁっ…\n…匂い嗅いでるだけで、興奮してきちゃいますの……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103136" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「の、飲めというんですの？　はあぁ、ごきゅっ、ごくっ……んっ、んんっ、\nごくっ、ちゅぱ、ちゅるりゅ、ごっ……くん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103137" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「はぁ、はあぁ、あなただけですのよ、こんなことしてあげるのは……んあぁ\n、はうぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103138" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「えっ、えっ？　このまま子作りもしちゃう……！？　あっ、あの私……その\n、初めてですのよ。それでも……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103139" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「い、いいんですのね……？　は、はい。あなたが相手なら私……身を捧げて\nも、んっ、んんぅ、あぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "146_0103140" ]},
		{"command":[ "SETNAME", "レナリー" ]},
		{"command":[ "SETTEXT", "「でも、今すぐはダメですの。まだ恥ずかしいから……あなたの本気、見せて\nくれたら、きっと……」", "NORMAL" ]},
