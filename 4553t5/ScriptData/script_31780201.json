{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うぐっ……！　ぐっ、んむっ……！　今日はまた一段と激しい拘束ね……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私の姫騎士姿に興奮して、暴走してるのね……ふふっ。触手は本能的に姫騎\n士を襲いたくなるものなのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「まあ、こういうプレイも嫌いじゃないし、せっかく姫騎士になってるんだか\nら、姫騎士になりきって付き合ってあげるとしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「くううぅっ……！　汚らわしい触手たちめ……！　この私を誰だと思ってる\nの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「姫騎士である私にこんな辱めをしてただで済むと思って……んむうううぅ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「しょ、触手が口を無理やり広げてきてるっ……！　な、何をしようというの\n……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ま、まさか……！　その太い触手を私の口に押し込もうとしてるの……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「やっ、やめっ……！　やめなさいっ！　そんなもの口に入れるだなんて、死\nんでもごめんだわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「何とかして口を閉じないと……ぐっ、あぐっ……！？　うっ、ひぎいぃ……\n！？　触手の力が強すぎて、勝手に口が開いていくわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「やっ、ああぁ……！　やっ、やめなさいっ……！　そんなもの入れようとし\nないでっ……！　いっ、イヤあああああぁーーーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うぐうううぅ！？　じゅぶっ、ぐっ、じゅぱっ！　しょ、触手が口の中に入\nっへきてりゅうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いやあああぁ！　ヌルヌルしゅりゅうぅ！？　そりぇに何なの、このいやら\nしい弾力っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おぐっ、ぐじゅぷうううぅ！？　のっ、喉の奥にまで入り込んりぇ……！？\n　ぐぶっ、じゅぱっ、ぢゅぐるっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「くっ、クソっ！　今すぐ抜かにゃいと、噛みちぎってやりゅからにゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぐっ！？　じゅぶ、ちゅぱっ、ぢゅるるるっ！？　口にょ中れ触手が暴れ\nまわっへ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そりぇに拘束が強しゅぎて、口を閉じりゅどころか手も足も動かせにゃいだ\nらんてっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「クソっ……クソぉ……！　こんにゃ辱めを受け続けるくりゃいなら、いっそ\nのことひひょ思いに殺せっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅるっ！　ずちゅ、にちゅる、ぐちゅるうぅ！？　おっ、おおぉ……！？\n　もっと口の奥にまで触手が入りこんでくりゅうぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんらの、本当に死んじゃうっ……！　触手に一方的に嬲らりぇながら窒息\nしちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そ、そうらわ……！　このまま触手をイカせりぇば、満足して離れりゅはず\n……！　そうなったときがチャンスよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こいつりゃが油断ひたとこりょに一撃を浴びせりゃれれば……！　そのため\nにも、早くこいちゅりゃをイカせてあげないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んちゅ、じゅるるっ！　ちゅぱっ、れりゅ……！　ちゅぶっ、ぴちゃ、りゅ\nるるっ！　ちゅぷっ、ぢゅぱっ、にちゃあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　舌で触手を舐めりゅたびに、変な汁がどんどん溢りぇてくる\nわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そりぇに何なの、この変な味っ……！　しょっぱいにょに甘くて、頭がおか\nひくなりそうらわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「臭いも変ら感じだひ……うっ、うぷっ……！　気持ち悪しゅぎて吐きそう…\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「れも、今は従順な振りをひて奉仕ひないと……！　ちゅぱっ、れろっ……！\n　ずぶっ、ちゅぷぷっ……！　ぴちゃ、にちゃあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、うぶっ……！　ぐっ、うぐぐっ……！？　触手がひゃらに大き\nくなっへきてりゅっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そんらっ……！　しゃっきのれも口にギリギリ入るりゅくらい大きかったに\nょに、まら大きくなるだなんへっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ！　んちゅ、ちゅるるっ！　ぢゅぱっ、じゅぐっ、ぴちゃ、んじゅ\nるっ！　あむっ、ぐむっ、んむうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぐっ、苦じっ……！　こんらに喉の奥をズポズポしゃれたら、息が出来ない\nわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「このままらと、触手を満足しゃせるまえに私が死んじゃうっ……！　ぐっ、\nうぶっ！　ちゅぱっ、れりゅううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぐっ、おぶっ！？　触手がビクビク震えてりゅわっ……！　もしかひて、そ\nりょそりょイキしょうなのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「なりゃ、もう少しらけ我慢すりぇば……触手も満足すりゅはずだわっ……！\n　ちゅぱっ、ちゅ、じゅるるっ！　ぐりゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「汚りゃわしい触手めっ……！　早く……イキにゃさいっ……！　じゅぶっ、\nぢゅ、ずりゅるるっ！　にちゅあ、じゅぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅじゅっ！　私の口の中りぇ思いっきり触手汁を出ひて、精魂尽き\n果てなさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぐむうううぅ～～～～～！？　触手汁がびゅーびゅー出ひぇるうううぅ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こ、こんらに出るだにゃて予想ひてないわっ！　ぐっ、おっ……おおおぉ…\n…！？　触手汁れ口の中がいっぱいになりゅうぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こにょままらと、触手を倒しゅ前に私が死んじゃうっ……！　急いで汁を飲\nみ込まにゃいと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ごくっ……ぐっ、んぐっ……！　おっ、おええぇ……！？　なんて\n酷い味にゃのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「れも我慢ひて飲まにゃいと……！　ずっ、じゅるるっ……！　ごくっ、ごく\nっ……！　んぐっ、ごくっ……ごっくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ようやく、口の中にょ触手汁を飲み込めひゃわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こりぇだけ出せば、さすがに満足ひたでしょう……拘束が弱まったらすぐに\nれも抜け出して、一撃で仕留めてやりゅわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「って……あ、ありぇ……！？　どうひて触手が口から抜けにゃいのっ……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そりぇにさっきよりも拘束が強くなってりゅ気が……！　ま、まひゃか、ま\nだ満足ひてないとでもいうのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　やっ、イヤっ……！　さっきのでも十分苦ひかったにょに、\nもう一度だなんて無理っ……！　ぐっ、んぐううううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ！　ちゅぱっ、れりゅうぅ！？　ぐちゅ、ずちゅ、にちゃ、ぴちゃ\nあぁ！？　ちゅ、じゅぢゅ、ずりゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おぐっ、おおおおおぉ……！？　ま、まひゃ触手が口の中れ暴れてりゅうう\nうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひかも今度は喉奥に出し入りぇするだけりゃなくて、頬や歯の裏側にまれ触\n手を押ひ付けてきて……うぶっ、おえええぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手のヌルヌルひた汁が強制的に流し込まれてりゅっ！　ひゃっきあれだけ\n飲んらにょに、まだ飲めっひぇいうのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんら屈辱、もう耐え切りゃれないっ！　くっ！　殺せっ！　一思いに殺し\nぇえええぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ！　ぐぱっ、ぢゅぶっ、じゅちゅるっ！　にちゃ、ずちゃ、ぴじ\nゅるうぅ！？　ぐっ、うぐぐっ……うぶうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ど、どうひて殺ひてくりぇないんだっ……！？　お前ほどの太い触手にゃら\n、私の気道を塞ぐにょなんて簡単だりょうがっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はっ……！？　ま、ましゃか……私を生かしたまま、苗床にすりゅ気にゃの\nか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手の子種を身体のありとあらゆるとこりょに植え付け、触手を生み出ひ、\n育てりゅために生かしゅとでもいうのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「そ、そんらのイヤああああぁ！　触手の母親になんてなりひゃくないっ！　\n触手を生みたくにゃいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅ、じゅるるっ！　ぐぶっ、んむっ！　おっ、おおおぉ……！\n？　ま、まひゃ触手がビクビク震えてりゅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ま、ましゃか、また出すのか……！？　さっきありぇだけ味わわしゃれた汚\nい汁を、出しゅとでもいうのかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いああああぁ！　もう許ひてっ！　お願いだかりゃ出さないれっ！　何でも\nしゅりゅから、種付けだけはひないでくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「苗床になる以外ならなんれもすりゅっ！　だからもう出さないれ……！　\nひぐっ！？　じゅぱっ、ちゅちゅ、んじゅるうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いあああああぁっ！　来るっ！　触手汁がすぐそこまれ来てりゅうううぅ！\n？　やっ、やめっ！　やめろおおおおおぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うぐううううぅ！？　じゅぱっ、ずゅるるっ！？　ま、また汚らしい汁が口\nにょ中にひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひかも、ひゃっきよりも濃厚れドロドロひてりゅっ！　臭いも強烈で、鼻が\n曲がりひょうらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「うぐっ！？　うぶっ、おっ、おおおぉ！？　ひかも強制的に胃の中に流し込\nまりぇて……！　ごくっ、んぐっ！　ごくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もう飲ませないれくりぇっ！　お願いらから、触手汁を注ぎ込まないれぇ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅぱっ！　ずりゅるるっ！　じゅぞっ、ちゅるるっ！　じゅ、ずず\nずっ、んぐっ、じゅぞぞぞぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ……ああぁ……お腹の中が、触手汁でいっぱいになってりゅ……私にょ\n身体が、すっかり穢れてひまった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんらの、お父様やお母様に顔向けできにゃいわ……！　ぐっ、うううぅ…\n…もう、殺してくりぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　な、何れまた触手が活動的になってりゅの……！？　ましゃ\nか……まだするっていうにょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もうこれ以上は本当に無理っ……！　身体の中が触手汁れいっぱいになって\n、苦しいにょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「やっ……！　イヤっ……！　助けてっ！　誰か助けてえええぇぇぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「きゃああああぁ！？　触手汁が顔に……！　あぶっ！？　ぐっ、あはあああ\nぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「こんなにも熱い汁をぶちまけられるだなんて……！　ひいいぃ！？　ドロド\nロしてて、気持ち悪いぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「それに口で味わっていた時よりも酷い臭いがしてるわっ！　ううぅ……臭す\nぎて本当に吐きそうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、ああぁんっ！　おっぱいにも触手汁がかけられてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いやあああぁ！　もうかけないでっ！　触手汁止めてっ！　私に酷いことし\nないでぇーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、あふっ……どうやら、満足したようね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00017802_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「拘束も随分と弱くなったわね。さすがに出しすぎて疲れちゃったのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……姫騎士っぽく演じてみたけど、随分と気に入ってくれたようね。\nいつも以上に暴れてて、とっても素敵だったわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「やっぱり触手たちは本能のままに女の子を襲うのが一番素敵ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「でも姫騎士でこれだけ暴れてくれるなら、他のシチュエーションだともっと\n激しくなりそうね……ふふっ。楽しみだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}