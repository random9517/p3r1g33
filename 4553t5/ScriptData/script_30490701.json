{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0152" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「よし、ちゃんと時間通りにやってきたな。ほら、こっちに来い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703101" ]},
		{"command":[ "SETCHARA", "0", "char_00004907_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「話してあった通り、今日はバレーの特別練習だ。君を徹底的に鍛えてやるか\nら、そう思え」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「他のチームメンバー？　いいや、今日は君だけだ。マンツーマンでの指導に\nなる。何か問題でも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703103" ]},
		{"command":[ "SETCHARA", "0", "char_00004907_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふむ、大丈夫なようだな。練習メニュー？　ふっ、すぐに分かる。まずは、\nここからだ……ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703104" ]},
		{"command":[ "SETCHARA", "0", "char_00004907_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……何を戸惑っている。いきなり押し倒されると思っていなかったか？\n　隙だらけだったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00004907_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「君は、普段の練習の時から私のお尻をチラチラと見ていただろう？　真面目\nに練習をしているフリをしながらな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まさかバレていないと思ったのか？　なに、別に今日はそれを咎めようとい\nうことじゃない。そんなに見たいなら存分に堪能するといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ほら……ケチ臭くチラチラ見るより、間近で見る方がずっといいだろう？　\n私がいいと言っているんだ……遠慮することはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もちろん、私も遠慮するつもりはない。どれ……ふふっ、チンポの方はしっ\nかりとその気になっているようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こんなにあからさまに勃起して……どういうつもりかな？　んっ、ちゅっ、\nぴちゃ……んちゅっ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703110" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……随分と可愛らしく震えるじゃないか。れろ……んっ、んりゅっ、何\nとも欲望に正直なことだ……れろ、んちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まぁ……要するにだな……お互い様というわけだ。君が、私のお尻を見てい\nたように……私も、君の股間を見つめていた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「なんだ、全く気づいてなかったのか？　それは些か観察力が足りんと言える\nな……れろ、んっ、ふっ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703113" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「或いは、私が気取られぬように、チンポを見る力に長けていたと言うべきか\n……だが、もうそれを隠す理由もない……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだ……このチンポにしっかりと特訓するのだ。どこまで射精を耐えられ\nるかをな……れろ、んえる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ふっ……んんっ……やっと反撃が始まったな……んっ、パ\nンツ越しだが……君の舌の感触が伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、ぉっ……んんっ……じゅぷっ、んっふ、思い切り鼻を近づけられて…\n…あふっ、息がくすぐったいな……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「この、もどかしい感覚……悪くない……んっ、私も負けていられんな……じ\nゅぽっ、んちゅぷっ、りゅぷっ、くぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703118" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふふ……私の方は直接舐められるから……少しだけ有利かな？　れろ、んっ\n、この傘の部分……可愛らしく揺れているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「れろ……バレーの練習中も……ずっと、このチンポのことが頭にチラついて\nいた……コーチとしては失格かも知れないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「今日、こうして……しっかりと鍛えてやれば、もう特別意識することもある\nまい……だから、徹底的に舐めていくぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んむっ、あぷっ、はっ、んむ、れる……れりゅぅ……ちゅぷっ……りゅぽっ\n、んぷっ、りゅぱっ、じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703122" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「かなり汗をかいたようだな……んっ、独特の男臭さと……アンモニア臭が入\nり混じって……鼻に来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが……んっ、このクセの強さこそが、私の神経を高ぶらせるのだ……あっ\n、おぉっ……君の舌も……食い込んでくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、ちゃんと……オマンコの筋にぴったりと布地がめり込んで…\n…あぁっ、上手いぞ……股間が痺れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こんな風にして……他の娘たちもよがらせているという訳か……自分で味わ\nわないと、分からないものだ……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いかん……んんっ、油断すると……されるままになってしまう……んっ、私\nが舌を止めるわけにはいかん……じゅるっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、んはっ、りゅぷっ……どうだ……？　私も、決してチンポをしゃぶ\nる経験に長けている訳ではないからな……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703128" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「正しくできているか……んっ、痛くしていないか……チンポが喜んでいるか\n……はっきりとは分からないのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、だが……君の様子を見る限りは、大きく間違ってはいないようだ\nな……はぁぉっ！　んっ、そのクンニが答えか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、分かった……この調子で、もっとチンポをしゃぶるぞ……じゅぱっ、\nだから……君も、もっとオマンコを刺激してくれ……あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁっ、ほぉぉぉっ……パンツ越しなのにっ……生々しい感触が伝わってく\nるっ……おぉっ、内側から愛液が滲んでしまうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703132" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「マ、マン汁……あぁ……そんな下品な言い方を……だが、確かにそうだ……\n君にオマンコ舐められて……マン汁を溢れさせているっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、だが……それは君もだな……？　んっ、じゅるっ……チンポ…\n…亀頭から滲む……この汁っ……チンポ汁っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「幹の震えも大きくなって……んじゅるっ、もう射精間際ということだろう…\n…どうなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、間違いないな……んっ、ならいいぞ……出せっ……このまま、\n咥えているからな……口の中に……らせっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅぽっ、んじゅるっつ、んじゅぅぅぅぅぅぅぅぅーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んふっ……！　んぷぁっ、れて……きたっ……んっ、ふごい量らっ……ん、\nんくっ、むぐっ、んっ、んんんーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっく、は、んふっ……あぁ……んぷっ……こくんっ、はぁ、どうだ……ち\nゃんと飲んだぞ……この濃さ……格別だったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703139" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「君の舌もよかった……精液を飲みながら、私も軽く甘イキしてしまったよ…\n…素晴らしい技だった……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……たっぷり出したようだが、このヒクつきっぷり……まだまだ\n打ち止めには程遠いようだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もちろん、私も遠慮するつもりはない……このまますぐに続きだ……んっ、\nりゅぷ、じゅるっ、んちゅぷぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ、こってりとした精液の風味が加わって……チンポがより味わい深いも\nのになっているな……じゅぽ、んじゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっふ……亀頭はかなり敏感になっているな……唇で軽く挟むだけで……ぴ\nくんと震えて……可愛らしいものだ……んっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あ……んむっ、君の舌も、また元気になってきたようだな……されてるばか\nりで満足する男ではないということか……あっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そこは……んぁっ、くっ……あぁ、ク、クリトリスの場所……当然、狙って\nくるか……はっ、んむっ……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703206" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あくぅ……さっきより私も感じやすくなっているっ……んっ、新しい蜜汁が\n……湧き出してしまうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ、周囲も舐め回されて……パンツがジュクジュクに染みてしま\nっている……脱がされるより恥ずかしいかもしれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、このゾクゾクする感覚……あぁ、クセになりそうだ……んちゅぷっ、\n私も……君をもっとゾクゾクさせたい……んりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「れろ、んぁむっ……ぴちゃっ……それにしても……改めて、このチンポの太\nさに圧倒されそうだ……りゅぱっ、ぷちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703210" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こうひて……咥えるだけでも、はぁんむっ……簡単ではない……じゅぽっ、\nんちゅぱっ……だが……んじゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「れろっ、んふっ、舐める度に……ピクンと反応してくれるところを見ている\nと……もうそれだけで……ちゅぷっ、舌が動いてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぷっ、んんっ……あぁ……はぁ、君の舌も……また……激しくっ、あぁっ\n……そんなにぴったり押しつけてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703213" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あひぉっ！　あぁっ、こ、声が……出てしまうっ、んふっ、あぷっ、んちゅ\nぷっ……はぁ、このシックスナイン……たまらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだ……んっ、後は我慢の特訓だっ……完全に快感に押し流されず……ギ\nリギリまで堪えるんだ……ちゅぱ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが、責め手を緩めては意味がないぞ……んじゅぷっ、ちゅぽっ、ぴちゃ、\nんりゅっ……もっと激しくさせながらっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んんっ、じゅぽっ、二人……一緒に高め合いながらっ……最後の瞬間を迎え\nるんだっ、じゅぷっ、じゅぱっ……んりゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……イキそうなんだな？　私もだっ……舌がっ、オマンコの弱いところ\nを的確に突いてっ……もうすぐっ……イクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はぁ、んちゅぷっ……ギリギリだっ……ギリギリのところまでっ、それから\n一緒にっ……んふっ、じゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いいぞっ、チンポっ……出せっ……！　君の欲望の全てをっ……私に……全\n部、出してしまえぇっ！　んじゅぷっ、んちゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ふぶぅぅぅっ！　むぐっ、おっ、んふっ、んぐっ……んっ、二発目……れて\nっ、んっ、むぐぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「こくっ、んくんっ……溢れてひまう……んんっ、味わってる余裕もないくら\nいら……ごくっ、んっ、こくっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んふぁ……あぁ……イッた……さっきよりも、強烈で……オマンコが、飛び\nそうになって……パンツもジュクジュクになってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んじゅぷ……ちゅるっ……はぁ……射精量も大したものだ……まだ、奥にち\nょっと残っているな……んちゅるっ、ちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703304" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっふ……これで終わり……か？　あぁ……本当にいっぱい出したな……疲\nれただろう、ご苦労だったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私も、何回もイッてしまった……君を鍛えるつもりの特訓だったが、私の方\nがよっぽど学ばされた気分だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「おっと……私としたことが、ちゃんと後始末をしなくてはならなかったな。\n待ってくれ……はむっ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、残滓をそのままになんて……勿体ないからな……じゅるっ、んちゅっ\n、尿道口の奥の分も……しっかり吸い上げて……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「うむ、これでいい。なに、礼には及ばない。コートを使った後の掃除は基本\n中の基本だ。チンポもしっかり後始末しなくてはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「よし、今日の特訓は以上だ。また、機会があればしっかりと鍛えていくから\nな。そのつもりでいるように……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ひぁぁぅっ！　あっ……っぷ、チンポ……抜けてっ、はぷっ、顔に……二発\n目ぇっ……んっ、ぷぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……顔面シャワーをさせたかったのか……？　はぁ……んぷっ、あぁ…\n…精液の濃いにおいが広がっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「くぅん……あぁ……わ、私もイッてる……オスのにおいに支配されて……ん\nふぁ……ずっとイッてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……また染みが広がる……オマンコから、新しい汁が……溢れてしまう\n……はぁぁ……はしたない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んぷぁ……はぁ、はぁ……やっと射精も落ち着いたか……？　こんなに出す\nとは……つくづく、君は絶倫だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703405" ]},
		{"command":[ "SETIMAGE", "0", "still_00004907_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ、私も何回もイッてしまった。だが、共に高め合うことができたという\nことだからな……特訓の甲斐はあったというものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ、もう少し待て。ちゃんと、掃除をしなくてはな……チンポはリラック\nスさせておいてくれ……んちゅ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「使ったものを綺麗にするのは、当然のことだ……れろ、ちゅぱっ……これだ\nけ頑張ったチンポだしな……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「うん、これでいい。ふふ、どういたしましてだな。私も、残りの精液をしっ\nかりと味わえて満足だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「というわけで、今日の特訓は終了だ。また、次があるかも知れないからな。\nその時まで、しっかりとチンポも鍛えておくようにな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0703410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}