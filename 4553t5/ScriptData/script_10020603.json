{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「一通り仕事を終えて、校庭へ。グルメコンテストが行われているエリアを歩\nく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「いい匂いがそこら中から漂ってくる。私の空腹をいやでも刺激する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0135" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「おなかが、空いた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「いま、私はいったいなにを食べたいのだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「お腹をさすりながら、自問自答。屋台の間を右往左往」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……カレー、か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「グレーテル先生が顧問の魔術研究会の屋台」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「行列はできているけど、ちょっとくらい並んでもいいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ここが最後尾ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「たかが屋台の料理。並んでまで食べたくない、そう思う人もいるかもしれな\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「だが、私はそうは思わない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「こうして並んでいるうちに漂ってくるカレーの匂い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「料理は舌だけで味わうものではないと教えてくれる、食欲をそそる香り」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「これを嗅ぎながら料理にありつけるまで待つというのも、いいものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一般生徒" ]},
		{"command":[ "SETTEXT", "「えっと、次のお客様ー」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ、はーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「いけない、香りに夢中になっていたらあっという間に私の番だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カレーをひとつ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ここは魔術研究会の屋台。売られているのはハーブたっぷり欧風魔女カレー\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580013" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「皿と箸を受け取って、近くの席に座る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「すごいわ、具がみえなくなるくらいまで煮込まれているなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「しっかりと煮込まれたカレー。香りはなんだか高級感がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「いったいどれくらいのハーブが使われているんだろう。想像ができないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……ぱく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……うん、美味しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580009" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「美味しい。普通に美味しい。そうだ。この味だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「家庭料理として一般化したカレーは、その家族を映す鏡と言っても過言では\nない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「複雑な味。しかしどこか安心できる味。特別に美味しいわけではないが、ひ\nどく不味いわけではない味」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こういうのを、家庭の味って言うのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そう、こういうのでいいんだ。こういうので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ごちそうさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「カレーはあっという間になくなってしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……まだ、満腹じゃないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580012" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ふと顔を上げると、すぐに別の屋台が目に入る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580022" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「あそこは遥架先生が顧問のエジプト文化研究科の屋台だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……寿司？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580013" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「意外にも、寿司の屋台らしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580024" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「いや、寿司は屋台で売られていたファーストフード。おかしいところはない\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ちょっと並ぶけど、まあ、いいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580014" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「カレーを食べたばかりのお腹をおちつけてから、寿司にありつくことにしよ\nう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架の部下" ]},
		{"command":[ "SETTEXT", "「お待たせしましたー」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「えっと、なにがあるのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580015" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「頭上に並んだメニューを見る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580027" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「えっと、ナイルパーチ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580016" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「見慣れない魚の名前。思わず注文してしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一般生徒" ]},
		{"command":[ "SETTEXT", "「すみません。その魚はまだ届いてないんですよ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「がーんだな、出鼻をくじかれた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そう……。じゃあ……この『ナイルに寿司』っていうのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580017" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一般生徒" ]},
		{"command":[ "SETTEXT", "「はい！　それならご用意できます」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「出てきたのは握り寿司と巻物のセット。握りはほとんど白身魚だった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580030" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「白身魚のお寿司も美味しいわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580018" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「とはいえ、白身魚と白身魚と白身魚。白身魚が被りまくりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580031" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「でも、美味しい。さっぱりした味。口の中が爽快だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580032" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「炙りもとろけるような舌触り。タレがちょうどいいアクセントになっている\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580033" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「握りが白身魚なら軍艦は白子のような白い魚卵だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580034" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ん、もぐもぐ……これも美味しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580021" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こっちの海苔巻きに入っているのは、白身魚のフライなのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「本格的な握り寿司の中に、一点の変わり種。異彩を放つ一品に思わず手が伸\nびる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580035" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「タルタルソースと酢飯って、微妙かと思ったけど意外といけるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「これもあっという間に食べ終わってしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580036" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ごちそうさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580024" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「こんなにいい屋台があるなんて、学園祭というのも悪くない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580037" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……でも、まだまだ食べたりないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580025" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「また別の屋台を覗こうとして、ふと、あることを思い出した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580038" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そういえば、グルメコンテストの審査員に呼ばれていたんだったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580026" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「それなら、満腹になるほど食べるわけにはいかないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010113580039" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほどほどにしておきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113580027" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
