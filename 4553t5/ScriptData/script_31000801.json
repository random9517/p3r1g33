{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの、こんなところに呼び出して何の用事だ？　今日は確かに予定は何\nも入ってなかったと思うが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803101" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん？　いーすたーの風習？　いや、初耳だな……一体、どういう風習がある\nというんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なに？　男と女が一晩を共にして、一日中まぐわい尽くす……さもないと、\n呪いが降りかかる……それで隊長どのと私が？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの、一応確認しておくが、それは本当のことだろうな？　もし、それ\nが嘘だとしたら一体どうなるか……覚悟の上で言ってるな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803104" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「謝るということは、嘘なのか……全く、そんな一瞬でバレるような嘘をつく\nこともなかろうに……隊長どのときたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803105" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「大体だな……別にそんな嘘をつかなくても、素直に言ってくれれば……私は\n断らないんだがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803106" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だ、だから……断らないと言ったんだ。隊長どのには、日頃から世話にはな\nっているし、私も……嫌いじゃないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わ、分かった分かった。そんなに頭をすりつけなくても、二言はない。ほら\n……するから……どうすればいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803108" ]},
		{"command":[ "SETCHARA", "0", "char_00010008_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なるほどな……ふふ、隊長どのはこんな風に甘やかされるのがお望みだった\nか。バニーガールに膝枕……本当に正直なことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00010008_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「しかも、おっぱいは間近で見ていたい……ここまで欲望に忠実だと、いっそ\n清々しささえ感じるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「本当に見せてくれると思わなかった？　言っておくが……誰彼構わず見せる\nわけじゃないからな？　隊長どのだからだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ……そんなことを言ってたら大分興奮してきたのか？　ここが、もうす\nっかりビンビンになって……分かりやすいことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それで、この勃起しきったペニスを、どういう風にして欲しいんだ？　ココ\nは一体どうすれば喜ぶのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「手でして欲しいと……相変わらず欲望に忠実なことだ。いいとも……正直に\n言えたご褒美に、手のご奉仕を楽しんでくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……ほら、こんな感じかな……？　あぁ……くちゅりと音がして来るな\n……んっ、少し湿ってるからかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「皮をゆっくり捲り返して……ふふっ、私の手の中でビクビクと脈打っている\nぞ……なんとも可愛らしいものだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どうだろうか、力加減は？　強すぎたり弱すぎたりしたら、ちゃんと教えて\n欲しいからな。今の感じで大丈夫だろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうか……なら、ほんの少し強く握って……あとちょっと速く扱いていこう\nな。そうだな……これくらいだ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰がもぞもぞと揺れているな。表情を見るに、ちゃんと感じてくれ\nているようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まだまだ、もっとしていくからな……安心して身を委ねてくれ。くびれのと\nころも優しくなぞって……つぅっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いい表情だ……隊長どのの気持ちよさそうな顔を見ていると、私もだんだん\nいい気持ちになってくるような……ひぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁっ……んっ、あっ……隊長どの……急に、乳首を……あっ、ふっ……ん\nんっ、吸うなんて……あ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803122" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「目の前にあって我慢できなかった……あぁ……全く……本当に、どこまでも\n正直過ぎる……欲望にも忠実で……んっ、ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや、駄目ではない……ふふ、赤ん坊のように甘えたいんだろう……？　な\nらば、それに応えるのも私の務めだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、今日は隊長どのを徹底的に甘やかしていくぞ。生憎と、本物の母乳を\n出すことはできないが……おっぱい存分に吸ってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「分かっている……このまま、手も動かしていくからな……これは、そうだ…\n…確か授乳手コキというやつだったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ、バニーガールの授乳手コキなんて、なかなか味わえるものじゃないぞ\n？　貴重な機会と思ってくれなければな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……唇で挟まれている……んんっ……優しい力だ……いい子だな……先\n端が気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……！　舌で……転がされて、んっ、あぁっ、さっきより、乳首\nがしこっていくのが……自分でも分かるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ……！　隊長どのも、舌だけで……私をこんな気持ちにさせるとは…\n…テクニシャンだな……なら、私も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ただ握り締めるだけでなく……んっ、この血管の部分をつぅっと撫でてみた\nり……鈴口の割れたところを……ちょんとつついたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ……また跳ねた……全く、油断も隙もないヤンチャなペニスだな……\n隊長どのにそっくりだ……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、こうして私の手のひらの中で、ピクピクする……この可愛らしさもそ\nっくりかも知れん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、はっ……あぁ……亀頭に、我慢汁が滲んでる……これは、もうそろそ\nろ射精したくなっているようだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいぞ……出したくなったら……そのまま身を委ねて。私の手の中で……い\nっぱい溢れさせて欲しい……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁんっ……こ、こら……隊長どの……そんなに夢中になって吸われたら…\n…こっちも集中できないだろうっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803136" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「けど……それだけ、余裕がないなら……もう、出すんだっ……私の手の中で\n……思いっきり射精っ……しろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ……！　飛び始めたな……隊長どのの精液が、私の手にいっぱい出て、あ\nぁっ……溢れてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふっ、扱けば扱くほど、どんどん出て……はぁぁ……どれだけ溜め込んで\nいたんだ……これは、しっかり吐き出さないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……落ち着いたか……気持ちよかったか？　それならよかった。これだ\nけ射精したなら、私の技も満更でもないということだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さて……一旦は落ち着いたようだが……まだまだ、ペニスは漲って仕方ない\nという様相だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これは、まだまだ出し足りないと……そういうことだろう？　任せておけ。\n私の手コキはこれからが本番だからな……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「今は射精したばかりで痺れているだろうが……じっくり少しずつしていくか\nらな……これくらいの強さでどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　ふふっ……乳首を吸って返事代わりとは……いかにも隊長どのら\nしい……よしよし……いい子だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「頭を撫でられるのも悪い気分ではないだろう？　もちろん、こっちも忘れて\nはいないぞ。隊長どののペニスもよしよししてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ……！　んっ、また舌が元気になってきたな……あっ、んむっ……あ\nぁ……乳首が……切なくなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ、んむっ……こんな風に甘えてくるなんて……いけない子だ……ちょっ\nと強くしてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、手がヌルヌルする……自分で出した精液がつくのは大丈夫か\n？　気持ちいいなら問題ない……？　豪胆なことだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、遠慮することはないと言うなら、安心してご奉仕ができる。また、し\nっかり扱き上げていくからな……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ……ほら、感じてるだろう……？　隊長どのの反応は分かりやすいか\nらな……弱い場所を探すのも簡単なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ふふっ、抗議しているのか？　だが、私はもう隠す気はない\nからな……隊長どのの乳首吸い……とても気持ちいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだな……このまま、お互いに高めあいながら……一緒に、最後まで……\nあっ、はぁっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの……今……乳首……軽く噛んだな？　んくぅっ……あっ！　敏感に\nなっているのに……こんな真似を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お返しに……ぎゅっと、亀頭を締め上げて……ん、ふっ……！　このビクビ\nクが……また大きくなって……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふ……不思議な感覚だ……こうして乳首を吸われていると、本当に母乳が\n出てしまいそうな……母性本能をくすぐられるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　だが、こんないやらしい吸い方をする子供はいない……それ\nに、こんな立派に屹立したペニスを持つ子供も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、ビクビクが……もっと大きくなって……くっ、ふっ……！　ま\nた、出したくなってるんだなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んくっ……今度は、隊長どのはどうしたい……？　このまま私に任せてしま\nうのか……それとも、思い切り顔にでも出してみるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私は……どちらでも構わない……隊長どのの……思った通りにして欲しいぞ\n……んっ、そうだ……私の手で射精させることに変わりはないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁっ……シコシコっ、ペニスを扱いてっ……早くっ……んん\nっ、精液っ……いっぱい出してくれっ……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あふっ！　また出てきたな……隊長どのの子種……新鮮な精液がどんどん溢\nれ出して来ている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……この量はまた……手がじゅくじゅくになって……しかも、濃さも半\n端じゃないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぺろっ、あぁ……ドロドロだ……こんなに生命力のある精液……もし、中に\n出されてたら一発で妊娠したかも知れないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なんて……言ってる間にも、まだ溢れて……んふ……本当に気持ちよくなっ\nてくれたようで何よりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「っと……さすがに、もうおしまいか。頑張ったペニスに、お疲れさまだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803305" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ところで、隊長どの。その……おっぱいはいつまで吸うつもりでいるん\nだ？　全く離れる気配がないんだが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ！　もう少しだけ……？　全く……本当におっぱいが好きで仕方ないん\nだな……こんなに甘えて、仕方ない隊長どのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、悪い気はしないな。それだけ隊長どのは、バニーガールがお気に入り\nということだろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なに……？　バニーも好きだが……中身が一番重要……そ、そうか……中身\nが一番重要……そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや……改まって言われると……なかなか照れくさいものだな……隊長どの\nは、本当に『たらし』だ……やられたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ……ふっ、顔に飛ばして……！　んっ、そこまで腰を突き出\nさなくても……届いてるぞ……んぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、さっき出して２発目だというのに、全く衰えないで…\n…むしろ、もっと多く出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この生臭さ……それにクセの強い味……こんなのを中出しされてたら……確\n実に妊娠してたんじゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふ……まだ出てくる……もうすぐ終わる……？　そうか、とにかくもう残\nしてしまわず、全部出してしまおう……扱いていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん……やっと射精が止まったな……これで、全部出た……間違いないか？　\nああ、お疲れさまだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803405" ]},
		{"command":[ "SETIMAGE", "0", "still_00010008_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……顔もベトベトだ……だが、せっかく出して貰ったからには、掬って\n舐めてしまうのがいいか……勿体ないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それで、隊長どのは……まだおっぱいを離すつもりはないのか？　いや、ま\nあ無理に引き剥がすつもりはないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もう少しだけ……分かった分かった。今日は甘やかすと決めてるからな……\n好きなだけ吸ってていいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふ、乳首がふやけてしまいそうだ……だが、先端が気持ちいい……んっ、\n身体全体がムズムズする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「また甘えたくなったらいつでも言ってくれればいい。いーすたーの風習に限\nらず、好きな時に……な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0803410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}