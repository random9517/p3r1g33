{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへ、隊長さんのチンポ、もうギンギンになっちゃってるねぇ？　あーし\nに日焼け止めローション塗るだけで、そんなに興奮しちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「確かにお願いしたのはあーしだけど、すっごい手つきがいやらしかったよ？\n　どこの変態だって思ったもん、えへへへ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それでぇ……隊長さんは、ここからどうしたいのかなぁ？　ふふふっ、もう\n、我慢できないんだよね？　言う事、あるよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　興奮してるのはあーしも一緒だって？　むぅ……それはそーだけどさ\nぁ、こう、気分のもんだいって言うかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「むしろ、入れてほしいならあーしの方こそ言う事あるだろって？　……ほう\nほう、隊長さん、そーゆー態度取っちゃうんだ、へぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でも……ふふっ、いいじゃん。その挑発、乗ったげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「お願い隊長さん……あーし、もう我慢できないのぉ。このみっともなく勃起\nした早漏チンポ、アソコに入れてほしいなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「その変わり……この先の主導権は、ぜ～んぶあーしが貰うけど、ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んあぁんんっ！　膣内がゴリゴリって削れて、一気に奥まで届いてっ……ん\nんっ、あっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふっ……入れただけでちょっとイッちゃった……隊長のチンポ、早漏だけ\nど固さと長さは……んんっ……中々、だよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ん～？　どうしたのぉ隊長さん？　腰がもぞもぞ動いてるよ？　え？　早く\n動きたいって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへっ、だ～め♪　言ったでしょ、主導権はぜ～んあーしにあるの♪　最\n初に調子に乗ったこと、後悔させてあげるんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほぉら、ゆっくり腰を回して、ぐーりぐーり……んんっ、あっ……いいねぇ\n、これが肉バイブって奴かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ、んあぁん……あっ、ふぁあ、あぁあんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふっ、隊長さんのチンポ、気持ちいいよ？　動かしたい？　猿みたいに\n腰を振って、あーしのオマンコ、ガンガン突き上げたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほんとはなぁ、あーしもそうしてほしいんだけどなぁ。すぐに許可だしてあ\nげるつもりだったけど、意地悪されちゃったからなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んあぁんっ♪　ふふっ、あーしの中、どんどんヌルヌルにな\nっていくの分かる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんのチンポのさきっぽで、ゆ～っくり中を擦るの気持ちいいんだぁ…\n…んんっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でもだめ、まだ突かせてなんてあげなぁい♪　……許してほしいなら、誠意\nってものがあると思うんだよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「……って、早！　謝るの早いよ！　えぇ……それでいいの隊長さん？　言っ\nとくけど、今の隊長さんめちゃくちゃかっこ悪いよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『申し訳ありませんシャラク様。いくらでも謝りますから、私のみっともな\nくて我慢の効かない租チンを動かす許可をください』って～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うっわぁ～……そんなこと、自分から言っちゃうんだ、ドン引きなんだけど\nぉ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でも……えへへっ、素直にあーしの身体を求めてくれる隊長さんは、ちょっ\nとかわいいかなって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふっ……そこまで言われたら、しょうがないなあ～？　これ以上我慢でき\nないんだもんねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ、来て？　あーしも動いてあげるから、隊長さんもガンガンって……\nんひぃんんっ！？　あっ、ふあぁんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「い、いきなり激し過ぎっ、あっ、ああぁんんっ♪　そんなに我慢してたんだ\n♪　すごいっ、隊長さんすごいよっ！　ふあぁっ、あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「許可した途端これとか、あぁんんっ♪　ふふふっ、どうしようもないなぁ、\n隊長さんは♪　あっ、んぁ、んふぅんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、ふあぁっ、はぁあああ～ん！　そこっ、そこいいよっ！　\nオーイェッ！　おく、もっとぐりっとしてっ、ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「早漏チンポのクセに、やっぱり固さだけは一人前なんだからぁ。ズンズンっ\nて突き上げられるの、気持ちいいよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ、あーしももっと動いてあげるから！　んあぁ、あぁんんっ♪　隊長\nさんも動き合わせるんだよ、いいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あっ、ふあぁんっ！　いいっ！　奥サイコーっ！　チンポ気持ちいい！　オ\nーイェッ！　小さくイクの、止まらないっ、あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんのが中で痙攣してるのが伝わってくるよ。分かってる、隊長さんも\n、このままイキたいんでしょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしの中にドクドクって、濃厚なチンポ汁、た～っぷり注ぎ込みたいんだ\nよね！　んんっ、あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ、来てよ隊長さん！　もうおねだりなんかいいから、一番奥に精液出\nしてくれたらそれでいいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あはぁぁんっ！　んあっ、んんんっ！　ふあぁ、あっあっ、来る！　あーし\nも来そう！　イキそう！　あひっ、んひやぁぁぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「出てるっ、出てるよぉ！　あひっ、ふあぁぁあんっ♪　こ、これ、あーしも\n出てる、潮吹いちゃってるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「気持ちいい、隊長さんの射精サイコー！　子宮に直接叩き込まれるの気持ち\nいいのっ！　あっ、ふあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしも気持ち良過ぎて、潮が止まんないっ！　膣内出し気持ち良過ぎて、\nお潮びゅびゅー止まらない！　オーイェッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへっ、まさか隊長さんのチンポでここまで乱されるなんて、思ってもみ\nなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ん？　隊長さん、どうして腰を引こうとしてるのかな？　……ふふふっ、本\n番はまだまだここからだよ、っと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへっ、一回の射精でやめる訳なんてないじゃん！　まだまだ続けて精液\nびゅーびゅーしてもらっちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『流石に出し過ぎて疲れたから、ちょっとだけ休ませてくれ』だって？　ノ\nー！　何度も言わせないで、主導権はぜ～んぶあーしにあるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「でもでも、みっともなくおねだりするなら、考えてあげないこともないよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『くそ雑魚早漏チンポの分際で生意気いって申し訳ありません。射精後のチ\nンピクが止まるまで待ってください、お願いします』ほぉら、言えるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「オー！　ノータイムで言っちゃたよこの人！　隊長さんってば、みっともな\nいなぁ、キモいなぁ、かわいいなぁ♪　んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふっ、ざ～んねん、あーしは考えてあげるって言ったんだよ。んっ！　\n考えた結果、やっぱり隊長さんを犯すことにしたの！　あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あぁぁんっ♪　そもそも、隊長さんが悪いんだよ、そんな可\n愛い姿をみせられて、我慢できる訳ないじゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ほらほらぁ、あーしのオマンコ、気持ちいいしょ♪　さっき出した隊長さん\nの精液も混じって、トロトロのぐちょぐちょなんだからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あっ、あ、あぁあぁんっ♪　一回出しても、やっぱりこの固さはいいね！　\nんんっ、ふあぁんっ！　奥ぐりぐりって擦るの、好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふあぁんんっ！？　ズンって来たっ、身体ごと引っ張られて、チンポズンっ\nてきたぁ！　あぁぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふふふっ『ここまで来たら負けてたまるか、とことんやってやる』って？\n　オーイェイ！　そうこなくっちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ふあぁんんっ！　すごい！　オマンコのなかでチンポ大暴れし\nてるっ、あぁあんっ♪　いいよっ、お臍の裏削るの気持ちいいよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いくら強がっても、全然余裕なんてないことはわかってるんだから。あっ、\nふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こうやって、ぎゅっぎゅ、ぎゅっぎゅって、おまんこ全部で締め付けるのが\nいいだよね♪　隊長さんのチンポ、またピクピクしちゃってるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「もう一回ぎゅっぎゅっ♪　えい、えい♪　えへへ、反応がかわいいなぁ♪　\nこんなの、あーしも我慢できなくなっちゃうじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんんっ！　一気に激しくなってっ、ふあぁ！　ああぁ\nぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「またイキそう、隊長さんのチンポで気持ちよくなれるの！　あぁんっ！　あ\nっ、んあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしもいっぱい腰振ってあげるからね！　おまんこグネグネって絞めて、\n搾りとってあげるから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「だから、ほらぁ！　また出してっ！　みっともない喘ぎ声あげて、アヘ顔晒\nしてさぁ！　精液びゅーびゅーっとあーしの中にちょーだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしもイクから、一緒にイクからぁ！　あひっ、あっ、ふあぁんんっ！　\nあっ、あっはぁあぁぁぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃいんっ！　出てるぅ！　熱いのまたドピュドピュ出てるのぉぉぉ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「これぇ、サイコー、ああぁんっ♪　お腹の中が隊長さんの精液で満たされて\nいく感覚、ふああぁんっ♪　サイコーに気持ちいいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あああぁ……中に出されるの、やっぱり好きかも……んんっ……お腹ふわふ\nわして……これ、しあわせ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……えへへっ、最初はされるがままだったくせに、結局い～っぱ\nい出したもんだねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「二回目だっていうのにすごい量……んんっ……相変わらず早漏には変わりな\nいけど、勢いだけは凄いよねぇ隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふふっ、このまま尿道に残る精液まで、ぜ～んぶ搾り取ってあげる♪　すっ\nからかんになるまで出し切らなきゃ、許さないんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え？　これ以上は本当に無理だって？　……むぅ、確かにオマンコの中でド\nンドンしぼんでいってる、かも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「まったく、情けないぞ～隊長さんのチンポ君。ほれほれ～、腰を動かしてあ\nげるからもうちょっとがんばれ、がんばれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あはっ♪　な～にその可愛い喘ぎ声、あーしに媚売ってるつもりかなぁ～♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ま、いいよ。それに免じて今日の所は許したげる。でも、次にやる時は最後\nの一滴まで搾り取ってあげるんだから、覚悟しておいてよね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ふああぁぁんんっ！？　だ、だめっ、激し過ぎてチンポ抜けちゃったよぉ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「隊長さんの精液が、身体にかかって、あっ、ふあぁんんっ！　付いたところ\n、熱くてじんじんして……ふあっ、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「膣内に出してもらえなかったのは残念だけど、これはこれで、心地いい、か\nも……んあぁん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ぶっかけられるのがここまで気持ちいいなんて……えへへっ、嬉しい新発見\nだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00009902_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うわぁ、あーしの身体、隊長さんの精液でベトベトのドロドロになっちゃっ\nてるじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どうどう？　隊長さん的には嬉しい？　ドキドキする？　あーしみたいに可\n愛い女の子を、くっさ～い精液で汚した感想おしえてよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「『控えめに言って最高』って？　えへへ、まぁ？　当たり前だよね？　この\nあーしにぶっかけた訳だしね？　えへへへへっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「というか、隊長さんってば、結局ノリノリだったね。最後の方なんてと～っ\nてもかわいい喘ぎ声で身悶えてたよ、気づいてた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ～、照れてるんだぁ～♪　隊長さんってば、かわいい～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいよ、その態度に免じて最初の意地悪は許してあげる。だからさ……えへ\nへ、またエッチなこと、いっぱいしよ～ね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}