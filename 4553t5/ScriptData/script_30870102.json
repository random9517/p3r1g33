		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104405" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「精液の臭いだけでイッてしまう……！　あッ、ああっ……ああっ、からっぽ\nのオマンコ、惨めに情けなく蠕動して……ううううう……！！」", "NORMAL" ]},
