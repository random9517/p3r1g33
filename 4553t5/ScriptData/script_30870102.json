		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104131" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ああああああ♪　そう、そう、そうぅうっ！　ズッポズッポしてくれええっ\n！　殺すつもりでピストンっ、ピストンしてくれええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104132" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ああっ、あっあっああッ♪　あぁあっ♪　膣口から子宮口まで貫通する快感\nっ、快楽っ、エルフアクメっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104133" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んぉおおおっ♪　どっちゅどっちゅ中を……膣内を往復されるたび……ッ、\n太い快楽が身体を串刺しにして……あああ、私を処刑するぅ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104134" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ああ、隊長、隊長隊長……！　どうしてそんなに、あっ♪　天才的な腰使い\nなんだぁあ♪　私っ、わた、ひ……わたひ、淫売になってしまうっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104135" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「オチンポすごすぎて、お、オマンコのことしか考えられなくにゃるっ！　オ\nマンコッ、チンポでズンズンされる以外どうでもよくなってしまうっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104136" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ん、んんんん……！　重低音のよう、に……響く快楽……！　う、ぅ、う、\nぅうう、うう……すまない……ッ、すまないすまないぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104137" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「娼婦のように腰を振ってっ、オマンコ蠢かせながら……ああっ！　レイプ堪\n能する淫乱ダークエルフですまないぃいっ、すまないぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104138" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「っああああああ♪　みんなっ、森のみんな、ごめんなさいっ♪　私、このオ\nチンポに支配されますっ、オチンポ様の下僕に成り下がりましたっ♪」", "NORMAL" ]},
