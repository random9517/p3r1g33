		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104139" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あひっあひっあひっ♪　永遠に性交して欲しくってっ……オチンポもらえる\nなら何でもしてしまうと思うっ♪　本当に……本当にすまないっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104140" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「っあああああ♪　隊長のオチンポ美味しくて、じゅぷじゅぷマンコで舐めま\nわしてしまうっ♪　あは……アハハハ、もうだめ、もうだめだぁ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104201" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「って、んんんんんんっ！？　やっ……隊長！？　なに、なんだ……？　私の\n尻を手で叩く、なんて……ああっ、痛みで一瞬気が逸れて……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104202" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「何？　私が淫乱ダークエルフだから？　お仕置きにスパンキングをしてやっ\nている……？　あっ♪　ス、スパンキング……？　これが？　あっああっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104203" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あぐぅっ！　痛いっ！　痛い、やめてくれ……！　痛い、のに……んぁああ\nあっ……どうしよう、ますます濡れてきてしまった……あぐぅっ！　んぐ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104204" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「痛いぃっ……痛い、いたいぃ……！　ひぐっ！？　うぐっ！　んぐぅっ！　\n痛い、痛いのにぃ……自分でもわかるくらいに溢れてくるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104205" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「愛液が洪水みたいに溢れ出して……オマンコの締まりも良くなって……。ん\nあああああ！？　感度まで上がって、敏感に……嘘だろうっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104206" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「隊長っ、隊長、私をどうした！？　んあああああっ！　尻っ！　尻を叩かれ\nながらオチンポ抜き差しされると……あああああんっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104207" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「死ぬほど感じるぅううう……！　はひっ♪　はひ、はひぃっ♪　酸欠状態に\nなって、頭がカーッとあったかくなって……そのかわりっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104208" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「バシッ！　バシッと打たれるたびに……私の奥が、オマンコの奥がぁああっ\n！　キュンキュンと疼いて止められない……止まらないぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104209" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あっ、ああ……！　ひどいこと、ひどいことをしないでくれ……。あううっ\n！　痛いっ、あああ……気持ちいい、気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104210" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あぅぐっ！？　尻が腫れてしまうぅっ……んあっ！　オマンコ掻き回しなが\nらスパンキング、しないでくれ！　おかしくなるぅう……！」", "NORMAL" ]},
