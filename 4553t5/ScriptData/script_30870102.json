		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104403" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あッんんんっ……！　このネバネバ、とてつもない量の精液……ぃ。これが\n私の腹の中に出ていたら、どれほどの快楽だと思うんだッ……！」", "NORMAL" ]},
