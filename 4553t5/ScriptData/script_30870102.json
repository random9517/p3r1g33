		{"command":[ "PLAYVOICE", "087_0104307" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んぐっ……ん、ん、ん、んん……！　はァーっ……！　はぁッ……はぁああ\n……ッ……」", "NORMAL" ]},
