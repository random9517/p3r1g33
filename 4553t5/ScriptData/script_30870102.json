		{"command":[ "PLAYVOICE", "087_0104121" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「うねって、チンポにすがりついてしまう……！　レイプ、レイプしてくれ…\n…。いいや、レイプ、してくだ……さい……お願いします……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104122" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「私の、い、卑しいダークエルフのアーリッドの……。処女のくせにチンポ大\n好きな淫乱オマンコを、激しいピストンで罰してください……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104123" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ッ……！　あっ……！？　あっ、ああああっ……！？　おっ♪　ああっ♪　\nひゅご……！　ひゅごい……！　ひゅぎょい、ひゅぎょいぃい♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00008701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104124" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「入れただけで気持ちイイというのにぃいいっ、動くともっとしゅごいっ♪　\nしゅごいぃいっ♪　おほっ♪　あひぉおっ♪　おおっ、おおおんっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104125" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「ああ、奥、奥、奥を突け、奥ぅうっ！　突いて、突いて、突いてくれぇえっ\n……！　んあああああ♪　これっ、これこれこれぇええ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104126" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あーっ隊長♪　隊長愛しているッ♪　隊長本人のこと、も……ああああんっ\n、チンポ、隊長のチンポも愛してい、るぅううっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104127" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「オマンコが悦んでいるのが伝わるだろうッ？　ギチギチにチンポ……大好き\nなチンポを締めつけて……独占欲にまみれたエルフマンコっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104128" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「あひっ♪　あひっあひっ♪　脳細胞ッ、壊れるくらいにチンポ、気持ち良く\nて……私、私、自分から腰振ってるっ、腰揺らしてしまってるぅうっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104129" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「んぁあああああ♪　コレだぁあああ♪　私の世界に足りなかったのは、この\n屈強たるチンポぉおっ……隊長のデカチン、この、快感んんんっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "087_0104130" ]},
		{"command":[ "SETNAME", "アーリッド" ]},
		{"command":[ "SETTEXT", "「はぁ……っ、はぁあああっ……♪　気持ち良すぎるぅうッ……！　な、なあ\nっ……腰、腰を掴んで叱るみたいにガン突きしてくれっ」", "NORMAL" ]},
