{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいか……大人しくしといてくれよ？　んっ、せっと……ふぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「よし……何とか、しっかり挟めたみたいだね……うわわっ、だ、だから大人\nしくしといてくれって言ってるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「自然に勃起するのは止められない……んっ、まぁ……そりゃあ、そもそも大\nきくさせようとしてるんだし、嬉しいっちゃ嬉しいんだけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ただ、あんまり大きくされると……ちょっとやりにくいっていうか…\n…んっ、何とか最初だけでも落ち着いていてもらいたいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふむ……とにかく、お互いに善処するってことで……よし……それじゃ、動\nかしてくよ……んんっ、はっ、うんっ……んっく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おぅ……んっ、しょっ……もうちょっと……スムーズに動いた方が、いいん\nだよね？　まだ、少しぎこちない感じがするね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「上下に……して……んっ、よいっ、しょっ……んっ、ふっ、んっ……んんっ\n、はっ、んっ、うんっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……それにしても、大したオチ○ポだねぇ……あたしの、このおっぱ\nいでもやっと抑え込めるかどうかなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあこれ位の元気がなきゃ、張り合いもない。んっ、そうだね……ちょっと\n滑りやすくしてやろうか……んっ、えろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ……こういう時は、シンプルに唾液が一番手っ取り早いね。んっ……ち\nゅぱ……んふぅ……うん、まんべんなく……濡らしてやるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ぴちゅ……んちゅぷ……れろ……んりゅ……れろぉ……えろっ…\n…れろ……んっ、えろ……れろん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ちょっと濡らすだけのつもりだったけど……中々どうして……や\nっぱり、チ○ポ舐め……一度始めると、止まらないね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んれる……れろぉ、何せ……愛する夫の、子種をいっぱいくれる大切なオチ\n○ポ様だ……ふふ、特別待遇にしてあげないとね……える……れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ん、ぴちゃ……ちゅぱっ、んむぅ……おっと、鈴口がピクピク震えてきた…\n…ふふっ、相変わらず弱い所が隠せないねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、そういう分かりやすい反応は嫌いじゃないよ……れろ、んっ、えろ……\nれろぉ……ほぉら、こいつが気持ちいいんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぴちゃ……んふっ、おっと……いけない。本来はパイズリが一番\nの目的だったね。ちゃんと、してやらないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ、いいよ……ぎゅぅっと挟み込んで……ぐにゃりと……押し\nつぶして……擦り込んでいく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、熱いオチ○ポと……おっぱいが……揉みくちゃになって……\nはぁんっ……汗が滲んで来ちまうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、気持ちいいかい？　そいつは何よりだ……んっ、ここで裏筋なんか\nを舐めたら……えろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……おっと、またピクっと来たね……ふふっ、本当に分かりやすい\nチ○ポだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、えろ……れろ……れろぉっ、はぁ……ちゅぷっ……んんっ、いいよ\n……一緒に扱いてサービスしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はんっ、んんっ、あぁ……んっ、やだね……あたしの……おっぱいも、んん\nっ、ピリピリって……ちょっと痺れて来たよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぁ……そりゃあ、こんなデカチ○と揉みくちゃになってるんだ……はん\nっ、カラダ……火照るのも無理はないさ……あっ、んっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……うんっ……んくっ……ふふっ、あたしを見る目がギラギラしてるよ\n……こんなナリのあたしを怖がらない物好きも、あんた位のもんかねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁ……今更、ダンナの度量を疑うこともないけどね……んっ、ふっ……あ\nぁ……硬くなった乳首……当てるよ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁんっ、やっぱり……くぅんっ……これぇ……はっ、んっ、気持\nち……いいよ……乳首と亀頭のキスぅ……か、感じるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、ちゅって……あぁっ、軽くくっつけ合うだけで……はぁぁん\nっ、力が抜けそうな感じになって……はぁっ、もっと……あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……バ、バカ、からかうんじゃないよ……あっ、こんな声が出るの\nは……仕方ないだろ……んっ、くぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それだけ、あんっ……あたしも……ドキドキしてるんだ……はぁっ、んっ、\nいやらしい声位……出ちまうさっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、あんただって……ここを……こうしたら……んちゅっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、言わんこっちゃない。れろ……お互い様だよ……ん、どっちも……\nんあっ、いやらしい気分になって……ムラムラして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅん……んふっ、またチ○ポが跳ねて……汁が滲んできたよ……そろそろ\n、限界じゃないのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰に力が入ってるね……せいぜい、ギリギリまで我慢したらどうだ\nい？　でも……あたしのおっぱいプレスにどこまで耐えられる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……やっぱり限界だろう？　さあ、観念して……このまま、あたしの\nおっぱいに出しちまいなっ！　ん、くぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ、ふっ……出て来たっ……チ○ポの先からっ、びゅうびゅう\nって……はぁんっ、ドロドロのやつが……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……相変わらずこんなに……んっ、おっぱいに……まだだよ、もっと\n扱いてやるから……どんどん出しな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あふっ……んんっ、そうそう……んっ、またビュルっと出てきたね……あぁ\n、このムワッとするニオイ……これがあたしをおかしくするんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……はふ……何とか、落ち着いて来たね。んんっ……おっぱいが温かい\nよ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ、妻のご奉仕の味はどうだった？　こんなことしてやるのなんて、勿論\nあんた以外にはいないんだから……少しは感謝してもらわないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「バ、バカ……そんな、改まってお礼を言われたら……調子が狂っちまうよ…\n…言葉のアヤなんだから、もっとどっしり構えてなっての……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「別に照れてる訳じゃないさ……あぁっ、もういいっ、ほらっ、まだ一発だけ\nなんだっ……続きするよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ……これだけチ○ポから出しても、ビンビンのままだろう？　全く、\n節操のないダンナだよ全く……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ、んっ、あんたのザーメンのお陰で、おっぱいとチ○ポがめちゃく\nちゃになってるよ……汁が糸を引いて……いやらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……このニチャニチャした感触……もっと、味わっていこうねぇ\n……あふっ、うんっ……んくっ、うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、れろぉっ……あぁ、生臭いけど、んっ、ちゅぷ……この青さ\nが……れろっ、すっかり病みつきになっちまってる……ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふっ、れろっ、れろぉっ、れろんっ、れるっ、れりゅっ、んれるぅぅぅ…\n…れろろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、精液の味ぃ……もっと、んっ、楽しませとくれ……ち\nゅぱぁっ、んちゅ、ぴちゃっ……えろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふふっ、舌の方の反応がいいね……れろ、んっ、この鈴口の所……えろっ\n、押し込まれると、ピクってしちまうんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「れろ……れるぅ……んふっ……ちゅぱっ、分かってる……集中的にしてやる\nさ……んりゅぅぅ……れる、れろっ……えろっ、れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……それから、またぎゅうっと……縦と……横にぃ……はんっ、あぁ…\n…オチ○ポ……こすれるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んぁっ……おっぱいとオチ○ポが溶け合ってぇ……はぁぁ…\n…トロトロになってく感じが……ずっといい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んちゅぷっ……汗と……ザーメンと……あたしの唾液が……ぐち\nゃぐちゃって一つになって……はんっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おっぱいの谷間で……オチ○ポがあっちこっち向いて……あぁ……それを見\nてるだけでも、ドキドキしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁっ、また……チ○ポがビクビクしてる……んんっ、目の前でま\nた射精する所……見られるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁ……ここから本気のパイズリぃ……ほらっ、また……オチ○\nポからっ……ビュビュッと……ミルク出すんだよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、んぁっ、はんっ……ほらっ、このプレスぅっ……あぁんっ\n、あたしのおっぱいも気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁあっ、止まらないっ……チ○ポっ……あぁっ、もうすぐ出るの\n分かるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、うんっ、んくんっ……この赤いチ○先から……白いミルクぅっ…\n…いっぱいっ出すとこぉっ……ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「えろっ、れろれろれろぉぉっ……またおっぱい中出しでもぉっ……顔にぶっ\n掛けてもいいからぁっ……んれるっ、れろぉっ」", "NORMAL" ]},
