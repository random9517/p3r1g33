		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……はぁぁ、あふっ……イ、イッてる……おっぱい中出しされてイ\nクなんて……あたしも、ずっとスケベになっちまってる……」", "NORMAL" ]},
