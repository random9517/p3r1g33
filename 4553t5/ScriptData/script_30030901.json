		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……また、おっぱいに出したいのかっ？　分かったっ……このまま\n、思いっきり出しちまえっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0903301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
