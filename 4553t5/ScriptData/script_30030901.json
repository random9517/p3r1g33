		{"command":[ "PLAYVOICE", "v2_003_0903305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000309_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
