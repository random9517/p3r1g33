		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「トン、トン、トン。沙世子です～♪　お部屋に入ってもいいかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっ。入っていいのね？　ありがとう。あなたは忙しいかな～って思ったん\nだけど、もし……時間が空いていたら、ちょっとだけ……いいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「毎日毎日、お仕事ばかりで疲れてなぁい？　私は淫魔主婦だから、癒すこと\nに長けてるの。良かったら、気持ちいいマッサージをしてあげたくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……うふふ。そうね。その代わり、すこーしだけ私の性欲も発散させてもら\nって。精液もちょっとだけもらうけど、それでもよかったら。どうかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「いいのね♪　じゃあ、契約成立～、ということで♪　さっそくおっぱいをぽ\nろーん♪　出しちゃいました～♪　ミルクの香りがむわっとするでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025901_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「乳首をね……ちゅーって吸ってほしいの。うんうん、とっても上手よ。唇で\nはむって甘噛みして。そう、あとはあったかい口の中で転がして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっ、んっ♪　気持ちいい……♪　ここをね、れろれろれろ、ぴちゃぴちゃ\nちゅーちゅーって吸ってると、いいことがあるはずよ。まだ内緒だけど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私のおっぱいの、ふわっふわの感触と優しい体温に酔いしれながら……コリ\nコリに硬くなってる乳首を飴を舐めるみたいに上手におしゃぶりして♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……うん♪　うん♪　そうしたらぁ……私からもお返ししてあげまちゅね♪\n　おちんちん……うふふ、すっごく硬く、大きくなったこれを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ぎゅうっておててで握って、シコシコしてあげる……♪　あん、恥ずかしが\nっちゃだめですよ？　腰を浮かせてぇ……そうそう♪　いい子ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「手の中で凶悪に勃起して、ビックンビックン脈打ってるわ。あは……♪　な\nんて強くて逞しいおちんちんかしら。あの人のとは全然違う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……あ。ごめんなさい。他の人と比べるだなんて、マナー違反ね。私には夫\nがいるものだから、夫を基準にしてしまいがちで……気をつけるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ただ、これは信じてほしいわ。あなたのおちんちんはぁ……♪　ごくっ♪　\n私の淫魔の血を騒がせる。サキュバスが喜ぶいやらしい形をしてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「証拠に、ずーっと触っていたくて、まったく手を離せない……♪　んあああ\n、なんて理想的な形なの。長ぁい……元気いっぱいで、反っていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「美味しそう……♪　あっ♪　よだれが出ちゃいそう。うん……♪　シコ、っ\nて手を上下に動かすと……ビクッ、て震えてとっても可愛いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……私の手。嫌じゃない？　シコシコされるの、気持ちいいかなぁ？　私の\n方はね……おっぱい、い～っぱい気持ちいい♪　もっともっと吸って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　エッチな舐め方……いいわ、すごく感じちゃう……♪　んっ\n♪　ちゅぱちゅぱって音を立てながら、吸って、噛んで……あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……♪　いい……♪　こっちも指が止められなくなってきて…\n…♪　ああぁっ、一緒にどんどん昂っていきましょうね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……んん？　私の指の動きが卑猥だ～って？　そうよ。あなたにいっぱいエ\nッチな気持ちになって欲しくて、やらしい動きで刺激してるんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたもめいっぱいエロい舌使いで、私のおっぱいおしゃぶりしてほしいわ\n♪　……じゅるっ、じゅるって唾液を鳴らして……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ね？　あなたがエッチな舐め方すると、私の手もなまめかしくおちんちんを\n這い回ってく……。どんどん乳首とおちんちんが熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「っあんっ♪　急に乳首を噛んじゃだめぇえ♪　んっ、う、嘘よ、ダメじゃな\nい……♪　もっと強く噛んで♪　歯のあとがつくくらい……はぁうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「いいわ、いいわぁ……♪　私も亀頭をクリクリしてあげる♪　カウパーを指\n先につけて、クリュクリュクリュ～♪　んふふ、ビクビクしてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「カリ首も、肉竿も……おタマタマもまんべんなく♪　んぁっ♪　あなたも反\n撃ね？　あぁっ、おっぱい、おっぱいぴちゃぴちゃおしゃぶりしてくるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああああぁ……ッ！　舐めて、舐めて、舐めてぇ♪　も、うすぐだから……\nもうすぐあなたを驚かせてあげられるわ、……あっ、イクわよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁああああっ♪　わかる、かしらぁ♪　母乳が噴き出しちゃってるの♪　\nあぁんっ♪　あんっ、あぁんっ！　そうなの、絶頂すると出ちゃうのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私っ……♪　淫魔主婦って、イクとおっぱいミルクが出るのよぉっ♪　ああ\nあっ……！　事前にたっぷり乳首を刺激してもらって……あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「限界に達すると、溜まった母乳がびゅーって♪　びゅーってぇ♪　んんん♪\n　おいちい？　甘くてとろーっとしたサキュバスおっぱいミルク♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたのためにたくさん出すから、お口に溜めてゴクゴク飲んでぇ……♪　\nああっ♪　あんっ、あんっ、あんんっ♪　すごいがっつき……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「出した分ぜ～んぶすすってくれてありがとう♪　……あら？　母乳を飲んだ\nら、おちんちんがますます硬くなってきたみたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「やぁだ♪　指でつかめないくらい太いわ、パンパンに腫れてるぅ……♪　そ\nうなの♪　母乳ちゅぱちゅぱしながらおちんちん握られるのちゅきなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたって赤ちゃんみたいね……可愛いわ♪　ん～♪　ママのおっぱいを飲\nんで勃起ちたおちんちん、撫で回されるのゾクゾクするのよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んんん？　どうしたのかしら？　おちんちんから精液ぴゅっぴゅってしたく\nなってきちゃったのかなぁ？　うふふ、我慢することなんてないのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私も……あっ♪　私もおっぱい張ってきてる、たっぷり感じて胸がいっぱい\nになってきてるから……！　一緒にびゅーって出しましょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私の合図でびゅるびゅるしてね？　はぁい、シコ、シコ、シコシコシコ♪　\n５……４、３、２、１……はい出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んんんんっ♪　いいわ、そのままぁ……っ！　あっつい精子がびゅる～って\n♪　びゅるびゅるびゅる～って手の中に出てる……溢れちゃう！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私もまた母乳っ、母乳出てきたわ……っ！　あああっ、あなたはおちんちん\nから！　私は乳首から真っ白な体液を発射しあって……っ、んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「こんなに幸せな瞬間って他にないわっ♪　ああああっ、気持ちいい……ッ♪\n　気持ちいいっ、あなたの精液を受け止めながら、母乳を発射して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「二人で天国に来ちゃったみたいね……♪　あぁんっ、私ったら淫魔主婦なの\nに、天国だなんて言って……。でも、エッチで楽しいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「悪い子の天国……あんっ。こんなにピュッピュしてくれると、絞ってる私の\n方まで楽しくなってきちゃう……♪　シコシコ良かったのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「……うん♪　私もおててでするのす～っごく面白かったわ。ごくっ……♪　\n想像してたよりずーっと濃い精子が飛び出してきて……。はぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「この芳醇な香りぃ……。今すぐ自分の手をペロペロしちゃいたい♪　きっと\n苦くて、サキュバス好みの強烈な味なのよね。たまらないわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ほら。わかる？　私の手の中でねちょねちょ粘ってる。強い精液って粘り気\nでわかるのよね……。触ってるだけで幸せ……って、まあ、まあ、まあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちん、全然萎えたりしないのね～♪　ぴゅっぴゅちたのにおっきいま\nんま♪　あらあらあら～♪　精液がローションみたいで感じちゃうの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だったらぁ……♪　せっかくだから、おちんちんに絡めてぬりぬりしまちょ\nうね～♪　っんっ♪　精液でヌラヌラに光ってるおちんちんってエッチ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバス淫魔主婦の授乳手コキ……そんなに気に入ってくれたなら、いく\nらでも続けてあげるわね♪　いいこ、いいこ……ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっ♪　おちんちんは悪い子かも♪　やぁん……♪　もう力を取り戻しちゃ\nって、私の手のひらをグイグイ押してくるぅ……力強い～♪　んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「えいえい、私も負けないわよ～♪　ぎゅう～っておちんちんを握りしめて…\n…ふふふ♪　ズリズリ上下に動かしちゃう～♪　はぁ、はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「精液のにゅるにゅるで私の手までベトベトだわ……♪　んん……♪　ぬるん\nっ、ぬるんって指がすべって……先端から根元まで一気にシゴけるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「根元を握ってぇ……先端までぬるぅうう♪　亀頭をいじって、尿道口をニュ\nルニュルして……また根元まで折り返しちゃってぬるぬるぬるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ん～～♪　感じると足がピクピクして、股間がだんだん浮いてくるのね～♪\n　わかりやすくっておちんちん、いじりやすいわ。ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたの感じるところを教えて……♪　はぁ、はぁ、性感帯、ぜーんぶ把握\nしてあげたい♪　それでね、時々焦らしてぇ……油断させてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もうだめ、おちんちんつらいよぉ～ってなった瞬間にニュルニュルニュルニ\nュルぅって一気にシゴき上げちゃうの♪　いっち、に、いっち、に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ここかなぁ？　こっちかなぁ？　うふふ、おちんちんを探検しちゃう♪　…\n…ん♪　今反応した？　敏感なのねぇ、とってもいいことよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「母性本能くすぐられちゃって、いくらでもご奉仕してあげたくなっちゃうわ\n……♪　こうかしら？　これくらいの力でいい？　もっと強く？　うん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「こうね。こうやって、強く握ってニュル、ニュル、ニュル、ニュル♪　は～\nい、だんだんおタマタマに精液が溜まってきてるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁ……もう今にも尿道をかけあがってビュルッて出してしまいたいわよね\n。んんっ、んっ……私もそれが楽しみなの。待ちきれないの……んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もう一回、真っ白なおしっこを上手にしーしーできまちゅか～？　ママねえ\n、あなたの新鮮な精液が欲ちいの。おねだりしてもい～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ぷりっぷりの特濃精液、出して私にごちそうしてぇ♪　ごのガッチガチの淫\n乱おちんちんからびゅうーって発射するとこ見せて、見せてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もらった精子は全部飲むからぁ……♪　だからお・ね・がい♪　おちんちん\nミルクちょうだい♪　ママの手に染みこむくらい出してぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁっ♪　やん♪　もぉスゴすぎよ♪　あっ♪　こらぁ……♪　飛ばしす\nぎちゃってお顔にかかってるぅ♪　んぅ♪　美味しい精子ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　ママの唇に、お口の中にも飛び込んできたよぉ……♪　じゅるる\nっ♪　ん～っ♪　舌が痺れるくらいの苦味～♪　妄想してた以上の濃さ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　あったかい精液の雨……♪　こんなの、淫魔主婦を喜ばせ\nるだけよ♪　サキュバスママにとって最高のプレゼント♪　気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ふぁあんっ♪　あなたのお顔にも母乳がかかって……♪　私のお顔にも精液\nがダラッダラ……♪　美味しいわぁ、あなたの精子が一番美味しいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「お顔の皮膚全部が喜んじゃうぅ♪　……あっ♪　精液でパックされてるみた\nい……♪　ママ嬉しくて若返っちゃうわよぉ♪　もっとかけてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　射精中にしごくと尿道の奥から噴水みたいに……！　びゅび\nゅぅうっ、ぶびゅううって、いくらでも出てくるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「…………あっ。ご、ごめんなさい。質の良すぎる精液を浴びると、ついつい\n栄養を吸収することに集中しちゃったわ。ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたの精子って、出てくるエネルギーが多くて理想的なの……♪　そうね\nえ、二回も出してくれたから一週間はもつかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「他の子の精液が白いご飯だとしたら、あなたのだけ松茸ご飯って感じで……\n。とっておきのご褒美グルメよ。はぁ……♪　堪能しちゃったあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたも私の母乳、気に入ってくれてたらいいなあ……♪　お腹がすいたら\nすぐに呼んでね？　いつでもごちそうしてあげるから。本当よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んっあっ♪　出た出たぁ♪　あっ……♪　今度はお尻にかけちゃうんだぁ…\n…♪　本っ当にいたずらっ子♪　やんちゃすぎるおちんちんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ママの大きいお尻がちゅきなのぉ？　ふふふっ、いいわよお♪　かけたいと\nころにぴゅっぴゅして……♪　それがサキュバスへのお礼だと思って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「っんんんんんんっ♪　暴れん坊のおちんちんから放たれる、純白の精液ぃ…\n…♪　お尻の谷間に、輪郭に垂れてと～ってもエッチね……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あああっ……♪　精液を浴びると気力がぐんぐんみなぎってくるわ……！　\n全身にくまなくかけて欲しいくらい♪　あんっ、ドロドロぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「そぉれ♪　尿道に残っている分ももったいぶらずにちょ～うだい♪　びゅる\n♪　びゅるっ♪　あぁ……精液のシャワー、感激ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もう出ない？　ちゃんと出しきれた？　あっ♪　最後に一回……、んぅうう\nう♪　サービス精神旺盛で助かるわぁ、なんていい子なのぉお……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025901_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んっ、あっ♪　あぁあ……♪　たくさん浴びせてくれてありがとう……♪　\nあなたの精液、特別なお酒みたいにまろやかで、ドロドロで素敵よお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「今まで、どれだけサキュバスとしてたくさんの男の子の精を食べてきても…\n…全然満足できなかった。ただのお食事でしかなかったわ。だけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私、今すごくドキドキしてる。こんな最高の精液を持つあなたに出会えたな\nんて……。ん～♪　このまま、精子の臭いに包まれて眠りたぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私にはあの人がいるのに……。夫よりも好きになっちゃったらどうするのよ\nぉ♪　でも……そうなっちゃったら、私が責任取るわね♪　ふふふ♪」", "NORMAL" ]},
