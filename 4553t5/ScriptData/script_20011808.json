{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……今でこそ、氷華は孤独に戦っている。でも『戦隊』の冠は絶対に外そう\nとしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550016" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それには、とても悲しい、気高い戦士の魂の、鎮魂の、勇躍の…………あー\n……えー……まあ、タフでクールな過去があったってわけさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "――言い回しに困ってんじゃねえよ。余計なこと言わなくていいからちゃんと\nしゃべれ、この野郎……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう思っていると、鳳雛はそのまま氷華の過去について語り始めた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……仮面戦隊マスカレード。もともと彼女は三人組で戦っていたのさ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550018" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0118" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたは自分がしたことの意味を理解しているのですか？！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550013" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マスク・ザ・レッドの胸ぐらを掴み、マスク・ザ・ブルーが激しく詰問してい\nた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マスク・ザ・ブルーは、マスク・ザ・レッドの気持ちを完全に測りかねていた\n。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「わかってらぁ！　しっかり腹括って実行したさ！　で、こうなっちまったん\nだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021550001" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……あなたは、それでも正義のヒーローなのですか？　子供たちの声援に、\n胸を張って応えられるのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550014" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「俺ぁテメェみてーに、日和見気取ったりしねーんだよ！　綺麗事だけ言って\n、なんにもしようとしなかったくせに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021550002" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……なんにもしなかったわけじゃありません。あなたのように浅慮に陥らな\nいようにしているだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550015" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「ざけんな！　悪をぶっ潰すには、絶対的な力が必要なんだよ！　それぐらい\n、てめぇだってわかってんだろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "胸ぐらをつかむ手を、マスク・ザ・レッドが振り払う。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マスク・ザ・レッドの説得を諦めたのか、マスク・ザ・ブルーはただ立ち尽く\nしてしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……そうですか。では、本当に残念ですが、あなたを仮面戦隊マスカレード\nのリーダーとして認めるわけにはいきません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550016" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「なっ？　何だと……？！　う、うわぁああっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……さようなら、ほむら…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550017" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "………………。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「――これが、真実。唯一無二のね。こういう経緯があって、氷華はリーダー\nを名乗らざるを得なくなったってわけさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550019" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……３人目は？　いつ出てくるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「言えない。探偵はもったいぶるのが仕事だからね……ふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……気になりますなあ。３人目は何色なのですかな？　赤、青……ですから\n、紫かもしれませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021550009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、色なんて見えないだろう。犬なんだし。俺はピンクだと思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おやおや、思考の飛躍が見られるね。まさか、そこが気になるとは……いい\nだろう、じゃあ、もう少しだけ真実の闇を払うとしよう――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550021" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、鳳雛が何かを言おうとした途端――。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「きゃあああああ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550018" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……氷華！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "話し込んでいる間に、マスク・ザ・ブルーの悲鳴が響き渡った。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}