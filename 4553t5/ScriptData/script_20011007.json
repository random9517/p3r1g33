		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あははははっ！　ほらほらほらーっ！　そーりゃりゃーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121330001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉわぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿！　だ、大丈夫ですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫じゃねぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「くっそ、こいつマジでメチャクチャしやがる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221330001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふーん、さっきはエラそーなこと言ってたけど、もう降参？　土下座した\nら、許してあげなくもないけどー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121330002" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「てんめ……調子こきやがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221330002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「く……しかし、このままでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んー？　まーだ諦めが悪そうだねぇ。それじゃ、今度こそ分からせてあげ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121330003" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「そこまでですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121330001" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「やーっと見つけた！　まったく、手間掛けさせやがってー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121330001" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ルシオラ！　ミラも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「待たせてしまいましたね、イグニス。お務めご苦労様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121330002" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「とんでもない、よく来てくれた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うぇー、何だよー、また面倒なのがわらわらと～。何で急にそんなに出てく\nるんだよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121330004" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「それだけ禍々しいオーラを出していれば、否が応でも感知出来るというもの\nですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121330003" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ずーっと、気配殺して雲隠れしてたクセにさ、いきなりイキりまくってんじ\nゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121330002" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何だ、こいつらは……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「同じ騎士団の仲間です。あちらが、銀の双剣、ルシオラ・キャンベル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「皆様、ごきげんよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121330004" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「隣にいるのは彼女の妹で、暁の鉄拳、ミラ・キャンベル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「へへー、よろよろー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121330003" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「銀の双剣……暁の鉄拳……もしかしてアレか、二つ名って奴か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「中々のこじらせ系でございますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しっ……あんま余計なこと言うな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「大いなる秘法（アルス・マグナ）の最強の姉妹二人が、こんな辺鄙な世界線\nにいったい何の用なのさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121330005" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「へへぇーん！　姉さん、あたしたち最強だって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121330004" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あら、そんなお世辞を言われても手加減はできませんわよ？　ずっと貴方を\n探していたんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121330005" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ここで見つかったが百年目！　とっととお縄につきなさいっての！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121330005" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よく分からんが……とにかく加勢が来たってことでいいんだよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はい、心強い仲間たちです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121330007" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっしゃ、なら、今度こそしっかり分からせてやろうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221330003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うっがー、めんどくさー！　いーよ、まとめて相手すりゃいーんでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121330006" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
