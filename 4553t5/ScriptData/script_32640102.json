{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長、来たぞ。わざわざ呼び出すなんて、どうしたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「なに、最近疲れているように見える？　別にそういう実感はないけれど……\nいつも見てるから分かる？　ふふ、そうか。ならそうなんだろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「だからストレッチを手伝うって、隊長、君が？　ん、じゃあお言葉に甘えて\nお願いしようかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、確かに手伝いをお願いしたけれど、この格好は……確かに足のすじ\nは伸びているけれど、ちょっと恥ずかしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026401_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「それで、ここからどうする……ひあっ！？　隊長、な、な、なにを……なに\nを出しているんだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「チンポって、そんなの見れば分かる！！　何で今それを出しているんだ！！\n　何を考えているんだ、君は！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「これを使ってストレッチって……そんなストレッチが……あ……んっ、すご\nく硬くなってる……こんなストレッチが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、こんな格好で、チンポを使ったストレッチ……ふっ、うっ……お、\nお願いしようかな、隊長。やらずに否定はできないし……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああああっ、入って、来た！！　んっ、隊長のチンポ、私のオマン\nコの中に、んっ、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「これで中からほぐすって……んっ、あっ、ふううっ！！　隊長、もっと優し\nく、んんっ、小突いたら、身体跳ねちゃう、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、あっ、んんっ、隊長のチンポが中をごりごりってこすって……\nひうっ、あっ、くああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、大きくて、硬くて、熱い……これが男の……いや、隊長のチンポ、\nふあっ、んんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ほぐれてきたかって、んんっ、ふうっ、はっ、ほぐれてる、私のオマンコ、\n隊長のチンポでほぐされてるっ！！　あんっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、この体勢、なんだか隊長と密着して奥がごりごりって、んっ、んう\nっ、隊長が動くたびに、奥が本当に……ほぐれてっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ、隊長のオチンポストレッチ、気持ちいいっ！！　あんっ、あ\nあっ！！　こうして動かれるのもっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「根元まで入れられてぐりぐりされるのも、どっちのストレッチも気持ちいい\nっ！！　ひああっ！！　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「それに、こうしてくっついていると、隊長の暖かさが伝わって……それも好\nきだっ！！　隊長、好き、好きだっ！！　愛してるっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、好きって言ったら、隊長のチンポが膨らんで……君も嬉しいんだね\n、なら、もっと言うよ、あっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「好き、隊長、好きっ！！　意地悪なところも、エッチなところも、実は私の\nことを見てくれているところも、この硬くて太いチンポも……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「全部、全部好きっ！！　ふううっ、だから、だからもっといっぱいストレッ\nチしてっ！！　もっと愛してっ、ひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んうっ、私も、こうして隊長のオチンポを愛するから……んっ、ふうっ、ふ\nっ、どうだい、いつも鍛えてる身体のオマンコは……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、締めつけて気持ちいい……んっ、そう言ってもらえたなら、\n鍛えてる甲斐がある……あんっ、ああっ、くっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「そんな、ずこずこ突かれたら、ふううっ、んんっ、あっ、ストレッチだから\n締めつけてもほぐさなきゃとか、あんっ、矛盾してるっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長のチンポの形、締めつけたらもっとよく分かる……んっ、あっ\n、はああっ、にゅるにゅるって、私の中をこすってる、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「カリ首も高くて、竿も太くて……先端の硬さが分かって……ふああっ、こん\nな逞しいチンポが私の中に、んんっ、あっ、はっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、奥でごりごりするのだめ、私のお腹、ぐりぐりされたら蕩け\nちゃう……んんっ、ストレッチだからって、こんなの、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「こんなのされたら、隊長の、君のことしか、君のチンポしか考えられなくな\nっちゃう、あんっ、あっ、くあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あううっ、うっ、だめって言ってる、言ってるのに！！　ああんっ、隊長、\n隊長のチンポっ！！　気持ちいいっ！！　ふっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、先端でぐりぐりって、ほぐれてる、もうオマンコの奥ほぐれてるか\nらっ、ふうっ、ううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「まだ足りないって、んんっ、そんなにされたら、オマンコがきゅんきゅんっ\nて、チンポ締めつけ続けちゃう……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、うっ！！　隊長、んんっ、隊長のオチンポ、こんなにずこずこ\nされたら、形を覚えちゃう……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、ああっ！！　私の、私のオマンコは君専用だから、いっぱい\nいっぱい覚えさせて、ひあっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、だから君も私のオマンコを覚えて……ふうっ、あっ、んんっ\n、あっ、こつこつこつってノックされてる、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「お互いの身体を覚えたら、効率的にストレッチができるって、んんっ、まだ\nそんなことを……でも、そうだね、あんっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「気持ちいいストレッチ、いっぱいしよう。あんっ、あっ、ふっ、隊長も気持\nちよくなって、一緒にたくさん気持ちよくなろうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、隊長のチンポ、膨らんで、ふんっ、んっ、出すんだね。いいよ、隊長\nのザーメン、いっぱい私の中にだして、んんっ！！　私も、イくっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長のチンポストレッチでイく、イく、イっくううううううっ！！\n　ふあああああっ、ザーメン、来たっ、あああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あんっ、ふううっ、チンポでほぐされたオマンコに隊長のザーメンがどくど\nくって、濃厚なザーメンがびゅるびゅるって出されてる……ひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、満たされてる、私の中が全部隊長で満たされてる……ふあっ\n、あっ、どろどろでふにゃふにゃに……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、このストレッチ、好き……隊長も好き……全部好き……隊長、愛し\nてる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あうっ、ストレッチはまだ終わってないって……あんっ、あっ、ほぐれきっ\nてないって、ああっ、そんなっ、ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んっ、中に出されたザーメンでぐちょぐちょになってるのに\n、ふああっ、あっ、そのまま突かれたら、んんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あんっ、あくっ、うっ、またオマンコほぐされて……んんっ、あっ、ああっ\n、あふうっ！！　私、火の女神なのに、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「私の火より、隊長のチンポの方が熱いっ！！　あうっ、んんんっ！！　カチ\nカチで、大きくて、熱くて……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「私の中、ぐつぐつにされてる……んんっ、こんなのでかき回されたら、ほぐ\nされるよりも、蕩かされる……ふっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「いっぱいトレーニングしたのに、鍛えた身体が全部どろどろにされちゃう、\nふああっ、んっ、ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「でも、嫌じゃない……隊長のチンポなら嫌じゃない、君になら、何をされた\nって、どうされたって嫌じゃない……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長、好き。大好きだっ！！　私の身体、隊長の好きなようにしてっ！！　\nあんっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「えっ、もう好きなようにしてるって、ふふ、嬉しい、あんっ！！　いっぱい\nいっぱい気持ちよくなってるって、なら、嬉しい、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「二人で気持ちよくなってるのが、嬉しい。私の身体で隊長が気持ちよくなっ\nてくれてるのが嬉しいっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、鍛えた締めつけが気持ちいいって……んっ、このためにトレ\nーニングしてるわけじゃないけれど、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「それでも君が喜ぶなら、あんっ、鍛えてよかった。あっ、んっ、あああっ、\nあっ、ふうううっ！！　急にそんな強く、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長も鍛えたチンポで私を気持ちよくしてくれるって……んんっ、ふふ、嬉\nしい、こういうの、二人でしてるって実感が……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あっ、すごいっ！！　本気の隊長チンポすごいっ！！　私の\nオマンコ全部刺激されて、ごりゅごりゅされてるっ！！　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、チンポが暴れて、んっ、私の中をみっちり埋めつくして、ん\nっ、隊長のチンポがオマンコを占領してるっ、ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうっ、あんっ、チンポで蓋されたオマンコに、隊長のザーメン出すんだね\n、出したいんだね、いいよ、いっぱい出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長のチンポとザーメンで、私の身体全部埋めつくしてっ！！　私を君のも\nのだって、しるしをつけてっ！！　ふあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、膨らんできたっ！！　隊長チンポ膨らんできたっ！！　濃厚\nザーメン来るっ、また来るうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、私も、私もイくっ、隊長のチンポでオマンコイくっ！！　ぎゅって\n締めつけながらオマンコイっく！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、出してっ！！　ザーメン出してっ！！　チンポとザーメンでイ\nっくううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あくううううっ！！　あっ、んんっ、ふあああっ！！　中にいっぱい出てる\nっ！！　隊長の濃厚ザーメンの追加出てるうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、中が全部いっぱいになって、注がれて……んっ、ぐりぐりし\nながら出さなくても、全部受け止めるよ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふふっ、チンポストレッチでほぐれきったオマンコが隊長のザーメンを全部\n飲みこんでる……んんっ、出されるだけで気持ちいいなんて、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んっ、最後の一滴まで出たかい……ふふ、それならよかった。\n隊長のザーメン、少しでも零したくないからね……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、満足したかい、隊長。あはは、答えなくてもその顔を見たら\n分かるよ。私でいっぱい気持ちよくなってくれたのがね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「私も隊長のストレッチでたっぷり身体がほぐれたよ……それに身体だけじゃ\nない、心も満たされたよ。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「大好きな人と、隊長と一つになるって、こんなに満ち足りたものだったんだ\nね……これはちょっとくせになっちゃいそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「それにしても、出されたザーメンが温かい……お腹の中がたぷたぷになって\nるよ。隊長はザーメンの量も凄いね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「しかし……こんなにいっぱい出されたら、子供ができてしまいそうだな。嫌\nじゃないぞ。君との子供なら、私の宝物になるに決まってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「もし子供が生まれたら、きっと私たちに似て元気な子なんだろうね。ふふ、\nそのときは一緒に子育てよろしくね、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ああっ！？　なんで抜いて……あっ、チンポが私を向いて。んんっ、あああ\nああっ、ザーメンが身体中に……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「すごい、いっぱいのザーメンでべとべとに……ふあっ、あああっ、熱いっ、\nこれがザーメンの熱……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、すごい、お腹に貼りついて落ちない……濃厚すぎてゼリーみたい…\n…そんなに気持ちよかったのか、隊長、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、隊長の熱とぬるつきで、それだけで頭が溶けてしまいそうだ\n……匂いも……んんっ、好きっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「オマンコの中も、身体もザーメンをべっとり塗りつけられて……マーキング\nみたいだ……こんなことされなくても、私は隊長のものだけれど、ふあっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「射精を間近で見たのは初めてだけど、先っぽから勢いよく飛び出て、んっ、\nこんな風に中でも出されたんだな……んんっ、あっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「私の全部、隊長の色で染まりきってしまったね。ここまでされたら、女とし\nて嬉しさしかない……んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「髪も、鍛えた身体も、オマンコも、私はもう全部隊長のものだよ。他の誰に\nも触らせたりしない。私がこうするのは、隊長だけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ。こんな風にかけられるのも悪くないな……隊長の思いが形になったよ\nうで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「また……しようね、隊長。あなたとのストレッチなら、いつでも私はオーケ\nーだよ。もちろん、今からでも。あはは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}