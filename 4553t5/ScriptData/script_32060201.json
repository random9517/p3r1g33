		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「うぃー、お疲れっ。悪いな閉店まで待たせちまって。へへ……まぁ、最後は\nちょっとソワソワしながら掃除してたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00020602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「分かってるって……ほら、アレだろ？　制服プレイしたかったんだろ？　ま\nぁ、ここの制服可愛いもんな……ちょっと分かるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「じゃ……控室の方に……って、お、おいっ、ちょっ、ちょっと……ひぁっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00020602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「な、何だよ……えっ、こ、ここで……？　た、確かに誰もいないけど……ヤ\nバくないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020602_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、なっ……服から……乳首……いや、この、それはっ……期待し\nてってことじゃなくて……んっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あっ、指ぃ……はっ、んっ、なに……そんな、集中的に……同じとこばっか\nり……あくっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「乳首……あっ、はぁっ、くぅ……うぁっ、どんどん膨らんで来るっ！　ジン\nジン痺れてっ……き、気持ちよくなってるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、そんなっ……乳首だけでイクなんてっ、あぁっ、そんなこ\nとっ……ヤバいってぇっ、あっ、ギュッてされたらぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ひぁっ、ひゃひっ、イクっ……あっ、あぁぁぁぁっ……お、おっぱいイクッ\n……乳首でイッちゃうっ、くっ、んぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あっ……はぁっ、んっ、ふぅ……か、軽くイっちゃった……乳\n首だけでぇ……はぁ、んふぅ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あふっ……ア、アタシだけがイクのずるいって……な、何でさ……イカせた\nの、お前じゃんか……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ちょっと……あっ、オ、オチンポ……谷間に……んっ、くっ……中入れるな\nんて……聞いてなっ……うぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「や、ヤバいって……制服汚しちゃうしっ……た、確かにどうせ洗濯はするん\nだけど……そ、そういう問題じゃ……んぁうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ちょっ……今、おっぱい弄るのずるいっ……あっ、今……イッて……敏感に\nなってるのっ知ってる癖にぃ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あぁ……熱いの……ぐにゅぐにゅって……動かしてくる……はぁ……めちゃ\nくちゃ……オチンポ大きくなってるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……こ、こんなのでも……気持ち……いいわけ？　アタシ……何\nもしてない感じなんだけど……はぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「大きくて柔らかければそれでいいって……何か、それはそれでムカつくな…\n…もうちょっと言い方が……えっ、もう一つ……何？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁっ！　くっ、んふっ……か、感じやすいこと……あっ、うくっ……そ、\nそれは……んぅっ、ひ、否定……出来ない……あっ、ふ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「オチンポ……んんっ、すごい……おっぱいの中で……ビクビクしてるの分か\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ってか、これってさ……お互い様なんじゃないのか……？　お前のオチンポ\nだって……それだけ感じやすいってことで……ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……ふっ、き、気付くに決まってるだろっ……めちゃくちゃ熱く\nなってるし……んぁ……中……擦れてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、ずりゅずりゅっ……してるっ……あぅっ、オチンポ……おっぱ\nいの中で動いてるぅ……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「こんな服越しの窮屈なの……動きにくくないのかっ……？　何か無理矢理し\nてるみたいな感じで……はぐっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「それが、いいって……んぁっ……や、やっぱ変態じゃんか……あっ、ん……\nふっ、あ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「もしかして……客で来てる時も……ずっと、こんな風にオチンポ入れたいっ\nて……思ってたのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「そんなの……ヤバいだろ……はぁんっ、あっ、アタシだって……そこまでは\n……あっ、考えたことないのにっ……は、ひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「こ、興奮してるって……そ、それは……お前が、めちゃくちゃ……してくる\nから……はっ、ひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あぁっ、また、乳首っ……んんっ……クリクリしながらっ、あっ、オチンポ\nっ……！　もっと……深く入って……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「な……ち、違うし……オ、オマンコに入ってるわけじゃない……こ、ここは\nおっぱいで……違うからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ここも……オ、オマンコ……？　おっぱいマンコ……な、何言って……んぁ\nっ！　あっ、オチンポっ……また激しくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「マ、マジで……アタシのおっぱい……あっ、犯されてるっ……おっぱいマン\nコにされてるのっ……くぅんっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「何か……ヌルヌルして来てるしっ……あひっ、オチンポ……先走り……出ち\nゃってる……んっ、て、ことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、はぁっ、こ、このまま……出しちゃうつもり……？　制服の中\nに……直接……んぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「くぅっ……この変態っ……！　ああぅっ、けどっ……あっ、乳首……また気\n持ちよくなってっ……はっ、あひぁっ、アタシも……またっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁんっ、イ、イクのっ？　何でもいいっ……何でもいいからぁっ、あっ、\nイッてもっ……いいからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁんっ！　出て……来たっ……！　あっ、マジで……おっぱいの中\nっ……制服着たまま……出されてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　熱い……ふぁ……どんどん溢れて……あぁ……おっぱいの\n間……ドロドロにされてる……んくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はう……んっ……ふぁ……やっと、収まってきた……んっ\n、オチンポ……止まった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ふぁ……めちゃくちゃ出てるし……どんだけ興奮したら、こんなんなるんだ\nよ……もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「マジで……おっぱいマンコにされちゃったじゃんか……アタシの……んっ、\nヌルヌルだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……はぁ、はぁ……あの……オチンポ……抜かないの……？　こ\nれ……そのまんまなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「まだ……ムラムラしてる……えと……それってつまり……あっ、んぁっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「や、やっぱり……このまま続き……？　あっ、それは……確かに……アタシ\nも、んっ……おっぱい……その、ヘンな感じのままだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぅぁっ！　べ、別に……もっと乳首をして欲しいっていう意味じゃ……ひ\nゃっ……んっ、ふぅぅぅぅっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ち、乳首……服から浮き上がってるとか言うなって！　んくっ、あっ……精\n液……染み込んで……ヌルヌル、してるっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はっ、ヤバい……このやらしい匂い……嗅いでると……乳首、\nもっと硬くなって来ちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、音もすごい……にゅるにゅる……してる……んんっ、オチ\nンポ……挟んでるだけなのに……うぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁっ……めちゃくちゃ腰振ってるし……マジでアタシ……オ\nナホールみたいにされてんじゃん……これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……こんな、感じやすいオナホールなんてないって……う、う\nるさいなっ……だって……気持ちいいんだからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「こんなっ、おっぱい……揉みくちゃにされてっ……乳首……何度も弾かれて\nっ！　オチンポっ、擦れてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「気持ちいいに……決まってるっ……んぁぁっ、もっと……アタシのおっぱい\nマンコっ……感じさせてぇっ……ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ！　そこぉっ、その乳首ぃっ……！　あっ、コリコリされるの、\nすごくいいっ！　はうんっ、あぁっ、うぁっ、あぁぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ヤバいのっ……あっ、されてるっ、熱いっ……オチンポが……暴れてるのっ\n、すごっ、すぎぃっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、もっと触ってっ！　乳首ごとっ、グリグリ擦ってっ！　くぅんん\nっ、そぉっ、あっ、それぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んあぁっ、オチンポすごいっ……！　また……ヌルヌル出てきて……あぁっ\n、」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ……オチンポ……震えて来てるっ！　これっ……また出したく\nなって来てるってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……だったら……も、もう……分かってるよなっ？　またおっぱ\nいに出して……いいからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ていうかっ……！　アタシもイクからっ、もっと……おっぱいぐにぐにして\nっ、乳首……してっ、それでっ……一緒にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁっ、またイクッ……おっぱいイクからぁっ、はぁぁんっ、出してっ……\n！　熱いの掛けてっ、ビュクビュクしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁっ、イクッ……！　アタシのおっぱいっ、またっ……イクぅぅぅぅぅ\nぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203220" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「うぁぁぁぁっ！　また……出て来てるっ……！　おっぱいの中ぁっ……ザー\nメン、出されてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……んんっ、すご……どんどん溢れてる……制服……もうぐちゃぐ\nちゃなのに……まだ出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「もう、このまま出し切っちゃえ……おっぱいマンコの中……全部……精液で\nいっぱいに満たしちゃっていいからぁ……ん、はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んふっ、うぁぁ……熱い……谷間グチョグチョだ……でも\n……気持ちいい……おっぱいマンコ……すごくいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ……終わった……？　ちゃんと全部出し切った……？　もう、後からま\nだ出るって言ってもナシだかんな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はふ……うぅ……でも、おっぱいだけで２回もイカされるのは複雑な気分だ\n……パイズリも自分でしたって感じじゃないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「フン……また調子のいいこと言って。制服姿だったら誰でも発情したんだろ\n？　このスケベ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ……そんな、取ってつけたように……アタシのおっぱいが魅力的とか…\n…って、人が話してるのに、またオチンポを動かすなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「全く……油断も隙もありゃしない……もう魅力的だってのは分かったから…\n…！　そこは……まぁ、あ、ありがとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「けどっ、今度はアタシの方からパイズリしてっ！　もっともっと気持ちよく\nしてやるからっ、そこは……そのっ、覚悟しとけよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁんっ！　出てるっ……！　はぷっ……！　んっ、今度は……顔に…\n…いっぱいっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んふぅっ……あぁ……臭いの……いっぱい浴びてぇ……ちゅぷっ……んぱっ\n……まだ溢れて……れろっ、あぁ……濃い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「２発目なのに……こんなにドロっとしてて……ザーメン、元気良すぎだろ…\n…これ……んちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ヘンな味ぃ……こんなの、全然美味くないのに……れろ、何\nか……舐めちゃう……れろ、ぺろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あっ……止まった……射精……終わった……？　ホントだな？\n　後からまだ出すとかナシだかんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ……えと……お、お疲れ……っていうか、アタシ何にもしてないけど…\n…ただ、ひたすらおっぱいいじくり回されただけだった気が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「気がついたら夢中に……？　フン、後付けでなら、どんな風にでも言えるし\n。ていうか、アタシだってしてやりたかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「い、いや、ちがくて！　その、されっ放しだと不公平っていうか……別にご\n奉仕したいとか、そういう意味じゃないから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「うがーっ、ニヤニヤすんな！　今のは言葉のアヤだからな！　ヘンな勘違い\nはするなよなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「とにかくっ……！　次はアタシも本気で気持ちよくしてやるからっ、そのつ\nもりでいろよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}