{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0200" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「一行が次に向かったのは、ＥＤＯの本部前ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115440001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、ここは案内するまでもないと思いますけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「来たのは初めてだがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「あ、いや。本当に九重市にきたのは初めてなのだ。本部にはまだ顔を出して\nいない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう……なんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "さすがに嘘をつき続けるのも厳しくなってきたな……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "それに、ここは敵の本丸。案内してもらったのはいいが、中に入るのはや\nめておくべきだな", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せっかくだから、中も見ていきます？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「いや、それは今度でいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、これから毎日のように見ることになる職場の中を案内する必要はな\nいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115440002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それもそうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ほかに、いい場所はないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「困っているようだな、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その声は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ＥＤＯ本部の塀の前をみると、腕を組んで立っている人影が！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ベルガっと参上！　ベルガっと解決！　人呼んでさすらいの美女、ベルガマ\nスク！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわでた！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ベルガマスク……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440007" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちが困っているときに突然現れて、いろいろと助けてくれた人物……か\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、そのアドバイスにひっかきまわされたこともあったような……そっちの\n方が多かったような……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「第２部から登場したお方で、その素性は謎に包まれておりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115440003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「隊長が見慣れないご婦人の案内をしていると小耳にはさんでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440003" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、この人はトキノさんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ほう……。ご婦人、どうしたのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「いや、少々知人にそっくりだったのでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440008" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「そうかそうか。そういうご婦人も、私の知人にそっくりだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440005" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ふむ、お互いがお互いのそっくりさんを知っているとは、不思議なこともあ\nるものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440009" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「まったくだな、はっはっは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440006" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "おい、ジュンジロー。なんか寒気がしないか？", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「奇遇ですなご主人。わたくしも、会わせてはいけないふたりが出会ってし\nまったかのような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「嫌な予感を察知しております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115440005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい。ベルガマスク、いったいなんの用なんだ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「うむ！　助け舟を出してやろうと思ってな。この街を案内して欲しいのだろ\nう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「私は詳しいぞ。レンタルビデオ屋の場所や、この街で一番安いスーパーとか\nな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440008" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、そういうのを知ってどうするんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ガソリンが一番安く買えるスタンドなんかも知っていて損はないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440009" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かにそうかもしれないが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「まあいいではないか。私についてこい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「この街に来たなら絶対に見ておくべき観光スポットをひとつ知っているから\nな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか！？　そんな場所があるなら、俺も見に行きたいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいですか、トキノさん？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ああ、かまわんよ。どこへ案内してくれるのか興味がある。なあ、ベルガマ\nスクさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115440010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「呼び捨てでよいぞ、刻の……いや、トキノさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115440012" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだか空気がヒリヒリしているんだが……これはいったいどういうことだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とにかく、俺たちはベルガマスクに案内されてその場を移動した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ、女王様と一緒にいるのはなんとかマスクではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あいつ、城に攻め込んできたやつだよな？　そいつと一緒に、“女王様”は\nどこへ行くつもりなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もしかしたら、女王をなにかの罠にはめるつもりなのかもしれぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115440002" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こうしちゃいられない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115440002" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そこまでよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115440001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115440003" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まさか、本部の前にやってくるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115440001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なんじゃと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115440003" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「どうするエファナティカ様、このまま、こいつらぶっとばしちまうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115440004" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「バカなことを言うな。この状況では我らが不利であるのは自明」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115440004" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「また戦闘中に女王様を見失うやもしれん。ここは退くぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115440005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……まあ、そうだな。命拾いしたな、お前ら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115440005" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、逃げるつもりね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115440002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「追いかけましょう！　きっと、刻の女王のあとを追うはずよ。これで挟み撃\nちの形になるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115440002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そうね。いこう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115440003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}