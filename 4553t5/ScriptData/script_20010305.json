{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "市街を派手に巻き込む大立ち回りを演じた結果、見事に敵対勢力をすべて撃退\nし、意気揚々と帰還したトリプル・クラウンの３人。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "噂に違わぬ実力とトラブルメイカーっぷりを存分に知らしめた――その代償は\nあまりにも大きかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ううぅっ、頭痛いしー！　あのオバサン、本気で叩いたー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020053" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「よりにもよって、この私の頭を叩くなんて……この偉大な英知が台無しにな\nったら、世界的損失です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020045" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うぅ、痛いし、おやつ抜きだしー……がっくり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020029" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あまりにも大きすぎる騒動に、西欧魔女協会・マジックフォックスへの抗議も\n殺到。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結果、３人は魔女王直々に、その報いを受けさせられることとなったのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "無事に持ち帰った魔法石も、騒動を収めるための必要経費として組織に没収さ\nれてしまい、結局、成果も０となってしまう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そんなんだから、道化師って言われるって……あのオバサン、いつもひと言\n、ふた言多いんだから！」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "9", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020054" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そっちこそ、そんなんだから、いつまでもいき遅れになるんだしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020055" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ピコさん、今、あの人を刺激するようなことをあまり言わないでください。\nもう、お仕置きはこりごりです……うぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020046" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……私のおやつー……しょんぼり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020030" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あれだけの苦労が水の泡――だが、この程度のことでへこたれるような、トリ\nプル・クラウンではない。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「やっぱり、手に入れた後に研究しないと使えないお宝とか、面倒くさーい！\n　今度は、すぐパワーアップできるお宝にする！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020056" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「それは……さすがに非現実的すぎるお宝では？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020047" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……ピコ、なにか情報掴んでる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020031" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「当然よ！　今、悪と戦う特設部隊の隊員を募集してるって話、聞いたことあ\nるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020057" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「そこの部隊の隊長が、部下をチョー強くする力を持ってるって噂よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020058" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「それは……本当ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020048" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「パワーアップ……どうやってー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020032" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「それはわからないけど、調べてみる価値はあるでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020059" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「っていうか、しばらくあのオバサンの顔見たくないから、ちょっと離れたい\nしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020060" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「それは、私も同感です。それに、強い力を持つものが集まる組織……魔法的\nにとても興味深いですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020049" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んー、いろいろなところから人が集まってるなら、美味しいお菓子もいろい\nろありそー……いこー、いこー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020033" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "少しの失敗を引きずることもなく、常に前向きで突っ走る。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな前向きさが、トラブルメイカーである彼女たちがなんとなく許される一\n因なのかもしれない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「よーし、それじゃあ、その特設部隊でピコさまたちの力、思う存分見せつけ\nてやりましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020061" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「魔法でサイキョー、可愛さサイコー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020062" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「天才的なその実力！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020050" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「目指せ魔女王、王冠は私たちのものー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020034" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "『魔法の神髄、見せてやる！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020063" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "0", "LEFT", "-200" ]},
	{"command":[ "SETCHARA", "1", "char_00004101_01", "8", "CENTER", "0" ]},
	{"command":[ "SETCHARA", "2", "char_00004201_01", "8", "RIGHT", "200" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "『サイキョー、サイコー、トリプル・クラウン！　出撃！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020064" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こうしてお騒がせな道化師――否、王冠娘たちは、特設部隊へ入隊する運びと\nなったのだった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}