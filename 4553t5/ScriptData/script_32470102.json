{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「今日は塗装に向けて、車両を磨くと聞いていたんですが……まさか、カツマ\nさんが機械を操作してくれるだなんて思ってませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「操作はするけど、初めてやる作業だから少し不安……？　ふふっ。そんなに\n気負わなくて大丈夫ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「基本的に機械が全部やってくれるので、カツマさんは私の要望に合わせてボ\nタンを押したりするだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それに百聞は一見にしかずと言いますし、実際に見てもらうのが早いと思い\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「では、カツマさん。操作パネルにある、作業開始ボタンを押してみてくださ\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……！　こんな感じでアームが動いて、ブラシが車体の表面を\n削ってくれるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「洗車のブラシと違って力強くて……細かな部分にもしっかり当たるようにな\nってて……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ……？　変な声が出てる気がする……？　あっ、すみません……！　実\nはこれ、見た目以上に気持ちよくて……んぐっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「車体の表面を削るのでかなり勢いがありますし、敏感なところを的確に刺激\nしてくるので、どうしても声が抑えられないんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんもマッサージをされると、気持ちよくて声が出たりすると思いま\nすが……感覚的にはそれと似たよなものだと思っていただければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……！　でも、何ででしょうか……今日のブラシはいつも以上\nに感じて、いやらしい気持ちになっちゃう……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あっ……！　あの、カツマさん……少しブラシの回転速度を\n落としてもらえますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「次の塗装作業のためにしっかり磨く必要があるのは理解しているんですが…\n…少し振動が強いみたいで、凄く感じて……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ブラシの回転速度やアームの位置は、お手元のパネルで色々と調整できます\nので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、ダメですよっ！　そんな適当にボタンを押さないでください！　ちゃ\nんとマニュアルを見ながら操作して……あああぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「さっきよりもブラシの力が強まってますぅ！　回転速度が上がって、私の車\n体がズリズリ削られて……あはあぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ！　振動を弱めるボタンはそこじゃありませんっ！　そこ\nから少し右の……！　あっ、それも違っ……きゃあああぁぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「今度はアームが前後に動いて、車体全体を磨いてきてますぅ！　ああっ！　\nそこは特に敏感なところで……んっ、あっ！　だ、ダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「先端部分を行ったり来たりしながら、グリグリされて……！　ひっ、あっ！\n　あっ！　そんなに激しく撫でないでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やああぁ！　エッチな声が止まりませんっ！　出したくないのに、いやらし\nい声が出ちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んひっ、あっ、んっ、うぐっ！　だ、ダメっ……！　カツマさん、また勝手\nにボタンを押さないでっ……！　ひうううぅぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！？　さっきまで前後に激しく動いてたアームが、今度はゆ\nっくりした動きに代わってますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「バイブの強い振動が、ねっとりと私の車体表面を撫でまわしてきて……んっ\n、あっ……！　これ、さっきよりも感じますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、ぐっ、ああぁ！　そんなにゆっくり動かしながら車体を削られると…\n…！　ひっ、あああぁ！？　と、塗料の付きがよくなりすぎちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「塗料の付きをよくするための作業だから、問題ないんじゃないかって……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「確かにそうなんですけど、こんなゆっくりとした動きは想定外でして……！\n　あああっ！　ダメっ！　これ以上車体表面を削らないでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ！？　あひぃぃぃんっ！？　ダメって言ってるのに、今度は別\nのアームがフロントガラスの周りを磨いてきてますぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ガラス周りにブラシを当てるのは危険なんですっ！　強くゴシゴシされると\n、ガラスが割れる可能性が……あっ、ひぐっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あはぁぁぁんっ！？　気持ちいいのがずっと続いてて、もう\n身体の抑えが効かなくなってますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなのイッちゃうっ！　車体をブラシでゴシゴシされてるだけなのに、は\nしたない姿を晒しちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んひいぃぃぃ！？　アームがさらに動いて、仕上げに取り掛かるような動き\nをしてきてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　アームでグリグリするのダメですっ！　車体の先端をツンツ\nンしたり、小刻みにトントンしないでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「そんなに刺激されたら、本当にイッちゃいますからぁ！　んひっ、あぐっ、\nんんっ！　はぁ、あっ！　ぐっ、んくうぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イクッ！　イクぅ！　カツマさんの前でイッちゃうぅっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクッ！　あああぁぁぁんっ！　イックぅぅぅぅぅ～～～～～！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふああああぁぁぁ！？　気持ちよすぎて、私のフロントガラスにウォッシャ\nー液がびゅーびゅー飛び散ってますぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ……！　止めたいのに止まらなくて……！　ひあああぁ！？　ま\n、まだ出てるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やあああぁ！　カツマさん、見ないでくださいっ！　私がイキながらウォッ\nシャー液を噴き出してるとこ、見ないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　んんっ！　ダメっ……！　カツマさんのことを意識したら、また気\n持ちいいのが奥から来て……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「イッ、イクッ……！　イッてるのに、またイッちゃいますっ……！　んっ、\nあっ、あっ！　あああああぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はああぁ……やっとブラシが落ち着いてくれましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それにしても、車両を磨かれただけでイクなんて……普段はこんなこと絶対\nないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もしかして、カツマさんが操作してくれたからでしょうか……と、とりあえ\nず、車体を磨くのは終わりましたので、塗装の工程に移らないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ……？　まだ磨いてない部分があるみたいだから、続きをするって……\nそ、そんなはずありませんっ！　もう十分磨かれてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひうっ……！？　ま、またアームが動いてきてるっ……！？　まさか、本当\nにもう一度車体をブラシでゴシゴシされるんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、あああぁんっ！？　ブラシがさっきよりも速く回転して、車体\nをえぐってきてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「今度は台車の方にまでアームが伸びてきて……！　ひうっ、あぐっ、んんっ\n！　足回りの部分は弱いんですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんっ！　お願いですから、パネルを操作してアームの位置や回転速\n度を調整してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「このままだと、私のボディが削られすぎて……今の塗装すら剥げちゃいそう\nですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もし塗装が剥げたら、カツマさんに生まれたままの姿を見られちゃうっ！　\nそんなの、恥ずかしすぎますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　アームが少しずつ動いて、回転速度も弱まっていってる……\n！　よかった……わかってくれたんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ええ、そうです……今の塗装が剥げたら元も子もありませんので……！　で\nはこのまま、アームを止めて……んひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ……！　あっ……！？　な、何でっ……！？　どうしてまた、アームが\nフロントガラスの周りに押し付けられてるんですかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ……！？　機械を止めようとしたけど、磨き残しがあるみたいだから止\nまらないんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「なら、本当に綺麗に磨き終えるまで、ずっとこれが続くってことじゃ……！\n　そ、そんなの耐え切れませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んひっ！？　あっ、あうっ、あああぁんっ！　またブラシの回転速度とアー\nムの動きが強くなって、全身をゴシゴシされてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　ひぅ、んんっ！　あっ、ダメっ！　これ……気持ちよすぎて\n、またイッちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　またカツマさんの前ではしたない姿を見せることになっちゃ\nうっ！　そんなのダメなのに、イクの止められませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ！　お願いですから、何とかしてくださいっ！　このまま\nだと私……あっ！　イクッ……！　イッちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「車体の奥が震えてっ……！　もう限界ですっ！　あっ！　んっ、あっ！　イ\nクッ！　イクッ！　イクぅぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま","LABEL1","外して","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふああああぁんっ！？　イッてるのに、さらにアームとブラシが強く車体に\n押し付けれてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んふっ、あぐぅ！？　ウォッシャー液が止まりませんっ！　次から\n次に、びゅるびゅる溢れ出て……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなにされたら、本当に塗装が剥げちゃいますっ！　お願いですから、ブ\nラシを止めてくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐっ、んふっ！　あっ、んぐっ！　またイッ……イッちゃうっ……！\n　表面削られすぎて……イッ、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あふっ、ひっ、くうぅ……！　あっ！　イクッ！　イクッ！　イ\nクぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はああぁ……やっとブラシの勢いが弱まってきましたね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「アームも少しずつ離れていってくれてますし……ようやく、車体を磨く作業\nが終わったんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それでは、私はこのまま塗装に移りますので……これで失礼します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「……えっ？　塗装作業もカツマさんがお手伝いしていただけるんですか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「い、いえっ！　イヤなわけではありませんっ！　むしろ嬉しいのですが……\nまた変なことされたり、しないですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　急にアームが車体から外れて……！　あぶっ、んんっ！\n　な、なんですかこれぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「全身に冷たいお水がかかって……！　カツマさんの子種を注がれているみた\nいな感じがしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひっ、うぐっ、んんっ！　ああぁんっ！　気持ちいいですっ！　お水をびち\nゃびちゃ浴びせられるの、たまりませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「私の火照った身体がどんどん冷却されていってますぅ！　これ、すごく気持\nちいいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もっとかけてくださいっ！　私の車体に冷たいお水をどぴゅどぴゅ垂れ流し\nてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……たくさんお水をかけられたので、身体の火照りも\n随分と収まってきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ボディもツヤツヤになりましたので、これで心置きなく塗装作業ができます\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それにしても、どうして今日はこんなにもアームが激しく動いたんでしょう\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんの操作があったとはいえ、普段はこんなこと絶対に起きないのに\n……あっ、いえ。別にカツマさんを責めているわけでは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「と、とにかく、今日はありがとうございました！　また機会があったら、お\n手伝いよろしくお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}