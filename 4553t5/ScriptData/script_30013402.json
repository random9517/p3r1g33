		{"command":[ "SETTEXT", "「んぁっ、あっ、あぁっ……いっぱい突くから許せって……そ、そういうつも\nりじゃ……あひっ！　また、オチンポっ、暴れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はひっ、はひぁっ！　あぁっ、気持ちいいところっ、いっぱい当たるっ……\n！　奥にゴツゴツしたのが……擦れてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そこっ、あぁっ、弱いとこぉっ、あぉぉっ、もっと突いてっ……ズリズリし\nてっ、子宮口っ、ノックしながらかき回してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、おっぱいもぎゅってしてっ、全部……いっぺんにしてっ、\nあひぁっ！　また……イクっ！　オマンコイキたくなってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぅっ……はぁぁっ、お前もっ……なんだなっ？　あぁっ、もう少しだけ\n、このオチンポを感じていたいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ……はぁんっ、けどっ、疼きオマンコがもう限界だっ、あぁっ\n、イッてっ！　私もっ、あひぁっ、もうイクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「出してっ……またイッてっ！　濃すぎるオチンポザーメンっ、思いっきり…\n…ビュクビュク出してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404220" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぅぅぅぅぅぅんっ！　イグッ……おぉぉっ、イグぅ！　中出しされてっ…\n…オマンコッ……またイグぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、ふぁぁぁ……ずっと中に出続けてる……くぅぅぅん……濃いのが流し\n込まれて……はぁぁ……種付けされてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメだ……気持ちよすぎる……あぁぁ……オマンコ……震えて止まらない…\n…こんなの、最高過ぎる……はひぃぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ……深い所で……ザーメンがとぷんって……溜まっていく……オチン\nポの震えが伝わる……あぁ……種付け……感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっく……はぁ……んっ、あぁ……終わった……？　射精……今……止まっ\nたのか……まだ、分からない……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか……終わったんだな……あぁ……オチンポがよすぎて……何も分から\nなくなっていた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……隙間から精液が垂れて来る……ふぐっ……止まれ……あぁ……ダメ\nだ……止まらない……漏れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はふっ、んぁ……気にしないでいい……また、足りなくなったら注いでくれ\nる……本当だな？　甘えて……いいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……そうか、それなら……改めて甘えさせてもらうとしよう……はふ…\n…ありがとう……最高のセックスだった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「これからも、よろしく頼む……ヴァルキリーとしての私を……もっともっと\n犯してくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁぁぁんっ！　あぁっ……お尻に掛かって……熱いのっ……はひ\nぃっ、イグっ……あぉぉっ、イグゥっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404401" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁ……種付けされただけじゃなく……マーキングまでぇ……内側からも\n……外側からもザーメンに浸されてくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……気持ちいい……もっと掛けて……ネバネバのベトベト……ぶちまけ\nて……ザーメンまみれにさせてくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はふっ……あぁ……まだ掛かってる……まだびゅくって……本当にど\nれだけ出すつもりなんだ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、終わった……？　そうか……あぁ、ねとねとだ……お尻が生\n温かくて……妙な気分だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はふ……あぁ、たっぷり乱れてしまったな……かなり恥ずかしい所を見せて\nしまったが……まぁ、お前にならな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、当たり前だ……こんな所を見せるなんて、お前以外には絶対に御免だか\nらな。私にも、相応の羞恥心というか……慎みはある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それにしても、ヴァルキリーの感度……どうにも持て余してしまうが、お前\nがいれば、多少は安心できるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「何しろ、天性のスケベで、精力も絶倫と来ている。私の疼きを受け止められ\nるのはお前しかいない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3404409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000134_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、またきっと疼くだろうからな。これからも、たっぷりと私の身体を開\n発していってくれ……頼んだぞ？」", "NORMAL" ]},
