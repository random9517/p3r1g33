{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0077" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……ふふ。今夜は、とても良い夜です……。隊長様と一緒にお風呂……。私\nなんかに、こんな幸せなことがあってもいいんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あ、はい。私は河童ですが……冷たい川の水でなくても、お湯でも癒される\nことはできますよ。元から、頭のお皿もない、できそこないの河童ですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「一応……尻子玉は知っています。ただ……私の場合、人から尻子玉を抜くの\nではなくて……ええと……。……あっ、ちょ、ちょうど今、はじまりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「尻子玉を……定期的に、抜かなければいけないんです。んっ……そうしない\nと、お腹が苦しくなって……。あああ、も、もうだめです。お願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「今回は……隊長様に私の尻子玉を抜いていただいてもよろしい、ですか……\n？　は、はい……。お尻、お尻を向けさせていただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁ、はぁ、はぁ……。み、見えますか……？　私のお尻……\n。し、尻子玉……。アナルビーズじゃないか……ですか？　ええと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「なんですか、それ……？　人間の尻子玉はそういうお名前なんでしょうか…\n…。と、とにかく早く抜いてほしいです……。い、いいでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ……。そ、そうです。ゆっくり……優しく抜いてください……。はぁ、\nはぁっ……。何個か中に……お尻に入っていますから、少し……ずつ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私も力をゆるめて、協力しますので……。あ……っ、あ、あ、あ……！　じ\nょ、上手です……！　そ、そう……そのまま……あふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はぁううっ！　ふぁあっ……！　あんっ、ちゅぽんっ、て……あぁんっ！　\n１つ、ずつ……大切な、河童の尻子玉……抜けていきます……。っあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「隊長様の指で……少しずつ、抜いてもらえて……。っはぁああっ、き、気持\nちいいです……！　あっ！　イキそうです、あんっ！　イ、イクぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「は、はいっ……！　か、河童はぁっ……お尻が弱点なんで、す……ぅっ。特\nに、私みたいに……尻子玉をよく抜いている河童、は、お、お尻が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「開発されて、せ……性感帯になってしまっていて……はぁんんっ！　１つ玉\nを抜かれるたび、に……ああああっ！　イッてしまうんです、あぁイクぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、はしたなく達してしまってますっ……！　ごめんなさいっ、す\nみませんっ……！　お尻で感じるエロ河童でごめんなさいぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お、おまんこもぐちょぐちょに濡れてしまっていますよね……。あっ、い、\nいつもそうなんです、お尻に刺激が加わると……私、私……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　はしたなくてごめんなさいっ……！　イッてしまいますっ…\n…！　あっ、ぁっあっ！　隊長様の手、すごく優しくてぇ……はぁうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あ……♪　あ……っ、あと１つで全部抜けます、から……っ。それで終わり\nですから、お願いします……。って、あっ！？　な、何をなさって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ひぅうううううっ！　い、いきなり全部っ……尻子玉をお尻に戻すなんてっ\n……！　あふぅううっ、ど、どういうことですかっ、あっ、気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「気持ちいいですけど……もう一度抜いてください！　でないと……でないと\n私、尻子玉、入れたり出されたり……繰り返されたら、お、お尻、が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「バカになってしまいま、すぅうう……！　あ、あ、あ……っ。み、見てくだ\nさい……。腰がもうガクガクで、おまんこからおつゆが垂れて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ふぁうううっ！？　えっ！？　ど、どうしてぇええっ……！？　んぁあああ\nっ！　隊長様の大切なおちんぽがっ！？　えっ！？　私の中に……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっ……！　た、隊長様……っ！　私にわかりやすく、お、教えてください\nぃ……っ！　どうして尻子玉を戻して、お、おまんこにおちんぽを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ふぁぁあっ！　お、おまんこが濡れすぎていて、開いていて……物欲しそう\nだったから？　そ、それは……！　は、はい……そうです、そうですがっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お、お尻……お尻の尻子玉を抜いていただかないと……、っんぁああっ！　\nだ、だめ……！　おちんぽ動かさないでください、あっ、だめ、だめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「おちんぽでおまんこされながら……。あっ……？　も、もしかしてっ……こ\n、この状態で尻子玉を抜くおつもりですか！？　そ、それは危険ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お尻だけでも私、イッてしまうのに……！　あっ！　お、おまんこまでほじ\nられて、こんな素晴らしいおちんぽで突かれながら刺激されたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「じ、自分でもどうなってしまうかわからないんですうぅうっ！　お願いです\n、ど、どちらかだけにしてくださ……。っああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はぁんんんんっ♪　尻子玉ぁああ……ッ！　尻子玉抜けちゃいました、１つ\nすぽぉんって抜かれちゃいまひたぁあっ♪　あっ、イキます、イクっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「や、やぁああっ……♪　お尻でイッている最中に、おまんこ突き上げないで\nくださぁいいいっ！　おまんこでもイキます、イッちゃいます、イクぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お尻、おまんこ、お尻、おまんこぉおおお……っ！　も、もうどっちを気に\nしていいか……わ、わかりませんっ！　どっちでもイクっ、イクぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「前も後ろも、おっきいの入れたり抜いたり、入れたり抜いたりぃいいっ……\n！　あっ、あああっ！　両方気持ち良すぎておかしくなっちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あへぇっ♪　イクぅっ、ずっとイクぅっ！　イキますっ、尻子玉……抜かれ\nてぇっ！　おちんぽ奥に突っ込まれてぇっ、ずっとイッてますぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「おふぅうっ♪　ふぉおぉおっ♪　……あっ♪　隊長様……っ。隊長様のおち\nんぽも、なんだか様子がおかしくて……あっあっ、ふ、太いですっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ！　おちんぽが動くの、どんどん速くなってきてますっ…\n…！　出すんですか、汚れっ……精液おまんこに出すんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「し、尻子玉引っこ抜いちゃだめですうぅううううっ！！　ああああ、イキま\nすっ！　イキ狂ってしまいますぅううっ！　ひぁああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ふぁうぅうっ……！　た、隊長様ぁああ……っ！　隊長様の精液っ、おまん\nこの中にドクドク注がれていますっ……。熱い、熱いですぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ぽっかりあいたお尻の穴と……あああっ♪　反対に、精液とおちんぽでミチ\nミチに詰まったおまんこっ……！　あぁっ、もう目の前がチカチカして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「イキっぱなしで、麻痺してますっ……♪　あぁあああっ、んぁあああっ……\n！　あふっ、こ、こんなに、直接精液をいただくのがイイなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「す、すごい、れひゅ……っ♪　じゅわじゅわぁって熱い精液が……！　隊長\n様の汚れが、私のおまんこの粘膜に染みこんでいきます……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「それに、それにぃ……！　中に射精されている私の姿、尻子玉を抜かれて間\n抜けに開いたお尻の穴、ぜんぶ、ぜんぶ隊長様に見られて……イクぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「わ、私ぃ、エロ河童です、お皿もないくせにエロいところだけっ……！　ん\nぁあああっ……！　ごめんなさい、エロでごめんなさいぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ひぅっ、あうっ、あぁあああ……！　……っぅ……♪　ううぅうう～～っ♪\n　……はぁあ、はぁあっ……♪　精液……精液、出し終わり……ましたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「わ、私ぃいい……もう、動けないです……！　射精の衝撃と、尻子玉を一気\nに抜かれた驚きとで……。も、もう、放心状態で……、はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「こんなにすごい経験……っ。他の河童だってしたことないって思います……\n。どうしましょう、ヘンなイキ癖がついてしまったら……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……うぁっ、うああああっ！？　ま、またっ……尻子玉をお尻に戻すなんて\n……！　む、無理です、もう無理です、確かに気持ち良かったですがっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて逆にもう無理なんです……！　あひぃっ、奥に、奥にまで尻\n子玉……ねじこまれて……！　お尻の穴がヒクヒクしちゃってぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「そ、そんな状態でまた……！　おちんぽでおまんこを掻き回されたら……あ\nっ！　んんんっ、だ、だめぇ……だめです、はぁんっ、あんっ、あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「せ、精液ぃ……♪　隊長様のこってりした精液が、おまんこの中で……ぐち\nゅぐちゅ音をたてて……！　わ、私の愛液もそれに混じって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「す、すごく卑猥な水音がしてます……っ。ううっ、げ、下品ないやらしい音\n……！　その上、尻子玉を抜かれたら……はぁうううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「今ぶぼって、あっ、お尻の中の空気が鳴って……！　あっ！　き、聞かない\nでくださいぃい……っ！　隊長様、私恥ずかしいです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……ひぅうっ！　は、恥ずかしい音を聞いて、恥ずかしがる私を見て……ど\nうしておちんぽを硬くしていらっしゃるんですかぁっ、あっ、だめですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お尻っ、おまんこぉおおっ！　何度も刺激して、……んっんっ！　熱いおち\nんぽで私のおまんこの中っ、串刺しにして、貫いて……突き上げてっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「それと一緒に尻子玉……！　あっあっ！　つぷつぷ入れて、ぬるぅって引き\n抜いて……！　あっ……ああうっ、こんな快感知りませんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁんっ……あああっ♪　いつもお世話をするだけの私、が……\n！　こんな風に気持ちよくしてもらえるなんてっ、嬉しいですぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「もっと……もっとしてください、隊長様の手で、おちんぽで私のお尻の穴を\n！　おまんこをイカせてくださぁいいっ！　はぁっ、ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっ、んぅううっ♪　んぁああっ……ふぁあああっ……♪　だんだん、お尻\nの穴……っ！　スムーズに尻子玉が、出入りするようになってきて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　ずるんって抜けるの気持ちいいっ♪　お尻に気を取られてっ\n……油断した瞬間、おちんぽで突かれるのも気持ちいいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっぁっ、イクぅうっ！　イクッ、イクぅううっ……！　隊長様ぁああっ…\n…！　もっと、もっとイカせてくださぁいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私のこと、めちゃくちゃにしていいですからっ……！　っあああああ……っ\n♪　もうだめ、だめ、だめぇ……！　イクっ、イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「隊長様、隊長様の精液で私をイカせてください！　お願いします、もう一度\n熱い精液を……っ！　粘膜に感じながらイキたいです！　っふぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁああああっ♪　あ、ありがとうございますっ……ありがとうござ\nいますぅううっ！　精液……精液が奥に流れこんでくるぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_24" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あひぃいっ！　おまんこが疼いてる、精液もらって喜んで……！　うねって\nる、うごめいて……おちんぽの射精を助けてるっ……♪　はぁっ、あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「大丈夫です、もっと入ります……っ♪　おまんこにもっと精液入りますから\n、入れてっ……注入してください……！　あっ♪　あっ、すごいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「隊長様のおちんぽっ、びっくんびっくん脈打って……！　精液を何度も撃ち\nだしてくれてます……！　あっ♪　あぁ、こんなに感じている時に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「おまんこの中に大量に汚れっ……♪　精液を流しこまれたら……子、お子が\nできちゃいます……！　隊長様のお子が……っ♪　でもいいんですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「それでもいいからっ……！　私の中に出してくださいっ……♪　あふぅうっ\n♪　出てます……！　ずっと出てて……イキますうぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……あああ……。はしたなく、喘いで、乱れてしまって申し訳ありませんで\nした……。わ、私みたいな地味な河童が……出すぎたまねを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私は、お客様や隊長様に……ご奉仕するのが大好きですが……。ここまでの\n快楽を相手に与えられる、隊長様には遠く及ばないことを知りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「一体どうしたら、そんなに上手に……相手を喜ばせることができるんですか\n？　教えてください、私なんてまだまだです……。……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「特に何も考えていない……？　なるほど。達人はその域に達しているのです\nね。これからも、隊長様のそばにいて、そのご奉仕力を学んでいかないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あ、うぅううっ……♪　くぅううっ……♪　た、隊長様ぁ……♪　精液……\n外に出てしまってます……っ、あっ、ね、粘膜じゃなく身体に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_27" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　で、でも……これもいいです、すごく感じます……！　隊長様\nの精液を浴びて、……あぁっ、隊長様に全身を支配されている気分でっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「もっと、もっとかけてください……！　身体にも、お尻にも、おまんこにも\n……私のすべてに隊長様の精液をください、あっ……熱い、もっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「このヌルヌル……っ、お風呂場でならいくら出しても大丈夫です、だから…\n…かけてぇ……！　あっ……あっ、すごい臭い……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_26" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「これが隊長様の臭い……♪　私なんかに興奮して、こんなにたくさん出して\nくれたんですね……っ♪　だから大好きなんです、ずっと……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「大好きな隊長様の精液……♪　汚れだなんて思いません、私の隊長様の、大\n事な精液に包まれて……あっ、あっ、気持ち良くて幸せです……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「……あ、あの……っ。あの、さ、最後にヘンなこと……。告白みたいなこと\n、言ってしまって……その。め、迷惑をかけてしまいましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027301_02_25" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「私にお皿がないこと、し、尻子玉のこと……。他の人には見せられない卑猥\nな姿も全部見せてしまって……。隊長様といると、私、おかしくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「で、でも、そんな自分がいやじゃないっていうか……。えっと……えっと。\n変わっていく自分、新しい自分を……もっと知りたいんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ですから……もし、良かったら……そばに置いていてもらえませんか？　絶\n対に邪魔なんてしません！　静かにするので……お願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}