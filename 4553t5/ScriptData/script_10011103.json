{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0001" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ダイヤナ！　大丈夫！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫～！　でも、あのロボットちゃんたち強過ぎよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「だがしかし、ここで倒さなければ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだね……なんとかして奴らを止めないと、この先には民間人の居住区が\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……！　でも、俺たちで止められるのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「長官！　冴島長官！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「陛下！？　なんでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「こんなときじゃが――いや、こんな時じゃからこそ、頼みがある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「頼み、といいますと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「カツマやルナはがんばってくれとるがの、この調子では、地上の居住区はと\nうてい守り切れん。正直、地下も危ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待ってください母上様！　我らは必ず――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「お前たちの力を疑っとるわけじゃない。だが、戦力差はいかんともしがたい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………くっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぬしの意気込みはわかる。だが、危険はおかせん。非戦闘員を避難させる\nことにする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様、残念ですが……民の安全を考えれば、それが一番です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、わかっている。母上様の判断は正しいと思う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「すまんの、ルナ。わかってくれ。さて、長官。話を戻すが、頼みというのは\n他でもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はい。なんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「グレート・ルナリアムの避難民を、地球で受け入れてくれんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「地球で！？　グレート・ルナリアムの住民全員をですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「幸か不幸か、避難しなければならぬ人数はそう多くはない。せいぜい数万人\nじゃ。余をはじめ戦えるものは、月に留まりギリギリまで戦う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「最悪、その者たちも逃がす必要はあろうが――いや、そのことは後でいい。\n『出る前に負けること考えるバカいるかよ』と、ある偉大な戦士も言うておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「頼む、長官！　数万人がダメなら千人、百人、いや、ひとりだってかまわん\n。どうか、避難民を受け入れてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050010" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……わかりました。命の重さに、地球人もルナリアンも変わりはありません\n！　非戦闘員、全員の脱出準備を！　ひとり残らず、地球にお迎えします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「すまぬ……！　長官！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050011" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかし陛下！　数万人の避難民を、ゲートで地球に送るのですか？　ゲート\nでは一度に数人しか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「エファよ、忘れたか？　こんなときのために、脱出船が用意してあるのを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050012" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「脱出船……！？　脱出船団を、発進させるのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ですが……陛下が残られるのであれば、誰が船団の指揮を？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010111050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「長官、すまんが指揮を頼む。宇宙船に詳しい者を補佐につける。どうか、避\n難民を地球に届けてやってくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050013" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お任せください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010111050008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「カツマ！　そちたちはロボットたちを脱出船に近づけぬよう、なんとしても\n発進基地を守り抜くのじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050014" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「脱出船を守れ……か。へへへ、めずらしく、やりがいのありそうな仕事じゃ\nねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「承知いたしました、女王陛下！　ロボットどもは、ここから先へは一歩も通\nしません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ！　よく言ったぞカツマ！　それでこそ我が下僕！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010111050005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「お？　なんじゃおぬしら？　いつになく気合が入っとるのお？　その分なら\n、すべてがうまく行きそうじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050015" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ！　我々にお任せを！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ！　よろしく頼むぞ！　それでは、いったん通信を終わる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010111050016" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「カツマさん！　めずらしくカッコよかったよ！　隊長っぽかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へへへっ！　サインはあとだぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　やろう！　私、がんばる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あんなロボット。粗大ごみにしてやろうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010111050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ、大丈夫。この次元は、あの次元とは違う。あんなことは、もう起き\nない。起きるはずがない……起こさせない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「え？　な、なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111050005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ドラグソードは呼べるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「そうか！　ロボットにはロボットをぶつけるんだね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、呼べる。しかし召喚に少しは時間がかかる。その間、あいつらを食い\n止めてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111050006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかった！　それじゃあみんな、配置に就け！　ロボットはここで食い止め\nるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「了解！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010111050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}