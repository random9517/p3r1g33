{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「来たわよ、隊長くん。お姉さんにシて欲しいことがあるんでしょう？　ふふ\n、遠慮しないで言っちゃいなさい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00007501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ふぅん、お姉さんにご奉仕してほしいんだ～……。それが、パワーアップに\n繋がるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00007501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「なるほどね……。ちょっと信じられないけど、隊長くんの頼みだったら仕方\nがないかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00007501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ふふ……隊長くんったら、自分で頼んでおいて緊張しちゃっているの？　そ\nの割には、おち○ぽおっきくなっちゃってるわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00007501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「すっごい……おち○ぽをビンビンにしちゃって……。ふふ、すっごく男の子\nの匂い……くんくん……くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「こんなに立派なおち○ぽ、見ていたらお姉さんドキドキしてきちゃった。こ\nれ、お口に入るかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅっ、ぴちゅ……。まずはたっぷり、おち○ぽに、ちゅっ、ちゅ\n……っ、んっ、んちゅ、ちゅ……う……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んふふ、ビンビンおち○ぽがびくびくしちゃってるわ。隊長くんってばかわ\nいいんだから……ん……ちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああ、とっても興奮しちゃう……その反応、素敵よ……ちゅっ、ちゅぱっ。\nん……ちゅぷっ、ちゅるる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「男の子の匂いと……味……。ンッ、ちゅぶっ、とっても、濃い……おち○ぽ\n……。んふふ……素敵……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「なあに……？　そろそろ、咥えてほしいの……？　この勃起おち○ぽを、お\n姉さんに咥えてほしいんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「キスしたり、舐めたりだけじゃ物足りないのね。わかったわ、隊長くんのお\n願いなら、聞いてあ、げ、る♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んぁ……はぁ……も。ん、ん……んぢゅ……。隊長くん……お口に……入っ\nちゃったわよぉ……ん、んふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「口の中……ンッ、隊長くんのあつあつおち○ぽでいっぱい……んっ、んじゅ\nる……じゅぶ、じゅぶ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ、とっても……かったぁい……。んっ、じゅるっ、じゅるる……それ\nに、おいしいわ……んふぅ、じゅちゅっ、ちゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「口の中……んじゅるっ、じゅるる……どんどん……よだれが溢れてきちゃう\nわ……じゅちゅちゅぅっ！　んっ、んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くんのおち○ぽ、んじゅるっ、よだれまみれ……んぢゅるるっ！　じゅ\nぶつ、じゅぶっ、じゅちゅちゅちゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「口の、中で……ンッ！　舌も、いっぱい……動かしちゃう……。んふぅ、ど\nうかしら……？　じゅろろっ、じゅりゅりゅりゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ！　おち○ぽが膨らんでるわね……。お姉さんのお口で、いっぱい気\n持ちよくなっちゃってるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ぢゅちゅちゅっ！　んっ、んっ！　お姉さんのお口、もっともっと感じて…\n…んちゅちゅぅっ！　ほら……んじゅるっ、じゅぶっ、じゅぶぅつ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「おち○ぽ……じゅるっ、ちょっぴり苦いお汁がでてきているわね……じゅぶ\nっ、じゅぶぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くんのおち○ぽが気持ちよくなってるって知ったら、お姉さんますます\n興奮しちゃうわ……んふぅ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「もっと……？　んふ、もっと吸って欲しいのね……？　おち○ぽに、吸い付\nいて欲しいのね……？　ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、じゅるる……っ！　こう……？　んんっ、じゅぶっ、じゅぶ\nっ、じゅぶ……じゅるるるるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「唇……んじゅるっ！　ぴったり、おち○ぽに、くっつけて……じゅるるっ、\nじゅるるるぅ……っ！　ぢゅぶっ、ぢゅぶっ、ぢゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「口の中で、舌もうごかして、ぢゅりゅりゅぅっ！　んんぅっ！　お口の中で\n、おち○ぽ暴れさせちゃだめよお……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「じゅぶっ！　じゅぶっ！　じゅるるるるぅ……っ！　もう、射精しそうなの\n……？　んぶっ、んっ、んんん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「そんな、隊長くんまで……腰を動かしたら……っ！　んぐっ、奥に……おち\n○ぽ喉の奥に……届いちゃう……つ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、んつ、んぐぅううっ！　んぶっ、んぶっ、んぢゅぢゅぢゅぅううっ！\n　んぶぅっ、んんっ、んぶぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103129" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「むぐぐっ！　むぶぅうっ！　んっ、んっ、んんぅ……っ！　ぶぢゅるっ！　\nぶぢゅりゅりゅりゅぅうううぅつ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んぐううううっ！　んっ、んっ、んふぅううう……っ！　隊長くんの……口\nに……いっぱい流れ込んできているわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んくぅ……っ！　これ……飲み干させるつもりなのね……んふ\nぅ……いいわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んくっ、んく……濃い……ドロドロ精液……。ネバネバして、なかなか……\n飲み込めないわ……んっ、んぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「こんなにネバネバして……息ができなくなっちゃいそうだったわよ、隊長く\nん。でも、とっても美味しかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「こんなに精液をだしちゃったってことは、お姉さんのお口はとっても気持ち\nよかったのね。うふふ、嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「だけど、これで本当にパワーアップできるのか疑問ね。隊長くん、お姉さん\nをだましてなーい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ふーん、一度だけじゃ効果は薄いのね……。だったら、もっともっと隊長く\nんとエッチなことをしないといけないのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くんのおち○ぽも、まだまだ勃起しているままだものね、もっと射精し\nたいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「お姉さんのお口でよければ、もっともっとシてあげてもいいわよ。うふふ、\n最近ご無沙汰だったからね、こういうコト」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ほら、はやくしましょう？　こういうのはスピード感が大事なんだからね♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああ、本当に立派なおち○ぽね……。全然萎えていないじゃないの……。あ\nんなに射精したのに、たくましいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ふふ、一度で打ち止めにならないおち○ぽは好きよ……。んっ、ちゅぶ……\nちゅぅ……ちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「また、ビクビクって……んちゅぶっ！　射精したあとのおち○ぽだから、敏\n感になっちゃってるのね……んちゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああ……おち○ぽの中に、まだまだ精液が残っているわね……ん……じゅる\nる……じゅるるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「尿道の中の精液を啜られるの……どう……？　んふふ、腰がビクンビクンし\nちゃうくらい気持ちいいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、ちゅぶぅ……。んっ、んっ、んふぅ……じゅるる……ん、ん……\nちゅば……ちゅるっ、ぢゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「また……腰が動いてるわね……んっ、ちゅっ、ちゅぶ……。え……？　私の\nお尻も、動いてる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「おち○ぽ咥えながら、嬉しそうにしてる……？　あんっ、やだ……恥ずかし\nいこと言わないでよ……んちゅっ、隊長くんったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「だって……ねぇ……。んちゅっ、ちゅぶ……。隊長くんのおち○ぽ、おいし\nいんだもの……んふっ、ちゅるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「お姉さん、んちゅっ、我慢できなくなっちゃってる……。ちゅぶっ、ちゅる\nる……んふぅ……ぢゅぶっ、ぢゅぶ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「おち○ぽしゃぶりながら、ンッ、興奮して……発情して……。じゅぶ、じゅ\nぶ、おま○こも濡らしちゃってるのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「そうよ……隊長くんのおち○ぽおいしいの……精液も、おいしいの……。ん\nじゅるっ、じゅぶっ、じゅぶ……んふふぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
