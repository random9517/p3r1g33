{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へん！　お前らがあたしにケンカふっかけるなんざ、十億光年早ぇんだよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「ち、ちっきしょぉ～！　覚えてやがれー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ｂ" ]},
		{"command":[ "SETTEXT", "「光年は時間の単位じゃねえぞバカヤローッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ははははは！　おとといきやがれってんだよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109070002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＣ" ]},
		{"command":[ "SETTEXT", "「でもアネキ。奴らの言うことにも一理ありますよ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……どういうことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109070003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＣ" ]},
		{"command":[ "SETTEXT", "「『光年』は時間じゃなく距離の単位ですから」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いま気にすることか？　それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109070004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「おたくの女幹部さんが……しかも、一人は首領であるあなたの娘さん。それ\nがうちの組を裏切った女に加担している……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「これはいったいどういうことで？　納得のいくよう、ご説明を願いたいんで\nすがねぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どういう、と言われてものう？　長官、どう思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こちらに振るんですか！？　そう言われましてもねえ……隊長はどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　俺に振られたってわかりませんよ！　おいジュンジロー！　おま\nえが答えろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あんたらなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあまあお七。そう熱くなるな、血圧が上がるぞ。とにかく、そもそもの問\n題は懇親会の会場についてじゃろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「わかってるんなら、どうにかしてくださいな。このままじゃ、九姉妹（ナイ\nンシスターズ）全部を巻き込んでの戦争、なんてことにも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「だから、そうカッカするな。あれじゃろ？　もう一回投票をやって、今度こ\nそ恨みっこなしで決めればいいだけの話じゃろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そう言われましてもねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そこはほれ、おぬしのやり方次第じゃないかのう？　聞いとるぞー？　他の\n組織の店がどうなっとるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「へぇ……？　どうなってるんですかねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070006" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「競争が激しくなりすぎて、次々と会場争いから手を引いとるそうじゃないか\n？　いまでも元気にやっとるのはおぬしんとこだけ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「いや、おぬしんとこと、値引き競争に乗らなかった正義（まさよし）だけら\nしいのう？　だからおぬし、そんなに焦っとるんじゃないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「おやおや、ずいぶんお詳しいことで。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「宮殿じゃ毎日ヒマこいとるからの～。芸能人のスキャンダル感覚で追っかけ\nとるんじゃよ。ま、ともかくじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「しばらくしたら、もう一度会議を開いて再投票してみたらどうかの？　おぬ\nしも、それをにらんで動いとるわけじゃろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「まあ、そんなところですかね。で？　もし再投票をやるとしたら、陛下もこ\nちらに味方してくださるんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、それも考えとったんじゃがの？　うちは、若い連中の自主性ってやつを\n重んじておるでのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070009" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「相変わらず、態度は保留ということですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070009" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「投票までには決めとくぞ？　ウチの連中に、いろいろと意見を聞いた上での\nう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070010" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「おやおや……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070010" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そのほうがいろいろと面白そうじゃしのう？　お互いに。のう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109070011" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ、まったくですねぇ。ふふふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070011" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「挑発ともとれるルナルバースの言葉を受け、お七はさっそく行動を開始する\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109070001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0097" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うおおおおおお～っ！？　いいのか！？　これ、ホントに全部食っちゃって\nいいのかぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ、ええ。もちろんですとも。遠慮なくどうぞ、おかわりも用意してござ\nいますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070012" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いただきまぁ～～～っす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0039" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うっそぉ～！　これ、全部ダイヤナちゃんがもらっちゃっていいのぉ～！？\n　このバッグにこのアクセにこの靴っ！　ぜーんぶ欲しかったのぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ、ええ、ご遠慮なく。Ω（オメガ）組からのプレゼントですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070013" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そのかわり、と言ってはなんですがねえ？　懇親会会場の件では、どうかう\nちの組織の鳥Ω（オメガ）をよろしく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「懇親会の会場は、ふたつもいりませんのでねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109070015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「こうして、Ω（オメガ）組は食欲と物欲に弱い二人の幹部を手中に収めた。\nそして、欲の皮の突っ張った幹部と言えばもう一人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109070002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0029" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よしよし……オレんとこにもお七からのメールが来たな。それじゃ、さっそ\nくご馳走になりに行きますかぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ、ご主人。恥ずかしくはないのですかな？　このような見え見えの\n買収に乗せられるとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ！　買収だろうと来週だろうと関係あるかぁ！　高級焼肉だぞ、高\n級焼肉！　そんなの、もう何年食ってねえと思ってんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「我がご主人ながら、本当に情けなくなりますな。ですが、どうしてもとおっ\nしゃるのなら仕方ありませんな。ワタクシもお供を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010109070002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ペット同伴で焼肉屋に入れるわきゃねえだろアホ犬！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「カツマ様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030109070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000807_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お。ダイヤナんとこのピースムーンじゃねえか。迎えに来てくれたのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「いえ。大変申し訳ありませんが……カツマ様は病院送りにしろと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040109070001" ]},
		{"command":[ "SETCHARA", "1", "char_00000805_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんじゃそりゃあああああっ！　焼肉っ！　焼肉どうなってんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「焼肉は、ダイヤナ様とセレーナ様、そして我らがおいしくいただくことにな\nっております！　では、お覚悟っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050109070001" ]},
		{"command":[ "SETCHARA", "2", "char_00000809_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひでぇええええええええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}