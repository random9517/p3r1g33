{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「今日はエンジンオイルを交換してくれるのね。うふふっ。カツマちゃんの手\nでオイルを注いでもらえるなんて嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「古いオイルはもう抜いてあるから、いつでも新しいのを注いでくれていいわ\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「それにドレンワッシャも新品に交換してるから、カツマちゃんはオイルを注\nぐことに集中してね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、そうそう。オイルを注ぐ前に必ず取扱説明書やメンテナンスノートを\n見て、エンジンオイルの規定量を確認してね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「それくらい知ってる？　うふふっ。さすがはカツマちゃんね。それじゃあ、\nフィラーキャップを開けて、オイルを注いでいって頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　オイルジョウゴを使わずに、オイルジョッキを使うだ\nなんて……！　オイル交換に慣れてるって感じがするわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「念のために聞いておくけど……私以外の車に、オイルを注いだりしてないわ\nよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「どうしてそんなこと聞くのかって……！　だ、だって……！　カツマちゃん\nの愛車は私だけだからっ……あっ、あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「私以外の車のメンテナンスをしてるところを想像するだけで、嫉妬してエン\nジンに火が付いちゃいそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　急にオイルが激しく流れ込んできて……！　あんんっ\n……！　そんな……いきなりドプドプ注ぎ込むなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……んふっ……！　えっ……？　今は他の車の話より、オイル交\n換に集中したい……？　ああっ、嬉しいわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「わかったわ……私もオイル交換に集中するから、もっといっぱいエンジンオ\nイル注いで頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、ひうっ……！　ジョッキがさらに奥まで入ってくるぅ……！\n　プラスチックの感覚が、穴いっぱいに広がってるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、くうぅ……！　エンジンにオイルが溜まって行くの感じるっ…\n…！　はあぁ……ボディが少しずつ重たくなって……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんは……重たい私は嫌いだったりする……？　もっと軽い車体の\n方が好みとか……そういうの、あるかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……どんな重量でも気にしないでいてくれるのね……ありのままの\n私を愛してくれるなんて、すごく嬉しいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ！　ひっ、あぐっ……！　な、なにっ……！？　いきなりジョッキをグ\nリグリ回し出して……んんっ！　あっ、あぐうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「なにかに引っかかってるみたいな感じがするから、少し我慢してって……！\n　やっ、あっ！　そ、そんなっ……ひぐっ、あはぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「中にジョッキ入れられたままグリグリされて……が、我慢しろだなんて……\n！　んんっ！　あっ、あっ！　ひああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああっ！　先端のカタいのが暴れてるぅ！　オイルパンの中、ガンガン突\nかれてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「やっ、ひっ、んぐうぅ！　そんなに激しくされたら……！　お、オイルパン\nが削れちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！？　今度は前後にズポズポするなんてっ……！　そんな、激し\nく出し入れしちゃダメっ……！　あっ、あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　カツマちゃんのジョッキ、感じちゃうっ！　この太くてカタい\nの、ボディが覚えちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　んっ、あぐっ、ひうぅ！？　お、お願い……！　もっと\nゆっくり……んっ、くううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……オイルは急いで注いだりしないで……そうやって、優しくっ\n……ああっ！　浅いところも感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「さっきまで奥をガンガン叩かれてたせいで……ボディがビンカンになって…\n…くっ、ああっ！　ひっ、うぐっ、あううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ！　カツマちゃんの手が小刻みに震えてるせいで、ジョッ\nキも震えて……んふううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「お、オイルのせいで重たいのはわかるけど、そんなにジョッキをブルブルさ\nせないでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「片手でジョッキを持つのがつらいなら、両手で持って……！　ひっ、あああ\nぁ！？　ま、また奥までカタいのが入ってくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　オイルパンに並々オイルが注がれてるっ！　私の規定量、超え\nてきてるからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ダメっ！　このままじゃ溢れちゃうっ！　エンジンオイルが注ぎ口から漏れ\n出て、エンジンがベトベトになっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　ダメっ！　ダメぇ！　それ以上注がないでっ！　もうオイルパ\nンいっぱいだからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、ぐっ、あはああぁんっ！　注ぎながら、ジョッキ出し入れしないで\nぇ！　そんなにされたら、私イッちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　もう我慢できないわっ！　エンジンオイルが溢れてきて……！\n　あっ、あっ……！　イクッ……イクぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んはあああぁ！　イックうううううぅぅぅぅぅ～～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　エンジンオイル溢れてるぅ！　私の注ぎ口から、どぴゅ\nどぴゅ出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んんっ！　あっ、ダメっ！　オイル漏れてるのに、ジョッキを奥に\n入れながらグリグリしたら……！　んひいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　せっかく注いでもらったオイルが、どんどん溢れ出ちゃうぅ！\n　奥に溜まってるのまで、全部漏れちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「せっかく新しいの注いでもらったのに、タンクが空になるぅ！　あっ、やあ\nあぁ！　ダメっ！　ダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんなの、またイッちゃうっ！　オイル漏らしながら、イクうううううぅぅ\nぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104140" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……！　ああぁ……エンジンオイルでボディがベタベ\nタだわ……んっ、くうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「エンジンを汚してごめん……？　そ、そんな！　謝らないで頂戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「確かに、規定量を超えてもオイルを注ぎ続けたことは問題だけど……私もカ\nツマちゃんのジョッキで感じすぎて、自制ができなかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……それに、まだジョッキは中に入ったままだし……オイルもまだ残っ\nてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ねぇ、カツマちゃん……空になった私のオイルタンクに、もう１回オイルを\n注いでもらえる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、んくうぅ……！　あっ、あっ……！　またさっきみたいに、オイルが\nドクドク注がれて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふっ、あぐっ……！　今度はゆっくりした動きで……！　ああぁ！　\nジョッキが入口に擦れるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「さっきみたいに乱暴に注がれるのもいいけど……こうやって優しくされると\n……！　んんっ！　また違った感じ方がっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ひっ、んふっ……！　くっ、んぐぅ……！　あああぁ……！\n　いいわよ、カツマちゃん……そのまま、ジョッキをもっと奥まで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひっ、あっ……うぐっ……！？　おっ、奥にあたるぅ……！　オイルパンの\n底にまで、ジョッキが届いてるみたいな感じがして……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひあああぁ！？　だ、ダメよっ！　この状態でジョッキをグリグリされたら\n……んんっ！　くっ、あっ、あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あっ、あはぁ……！　カツマちゃんのジョッキで奥の奥まで\n愛されて……！　たくさんオイル注がれてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんな幸せ……今まで感じたことがないわっ……！　乗車してもらうのもい\nいけど、メンテナンスもとっても素敵よっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「くっ、んふっ、ああぁ！　これ、本当にエンジンに火が付いちゃいそうっ…\n…！　気持ちよくて、回路が暴走しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うぐっ、んんっ！　あっ、あひっ！？　勝手に車体も動いてっ……！　ああ\nっ！　快感でタイヤが跳ねちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　オイルももうすぐ規定量にまで届いて……！　ひぐっ、んん\nっ！　こんなの、またイッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひぐっ！？　えっ……！？　ちょ、ちょっとカツマちゃん……！？　どうし\nてまた、勢いよくオイルを注ぎ込んでくるのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「もうすぐ規定量って言ってるのにっ……！　あっ、あっ！　ダメっ！　また\n超えちゃうっ！　規定量超えちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「さっきみたいに、オイル溢れちゃうからぁ！　私のエンジンルーム、オイル\nまみれになるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　ダメっ！　ダメえええぇ！　イッちゃうっ！　溢れちゃうぅ！\n　もうこれ以上、オイル注がないでぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひっぎいいいぃ！？　おっ、おおおぉ！？　カツマちゃんのジョッキが、オ\nイルパンの奥底に届いてぇ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あぐっ！　それに残りのオイルもどぴゅどぴゅ注がれて……！　ま、\nまたオイルが溢れてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　ダメっ！　最後の一滴まで注ごうとしないでぇ！　もう溢れて\nるからぁ！　これ以上、オイル入らないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んぐっ、あふっ、ああああぁ！？　おっ、奥の奥まで入れられたまま、グリ\nグリされて……！　こんなの耐えきれないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　イクッ！　イクッ！　カツマちゃんのジョッキで、またイカさ\nれちゃうううううぅぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……はああぁ……たくさん溢れちゃったけど……さっ\nきと違って、オイルはしっかりとタンクの中に入ってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「くっ、んふっ……！　エンジン回りがベトベトするわ……すぐに拭かないと\n、ニオイが染み付くどころか、パーツがダメになっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「えっ……汚したお詫びに、拭いてくれるの……？　そんな……気にしなくて\nいいのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「私はこうやって、カツマちゃんの手でメンテナンスして貰えるだけで幸せだ\nから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、他の車をメンテナンスするのだけはやめてね！　カツマちゃんがメン\nテナンスしていいのは、私だけなんだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「きゃあぁ！？　な、なんで急に新品のオイルを用意してっ……！？　ま、ま\nさか……それを注ぐ気じゃ……んひいいぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ひああああぁ！　溢れてるからって、違うオイルを入れちゃダメぇ！　違う\n製品のオイルを混ぜるの、ダメなのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　オイルパンの中で、粘度の違うオイルが混ざってるぅ！？　\n私のタンク、ぐちゃぐちゃにされてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「しかもジョッキで中をかき混ぜられてっ……！　ひぎぃ！？　２種類のオイ\nルが、エンジンの中で暴れてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「違うのダメなのに、どっちもカツマちゃんが注いでくれたオイルだからボデ\nィが悦んで……！　ひっ、あっ！　あはあああああぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……！　い、いい……カツマちゃん……車ごとに、適\n切なエンジンオイルの粘度っていうが決まってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022501_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「推奨されてる粘度範囲以外のオイルを使ったり、粘度が異なるオイルを混ぜ\nると……燃費の低下やエンジントラブルを引き起こしやすくなるのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「もし私が走れなくなったりしたらイヤでしょ……？　だからオイルの種類は\n、しっかり確認してね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「えっ……？　違う種類のオイルを混ぜたから、１度オイルを抜いてもう１度\n入れ直す……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「そんなっ……！　またあの快感を味わうだなんてっ……！　そんなの、今度\nこそ本当にエンジンに火が付いちゃうわっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}