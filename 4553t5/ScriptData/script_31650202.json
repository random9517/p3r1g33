		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「センパーイ、こっちっスー！　ほら、ここ、ここー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「やっぱ警備員スタイルだと、ちょっと新鮮っスねぇ。えへへ……なんかいい\n具合に高まって来ちゃいましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「まあ、わざわざ来てもらったのは、他でもないって言うかぁ……もう、分か\nってるよーな気がしますけどぉ……えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「この教室……今、使われてなくて、メインの教室からも離れてるし……って\nいうことはぁ……しちゃうにはバッチリっていうかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「おやぁー？　どしたんすか、センパイー？　なーんか、前かがみになっちゃ\nってぇ……やっぱりその気になっちゃってますぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「それじゃあ、そんなエロエローなセンパイをもっとその気にさせちゃう為に\nぃ……とっておきのポーズしちゃいますねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204106" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はーいっ♪　どうスかー？　あーしの身体、めっちゃ柔らかいでしょ？　Ｉ\n字バランスも、余裕で出来ちゃうんスよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016502_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふふっ……どうしたんスか、センパイ？　目をギラギラさせちゃって……\n鼻息も荒いですよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「どこ見てるんスかぁ？　むき出しオッパイです？　それとも……こっちの開\n脚オマンコかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふぅ……あーし……今日はもう朝からずっとムラムラしてて……ほらぁ…\n…もう、ワレメからお汁滲んでるの分かります……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「もうセンパイのチンポ……ぱくって頬張りたくて……ヒクヒクしてるんです\nよぉ……ほぉら、ちょっとくぱっとしたりしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「乳首も……見えてますよね？　まだ、全然触ってないのにピンって硬くなっ\nて……コリコリしてるの分かるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あーし、今……めっちゃ発情中なんで……もう、一気にズブって来てほしい\nんス……センパイのチンポ……オマンコで食べたいんス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はい、もう……最初っから準備出来てますからぁ……そのまま一息に……あ\nっ、はぁぁぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あぁっ……んっ、はぁぁぁ……チンポッ……来たぁっ……！　熱いのっ……\nズブって……めり込みっ、ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「くぅぅぅんっ……あぁ……すごっ……根元……一番深いとこまで簡単に届い\nちゃった……やっぱ開脚ポーズのおかげっスかねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふっ、すっごくカラダが密着して……センパイの熱……めっちゃ伝わって\nくるっス……はぁぁ……オマンコと……オッパイと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あ……動いていいっスよ……？　ていうか、お願いします……あーしのヌル\nヌルオマンコ……センパイのチンポでメチャ突きして下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あっ、あひぁっ、あっ、はぁぁぁぁんっ！　すごっ……んぁっ、く\nぅぅんっ、チンポッ……ヤバぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あぁっ、ぐちゅぐちゅっ、中っ……かき混ぜられるのっ……超\n気持ちイイっスっ……ひっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、くぅんっ、そうっス……あっ、奥に押し込む感じでっ……オ\nマンコの奥っ……ズブって来て下さいっ……あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んくうっ……ポーズ……ですか？　あーし、これでも鍛えてるんで……全然\n余裕っスよ、あっ、んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「けどっ、気持ちよすぎてっ……そっちの方で腰がガクガク言うのがヤバいか\nもっ……あっ、ひっ、あひんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁふっ……オッパイも……いいっスよ……こんな近くにあるのに……触ら\nないなんて……生殺しっスよねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「遠慮なくぎゅうーって……あっ、そぉっ、んっ、モミモミしまくって下さい\n……あっ、乳首……キュンってされちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あぁっ、んっ、はぁっ……チンポッ……響くぅっ……ズンズ\nンされる感じっ……マジ、ヤバぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁっ、でも……こんなトコ……見られたら……超ヤバいっスよねぇ……め\nちゃくちゃ恥ずかしいポーズで……オマンコされてるなんてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、考えただけでっ……あっ、オマンコっ……ヌルってしてっ\n……あひっ、もっとチンポして下さいっスぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、あぁっ……センパイ……あぁっ……んっ、はっ、リズミカルな\nピストン……声……出ちゃいますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あひっ、んくぅっ、はっ、あぁっ……！　こんな美味しいチンポ……独り占\nめしちゃうなんて……あーし、マジ……幸せっス……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、んんっ……！　深い……んくぅぅ……これ……子宮口まで届い\nてるかも……あ、くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あーしも、ヒダが……震えて……んっ、チンポ……キュウって吸い付いちゃ\nうの……分かりますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふっ、乳首……カリカリってされるとぉ……カラダ……ビクってなって…\n…勝手にオマンコ締め付けてぇっ……あ、そ、それぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁんっ、センパイに……あーしの動き……支配されちゃってる……んっ、\nあぁっ、チンポ……まだ激しくっ、はぁっ、ひぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁっ、はひっ、センパイもっ……ヤバいっスか？　んっ、出したくなって\nるっ……じゃあ、当然中出しってことっスよねぇっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「もしかしたら……んっ、妊娠しちゃうかもっスねぇ～、あひっ、あっ、んぁ\nっ、あぁっ、センパイ……マジの……ピストンんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あっ、ダメッ……イクっ、イキますっ！　チンポ良すぎてっ……オマンコッ\n……ひっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁっ……！　んっ、あぁっ……どぷどぷっ……中に……出てる\nっ……ザーメン、流れ込んでますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁぁ……ヤバ……ホントに子宮まで届いてそう……マジ、気持ちよすぎる\nぅ……は、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……全部注ぎ込まれたぁ……あふ……本気の種付け……されちゃ\nいましたぁ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ふふ……めっちゃサカリましたねぇ、センパイのチンポ……\nまだギンギンに震えてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、まだ……し足りないんじゃないっスか？　いいですよー、もっと続け\nてしちゃっても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「オマンコの中で……センパイのチンポもまだしたいって言ってるみたいです\nしぃ……まだまだ、あーしはこのカッコ……よゆーですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁんっ！　ふぁふっ……あんっ、また……チンポっ……グリグリ……始ま\nりましたぁっ……んぁぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぅっ……あんっ、あぁ……オマンコが……ぐちゅぐちゅして……はぁうっ\n、蕩けちゃうっスぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あふっ、んぁっ、一回イッたオマンコ……トロトロの中っ……かき混ぜられ\nるの……めっちゃいいっ……あぉっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、おっぱい……揉みこんでぇ……ぎゅうってされながら……\nリズミカルに動いてぇ……やっぱ、この角度……いいんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あ……えっ、どうしたんスか……？　顔……こっち？　あっ……んむっ、ち\nゅぷっ、はっ、あぁぁんっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「うぁ……い、今……そのキスはヤバいっスぅ……んりゅっ、れろ……本気で\n……オマンコ……トロンてしちゃう……はぁ……あ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、あむっ、んちゅぷっ……は、ひぃ……ち、乳首までぇ……あぁ……ん\nむっ、あーしのカラダ……センパイに全部されてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁっ……柔らかいれふか……？　んんっ、やら、ヘンな時\nに褒められたら……また、オマンコぐじゅって……してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あふぁっ、んくぅっ、汁が……また出ちゃいまひゅっ！　はぁぁっ、そこっ\n、あっ、そこぉっ、もっとして下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あぅっ、んんっ！　はぁっ、あっ……チンポッ……気持ちいいっ……！　ん\nぁっ、ヤバいっスっ、あーしっ、もうイクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、へぁぁぁ……あぁ……一気に……イカされちゃいましたぁ……はぁ、\nセンパイのチンポ……すごすぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっ、まだそんなっ、はぁうっ、んくっ、あふっ、んんんっ！　イ\nッたばかりのオマンコっ……ぐりゅぐりゅって……んっ、ひぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……あっ、またキスぅ……んりゅ……れろ、ちゅぱっ、あぁ……全\n部……気持ちいい……メロメロにされてくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっ……センパイのチンポに……オマンコ吸い付いちゃうの……止\nめられないっ……くふぅっ、気持ち……よすぎぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ、あくぅっ……んんっ、あぁっ、チンポっ……本気で激しくっ\n！　んぅっ、またっ……あっ、イクんですねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、下さいっ……センパイの２発目っ……好きにしていいです\nからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あーしもっ、またイクっ！　続けてイキますっ！　ひぁぁぁんっ、オマンコ\nッ……イックぅぅぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁふっ……あぁぁ……また……中ぁ……んんっ、すごい……出てる……止\nまらない……どぷどぷ……来てまひゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んくぁぁ……ダメ……溢れちゃうっス……オマンコ……いっぱいなのに……\nまだまだ出されるなんてぇ……んくぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あっ……とっ……ヤバ……流石にっ……バランス……崩しそう……あっ、ん\nんっ……センパイ……支えてくれてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「えへへ……マジ、こういう時スッと優しいトコ出るのが……センパイのいい\nとこですよね……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「それで……まだ、中出し……したままってのが、またセンパイらしくて……\nあふっ、はっ……あーしも、まだイッてるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、止まった……はぁ、はぁ……はぁ……効きましたぁ……チ\nンポぉ……マジすごかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「センパイ……もうちょっとだけ、繋がったままでいいですか？　あと少しだ\nけ余韻モード入りたいっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「足……開きすぎて……ゆ、ゆっくりじゃないと……戻らないっていうか……\nすみません……面倒掛けちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふぁ……はぁ、はぁ……んっ、はぁ……んっ……それで、センパイはどうで\nした？　結構スリルもあって……ハマったんじゃないスか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふふっ、またしたくなったら言って下さいね。あーしは、いつでも大歓迎で\n待ってるっスから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁんっ！　あぁぁっ……出てるっ……精液……掛かってっ、んぁっ、\nあっ、あーしもっ……またイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁ……２発目もヤバい……んっ、ネバネバ精液……元気良すぎぃ…\n…はぁ、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「とと……ちょっとフラついちゃいました。んっ、センパイ……ちゃんと支え\nてくれるの、優しいっスよねぇ、えへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「でも、チンポは……まだあーしに掛けてるし……流石、本能の人って感じ…\n…あっ、ウソウソ、冗談っスから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、でも……こうして……チンポ押し付けられて……精液……\n塗られるの……ちょっとゾクゾクってしちゃうっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「そろそろ終わりみたいスね……んんっ、せっかくですから、全部マーキング\nしちゃって下さいよね、センパイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ、はぁ……終わり……あふっ……マジお疲れ様でした。ちょー気\n持ちよかったっス……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「もうちょい、余韻モードいいスか？　足も……そろそろ下ろさないと……ち\nょっとフラフラ過ぎて……えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「で……どうでした？　いつも以上にサカッてくれたし……逢い引きセックス\n、気持ちよかったってことでいいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふふっ、またしたくなったら言って下さいね。あーしは、いつでも大歓迎で\n待ってるっスから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0204410" ]},
