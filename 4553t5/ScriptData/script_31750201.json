{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほぉーーらぁー、じっとしてなさい。全部やったげるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なーに、ビクビク怯えてんの？　こんな明るいトコだと心配になっちゃう？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「大丈夫よ、ヤムが細工してるから、他のヤツには見られたりはしないし、そ\nこは安心していーから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ってことでぇ……んふふっ、はーい、ズボン開いちゃおっ♪　服ももっとぐ\nぐーっと上げちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっれぇー？　おかしいなぁー、色々マズいとか言ってる割に、これはどう\nいうことなのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……チンポ、どんどん大きくなってるじゃない。ね、ね、これはどーい\nうことなの？　ヤムにして欲しいことってことじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どうなのかなぁー？　ヤム……言ってくれないと、分かんないなぁ……ほら\n、こーいう時ってアレをするんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムにオチンポをシコシコして下さいっておねだりだよ。ほら、チンポ気持\nちよくなりたいんでしょ？　どうなの？　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、娘におねだりしちゃうなんて、いけないパパなんだぁ……♪　でも\n、それだけ我慢出来なかったってことだもんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「しょうがないなぁ……じゃあ、むぎゅって……してあげるっ、んふふっ、手\nは人間のやつよりこっちがいいよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「痛い？　でも、ちょっとチクってする位の方が、気持ちよかったりするんで\nしょ？　だって、パパはそっちの方も行けるって聞いたことあるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「別に誰が言ってたっていいじゃん。ていうか、みんな思ってることでしょ？\n　パパが気持ちよければ何でもいいヘンタイだってことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だからぁ……んふっ、ちゃんとヤムがその欲望を叶えてあげる。ほら……お\nっぱい……れろっ、してあげるし……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふぅっ、くすぐったい？　ダメよ、逃げちゃ。それとも、乳首も噛んで\n欲しかったりするのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……ヤムのおっぱいもみせたげる……別におっきくなくても……パパは\nちゃーんと興奮しちゃうんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはっ、いいよ顔をそっちに向けても、チンポの方が全部教えてくれるし～\n。ビッキビキになって、気持ちいいです～って言ってるじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「しょうがないなぁ……シコシコしてあげる。ぎゅうぅぅーって……ほら、オ\nチンポ……これでも感じるでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムがちょっとその気になったら、これ位……簡単に握り潰せちゃうんだよ\n？　そんなアブないモノにチンポを預けてる気分はどぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、ドキドキするんでしょ。チンポの脈がビクビクって……大きくなっ\nてるのバレバレだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ……乳首も……コリコリになって来た。ヤムので、そんなに興奮しちゃ\nってるんだぁ……んっふふぅぅー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあ、もっと速くシコシコしてあげる。ほらほら、気持ちいいやつだよ～\nチンポにご褒美だよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはっ、やっぱり喜んでるじゃん。ヤムのごつごつの手で、しっかりチンポ\n感じてる～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちょっと爪を食い込ませたげよっか？　ここのとこぉ……ぎゅぅぅぅって…\n…くふふっ、何かめっちゃ汗かいてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「分かってるよ、ヤムはちゃんと加減してあげてるって言ってるでしょ？　そ\nれとも、ヤムの言うことが信用できないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そうよね、分かってるならいいケド……ちゃーんと、ヤムのご機嫌は取って\nた方が、チンポの為でもあるかもよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ……ぴちゃ……んっ、いい子にしてたらぁ……んっ、いーっぱい気持ち\nよくして……ドロドロ精液、ぴゅっぴゅさせたげるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どうせ、めちゃくちゃ溜まってるんでしょ？　出したくて出したくてウズウ\nズしてるんだよね？　ヤムにはバレバレだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふ……そうだ、タマも揉んであげよっかー。むにゅって……あははっ、情\nけない声出しちゃってぇ……もっとしっかりしたらぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらほら、パーパ。ちゃんと腰に力を入れてぇ……ぎゅってしないと、すー\nぐお漏らししちゃうよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もし、勝手に出しちゃったら、もっとすごいオシオキしちゃわないといけな\nいカモ……そんなのイヤだよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なら、ふふ……ちゃんとヤムの指に意識を集中させてぇ……気持ちよさそう\nな顔を見せてればいいのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どう？　ヤムの手コキ……気持ちいい？　オチンポ喜んじゃう？　嬉しい？\n　ね、嬉しい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、そっかぁ……出したくなっちゃってるんだぁ。じゃあ、それもおね\nだりだよね。こーいう時は、どういう風に言うのかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えぇ、聞こえなーい？　もっと大きい声でー。ヤム様の手コキでチンポぴゅ\nっぴゅしたいですって言わないと～、ほら、早くぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あははっ、ホントに言うし～。うんうん、しょーがないなぁ……そんなに出\nしたいなら……お望み通り……イッちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ！　めっちゃ出てるしっ……んっ……ヤムの手に……熱いの……びゅ\nくびゅく掛かってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、すごい勢い……チンポって出す時こんな風になっちゃうんだ……\nあっ、ダメよ隠しちゃ……ヤムによーく見せなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ね、恥ずかしい？　そーよね、パパの威厳なんか台無しで、こんなに射精し\nちゃうんだもんねぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あー、終わっちゃった。もっと出すのかと思ったけど、案外大したコトなか\nったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま、それでも、気持ちよかったんでしょ？　んふふっ、ヤムに感謝しなさい\nよ、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さて……あれれぇ？　終わりかなーと思ったら……チンポはまだそのつもり\nはなさそうだったり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「一回しぼみそうになったのに……ヤムの手の中でまたムクムクしちゃってさ\n、これってどういうことなのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「つまり……まだして欲しいってことでしょ？　ほーんと、やらしいのが大好\nきなのねぇ、パーパ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「しょうがないから、続きしてあげる……れろっ、ちゅぱっ……んふふっ、乳\n首もそうして欲しいって。よっぽど正直さんなんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぱ……んちゅ……んふ……おっぱいムズムズする？　ヤムも…\n…ちょっと、そんな感じになって来ちゃったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ、でも、今日のお触りは禁止だし？　パパは当然見てるだけー、じゃない\nと、通報されちゃうかもねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま……その代わり、ちゃんとオチンポは可愛がってあげるから……はい、じ\nっとしてて……んっ、はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「こすこす……さすさす……ね、気持ちいいでしょ。チンポの根っこのトコ、\nぎゅーってされると、腰が浮いちゃうでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「他にもヤムは知ってるよ？　どこで感じるか……痛くなるのかも……むぎゅ\nぅぅぅって……ふふっ、ウソ、ここはちょっとだけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やっぱりじわじわぁーって溜めて、びゅびゅーって出すのがいいもんね？　\nちゃんとそうしてあげるから、安心してヤムの指にまかせてなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「くにくに……こすこす……んふふっ、まーたチンポが震え始めてる。パパの\n気持ちよさそうな顔見てると、ヤムもゾクゾクして来ちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあ、こういうのは好き？　れろ……ちゅぱっ……乳首……ナメナメしな\nがら、一緒にキンタマもさすってあげるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「指でつぅぅーってなぞってぇ……そのまま、またチンポに爪先を引っ掛けて\nぇ……こりこりってしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはっ、めっちゃ跳ねるし。おもしろ～いっ、パパのチンポがヤムの手でビ\nクビクしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぴちゃっ……乳首も超コリコリぃ……んふっ、もう全然我慢出来\nないんでしょ、ならぁ、出しちゃうしかないよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もう一回射精しちゃってるんだし、今更我慢したってムダなんだからぁ……\nもう出しちゃえばいいよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほぉらぁ、いいよぉ、腰振ってもぉ？　ぐってチンポ前に出してぇ……みっ\nともなくいっぱい射精するトコ、また見せて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろっ、ぺろっ……んれろぉっ……ね、我慢できないの知ってるし……気持\nちよーく、ぴゅっぴゅしちゃお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃ、またおねだりしよっかぁ。ヤム様の手でしこしこ出してもらって、ど\nうしたいのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いーよ、特別に許したげる。掛けたいんでしょ、どこがいいの？　ヤムのお\nっぱい？　それとも顔にする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、おっぱいに出したいんだぁ……パパってば、ヘンタイなんだから\nぁ……でも、いいよ……許したげる。ほら……出しちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　んぷっ……ふふっ、めっちゃ出てるしっ！　チンポマジで元気\nいっぱいなんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーら、しこしこぉー、出してる途中でチンポ扱かれるの気持ちいいでしょ\nぉ……もっともーっと出しちゃっていいんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ、ヌルヌルさせてるぅ……ヤムのカラダ……ネトネトにされ\nてる……んふぁ……あぁ、ヤダ……気持ちいいかもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あぁ……もう出るの終わり……？　ダメだよぉ……もうちょっと頑張って…\n…ほら、後少し出すのっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あんっ……出せたじゃない。ちゃんと残ってるの……搾り出しち\nゃったねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んんー、ビミョーな味……。ま、あんまり贅沢言ってもダメかぁ\n、しょせんパパだしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま、一応は頑張ったんじゃない？　パパにしては頑張りましたってことで、\nよしとしなきゃね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ、もしかして悔しかったりする？　でもぉ、パパが見せたカッコ悪い\nとこは全部本当のことだしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「大丈夫、ヤムは別に言いふらしたりしないから。またヤムにだけ見せてれば\nいいの。分かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、顔に掛けたいんだ……パパってば、ヘンタイなんだからぁ……で\nも、いいよ……許したげる。ほら……出しちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　めっちゃ出てるしっ……本気でヤムの顔にシャワー出しちゃっ\nてるぅ……！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ、れろ……二発目でも、結構ドロドロのまま……ちゅぱっ…\n…うぅん、変な味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁん……まだ出てる……んっ、ふっ……いいよぉ、まだ頑張って残ってる\nのぴゅっぴゅしよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、出しながらこすこすされるのいいでしょ……奥に残ってるの、全部出\nしちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ！　そうそう……はぁんっ、ねばねばぁ……すごいニオイ……んふっ、\nヤムの顔をこんなに汚すなんて悪いパパだねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あふ……終わった？　んー、れろっ、ちゅぱっ……んりゅ……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あーあ、顔べっとべとぉ。ほぉら、何か拭くモノ出してよね？　そっち仕舞\nうのはあとでいいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そうそう、ちゃぁーんとキレイにしてね、パーパ？　隣にせーえき臭いちっ\nちゃいこ連れて歩いてたら、ケーサツ来ちゃうもんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「え？　何ポカーンってしてるの？　これから一緒に買い物するのよ。まさか\nタダでヤムとお楽しみデキるワケないでしょ？　あははっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}