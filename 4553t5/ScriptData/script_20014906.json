{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "光が止む。目を開けると、そこには元の姿に戻ったダイヤナが呆然とした顔で\n立ちつくしていた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "洗脳されていた参加者たち、そして姫様たちも、同じように光に包まれて元の\n姿に戻っていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ……あれ……？　ダイヤナちゃん……いったいどうしたのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……うぅ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「な……なにが……どうなって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やりましたの！　みんな元に戻りましたの～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300001" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その様子を見て、アンがダイヤナに飛びついた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃっ！　あ、アンちゃん？　えぇっ、どうしたのその格好！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「誰かの願いが形になった、花嫁衣裳ですの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300002" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それよりダイヤナさま、お身体の具合は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300003" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え……？　う～ん……なんだか、頭がクラクラするし……ん～、夢でも見て\nいたのかしら、さっきまでのことを思いだせないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナは首をかしげている。クリスタルに覆われていたときの記憶がないみ\nたいだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様たちも、大丈夫ですか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだか記憶が……曖昧だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「覚えてないんですか、俺にイチャついてきたこと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様、言ってましたよね？　イチャイチャしろって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "光を浴びてしまった姫様のことを話すと、その顔がみるみるうちに真っ赤にな\nった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふ、ふざけるな！　誰がそんなこと言うか！　私がお前とイチャイチャだと\n？　するかそんなこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私は……どうだったんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザーは、いきなりキスしてきて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ……そんなことを……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んなっ！　アナザー、貴様そんな破廉恥なことを……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、記憶にない！　そんなことをした覚えは……しかし、唇に……口の中\nに感触が残っているような……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、貴様のせいだろ！　私たちがおかしくなっている間に、貴様がなに\nかしたんだろぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ、詳しく話を聞かせてもらおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、違いますって！　俺はなにもしてませんって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「口は不幸の元……。カツマくんって、本当に不幸だね……フフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300001" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0032" ]},
		{"command":[ "SETTEXT", "スタークリスタルを破壊したせいだろうか。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "めちゃくちゃになった会場はすべて元通りになり、まるで最初からその存在が\nなかったかのようにイベントは進んだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックとアンの花嫁衣裳は、イベントが終わるまで観客や参加者たちか\nらの注目を浴び続けて、一緒に写真撮影をしたいという列までできていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こんなに目立って疲れちゃった。はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300002" ]},
		{"command":[ "SETCHARA", "0", "char_00001805_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "花嫁衣裳のまま階段に腰かけたグリムロックがため息をつく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すると、変身する前の魔法少女の姿に戻った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「元に戻っちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300004" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうみたいだな。似合ってたぜ、花嫁衣裳」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふふっ、本物じゃないけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300005" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「時間限定のドレスだなんて……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300006" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「幸せは永遠に続かない……。それに、どんなドレスを着たって、私を見つけ\nてくれる王子様は現れない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなこと言うなよ。それに、さっきの花嫁衣装はお前に向けられていた願\nいが形になったものなんだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前が見つけてないだけで、お前の王子様はいるんだよ、たくさん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そうなのかな。だけど、私にエッチなドレスを着せたい王子様がいるのって\n、幸せなのか、不幸せなのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300008" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「でも……ありがとう。私の知らない、私のことを知っているたくさんの人た\nち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300009" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックは寂しいような嬉しいような、感情の入り混じった微笑みを浮か\nべて空を見上げていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300004" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこへ、アンがトタトタと走ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたんだアン……って、その手に持ってるのはなんだ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ、“こ～いんとどけ”ですの～！　花嫁衣裳を着ているうちに、サインし\nてほしいですの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300005" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この衣装になってから、らんしがどんどこ出てきているのを感じますの。こ\nのまま結婚して、しょやを迎えれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300006" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのこどもをばっちり授かれちゃいますの～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300007" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なにを言ってるんだ！？　というか、婚姻届けなんていつの間に用意し\nたんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いつでも旦那さまと結婚できるように鞄に忍ばせてますの。乙女のたしなみ\nですの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300008" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……避妊具みたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300010" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「避妊じゃなくて、懐妊する気なんだが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「当たり前ですの～♪　さぁ、いまこそサインを！　ふたりで永遠の愛を誓い\nますの～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300009" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おいっ、いま婚姻届けとか言ったか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「初夜だとか懐妊だとか不穏な言葉も聞こえてきたぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アン＝クァーが大声で危ない発言をするものだから、近くにいた姫様たちがそ\nの中の単語に反応してしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「さあ、さあ、旦那さま～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300010" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「落ち着けアン！　俺は、まだ、そんな犯罪的行為に手を染めるわけにはいか\nない……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい待て、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「婚姻届けにサインなんかさせないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結婚を迫るアン＝クァーから逃げる俺。それをさらに姫様とアナザーも追いか\nけてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「痴情のもつれ……。フフ、不幸だね……。でも、幸せそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300011" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ねえ、グリムロックちゃん。となり、いいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……ダイヤナさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300012" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んもぅ、呼び方が戻ってる。あたしがおかしくなっていたときには“ダイヤ\nナちゃん”って呼んでくれたのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300005" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えぇっ！？　な、なんでそれは覚えてるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300013" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「わからないけど……。グリムロックちゃんが、あたしのことを思って言って\nくれた言葉だから……かしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300006" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あぁ……その……。あのときは私も、衣装のせいでちょっとテンションがお\nかしくなってたっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300014" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「一回呼べたんだから、もう一回くらいできるんじゃない？　ほら、あたしの\nこと“ちゃん”づけで呼んでみて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300007" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え……ああ……。ダイヤナ……ちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300015" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふふっ。なぁに、グリムロックちゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300008" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ。こういうやり取り、陽キャっぽくてちょっと、わ、私には早\nいかも……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300016" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そんなことないのにぃ。じゃあ、ちょっとずつ慣れていきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300009" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うん、ダイヤナちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300017" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうそう、その調子♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300010" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「や、やっぱりまだ、恥ずかしいかも……。それより、グランプリおめでとう\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300018" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……あっ。でも……クリスタル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300019" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うん、スタークリスタルちゃん、なくなっちゃった。かけらもないくらい、\n粉々で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300011" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ごめん。あれ、私が壊しちゃって……。本当は、無力化する程度のはずだっ\nたんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300020" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ううん、いいの。記憶はないけど、なんとなくわかるの。あたし、あれのせ\nいでおかしくなっちゃってたんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300012" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それで、グリムロックちゃんにひどいこと言っちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300013" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ううん、気にしないで。幸せになりすぎると周りが見えなくなっちゃうのは\n、誰にでもあることだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300021" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だから、私は気にしてない。それより、コスプレサミット楽しかったよ。ま\nたみんなで、どこかにいきたいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うぅっ、グリムロックちゃんって、すっっっっごく、オトナぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300014" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えっ、あっ、ちょっとこんなところで泣かないで……か、カツマく～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300023" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ど、どうしたグリムロック。ああ、だがすまん！　こっちは手が離せないか\nら、そっちでなんとかしてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、アン！　お前、元の姿に戻ってるぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どんな姿でも旦那さまへの想いは変わりませんの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300011" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お色直しを済ませたわたくしとこづくりハネムーンに出発ですの～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023300012" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どこでそんな言葉を覚えてきたんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様ぁっ！　こんなちっちゃな子と、は、破廉恥なことをするつもりかぁっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023300009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「させないぞ、カツマ！　第一、そんなことをしたら社会的にまずいだろう！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023300009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ、わかってるよ！　だからアン、ちょっと落ち着けぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ええっ！？　あ、あっちはあっちですごいことになってる……。でも、こっ\nちも……。あ、あの……えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300024" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ごべんねぇ、グリムロッグぢゃぁあ゛ん゛っ！　あ、あだじぃ……ぐずっ、\nあだじぃ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023300015" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だ、ダイヤナちゃん。いいよ。そんな、号泣するほどのことじゃないよ……\n。あぅ……あ……えっと……ふ……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300025" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……でも、こうして“ちゃん”づけで呼び合える友達が増えるのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300026" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「『不幸』じゃない……かも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023300027" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}