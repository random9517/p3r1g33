		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「……悪いっ、呼び出し時間に遅れちまった！待たせたか？……ホントにごめ\nんな……。で、特別な用事って、なんなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「あー……アタシと葉金の関係について、かぁ。なんていうか……ライバルか\nな。ただ、あっちの方がレベル高いのは事実っていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アタシも負けるつもりはないんだけど……。そうだ、隊長。なんでもいいか\nら、アイツに勝てるような特訓方法ってないかな？……え？ある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「『ちょうどその話をしようと思ってた』？えええ、マージ―かーよー♪アタ\nシら相思相愛だな、で？何すりゃいい？……シックスナイン？んだそれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「オトコと女が互いの性器を舐めたり吸ったり触ったり、す、る……って隊長\n！そ、そ、そりゃエロ行為じゃねーか！そんなんアタシはイヤだぞ！って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「『今までと同じことをしていても今まで以上には強くなれない』……？確か\nに……でも……。『他の幹部はこれで強くなった』？……ほ、ほんとにか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「……強く……なるため。アイツを超えるため……。迷う、けど……。アタシ\n、隊長のこと尊敬してっからさ。一度くらいは試して……みる。うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「で？隊長の顔の上にまたがって……。ア、ア、ア、アタシ、アタシ、は隊長\nの……チンポ、チンポっの、前に顔、置いたけど、こここここれでいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「っ、シックスナインってこんなんなのかよ！聞いたことも見たこともねえと\n思ってたら……アブノーマル！ヘンタイプレイ！じゃねーか！騙したな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ええっ……あぁっ？つーかチンコ死ぬほどデカイんだけど！アタシのか、顔\nっくらいあんだけど！これを口で……？イカれてんのかよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「うぁ……。あ……グロい……。風呂場で見た父ちゃんのと全然違う……。は\nぁ、はぁ、こ、これが隊長の……ってんぁ！？アソコ舐めんな！バカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「……濡れてたからぁ！？アタシがか！？アタシの……股が……んなわけない\nだろ！なんか垂れてくるから舐めてるだけぇ！？ぅ……あ、ぁ、あ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「本当にこれをしゃぶったら強くなれるんだろーな！？そんなら、もう……ア\nソコ舐められてるし……しないの、単に損だから……。するよ。こうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「っペロ……。ぺろっ、ぺろ……ぴちゃ……。ぴちゃ、ぴちゃ……うぇえ……\n。んだこれぇ……なんかしょっぱ……。んぅ……ぴっちゃっぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ふぁあっ！？アタシのマンコ、あんまベロベロ大きく舐め……んなァ……！\nくすぐってぇ、なんかゾワゾワする……。んぐっ、ンン、んっ、ん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「クソ、変な声出る……。この声止めるには……！な、舐めるっきゃねーのか\nよ……！クソ、クソぉ……ぺろ……ぺろ、れろ……れろ、れろ……んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「葉金には絶対言えねー……！隊長のチンポ舐めれ……パワーアップしようと\nひてるろか……！一生言えねー！っちろ……チロ、ぴちゃ、ぴちゃ、ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「あの……あのさ、なんか先っちょがいいとか、でっぱりがいいとかあるか？\nなんか裏筋……舐めるとビクビクしてるみたいらけど……根元とか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「あー……。た、タマも感じるのかよ？えっ、オトコってスゴすぎだろ。チン\nポ全体性感帯ってことか……？……で、でも、わかった……全部やる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「全部……れんぶ……っ。ちゅぷ……くちゅ、ちゅぷっ、ぷちゅ……。れろ…\n…れろ、れろ、れろ……はむぅっ。ちゅぅう、くちゅっ、くちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「チュク……くちゅっ、ちゅく、くちゅ……。ん、と……タマを口に入れて…\n…ムニュムニュして……吸って……。ぢゅるるる、ぢゅる、ぢゅるる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「根元から……れろーって舐め上げて……れろ、れろぉおお……れろ、あとは\n竿とか、段差……とかに唾つけて……ぴちゅ、ぴちゅ、ちゅっぷ……はふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「あ、あと、は、先端を……舐めて、舐め、れ……。くちゅ、くちゅ、くちゅ\nっ……ちゅぷぷ、れろれろれろ……れろれろれろ……んぁああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「くっそっ、マンコねぶられてっと力が出ねぇよ……！口がしびれぅ……！…\n…ん？チンポ全体を咥えて思いっきりしゃぶれ？しゃ、しゃぶれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「それくらいしないと葉金には勝てない？……わ、わーったよ、わーったよも\nぉ！ずっとマンコ舐められっぱなしなのも困るし……ヤるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「た、短期集中決戦だ……。い、いくぞ……。えいっ……かぷっ！ぐちゅっ！\nぐっちゅっ……んんん、おぇ！喉に刺さりゅ……負けるか、ぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ぐちゅ……ぐちゅぷっ、ぶぢゅっ、ぶぢゅ……んぉ、ぉお……ちゅばが溢れ\n……。ぢゅるっ……ぢゅる……ごくっ、ごきゅ……ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「んんんむぅう、アソコと口が……くひがあっつくなってわけわかんな……い\n、ぢゅぷっ！ぢゅぽっぢゅっぽっぢゅぽっぢゅっぽっ、んむ、んぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「な、なんかっ、口、くひの中、くひの中でひんぽ膨らんれ……！んぐぅうっ\n！えふっ！？んぐっ！んぐぅっ、ぐちゅっ！ぐちゅっ！ぐちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「だ、出す、出ひゅ前準備ぃ……？出ひゅって何を……んん！？止めずにしゃ\nぶれ！？っぅ、わ、わかったよ……！ぢゅぽっ！ぢゅっぽっずちゅっれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「レロレロレロ、ぢゅぅううっ！ぐっぷっぐっぷっぐっぷっ、ぐちゅっ！ん！\n？やめ……りょ、いきなり奥に突っ込むな……ってんんんんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「んぐぅうううううう！？んぐぅうっ！？んぶぅううううう！？ん！？んん！\n？んんんッ！？なんか出たっ！？アッツい汁、口ん中に……んぉええ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ごぷっ……んぶぅっ！？なんらこれっ！？……せ、精液……精液ぃいい！？\nんぁあ……っ！ヤッバイ……！口ん中でドロドロネチャネチャしてて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「全然取れねぇ……それににがっ！おぇっ！臭いっ、オイオイオイオイ！何出\nしてンだよ！……はぁ！？これを飲めばレッスン完了だぁ！？……はぁああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「の、飲む……飲む！？……じゃないとしゃぶったのが無駄になるのか！？…\n…おぇ……じゃ、じゃあ……仕方ねえな……。ぅ……ごっくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「んんんんんんんん……！気持ちワリぃいいっ……しかも一回じゃ、全然喉に\n流れていかねぇ……！くそっ、くそ……ごくっ！ごきゅっ、ごく……ぷぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「う、ううううう～……！ユメに出そうなマズさだったぞ！それに……飲んで\nる時までマンコ味わってんじゃねえ！あっ！あっ、コラッ、うぉっ、イく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「イクっ……！精子飲まされて、マンコ舐められて……イく！こ、この、この\nアタシ、が……！最強の、鈴、伊形鈴、が……くそおおぉおっ！あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「あああっ！イクぅっ！イクッ、イカされる……ぅううっ！ちくしょぉおおっ\n！ちくしょ……あああっ！イ……くっ、イクっ、イックぅうう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「……あーっ♪こ、これで強くなってなかったらぁ、ゆ、ゆるさねーからなぁ\nああ！隊長ぉおおおお！ばかーーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00011401_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
