		{"command":[ "PLAYVOICE", "v2_127_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んはっ、ああっ、いいぞ……ンッ、ンッ、ンッ、んじゅるるっ！　イキそう\nなら、我慢しなくても……いいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ！　射精、しそうなんだろう……？　んじゅぶっ、じゅぶっ、\nじゅぶっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「なら……いいぞ、んっ、好きなように……精液を、ンッ、出して……しまえ\n……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んんっ！　んっ、んっ、んむぅっ！　んぐぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んふぅっ！　んっ、んっ、んん……んく……うぅ……っ！　精液が、口の中\nに……いっぱい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「また……ドロドロしたのが、喉の奥に直接、流し込まれて……っ！　んっ、\nんぐっ、んぐ……んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「凄い粘り気で……ンッ、んはっ、飲みこむのにも……苦労するくらいだぞ…\n…ンッ、んぅ……んぐっ、んぐ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んっ、二回目だっていうのに……んふぅ……たいしたもんだ……。んむっ、\nんっ、んふぅ……じゅるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まだ……射精が収まらない、みたいだな……。んっ、んっ、んく……。最後\nまで……面倒見てやるから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んじゅるる……じゅぶっ、んっ、んふぅ……んふぅ……口いっぱい……キミ\nの精液だらけだよ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_12" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「どうした……？　もっと、するか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふっ、いいだろう。サメ退治で予定が狂った分、その埋め合わせをしっか\nりしようじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私に付き合わせてしまった分、今度はキミに付き合うよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んはぁあっ！？　ああっ、んっ、んん……んくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「いきなりペニスを抜いたと思ったらっ、ンッ、精液が……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「たくさん……んっ、ああ……すごい……二回目だっていうのに、こんなに出\nるとは……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_13" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「キミの濃い臭いに……包まれているみたいじゃないか……ンッ、はぁ……。\n呼吸するたびに精液の臭いが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んっ、鼻の頭に、ペニスを擦りつけて……私にもっと、キミのペニスのいや\nらしい臭いを嗅がせようというのか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_14" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「キミは変態だな……んくぅ……。それにしても、まだまだ硬いようだな……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「二回射精したくらいじゃ、満足できないってことか……。ふふっ、もっとシ\nてほしいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まあ、これからの余裕もないし、このままこのビーチで続きをしようか」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_16" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ンッ、ペニスをビクンと震わせながら返事をするなんて……。まったく、本\n当にいやらしい男だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふっ、今度はどうやってキミを射精させてやろうかな……？」", "NORMAL" ]},
