		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はやくしゃぶれって？　そんなに焦らせるなよ……んちゅっ、どうせなら、\n君だって楽しみたいだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぷ……ン……ちゅぱ……。ふふ、それじゃあ……いくぞ……ン\n……ぁむ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
