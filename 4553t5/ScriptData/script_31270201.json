		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「しかし、ちょうどいい機会だったよ。キミに、この新装備の性能を見せるこ\nとができたからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「どうだった……って、エロかった！？　キミはどこを見ていたんだ、まった\nく」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ちょっと待て。なんでペニスを露出させているんだ。しかも……すっかり勃\n起してるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「まあ、確かにここはサメがでるから人気はないが……。だからって、こんな\nところで奉仕をしろと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「うう、突然サメ退治に付き合わせたのは確かに悪かったよ……。はぁ……そ\nういうことなら、お詫びにペニスのひとつでもしゃぶろうじゃないか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012702_01", "1", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_127_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ン……。それにしても、洗ってないペニスは凄い臭いだな……。キミの臭い\nが、鼻をいっぱいにする……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_01_01" ]},
