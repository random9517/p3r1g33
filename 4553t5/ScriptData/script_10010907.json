{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0140" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「ううう……やりやがったな、ちきしょお……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ウチの姉ちゃんをいじめるΩ（オメガ）組は許さない！　文句があるなら、\n今日の夜、採石場で待ってるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「血桜（ちざくら）お七さんが戻ったら、伝えておいてください。それでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ｂ" ]},
		{"command":[ "SETTEXT", "「くそぉお！　あいつら、正義（まさよし）の鉄砲玉かっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「おーい！　誰か歩けるヤツ！　ひとっ走り言って、姐さんに知らせてくるん\nじゃ！　戦争じゃ！　採石場で出入りじゃー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「一方そのころ、居酒屋・正義（まさよし）では」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109120001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん……！？　わたしたちに、話……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマが……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。おまえとカグヤに、ぜひとも言わなきゃならないことがあるんだ。今\nから公園まで来てくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わ、わかりました！　カグヤと行きます！　待っててください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、でもな。ほむらや、ルナテミスに邪魔されちゃ困るんだ。嘘の行き先を\n書いて、メモを残しておいてくれ。たとえば……採石場に行くとか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わかりました。そうします。では、またあとで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待ってるぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……カグヤ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……うん、行こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「指定されたのは、この公園だけど……カツマさんは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いた！　あそこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあ！　カグヤ！　待ってたぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　頭は大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんとなく誤解を招きそうな聞き方だが、まあ大丈夫だ。だいぶコブも小さ\nくなってきた」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「よかった！　それで、話と言うのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、それな。その前に……メモは残してきてくれたか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええ。『採石場に行く』と書いて、残してきましたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか、よかった。それだったら――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「話をさせてもらおうかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109120001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010109120008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「冴島長官と……ＥＤＯの戦闘部隊！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お前たち、かかれ！　まりあとカグヤを捕獲せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109120002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＥＤＯ隊員" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ど、ど、どういうこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}