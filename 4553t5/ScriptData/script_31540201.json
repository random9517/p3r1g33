{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あのー……パワーアップするためのトレーニングをするって伺ってきたので\nござるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「拙者……あんまりお役に立ててないでござるよね……？　本当にいつもいつ\nもご迷惑を掛けてしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「だって、二重人格だなんて、面倒ですよね……？　自分でも時々……いえ、\n毎日毎日ウンザリしているんでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「だから、この今の人格のままで、もっと活躍できればっていつも思ってるん\nですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「と、とにかく、トレーニング、頑張ります！　で、一体何をすればいいんで\nござるか？　へ？　え？　パ……パイズリ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「そっ、それぐらい知ってますよ？　ええ、今どきの処女の耳年増っぷり、\n甘く見ないで欲しいでござる。エッヘン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「……で、でも、まさかホントにすることになっちゃうだなんて……うう、い\n、いえ、隊長氏のご命令とあらば従うのがくのいちの使命でござるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「うわぁぁ……オチンチン、すごぉい……こ、こんなに熱いんでござるね……\nはぁ、おっぱいがホカホカしちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……こ、このわたしがパイズリだなんて……こんなに大胆なこと、しち\nゃうだなんて……ビックリでござる……ニンニン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ、硬い……おっぱいの中でゴリゴリしてる……それに、こんなに太くて\n逞しい……ああう、棒状のもの、苦手なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「で、でも……拙者に興奮して、こんなになっちゃってるんでござるよね……\n？　それは少しうれしいでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「それで……これは、このギュッと挟み込んだまま、上下に動かせばいいんで\nござるよね？　ううん……上手くできるかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ええっと……とりあえずやってみるでござる！　せぇの……ん、んしょっと\n……こうかな……？　ん、ん、んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　わたし……じゃない、拙者、上手いでござるか？　あはは、ありがと\nうございます……拙者、棒状のものの扱いは慣れてるでござるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……棒……棒状のもの……はぁ、はぁ……棒……い、いえ、なんでもあ\nりません……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ、あの……いかがですか？　隊長氏……気持ちいいでござるか？　あっ、\nありがとう、ございますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ただ、大きいだけのおっぱいなのに……ん、ふぅ……こんなに喜んでいただ\nけるだなんて……光栄でござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ、なんて逞しい……あああん、硬ぁい……はぁ、ふぅ……棒が、谷間の\n中で、気持ちよさそうに震えてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「くんくん……はぁ、オチンチンの匂いがする……少し、臭い……でも、嫌い\nな匂いじゃないでござる……くんくん……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ん、んん……おっぱいが、タプタプ揺れて……オチンチンが一緒に震えてる\n……はぁ、はぁ……あぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んふふ、谷間から赤くて丸い先っちょが顔を覗かせているでござる……ふふ\n、ちょっと可愛い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……んんぅん、ドキドキが止まりません……はぁ、身体が、オ\nチンチンを欲しがっているでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「オチンチンが、ビクビク震えてる……ああん、おっぱいの中で、気持ちよさ\nそうにしてるでござる……はぁ、はぁ……はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　もっと激しく……？　わかったでござる……け、けど……上手くでき\nなかったらごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふく……あぁん、身体が熱いでござる……へ？　汗でビチャビチャ\n……？　し、失礼しました……一旦止めて、汗を拭いてくるでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　そんなことしなくていい？　そ、そうでござるか……じゃ、じゃあ、\nこのまま続けるでござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……挟み込んだまま、こうして……ん、んん……上下に……は\nぁ、あふうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「もっと締め付けるでござるか？　はぁ……ふぅ……わかったでござる……ん\n、んん……はぁ、んん……いかがでござるか？　んはぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「え？　もっと……？　承知したでござるっ……はぁ、はぁ……ん、くぅ……\nあああ、すごぉい……ビクンビクンしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「おっぱいの中で、オチンチン……気持ちよさそうにしてる……はぁ、あぁぁ\nん……興奮、しちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「もうすぐ、イキそうでござるか？　はぁ……はぁ……わかり、ましたでござ\nる……もっと激しくするでござるね……ん、ん、んんん～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ……いかがでござるか？　はぁ……はぁ……気持ちいいでご\nざるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あぁあん……こんなにおっぱいが揺れてる……ちゃぷんちゃぷん、音がしち\nゃうぅ……はぁ、ふぅ……んんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「今、肌の中に、ん、はぁ……おっぱいの中に、オチンチンのビクビクが伝わ\nっています……はぁ……興奮します……ヤバい……これ、ヤバいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んくぅ……あはぁ……隊長氏、エッチな顔してる……はぁ、ふぅ……その顔\n、大好き、かも……あ、ああ、出る……オチンチン、爆発しちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁああん……出てるぅ……あ、ああ……谷間の中で、オチンチンが暴\nれてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……すごぉい……こんなに、ん、んん、精液が……顔に、んぐぅ\n……んぶぅ……んんぅ、ゴクン…………はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……精液がドバドバ溢れてる……駄目、あ、んん……匂いが身体に、\nしみついっひゃう……んんんん……ゴクン……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はー……はー…………隊長氏ぃ……わたし、んふぅ……変に、なっちゃいそ\nう……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ……まだ出てる。ちょろちょろ滲んでる……ふふ、エッチな棒ですね…\n…わたし、気に入っちゃった、かも……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふぅ……オチンチンが……棒が……まだ硬い……あ、はぁ……棒\nが、棒が……こんなにぃ……はぁ、はぁ……あはははははぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「――おい、おいおいおい！　アンタさぁ、処女のあたしに、無茶させんじゃ\nねーってのっ……ったくよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はは、まあいいさ……くんくん……ふぅ、すげぇ匂いだな……とりあえず、\nこのまま続けるぜっ！　オラオラオラァ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふひひ、いい感じだぁ……はぁ、ふぅ……準備運動、バッチリって感じだぜ\nぇ……いい感じに身体が動くぜ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「すー……はー…………変な匂いだな、精液ってのはよぉ……けど、ん、ふぅ\n……頭がボーッとするぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「谷間の中で、ニチャニチャ音がしてやがる……ふぅ……超エロい……聞いて\nて、興奮しちまうぜ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「どうだぁ？　いいリズムだろ？　身体で感じるビートってやつだぁ……これ\nでもプロ志望のドラマーだったもんでね、リズム感には自信があってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「まあ、ンなこと、今となっちゃどうでもいいことだけどよぉ……はぁ、はぁ\n……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「いや、どうでもいいってこたぁねえか……へへ、おかげで戦うことが出来る\nし、こうしてアンタのチンポの世話もできるしな……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふふふ、やっぱ棒を扱わせたら、アタシに勝てるものはいねーよな\n……はぁ、はぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ？　何？　もっと谷間を寄せろぉ？　うっせーな、黙ってろぉ……はぁ\n、ふぅ……好きにさせてもらうぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……身体がヤベェ……燃え上がりそうなぐらい熱い……ん、んん、精液\nが乾いて、ペタペタする……はぁ……変な感じだぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「肌に、チンポが張り付いてくるみてぇだ……ああ、これやべぇ……おっぱい\nの中に、チンポが溶け込んでくるみてぇだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……あああ、この匂いぃ……ん、ふぅ……クラクラする……は\nぁ、ふぅ……子宮が、熱い……マンコの奥で、燃え上がりそうだぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ヤベェ……身体が、精液、欲しがってる……ああ、もっと\n、欲しい……もっと……もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……アンタ、イキそうになってんだろ？　はぁ……ふぅ……い\nいぜ、いつでも……出してくれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「へへ……おらっ、おらおらおらぁぁ……どうだぁ？　アタシの乳マンコ……\n気に入ってくれただろ？　はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「アンタになら……はぁ、はぁ……乳マンコじゃなくって、本物のマンコ、使\nわせてやってもいいぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ああ？　また今度？　チッ……仕方ねえなぁ……はぁ、はぁ……忘れんじゃ\nねーぞぉコラぁ～～……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「おら、もう出そうなんだろ？　はぁ、はぁ……イケっ、イキまくりやがれ…\n…おるぁぁあ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「うぉぉ、めっちゃ出る！！？　んひぃ！　ひゃうぅぅ……な、なんだよっ、\nさっきもタップリ出したじゃねーか……なのに、こんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ん、ふうぅ……胸が溶けるぅ……ああ、体温が染み込んでくるぅ……はぁ、\nはぁ……谷間が精液で埋まっちまったぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んん、はぁ……うう、口の中にどんどん入ってくる……んんんん……ゴクン\n……はへぇぇ……すげー匂い……頭がぼーっと、するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はー……はー……あふぅ……やっと、治まったみてぇだな……ふぅ、アンタ\n、すげーなぁ……流石は隊長氏だぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……精液、ヤベぇ……ドキドキが治まらねぇ……身体が戦闘モードのま\nまだぜぇ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「あ……ああ……精液が、ネットリ滴ってる……はぁ……これ、いいな……肌\nに精液が溶け込んでくるみてぇだ……はー……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「なぁ……約束したからな……はぁ、はぁ……次は、マンコを使ってくれよ…\n…？　絶対だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「へへ、楽しかった……おかげですっかりクノイチ設定を忘れちまったぜ……\nんじゃ、またな。しからばゴメン――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んんんぅ！？　んぐぅ……か、顔が……ううっ、ヤベぇ……目が開かねぇ！\n！　うあぁあ……なんだ、こりゃぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「うぉぉ……顔にぶつかってくる……精液、すげぇな……まるでシャワーだぜ\n……はぁ、はぁ……あうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んんん、鼻が、苦しい……はぁ……はぁ……あああ、口の中に滴って、くる\n……んん、ずるる、んちゅるるる……ゴクン……はへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ん、んん……鼻の中にも、入ってくる……うう、ずずず……ずるるるる……\nんぐぅ……はぁ、はぁ……匂いが、ダイレクトに入ってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……鼻の穴で、妊娠しちまいそうだぜぇ……はー……はー…\n…ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「うあぁ……まだ出てる……顔に擦り付けられてる……ああん、ヌルヌルが、\n顔を滴って……はふぅ……アタシ、今、すげぇ顔してるんだろうなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……やっと、射精が治まったみてーだなぁ……ふぅ、たっぷり出しやが\nって……マジ、遠慮なしかよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はぁ……ヤベェ……戦闘モードから、元に戻らねぇよ……ったく、興奮させ\nすぎだぜぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……なあ、次はマンコを使ってくれよ？　そう約束してくれたよな？　\nな？　よぉし、絶対だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00015402_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「ふぅ……あたし、自分がクノイチだってこと忘れてたぜ……んじゃ、隊長氏\n。拙者はこの辺でおさらばするでござる……しからばゴメン――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_0203410" ]},
		{"command":[ "WAITINPUT" ]},
