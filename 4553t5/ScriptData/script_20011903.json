{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「オラオラぁ！　どうした、フランカっ！　テメェの実力はその程度かっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580001" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「さすがはライオット……中々隙を見せないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580001" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あの４４マグナム、威力高すぎるっての！　あんなの一発でも食らったら、\n即死もいいところだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580001" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「さて、どうしたものか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580002" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そこまでだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカとデビルトンファーが責めあぐねていると、突然大きな声が響いて来\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「市民から通報があって来てみれば……！　こんな街中で銃撃戦など言語道断\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お前たち！　今すぐ銃を下ろし、大人しく投降しろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あん？　あいつは確か、錬金十字騎士団『大いなる秘法（アルス・マグナ）\n』のイグニス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580002" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ちっ……！　とんだ邪魔が入りやがったぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「この街の平和は私が守る！　観念するがいい、悪党どもっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「だーれが悪党だ！　姉御とアタシは正義の味方で、この街を守るヒーローだ\nっての！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580002" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お前たちがヒーローだと？　ふんっ！　笑わせるなっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「市街地で銃撃戦をすれば、市民に被害が出るだろうが！　そんなことも分か\nらない輩に、正義を語る資格などないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「こっちの事情も知らないで、言いたい放題言いやがってっ！　許さねぇぞ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580003" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「本性を現したな、悪党めっ！　我が大剣のサビにしてくれるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580007" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「待ってくれ。できるなら争いではなく、話し合いで解決をしたい。いいだろ\nうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580003" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「話し合いだと……？　ふむ……お前はそいつと違って、話が通じそうだな。\nいいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580008" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だがその前に、まずはその物騒な銃をしまってもらおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「すまない。恩に着る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580004" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカは手にしていた銃をホルダーに収め、投降するように両手を上げる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「ちょ、姉御！？　なにしてるんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580004" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私たちは悪ではなく、正義なんだ。なら、彼女の指示に素直に従え」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580005" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「わかった……姉御がそういうなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580005" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカが武装を解除したのを見て、デビルトンファーもトンファーを下ろす\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その姿を見たライオットも、不満そうな顔をしながら銃をホルダーに収めてい\nく。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それで？　この騒動の原因はなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580010" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ちょっとしたいざこざがあって、喧嘩を売られただけだ。そして私たちは、\n自分の身を守るために行動していたにすぎない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580006" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「つまり、お前たちは被害者だということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580011" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ、そういうことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580007" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「貴方の言う通り、ここで戦えば市民に被害が出る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私が倒すべきは悪であり、それ以外の者……特に市民に被害が出るのは、本\n意ではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なるほどな。お前の考えはわかった。それで？　どういういきさつで喧嘩に\nなったのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580012" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「大したことじゃねぇよ。ちょっとばかし、アタシの実力を思い知らせようと\nしただけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580004" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「なーにが実力を思い知らせるだ！　姉御に一発も当てられなかったクセにっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580006" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あんだとぉ！？　なんなら、今ここでテメェのケツに鉛玉をブチ込んでやっ\nてもいいんだぜ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580005" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「やれるもんならやってみやがれっ！　風穴開けられる前に、アタシのトンフ\nァーでボッコボコにしてやるよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580007" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「やめろ、二人とも。せっかく設けた話し合いの場だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580010" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これは喧嘩にもなるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580013" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「まあいい。とにかく、市街地で争いごとはご法度だ。喧嘩をするなら、もっ\nと人気のないところでやるといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580014" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「クソっ……！　イグニスに言われちゃ、従うしかねぇな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580006" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「彼女のことを知っているのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580011" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ああ、大いなる秘法（アルス・マグナ）のイグニスは、有名人だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580007" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「知っていてもらって光栄だ。では、争いも収まったようだし、私は失礼させ\nてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580015" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って、イグニスが剣を収めた直後……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「へへっ！　姉ちゃん、いい時間稼ぎをしてくれたな！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこに居たのは、先ほどライオットに吹っ飛ばされた悪者だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかも手には爆弾が握られており、今にも投げつけんばかりの形相だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「んなっ！？　あいつ、さっきライオットが吹っ飛ばしたはずじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021580008" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「テメェら！　さっきはよくもやってくれたな！　こいつは礼だ、食らいやが\nれっ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ば、爆弾だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580016" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "イグニスが居る方向へと、爆弾が投げ込まれる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "即座に反応し、回避しようとするイグニスだが……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しまった……！　このまま避ければ、街に被害が出てしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580017" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "イグニスは狼狽え、判断が鈍る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "何とかしようと大剣に手をかけた、次の瞬間……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なっ……！？　爆弾が、空に……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021580018" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「安心しろ。街に被害は出させない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021580012" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「へっ！　こんなしょぼいモンで、アタシたちを吹っ飛ばせるワケねぇだろう\nが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021580008" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカとライオットが同時に銃を撃ち、爆弾を空へと打ち上げる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "爆弾は誰も居ない上空へと飛んだまま、大きな音を立てて爆発していった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
