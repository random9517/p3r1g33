{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「くっそー！　よくも我々の怪獣戦車を壊したな！　おぼえてろーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせー！　先に壊したのはおまえらじゃねえか！　ざまーみろー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……子供のケンカ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、いつものことですからな。お、ごらんください。襲来者（インベーダ\nー）が逃げていきますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく！　いつものことながら、ろくでもない作戦ばかり仕掛けてくるな\n、あいつらは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ま、いいじゃない！　これでまた、模型シミュレーションで遊べるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「はい！　皆さんのおかげです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、ミス・パープル。マシンは直ったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ。ウイルスの元凶が取り除かれましたので、なにも問題はありません。\n明日から営業を再開します。これは、ほんのお礼です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113390002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「なにこれ？　もしかして、タダ券！？　タダ券！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「はい！　おひとり様１枚ずつ、無料招待チケットを差し上げます。どうぞま\nた、遊びに来てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113390003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "と、いうことで翌日。俺たちはそろって地下へとやってきたわけだが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「あ、あのですね？　修羅姫さん？　私はただ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113390004" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そ、そうなんだ！　私はただ、ミス・パープルにそそのかされて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「あ！　ちょっと！　珠魚さん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113390005" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やかましーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル＆珠魚" ]},
		{"command":[ "SETTEXT", "「ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113390002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "3", "CENTER", "300" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だれが言い訳をしろといった！　特に珠魚！　おまえには前回も、学園内で\n妙な商売をするなと言ったはずだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「だ、だから～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113390003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うるさい！　正座、あと１時間追加！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル＆珠魚" ]},
		{"command":[ "SETTEXT", "「ひいいいいいい～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113390004" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "4", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "4", "CENTER", "300" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、こうなる気はしてたんだよな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「関わらないほうがいいね。帰ろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おまえたちも、待て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おまえたち……この前も言ったはずだぞ。とくにカツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やべえ！　来る！　来る！　これは間違いなく来る！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「学園におもちゃを持ち込むなと、何度言ったらわかるんだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113390007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "来たぁあああああーっ！　特大のカミナリーーーーーーっ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、言うわけで。俺たちはそろって修羅姫にこってり絞られ、ミス・パープル\nの『模型シミュレーションセンター』もその日限りで閉鎖となった……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くっそぉ……またこのオチかよ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうしました？　ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「怪獣戦車退治の経費！　ミス・パープルが払ってくれることになってたよな\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういうお話でしたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113390003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でもまだ、俺プラモ代もらってない！　材料費も！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういわれましても。ミス・パープルは当分、学園出入り禁止ですからな。\nどこかで会ったときに請求するしかないのでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113390004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「冗談じゃねえ！　俺は！　今！　現在！　ぜんぜん金がねえんだよ！　ああ\nあああーもうっ！　どうすりゃいいんだーーーーーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、なんと申しますか。戦争とは金ばかりかかって、空しいものです\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113390005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからお前は！　どっかで聞いたセリフでいい話風に締めるんじゃねえええ\nえええええーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
