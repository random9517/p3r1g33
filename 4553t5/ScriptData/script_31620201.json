		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「私を呼び出して何の用だ？　美味なスイーツをくれるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「特製プリンだと！　それは、確かに求めていたもの……！　なに……条件が \nある……なんだ、何でも言ってみろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「私の色々とパワーアップしたところを見せて欲しい……？　ふむ……この部 \n屋で、それを聞くということは……そういうことか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「確かに、まだお前にはどれだけ私がパワーアップしたか、はっきりとは見せ \nていなかったな。いいだろう……特別だぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ……こうして……反対側に跨がればいいんだな……？　むぅ……これは \n、また……何もする前から思い切り大きくさせているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んむ……だが、これをどうすればいいかは本能的に理解している。私に任せ \nておくがいい……んっ、ぴちゃ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「れろ……えろっ、んえろぉ……見ろ……分かりやすく震えている……ちゅぷ \nっ、舌で刺激してやるのがいいんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「このまま、もっと刺激を与えてやるからな……じっくり待っているといい… \n…んっ、ちゅぷっ、んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ！　あっ、んぁっ！　待てっ……お前の舌が……あっ、んぅ \nんっ、私の……筋をくすぐってっ、んくぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「か、感じやすさも……今まで以上にっ……それはっ、あっ、そうかも知れな \nっ……はひぁっ、中に入って……くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふっ……あぁ……はぁぁぁ……ふ、不覚だ……不意打ちだったとは言え、軽 \nく達してしまった……パワーアップしたところを見せる筈だったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「いや、だが別にこれで終わりではないからな。ここから、私の本来の実力を \n見せてやる……はむぅっ、ちゅぷっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「れろ……んりゅっ、じゅぱっ、ふぉら……こうひて……んっ、口の中に咥え \nて……まず……たっぷりと汁を絡ませる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ちゅぷんっ……続けて、りゅぷっ……舌を、れろ……割れている \n所に押し付けて……ろんろん、わらひの汁を塗りこんれいく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……どうら……気持ちいいか？　んふぅっ、んじゅぷっ、じゅぽっ \n、じゅぱっ、くぷっ、んちゅぷっ、りゅぷんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうやらいいみたいだな……聞きたかった余裕のない呻きが漏れて \nきたぞ……？　りゅぱ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「まだまだ、ここからだ……私がどれだけパワーアップしているか……んっ、 \nしっかりとチンポに味わわせてやろう、りゅぷっ、んちゅぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「この赤黒くなっている場所……れろ、んれろぉっ、れろっ、触れるかどうか \nのギリギリの力で……撫でていく……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　んふっ、また……舌が動いて来てる……なるほど、私に一方的 \nに主導権を取らせるつもりはないということか……面白い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ならば……私も遠慮している場合ではないな……んちゅるっ…… \nもっと、積極的にチンポを責めてやらないと……ちゅぷぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んふう……腰が何度も痙攣しているな……んちゅぅぅぅっ、かなり強く吸い \n上げているが……痛みはないな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うむ、ならばいい……なに？　それでも強すぎるのはまずいだと？　だが、 \nこの発汗の仕方は快感を得ている時の反応の筈だが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あっという間に出てしまう……？　ふん、それならば私も先程軽く達したの \nだからな……何も気にすることはないぞ……じゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぉら……んちゅぷっ、れろっ、れる……んれるぅ……んふぅ……どうだ？ \n　情けない声が出ているじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふぅ……その声は好きだぞ。もっと私に聞かせるといい。じゅぽっ、んち \nゅぷっ、ほれ……ここをこうすると出るんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　んぁっ、あっ、んむっ……ま、また……あっ、んむっ、オマ \nンコにっ、舌がっ……く、ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だが……んっ、この程度では止まらない……お互いに……ふぁっ、情けない \n声を出しながらっ……高めあっていく……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁふっ、あぁっ……舌が……奥に入ってくるっ……！　肉壁を……舐めら \nれてっ、からだっ……震えるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んちゅぅぅぅっ……あぁ、んむっ、一番……敏感な場所同士っ… \n…高まって……ふごいっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁっ……ぴちゃぴちゃ……音がなる……興奮を誘う音だ……んんっ、私の \n股間からも汁が溢れて……止まらなくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んちゅぱ……お前もそうなんだな？　射精前に溢れる……腺液が……口の中 \nに広がって来た……そろそろ、出そうなんらな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「もちろん全部理解している……じゅぷっ……全部飲ませてもらう……んじゅ \nるっ、口の中に出すんら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　あっ……あぁっ……わらひの……オマンコもっ、同時にっ…… \nイキそうらっ……ふっ、んぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「それでもいいっ！　さあっ……このままっ、イッてっ……出してっ……くれ \nっ、じゅぷっ、んちゅうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んむぅぅぅぅっ！　んぐっ、んんっ……ふっ、れてっ……来たっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「口の中が……んんっ、じゅるっ、ドロドロのでいっぱいになってる……んぐ \nっ、こくっ、んくんっ……ふごい量ら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んちゅぅぅっ……ふはぁ……そうら、この味ぃ……んふっ、これ \nを美味しく感じられるのも……私のパワーアップの一つら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、はふ……見ろ……出した分、残したりすることもなく、全部飲ん \nでしまったぞ……どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「イキながら……飲んだ？　むぅ……ま、まあ、そうだな。確かに私もイッた \nことは間違いない。それは認めなくもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だが、大事なのは私がパワーアップしたところだ。ちゃんと理解したか？　 \nうむ、それならいいのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「さて……お前は射精一度で終わりになるようなタマではなかったな。このま \nま続行して問題ないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「私としても、お前の情けない声が好きだからな。もっと、それを身体に染み \n込ませておきたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ……逃さないぞ。はぁんむ……ちゅぱっ、さあ……二回戦の……始まり \nら……じゅぽっ、ちゅぷ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「りゅぷんっ、じゅぷっ……ちゅぱっ……んんっ……さっき出した精液の味が \n……いっぱい残ってる……じゅぽっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁっ……ふっ！？　私も……だと？　んっ……オマンコから出た……愛液 \nの味が……いっぱいする……そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「なるほど……自分の状態を指摘される羞恥は……快感に繋がりやすいのだな \n……新たな学びだ……はっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……舌が心地いい……そこの襞の連なるところを舐められると……内側 \nから、じゅわりと……汁が湧き上がるのを感じる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、んんっ！　もっと、もっとして欲しいぞ……私も、お返しするか \nらな……くぽっ、んむっ、ちゅぷぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「こうひてっ……口いっぱいに頬張って……吸い上げ……ずぞぞっ、ぷじゅっ \n……んじゅぅっ、じゅるるっ、んじゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んふふ……気持ちいいみたいだな……よし、もっとしてやるぞ……お前の弱 \nいところを集中的にしてやるからな……んちゅっ、ちゅうぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「どうした？　この程度のチンポ責めで、そんなに腰を引いてしまうのか？　 \n私に負けてしまってもいいんらな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　じゅぷっ、りゅぷっ……んふっ、もうオマンコへの反撃も予 \n測済みだ。その程度の刺激では……んひゃいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……んんっ、い、今のはっ……あぅんっ、はっ、ひっ……クリ……ク \nリトリスっ？　さっきまで……そんな場所……全然……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「と、とっておきっ……んんっ……な、生意気なことぉっ……！　私はっ、そ \nんなのに負けないっ、じゅるっ、ちゅぷっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……！　あっ、んむっ、腰に……力が入らない……んくぅ、こ、こ \nのままでは……だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そっちがそうなら……れろっ、んりゅっ、私は……ちゅぷっ……このタマを \n責めるぞ……いいんらなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、あむ……このふにふにした場所を……唇ではむはむしてぇ……ん \nぅ、ちゅぷ……むぐ……りゅぷ、ちゅぱっ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「見ろ……ふるえてりゅぞっ！　これれ、わらひもっ……んんっ、お前をイカ \nせてやるからなっ、んんっ、くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ふぉら……チンポっ、もう限界なんらろっ？　んんっ、オ、オマ \nンコもっ……もうギリギリれっ、んむぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んじゅぷっ……出して……しまえっ、ふぉらっ……射精っ、するんらっ、ん \nっ、じゅぷっ、ちゅぷぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んむぅぅぅっ……！　あぷっ、はぁっ……んんっ、また……いっぱいれてっ \n……んぐっ、こくっ、んくっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「大丈夫だ……んんっ、全部……飲むっ……これも私のパワーアップしたとこ \nろなのだからな……んっ、うぅんっ、けほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「問題ない……私も一緒にイッたからな……それで、ちょっとむせただけだ… \n…んちゅっ、ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぉら……ちゃんと全部飲んだらろ……？　わらひの優秀さが……少しは分 \nかった筈だ……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、たっぷり射精させて……それを飲んで……りゅぷっ、後始末まで完 \n璧にしてるんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「何……感じやすさもパワーアップしていた？　むぅ……ま、まぁ、そうだな \n……そういう一面もあることはあるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「可愛さも……う、うむ。まあ、そうだな。エッチな声も……うむ。乱れた表 \n情も……も、もういい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「フン……それなら私にもお前のイッた時の声の可愛らしさや、ちょっと変な \n顔になるところが好きだと言っておくぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「他にも、最後は優しく舐めてくれるところとか……ちゃんと身体を支えてく \nれるところとか……普段はおやつをくれるところとか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「恥ずかしくなってきた……？　ふふん、ならば勝負は私の勝ちだな。また、 \nいつでも相手をしてやるから、掛かってくるといいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ひゃあぅっ！　んぁっ……顔にっ、掛けられてっ、んぁっ、はぷっ、んんっ \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「大丈夫だ……少しびっくりしただけで、これも想定したものだ……顔面シャ \nワーというやつだろう……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「パワーアップした私が……全部、受け止めてみせるぞ……んぁふっ……もっ \nと出してしまえ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁ……びゅるびゅる……出てる……粘っこいのがいっぱいへばりついて… \n…あったかいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はふ……終わったか……んっ、顔がベトベトだ……私も、一緒にイッてしま \nって……まだ少し頭がボーっとしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だが、これで分かっただろう。私がどれだけパワーアップしたのか。ふふん \n……どうした、驚きに声も出ないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「乱れ声もパワーアップ……そ、そこはついでだ。ちゃんとお前のチンポにし \nてやったテクニックのことを考えていればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そうだ。だが、あれで私の実力が全てだと思わないことだな。まだまだ、本 \n気を出せばすごいことになるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「また見たい？　ふん……そうだな。私も忙しい身だからな。おいそれと、約 \n束することはできないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「何っ、限定スイーツの詰め合わせだと！　いつだっ、次はいつすればいい？ \n　いいぞ、今これからするかっ？」", "NORMAL" ]},
