{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「３日目の東ホールのような暑さと湿気。お肌に赤い刺し傷をつけてしまう虫\nども。緑に塗りこめられてはいるが、ここも地獄に違いない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021420001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）の襲撃から脱出したカツマたちにとっても、その湿\n地帯は天国とは言い難かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021420002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……暑い……一歩踏み出すごとに、体力を奪われるような気がします…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「きゃっ！　泥が！　あああああ、髪にべったり付いちゃった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あれ？　向こうでなにか動いたような……ひいいいいーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「どうしたんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ワ、ワニですっ！　でっかいワニっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021420002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「おちついて。今は空腹じゃないみたい。下手に刺激しなければ、なにも……\nあら？　どうしてワニが慌てて逃げていくの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「っ！？　隠れろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エフュサスの号令で、全員が慌てて木の影に飛び込む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「うわあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "誰かが慌てて沼の中で転倒したようだが、それでもどうにか、飛んできた光線\nの直撃は避けられた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「くそっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021420002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エフュサスがとっさに撃ち返したが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「外れたか……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「外してはいない。相手の姿が見えないので、確認できないだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021420003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「姿が見えないって！？　どういうことッスか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021420002" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「体を透明化できる装備を使っている、ということ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021420002" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「いや、特殊な訓練を受けた襲来者（インベーダー）なんだよ、きっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021420001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ん……？　ちょっと待て、みんな。あれを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021420004" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言って、エフュサスは大木の陰を指さす。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこからは、襲来者（インベーダー）の尻がのぞいている。今の攻撃で、一部\nだけ透明化が切れてしまったのに気づいていないようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あららら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021420002" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「頭隠して、尻隠さずですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021420002" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「尻が出るなら、倒せるはずだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021420005" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「見えない襲来者（インベーダー）は撃退した。しかしビキニ装備には意外な\n弱点が。敵の目を避けつつ、潜入作戦は続く」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021420003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「誰がビキニを望んだのか。それは言わないお約束。今はただ、露出度を高め\nて駆け抜けなければならない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021420004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「次回『戦場はどうや』。Ｎｏｔ　ｅｖｅｎ　ｊａｓｔｉｃｅ，Ｉｗａｎｔ　\nｔｏ　ｗｅａｒ　ｂｉｋｉｎｉ！　真実は見えるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021420005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}