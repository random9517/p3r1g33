{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「トキノどのに急かされながら、わたくしたち一行は正義へとやってきたので\nありました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いらっしゃ……って、うわっ、カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "店に入った途端、ほむらが目を丸くした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どうなってんだよ……。カツマが、知らない女を連れて店に来るなんて……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「もしかして、明日には人類が滅亡するんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなわけあるか！　この人はトキノさん、新入りらしい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「よろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430001" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうなのか？　新入りが入るなんて連絡、きてたっけかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「せ、正式に名簿に入っていないだけだ。それより、カツマのおすすめがこの\n店なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430002" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　まあな。けっこう美味いぞ、値段もリーズナブルだしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほむらの接客態度が悪い以外は完璧だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、ケンカ売ってんのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「うむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430003" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「てめぇっ、冷やかしに来たんじゃねーだろうな！？　さっさと席ついて注文\nしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正義のメニューを見てみると、いつの間にかメニューが増えていた。デザート\n系が充実している。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつの間にこんなにスイーツが増えたんだ？　パンケーキとか居酒屋で頼む\nもんじゃないだろ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、そうかもしれねーけど、イグニスがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほむらの作る甘味も美味しいのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「イグニスどのに頼まれて、スイーツをメニューに追加したってことですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、そんなところだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「学園祭の一件で、正義に学生も顔を出すようになったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430002" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「学生向けにスイーツを用意しようと進言したのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「本当はイグニスが食べたいだけのような気もしたんだが、まあ、確かに一定\nの需要はあったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふうん……。あ、炎のパンケーキって、俺たちが学園祭で作ろうとしたやつ\nじゃねーか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いいだろ。アイデアの出どころは俺だからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私のおすすめでもあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430004" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「パンケーキ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430004" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そこの嬢さんはパンケーキを食べたことがないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「うむ……。私にとっては、必要がないと思っていたからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430005" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それはもったいない！　食はなによりも大事なものです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430005" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「お……おう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430006" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぐいっと迫るイグニスに、トキノさんは若干引いていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「では、食べてみるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ぜひ食べてください。カツマさんのおごりで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430006" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が金払うのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、あんなデートみたいな雰囲気で来店したんだ。ここはカツマの支払い\nだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「し、心配はいらないぞ。私が払ってもいい。私が食べたいと言ったのだから\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430008" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいおい、隊長のくせに新入りに払わせるのかー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115430013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、ご主人の甲斐性では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああわかったよ！　俺が払えばいいんだろ！　炎のパンケーキひとつ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、わたくしの分は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115430004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あるわけねぇだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "それからしばらくして炎のパンケーキがやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうそう、パンケーキの上に生クリーム、イチゴとベリーソースで炎が描かれ\nている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園祭のグルメコンテストではこいつを作ろうとしたんだが、グレーテルのカ\nレーのせいでできなかったんだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "パンケーキはとても厚く、ふわふわだ。流々那も上手だったが、ほむらはさす\nがプロだな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「これは……美味しそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430009" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうでしょう。きっと気に入ると思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430007" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「では…………あむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430010" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ふむ……うまい。なるほど、こういったものも、確かに必要だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430011" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうでしょう、そうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010115430008" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "パンケーキを食べているトキノさんの所作は、とても優雅だった。もしかして\n、本当はどこかのお姫様とか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「カツマ、なにを見ている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430012" ]},
		{"command":[ "SETCHARA", "0", "char_00020102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、すみません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "食べているところを見つめているのは、失礼だったな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0199" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「……カツマにも分けてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "パンケーキを一口大に切って、トキノさんが差し出す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ほら、あーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いいんですか？　少し恥ずかしいというか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「なに、よいではないか。ほら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、あー……ん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ふふ、どうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うん……うまい……っす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "正直、周りに見られながら『あーん』とされることの気恥ずかしさが勝って、\n味なんてよくわからない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、なんだろう。トキノさんにこうされると、妙ななつかしさが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "母性……。たしかに感じる……。吹いてきてる……トキノさんの方から、俺に\n向かって、母性の風が……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ふふっ、もう一口食べるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430017" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいんすか？　じゃあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結局、俺がパンケーキを半分ほど食べてしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "「ごちそうさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115430018" ]},
