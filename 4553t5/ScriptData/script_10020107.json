{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……いいかげんに……おとなしくしろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「落ち着いてくれ！　ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわぁああああ～ん！　放せ、放せぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大乱闘の末、どうにか俺たちはルナテミスを取り押さえたが……彼女はまだ、\n泣きわめいてジタバタ暴れている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな彼女に冴島長官が歩み寄り――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いいかげんにしろ！　いや……いいかげんにしてください！　ルナテミス王\n女！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "「王女」と呼ばれたルナテミスは、驚いた様子で長官を見上げる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ルナテミス王女……私だって、こんなことは言いたくないのです。しかし…\n…言わないわけにもいかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「自分の身を犠牲にしてまで、我々を、そして国民たちを守ったルナルバース\n陛下のためにも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「母上様の……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113070003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうです。ルナルバース陛下なき今、Ｇ・ルナリアムを建て直すのはあなた\nの役目ではありませんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それなのに、このようなことで……そして、このような成績で……陛下が安\n心して眠れるとお思いですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は、母上……母上様……！　うっ、うっ……ううううううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113070004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「しっかりしてください、ルナテミス王女。我々は、決してあなたが憎くて、\nこんなことをしているのではありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ルナルバース陛下に負けない、立派な女王になってほしい。その思いで我々\nはあえて、あなたに厳しく当たっているんです。ですから――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぁああああ……母上様、母上様ぁあああ……うううううううっ……ぐすっ\n……ぐすん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113070005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官の話を聞いていたルナテミスは泣きながら、その場にへなへなと座り込ん\nでしまう。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「長官……どうか、それぐらいにしてやってほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090113070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだな……部屋に連れていってやってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザーはうなずくと、泣きじゃくるルナテミスを抱きかかえるようにして学\n生寮へと連れていく", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官はそんな二人が、体育館を出ていくのを見届けると……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さて！　問題の勝負のやりかただが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やるんかい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "思わずツッコまずにはいられなかった。さっきのしんみりした空気はなんだっ\nたの！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、ルナテミスの成績を、どうにかしなけりゃならんのは事実だからなぁ\n。それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「このままではＧ・ルナリアム側にもブラックメルヘン側にも、モヤモヤが残\nるだろう？　こういうのは、勝負をつけて発散したほうがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010113070011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃそうでしょうけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こちらとしては異存はないぞ。で？　どのように勝負をつけるつもりだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113070002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "……と、いうことで双方話し合い、「教育バトル」のルールが決まった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "ブラックメルヘン側は修羅姫こと明日楽が担当する古文で。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わ、私が……助手ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "Ｇ・ルナリアムは、エファの担当する数学で。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やるからには、１００点を目指すわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんが手伝うのぉ……？　やぁん……めんどくさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "２週間後にそれぞれの担当教科で小テストを行い、ルナテミスがいい点数をと\nった方が勝ち。ただし両方６０点以下、あるいは同点なら再試合。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というルールだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いったい、どうなるんでしょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113070002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ほんとよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まったくだ……今回ばかりは、この２人にまったく同感だぜ……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はぁ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}