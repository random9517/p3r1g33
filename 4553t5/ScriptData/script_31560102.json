{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長……あ、あのだな……。１つ、こちらの宇宙のことを教えてほしいんだ\nが……。今、時間は空いているか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ありがとう。それで聞きたいこと、なんだが……数日前からずっと、妙に股\n間が濡れて仕方ないんだ。乳頭もずっと硬いままで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「全身が過敏になってしまっているというか、頭もボーッとして。こんなこと\nは今までなくて……。自分でも色々と考えて対処してみたんだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「どうにもこれは、隊長が近くにいる時にひどくなるようなんだ。私は今まで\n、男の近くにいたことがないからこれが何かわからないんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまえにはこの理由がわかるか……？　って、うわっ！　な、なんだっ！　\nいきなり私を押し倒して……あっ！？　な、なぜチンポを出す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015601_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の今の状態は……発情？　この火照りを冷ますには、こうするしかない？\n　ほ、本当なのか……？　だ、だが、こんな格好……変だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それにチンポが、た、隊長のチンポが大きくなっているし……。私の尻に当\nたっていて……これでは冷めるどころか、なんだか……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長を信じて任せるのは構わないが、……し、信じていいんだろうな？　な\nるほど……し、尻っ、尻でチンポをシゴくと楽になるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そんなこと、自分で思いつくはずもなかったから助かった。……んっ……！\n　チンポはすごいな、……あっ、こう？　こうか、尻で……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んひっ……ンンンッ！　な、なあ……？　なんか逆に、身体が疼いて……全\n然冷めないどころか、燃えてきたような気がするんだが……あっ！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「もっと即効性のある方法はないのか？　……ある？　なら、……あっ！　チ\nンポを尻にこすりつけずに、あっ、そ、ソレを頼むぅ……あううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ！？　チンポをどうするんだ？　あっ……ちょ、ちょっと待ってくれ、\nそこはっ……そっちは！　……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うあああああああっ！？　おまんこっ、お、おまんこ、にチンポが無理やり\n入って……！　あっ！　い、痛いっ、痛い、いたいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ぬ、抜いてくれっ、わ、私はそこに触ったこともないっ！　ましてや何かを\n入れるなんて……ああっ！　無理、無理だ、チンポは大きいからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「大きなモノっ……入らないから……！　っああああっ！　お、奥まで入れる\nなっ、入らない……あっ！　うっ、ぁっあっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「だ、だめだ、駄目……。んっ！？　痛みを和らげるにはスパンキングがいい\n？　す、すぱんきんぐ？　また知らない言葉だっ、やだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んああああっ！？　どうして私の尻を叩く、んだぁ……あっ！　あっ！　隊\n長はっ、隊長はおかしなことばかりする……んあっ！　あっ、駄目だぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「尻っ……尻叩かないでくれっ……！　あっ！　それにチンポッ……チンポが\n太すぎて……アソコが痛いぃ……あっ！　あっ！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ううううっ……！　も、もうワケがわからない……あっ！　火照りっ、疼き\nを止めて欲しいだけだったのに……うううっ……！　あああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お……俺を信じろ？　本当に、本当にコレが疼きを止める方法なんだよな…\n…？　し、信じるぞ、信じる、けど……！　あっ！　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「確かにな、なんだか……。尻をぶたれるたびに、アソコが濡れて……チンポ\nの圧迫感が薄れていくような気もしなくない……。でも……あぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「な、なんか屈辱的ぃっ！　なんだがぁっ！　あぁ！　痛いぃっ！　尻っ、尻\nが熱い……あんまりぶたないでくれぇっ！　あ！　あっ！　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「尻が痛い時にはオマンコを刺激するとだんだん気持ち良くなってくる……？\n　えっ……う、動くのかっ……！　私、私は初めてなんだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまんこにチンポを入れて動かす、なんて……未経験なんだ！　あっ……♪\n　んッ……あっ……！　こ、怖い……でも……でも、でも……ひぅっああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「しんじ、る……隊長を信じる、しんじ……るぅ……！　あっ！？　あっ、あ\nっ、あっ……チンポ……チンポ、中で動いてる、動いてるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「このっ、じゅわじゅわ奥がっ……オマンコの奥が潤んでくる感じ、これが気\n持ちいいって……ことなのか？　ぶたれた尻と、オマンコが熱いぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あッ……あっあっあぁっ！？　あぁっ……はぁっ、はぁあっ……あぁっ！　\n中で、中で動いている……！　は、激しいぃ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「う、くぅううっ……くふぅううっ……！　あっ！　あぁっ……た、隊長……\n！　すまない、な……私のために身体を張って助けてくれ、て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私は……あああっ！　私は嬉しいよッ……！　あり、がとう……ありがとう\nっ！　あぅっ！　チ、チンポ……デカくて気持ちいいよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまえが協力してくれるから……んぅううっ！　火照りっ、火照りが気にな\nらなくなってきた……意識が全部、尻とマンコに集中して……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「すごく、スゴくイイよぉ……感じるぅ……！　あぁっ、もっと、もっと尻を\n叩いてくれ、それで……それでオマンコほじって……んぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「きゃうっ！　あうっ！　あううっ！　そうだよっ、そうやってスパンキング\nしながらアソコを突いて、突いて突きまくっておくれ……！　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うぁっ……あああっ！　んっ！？　な、なんだ！？　何か言ったか！？　オ\nマンコのヒダヒダがチンポを締めつけている？　い、言うなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私は今絶頂した？　そ、そうなのか？　これが絶頂……？　あっ……！　強\n烈な体験だけど、い、イヤじゃない……むしろ心地よくて……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「絶頂……絶頂を何度もすると、火照りが、疼きが消えるんだな！？　そ、そ\nういう仕組みだったのか……。隊長、おまえは賢くて凄いぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そうとわかれば、私はおまえにもっと絶頂させてほしい……！　あっ、チン\nポ、チンポもっと入れてくれっ、尻もたくさんぶって……。っんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あぁっ、アァッ、あぁっ……！　気持ち、いい……気持ちいい\n！　全身がカァッとなって……戦闘中みたいに興奮して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまんこと尻から、気持ちいいのだけが伝わってくる……！　あっ！　あっ\n！　隊長っ、隊長のチンポと手、すごいっ、すごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「スゴくいぃい……！　はぁああっ！　あああっ！　あっ！　あっあっ！　絶\n頂するぅ！　私、絶頂しまくって……あんっ、オマンコ締めちまうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「いいっ、いいよ……！　隊長、隊長のチンポもなんか、調子いいじゃないか\n……どんどん太くなって、おまんこ突いてくる……。ンッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あはッ！？　な、なんだこれっ！？　なにっ！？　今なんか……マンコの奥\nにブビュブビュってなんか出たぁ……！　あっ！？　あっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「今のっ……すごく気持ち良かった。まだ出るか？　ああっ……出して、出し\nてくれぇ……ソレ、好きだから……もっと欲しい、欲しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あああああ～っ……♪　あああああっ、んぁあああああ……♪　しゃせい？\n　射精っていうのか、コレぇ……好きだ、しゃせい、好き、好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「せいえきがマンコの中で出ると、こんなにイイなんて……！　あっ！　あっ\n、いいぞ、しゃせい、一回でも多くしてほしい、しゃせいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……うん、うん、わかってきた……。隊長の言う事は大体正しいんだ。すぱ\nんきんぐもチンポ入れるのも、しゃせいも気持ちイイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ♪　こ、このまま抜かずの二発目を出してもいいか？　いっ、いいに決\nまってる……！　私もそうしてほしい、あっ、協力するから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「出来るだけマンコの中っ、奥にせいえきをしゃせいしてくれ……！　あ♪　\nマンコ、マンコをきゅーっと締めるとしゃせいしたくなるんだったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ……こう？　こうか？　こうやって、下っ腹に力をこめて……。んうう\nうっ！　コレッ、コレ、私も感じるぞ、あぁ♪　これすごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「たくさんしたい……！　ンンッ……わ、私も尻を揺らせばもっと摩擦が起こ\nるだろうっ？　……こうやって、ぐいっ……ぐい、ぐいってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……ああっ……♪　二人のリズムがうまくカチ合うと、気持ちいいのがあが\nってくるぅう……！　オマンコぎゅんぎゅん締まっちまうぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ッあぁああっ♪　隊長……隊長、隊長……！　出来るだけたっくさんせいえ\nき作っておくれよ……！　私、全部もらうからさ……はぁっ、はぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「た～っぷり溜めて……限界まで溜めてビューッて中に出してもらうんだ……\n！　そうすれば、絶対気持ちいい、最高に気持ち良くなれる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そうだよねぇ……？　んっ……いっち、にぃ……いっちにぃ……アアアアッ\n♪　やっぱりそうだぁ……！　我慢して、我慢して最後に解放するっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「修行と同じだよっ、せいえきは溜め続けるとぉ……。あっ♪　チンポが硬く\n、強くなってくんだ……！　私、今のっ、今の太いのがイイっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「太いのでオマンコ、ズコズコ突き上げられるとたまんないんだよッ♪　あ～\nっ……コレッ……ハマっちまいそうだ……あっ、あっ、すごくイイっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「好き、だよ……！　あうっ！　一番深いとこっ、奥の奥をズンズン貫かれる\nのぉおお……！　クセになるぅっ……！　オマンコうねっちまうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こ……こんないいことを教えてくれるなんて、隊長は神サマ、みたいだよ…\n…！　っあっ♪　あっ、いいよっ、せいえき溜まってきたかいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「わた……し、私もまた絶頂キメる寸前だぁっ……♪　んっ？　イク？　絶頂\nのことをイクっていうのかい？　あっ、イクって言うと気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「わ、わかった……絶頂する時は、……あぁっ♪　ちゃんと言うよぉっ……イ\nクッ♪　イクイクぅっ！　私のオマンコイクよぉっ、隊長ぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あはっ♪　隊長もせいえき限界みたいだねぇ……いいよっ！　二度目の発射\n、しゃせいを頼むよ！　景気よく派手に……！　んぁああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「くふぁあああああっ♪　あはああぁっ♪　キたキたぁあ♪　最強に勢いづい\nたしゃせい……しゃせいでイクッ♪　イクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「これっ、やっぱりキくよぉおおお……♪　あはっ、あははっ♪　隊長……！\n　ギリッギリまで溜めた甲斐あったねぇ、すっごい出てる、出てるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ご褒美みたいに出てるよォ……！　あッ……♪　あっあっはぁああっ♪　あ\nっつい……！　マグマみたいにドッロドロ……最高だぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あッ、ちょ、ちょっと待ってくれないか……！？　私のオマンコでギュウッ\nと搾り上げてみせるよ……。ンン～～～っ……あぁっ、どうだいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チンポの根元から先の先までせいえき、取れるだけ取ってやったよ……♪　\nはぁああっ……はぁああ～♪　確かに火照りに、疼きにキいてくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の全身から湯気があがっちまってるぅ……♪　なんか、頭もスッキリして\n……。この宇宙の絶頂や射精ってのは万能なんだねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ健康になったってカンジがするよ。アハハッ、こんなにいいも\nのなんだったら、もっと早くにお願いすればよかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……こ、今度はもっとスパンキングの回数を増やしてみるか\nい？　今、私からはよく見えないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あんだけ叩けば、尻も結構赤く腫れてるんだろう？　次は……白いトコロが\nなくなるくらい叩いてもいいよ。そうしたら……ハハハッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「な、なんだか次のことを想像しただけでまた濡れてきちまった……。疼くた\nびにコレが出来るなら、こっちの宇宙に来られて良かったかも……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あぁあっ！　イクぅ～……って、えっ！？　な、なんでだいっ……なんでオ\nマンコにしゃせいしないんだいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うぁっ……！　スパンキングされた尻にしゃせい……！？　あふっ！？　あ\nふっ……あああっ！　な、なんだかヒリヒリするぅ……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あぁ……こんなにベットリせいえきぶっかけて……。んっ？　まだ出るのか\nい？　そりゃあ、あんだけ溜めればそうかぁ……いいよ、かけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……ンッ……♪　んっんんっ……♪　あはっ……尻が真っ白に染まっちまっ\nたよ……。でも、惜しいなぁ……せっかく溜めたせいえきが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ああ、いや……コレはコレでいいモンだよ？　確かに火照りも、疼きも止ま\nったし……。まだ少し熱はあるけど、身体が軽くなったのがわかる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ただ……。一度目にオマンコに強引に流し込まれたせいえきが、どうにも忘\nれられないのさ……。アレは良かった。常識がブッ飛ぶ威力があった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の知ってる宇宙の秘密なんか、全部凌駕するくらいの強い一撃……。はぁ\nあっ♪　ねぇ……今度は、次は二度目もオマンコに出しておくれよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「どうせ疼きを解消してもらうんなら、より気持ちイイやり方の方がお得じゃ\nないか……。それとも何かい、オマンコよりスゴいのがまだあるって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ええっ……！？　アナルにフェラにイラマチオ、手コキにマンズリ素股にコ\nスプレ？　ま、待っておくれ、一度にたくさん言われても困るよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「わ、わかったよ……。隊長のオススメなら間違いなく気持ちイイんだろうさ\n……。好きなヤツから試せばいい。私も楽しみにしておくよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0104410" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
