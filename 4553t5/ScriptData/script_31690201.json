		{"command":[ "PLAYVOICE", "v2_169_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あなたも……出して下さいっ、太いオチンポからっ……熱くて濃い精液っ…\n…またビュルって出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「このままおっぱいでもっ……お顔でもいいですからっ、あぁっ……わたくし\nもっ、オマンコッ……また、イキっ……ますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁんっ！　イクッ、あっ、イクゥっ！　おっぱいマンコに中出\nしされてますっ、熱いのっ……出てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……びゅくびゅくって……おっぱいの中が……新しい精液でドロド\nロにされていきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……おっぱいとオマンコ……両方でイッてしまうなんて……んふぁ\n……お肌がずっとピリピリしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んくっ……まだオマンコの中のディルドーがみっちり詰まってて……こ、腰\n……持ち上がらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「とにかく……これで、妹を解放してくれるんですね……え……あ、も、もう\n、お芝居は終わりでいいのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「え、演技とは思えない臨場感……す、すみません。何というか、途中から本\n当にそんな気分になってしまいまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「乱れ方も色っぽく……も、もう……やめて下さい、ご主人……改まって言わ\nれますと……顔から火が出るほど恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「でも、ご主人のオチンポも、こんなに沢山射精なさって……これは、わたく\nしの姿で興奮してくださった証ですよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んふっ、ちゅぷっ……精液の味もとっても濃厚で……れろ……こんな風にの\nめり込めるなら……またしてみてもいいかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「その時は……また、わたくしを拘束して……すごいこと……して、下さいね\n……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁんっ！　イクッ、イキますっ、顔にっ……いっぱい掛けられて\nぇっ、わたくしもっ……またイクぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぷっ……んんっ、あぁ……精液の匂いが凄い……んくぅ……べっ\nとりへばり付いて、嗅いでいるだけで……また……んっ、イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、れろ……あぁ……粘りついて来ます……髪の毛にも絡\nんで……お肌にも染み込んでしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ……まだ飛んでくる……はぁ……んふっ、ドロドロになってい\nくぅ……気持ち……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016902_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「……んっ、ふっ……あ……これで、一段落なのですか……えっと、お芝居も\n終わりで……は、はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「途中から本気に……あぅっ……その、本当に囚われの身になってしまったよ\nうな感覚でした……もっと自分を強く持たなくては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ビキニアーマーに合っていました……か。この姿は色々と思う所があるので\nすが……ご主人が喜んで下さったのなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はい、確かに……オチンポ……沢山射精頂いて……んふっ、まだ先端の方に\nもついてますね……わたくしのおっぱいに擦り付けて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あふっ……ありがとうございます……んふっ、自分でもここまで感じてしま\nうとは思いませんでした。何というか、癖になってしまいそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もし、また次の機会がありましたら………また、わたくしを拘束なさって…\n…色々……して下さいませ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}