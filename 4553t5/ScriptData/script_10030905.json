		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「実は、刻蹄館塾に通っていたほかのみんなも、ルルーナさんたちと同じよう\nな状態なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850006" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「塾で習ったらしいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115850001" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「なんだか記憶が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020115850001" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「うーん……というか塾でどういう勉強していたっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030115850001" ]},
		{"command":[ "SETCHARA", "0", "char_00002302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いやいや、そこまで覚えてないの？　大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850007" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「塾での勉強なんて、みんなで机に座って先生の話を聞くとかそういうのじゃ\nないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロックの部下" ]},
		{"command":[ "SETTEXT", "「ああ、そうだった……そうだった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115850002" ]},
		{"command":[ "SETCHARA", "0", "char_00001902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラの部下" ]},
		{"command":[ "SETTEXT", "「わたしに聞かれても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020115850002" ]},
		{"command":[ "SETCHARA", "0", "char_00002102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーンの部下" ]},
		{"command":[ "SETTEXT", "「ルルーナさん、どう思います？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030115850002" ]},
		{"command":[ "SETCHARA", "0", "char_00002302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さて……どうだったかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115850003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いったいどうなっているのよ桃花ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115850003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「わたしに聞かれても知らないわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850009" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0164" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「……ということがあったんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、だいたいわかったが、それってただあいつらがニワトリ並みの頭なだ\nけじゃねーのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どんな教育してんのかしらねーけど、詰め込み教育したってすぐ忘れるんだ\nよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうだとしたら、余計心配です。あのルルーナさんとマーガレットさんが、\n大人しく詰め込み教育を受けるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「桃花さんとの勉強会でも途中で暴れだすほどだったのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……私、そんなに詰め込み教育してた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850010" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあそうかもしれないけど、きっと教師の腕がいいんだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あいつらが暴れださないほど上手に教えられるなんて、そんな教師の顔を一度\n見てみたいものだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「むぅ……。じゃあ、わたしだけで塾のこと調べます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850006" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、夜日楽！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ああもう、変なところで頑固なんだから……。ちょっと、カツマさんも協力\nしてよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850011" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでだよ！　どうせあいつらのことだから３歩進んで４歩下がってるんだ\nろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なんで後退してるのよ！　とにかく、夜日楽を一人で行かせるわけにはいか\nないでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ちょっと調べたら満足すると思うから、さっさと済ませちゃいましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850013" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しょうがないなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0028" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "結局、俺は桃花に連れられて夜日楽のあとを追った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "塾の近くまでやってくると、夜日楽が塾に入ろうとしているところだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「夜日楽、待って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850014" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「桃花さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850007" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ちょっとこっちにきて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850015" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ええっ、あっ、えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850008" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜日楽を塾から引き離し、少し離れた場所で作戦会議を開く。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「まったく……なにをしようとしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850016" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「なにって……塾の生徒として潜入して、秘密を暴いてやろうと思ったんです\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850009" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「もしルルーナさんたちになにかあったら、救出もしようと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いやいや、そういう作戦って大抵失敗するよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850017" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115850011" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、まずは張り込んで、塾にどんな人が出入りしているか調べてみようぜ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この塾に問題があるのなら、怪しい人物のひとりやふたり紛れ込んでいる……\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ！　ちょっとカツマさん見て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115850018" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ……って、時間帝国の兵士じゃねーか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵" ]},
		{"command":[ "SETTEXT", "「むむっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040115850001" ]},
