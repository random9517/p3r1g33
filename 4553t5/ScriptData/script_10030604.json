		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そういうクロちゃんが一番楽しそうじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115400002" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そんなことないぞ！　ほら、はやく女王様を見つけなければ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115400002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「見つけるって言っても、どこにいるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115400002" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それっぽい気配が感じられればいいんだけど……」", "NORMAL" ]},
