		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こ、こらこら、ふたりとも。観光に来たのでは、な、ないんだからな？」", "NORMAL" ]},
