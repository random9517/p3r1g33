		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "通行人２" ]},
		{"command":[ "SETTEXT", "「あの耳！　エルフだ！　はじめて見た！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "通行人３" ]},
		{"command":[ "SETTEXT", "「あの格好、まさしくドスケベダークエルフよっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「なっ、またドスケベダークエルフだと！？　や……やはりそう見えるのか…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_010115400003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふーん。もしかして地球の人って、みんなそういうこと考えちゃうの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010115400003" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはは☆　んじゃあ、きちんと挨拶しちゃおっか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115400004" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
