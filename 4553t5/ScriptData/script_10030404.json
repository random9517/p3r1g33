{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……というわけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なるほどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「宝箱を持つタヌキ像とかいうのを探すのを手伝ってほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まかせてくれたまえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「即答だな。頼もしい限りではあるが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「今の僕の懐事情だと、依頼をえり好みしている余裕なんてないからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ……そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「この時の僕は、まさかあんな恐ろしい事件に発展するなんて考えてもいなか\nった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだその意味深なナレーションは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ちょっと気分を盛り上げようと思って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120005" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「変な奴だな。とにかく、さっそく探しに行くか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それよりも、もっと君たちの持っている情報が欲しいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120006" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まずはこのタヌキ像について、知っていることを教えてくれない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「情報って言われても……なあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だって、この写真のタヌキ像の顔は君たちにそっくりなわけじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120008" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君たちもなにか、この像について心当たりがあるんじゃないかと思って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、あるわけないだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もしもあるなら、自分たちで見つけられている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……うーむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、見れば見るほどお前にそっくりだなと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だーかーらー！　私に似ているということは、お前にも似ているということ\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「ケンカはいけないわー。ほら、おうどんをサービスしてあげるから、これ食\nべて仲直り、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115120001" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にか、Ｍ．Ａ．Ｍ．Ａがうどんを用意した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「むっ、すごいコシだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「がんばって踏んだのよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115120002" ]},
		{"command":[ "SETCHARA", "0", "char_00021201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「足踏みの工程がしっかり行われている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120010" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「足踏み？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「うどんを作るときは、生地を足で踏むんだ。生地を鍛えるともいう。どうし\nてか知っているかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120011" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「足踏みはうどんに対して適度な力を様々な方向から与えるための工程なんだ\nけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これによってグルテンが網目状を形成し、弾力のある美味しいうどんになる\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ただ、足踏みは衛生上の問題からちょっとした騒動になったらしいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だけどおいしいうどんのためには大事な工程だから、足踏みをする機械があ\nるくらいなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「たぬきといえば、たぬきそばは関西にはないんだってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「関西では、たぬきっていうと油揚げの乗ったそばのことで、関東でいう『た\nぬきそば』は関西にないんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120017" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「へぇー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115120013" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ちなみに、同じ関西でも大阪と京都では『きつね』の定義もかわってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120018" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「同じ国でも、地域によって言葉の指すものが変わる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ということは、それが次元規模になれば、言葉と意味のギャップはもっとも\nっと大きくなるだろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だとすれば、このタヌキ像の顔が君たちに似ているのも、なにか意味がある\nのかもしれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115120021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……この探偵、本当に大丈夫なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}