{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……そして、俺がカグヤと２人で冬の町をうろついているちょうど同時刻。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ミニスカサンタ３人組……ルルーナ、エファ、兎子達は商店街を訪れていた客\n達に囲まれていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "少女１" ]},
		{"command":[ "SETTEXT", "「サンタさんだ！　サンタさんだー！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ちょっ……ちょっと何をするです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "少女２" ]},
		{"command":[ "SETTEXT", "「そのお洋服、可愛い～！　ねえ、プレゼントを配りにきたの～？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「い、いえ……私達はそういったことは……。あっ、ス、スカートを引っ張ら\nないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "買い物客" ]},
		{"command":[ "SETTEXT", "「いや～、別嬪さんがたくさん来てくれたもんだな～。なんだ？　アイドルの\nイベントか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「アイドルだなんて……。お褒めいただきありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "買い物客" ]},
		{"command":[ "SETTEXT", "「１曲歌ってくれねぇか？　もーっと観客を集めてくるでよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええと……。あっ、ど……どうしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "少女１" ]},
		{"command":[ "SETTEXT", "「ねえねえっ、トナカイさんはどこにいるの～？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "少女２" ]},
		{"command":[ "SETTEXT", "「おねえちゃんおねえちゃん！　私、今年良い子にしてたんだよ！　これ、靴\n下……プレゼント入れて～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あら……。偉いんですね。でも、靴下は夜にベッドに置かないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "少女２" ]},
		{"command":[ "SETTEXT", "「どうして～！？　ここにいっぱいサンタさんいるのに、なんで～！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あああ～っ！　これじゃあ全然動けないです！　不審者どころじゃありませ\nん～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……あまり目立ちすぎるのも問題ですよねぇ……。裏方に徹していた方が良\nかったかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ま、まあ……ちやほやされるのは嫌ではありませんけれど……。ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私達を目当てにたくさんの人が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022100004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「これは、脱出するのに相当骨が折れそうねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "サンタ３人娘が、ご当地アイドルとして人々に祭り上げられているその時間。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あら？　楽しげな音楽が聞こえませんか？　ジュンジローさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100001" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "てくてくてく、と１人の露出美女と１匹の犬が、カツマ・カグヤ組とは反対側\nから商店街を見回っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「何か特別なステージでもやっているのかもしれませんな。いやはや、見られ\nなくて残念ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……ふふっ。そうですね。せっかくのクリスマスにパトロールを頼んでしま\nってすみません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100002" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴方にまで手伝っていただいて……。本当にありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえいえ。私めはまったく問題ありませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ただ……問題はご主人達の方と言いますか……。手を回し、尽力して二人に\nするのに途方もない苦労をしましたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ふふふっ。いつもお疲れ様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100004" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "巨大なバストを揺らす道子と共に、ジュンジローは素早く周囲を警戒する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむふむふむ。今のところ、あやしい臭いはしませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そうですか。それなら引き続き、頑張ってパトロールしましょうね。不審者\nの情報を集めて……もし遭遇したら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100005" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あちらの２人に連絡して、協力して捕まえましょう。それが学園長として、\n生徒を守る私の使命です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「残念ですが……青少年にとって一番不審なのは、あなただと思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あらあら。ジュンジローさんは、ご冗談もおっしゃるんですね。紳士のたし\nなみといったところかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100007" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……この学園長、かなりの天然なのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "……そうして、どれほど町をぐるぐる徘徊しただろうか。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "美女と犬の不思議なコンビは、ゴムのエプロンをつけた１人の男に呼び止めら\nれた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「あっ！　先生、先生！　学園長の先生！　こっちです！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あら。魚屋のお父様。お元気そうで何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100008" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「いつもウチの商店街に良くしてくださってありがとうごぜえやす。で、先生\nにぜひともお教えしたい情報があるんでさあ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「なんでしょう？　困ったことがあればいつでも何でも言ってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100009" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「いやはや……ありがたいこってす。それで、その情報っつうのが……黒いサ\nンタのことなんです」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「黒いサンタ？……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　犬が喋ったぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あわ、あわわわ、し、失態を……アワワワ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「先生、なんなんです！　このみすぼらしい犬は！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「彼は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100010" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "つい声を出したジュンジローを、道子はぱっと抱き上げてぬいぐるみのように\n手足をパタパタ動かしてみせた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「うふふふ。最近、私……腹話術を練習しているんです。上手なものでしょう\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100011" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「ああ……そうだったんですね」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それに、みすぼらしいだなんて悲しいです。とっても勇敢で、頼りになる名\n犬さんなんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100012" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それで、黒いサンタというのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100013" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「ああ、そうでしたそうでした。そいつは黒いサンタの服を着た、あやしい女\nだそうなんです」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「どこからともなく現れて、どこかへひらりと去っていく……。闇から闇へ駆\nけるその不審な影」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "男" ]},
		{"command":[ "SETTEXT", "「そいつはクリスマスで幸せそうにしているカップルを襲って、ぶち壊しにし\nていくっつうんですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「まあ。なんてひどい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100014" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "涙ながらに語る男の近くで、道を歩いていた女が同調する。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女" ]},
		{"command":[ "SETTEXT", "「その女、私も見ました！　っていうか、さっき……友達が襲われて」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女" ]},
		{"command":[ "SETTEXT", "「初めてのデートだったのに……めちゃくちゃになっちゃったって言って泣い\nてて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それは許せません。どうか、お友達さんを慰めてあげてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100015" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女" ]},
		{"command":[ "SETTEXT", "「はい……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「その不審者は、必ず私達が捕まえます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100016" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女" ]},
		{"command":[ "SETTEXT", "「ありがとうございます、学園長さん！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……ということで、不審者についての強力な情報が得られましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100017" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「黒いサンタの女……。一体、何が目的なのやらですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「カップルを襲う不審者となれば……もしや、カツマさんとカグヤさんも狙わ\nれてしまうのではありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100018" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それには、あの二人がラブラブでアツアツなカップルに見えなくてはなりま\nせんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「若いお二人ですもの。こんな素敵な夜に二人になれば、自然と距離は縮まる\nのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100019" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あのご主人ですからねぇ……。二人きりになったところで、どれほど進展す\nるのやら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100013" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そうなんですか、カグヤさんも大変ですね。うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100020" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "和やかで、穏やかな１人と１匹のパトロール。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "彼らがのんびりと見回りを続けていると……、ドンッ！　と羽根の生えた女が\n学園長にぶつかってきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「きゃっ！　ご、ごめんなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100001" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「平気ですよ。どうかお気になさらないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100021" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「ひゃっ！　また、エッチな服を着た痴女さんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100002" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「私は痴女ではありませんよ。この町をパトロールしている者です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100022" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「あ、そうなんですか……。すみません、さっき同じような姿の人に、酷い目\nにあわされたばっかりで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100003" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「少々震え上がってしまいました。え、えーと……クリスマスにほかほかのチ\nキンはいかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「１ついただきます。ですが、あなた……チキンの姿でチキンを売って心は平\n気なのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100023" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「えっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100005" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「その……言い方は悪いですが、共食い……になってしまうような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100024" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「そ……それについては忘れてください。色々事情があるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100006" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「わかりました。これ以上聞くことはやめましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100025" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "物わかりのいい道子にホッとしたのか、チキン乙女の緊張が解けていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その隙を見逃す学園長ではなく、道子はすぐさま不審者についての質問を投げ\nかけた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そうです。貴方、このあたりに出没とするという不審者について知っている\nことはありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100026" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「不審者……ですか？　私のことではなくて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100007" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴方は勤労に真面目にいそしんでいる素晴らしいアルバイターさんです。不\n審者とは違うのではないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100027" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「じぃーーーん……。あ、ありがとうございます！　ええと、不審者……不審\n者ですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100008" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「ちょうど、ついさっき目撃しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「な、なんですと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100014" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「その人はエッチでかわい～いサンタの格好なのに、ものすごい殺気を放つ\n女性だったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100010" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「どうやら隣にいたサンタさんとカップルだったようで……。私がお邪魔し\nちゃったから怒ったのかもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……その女性というのは、こう……オカッパで……キュートな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100028" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「はい。こんな感じに、髪をこのくらいの長さで切りそろえていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100012" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "くい、くい、と指で描かれた髪型はカグヤのものに間違いない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そうでしたか。おそらく、その女性は私の知っている女性だとは思いますが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100029" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「ひえっ！　そうなんですか！　やっぱりあなたはあの人の仲間……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100013" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そう怯えないでください。彼女もいつもは、とても可憐な恋する乙女なので\nすよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100030" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「ひええええん、やっぱりそうなんじゃないですか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100014" ]},
		{"command":[ "SETCHARA", "0", "char_00021902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チキン乙女" ]},
		{"command":[ "SETTEXT", "「私、もうこのバイト嫌です！　家に帰ります！　うあああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_020022100015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あら。あらあらあら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100031" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "泣きながら走り去ってしまったチキン乙女を見送ると、道子はジュンジローを\nようやく地面に下ろして呟いた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「彼女たちの様子も気になりますし、一旦合流しましょうか。ジュンジローさ\nん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022100032" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですな。こちらが得た情報を、早めに教えておくべきでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022100015" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目を合わせて、こくこくとうなずき合う。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園長とジュンジローは、小走りにカツマ・カグヤペアの元へと駆け出した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……最初の使命、パトロールの事をすっかり忘れたミニスカサンタ３人を残し\nたまま……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "観光客" ]},
		{"command":[ "SETTEXT", "「いいぞ～！　アイドルミニスカサンタ隊～！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ご、ご鑑賞ありがとうございますわ～！　あわわわ。ええと、次の楽曲は…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ライブ後の握手会とサイン会はこちらで行います～。チケットを購入してか\nら並んでくださいね～」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022100005" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……きっちり参加費を取っている……。さすが、エファは策士なのです……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}