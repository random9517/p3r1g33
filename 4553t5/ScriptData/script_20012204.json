		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「なるほど……ふむ……ん……そういうことですか……だとすると……いや、\nでも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「かれこれ数時間、ずっと没頭しておりますなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「すごい集中力ね……でも、どうしたものかしら……そろそろ次の手を考えな\nいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「うん……うん、ふむ……はい、すみませんっ、お待たせしました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790002" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どうかしら、翔生子さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そうですね、色々と興味深いことが書かれていましたが、竜に関わることは\n中々情報が少なかったというのが正直なところです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790003" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「ただ、過去の伝承に記されていることが、実際に今の状況とどれだけ関係し\nているのかは分かりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790004" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「少なくともイルルちゃんの今の状態は、本来の力からは程遠いというのは間\n違いないと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「つまり……目覚めはしたけれど、力が封印されている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そうですね……イルルちゃんがどのように感じていらっしゃるかは分かりま\nせんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790006" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イルルちゃん……貴方……本当の力が出せてないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……え……と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「よく分からない？　自分がもっと強くなるってイメージ……湧いたりしない\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790007" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……ん…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「本人の力の問題じゃないのかな……まだ、何か違うファクターがあって、そ\nれを見落としてるとか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790008" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「困ったわね……相手の力も未知数だし、今のままでは動きようが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ん、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「イルルちゃん……どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790009" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……イルル……変わっちゃう……から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「変わっちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790010" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「今のじゃなくて……もっと……こわいのに……なっちゃうかも……だから…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「こわいの……もしかして、姿が……変化するってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790011" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルのほんとうの姿……おとーさん……こわいかもって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「そうか……にいさまに愛されたい、娘でいたいっていう気持ちが強いから…\n…竜としての力を無意識にセーブしちゃってるのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790012" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル……こわい……おとーさんが、きらいになっちゃったら……イルル…\n…そしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「エファさん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790013" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「イルルちゃん、私のこと……見ていてくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790008" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021790009" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790009" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この状態……あんたには、初めて見せる姿だったかねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790010" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おかーさんじゃないよ、泣く子も黙るグレートルナリアムの狂魔元帥……エ\nファナティカ様さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えふぁ……な……てぃか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790011" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうとも。普段のエファは、世を忍ぶ仮の姿。こっちこそが、本来あたしの\n本当の姿ってワケさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790012" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それで、どうだい？　あたしの姿……フフッ、この爪をちょっと振り下ろせ\nば、あんたの柔らかいほっぺがズタズタになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790013" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「大人しいね。怖くて、声も出せないかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790014" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「違うって？　何が違うのさ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790006" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさんはおかーさんっ……見た目……ちがうけどっ……でも、ちがわな\nいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790015" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうして、そう言える？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790007" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わかんない……けどっ、イルル……何となく……そんな気がする……からっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790016" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はん……答えはちゃんと出てるってワケだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790008" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790017" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「イルルちゃん……にいさまは、イルルちゃんがどんな力を持ってても、そん\nなことで態度を変えたりしないと思うよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790014" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……おねーちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790018" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「だって、どんなものでも受け入れちゃえるのが、にいさまのすごくて……素\n敵なところだと思うから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010021790015" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790019" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なら……もうそこで迷うことはないんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790009" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん……イルルは……おとーさんをしんじる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790020" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお……これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「見た目は全く変わってないけど……ふふ、ビリビリ来たよ……そいつが、あ\nんたの力の一端かい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021790010" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……ヤムのところ……行く。おかーさん、一緒について来て……くれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021790021" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だから、おかーさんじゃ……まぁ、いいさ。あんたがやる気出したんなら、\nそいつはしっかり見届けてやろうじゃないか」", "NORMAL" ]},
