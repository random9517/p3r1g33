		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……夜の公園に誘われて、ノコノコとやってくるとは。お前は本当にお人好\nしで、のんきな男だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「しかし、今夜ばかりは助かった。そ、の……前に、お前にボウチュウジュツ\nのことを話したことがあっただろう？　それで、したいんだ。それを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ボウチュウジュツの中には……男女が直接まぐわうものがあるらしい。それ\nを……それをお前としたい。なんでも言う通りにする。頼む……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……ん？　な、なんだ？　このポーズは……。はぁっ、はぁ、わ、私は本番\nのボウチュウジュツを要求したんだぞ。これではただの辱めだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025701_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ、それとも……深い意味がある姿なのか？　特別な気を練り上げて、ジ\nュツの効果をあげる儀式？　ちがう？　メス犬のおしっこのポーズ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お、おしっことは……？　そ……そんなおかしなことをしにきたのではない\nぞ！　私はっ……私はお前と……！　……ん？　どうしてもしてほしい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これは命令で……メス犬になりきることで、オスを誘惑してジュツにハメる\nために必要なこと？　う……確かにそうなのかもしれない。だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「裸でこうして誘っているだけではだめなのか？　勇気を出して言ったのだぞ\n？　女の方から、それもダークエルフから交尾に誘っているのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ダークエルフである前に私はニンジャ？　くっ、それを言われると弱い。メ\n……メス犬になりきって、ボウチュウジュツを披露する……。ううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「メス犬の時にはご主人様と呼べ、と言うのか。そこまで高貴なるダークエル\nフをおとしめるとは……。でも……でも、ニンジャ……だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……わ、かった。い、今から排泄を……メス犬おしっこをさ、させていただ\nき……ます、ご主人様……。どうかご覧になってください……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「おしっこ……。っはぁっ、はあ、はぁっ……足をあげて、女性器をさらけだ\nして……出します、放尿します、見ていてくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ッあ……っ！？　ああああああっ、ああああああ……！　いやだっ、ああ…\n…♪　一度出始めると、も、もう止められない！　んぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「じょろじょろ漏れて……！　溢れて、ほとばしって……！　うううっ♪　黄\n金色のお小水が！　公園の土に広がって……ああああっ、湯気が出ているっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ご主人様……！　ご主人様、こ、これでいいのですか？　ちゃんとメス犬出\n来ていますか？　出してます、私、たくさん……おしっこしています！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「っくぅうううう……！　なんだ、この異様な解放感……！　あっ♪　こんな\n姿を誰かに見られるだなんて恥ずかしいはずなのに……！　っふぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「やぁ、あ……♪　外で陰部を露出して、放尿したのが気持ち良くて……達し\nてしまう！　んああああああッ♪　ああああ♪　イ、く……イクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁっ……！　はぁ、はぁ、はぁ……！　どうしよう、アソコが熱い……！\n　オマンコから尿だけじゃなく、愛液が溢れて……。ん！？　ま、待て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んはぁああああッ！？　えっ！？　あッ！？　な、なぜだ……っ！？　あっ\n……！　なぜいきなり男根を突き入れて……！　あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「くぅううっ♪　あんっ、ンンッ、んんんっ……！　こ……これが挿入……？\n　本当のボウチュウジュツ……！　あっ♪　すごい、すご、すぎるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、私の中に硬く太い肉棒がずっぷりねじりこまれている……！\n　っふ……♪　ついに……男女の交わりを経験することが出来たのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ♪　ご……ご主人様、どうして急にこんなことを？　えっ、私のオマン\nコがだらしなくよだれを垂らして欲していたから……栓をしたと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そ、それでこんなにも強引な挿入を……♪　はぁ、はぁ……♪　はい、だ、\n大丈夫です……一度絶頂していたからか、痛みはまったくありませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「それどころか、身体がカッと熱くなって……快感を得ています。んんっ、こ\nれが……これがボウチュウジュツ……！　私の初体験……！　……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あ、ああ。そうだ。言っていなかったか？　私は処女だ。処女だった、がっ\n……♪　ニンジャたるもの、ジュツは極めなければいけないから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ♪　だからいいんだ、それに……し、してほしかったから……。くぅっ\n……！　処女のくせに淫乱の素質がある、と言うのか。恥ずかしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「メ、メス犬の素質がある？　それは褒めてくれているのか……。っあっ♪　\nこ、答える前に腰を突き出すなぁ♪　あんっ♪　あん、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「うぁっ♪　あああっ♪　おしっこ……！　おしっこしたばかりの肉壺に！　\nオマンコに肉棒が出入りしている、本当に入っているぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「え？　初めてとは思えないほどに中がトロトロで仕上がっている？　そ、そ\nれはっ……私は自慰が多いから……っ！　あっ、い、言わせるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「それに興奮しているんだ！　お……お前に初めてを奪ってもらえた、から♪\n　お前にボウチュウジュツを教えてもらっているからっ……！　んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ニンジャとて、相手が誰でもいいわけでは……ないぃっ♪　あっ！？　どう\nしよう、中で肉棒がまた大きくなった……！　あっ、すごい、すごいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「オマンコ、どんどん拡張されていくぅうっ♪　私のダークエルフニンジャオ\nマンコぉっ♪　初めてなのに本気で感じている！　締めつけてしまうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あ……♪　あ、ご主人様……！　私はメス犬、なので！　あぅっ♪　またす\nぐに絶頂しそう……ですっ！　快楽の波が強すぎて、あっあっ、理性が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「理性がトびそうです！　どうか、どうかご主人様もこのメス犬ダークエルフ\nオマンコに射精してくださ……いぃ♪　んくぅううっ♪　あぉおおんっ♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああっ♪　イキかけて本当に犬のような声がっ！　あっ！　あっ！　気持ち\nいい！　気持ちいいぃいっ！　喘ぎ声が止められない……！　イクぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぅああああああっ♪　あおぉおっ♪　おぉおッ、んぉおおっ♪　処女喪失\n、即膣内射精ぃいい……♪　あっあっ、熱い！　熱い熱い熱いぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前の精液が……っ！　白濁液がオマンコの奥でじゅわあああっと広がって\nいくぅう、子宮、にまで入ってくる♪　熱い……焼ける、おかしくなるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んっ……あっ♪　あっ、あああ……♪　種汁が、何度も何度も発射されて…\n…んんっ♪　べったりとオマンコの奥にはりついている……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これ、は……♪　んんんっ、妊娠してしまったかもしれない……♪　フフ、\nそれなのにまったく嫌ではない……。むしろ肌が火照ってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「オマンコの奥が、きゅうきゅうと切なげにうねって、種汁を吸い上げていく\n……。あああぁ♪　なあ、もっとボウチュウジュツを知りたいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「このままっ♪　メス犬になった私を犯し続けてくれないか……。あっ♪　嫌\nでないことはわかっているぞ。まだ、腹の中の男根が硬すぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これは力を失った肉棒の大きさじゃない。あ……♪　んんぁ♪　んぁっ……\nあぁ……♪　ど、どうだ……？　オマンコに力を入れたり、抜いたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そうすると、肉棒に絡みついてくるだろう？　あああっ♪　私の方も、気持\nち良くなってしまうのが難点、だが……あぁ♪　必要な犠牲だろう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、せっかくメス犬の私に栓をしてくれたのだから……っ♪　\nまだ抜かないでほしい♪　このまま……このままずっと突いてほしい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……はぁんんっ♪　い、いいのかぁっ？　私、にぃっ！　コレ！　男根をも\nっとねじりこんでくれる、のか……っ！　あぁっあっあっあっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「これっ……これ好きぃい……♪　んんぁっ、初めては痛いだけだと聞いてい\nた、のにぃ……！　全然痛くない、ニュルニュルで気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　出してもらったばかりの精液とぉ……私の愛液が絡んで最\n高の粘液になっているぅ……！　んんぁああっ♪　交わりが好きになるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ひぁっ♪　あぁっ、全力で犯してくれぇっ！　私はメス犬ニンジャっ！　わ\nぅうんっ♪　メス犬ダークエルフなのだからぁっ！　わん！　わんわん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んあああああっ♪　あああんっ♪　わぉおんっ♪　わんっ♪　わんっ♪　あ\nあぁああ……ッ♪　な、に？　オマンコが締まりすぎている？　あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「キツくなってしまうのはぁ♪　メス犬ならば仕方のないことなのだぁあ♪　\nああっ！　大丈夫、濡れているから無理やりに出し入れして平気、だっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「突き上げて……！　んぁっ♪　あぁ、あぁっ、あぁ！　だ、めだ♪　まった\nく忍べない……っ！　夜の闇にまぎれるどころか……！　ふぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「露出して、おしっこして、膣内射精されてもまだ男根をっ♪　欲しがって、\n腰を動かしてしまうぅっ♪　あぅうんっ♪　わんっ、わん、わんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ぐっちゅぐっちゅと卑猥な水音がするぅ……っ♪　うぁあああっ♪　この音\n……頭がおかしくなる、男根のことしか考えられなくなっていく……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　あっぁっあっあぁっんんっ！　すまない……っ！　淫乱ダークエ\nルフニンジャですまないぃっ！　ボウチュウジュツ、気持ち良すぎるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もっとしたい、ずっとしたい、永遠にコレっ♪　ずちゅずちゅしてほしいぃ\n……！　はぁああっ♪　これがメス犬の気持ち……あああっああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「突いて……！　突いてくれぇ♪　誰にどう思われてもいい、見られてしまっ\nてもいい……！　んぁああっ♪　今は肉棒のことしか考えられないぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んぉおおっ♪　ほぉっ♪　あぉおおっ♪　メス犬になりきって……男根を味\nわって……♪　あぁ♪　ゾクゾクする、快感が止まらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あああああ……♪　また、目の前が真っ白になってきた……！　んぁあっ、\n絶頂……してもいいか？　あッ♪　お前の男根で果ててもいいかぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「かなうのならば……もう一度♪　このままオマンコに出して欲しい、たっぷ\nりの種汁で、私を妊娠させてほしいっ……種付けしてほしいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁ♪　あぁ、ください……くださいぃ♪　受け止めますからっ！　ニンジ\nャとしてご主人様の種汁全てをありがたくちょうだいしますぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぅうううっ♪　あふぅううっ♪　ひぃっ♪　イイッ……♪　中出しイイっ\n、膣内射精イイっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あり、がとうございますぅううっ♪　ご主人様ありがとうございますっ！　\n私……オマンコ絞り上げますからっ、一番奥に出し続けてくださいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ッんん……っ♪　んんんん～っ♪　んぅっ♪　ん～～～っ♪　あ……♪　ま\nたドクドクって……！　入ってくる、流れこんでくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あああッ♪　これが、メス犬ダークエルフニンジャにとっての最高の幸せな\nのか……っ！　主に思うがままに種汁を与えてもらい、絶頂する……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「んあっ♪　はぁっ♪　ありがとうございますぅうっ♪　どっくんどっくん肉\n棒が脈打って……っ！　白濁液でいっぱいに満ちていきますぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……普通の人間は、二回も続けて射精しても……こんなに種汁を放出しない\nと思うのだが……。なぜ、お前だけこんな量を出し続けられるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……はっ！？　も、もしかしてお前も……！　ご主人様もボウチュウジュツ\nの使い手だったということか？　さすがは私の純潔を奪った男……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前こそ、真のニンジャ、究極のボウチュウジュツの使い手だ……！　フフ\nッ、フフフッ♪　お前のような強者の種を孕めば……子もジュツに優れ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「最高のダークエルフニンジャになってくれるに違いない……♪　ああ、それ\nを想像するだけで……♪　もう、興奮で頭がどうにかなりそうだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「この契り、なんとしても盤石なものにしたい。私には何度でも種汁を注ぎ込\nんでかまわないから……絶対に、お前の子を孕ませてほしい。お願いだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　イクっ……！　達するぅうっ♪　……あ、あれ！？　ご主人\n様っ……！　男根が抜けて……！　あっ！？　んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あっあああああ……！　頭に、胸に種汁がびゅぶびゅぶと降りかかってくる\n……っ！　熱い……なんという強烈な臭いぃ……！　んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「つい先程まで私の中に、オマンコの中にあった肉棒が……！　ブルブル震え\nて大量の種汁を発射してくる……！　ああっ、生臭い……すごいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「種汁を浴びるの、気持ちいい……！　もっと！　もっとかけて……！　私の\n全てを真っ白に染め上げてくれっ……！　ッああああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「嬉しいぃっ♪　肌のいたるところにお前の臭いっ♪　マーキングされている\n……！　あぁっ！　私を、私をお前のモノにしてくれぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……っふーっ♪　フーッ、ふーっ……♪　に……二度目も安易にオマンコの\n中に出すわけではなく、油断させておいて種汁をぶちまける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025701_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ニンジャの私すら見事にもてあそぶ、このジュツがボウチュウジュツ……♪\n　そして、お前は……ご主人様はその師範代でありマスターなのか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あぁあ……♪　恐れ入った……。私は修行が全然足りない……♪　自らの欲\nに流され、絶頂し、男根に溺れ……我を失ってしまっていた……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、これからも、もっとボウチュウジュツの知識を、経験を深めな\nければ……♪　今回は初歩の初歩、……んっ♪　しかし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「交わりも、お前の種汁も好きになれたということは、私にもジュツの才能が\nあるのかもしれない。それを、何度も確かめていきたいんだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
