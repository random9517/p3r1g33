		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「いっぱいかけてごめん……？　ふふっ……謝ることなんてないのよ。私はカ\nツマちゃんが気持ちよくなってくれて嬉しいもの……」", "NORMAL" ]},
