	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ。カツマちゃんったら、私を見るなり服を脱いで抱きついてくるなん\nて……すっかり私のおっぱいベッドが気に入ったみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「今日も激務だったのね……カツマちゃんはいろいろな仕事をこなしてるから\n、心も身体も疲れちゃうわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「でも、私の前ではそんなに気を張らなくていいわよ。カツマちゃんのためな\nら、いつでもこうして癒してあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「声をかけてくれたら、どんな時でもおっぱい布団でマッサージしてあげるか\nらね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　ふふっ……カツマちゃんのが、おっぱいの中で大きく\nなってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私のおっぱいに抱き着いて、勃起しちゃったのね……あっ、んふっ……！　\nカタくて、たくましいのが奥まで入ってるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そんな切なそうな顔しないで……今日も全身だけじゃなくて、こっちの方も\nマッサージしてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ。別に迷惑だなんて思ってないわよ。むしろ、カツマちゃんに奉仕が\n出来て嬉しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　またそんな急に強く抱きしめるなんてっ……！　もう、カ\nツマちゃんったら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ほら、もっとチカラを抜いて頂戴……私のおっぱいに心も身体も委ねて……\nリラックスしてね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　はぁ、んふっ……くっ、あああぁ……！　あっ、あっ…\n…！　カツマちゃんの、すごく熱いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「アソコだけじゃなくて、全身が滾ってるみたいだわ……！　おっぱいで擦る\nと、もっと熱くなってきて……！　んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あくうぅ……！　だっ、ダメっ……！　カツマちゃんは動い\nたりしないでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「アソコも身体も、私が動いて癒してあげるから……！　だからカツマちゃん\nは、おっぱい布団に寝そべってて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……！　んっ、あっ……あはぁ……！　カツマちゃんの手が動い\nてっ……おっぱい揉み揉みされてるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あっ、あっ……！　揉みたいみたいだし、もう少しおっぱい\n柔らかくしてあげるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ……私の胸は特殊なポリマー素材で出来てるから、カタさを調整する\nことができるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だからこうして……んっ、ああぁ……！　カツマちゃん好みの柔らかさにす\nることだってできるんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひっ、あっ……んはあぁ……！　おっぱい柔らかくしたから、カツマちゃん\nの手がもっと奥まで来て……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「谷間の中もアソコのカタチに合わせて変形してるっ……！　カツマちゃんの\nで、おっぱいが変形合体してるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、ひぐっ、あはぁ……！　こんなに熱いのを味わわされたら…\n…胸のエンジンに火が付いちゃうわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　くっ、あっ、んふうぅ……！　いつもより乳首が大きくなっ\nてっ……！　あっ、あっ！　感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんを擦るの、止まらなくなっちゃうっ……！　光の速さでダッシ\nュするくらい、激しく擦っちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カリの部分がおっぱいに引っかかって……！　あっ、ひううぅ……！　谷間\nの奥で暴れてるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　カツマちゃん……！　もっと身体を谷間に埋めてっ……\n！　カツマちゃんのを、もっと感じさせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んはあああぁ……！　あっ、あっ……！　カツマちゃんが、奥まで入ってく\nるぅ……！　私のおっぱい、カツマちゃんを飲み込んでるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっあっ！　ダメぇ！　その状態で動かないでぇ！　カツマちゃ\nんの下半身、感じすぎちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ふっ、くうぅ……！　アソコだけじゃなくて、カツマちゃんの脚も\n動いてるっ……！　つま先でおっぱい弄られてるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私がシコシコしてるはずなのに……はぁ、あっ、ひゃうぅ……！　いっぱい\n、感じさせられてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「これじゃあ、マッサージになってないわっ……！　私がカツマちゃんのこと\n、癒してあげないといけないのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んひっ……！？　あっ、ひううぅ……！？　カツマちゃんのが、奥でビクビ\nクって跳ねてるっ……！　おっぱいで暴れてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「マッサージされて気持ちよくなったから、出ちゃいそうなの……！？　くっ\n、あっ、あっ……！　なら、出していいわよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私のおっぱい布団の中に、いっぱい射精してっ……！　カツマちゃんの溜ま\nってるモノ、全部受け止めてあげるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　ひっ、あっ！　あっ……来るっ……！　そろそろ出ちゃいそう\nなの、わかるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　出してっ！　カツマちゃんっ！　私のおっぱいに、エッチなお\n汁びゅるびゅる出してぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはあああぁぁぁ！　あっ、んっ、くふっ！　熱いのいっぱい出てるわっ！\n　相当溜め込んでたのねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「特殊ポリマー素材で熱にも水にも強いはずなのに……！　身体の奥にまで染\nみ込んできちゃいそうだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　回路が焼き切れちゃいそうなくらい、熱がこもってて……！\n　はぁ、あっ、んくうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私ロボットなのに……マシーンなのに……！　だけどわかっちゃうのっ……\n！　燃える感情がメモリに刻まれてくるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっ……！　カツマちゃんっ……！　好きっ、大好きぃ！　あっ、あっ\n！　あはあああぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ……！　すごいわ……カツマちゃんの精液を浴びてたら\n、イッたような感覚を味わえたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ……谷間がベトベトね……こんなに出せるなんて、カツマちゃんも若\nいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「若さの秘訣は振り向かないこと……？　ふふっ。カツマちゃんは前向きなの\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　出したばっかりなのに、もうこんなにカタくなって…\n…こっちの方も随分と前向きなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「まだまだ奉仕できそうだし……このまま続けて、マッサージしてあげるわね\n……んっ、あっ……あはぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んふっ、くっ、あふっ……！　あっ、あはあぁんっ……！　カツマちゃんの\n精液のおかげで、滑りがよくなってるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「アソコがおっぱいでズルズル擦れる感覚が強くなってっ……！　あっ、ひう\nうぅ……！　おっぱいが溶けちゃいそうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あはぁ……！　もっと強く抱きしめて欲しいのっ……！？　い\nいわよっ……いっぱい挟み込んであげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……くっ、んんっ……！　あっ、あっ！　強く挟めば挟むほど\n、カツマちゃんを感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私とカツマちゃんが一緒になってるみたい……！　こんなの、変形合体どこ\nろじゃないわっ……！　融合合体よっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　もっとカツマちゃんと融合したいわっ……！　アソコも身\n体も、いっぱいくっつかせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　シコシコするたびに、カツマちゃんのが震えてくるわっ…\n…！　もっと熱い血潮を滾らせてっ！　気合見せてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んふっ、くっ……あうっ、あぐっ、あはああぁ！　エッチな\nニオイがいっぱい広がってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00011104_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「精液が谷間でかき回されるたびに、ニオイセンサーがエラーを吐き出して…\n…！　でも、このエラー嫌いじゃないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だって、カツマちゃんの精液だものっ……！　嫌いになんてなるはずないっ\n……！　むしろ、大好きなのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ！　だからもっと私の身体に塗り込んでっ！　カツマちゃん\nので、マーキングしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私の全てはカツマちゃんのものだから、所有者の証をいっぱい刻み込んで頂\n戴っ！」", "NORMAL" ]},
