		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふふぅー、センパイ……ここまで来たら、もう邪魔は一切ナシのナシナ\nシっスよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
