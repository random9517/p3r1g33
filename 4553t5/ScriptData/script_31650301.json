		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「もうずーっとムラムラウズウズしててぇ……センパイに、どんな風にしてあ\nげるか……色々考えてたんですよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「てことでぇ、さあ……脱ぎ脱ぎしちゃいましょ♪　センパイのチンポ、御開\n帳～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「わぁおっ、めっちゃビンビンになってるしぃ。分かってるっスよぉー、今、\nいー感じにしちゃいますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほぉら……どうスか？　センパイ……あーしのおっぱい……なかなかでしょ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016503_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「これを……こうしてっ、んっ、むぎゅっとっ……はいっ、サンドイッチしち\nゃいましたぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふっ……すっごく熱い……ビクビクして、元気いっぱいって感じですね\nぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「においも……んんーっ、一日動いたセンパイの汗とおしっこの残り香……？\n割とキツめのが残ってて……んふぅ……コーフンしますねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、まずはぁ……ゆっくりと……抑え込んでぇ……んっ、しょっ……ずり\n……ずりっ……軽く扱いてみたりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あはっ、もうピクピクしてる……センパイのチンポ、ビンカン過ぎ～。でも\n、それだけおっぱいの感触がいいってことスか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そんな反応されるとぉ……もっともっと、してあげたくなっちゃいますね。\nんっ、あっ、ふっ、んんっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「どースか？　あーしのおっぱい……んふふっ、柔らかいでしょお？　こう、\n押しつぶすっていうの……どうですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んんーっ、いいみたいですねぇ……えへへぇ、それじゃあ……このまま失礼\nして、先っぽを……んりゅっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぴちゃ……んちゅぷっ……はぁぁん……センパイのチンポ……や\nっぱティスティ……めちゃウマっスぅ……んれるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えろっ、れろぉぉんっ、れる、んれるうっ……んりゅっ、れろっ……亀頭の\n割れてるトコぉ……いっぱいペロペロしますからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んりゅ、れる……れろ……んちゅぷっ、んふっ……はぁ、このクセの強いチ\nンポのにおい……たまんないっスねぇ……んすぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、たっぷり唾液をまぶして……える……んちゅっ、ちゅぽんっ…\n…んふっ、チンポ飴しゃぶるみたいに……舐めてくっス……んりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ひってまふ……？　センパイ……？　めっちゃチンポの形そのものの飴があ\nるの……今、あーし……それを堪能してる気分れふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「と言っても……こっちの本物の方が、何百倍も美味しいれふけどね……んち\nゅぷっ、んちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ、もうお上品に舐めるだけじゃ済まないっスね……もっと思いっきり\n頬張りまぁふっ、はむぅっ、んりゅぷぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ……根元まで咥えてぇ……このままで、マジのパイズリフェラ……\nしていきまふよぉ……んむっ、ふぐっ、んりゅっ、じゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぱっ、んちゅぱっ……はぁっ、んむっ……くぽっ、むふぅぅっ…\n…めっひゃ……頬張っひゃったぁ……んじゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぉれで……んっ、おっぱい……思いっきり扱きまふぅ……んんっ、じゅぷ\nっ、うんっ、んっ……んふっ、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ろうれふか……？　なかなかの……お肉クッション……れひょっ？　んっ、\nむぎゅって押しつぶすと……おっぱい、やらひぃ形になってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、コリコリ乳首もぉ……ちゅぷっ……お腹のトコ……いっぱいくすぐっ\nてぇ……んふぅっ、あーしも気持ちよくなっちゃうっていう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ちゅぷっ、んっ、あふっ……んふんっ……はぁ……チンポも震え\nて……ますますサカっちゃいますよぉ……んっ、じゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……あぁ……今、腰がビクンってしまひたね……？　また一つ弱\nいトコ……見つけちゃいまひたねぇ……んちゅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぉら……んじゅるるっ、この吸い上げ……んちゅぷっ……チンポが何度も\n震えて……んじゅるるっ、分かりやすく悦んでまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「更にぃ……ぎゅっ、ぎゅっ、ぎゅぅぅーっと……んっ、谷間ズリが……根元\nの方をシコシコしまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……んふふぅっ……余裕のない顔れふねぇ……サキュバスのパイ\nズリ……気に入ってもらえて何よりれふ……ん、ちゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でも……まだまだぁ……あーしで、いっぱい興奮して欲しいれふからね……\nんちゅっ、ちゅぷっ、んちゅっ、ぴちゃっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ、センパイの弱いトコにキスしまくりぃ……んちゅぷっ、このくびれ\nのトコとか……チンポ、めっちゃビクってするひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「血管が浮き上がってるトコとか……んっ、おっぱいに直接当たってぇ……ん\nちゅぷっ……ビクビクが強くなってくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……んんっ……あぁ……お汁……浮いてきまひた……んりゅっ、\nチンポも……熱くなって……そろそろ……れふかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「またまた……とぼけてぇ……いいれふよっ……なら、問答無用で……搾り取\nっちゃいまふからっ、んっ、んふっ、んりゅっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「巨乳プレスのっ……パイズリピストンっ……もうっ、限界なんれひょっ！　\nふぉら……お漏らししひゃうんれふっ……んじゅうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぶぅっ……！　ふぐっ、れまひたっ……んんっ、こくっ、んくんっ、ごく\nっ、んんっ、じゅるっ……んぐっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふぁっ……ちゅぷっ、はぁ……ぷぁっ……濃い精液……んっ、一気飲みし\nひゃいまひたぁ……んちゅぷっ、ぷはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁ……新鮮なチンポミルクぅ……やっぱり特別っスね。ちゅぱっ……口の\n中にいつまでも残ってる感じれふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゅるっ……んっ、ご馳走様でした。んふふっ……やっぱり、センパイの精\n液……マジ極上っス。いやもーホントに。完璧っス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゅぽっ……さて……とーっても美味しい精液を頂いといて……こーいうこ\nとを言うのは恐縮なんスけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイのチンポ……まーだ、結構元気いっぱいですよね？　ほら……この\nピクピク……出し切ってないって言ってます、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「てことでぇ……もっと食べさせてもらおうかなぁーって……んじゅぷっ、く\nぽっ、ちゅぷ、んふっ、りゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぇっ……？　まだいいって言ってない？　まぁまぁ、カタいことはナシに\nしまひょうよ。カタいのは、チンポだけで十分なんで……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んちゅぷっ……もう細かいことはどーでもよくなる位にぃ……じ\nゅぷっ、いっぱいしてあげますぅ……んじゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ、はっ、んんっ……第２ラウンドになると……おっぱいのぬめりも…\n…結構ヤバい感じになりまふねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイの精液と、あーしの汗と……唾液と……んっ、色々混ざり合ってぇ\n……ぐちゅぐちゅ音……ヤバすぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あふっ……んんっ……！　乳首……押し付けちゃいますか？　\nいいですよぉ……んっ、えいっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あーしにも、めっちゃ電気走るっス……この気持ちいーの……\nヤバ……んっ、はっ、あっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……あふっ、んりゅっ、れろ……ちゅぱっ、舌がもう……自然に\n動いて……止まらないっス……んりゅっ、れろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゅぷぅっ……はぁ、んっ、エロい気持ちが……全部おっぱいと……口に乗\nり移って……んじゅぷっ……おぷっ、んふっ、あぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「擦れてるとこ……まるでセンパイと一つになってるみたいで……マジ……気\n持ちいいっス……んぁっ、はぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぅっ、んくっ……あぁ……センパイも……腰を使って……あぁっ、おっぱ\nい……犯してるっ……本気のおっぱいセックス……気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ、あーしもっ……もっとクポって咥えて……もごっ、顔を……むぐっ\n、縦にスライドひゃへてぇっ……じゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「うぐっ、んぐっ、りゅぷっ、んむぅっ、じゅるっ、んちゅぷっ……！　ぷぁ\nっ……チンポ吸い付きまふよっ……んんっ、んじゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぁ……また、新しい先走り……れてるっ……センパイ……おっぱい感じて\nくれてまふねっ……んじゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「次も……我慢しないで……一気にらひてっ……いいれふからねっ……センパ\nイの欲しいれふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ……飲みたいれふけど……もひろんっ、今度は……ぶっかけでもっ……\nいいれふよっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイの欲望をっ……あーしに、思いっきりぶつけてくれればっ……なん\nれもいいれふからっ……んっ、おっぱい……ぎゅってしますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「らからっ、ザーメンっ……早くっ、射精っ……ひてくらひゃいっ……じゅぷ\nっ、んじゅるっ、んじゅぅぅぅぅぅぅーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぐっ……んぶぅっ！　おぷっ……んぐっ、うっ……んふっ、ふごい……れ\nてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「２発目なのに……全然勢い変わらない……んぐっ、じゅぷっ、んっ、こくっ\n、んっ、んぐっ、飲みきれないっひゅ……むぐっ、んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぁ、はぁっ……ふごい……量、れましたぁ……んじゅぷっ……\nちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……んっ、まだ全部……出し切れてないれふよね……後は、おっぱい\nで圧迫して……搾り出しますねぇ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゅぅぅぅぅっ、ずじゅるっ……んちゅぅぅっ……じゅぷっ、んりゅっ……\nんちゅっ、ちゅぷぅぅ……んふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁぁー、たっぷり飲みましたぁ……マジご馳走様っス！　んんーー、満足\nぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「っととぉ。ただ満足してちゃダメっスね。最後のお掃除フェラまできっちり\nとですよね。ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅ……んっ、まだヌルンとしたエキス……チンポの先に残ってま\nす……ちゅぅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ、はーい、おっけーっス。ピカピカの新品同然チンポに戻りましたよ\n～なーんて、えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイ……パイフェラ堪能してもらえましたか？　あーしも、めちゃくち\nゃ楽しんじゃいました。またエッチしましょうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あぷっ……顔ぶっかけっ……すごいっ……いっぱいっ……出て\nまふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あふっ……新鮮でトロトロのチンポミルクぅ……あぁ……んっ、へばりつい\nてます……はぁんっ、おっぱいにも垂れて来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、ホントに元気ですね……センパイのチンポ……ちゅぱっ、んんーっ、\n精液も……テイスティー、めちゃウマっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「まだ、もう少し出そうですか？　じゃあ……後はおっぱいをズリズリして…\n…残ってるのを搾り出しちゃいましょうねぇ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっしょ……よいしょっ……あはっ、出てきた……先っぽから、ちょろっと\n出てくるの……なんか可愛いー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「で、当然これはぁ、しっかり残さず頂かないとぉ……んっ、れろ……ぺろ…\n…んりゅ……れろ、んちゅっ、んはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「これでおしまいですかね？　あっと、もちろんお掃除を忘れちゃいけません\nね。今、しちゃいますからねぇ……んちゅぷ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……れろ、えろ……んっ、これで……おっけーっス。いっ\nぱい出してくれて、マジお疲れ様でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「それで……どうでしたか？　んふふ、サキュバスのパイフェラ……楽しんで\nもらえましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「気持ちよくなってくれたなら、よかったっス！　また、したくなったらいつ\nでもエッチしましょうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
