		{"command":[ "PLAYVOICE", "101_0103408" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「は～～～……びっくりしたぁ……あんなにいっぱい発射するだなんて、思っ \nてなかったです……ふぅ……」", "NORMAL" ]},
