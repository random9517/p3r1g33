		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103302" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああぁぁ……こんなに出すだなんて、はぁ、はぁ、ひやあ！？　ま、まだ出 \nてる……うわぁあ、すごぉ～～い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103303" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「か、顔が……ドロドロに覆われているです……ああ、顔に精液がびっちょり \nくっついてる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103304" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ……い、息が苦しい……んん、ふぅ……ああ、鼻の中に精液 \nが入ってきちゃったぁ……精液の匂いで、いっぱいになってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103305" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……顔が、おっぱいが、隊長さんにいっぱい汚されちゃった… \n…ああ、酷い……こんな姿、妹達が見たら、どう思うんだろう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103306" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……ああうぅ、精液の匂いで、頭がクラクラしちゃうぅ……は \nぁ、ふぅ……鼻の中に射精されたみたいです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103307" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んん……ちゅるる、れろれろ……ゴクン……んん、変な味ぃ……口の周 \nりもビチャビチュです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103308" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……目の前が真っ白ですぅ……ああ、谷間がニュルニュルして \nる……ん、ふぅ……変な気分になっちゃうですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103309" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そ、それで？　もう満足されたですか？　そう……よかった、ですぅ……こ \nれ以上続けたら、私、私……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103310" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「い、いえ、なんでもありませんっ、お気になさらずに……そ、それじゃ、ま \nたこのトレーニング、して下さいね……」", "NORMAL" ]},
