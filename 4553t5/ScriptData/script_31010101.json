		{"command":[ "PLAYVOICE", "101_0103402" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うぇぇぇ……酷い味ぃ……はぁ、はぁ……ううう、ギリギリ毒じゃないって \n感じの味、です……げほっ、おえぇぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103403" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うう、喉の奥に飛び込んできちゃいました……はぁ、ふぅ……ゴホゴホ…… \nうう、むせるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103404" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああ、すごぉい……息をすると、精液の味がします……あああ、鼻の中まで \n入ってる……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_10" ]},
