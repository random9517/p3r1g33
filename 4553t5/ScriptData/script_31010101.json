		{"command":[ "PLAYVOICE", "101_0103401" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んっ！？　んぶぅぅ！　んぐっ、げほっ……ごほ \nっ……うぐぅぅぅ……い、いきなり何するんですう……おぶぅ、んんぅ……っ \n」", "NORMAL" ]},
