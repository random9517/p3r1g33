		{"command":[ "PLAYVOICE", "101_0103405" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「こぼさず最後まで飲め？　うう、わ、わかりましたです……ん、ん～～～… \n…ゴクン……はふぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103406" ]},
		{"command":[ "SETNAME", "序" ]},
