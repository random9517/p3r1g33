{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "101_0103101" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あのっ！　来ました。えーっと、何かトレーニング的なことをするんですよ \nねっ！」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00010101_01", "8", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103102" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「運動とかぶっちゃけ苦手ですけど、持ち前の根性で頑張ります！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103103" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　運動苦手ですよ！　サムライになったのは、テストで楽するためです \n！　刀とかサムライテールになるまで握ったことすらありません！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103104" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「なるほど……だからこそトレーニングが必要なんですね！　で、どんなこと \nするんです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103105" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「へ？　エッチなこと……？　きゃっ！　えっ、や、やだ、ズボンを脱がない \nで下さいです～～！　ひっ、やっ！　止めてぇぇぇ…っ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103106" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「…………うう、ほ、本当にこんなことで強くなれるんです？　は \nうぅうぅ……恥ずかしい……おっぱい、男の人に見られるなんて初めて……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103107" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「こういうこと、初めてか……ですって？　そ、そりゃそうですよっ……おっ \nぱいで。お、お、オチンチンを……アレするだなんて……ひうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103108" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そ、そそ、それより……私、おっぱい変じゃありませんか？　あうぅ……あ \nんまり、自信ないんですけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103109" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「だ、だって、みんなジロジロ見てくるんですよ？　うう……確かに私、ちょ \nっと大きめですけど……なんだか見られるの苦手で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103110" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……おっぱい、綺麗？　ほ、本当です？　え？　それに、いやらしい……あ \nあうぅ、は、恥ずかしいです～～……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103111" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そ、それで？　どうしたら、このトレーニングは終わるんです？　え？　気 \n持ちよくなれば終わる……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103112" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「こ、これを気持ちよくすればいいんですよね……ええっと、気持ちよくする \n方法、知ってるような知らないような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103113" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　基本的なことは保健体育の授業で習うはず……です？　そんなこと言 \nわれても困るです！　私、保健の授業は居眠りの時間って決めてますから！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103114" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　元気よく言うことじゃない……？　ま、まあ、どうだっていいことで \nすよね～……あはははは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103115" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「で……？　結局どうすればいいんです？　ふえ？　まずおっぱいで、オチン \nチンをもっとぎゅ～～～っと挟む……？　こ、こうでしょうか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103116" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うぅぅ、オチンチンの匂いがします……結構おしっこの匂いがするんですね \n……うう……ま、まあ、我慢できますけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103117" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「それからどうしたらいいんです？　はぁ、なるほど……ぎゅーっと挟んだま \nま、上下におっぱいを動かす……！？　それって……どうやるんです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103118" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「おっぱいを上下に動かすなんて、そんな器用なこと──ふええ？　あ、ああ \n、手で持って動かしていいんですか……そ、それ先に言って下さいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103119" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええっと……こう、ですか？　なんだ、簡単ですね！　これなら楽勝です。 \nこれで気持ちよくなったです？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103120" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えー……？　もっと繰り返すんですか……わ、わかりました。頑張ります！ \n　よいしょ……こらしょ……ん、んん、んくぅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103121" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はふぅぅぅ……結構繰り返しましたけど、いかがです？　 \n気持ちよくなったです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103122" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　ホントですか！　気持ちいいですか！　あはは、嬉しいです！　なん \nだかだんだん楽しくなってきたですよ！」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103123" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「このまま続ければいいですか？　わかりました……はぁ、はぁ……え？　イ \nクまで続けろ、ですって？　一体どこに行けば──」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103124" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「わ、わかってます！　『イク』って意味ぐらい、なんとなく知ってるです！ \n　はぁ……はぁ……イカせればいいんですね！　もっと気合入れるです！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103125" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ふぐぬぬぬぬぬぬ……う、うぐぅ、うおりゃああ！！　は \nぁ、はぁ……え？　気持ちよくなってきたですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103126" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「でも声がエッチじゃない……？　そんなことどうでもいいです！　サムライ \nテールに不可能はありません！　何がなんでもイカせてみせます！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103127" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ふぬぬぬ、うぐぬぬぬぬっ！！　はぁ、ふぅ……うぁぁ、 \nおっぱい、ジンジンしますぅ～～……」」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103128" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「きゃうぅう、お、お、オチンチンが、震えてる……ああん、谷間が、熱い… \n…はぁ、はぁ……んん、うくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103129" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　そろそろ、出そう……？　おしっこですか？　どうして私がおしっこ \n我慢してること、知ってるです……？　今もチビっちゃいそうです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103130" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　あ、ああ、せーえき……？　せ、せーえきぐらい知ってるです！　は \nぁ、はぁ……なるほど、精液が出れば、終わるんですね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103131" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……わかりました……んっ、くぅ……はぁ、はぁ……い、いい \nですよ。出して、下さいはぁ、ふぅ……んっ、うぐぅぅぅ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103132" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「きゃうぅ、震えてる……谷間の中で、オチンチンが、ビクンビクンしてます \nぅ……はぁ、ふぅ……んっ、くぅ……うぅ、うあぁあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103133" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「イ、イク、ですか？　はぁ……はぁ……あああ、オチンチン膨らんでる…… \nひゃうぅ……出る……精液が、精液が、オチンチンに集まってる～～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103134" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひええええっ！？　こ、こんな感じで出るんですか……？　はぁ、 \nはぁ……うあぁあ、すごぉい……こんなに、いっぱぁい……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103135" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あうぅ、熱いぃ……おっぱいが……谷間が、真っ白になっちゃってるですぅ \n……はー……は……あはぁぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103136" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うぁぁ、顔までドロドロですぅ……んん、ふぅ……変な匂い……んんぅ、そ \nれに、変な味ぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103137" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あふぅ……頭が、ぼーっとしちゃうですぅ……こ、これが \n精液のパワー……なんですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103138" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「サムライとして、さらに成長するために、こーいうことをさせたんですね… \n…はぁ、はぁ……お心遣い、感謝ですっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103139" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふ～～……こ、これで、お仕舞い、です？　え？　もう一回……？　わ、わ \nかりました……私、頑張るですっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103140" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人いわく……『エッチは相見互い』！　私も段々楽しくなって来たところ \nですからね……うふふふ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103201" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「よいしょっ、どっこいしょっと……はぁ、ふぅ……うあぁぁ、なんだかさっ \nきよりも硬いくらいですっ、うわぁ……すごぉい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103202" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……にちゃにちゃして、なんというか……ん、はぁ……変な感じ、 \nです。精液って、こんなにドロドロしてるものなんですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103203" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ……この匂い……うう、なんだか漂白剤みたい……。私、時々家事を \nするので、漂白剤の匂いを知ってるんです。これ、すごくないです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103204" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　べつにすごくない……？　そ、そうなんですか……まあ、どうでもい \nいことですねっ……はぁ、ふぅ……ああ、精液の匂い……すごぉい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103205" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……ふええ？　匂いで興奮してるのか、ですって？　うーん…… \nどうでしょう？　わかんないです……でも、ちょっと好きな匂い、かも……？ \n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103206" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あぁあ、なんだか、ぼーっとしちゃう、です……はぁ、はぁ……ああ、やだ \n、谷間がにちゃにちゃする……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103207" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「さっきと感触が全然違います……え？　精液ってすぐ渇く？　水気が無くな \nってるから、こんなネトネトしてるんです？　へー……」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103208" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、は……あふぅ、精液に詳しく、なれそうです……ん、んん、はぁ…… \nはふぅ……え？　気持ちいい……？　ホントですか？　嬉しいです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103209" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「もっと激しい方がいいです？　わかりました！　超気合入れて、全力でゴシ \nゴシするです！　……え？　やりすぎ注意？　わかりました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103210" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……んん、よいしょ……どっこいしょ！　ふん、ふん……うぬぅぅぅ…… \nはぁ、はぁ……どうですか？　ちょっと激しくしましたけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103211" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　もうちょっと激しく……？　わ、わかりました……ふん、ふんふん、 \nぬぬぬぬ～～～～っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103212" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「もっと？　わ、わかりました……ふぐぬぬ、ぬわぁぁぁっ！！　はぁ、はぁ \n……け、結構疲れるですっ！　でも、ド根性ーーっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103213" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……へ？　やりすぎ……？　わ、わかりました……じゃあ、こ \nれぐらいで……はぁ、はぁ……ん、んふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103214" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……あははぁ、隊長さんっ、今ちょっといい顔しましたです！　えへへ \n……それに、ちょっとエッチに喘いでたですっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103215" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふふふ、なんだか楽しくなってきたですよ……はぁ、ふぅ……ん、んん、ど \nうです？　歴史あるサムライの家系のおっぱいは……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103216" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……まあ、私自身サムライに全然興味なかったんですけどねー……あはは、 \nって、どうでもいいですね、そんなこと……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103217" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　そろそろイキそう……？　わ、わかりましたっ、気持ちよくなったら \n、じゃんじゃん出して下さいですっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103218" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……さあ、いつでもどーぞぉ！　さぁ、どばーっと……はぁ… \n…ふぅ、ん、ん、はぁ……はぁぁん……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103219" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああ、なんだか興奮して来ちゃいました……はぁ、ふぅ……精液、欲しい… \n…ああ、やだ、私、どうしちゃったんだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103220" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　出る？　ど、どうぞ……はぁ、はぁ……下さい……隊さんの、せーえ \nき、私に……ん、んん、はぁ……んんんん～～～……っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "101_0103301" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃん！？　ひやあああ！？　あっ、ああああ… \n…す、すごい、さっきより、ん、んん、激しい……ですぅ……はぁ、はぁ…… \nきゃうぅぅ……っ」", "NORMAL" ]},
