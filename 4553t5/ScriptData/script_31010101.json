		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0103407" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　まだ口の周りにこびりついてる？　ん……れろれろ、あ、ホントだ… \n…じゅるるる…………ゴクン……あふぅ……」", "NORMAL" ]},
