		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「さっきみたいに、んちゅっ、私にむかって精液を……んちゅぱっ、容赦なく\n飛ばすつもりでいるのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「いいから、んちゅぶっ、ちゅるる……精液……んちゅっ、ちんぽから出しち\nゃいなさい……んれろっ、れろれろぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んんっ、はやく……んれろぉっ！　じゅるるっ、んっ、じゅぶっ\n、じゅりゅりゅっ、んんっ、じゅぶぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　んぁっ、ああ……っ！　んはぁあああぁぁぁ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ま、また……ンッ、顔に……。んはぁ……はぁ……。メガネに、精液を……\nんっ、ああ……んふぅうう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんなに重たい精液が……レンズにのっかって……はぁ……メガネが重たく\n感じるほどにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。も……もういいわよね……？　ま、まだなにかあるの？\n　もしかして、またペニスの掃除をさせるつもり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ、射精後のペニスをまた……んちゅぱっ、こうして舐めさせ\nるなんて……ちゅ、ちゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んふぅ……濃厚なペニスの味……んちゅるるっ、頭の中が真っ白になっちゃ\nいそう……だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「れろっ、れろれろぉ……。もう……こんなに卑猥なことばかりさせるなんて\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「き、気持ちよさそうだったですって！？　こっちはメガネを思いっきり汚さ\nれているのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「気持ちいいわけがないでしょ。うぅ……たしかに、乳首はこんなにコリコリ\nになってしまっているけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「とにかく、異種族交流はここまでよ。さ、さっさと上からどきなさい！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んぶぅうっ！　んっ、んぁあっ、んはぁっ、ああぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んぁあっ、精液ぃっ！　ちんぽから精液がっ、んぐうっ！　いっぱいっ、口\nの中に入ってくるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁあっ、ネバネバしてっ、んぐぅっ、ひどい味ぃ……んくっ、な\nのに……身体が……熱くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「む……無理やり精液を味わわされて、興奮しているのかって、そんなはずな\nい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「え……エルフだぞ……！　エルフが、こんな……ニンゲンの精液で、発情な\nんか……んっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽ、ちんぽ口にっ、んむっ、擦りつけるな……んぅっ、んふぅうっ！　\nはぁっ、あむぅっ、んっ、んじゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「くひゅぅうっっ！　舌が痺れるぅっ！　ちんぽ味わわされてっ、んっ、んじ\nゅるるぅっ！　勝手に、舌が動くのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んむぅっ、じゅぶっ、じゅぶっ、じゅるるるぅっ！　んふぅ～～～っ！　も\n……もういいでしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「射精した後のちんぽも、ちゃんときれいになったんだから……もう、異種族\n交流は、今日はここまでよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「また今度交流しようですって……！？　そ、それは……ふんっ、考えておい\nても……いいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103410" ]},
