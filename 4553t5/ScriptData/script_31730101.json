		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……って、どうして服を脱いでいるの！　やっぱりニンゲンは野蛮ね。急に\nペニスを露出するなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「し……親睦を深めるために肌を晒すですって……？　そんな文化聞いたこと\nがないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「裸の付き合いという言葉がある？　だ、だからって、ニンゲンの前で肌を晒\nすなんてできないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「うっ、不公平と言われれば……そうかもしれないわね。だったら胸だけ見せ\nろって？　し、仕方ない……わね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「きゃぁあっ！　な、なにをするの！　胸を見せた途端、押し倒すだなんて…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017301_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「しかも、ペニスを胸の間に挟むだなんて……！　ンッ、ちょっと、これって\n興奮しているの？　硬くなってるじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんな異種族交流、聞いたことがない……ああんっ！　ペニスを動かさない\nでっ、ンッ、胸に……擦れるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「う……くぅ……。こんなに顔の近くに、ペニスが……。な……なんて大きさ\nなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「胸から真っ赤な亀頭が顔をのぞかせるほど勃起して……んんぅ……ああ……\nあはぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちょっと、強く揉み過ぎよ……アンッ！　そんなにぎゅっと、胸でペニスを\n挟まなくったっていいでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンと違って、エルフの胸はデリケートなんだから……って、聞いてる\nの？　あぁんっ！　だから、強い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「強く揉まれて感じてるって、そんなはずないでしょ……ンッ、あはんっ！　\nちょっと……さっきから口元に、ペニスを近づけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「な、舐めろってこと？　胸で挟んで、ペニスを擦りつけるだけじゃ満足でき\nないって言うのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ど……同族相手にもしたことないのに……。ニンゲン相手に、フェラチオま\nでさせられるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「なに？　フェラチオを知っていて意外？　エルフだって、性行為の文化くら\nいあるのよ。バカにしないでちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「舐めれば、いいんでしょ……んっ、ちゅる……ん、んふぅ……ちゅ、ちゅぱ\n……。ン……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、ん、んちゅ……これがニンゲンのペニス……んちゅぱっ、なんて\nひどい味なの……ん、ちゅるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「この、裏筋の部分なんか特に……んれろ、れろれろぉ……。舌がピリピリす\nるような味……んちゅぶっ、だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅっ、ちゅるる……。ンッ、ちゅぷっ、ぴちゃ、ぴちゃ……。\nんちゅぷ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ペニスが……ンッ、谷間でビクビクしている……わね……。ちゅるっ、私の\n舌が……ンッ、気持ちいいのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぶ……。これがフェラチオなのね……んちゅるっ。ペニスを\n舐める行為でオスがこんなに悦ぶなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「胸を掴む手にも、力が入っているみたいね……。アンッ！　こうやって舐め\nられて、余裕がなくなってきているのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、乳首をつまんで……んんっ、くぅうっ！　ペニスを舐めなが\nら興奮なんて……んっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「これは、異種族交流の一環なんだから……んちゅ、ニンゲンと違って、いや\nらしいことなんか考えていないわ……ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゅぷっ、ちゅぷっ、んちゅるるっ。そんなに……んちゅぱっ、腰\nを振らないでちょうだい……んっ、ちゅっ」", "NORMAL" ]},
