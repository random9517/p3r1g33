		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、こんな……顔に、んぐっ、すごい臭いの濃い……せ、精液よね……\n？　これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ドロドロした……熱いのが……いっぱい……。くぅう……しかも、大切なメ\nガネに向かって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こ……これがニンゲンの射精……。これほどまで粘度の高い精液をだすなん\nて……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「繁殖のことしか考えてない、野蛮な種族だわ……あなたたちは……。んっ、\nんじゅる……ちゅぶ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
