		{"command":[ "PLAYVOICE", "v2_173_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んぅ……先っぽからまだ……んちゅぶっ、ネバっこい精液が糸を引いている\nわ……んちゅるるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「これが……ちゅぶっ、ペニスの味……。人間の性器の味ぃ……ちゅぶっ、ン\nッ、ちゅるるぅ……ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んぅ？　夢中になって舐めている姿がエロいですって……？　なっ、なにを\n言っているの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「これは異種族交流なの！　な、何度も言わせないで。ニンゲンのペニスなん\nて、ただ物珍しいからこうしているだけよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「にしても、なんでペニスが硬いままなの？　私の顔をドロドロにするほど、\n射精したじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「い、一度だけじゃ収まらないものなの？　だからもっとしゃぶれですって！\n？　わ……わかったわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「本当に……萎えてないないし……んちゅばっ、むしろさっきよりも、大きく\nなっているように感じるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んちゅぶっ、それに私も……視界を制限されているせいか、さっきよりも感\n度が……んじゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　また胸を、んちゅぶっ、強く揉んで……んふぅっ、ちゅっ、ち\nゅぶっ、んぐぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私の胸を、ンッ、ペニスをしごくのに使いながら、フェラチオさせるなんて\n……んちゅぶっ、んっ、んんぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んちゅっ、んふっ、ちゅぱっ。んぅ……こんなふうに好き勝手されて、興奮\nなんか……ちゅぶっ、するはずないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ちゅ、ちゅぱっ、んふぅ……。ちゅるっ、ンッ、れろ、れろれろ\n……んれろぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「本当に……なんていやらしい味のペニスなの……。それに、胸を揉む動きも\n野蛮で……んちゅっ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「いい加減に、射精しなさいよ……んちゅるっ、ほら、ここよね？　エラのと\nころとか、舐めてやればいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んれろ、れろれろ……んちゅぶっ、なに……？　は、早く終わらせたかった\nら、おねだりしろですって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「調子に乗るのもいい加減に……んひぃっ、胸っ、だめぇっ！　力が抜けちゃ\nう……ンッ、わかったから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「い……いっぱい舐めるから……。ペニスから、精液を……って、ちんぽって\n言えですって！？」", "NORMAL" ]},
