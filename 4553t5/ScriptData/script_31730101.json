		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ううぅ……。エルフがニンゲンに向かって、こんな卑猥な言葉を言うことに\nなるなんて……」", "NORMAL" ]},
