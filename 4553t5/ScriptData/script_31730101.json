		{"command":[ "PLAYVOICE", "v2_173_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　んはぁっ、ああっ！　んっ、んっくぅうううっ！　な……なに\n……いきなりぃ……っ！」", "NORMAL" ]},
