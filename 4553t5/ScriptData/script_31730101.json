		{"command":[ "PLAYVOICE", "v2_173_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ンッ、はぁんっ！　んぁっ、胸を……あんっ、ちゅ、ちゅぶ……\nそんなにぃ……んちゅぱぁっ！」", "NORMAL" ]},
