		{"command":[ "SETIMAGE", "0", "still_00017301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんぅっ、ちゅぶっ、んふっ、ちゅぱっ。また口に、ちんぽを押しつけて…\n…んちゅるるっ、ちゅぱぁっ！」", "NORMAL" ]},
