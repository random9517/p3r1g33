		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「お母さんたちも来れればよかったんですけど、仕事があるなら仕方ないです\nねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540009" ]},
