{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "俺たちは、龍神モードになったルナテミスと共に……暴れ続けるアナザー・稲\n穂姫のところまで戻ってきた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「……んむ？　なんじゃ。おめおめと逃げ伸びた負け犬どもが妾に何用じゃ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今度こそ、お前をぎゃふんと言わせにきた！　神社で暴れるのはやめてもら\nおう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺たちが来るまで時間を稼いでくれていたカグヤとＡルナテミスは、レジェン\nド状態を解除され、ボロボロの状態だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000201_01", "4", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「すまない。随分と待たせてしまったようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……その姿は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか。ついに、成ったか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。後は私たちに任せて休んでいてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690002" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー・稲穂姫！　おとなしく退いてここから立ち去るつもりはないのか\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690003" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "7", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00024103_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「ハッ、嫌じゃよ。この社が燃え尽き、崩れ落ちるまで妾は暴れることをやめ\nぬ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023690002" ]},
		{"command":[ "SETCHARA", "1", "char_00024103_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……ならば、戦うしかないようだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだそうだ！　む、無駄に苦労かけさせやがって……！　姫様、溜まった\nうっぷんガツンと晴らしちゃって下さいよ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「任せろ！　……いや、しかし、コレは中々制御が……。あっ！？　あっあっ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690005" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわ危ねえ！！　俺たちを攻撃するなんて、こ、殺す気ですか……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「し、仕方なかろう！　すごい力なんだぞ！！　制御が難しすぎるのだ！　金\n属バットで米粒をつまむような気分だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690006" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふむ。では、この子らは婆が守るからの、お嬢や、気にせず戦うがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そう言うなり、クラミツハはイルルとヤム、そして俺と自分、周囲の人々を囲\nう結界を張ってみせた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ほぉれ。これで誰かに被害が及ぶことはないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ありがたい……！　これで全力を出すことができる！　行くぞ、アナザー・\n稲穂姫！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690007" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふんっ。おぬしらに何が出来る。やれるものならやってみるが良い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023690003" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「吼えろドラゴニック・オーｒ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690008" ]},
		{"command":[ "SETCHARA", "0", "char_00000132_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……その名称はやめろォ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "龍の闘気を帯びたルナテミスが、全力でアナザー・稲穂姫に拳を叩きこむ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんだと！？　この力は……！　うッ、ぐっ！？　お、押し切られる……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023690004" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETTEXT", "「うああああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023690005" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "9", "CENTER", "0" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETTEXT", "ルナテミスの一撃を食らい、ブッ飛ぶアナザー・稲穂姫。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEINCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おねーさん、すごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やった！　蔵の方まで飛んでった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ぴょんぴょんと跳ねて喜ぶイルルとヤムを連れて破壊された蔵まで歩いて行く\nと……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "その中に、縛られた人影のようなものが見えた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰かいるぞ。……んっ！？　アナザーじゃない方の稲穂姫だ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほんものの稲穂姫さま……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「けほっ、けほ、けほ……！　正月から埃くさい蔵に閉じ込められ……。酷い\n目にあった……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「頼む……。ここから出しておくれ。けほっ、こんなところにいるのはもうこ\nりごりじゃあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかった。イルル、ヤム！　縄を解くのを手伝ってくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1", "2" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん、まかせて。稲穂姫さま、すぐに楽にしてあげるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690003" ]},
		{"command":[ "SETCHARA", "1", "char_00016401_01", "8", "CENTER", "-1500" ]},
		{"command":[ "SETCHARA", "2", "char_00017502_01", "0", "CENTER", "1500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "-600", "NORMAL" ] },
		{"command":[ "MOVECHARA", "2", "CENTER", "600", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんんっ！？　この縄、結構がっちり食いこんでる！　力を入れてほどかな\nいと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690002" ]},
		{"command":[ "SETCHARA", "2", "char_00017502_01", "7", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ありがとう、ありがとう、竜の子ら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690003" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00016401_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "2", "char_00017502_01", "8", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして、稲穂姫を解放した後……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺たちは、なぜアナザー・稲穂姫がここで暴れていたのかを稲穂姫に教えても\nらうことになった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾のアナザー……アナザー・稲穂姫があれほどまでに暴れていた理由は簡単\nじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690004" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「元々、あれは妾の親戚のようなものでな。妾と共に、大みそかの夜にとっぷ\nり飲み明かしていたのじゃが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690005" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「その時、以前、この神社が若い雄のおかげで繁盛したことをついつい自慢げ\nに言うてしまい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「過去の妾と同じく、閑古鳥が鳴きっぱなしの……別の神社を司っておったア\nナザーと、取っ組み合いの大喧嘩になってしまったのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690007" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うへぇ……。つまり酒の勢いで仲たがいをしたってことか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……そうなるのう。こちらの神社に嫉妬したアナザー・稲穂姫は、この社が\nなくなれば自分の社に人が来ると思い込み……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690008" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なかばヤケになって暴れておったらしい。よっぽど妾の話が、うらやましく\nてたまらなかったのじゃと思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690009" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「となると、いちがいにアナザーだけが悪いとも言いきれないような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ。その点、妾もきっちり反省せねばならぬ。とはいえ、アナザーのした\nこともまた、罪は罪。参拝客に迷惑をかけた責任は取ってもらわねばならぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690010" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、一体どうするつもりだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「決まっておろう。壁尻じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690011" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「か、か、か、壁尻ィ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「制裁として、今からアナザーを裸にひん剥き、裏のお布施用として……エッ\nチなサービス用の壁尻にしてやるのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690012" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「かべじり……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「裏のお布施用って何するの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "稲穂姫の言葉の意味がわからず、きょとんとするイルルとヤム。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "1", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00017502_01", "1", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺は無垢な２人に、これ以上破廉恥な場面を見せることを阻止するため、急に\n大声を出して稲穂姫の話をさえぎった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　稲穂姫も救出できたし、今すぐ姫様にお礼を言いにいかない\nとな！　そうだろ？　イルル、ヤム？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……そうだった。ルナテミスおねーさんのところにいかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「かべじり？　も気になるけどぉ……。ルナテミスおねえちゃんが心配してる\nかもしんないしね。うん、いいよ！　行こ行こ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690004" ]},
		{"command":[ "SETCHARA", "1", "char_00017502_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……やれやれ。なんとか稲穂姫たちから２人の興味をそらせたぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんじゃ。壁尻を使っていかぬのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_010023690013" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「２人の教育に悪いんで、俺たちは不参加で！　それじゃあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETTEXT", "俺はイルルとヤムの手を取って、慌てて姫様の元に戻ることにした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「お嬢。よく頑張ったのう、偉い偉い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690003" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "今回の１番の功労者であるルナテミスの頭を、クラミツハが優しくなでなでし\nているところに出くわしたのだった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00000101_01", "2", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふふっ♪　そんな……。先生に褒めていただくほどのことでは……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そんなことはないぞ。あの力が出せたのも、すべてお嬢の頑張りのおかげ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「婆はお嬢のことが誇らしい。これからの活躍を楽しみにしておるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます……っ。うふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690010" ]},
		{"command":[ "SETCHARA", "1", "char_00000101_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あのぉ～……。お取込み中のところ、すみません。ルナテミスさんがクラミ\nツハさんの力の断片で強くなったとの事ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023690001" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「クラミツハさんが戦えば、もう少し被害が少なかった……ような？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023690002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ギクッ！　……ば、婆にそんな力はないぞ……。ははっ、はははっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690006" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そ、それはそうとして！　お嬢の今回の働きは素晴らしかった。それだけは\n間違いなく本当じゃよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023690007" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、光栄です……！　龍神様の……！　クラミツハ様のお役に立てて良かっ\nた……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023690011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "クラミツハに頭を撫でられて、子供のように笑うルナテミス。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大人になると、褒められても素直に喜べなかったりするもんだが……。なぜ\nか、クラミツハの前では強がらなくていいような気がするな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんもがんばったもんね？　イルルがなでなでするね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムだって褒めたげるし？　ホラ、頭下げて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう？　あ……ありがとう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「なでなでなで～♪　なでなでなで～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00017502_01", "8", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1"]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパがいつも頑張ってることくらい、ヤムはちゃーんとわかってるんだから\nね……！　なでなでなで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……これは思ったよりも嬉しいぞ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えらいね、えらいね、おとーさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なでなでなで♪　なでなでなで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……嬉しい。嬉しいんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ちびっこ２人に頭を撫でられている俺に、周囲の白い目が突き刺さってくるの\nがわかる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ううっ！？　人として大切なものを代わりに失っているような……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もう撫でられなくても良くなったのか？　で、では……こちらを撫でてくれ\nないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023690002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私たちも頑張ったから……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023690002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマにナデナデ……してほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023690003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "体力が回復したのか、いつの間にか近くに来ていたカグヤとＡルナテミスがこ\nちらに頭を差し出してくる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00000109_01", "2", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……しかし、俺が動くより先にイルルとヤムが手を伸ばし、２人の頭を撫では\nじめた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2", "3" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「カグヤおねーさんもなでなで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023690009" ]},
		{"command":[ "SETCHARA", "2", "char_00016401_01", "8", "CENTER", "-1500" ]},
		{"command":[ "SETCHARA", "3", "char_00017502_01", "8", "CENTER", "1500" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "200", "NORMAL" ] },
		{"command":[ "MOVECHARA", "0", "CENTER", "-200", "NORMAL" ] },
		{"command":[ "MOVECHARA", "2", "CENTER", "-600", "NORMAL" ] },
		{"command":[ "MOVECHARA", "3", "CENTER", "600", "NORMAL" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「アナザーお姉ちゃんもぉ、良く頑張りました～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023690008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺に向けられていた白い目は次第に２人の方へ集まっていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1"]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うぅ……、見られてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023690003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、これは……カツマに撫でられるより恥ずかしいぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023690004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETTEXT", "俺たちは、そうして竜ッ娘２人に撫でられる形で……今年も正月を終えるのだ\nった。", "NORMAL" ]},
