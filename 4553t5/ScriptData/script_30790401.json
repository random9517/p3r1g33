{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「やぁ、ゆっくりしている所を失礼するよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00007904_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、そんなに驚かなくてもいいだろう。この大浴場は、完全プライベー\nトな空間という訳じゃない。ちょっとお邪魔しただけさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「うん？　風呂場に帽子？　ああ、気にしないでくれたまえ。これは僕のトレ\nードマークだし、本物という訳でもないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「っと……そうだった、なに……今日は君と親交を深めたくてね。ほら、裸の\n付き合いというやつさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ここの所、何かと君にはお世話になっているしね。ちょっと、そのお返しを\nしようと思って、こっそり忍び込んだという訳さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おっと……ふふっ、慌てている割には、ここはもう随分と正直に反応してい\nるじゃないか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00007904_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「しっかり反り返って……逞しいね。さあ、そこに横になってくれないか？　\n僕にご奉仕をさせて欲しいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、ありがとう……それじゃ、たっぷりと泡をまぶして……ぎゅうっと\n……身体を……くっつける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んふふっ……柔らかいだろう？　僕の身体は、しっかりと君の肌にフィット\nするようになっているけど……泡がより快感を足してくれるのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「こうして……ゆっくりと身体を上下させると……んっ、ふふっ……ぬるんと\nよく滑る……んっ、く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「どれ、もう少し泡を足してみようか。もこもこにし過ぎると、見た目も感触\nも泡だらけでつまんないから、加減が難しいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これくらいで……ずりずりっと……あふっ、あぁ……ごつごつした君の胸板\nに……僕のおっぱいが擦れていくよ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んふっ、なかなかいい感じじゃないかな？　ほら……何より\nこの正直なペニスが大好きだって認めてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「どうだい、ここを……手で扱かれたいって……そんな風に思ってるんじゃな\nいのかい？　ほら……すぐ下の玉袋も震えてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ちゃんとおねだり出来るなら、僕としても気持ちよくしてあげることにやぶ\nさかじゃないんだが……どうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ……こういう時、君は本当に欲望に忠実だね。いいとも……このペニ\nス……君の言い方だとチンポ……か。扱いてあげるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まずは……根本の方をぎゅっと握って……泡と一緒に、皮をスライドさせて\nいく……っと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、結構大きく動くね……これをまた元に戻して……何度も往復させて\nいく……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あはっ……くちゅくちゅって……水気のある音が先端から鳴ってるよ。うわ\n……何だか、もう一回り大きくなって来てるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「もっと速く動かしてあげるといいんだね。いいとも……こんな感じかな……\n？　ふふっ……んっ、ふっ、はっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「敏感な場所なんだね、すごくビクビクして……こんな威容でも、どことなく\n可愛さも感じてしまうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「さあ……後は、おっぱいも……しっかりと押し当てていこうかな……んくぅ\nっ……ふっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これは……思ったより、僕の方にも刺激が、来るね……そうか、気持ちが高\nぶっている所に、乳首が当たって……感じるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ……それなら、えいっ……もっと、乳首を……お腹の辺りから……つ\nぅっと……胸板まで……んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ、おっと……君の乳首とも重なっちゃうね……ふふっ、しかもよく見た\nら勃起してるし♪　つんつんって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あふっ……！　んっ、今のもよかったんじゃないかな？　肌と肌がしっかり\n密着して……揉みくちゃになる感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、んっ、僕の方も……かなり、ドキドキしているよ……もっと乳首…\n…ううん、おっぱい全体をめり込ませて……ずりずりっと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、脇の下がくすぐったいかな？　でも、多少は我慢してもらわないと\n……このムズムズも味のうちってね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……さて……こっちも、大分余裕がなくなって来たんじゃない\nのかな……？　このカリ首の所……えいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ、跳ねてる、跳ねてる♪　いいねぇ、その分かりやすい反応……もっと\nしてあげたくなっちゃうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほぉら……指が滑る度に、身体に力が入っちゃうね？　これだけ密着してい\nれば、もちろん僕にも伝わってくるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そのドキドキを、もっと僕にも分けて欲しいな……んんっ、あふっ……あぁ\n……本当に気持ちいいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まぁ……一方的なご奉仕よりも、こうして……お互いに感じあう方がいいよ\nね。あっと、でも君のお触りはご法度だよ。今は我慢して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、ある程度自由が効かない方が、もっと快感を得られることってのは\nあるものさ。だから、今はじっと僕のご奉仕を堪能して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……なんてことを言ってるうちに、もうこのペニス……いや、チ\nンポが出る寸前になってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403135" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、いいよ……遠慮はいらない。僕の身体に思いっきりぶち撒けてくれ\nていいんだからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……さあ、ビクビク震えてる先端から……激しい噴水が出る所…\n…いっぱい見せてくれっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あはっ、出た出たっ♪　あぁっ、すごいすごいっ、これはす\nごい量だねっ……元気な射精だっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あふっ、僕の身体が泡と精液まみれになっていくよ……んぁぁ……べっとり\nだ……あっ、んんっ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ふふ……どうだったかな？　身体同士をくっつけ合うだけで\n……こんなに気持ちよくなれるなんて……素敵だよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても、このべっとりとした精液……ヌルヌルだよ……これ\nをローションにしたら、もっと気持ちよく出来るかもね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、自分の身体が自分の精液に塗れるのはゾッとしないかい？　大丈夫\n……そこは、上手く泡も混ぜて上手くやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほら……チンポは正直だ。ちゃんと、まだして欲しいっておねだりをするよ\nうにヒクヒクしてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「分かってるさ、大丈夫。このまま、続けて泡踊りを楽しんでもらうよ。今度\nは、もっと大胆に身体全体をくっつけていきたいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほぉら……ずりゅずりゅって……んふふ……おっぱいが顔の近くまでめり込\nんで……太ももでぎゅっとチンポを挟み込む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おっと次は乳首を舐めてみようか？　れろ……んっ、んりゅっ、コリコリの\n先端……とっても可愛いね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕の乳首と擦りつけて……あんっ！　あふっ、今の……僕にも電気が流れた\nみたいに感じるよ……あ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403207" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「このドキドキが高まった状態で……んっ、あぁっ……しっかりチンポを扱い\nてあげるからね……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「すごいね……あれだけ派手に出した割に、全然小さくならないで……この逞\nしさが、君があの組織でやっていける秘訣ってことかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「こんなのを見せつけられたら……あぁ……僕も冷静じゃいられないよ……も\nっと、んっ、おっぱい擦りつけてあげるからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、ふっ……僕のおっぱいも……すごく感じやすくなって来てる…\n…んくっ……あっ、んぁっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「コリコリの乳首……気持ちいい？　ポッチが……ぎゅってめり込んで潰れる\nの……見た目にいやらしすぎるよね……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「分かってるよ……もっともっとくっつけるからね……おっと、でも同じとこ\nろばかりじゃなくて……違うところもしっかりね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「くぅんっ、あっ、身体が……とっても忙しいよ……手でずっとチンポを扱き\nながら、おっぱいを重ねて……首筋を舐める……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「でも、一つ一つの反応が……直接僕の肌にも伝わって……感じてくれてるの\nが分かるのが楽しくて堪らないね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほら、睾丸もぬるんとした手のひらで包み込んであげると……ふふっ、また\n眉がぎゅっと寄って……いいんだよ、もっと素直に声を出しても♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そんなやせ我慢を、はぁっ……んっ、見てるのも……楽しいよねっ……ふふ\nっ、でも、それも……そろそろ限界かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0403217" ]},
		{"command":[ "SETIMAGE", "0", "still_00007904_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
