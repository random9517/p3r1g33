{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「青い空！　白い砂浜！　これらを独り占めだなんて、キミには贅沢すぎるく\nらいだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00023104_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おまけにほら、こんな水着の美少女までセットなんだよ？　んふふ、どうど\nう？　ボクの水着姿、新鮮でしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00023104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ん～？　やらしい視線を向けちゃって、キミってば本当わっかりやす～い♪\n　え～、そんなことないって～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「正直に言っちゃっていいんだよ？　『ジェスタ様の水着、めっちゃシコです\n！　見抜きいいッスか？』とかさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403104" ]},
		{"command":[ "SETCHARA", "0", "char_00023104_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぐらかそうったって、そうはいかないんだから。こうなったらチンポに尋\n問略してチン問」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの水着で興奮しちゃってるか、直接、チンチンにインタビューしちゃう\nもんね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おお、勃ってる勃ってる。ズボンを脱がした瞬間、ビンビンチンチンでお出\n迎えとはねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00023104_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こうやって、水着からデカチチポロリしちゃったらもっと硬くなっちゃう？\n　ふふっ、チンポ反応したねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「素直じゃないキミにはオシオキだよ～♪　せっかくだからこのチンチンを責\nめちゃおっかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ん……ちゅっ、ちゅぱっ。潮風の香りとチンポの匂い……。夏だねぇ……風\n流だねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こらこら、逃げちゃダメだって。もう、それなら逃げられないように、チン\nポぱっくんしてやろうかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁむ。んふふぅ、これでよし。ん～？　どうしたの？　チンポ咥えられて\n気持ちよくなっちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だめだめ、気持ちよくなったらオシオキにならないでしょ～。射精しないよ\nうに、しっかり我慢してよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んじゅっ、ちゅぶっ、ちゅぶっ、んじゅるっ。ちゅるる、ンッ、ちゅぶっ、\nんぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「口いっぱい、ンッ、キミのチンポでいっぱいになっちゃってるよ……。じゅ\nるるっ、しょっぱい味……汗かなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「この匂いと、味……コーフンしちゃうねぇ♪　じゅるる、じゅぶっ、じゅぶ\nじゅぶっ。よだれも溢れちゃうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ンッ、腰引いちゃだぁめ。じゅぷっ、そうやって無駄な抵抗する\nと、もっとちゅぱちゅぱしちゃうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んちゅぶっ、ちゅっ、んんぅ。唇で、キミのチンポを思いっきりしごいちゃ\nうもんね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ。腰をピクピクさせちゃって、んふふ、やっぱりキミのチンポ\nはいじりがいがあるなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅぷ、んじゅるっ、じゅずずぅっ！　舌、思いっきり動かしてぇ\n、チンチン舐めまわしちゃおうね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「竿の部分にぃ、舌を絡ませながら、フェラチオ～……。ンッ、ちゅぶっ、チ\nンポまでビクビクしちゃってるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぬるぬるのベロに竿責めされて、気持ちよくなっちゃう？　それじゃオシオ\nキになんないんだけどな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ま、射精さえガマンしてくれればいっか～。ほらほら、お尻にきゅっと力込\nめて、ザーメンお漏らしは我慢だよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクはキミが我慢してるのに関係なくフェラしちゃうけど♪　んっ、じゅる\nるっ、どんどん硬くなるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「熱く、硬くなっちゃってぇ。んぅ、ちゅぶっ、ちゅぶっ、ちゅぱっ。んんっ\n、じゅるっ、じゅるっ、じゅぶぶぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゅぼっ、じゅぼっ、じゅぼっ、じゅじゅじゅっ！　んじゅるるっ、じゅぶ\nっ、じゅぶっ、んっ、んっ、じゅちゅちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ、ついついキミのチンポに夢中になって口数がへっちゃうや。ん～？\n　またボクのことエッチな目で見てた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「随分余裕あるみたいだね。ボクみたいな美少女のフェラ顔オカズにしながら\n、射精ガマンするなんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポはパンパンに膨らんで、先走りトロトロで射精間近なのバレバレなん\nだからね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、じゅぶっ、じゅるるっ！　んふぅ、ほらほら、ガマンしなよ？\n　じゅぶっ、じゅぶっ、じゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、じゅぶっ、じゅぶぅっ！　なに？　でちゃう？　だめ\nだめ、射精は……んっ、んじゅるっ、ボクがいいって言うまでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるっ、じゅぶっ、んんぅっ！　んっ、じゅぶっ、んぁっ、チンポ\n、ビクンってはねて……んっ、キミ……イッちゃうの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、んっ、んくぅうううぅぅぅっ！　んぶぅ、ん……っ！　口に……\nいっぱいでてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのザーメン……精液がどぶどぶ口に……。ンッ、喉が詰まりそうなほど\n、ねっとりザーメンきてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……。んくっ、んっ、んん……んくぅ……。じゅるぅ……。こ\nんなに……たくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403135" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「口から溢れちゃうくらい、射精するなんて……。しかも、まだボクは射精の\n許可をしてないんだけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403136" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まったく、我慢のできないダメチンチンだなぁ。褒められるところはザーメ\nンの味だけだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなにボクのフェラが気持ちよかった？　もう、おだてたってなんにも出\nないよ？　てか、出すのはキミじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……むふ、ひらめいた。そんなに言うならこのままもう一回、オシオキのヤ\nりなおしってことで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの口マンコでもう１発、射精してもらおうかなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふぅ、んむっ、んちゅっ。ほらほらぁ、休むには早いぞチンチ～ン。んっ\n、ちゅぶっ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ザーメンまみれの口で、もぐもぐされて……んっ、んちゅっ。んふぅ、だん\nだん勃起してきたねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いやぁ、さすがの回復力♪　それとも、僕のお口が気持ちよすぎちゃって勃\n起止まんなくなってるとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それじゃ、ボクのフェラ顔オカズにザーメンどぴゅっちゃってね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふぅ、ちゅぶ、ちゅぶ、じゅるる、んっ、じゅぶっ。チンポ、んっ、す\nっごくおっきくなってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「さっきより、膨らんでない？　んじゅる、ますます元気なチンポ……んっ、\n精液の匂いでクラクラするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こんなチンポにフェラしてたら、ボクまで興奮してきちゃう。じゅぶっ、ん\nじゅちゅっ、マンコも濡れちゃうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぅ？　そりゃねぇ、キミのエロチンチンをペロペロしゃぶしゃぶしてるわ\nけだしぃ、水着の中はびっちょびちょだよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ！　なになに？　チンチンビクンってさせちゃって、もしかして想像\nしちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もう、本当にエッチなんだから。反省したまえ、このエロチンが♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403210" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「下のお口もよだれまみれだけど、じゅぶっ、いまはこっちのマンコでザーメ\nン搾っちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、じゅぶっ、じゅぶっ、んふっ、じゅるるっ、じゅちゅちゅ、じ\nゅちゅちゅぅっ！　チンポにいっぱい、吸いつくぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「先走りが、口の中にあふれるぅ……。じゅずずっ、これも啜りながら、射精\nまでイかせちゃうからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、じゅるっ、じゅるぅっ！　チンチン、口の中で跳ねて……ンッ\n、イキそうになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの舌に、好き放題しゃぶられまくってぇ……カウパー垂れ流しながら悶\nえちゃってるねぇ。じゅるっ、じゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんじゃ、今度はちゃんとチンポに射精許可だしちゃおっか。じゅぷっ、も\nう我慢できないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポに吸いつかれて、じゅぽじゅぽ口マンコで気持ちよくなっちゃって、\nんじゅるっ、チンポ……限界そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぷっ、じゅるるるぅっ！　キミの中に残ってるザーメン、全部吸\nいだしちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほら、イッちゃえ♪　じゅぷ、じゅるるっ、ボクの口マンコでぇ、アツアツ\nザーメンいっぱいだしちゃえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、じゅぶっ、じゅぶっ、んんっ、んっ、じゅぶっ、じゅるる、ん\nっ、んっ、んん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんんぅううう～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んむぅ、んぐっ、んふぅ……っ！　んくっ、んくっ、んん……また……いっ\nぱい射精してる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポから、どぷどぷ濃いの……んくっ、お腹の中に、直接流し込まれてる\nみたいだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅ……。んく、んっ、ぷはぁ……。まったくもう、いっぱいだせ\nとは言ったけど限度があるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403304" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こんなに……んちゅるっ、まだチンポの中に精液のこってそうだね？　じゅ\nるっ、じゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こうなったら、残りまで全部吸いだしてあげる。ちゅるっ、ンンッ、またチ\nンポをビクつかせちゃってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まだまだ射精したりないんだねぇ。んふっ、夏だからチンポも開放的になっ\nちゃってるかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なに？　そろそろ口マンコ以外の場所にも射精したいって？　え～、ボクは\nまだ気分じゃないしなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゃあ、ボクが満足できたら、マンコでもお尻でも、好きなところにハメさ\nせてあげるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それまで、キミのチンポが勃起し続けていればの話だけどね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ちょっといきなり腰を引くなんて……！　んっ、んんぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁあああぁぁぁ～～～～っ！！　ちょっ、チンポから勢いよくザ\nーメンでまくってるぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「口マンコじゃなくて、ボクの顔に、身体に、びゅるびゅるって精液かかっち\nゃってるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「２回目なのに、ドロッドロの濃厚精液ぃ……っ！　んぁっ、ああっ、いっぱ\nいかけられて……イッ、イク……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。もう……ひっどいなぁ……。ボクのこと、こんなに精液\nまみれにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403405" ]},
		{"command":[ "SETIMAGE", "0", "still_00023104_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミの精液のいやらしい匂いに包まれて、ますます興奮しちゃうじゃないか\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「え？　チンポがマンコに欲しくなったんじゃないかって？　ふぅん、そうや\nって主導権を取り返そうって魂胆？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「残念だけど、その手には乗らないもんね。ボクのマンコにハメたくてたまら\nないのは、キミの方でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほれほれ、ヤりたそうにチンチンヒクヒクさせてないでさぁ、ちょっとは強\n引にボクのこと襲ってみたらぁ？　キミにできるかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふ、ほれほれ。夏なんだしぃ、思いっきりハメ外してハメちゃおうよ。\nキミにその勇気があるならねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
