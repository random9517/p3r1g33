{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あいたたた……。……ん？　どこだ？　ここは？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「暗い空……？　夜……ってわけじゃなさそうだが。まさか、宇宙か！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ご明察ですわね。その通り、ここは宇宙です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000001" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「さあさ、ようこそいらっしゃいました。こちらがわたくしたちの宇宙船……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000002" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「宇宙海賊団！　滅棲俄鬼（メス〇キ）の本拠地ってワケだ！　驚いたか？　\nおののいたか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000001" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえ……見た目よりも重いから、運ぶのに結構苦労したぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000001" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「そうそう。ここまで誘拐……じゃなかった、連れて来たあたいらの苦労もち\nょっとはわかってほしーよな～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000002" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！　色んなメス〇キが一度に３人も！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "6", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00020901_01", "6", "CENTER", "-600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……メス〇キ？　ああ、偉大なるわたくしたち……滅棲俄鬼のことを、あな\nたも知っていらっしゃったのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000003" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「偉大なメス〇キってなんだ？　態度がめちゃくちゃデカいってことか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なんだ？　おまえ。人質のくせにえらそうに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000002" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ。本当に態度はかなりデカいみたいだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「態度、っつうのはよくわかんないけどさ。あたいら滅棲俄鬼の規模は超でっ\nかいぞぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000003" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいらは、誰もが聞いてビビっちまうレベルの海賊団。部下の数もいち、\nに、さん……。す、すごくいっぱいいる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい。今適当にごまかしただろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はぁ～！？　ごまかしてないし！　とにかくめっちゃすごいってこと～！　\nばかばか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000005" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえなんかより１００倍すごいし！　５００倍強いし！　８００倍えらい\nの！　あほあほオタンコナス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかったぞ。こいつ、見た目以上に〇キだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はぁ～！？　はぁ！？　はぁ、はぁ～！？　〇キじゃありませんけどオトナ\nですけどぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000007" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……わかりました。わかりましたから落ち着いて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000004" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「仲間になだめられてんじゃねーか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、んなこたどうでもいいんだよ！　なあ、俺はジュンジローと一緒にい\nたはずなんだが……お前らがどっかにやったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「じゅんじろー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000008" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「犬だよ犬、これっくらいのデカさのドーベルマン！　見てないのか？　はぐ\nれただけか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぁ？　おまえのざこざこの犬のことか？　それならここでおねんねしてる\nぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000003" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ば、ばたんきゅ～でございます～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024000001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、いた！　お前ら！　犬にまで手を出すなんてひどすぎるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「まさか。わたくしたちがそんなことをするわけがないじゃありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000005" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえを連れてくる時に勝手に転んで気ぃ失っただけだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000004" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ご主人を離すのです～！　って言いながらあたいらにぶつかってきてさぁ、\n頭打って倒れたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000009" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジかよ！　助けてくれようとしてたのか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、そ、それくらい……当然ですぞ。わたくしめはご主人の相棒ゆえ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュ、ジュンジロー……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくしたちは正義の海賊団。荒々しい真似などいたしません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000006" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺の拉致は普通に荒々しいと思うが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「疑ってくれた分も、きっちり強奪させてもらうとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000005" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「さぁて、これからどうしようね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000010" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「手っ取り早くぎったんぎったんのバッキバキにするならわたしがやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000006" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んっふっふっふっふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024000011" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おっほっほっほっほっほっ♪　うふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024000007" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あ～っはっはっはっはっはっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024000007" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ、一体どうしてこんなことに……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "8", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00020901_01", "6", "CENTER", "-600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれは確か、レディ・ホープに呼ばれて次元統制局に行った時だったような\n……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　ご主人！　約束の時間からかなり遅れておりますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024000003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あーもう、なんでいつもギリッギリに呼びつけんだよ！　俺だって毎日忙し\nいんだぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「……その点についてはごめんなさい。こちらもいきなり問題が発生したもの\nだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おおっ。なんとか間に合いましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024000004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「そうね。約束の時刻１分前。あなたにしては優秀な到着時刻よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなことはどうでもいいんだが……。で？　俺らだけ呼ぶっていうのは、\n一体何の用事なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「私の知人から、ヘルプを頼まれたのですが……次元統制局は今、人手が足り\nない状態でして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「もしお願いできるのなら、あなたたちに代わりに助けに行ってもらいたいの\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この流れ……。いつもの雑用に駆り出されるパターンだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「であれば、慣れたものではありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024000005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……。まあな。んで、その知人っていうのは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ヨーーーーホーーーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「呼ばれて飛び出たアタシこそ！　じ～げ～ん海賊団のアルフィルク！　待た\nせたな、野郎ども！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな陽気なキャラじゃなかっただろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「……と、フザけたことを言ってなきゃやってられないくらい困ってるんだ。\n助けてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうか、次元統制局と次元海賊団って対立関係じゃないのか？　いつの\n間にそんなに気安い仲になったんだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000609_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「時間帝国の一件もあって、今は一時休戦状態なの」", "NORMAL" ]},
