		{"command":[ "SETCHARA", "1", "char_00000609_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「……とはいえ、当然……また問題を起こすようならすぐに敵対状態に戻るけ\nれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000006" ]},
		{"command":[ "SETCHARA", "1", "char_00000609_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「おいおい。固いこと言うなよ～？　一緒に飲み合った仲だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000004" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「そ、そのことは……誰にも言わないって言ったじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000007" ]},
		{"command":[ "SETCHARA", "1", "char_00000609_01", "2", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA",  "0" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「まったく、素直じゃないね。お偉いさんは大変だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000005" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「からかわないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000008" ]},
		{"command":[ "SETCHARA", "1", "char_00000609_01", "5", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ちちくりあってるところ申し訳ないんだが、本題に入ってもらっていい\nか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「も、もちろんよ！　ごほんっ、ええと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000009" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アタシらの縄張りで、次から次に宇宙船が襲われてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000006" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっと。雑用レベルの話じゃなくなってきてないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「実に素早いやつらでな。襲われたやつらを助けにいく頃にはもうトンズラし\nちまってまったく捕まらない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000007" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「懸賞金もかけちゃいるんだが……その額よりも、毎日積み重なる被害総額の\n方がデカすぎて……まいってるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000008" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこまで被害が大きくなると、黙って見過ごすのもなんだよな。わかった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちにできる範囲なら、手伝おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「フフッ、そう言ってくれると思ってたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000009" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「よし、話が決まればすぐ動こう。……いざ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024000010" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「待ってください！　その決め台詞は、私から言わせていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090024000010" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もしや久々の登場で張り切っておられるご様子ですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010024000006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディホープ" ]},
		{"command":[ "SETTEXT", "「そ、そんなことは……。と、余計なことを言わなくてよろしい。いいですね\n？」", "NORMAL" ]},
