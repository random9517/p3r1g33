{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ハーイ、隊長さん！　僕にお願いしたいことがあるって言ってたけど、一体\nなにかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふむふむ。日焼け止めを塗って欲しいんだね！　オーケー！　お安いゴヨー\nだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それで、何処に塗れば……って、た、隊長さん！？　どうして裸になってる\nの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えっ……勃起したコレに、僕のおっぱいを使いながら日焼け止めを塗って欲\nしい……？　別に手で塗ればいいんじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　隊長さんがそこまで言うなら……恥ずかしいけど、僕やって\nみるよ……ニンジャはドキョー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「こうして胸で挟みながら、日焼け止めをたくさん垂らして……んっ、しょ。\nこんな感じかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それにしても、隊長さんのコレ……すごく硬いし、変なニオイがするね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「別に不快なワケじゃないよ！　ただ、その……触れたり、嗅いだりしてるだ\nけで……とっても興奮するっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「なっ、なんでもない！　は、はじめるから、痛かったりしたら言ってね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「まずはおっぱいを強く押して、隊長さんのを圧迫して……んんっ、密着させ\nると、すごく熱が伝わってくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それから、上下に擦って……日焼け止めをたっぷりと隊長さんのに塗りたく\nれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふああぁ……おっぱいを動かすたびに、ちゅぷちゅぷってヒワイなミュージ\nックが流れてくるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「おっぱいで日焼け止めを塗ってるだけでも、イケナイことをしてる感じがす\nるのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「やっ、んんっ……！　隊長さんのを感じすぎて、頭がクラクラしちゃう……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それに、擦れば擦るほど谷間に熱がこもって、汗がどんどん浮かんできちゃ\nうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ダメだよ、これぇ……感じすぎて、ハツジョーしちゃいそう\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　隊長さんのがビクンってして、僕の胸で暴れてる……！　\nど、どうしちゃったの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕がハツジョーするなんて言ったから、つい興奮したの……？　そんな……\n僕のせいだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「不義理を働いたニンジャは、シュクセーされちゃうんだよね！？　うぅ、そ\nれだけは許して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕のおっぱいをたくさん動かして、根本までしっかり日焼け止め塗ってあげ\nるから……！　んっ、んんっ、あっ、はあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くっ、んんっ、ああぁん……！　根本の方はもっと熱いね……でも、シュク\nセー回避のために頑張らないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はあ、あっ、はあぁん……！　なんだか、さっきよりもヌルヌルの量が増え\nた気がする……どうなってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ワァオ！？　隊長さんの先端から、透明なエキスが出てるよ！？　大丈夫！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「なるほど……このエキスは、隊長さんのをおっぱいでシコシコしたりしてる\nと出てきて、体内の悪いモノを外に出してるんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それなら日焼け止めを塗るついでに、もっと出させてあげるよ！　不義理も\nカイショーできるし、健康にもなれる。まさにイッセキサンチョー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「この傘みたいなところから根本まで、一気におっぱいで擦れば……んんっ！\n　日焼け止めのおかげで、よく滑るね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふくっ、んぁ、あっ、ふああぁ……どうかな？　透明なエキス、たくさん出\nてる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「もっと激しく胸を擦れば、さらにエキスが飛び出るんだね……オーケー、や\nってみるよ！　僕のラビットパワーに任せて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……えいっ、んっ、うむぅ……！　本当に激しくするだけで、噴\n水みたいにエキスが出てくるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕はドクターじゃなくてニンジャだから、医学の知識はないけど……相当悪\nいモノが溜まってるのは理解できるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんにはずっと元気で側に居て欲しいから……僕、頑張っておっぱいを\n動かすね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くああぁ……あっ、はぁ、んんっ……！　オゥ！？　急に隊長さんのがビク\nビクしはじめたよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「これはシャセーの合図……？　どうしておっぱいでシコシコしてるのに、ス\nケッチの話になるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「シャセーの意味が違う……？　な、なるほど。よくわからないけど、とりあ\nえずこうして擦り続ければいいんだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ぐうぅ……どんどんビクビクが強くなってる……！　あっ、ああぁ……何か\nが、隊長さんの根本からこみ上げてきて……んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「きゃああぁ！？　あ、熱っ！？　なにこのエキス！？　さっきの透明なエキ\nスとは違うの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「このびゅるびゅる出るのがシャセーなの！？　ううっ、熱くてベトベトして\nる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それにとってもクサイのに、妙にクセになる……んっ！　これ、嗅いでると\n変になる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「透明なエキスよりも凶悪なエキス……つまりこれは、悪いモノの親玉……悪\n玉エキスってことだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それなら、こうしておっぱいでシコシコして、一滴残らず捻りだしてあげる\nよ！　んっ、んんっ、くううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はああぁ……悪玉エキス、ちゃんと搾り取れたみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えへへ。日焼け止めも塗れて、悪いモノも出せて、悪玉も倒して……さらに\n僕はシュクセーされない。イッセキヨンチョーになったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、これで終わりだね。僕はあっちで修行してくるから、隊長さん\nも気が向いたら来て……って、どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えっ……日焼け止めは塗れたけど、まだ悪玉エキスが残ってるの……！？　\nもっとおっぱいでシコシコしないと、酷いことになるかもって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫！　僕のラビットパワーでなんとかしてあげる！　おっぱいを使\nうのは恥ずかしいけど、背に腹は代えられないからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くううぅ……さっきよりも硬くて熱い気がする……！　これも全て悪玉エキ\nスが原因なんだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、退治していくね……んくっ、あっ、ふっ、ああぁ……はぁ、あ\nあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんのが、僕の胸の中でビクンビクンって跳ねまわってる……！　うう\nぅ、とってもつらそうだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「逃がさないように、もっと圧迫するね……んっ、ぐううぅ……おっぱいがひ\nしゃげて、隊長さんの形になっていくよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「こうして強く挟み込んだ状態で、何度もおっぱいを上下に往復させれば……\nああぁん！　透明エキスまで飛び出てくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ、んぐっ……ずり、ずりっ……はぁ、はぁ……これは中々のツ\nワモノだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「本当ならゲンにウタ、シャラや先生の力も借りた方がいいんだろうけど……\n今ここには、僕しかいないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「こんなこと頼めるのは僕だけなの……？　えへへ。そう言われると、すごく\n嬉しいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕、一生懸命頑張るからね……！　んっ、はぁっ、あっ、んんっ……むにゅ\nっ、ううぅん……」！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「傘の部分をクリクリされると、ビクビクが強くなるね……ここを重点的に刺\n激すると、エキスが出やすいみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それなら……こうして谷間を傘に押し付けて、グリグリってすれば……あぁ\nんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕の谷間にあるいろんなエキスが混ざって、ぐちゃどろになってるよ……い\nやらしい音がずっと聞こえてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うぐっ、くっ、ふあああっ……隊長さんのもビクビクって、ウサギみたいに\n飛び跳ねてる……！　悪玉エキスが出そうなんだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「全部受け止めるから……！　いっぱいエキスを出して……僕にシャセーして\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああっ、来るっ！　根本からすごい勢いで、悪玉エキスがこみ上げてきてる\n……あああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、あああぁ！　また谷間の中に、ドロドロで濃厚な香りのするエキスが\n出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「たくさんシャセーされてるっ！　僕のおっぱい、たくさん汚されて……んく\nううぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「もっと出してっ！　隊長さんの悪玉エキス、一滴残らずぶちまけてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ！　だ、ダメっ……僕もなんだか、キちゃう……！　おヘソ\nの下あたりが、きゅんきゅんって疼いてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あああっ、んぐっ、ぐううぅ……！　んんんんっ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……隊長さんのシャセー、とっても凄かったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「悪玉エキスもたくさん出たみたいだし、もう大丈夫そうだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でも、たくさんおっぱいでシコシコしたから、日焼け止めが落ちちゃったか\nも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「今度はおっぱいじゃなくて、手で日焼け止めを塗って欲しいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「別にいいけど……まあ、僕としてもおっぱいを見せるわけじゃないから、そ\nっちの方が嬉しいかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「きゃあああっ！？　悪玉エキスが胸から飛び出て、僕の顔に……ひうんんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あわわわわっ！　この白いのすっごく熱くて、ベトベトするっ！　た、隊長\nさん、これ取って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オォーウ！？　まだ出てくる！？　どれだけ悪玉エキスが溜まってるの！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「どぴゅどぴゅって、変な音させてるし……！　早く止まって！　ストップ・\nシャセー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はあぁ……なんとか治まったみたい……それにしても、すごい量の悪玉エキ\nスだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でも、無事に悪の親玉をセイバイ出来たみたいだし、イッケンラクチャクっ\nてとこかな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えへへ。僕の力だけで悪玉をセイバイしたって、妹や先生に教えてあげな\nいと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00009602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「このことは言いふらさない方がいいの？　なるほど……ニンジャは武勲や武\n功を言いふらさないんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「なら、これは僕と隊長さんだけの秘密……トップシークレットだね。こうい\nうの、ヒメゴトって言うんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　ヒメゴトには別の意味もあるの？　シャセーもそうだけど、言葉って\nムズカシイね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}