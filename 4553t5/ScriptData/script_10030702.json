{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "戦艦に乗って数時間。俺たちは秘境の惑星、ヒ＝ホーカンへと降り立った！", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こちらアナザー・ルナテミス。ヒ＝ホーカンの地表に到達した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「りょうか～い。んじゃぁ、頑張ってきてね。私たちは軌道上で待機している\nから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010115500001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いよいよ宝探しの始まりだが、目的地については赤道付近の空洞にある地下空\n洞ってことしか情報がない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして地下空洞ってことは、地上からではその入り口がわからないわけで……\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて、どうしたものか……ん？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふとアナザー・ルナテミスの方に目をやると、きょろきょろと辺りを伺ってい\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、この星に見覚えがあるような、ないような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、地下の空洞へ続く入り口がどこかにあるはずだろう、それを探せ\nばいいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうはいっても姫様、そんなに都合よく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、みんなあれを見て！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "つきみが指さした方向に倒壊した建造物があった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もしかして、あの建物がこの星の古代文明の名残？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほんとうにあったなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「近くに看板があるな。……内容は読めないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうやら古代文字で書かれているな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザー、読めるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……えっと……『お宝発見ドキドキムラムラダンジョン』……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだそりゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……胡散臭いな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115500003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「近くに階段があるぞ。入り口か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん、手掛かりはこれしかないし、入ってみるか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ここから地下に入り、目的の巨大空洞にたどり着ければラッキーだろう。なん\nにせよ、この星の地下に行く通路を見つけないといけない訳だし。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "俺たちはさっそく階段を下りて、地下に入っていった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うお～、意外と広いな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだね。しかも壁とか床とかしっかりしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115500002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "地下は壁や床が石で整備されている。灯りも等間隔に配置されていて、人工的\nに造られたものであることがわかる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「暗いし狭いしジメジメしているし、ダイヤナちゃん、もう帰りたいんだけど\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「でも、この奥にお宝があるんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「秘宝ってどんなのだろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115500003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「金塊かな？　肉まんを一生食べられるくらいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115500003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「秘宝っていうと……宝石かもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115500004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「宝石っ！？　宝石だったら、ダイヤナちゃんもちょっとやる気出るかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっとあんたたち、先行しすぎだよ。もうちょっと慎重に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。ここが遺跡なら、なんだかの罠が仕掛けられていてもおかしくない…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……何の音？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私はしらんぞ！　ただ、ちょっとでっぱってる石があったから押してみ\nただけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115500004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それって罠じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115500002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ぎゃあああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115500004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わあああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115500005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやぁあああぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115500003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115500007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "先行していた三人が、急いでこちらに向かってくる。その後ろからは、巨大な\n岩が転がってきていた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱり罠じゃないっすか姫様！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私のせいか！？　私のせいなのかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115500005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「とにかく逃げないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115500003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "俺たちは来た道を急いで引き返した。入り口まで戻り、降りてきた階段を駆け\n上って地上に戻った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぅ～……みんな無事か？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、大丈夫」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115500004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115500005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぶなかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115500006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あー、あー、隊長？　聞こえるー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010115500002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "急に通信が入ったと思ったら、軌道上で待機しているダイアンサスからだった\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ、セリカか。どうしたんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「いやー、ちょっと厄介なのがそっちに向かっちゃったから、その連絡よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010115500003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「厄介なの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なんだ先客か？　お宝は渡さねぇぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115500001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その声が聞こえて、誰かが俺たちに襲い掛かってきた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}