		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロボットどもめ。硬いわ数が多いわで、らちがあかねぇな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし、今のところ防衛線は抜かれておりません。避難の準備は着々と進ん\nでいるようですぞ。ご主人もやるときはやるのですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010111070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やめろ！　おまえにほめられると、なんだか気持ちわりぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……まったく、珍しくほめて差し上げたのにこれですか。おだてがいのない\nご主人ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010111070002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん！　ジュンジローちゃん！　漫才でなごませようとかしなくて\nいいから！　働いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010111070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「別にそんなつもりはねえよ！　それよりアナザー！　そろそろいけるか！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「待たせた！　今召喚する！　メカ・ジュンジロー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090111070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ジュンジロー" ]},
		{"command":[ "SETTEXT", "「了解（ラジャー）……！」", "NORMAL" ]},
