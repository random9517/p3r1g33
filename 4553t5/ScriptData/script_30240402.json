		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁっ！　あっ、お尻っ、ドロッとしてるのっ……掛かってるぅぅ\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁぁぁんっ！　私もイクっ、お尻……イクのっ……ははぁぁぁぁっ、気持\nちいいっ……お尻っ……いぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……ご主人さまのビュクビュク出て……はぁぁ……お尻も……太も\nもにも……精液……垂れて来てる……ドレス……汚れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404403" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、オチンポ塗り塗りされてぇ……あぁ、このヌルってするの……ゾクゾ\nクするぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ……射精……終わった？　今度は本当に……？　ちゃんと…\n…全部出したの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁぁ……お尻にまだオチンポが入ってる感じがする……ジンジン、ふわふ\nわして……落ち着かない……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……それで、ご主人さまー？　ずいぶん好きにしてくれたじゃない？\n　キツいって言ったのに、結局、ゴーインにしちゃうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「もうちょっとメイドさんらしくご奉仕したかったのに。まぁ……一応気持ち\nよかったから……そこは、いいけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、バレンタインだからって、いくらなんでもサービスし過ぎだったわよ\nね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ってことで、当然ホワイトデーのお返しは、期待してるわ！　ご主人さまっ\n♪」", "NORMAL" ]},
