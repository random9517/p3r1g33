	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁーい、ご主人さまっ。ちゃんと来てくれたわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「私が呼び出した理由……まぁ、何となくだろうけど、分かってるんじゃない\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふふっ、そうね。なんとなーく、ムラムラっとした気分になっちゃったし\n……私といいことしちゃわないかなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら、大好きでしょ？　このメイドさんのカッコ。この服着てると、ご主人\nさまってめちゃくちゃ張り切っちゃうの分かってるしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほらほらあ、どうするの？　甲斐性見せられるの～？　せっかくのメイドさ\nん……たっぷり楽しんでみない……ひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404105" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ……その気になって来たみたいじゃない。ほら……もう私もちゃーん\nと準備できてるの分かるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あふっ……んんっ、あんっ……お尻……そんなにオチンポでスリスリしてぇ\n……ご主人さまは、イタズラ好きなんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そのまま下の方……私のオマンコ……じゅんって濡れてるの……分かるでし\nょ……？　早くいれちゃお……ご主人さまぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えっ……？　あっ……ちょ、ちょっと待ちなさい。どこに……オチンポ当て\nてるのっ、そ、そこじゃないでしょっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「合ってるって……でも、そこはお尻の……ま、まさか本気でっ、あっ、ひっ\n、あっ、んぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あくぅっ……あっ、やだ……入って来る……そこ、違うの……あっ、お、お\n尻の穴ぁっ……んっくぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ……やだ……広がる……お尻の穴が……オチンポでぐぐって……\n広げられちゃうのっ、あ、ひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぁっ……くぅぅっ……あっ、あぁぁっ……通り抜けて、くっ……んんっ…\n…！　んくぁ……い、一番奥までぇ……あ、ひっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んくぅ……ちゃんと入ったって……そ、そういうことじゃないでしょっ……\nどういうつもりで……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぁ……やだ……お尻、熱い……んんっ……オチンポがめり込んで……んく\nぅ……はぁぁ……んくっ、ムズムズ、するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「え……う、動かすの……？　あっ、で、でも……今、そんなことされたら…\n…あっ、あひっ、はっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、はっ、あぁっ！　そんなっ、あっ……お尻っ……あひっ、か\n、かき回されるのっ……こ、これっ、あっ、ダメっ、ダメェっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だ、だってっ……あっ、こんな太いのっ、行ったり来たりしてたらっ、あく\nぅっ、戻らなくなっちゃうっ、お尻っ……広がったままっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　あぉっ……あぁっ、ダメだってっ……あっ、言ってるのにっ、\nひっ、あぁっ、オチンポっ、そんなにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「お願いっ……分かったからっ、まだいきなり強すぎないでっ、ゆっくりっ、\nあっ……ゆっくりしてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……はっ、あふっ……あぁ……やっぱり大きい……んっ、ご主人さま\nのオチンポ……ゴリゴリに感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぅっ……はぁっ、あっ、でも……んっ、ちょっとだけ……慣れて……あっ\n、来た……かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だって……んっ、いきなり何も言わないでお尻からするんだもん……オマン\nコの方だと思ってたし……んくぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……けど……あっ……慣れて、来たら……はぁっ、これ……悪く\n……んっ、ない、かもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ずりゅずりゅって……気持ちいいの……通り抜けて……あっ、オチンポが出\nていく時に……ゾクゾクってなるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁぁ……また入って来るぅ……くぅぅ……はぁ、はぁ……んっ\n……やだ、これ……気持ち、いいかもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ！　ま、まだだからっ……ゆっくりにしてぇ……ご主人さま\nぁ……あっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「うんっ……そう、あっ、今ぐらいのがいい、感じぃ……お尻の中で……オチ\nンポの先が……ぐりってされるのが、分かる感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あっ、んんっ、あぁ……ぐちゅって……音……し始めちゃった…\n…んんっ……お尻の穴……どんどん馴染んできてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んくっ……あぅっ、んんっ……あ、あぁっ……変な感じっ……\nこれっ、あっ、ダメかも……あっ、あぁっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だってっ……あっ、お尻のシワが広がってっ、ぐりってめくれてっ……熱い\nのっ、燃えちゃうみたいなのにっ……はひっ、ジンジンしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、気持ちいいっ……！　ご主人さまのオチンポっ……あっ\n、あぁっ、気持ちよくなってるっ、そこっ、もっとぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「うんっ、入り口のところっ……こすこすされるとっ……からだの力が抜けて\nっ、ふにゃってなってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あふっ、何度もっ……して欲しくなっちゃってるっ！　オチンポっ、お尻に\nめり込むのっ、もっとしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁっ……そこっ、あぁっ、ご主人さまもっ……あっ、いいのっ？　出した\nくなってるっ、射精するのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぁっ、何でもいいっ、いいからっ、してっ、出してっ……オチンポミルク\nっ、ザーメンっ、いっぱい出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁぁっ！　あちゅいのっ……出てるっ！　んんぅぅぅんっ、お\n尻っ……あひぃっ、お尻イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……入ってるぅ……びゅくってぇ……しゅごいの……あぁぁ\n……こんなにぃ……は……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「お尻……変になっちゃった……あっ……まだイッてる感じ残ってるぅ……あ\n、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ご主人さまのオチンポ……すごすぎたの……はぁ……んんっ、頭おかひくな\nりそぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……んっ、お尻が……あっ……まだ熱い……んっ、ム\nズムズしてる……中でオチンポ、硬いまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ、ねぇ……ご主人さまぁ……まだ続き……出来るでしょ？　このまま\n……オチンポ……続けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ウズウズしてるお尻……もっと欲しいの……ご主人さまのオチンポで、いっ\nぱいぐちゅぐちゅっ……してぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁんっ！　そうっ、あぁっ、出された精液っ……お腹の中でっ\n……かき混ぜられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、ぶぽっ、ぶぽってっ！　は、恥ずかしい音してるっ、お尻っ…\n…ケ、ケツ穴っ……燃えてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んくぁぁっ……オチンポっ……スムーズに動いちゃうっ、はんっ、んくっ、\nずぶずぶっ、出し入れっ……たまんないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁんっ、後ろからっ……ワンちゃんみたいにされてっ……お尻っ……され\nてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「苦しかったのにっ……どんどん気持ちよくなっちゃうのっ……私っ……変な\nのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　今のっ！　はぁぁぁっ、オチンポが引っかかってっ……中の壁\nっ……あぁっ、ぐりぐりっ……あっ、またぐりぐりってぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「中でっ……溶けちゃうっ……はぁぁっ、んうぅっ……せいえきっ……ぐちゅ\nって……分かんなくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ……あぁぁぁぁ……オチンポ抜けてくぅ……ひぁぁっ、ダメ……も、漏\nれちゃう……あっ、んぁぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ひっ、あぁぁ……またずぶって埋まるぅっ！　こんなの繰り返してたらっ…\n…お尻っ……ダメになるからっ、あっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はいっ、そうですぅっ……私っ、マーガレットはぁっ……ご主人さまを誘惑\nしてっ……お尻を躾けられているっ、いやらしいメイドですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ご主人さまのっ、太いオチンポに満足してもらうためにっ……四つん這いに\nなってっ、お尻の穴を開いてっ……アナルマンコっ……してもらいますぅっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいっ、いいのぉっ、もっとしてっ、してくださいっ！　オマンコ\nより気持ちいい、お尻っ……もっと、あぁぅっ、もっとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、オチンポが深いっ！　はぁっ、一番奥に届くのっ……くぅぅぅっ\n、いいのぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あくぅっ、あぁっ、私っ、これっ、またっ……あっ、イキそうっ、お尻っ…\n…ズボズボされてっ、イクのっ、あっ、あぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ご主人さまもっ……あっ、出したくなってるっ？　アナルセックスでっ……\n射精っ……またするのっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、もう何でもいいのっ、お尻気持ちいいからっ、一緒にっ\n……イクのっ、あぁっ、一緒にぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「中でもっ……お尻に掛けるのでもっ、どっちでもいいからぁっ……また来て\nっ、いっぱいミルク出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぁひぃぃぃっ！　またっ……中っ……お尻っ、あちゅいのっ……いっぱい\n出されてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁ……イクっ……お尻イクぅっ、気持ちいいのっ、続けてイッて\nるぅぅっ、んぁっ、あぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁぁ……ご主人さまの精液ぃ……いっぱいにされてる……あふぁ……入り\nきれない分……隙間から漏れちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どぷどぷって……まだ出てるの……んんっ、お尻の中……ヌルヌルして、お\nかしくなりそ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ……オチンポ……やっと止まった……はぁぁ……お尻……まだ感覚がお\nかしくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「もう……ご主人さまぁ……？　確かに誘惑したのは私だけど、ちょーっとは\nりきり過ぎじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ま、それだけマーガレットちゃんのお尻が魅力的過ぎたってことかも知れな\nいけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「も、もーっ、そんなにコクコクうなずいちゃってぇ……しょうがないんだか\nらぁ、もぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも……確かに気持ちよくて……ハマっちゃいそうだった。っと、メイドさ\nんみたいにしておかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ご利用、ありがとうございました……次は……今度こそ前？　それとも……\nまたお尻……？」", "NORMAL" ]},
