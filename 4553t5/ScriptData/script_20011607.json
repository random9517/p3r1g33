{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0084" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「よし。これで応急処置も終わったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530045" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「だいぶ楽になったよ……ありがとう、ホクサイ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530037" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うっ、ううぅ……先生……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530032" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「シャラク……いい加減泣き止んだらどうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530038" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「で、でも……この怪我は、あーしのせいだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530033" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「応急処置もしたし、もう大丈夫だ。安心しろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530039" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「それにしても、随分と手ごわい相手だったな。ホクサイの指示がなければ、\n全滅していたかもしれん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530040" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あれはちょっと調子に乗って油断しただけだ……！　次は絶対に勝つぜ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530037" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「次って……その調子と油断のせいで、先生が怪我をしたんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530046" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それに敵の基地を見つけたとき、一旦戻ろうって言ったよね！？　どうして\n、リーダーである僕の指示に従わなかったの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530047" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だって……行けると思ったんだもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530032" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それにあんなに手強いヤツが出て来るなんて、予想出来るワケないだろう！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530038" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そういった事態を想定するために、戻って準備をしようって話だったじゃな\nい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530048" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「おい、お前たち……それぐらいにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530041" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「みんな、喧嘩しないでよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530034" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしのせいで先生に怪我させちゃったのは悪いと思ってるし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530035" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こんなことになったのも、全部あーしのせいだから……言いたいことがある\nなら、全部あーしに言ってよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530036" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「シャラ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530049" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「シャラク、そう自分を責めるな。お前たちも、喧嘩をするんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530042" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「で、でも……あーしが油断したから、先生が……！　うっ、ううぅ……うわ\nあああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530037" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530050" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530039" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530033" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「師匠とは弟子を守るものだ。私はお前を守れたことを、誇らしく思っている\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530043" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ううぅ……先生～～～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530038" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「だから泣くなと言っただろう。これでは、せっかくの可愛い顔が台無しだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530044" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふむ……だがいい機会だ。お前たちに、一つ教えを説いてやるとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530045" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}