		{"command":[ "SETIMAGE", "0", "still_00011501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「先走り汁……。ぁっ……精液の前触れ？あ、ぁ、お、オトコも……女のよう\nに愛液のようなものが出るということ、ですか……不勉強でした」", "NORMAL" ]},
