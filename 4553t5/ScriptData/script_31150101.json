		{"command":[ "SETIMAGE", "0", "still_00011501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「んふぅっ！？反抗的ですわよ！？それに……わ、わたくしの綺麗な胸に透明\nな汁をなすりつけてくる……！これは？カウパー？カウパーとはなんです」", "NORMAL" ]},
