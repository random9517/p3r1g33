		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「少し、時間が早かったでしょうか？隊長さま。轟琴葉金、推参いたしました\n……。と、なんなのです？この無骨な部屋は……それに妙な臭いがします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
