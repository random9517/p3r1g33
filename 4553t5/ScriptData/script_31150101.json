		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「男と女のすえた臭い……。まさか、隊長さま。わたくしにもおかしなことを\n要求するつもりではありませんよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「パイズリ……？わたくしにパイズリをしてほしい、と？下手な小細工をすれ\nば見破られると思って、そうそうに本心を自白したわけですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「パイズリ……。いえ。当然処女を要求されるものと思っておりましたので、\n逆に戸惑ったまでです。パイズリ……語感からするとこうですわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「婦女子の乳房を使って、男性器を射精に導く性行為のこと……。正しいでし\nょう？初めて聞いた単語ですが、私の推理は完全なはず。それで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「隊長さまにパイズリすることで、わたくしに何のメリットがあるのですか？\nパワーアップ？……わたくし、既に強いので。……え？鈴？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「鈴を強化することで、わたくしの向上心を刺激したい？……なるほど……。\nそうですわね、鈴が強くなれば、わたくしは幸せです。……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「既に鈴は隊長さまとこういった行為をしている？……。つまり、ここで退け\nば……わたくしが、女として一歩鈴に遅れを取ると言いたいのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……ふぅ……。大層なことをおっしゃっていますけれど、結局は、肉欲によ\nってわたくしにパイズリとやらを所望している。そうですわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「策をろうせずとも、それくらいはかまいませんよ。……意外ですか？わたく\nし、隊長さまのこと、まったく嫌っていませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「鈴の件がなくとも、パイズリくらいはしてさしあげます。フフ、わたくしの\n好意はどうにも、伝わりづらいようですわね。さ、では性器をお出しなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……ぅ……。これが、男性器……。いえ、嫌悪ではなく驚愕しただけです。\nその、保健体育の授業で習ったものより大きいので。……ん……」", "NORMAL" ]},
