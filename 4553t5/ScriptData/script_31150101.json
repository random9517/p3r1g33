		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「であれば躊躇なく、お好きなタイミングでお出しくださいな……！ええ、こ\nこから、先端より精液が出ることは……知っています。どうぞ……！」", "NORMAL" ]},
