		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「っ……あぁ……！はぁっ、はぁ、はぁ、あぁ……むずか、しい……！でも、\nすぐにマスターしてみせますわ……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしに、出来ないことなどありえ、ませんから……。っ……ぁっ……ン\n……、あぁ、もう、感覚がつかめてきましてよ。フフ、天才ですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「んんっ……ん、ん、ん……気持ち良いですか？手や口でするより、は……ど\nうしてもかかる力が低くなってしまうと思います、けれど……んんんっ」", "NORMAL" ]},
