		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「っんん……！大事に育てた娘、が……あっ！婚約前の、っふぅっ……！男、\nの性器に仕えて快感のために媚びている、この姿……はぁっ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「こんな姿を見せたら卒倒するでしょうね……。っんっ……ん、ん……！隊長\nさま、よーく想像してくださいませ……財閥令嬢の、罪なき白い乳房」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「まだ誰も触れたことのない清らかな雪原、を……今。隊長さまのペニスとカ\nウパーがよごしているのです、くっきり痕をつけて、いるので……すぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「あたたかく、菫の匂いのするわたくしの乳房……。あっあっ、学園の、いい\nえ、世界中の男が憧れるこのわたくしの胸、にパイズリされて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ビクビクとペニスを痙攣させて……気持ちいいのですわよね？ふ、ぁ……あ\nっ、ええ、わたくしも……いいですよ、フフ、不良になったみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「大切な両親の愛情を裏切って♪箱入り娘が、こんなことをしているなんて…\n…あっ♪申し訳ないと思うと……感じますっ、ぁっ、いや、いやぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしたち……良き共犯者になれそうですわ、ね♪ゆっくりと……ゆっく\nりとぉ、ご賞味くださいま、せ……はぁっ、はぁ、はぁ、はぁ……♪」", "NORMAL" ]},
