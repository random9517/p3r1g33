		{"command":[ "SETIMAGE", "0", "still_00011501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「母性の象徴たる乳房であるからこそ良いので、しょうね……。えぇ、パイズ\nリ……理解はできます。技術の習得もすぐ……。で、ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「少し……だけっ、はぁっ、少しだけ……両親に申し訳ないと、感じます……\n。ぁっ……あっ、んっ、んん……お父様、お母様……あぁっ」", "NORMAL" ]},
