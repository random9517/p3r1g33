		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「バテたとか……疲れたとか……そ、そういうことではなくっ、意地悪だぞっ\n……全部分かっているくせに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ほら、あそこだっ……あの小屋の中でいいっ……あそこなら、誰にも見つか\nらないから、早くぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あぁ……分かってる……脱ぐ……んんっ、もどかしい……ほ\n、ほらっ……これで全部……脱いだぞっ？」", "NORMAL" ]},
