		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁ……まず、これを……抜いてくれ……んんっ、バイブ……オマンコのバ\nイブ……ずっと切なくてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ……あぁっ、ムズムズするっ……ずっと股間が疼いて……オマ\nンコが切ないの……は、早くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「お、お願いっ……お願いしますぅっ！　あたしのオマンコからっ、バイブ…\n…抜いてっ……じゃないとっ、あひっ、も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁっ……ダメっ……んぁぁぁっ、ダメぇぇぇっ……出る出る出\nるっ……出るぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んんっ、あぁぁ……も、漏れちゃった……あぁ……おしっこ……\nんっ、我慢出来なかった……あぁ……止まらないの……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うぅ……恥ずかしい……あなたの前だと、全部さらけ出してしまう……情け\nない姿も、乱れてる姿も……何もかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「でも、それに……身を委ねたい……お願い……あたしの欲しがってるオマン\nコ……バイブなんかじゃなくて……本物で埋めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あなたの……太くて硬い……逞しいオチンチンでっ……ぶすって挿し込んで\nっ……いっぱい、いっぱいかき回してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁんっ！　あっ、はぁぁぁんっ、オチンチンっ……入って来たぁっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……そう……このオチンチンっ……オチンポっ……これが欲しかった\nのっ、あぁっ、それぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「農作業をしている間……ずっと、オマンコのバイブが震えてて……んんっ、\n変な声が出そうで……気が気じゃなかった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「二人きりならともかく……他の仲間も一緒にいたのにっ……自分一人だけ、\nオマンコにこんないやらしいモノを入れてるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁ……そんなことを思うだけで、ゾクゾクしてっ……けど、本物のオチン\nポと違うからっ……待ち遠しくてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、あぁっ……こうしてっ……奥にっ……突きこまれてるのっ\n……嬉しいっ、あぁんっ、オチンポすごく気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「この生身の感じ……全然違う……あぁっ……熱くなって、硬いけど痛くなく\nてっ……ヒダの擦れる感じが……はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ、もっと……大きく……んっ、動いてっ……あんっ、はんっ、あはん\nっ、はひぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……あぁっ、うんっ……おっぱいも……してっ、あぅんっ！　あぁ\nっ……身体の隅々まで……敏感になってるのっ、んぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……そうっ、押しつぶしてぇ……んんっ、むぎゅって……されると…\n…オマンコもジンジンするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ！　そうっ……乳首……んんっ、くりくりってされるの……好きぃっ\n……♪　こっちは、刺激がなくて……切なかったからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やっと……指でしてくれてぇ……あっ、ふにゃって……力が抜けてく……あ\nっ、あんっ、あぁっ、あんっ、声っ……出ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁっ……みんなっ、こんなに気持ちいいことしてたなんて……\n知らなかったのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁっ、もう、これなしじゃっ……オチンポなしじゃっ、あたしっ……無理\nっ……欲しいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ、でも……仕方ないんだからっ……あなたがっ……あたしの仮面……\n取り払ってっ……どんどんエッチなこと……仕込んだんだからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うちの組織のメンバーに知られたらっ……顔向け出来ない位っ……いやらし\nい子になっちゃってるのっ……んぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁっ……責任取ってなんて言わないっ……言わないから、二人の時はっ…\n…思いっきり責めてっ……オチンポしてっ、あひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あたしもっ……んんっ、頑張って締めるからっ、オマンコ……喜んで貰える\nようにするからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁんっ！　あぁっ、激しくなってるっ！　んぅんっ、弱いとこっ\n……ズボズボされてるっ、んぁぉっ、そこっ、そこぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、んぁっ、オチンポっ……出そうっ？　あぁっ……あたしのオマ\nンコでっ……イキたくなってるのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んっ、もちろんっ……このままっ、中がいいわっ……元気な赤ちゃんの素っ\n……中に欲しいっ！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、出してっ……！　精液っ……オマンコの中にっ、いっぱい\nっ、出してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁぁぁーーーーっ！　来たっ……精液っ……あっ、中にっ\n……ビュクビュクっ……してるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……びゅくって……あふっ……出てるっ……んんぅ……すごい……\n気持ちいい……あぁ……オマンコビクビクするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、あぁ……溢れてきた……お汁……漏れちゃう……オマンコ\n……閉じきらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ダメ……ちゃんとしっかり締め付けてあげないと……あぁ……ト\nロトロになっちゃうの……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……やっぱりバイブじゃ全然味わえない感じ……気持ち\nよすぎ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あたし……完全に……このオチンポの虜になっちゃった……もう、戻れない\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んんっ……えと、うん……少しだけ、気持ち……落ち着いた。あ、で、でも\n……そのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「オマンコの方は……まだ、落ち着いてないって言うか……その、もっと……\nして欲しいなって……思ってたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「だから、もうちょっと……オチンポ……頑張ってくれる……？　あっ、ひぁ\nっ、あっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、嬉しいっ……また、オチンポが……オマンコの中で膨らんで\n来てるっ……あっ、あぁっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やっ、あぁっ、中に出されたのが……あふっ、ぐちゅぐちゅ言ってるっ……\nんぅっ、あぁっ、オチンポで精液……かき混ぜられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はふっ、そうっ、なのっ……この、いやらしい音ぉっ……聞かされてるとぉ\nっ、身体の発情が……深まってっ……また、オマンコ濡れてくのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ここぉっ、じゅくってオチンポの先で押し込んでっ……奥のザラザラしたと\nこぉっ……擦りつけてぇっ……は、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふっ、待ってて……あたしもっ……もっと締め付けるからぁっ……ちゃん\nとオマンコ喜んで貰うためにっ、お腹に力入れるからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……ど、どうっ？　んんっ、キュンって締める感じ……わ、分かる\nぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「んふふっ、よかった……ずっと、やられっ放しじゃ悔しいし……あたしだっ\nて、あなたのオチンポにちゃんと尽くしたいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、でも……これ、さっきより膨らんでる気がするっ……んんっ\n、絶対気のせいじゃないっ……オマンコぉ、いっぱいになってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、あぁっ……あっ、声がっ、止まらないっ……オチンポにメ\nロメロにされてっ、はぅんっ、身体っ……もっと熱くなってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっと……おっぱいも触ってっ……ぎゅって握り締めてっ……揉み\nくちゃにしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「それでっ、あぁっ、そうっ！　ぐっと深いところっ、突くのっ！　くひぃん\nっ、それっ……いひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00014502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、んぁっ、ずっと……こんなされたらっ、あっ、あら\nひっ、またイクっ……ひぃんっ、オマンコっ……イッひゃうっ！」", "NORMAL" ]},
