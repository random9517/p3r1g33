		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「な、中っ……子宮に、またドクドク流れ込んできて……！　びゅくっ、びゅ\nくって……チンポが、弾けてぇ！　んっ、あぁあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はあぁっ！　イ、イクっ！　中出しザーメンっ……おぼれ、ちゃうっ……！\n　んっ、んふぅぅっ！　イ、イクぅぅぅぅっ！！」", "NORMAL" ]},
