		{"command":[ "SETIMAGE", "0", "still_00018401_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あ、熱いっ……！　さっき、出したばっかり……なのにっ……んんっ！　ず\nっと溜めてたみたいに、たくさん出てるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
