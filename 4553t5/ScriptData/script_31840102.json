		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はひっ！　ひぃあっ、あひぃぃぃっ！　く、くるっ……またきちゃうっ！　\nアクメ、きちゃうっ……はっ、はあっ！　んっんぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
