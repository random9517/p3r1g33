		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あぁ、絶対にこの匂い、取れなくなっちゃう……はぁ、ああっ……肌に、染\nみ込んで……いって、ますぅ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
