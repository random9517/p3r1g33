		{"command":[ "SETIMAGE", "0", "still_00018401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「お、夫と……全然、違います……なにって、大きさが全然、違って……んん\nっ……硬さも、太さも……全部、違いますぅ……はぁあんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ、ふうっ……お、奥ぅっ……おっきいので、グリグリされるとっ……！\n　は、はあっ……子宮が、押しつぶされちゃいそう……！」", "NORMAL" ]},
