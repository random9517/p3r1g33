		{"command":[ "SETIMAGE", "0", "still_00018401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁあ、あぁんっ……き、気持ちいい……私、ぶっかけされながら\n、イッてるぅ……んんっ……身体、汚されてるのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「こんな、くさい……ザーメンまみれにされて、身体中を、ベトベトにされて\nるのに……興奮して、るの……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
