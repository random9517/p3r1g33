		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はい……申し訳ありませんでした……反省してます。……もちろん、わかっ\nてます。お仕置き……ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「それは、あの……噂、では……聞いてますから……。えっ……？　そんな…\n…期待だなんて、ち、違います……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私、人妻なんですよ？　夫がいるのに、夫以外の人と……セックス、だなん\nて、期待してるわけないじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あ、ああっ……待って、ください……！　お仕置きは、受けますから……乱\n暴にしないでください……！　うぅ……はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「脱ぎます……自分でやります、から……少し、待ってください。うう……は\n、恥ずかしいので、あまり見ないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……シミ、ですか？　知りません……言われた通り、脱ぎましたから……早\nく始めてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ですから、期待してるわけではなくて……ぬ、濡れてるのは……違います、\n違うんです……いいですから、早く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……おねだり、ですか……これも、お仕置きというなら……う、ううっ……\n人妻なのに、夫以外の、チ、チンポ……あぁ、許してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「わかり、ました……ぬ、濡らした、オマンコ……びしょ濡れの、浮気オマン\nコに……夫よりたくましいチンポ、ください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……あはぁぁぁっ！　は、はいって……くるっ……！　んあっ\n……大き、いっ……はっひっ！　ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
