		{"command":[ "PLAYVOICE", "v2_184_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「いれた、だけで……オマンコ、痺れて……おかしくっちゃうっ……あっ、あ\nっ……あんっ、あぁひぃぃぃっ！　すごいっ！　ああっ！」", "NORMAL" ]},
