		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あぁ、はっ……はふっ……ひっ、んぅっ……はぁぁぁ……さっきより、も…\n…量、多い……んうっ……すごぉい……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んはぁ、はぁあっ……はひ、反省……？　あ、あぁ……お仕置き、ですよね\n……はい、反省しました……んっ、ふうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
