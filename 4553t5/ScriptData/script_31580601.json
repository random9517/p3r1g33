{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「急に呼び出されたと思ったら……なに？　ＹＳＫモードの性能テスト？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603101" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それはいいんだけどさ……ここで？　この部屋で？　ご主人……ＹＳＫモー\nドを使ってえっちな事、したいだけだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603102" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、開き直った。ふふっ、まっ、別に嫌じゃないけどね。……ちなみに、\nどんなこと、したいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603103" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――太ももとふくらはぎで挟んでしごいて欲しい？　うわぁ、ご主人ってば\n、ほんとそーゆーの好きだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603104" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、してあげる。……こっちきて、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603105" ]},
		{"command":[ "SETCHARA", "0", "char_00015806_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のおちんちん、もうカチカチだね。んっ、ちょっと体勢がきついかな\n……もう少し、身体を寄せるね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015806_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、こんなプレイ要求しておいて、身体をぎゅっとしたぐらいで照れな\nいでよご主人。……ずるいなぁ、そーゆーところ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ん、しょ……膝裏と太ももでもっとしっかりおちんちんを挟んでっと……こ\nんな感じ、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「知識としてインプットはしてるけど、慣れてはないから……痛かったりした\nら、言ってね？　んっ……ゆっくり、膝裏で締め付ける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……扱くって言うより、横に揺らすイメージで……んっ……お\nちんちんを締め付けて、離すを繰り返す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「太ももだけじゃちょっと厳しいかな……おちんちんの先っぽの所、軽く撫で\nてあげるね……んっ、もうえっちなお汁でべとべとだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「どうかな？　上手くできてる？　って、その顔見る感じ、聞くまでもないみ\nたいだね、ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――いつもと違う感じの柔らかい肌の質感がいい？　ＹＳＫモード最高？　\nまったく、ご主人はぶれないよねぇ、ほんと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、でも、ＹＳＫモード最高最高ってのは同感かも。なんていうか……\n『肌』を通してさ、ご主人の熱がしっかり伝わってくるんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら……んっ、んぁ……太ももの間でおちんちんがピクピクしてるのも、す\nごくしっかり伝わってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぎゅっぎゅ、ってしてあげたら、嬉しそうにドクンって脈打って、少し強め\nに扱いたら、暴れるような弾力で返してくる……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のおちんちん、かわいい。――照れなくていいのに、私は嬉しいよ、\nご主人が私で身悶えてくれてるの。ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……少し、慣れてきたかも……もっと早く、縦の動きも追加して……ん\nっ、んぁ……おちんちんを太ももに埋めて、しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「挟んで、離す、挟んで、離す……えっちなお汁が膝の裏まで垂れて、ぐちょ\nぐちょ言っちゃってるね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「また先っぽも撫でて上げちゃう。……いや、それよりこんな変態なプレイ求\nめてくるご主人だもの、叩いた方がいいのかな？　ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「軽くぺちぺち、おちんちんの先っぽを指で弾いて、っと……あはっ、ご主人\n、いい顔してるじゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でもこれ……ぁ、んんっ……ＹＳＫモードだと、ちょっと『肌』の感度が高\nすぎるかも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「くすぐったい、っていうのかな……あっ、んふっ……おちんちんシコシコす\nるたび膝裏が擦れて、私も少し変な声出ちゃうかも……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと、あんまり顔覗き込まないでよ！　……そりゃ、顔も赤くな\nるよ、だってそーゆーこと、してるんだもん。むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ご主人、可愛いって言えば何でも許されると思ってない？　……いやま\nぁ、嬉しいから許しちゃう私もいるんだけどさ。ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも、そっか、ＹＳＫモードだと肌の色味の変化で私の照れとかも見抜かれ\nちゃうのか……なんか、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああ！　もういいから！　もっと激しくしていくよ！　ご主人は私に膝コキ\n？　されて気持ちよくなってたらいーの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、ご主人のだーい好きなおちんちんの裏側を擦ってあげるんだから。乱\n暴にずりずり、皮も巻き込んで一気にぎゅー、って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっちなお汁を膝の裏でかき混ぜて……んふっ……ぐちゅぐちゅ、ぐちゅぐ\nちゅ……ふふっ、血管を押さえたら、おちんちんピクピクしてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……シコシコだけじゃなくて、横にも振り回して……強く太も\nもで圧迫して～～～～……離す。はい、もう一回」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぎゅーってして、離す、ぎゅーってして、離す……ふふっ、おちんちん、真\nっ赤に膨れ上がらせちゃって、かわいいんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――わかった、もっと早くだね。締め付けも強く、下半身ごと、大きく足を\n揺らして……んっ……こう、だよね……んあっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、膝と太ももでして、なんて、まーた私のご主人は変態チックな事言\nい出したと思ったけど……これちょっと楽しいかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「力を入れるのが簡単だから、好きなようにおちんちんを圧迫できるし、手が\n空くから、こうやって先っぽを弄るのもやり放題。ぐりぐり、ぐりぐり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、ご主人、たくさん出して。おちんちんこーんなにピクピクしてるん\nだもん。もう我慢、出来ないんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私の柔らかい『肌』に包まれてびゅーびゅーって射精しちゃうの。このまま\nご主人のだい好きな太ももで受け止めてあげるから、たくさん出して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　すごい勢いだね……ふふっ、太ももに挟まれて扱かれただ\nけで、こんなに出しちゃうんだ……んんっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ドクドクってしてるのが、膝の裏を通してダイレクトに伝わってくる……ん\nんっ……！　必死に射精するおちんちん、やっぱりかわいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「射精中も太ももを動かして、っと……んっ、んんっ……根元からぎゅー、い\nっぱい搾り取ってあげるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……これが『肌』に精液を受ける感覚……いつものボディより、少し熱\nく感じるかな？　ふふっ、この身体も、ご主人に汚されちゃったね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そろそろ出し終わったかな。……んっ、分かってたことだけど、一回出した\nぐらいじゃ、ご主人のおちんちんは固いままだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「聞くまでもなさそうだけど……まだ出したりないんじゃないかな？　私の太\nもも、もっと堪能したい、よね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、もちろん、ご主人が望むなら、何度だって付き合ってあげるよ\n。私はご主人だけのモノなんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……やっぱり、一回出したからさっきより滑りがいいや。んふ\nっ……精液をぐちょぐちょにかき混ぜて、っと……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んふっ、あっ……これ、私の膝の裏、凄いことになっちゃっ\nてそうだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「どう、ご主人。私の膝裏おまんこ、気持ちいい？　熱くてドロドロに蕩けて\n、おちんちんを包み込む……ご主人を感じさせる為だけの場所だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、かわいい反応しちゃって。ご主人って、やっぱり弄り甲斐ある\nよね。そーゆー嗜好の人の気持ち、少しわかっちゃうかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、こうやって苦しいぐらいのおちんちんに力籠められるのが好きなんだ\nよね。裏筋を押しつぶす勢いで、ぎゅ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まだ離さない。まだ、まだだよ……少しずつ力を入れて、どんどん圧迫して\nいって……おちんちんが、もう駄目だよーって所まで、ゆっくり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「限界ギリギリまで来たら……離す！　ふふっ、おちんちん、大暴れしちゃっ\nてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「精液まみれの膝裏に挟んで……んふっ……大きくシコシコ、根元から先端ま\nでをずり上げるように、皮を巻き込んでシコシコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、分かってるよ、先っぽもまた乱暴にしてほしいんでしょ♪　括れの\n部分に指を添えて、ぐりぐり、ぐりぐり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人も、自分で腰を動かしていいんだからね。ほーら、私の膝の動きに合\nわせて、いち、に、いち、に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そうそう、かわいく腰をヘコヘコしちゃおうね。太ももが気持ちよくてへこ\nへこ、おちんちん指で弾かれるのが気持ちよくてへこへこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、ぁっ……や、やっぱり『肌』の感度設定ミスってるよねこれ\n……おちんちんが膝裏に擦れてるだけなのにっ、んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、さっきは適当に言ったけど、私の膝裏、本当におまんこみたいな感\n度になっちゃてるのかもね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人から出た体液でぐちゃぐちゃのドロドロ……熱く蕩けて、おちんちん\nを喜ばせるためだけに、締めて緩めてを繰り返して……んあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「シコシコもどんどん早くしていくから、このまま最後まで……！　んんっ…\n…ほら、ご主人も腰振って！　いち、に、いち、に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んくっ、あっ、んふっ……おちんちん、膨らんできたっ……私の膝裏おまん\nこで感じて、びゅーびゅって、射精したいんだ……んあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603219" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「好きなところに出して、ご主人！　私の新しい身体に、ご主人の子種を好き\nなだけぶちまけて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んくぅんんんぅぅぅっ～～～！　ま、また膝の中で出てるっ……！　私の太\nももに、熱いのがいっぱいっ、あっ、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「『肌』の感度がいいから、精液が降りかかったところ、熱くて、痺れて……\nあっ、んふっ……このノイズ、気持ちいい奴だ……んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、新しい身体も、またご主人にマーキングされちゃうね。……いいよ\n、私がご主人のモノだっていう証を、いっぱい刻み込んで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、んんっ……！　射精、全然止まらない。太ももでぎゅってす\nると、喜ぶみたいにおちんちんが跳ねて、あっ、またっ……んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、最後の一滴を出すまで、私の膝裏おまんこを楽しんで。ご主人のだ\nーい好きな太ももでよしよししてあげるから、いっぱい出しちゃってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……流石にお終い、かな？　うわ……私の膝裏と太もも、精液塗れにな\nっちゃってる。えっちな匂いもすごいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それで？　私のご主人は、ＹＳＫモードの性能に満足してくれた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――え？　まだ性能に不安があるからもう一回テスト？　次は足？　手？　\n腋？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ……喜んでもらえるのは嬉しいけど、ご主人、そーゆーとこ、だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まぁ、でも……ご主人が望むなら、何度だって。新しい私の事、いっぱいか\nわいがってよね？　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅんっ～～！　す、すごい勢いっ、ご主人の精液、顔にまで飛んで\nきてっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それでなくても、すごい匂いだったのに、顔になんて掛けられちゃうと……\nすんすん……んくっ、あっ、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の匂いだ……えっちでいやらしい……でも、私の大好きな、ご主人の\n匂い……！　あっ、んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、顔に飛ばしたぐらいで、今更謝らないでよ。新しい私の体……また\nご主人のモノだって証を付けられて、これでも、嬉しいんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……おちんちん、まだびゅくびゅくしてる……最後の一滴まで、膝の裏\nと太ももで、ぎゅーって搾り取ってあげるね。んっ、しょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――それで？　どうだったかな、ご主人？　ＹＳＫモード……というより、\n私の柔らかい『肌』は楽しんでもらえた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015806_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「太もも最高？　膝裏えろい？　……喜んでもらえるのは嬉しいんだけど、も\nう少し言い方とかさぁ……ご主人はいつもご主人だよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも、私も自分の『肌』がここまで弾力っていうのかな……さわり心地？　\nがいいって気がつかなかったや」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これなら、色々試してみたいことができたかも。ご主人、よかったらまた付\nき合ってよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もちろん、その代わり……えっちなご褒美、期待してくれていいからさ。ふ\nふっ、新しい私もよろしくね、ご主人♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0603410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}