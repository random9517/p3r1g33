{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "096_0103101" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えーと……パワーアップのための修行っていうから来てみたけど……これっ\nて、いったい……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103102" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ご奉仕って……え、えと、話には聞いたことあるけどさ……それって、ニン\nジャの仕事じゃなくない？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103103" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　仕事じゃないの？　修行の一環？　なんか、ウソくさいなあ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103104" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くさいといえば、隊長さんのこれ、けっこう臭うけど……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103105" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え！？　ちゃんと毎日あらってるし、さっきも洗ってきたばっかり？　ご、\nごめんね！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103106" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「って、そういう問題じゃなくて！　胸にこれをはさんで、なんの修行なの！\n？　ニンジュツと関係ないよね！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103107" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え！？　この修行法、先生から教わったの！？　こうすれば、僕の能力が３\n０００倍に上がるって！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103108" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そ、そうなんだ……って、ちょっと待って！？　それじゃもしかして、先生\nともこういうことを……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103109" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「う、うん……わかった。先生もしてるんなら、弟子の僕にできないはずない\nもんね。オーケー！　ヒアウィーゴ―！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103110" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「……って。言ってみたのはいいけど、どうすればいいのかな……え？　胸で\n挟んで、こするの？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103111" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はさんでこするって……こ、こう……かな？　よっ、と……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103112" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んっ……とっ……よいしょっ……ん……んんっ……こんな感じ？　どう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103113" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「もっと、ぎゅっと挟むの？　両方のおっぱいで？　こ、こうかな……？　\nぎゅう～……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103114" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！？　隊長さん！　なんで腰を動かしてるの？　え……？　\n僕の胸が、柔らかくて気持ちいい……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103115" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んっ……んんんっ……んっ、なんか、変な感じだよ。胸の間で、隊長さんの\nが激しく前後してて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103116" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　な、舐めるの？　これを？　えー！　なんで！　え……？　ここから\n、ニンジュツ上達エキスが出る……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103117" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「舐めれば舐めるほど強くなる？　マンヨーシューにも書いてある？　ほんと\nかなあ……ぺろっ……れろっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103118" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちゅっ……ぺろっ……れろ……ねえ、これで、ホントに強くなれるの？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103119" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え……！？　あ、ほ、ホントだ！　なんか。透明なエキスが出てきた！　オ\nーマイスシ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103120" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「もっと、真剣になめるんだね？　イエッサー！　ぺろん、れろん……ちゅる\nっ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103121" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　胸でも刺激すると、さらに最強のエキスが？　わ、わかったよ！　ん\nっ……よいしょっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103122" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「口の方も休まずに？　オーケー！　ラビットパワー！　んちゅっ……れろっ\n……ぺろっ……ちゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103123" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちゅるっ……ぺろ、ぺろっ……おっとっと、そうだった。胸も……休まずに\n……よいしょ……んしょ……っと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103124" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「すごいな、隊長さんの。なんだか、どんどん熱くなってくるよ……？　ぺろ\nっ……れろっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103125" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕の胸の間で、熱くて硬いのがぐりぐり動いてるよ。なんだか、変に興奮し\nちゃうな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103126" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「れろ……れろ……ぺろ……なんだかこれ、変な味だよね。えへへへ……ぺろ\n、ぺろ、れろん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103127" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、透明な汁が、どんどん出てくる……胸でこすると、もっと出るかな……\nえい！　えい！　ふにっ、くにっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103128" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、ちゅっ、ぺろっ……はあああ……なんだろ。僕、体の芯がカッカ\nしてきちゃった。これ、強くなってきた証拠なのかな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103129" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……ぷにぷに……ぺろぺろ……れろれろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103130" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　もっと真剣に刺激しろ？　もうすぐエキスがでる？　わ、わかったよ\n！　れろっ。ぺろっ、ぺろっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103131" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、ちょっと！　そんなに激しく腰振ったら……うわっ！　隊長さんの、す\nごく熱い！　それに脈打って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103132" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　もっと激しく胸でこするんだね！？　それに舐める！？　わかったっ\n！　えいっ！　はっ！　むにににににっ！　れろれろれろれろっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103133" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！　ちゅっ！　れろれろれろれろっ！　ちゅるるるる――んん\nん！　ラ、ラビットパワー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103134" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ！　た、隊長さん！　隊長さんのが、はちきれそうなぐらい膨れ上がって\n――わわわわっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103135" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんあああああっ！？　な、何！？　何これ!　胸の間でなんか出て……！\n　これがエキス！？　これがニンジュツ上達エキス！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103136" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うわああ……！　すごい！　隊長さんのアレ、まだドクドク脈打ってて、ニ\nンジュツ上達エキスがこんなにたくさん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103137" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「って、隊長さん？　さすがに僕も、なんだかおかしいなあ、って気がしてき\nたよ？　これ、ニンジュツ上達エキスなんかじゃないよね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103138" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうじゃなくて、精液……？　あ、そうなんだ……やっぱり、そんなことじ\nゃないかと思ったんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103139" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ま、いいんだけどね。正直言って、僕もちょっと興味あったし、隊長さんの\nだったら。別に、そんなに嫌じゃないし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103140" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「へへへへ……それにしても隊長さん、いっぱい出たね。僕の胸の間、隊長\nさんのでベタベタだよ。えへへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103201" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「って、なにこれ！？　隊長さんの、またおっきくなってきたの！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103202" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えと、これは、あれなの？　もう一回、したいってこと？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103203" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「わかった。じゃ、こんどはニンジュツじゃなく、エッチな修行ってことだね\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103204" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「パイズリ？　パイズリっていうんだ、これ。ふぅん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103205" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「わかった！　それじゃ、２回戦目、始めようか。オーケー！　レッツ・パイ\nズリ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103206" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んしょ……んしょ……よっ、とっ……はっ……ずりずり……ずりずり……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103207" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ぷにぷに……ぐりぐり……ふにふに……隊長さん、どう？　気持ちいい？　\nアーユーオーケー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103208" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　ぺろぺろも？　あ、そっか。それじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103209" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ぺろ、ぺろ、ぺろ……ちゅっ……ちゅっ……れろん……ちゅうっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103210" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんの、さっき出したばっかりだから……精液の臭いと味がするね。…\n…ぺろ、ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103211" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「どんな味かって？　うーん、ちょっと、説明しずらいなあ。少し、苦いよう\nな気はするけど……れろ、れろ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103212" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「味よりも、臭いがすごいかな……鼻にツーンとくる感じの、なんていうか…\n…刺激臭？　そんな感じ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103213" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でも、嫌いじゃないよ？　えへへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103214" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「わっ！　ど、どうしたの？隊長さんの、また熱くなってきたよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103215" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　今の僕の笑顔が、かわいくてエロかった？　そ、そうかなあ？　そん\nなにかわいかった？　エロいかどうかは、よくわかんないけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103216" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うん、わかった。もう一回出させてあげる！　ぺろ、ぺろ、ぺろ、ぺろ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103217" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「むにゅむにゅ……すり、すり……ぺろ。ぺろ、ちゅっ……れろっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103218" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、隊長さん、腰動いてる……気持ちよくなってきたの？　へへへへっ。じ\nゃあ、もっと気持ちよくしてあげるよ。これも、ワンオブ修行だもん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103219" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ぺろ、ぺろ……すり、すり……むにむにっ……あそこ、さっきみたいにピク\nピク脈打ってきたよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103220" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「出ちゃいそうなの？　いいよ？　オーケー、隊長さん！　ぶちまけてっ！　\nいざ、カマクラッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "096_0103301" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うわっ！？　あ、あああああ……っ！　出ちゃった！　ホントに出ちゃった\nね！　隊長さんの……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103302" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「精液、ドクドク出てるよ……おっぱいの間から、ダラダラたれてきちゃう…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103303" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんのアレ、まだピクピク震えてて、まだ精液出てる……精液って、二\n回目でもこんなに出るんだ。……隊長さんだけなのかな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103304" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うわ、べとべと……わ！　見て、これ、おっぱいの間で、隊長さんの精液が\n糸引いてるよ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103305" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「っていうか、やっぱり臭いもすごいね、こうして大きく息を吸い込むと……\nすぅ……ごほっ！　ごほごほっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103306" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ほらね？　むせちゃった……えへへへへ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103307" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さん？　この精液ってさ……赤ちゃんの、もとなんだよね？　こ\nれが、僕の体の中に入ると……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103308" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「知ってる？　隊長さん。ウサギってね、一度に何人も赤ちゃんを産むんだっ\nて。一気に大家族になっちゃうね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103309" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「な、なーんてね！　今はそれどころじゃないもんね！　それより修行修行！\n　僕、もっと強くならなくちゃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103310" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でもね、隊長さん。たまにだったら、また、こういう修行……してもいいよ\n　？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]}, 
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "096_0103401" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　あ。あれ？　もういいの？　おっぱいの間からアレを引き抜い\nて――」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103402" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ノオオオオッ！？　な、何これっ！　うわっ！　精液っ！？　わっ！　わわ\nわわっ！？　かかってる！　顔に――わわわわっ！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103403" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さん！？　なんでいきなりこんな！？　ワーオッ！？　まだ出てるっ！\n　？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103404" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あああ、もう……顔中ベトベトでどろどろだよ……臭いもすごいし。もう！\n　隊長さん、なんでこんなことするの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103405" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え……？　ベトベトにされて、なんだか興奮しないかって？　そ、そんなの\n……こんな、顔中臭くて、ベトベトで、ヌルヌルで……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103406" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ。ホントだ……！　なんだか、すごく興奮してきた……！　ワーオ……！\n　そういうことだったのか……奥が深い……イッツワビサビ……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103407" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　隊長さんも興奮したの？　ベトベトの僕の顔がいやらしくって……？\n　お、男の人ってそうなんだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103408" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「僕がかわいくて、いやらしいから、いっぱい出た？　……え、えーと？　そ\n　れは、ほめてるんだよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103409" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そっか、えへへへへ……ほめられてるんなら。悪い気はしないよ。サンキュ\nー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0103410" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、隊長さん。もしよかったら、また、エッチな修行……させてくれない？\n」", "NORMAL" ]},
