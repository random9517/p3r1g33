{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……飽きた。うん、もうサンタするのお腹いっぱいだよ。てわけで、今度は\nキミもサンタさんねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ね、サンタさぁん。今年１年、イイコにしていたボクのこと、いっぱい気持\nちよくして欲しいなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁはっ、いきなり後ろからっ、おっぱい……っ。んっ、んふっ、思いっき\nり掴んで……ああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00023103_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もみもみって、ンッ、激しくぅ……あふっ、それ、いいよぉ……。んっ、ん\nっ、すっごく感じちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ、乳首勃つぅ。ビンビンに勃起したエロ乳首になっちゃうよぉ。んっ\n、ほらほらぁ、乳首も責めてぇ、しっかりぃ……あはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「つまんで、くりくりって責められるの好きぃっ。あんっ、ボクのツボをしっ\nかりわかってて、サンタさんはさすがだなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「え？　腰が動いてるって？　そりゃあ、胸だけじゃ足りないからにきまって\nいるじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのチンチンも勃起して、ボクのオマンコにこすれてるの、しっかり感じ\nてるんだからぁ……んっ、ほらほらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっぱい責められて、オマンコ濡れてきちゃってるんだよぉ？　ねえねえ、\nチンポをオマンコに、プレゼントしてぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「バックから、ズコズコバコバコ、激しいやつお願い♪　サンタさんだったら\n、これくらい余裕でしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゃあ、ボクからは道化師サンタを一晩犯しまくりの権利をプレゼントして\nあげるから♪　ね、プレゼント交換だよ。いいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふっ♪　交渉成立ってことで……んぁっ、ああ……さっそくぅ……っ！\n　チンポ、き……きたぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンチンがずぶぅって一番奥まで届いちゃってるっ、あんっ、すっごく硬く\nて……太いよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああんっ、さっそく動いちゃうの？　んっ、あはっ、チンチンがオ\nマンコをごりごりしてくるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、トロトロになってるボクのマンコ、んくっ！　奥っ、奥を\n……んぁっ、いっぱいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ナカ、もう濡れまくりだって？　んっ、だってキミにハメてもらって、マン\nコが悦んでるんだもん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、すっごく感じちゃってる……っ！　ああっ、なんだかいつもより、気\n持ちいいかも……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっと乱暴にしていいよ。そうしたら、ボク、もっともっと気持ちよくなれ\nそうだからぁ……ね？　後ろから、いっぱい突いてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはっ、すっごい、おっぱいぎゅって掴みながら、ズンズンってチンチンが\nオマンコ犯してくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポが、何度もっ、オマンコを押し上げて、こすって……っ！　ああっ、\nすっごくいいのっ、気持ちよすぎるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、だめだめっ、内側から、イイとこ刺激されまくって……ん\nふっ、ちょ、ヤバ……ヤバいかもぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「このまま突かれまくったらぁ……ああっ、本当に、そのっ、ああ……だめだ\nめっ、我慢できなくなるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁああぁぁあぁ～～っ！！　で、でちゃったじゃないかぁ、おし\nっこ……んっ、キミがいっぱい突きまくるからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304123" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「マンコ側から、膀胱揺さぶるから、おしっこじょばじょばぁって、いっぱい\nでちゃってるぅ……♪　んひぃ……はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あんぅっ！　なっ、チンチンがビクンって震えて、しかもおっきくなってな\nい？　もしかして興奮した？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクがおもらししちゃうところみて、興奮しちゃったのかなぁ、この変態サ\nンタさんはぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぅっ！？　あっ、あぁあっ！　いきなりピストン急加速ぅっ！　ああっ、\n激しいのっ、きたぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、いっぱい中をっ、ごりごりってチンチンえぐってくるぅっ！\n　はぁんっ、それっ、気持ちいいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「サンタさんもっとぉ、もっとシてぇっ！　いっぱい、ボクのオマンコめちゃ\nくちゃに突きまくるの、ちょうだぁいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクも感じるぅっ、すっごく気持ちよくなってぇ、腰ぃ、うごいちゃってる\nよぉっ♪　んぁあっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「オマンコ反応しちゃってるっ！　んふっ、チンチンのこと、ぎゅーって締め\nまくっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「気持ちいいでしょ？　サンタさん、ほらほら、ボクのオマンコに夢中になっ\nて、もっと激しくぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああんっ、暴れん坊のサンタクロースチンポぉっ♪　どんどん、ピストンが\n速くなって、ンッ、イキそうな感じ？　ボクに中出ししちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいよっ、そのまま中出ししちゃってよ、サンタさんっ♪　ボクにたっぷり\n精液プレゼントしてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、あああぁぁぁああぁぁあぁ～～～～っ！！　きたっ、精液ぃっ、中出\nしぃいいぃぃ～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「奥にっ、チンチンずぶってされたままっ！　んっ、子宮の中にぃ、サンタさ\nんの精液がびゅくびゅく注がれてるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んはぁあっ、気持ちいい……っ！　アツアツのザーメンでお腹いっぱいにな\nりながらイク……ッ！　イッちゃうぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁああぁぁ～～……っ！　イキながら、また……おしっこぉ……♪　イ\nキションとまんないよぉ……あははぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ねぇねぇ……まだまだできるよね……？　キミのチンポぉ、勃起したままだ\nしぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのイイコ具合からすればぁ、サンタさんはもっとボクにザーメンをプレ\nゼントするべき。……ねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　いきなりまたっ、オマンコの奥にずぶぅって……っ！　あっ、あ\nあっ、チンチンぶっさすのいいっ、気持ちいいよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「イキマンコを休む間もなく責められるの感じるぅっ♪　サンタさん、ボクの\nことよくわかってんじゃぁ……あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなっ、おっぱいぎゅうって揉みながら、ピストンぅっ！　ああっ、おっ\nぱいとオマンコ同時っ、ンッ、効くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それ気持ちいいっ、感じちゃうぅっ！　ああっ、オカシクなっちゃうよっ、\nんひっ、あっ、ひぃいいぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、なに？　オシオキなの？　プレゼントを欲張る、ボクみたいなワルイ\nコにオシオキ？　んっ、ふふっ、なにそれぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「オシオキだったらぁ、もっともっと乱暴に犯さないとダメだよ、サンタさん\n♪　ほらほら、がんばれがんばれっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああっ、ああ……っ！　そうっ、そうやってぇっ、キツくおっ\nぱい揉むのっ、んひっ、ひぃいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「オマンコも、ンッ、チンチンでめちゃくちゃにっ、かき混ぜられて……ああ\nぁぁんっ！　いっ、いい……いいよぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああっ、ああぁっ！　すごい勢いでっ、腰っ、どちゅどちゅっ\nて、打ちつけられて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00023103_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンチン届くのっ、ボクのっ、子宮にぃっ！　先っぽが、あはっ、入り口ゴ\nツゴツって、たっ、叩いてる……んぅううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっ、オシオキなのにぃ……。ボクの身体、すっごく悦んじゃってるよぉ…\n…♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「乳首も、サンタさんが摘まみやすいようにビンビンだしぃ♪　んひっ、オマ\nンコだって、さっきの精液と、ボクのお汁でぐっちょぐちょぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「オシオキなのに気持ちよくなっちゃってる、エロエロワルイコサンタにぃ、\nもっともっとチンポでオシオキしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、ああっ、ああぁっ！　いっぱいっ、いっぱいぃっ、チンポでいっ\nぱいなのぉっ！　おっ、おおぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポが暴れまわってるっ、んひっ、いいっ、いいっ、感じるぅっ！　ごり\nゅごりゅ突かれるの気持ちいいぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっぱいも同時にもみくちゃにされてっ、頭の中っ、真っ白になっちゃう！\n　ああっ、本当に、オカシクなっちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、チンチン膨らんできたっ、キミも、イ、イク？　イッちゃいそう？\n　んふっ、また精液だしちゃう？」", "NORMAL" ]},
