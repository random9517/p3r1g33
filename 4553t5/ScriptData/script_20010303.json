		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「はー、本当、数だけ多いよねー、こいつら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020038" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「まともに相手をしていては時間の無駄だと、論理的に判断します。もう一度\n、透明化魔法を使うので、姿を消して逃げましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020028" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ですから、ピコ、今度こそ途中で大声を出さないように！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020029" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「そしてミラン！　あなたもお菓子に釣られて、単独行動を取るのは控えてく\nださい！　いいですね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020030" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……はーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020019" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「うー、怒ったときのティア、ちょっとオバサンに似てるよねー。迫力あるっ\nていうかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020039" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「だ、誰がオバサンですか！　さすがにあの人と一緒にされるのは、名誉的に\nいろいろと心外です！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020031" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「じょ、冗談だってー。っていうか、ティアも声大きいー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020040" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……声で見つかっちゃう。……あー……遅かったかー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020020" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ミランが少し疲れたように指さす先から、新手が駆けつける。", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「見つけたぞ、こっちだ！　はぁはぁ……魔法石を返してもらうぞ」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「うわー、今度はこっちのやつらかー。めんどーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020041" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うー、おやつの時間、どんどん遅くなるー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020021" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うんざり顔のピコとミランが、ちょっと責めるような目で原因となったティア\nを睨む。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "LEFT", "0" ]},
	{"command":[ "SETCHARA", "1", "char_00004201_01", "2", "RIGHT", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0", "1" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「わ、私のせいではありません！　おふたりが危機的状況にもかかわらずにマ\nイペースだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020032" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「無駄口はそこまでだ！　おとなしく魔法石を返せ！！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「まったく、噂どおりだ……どこにでも顔を出し、トラブルを引き起こしてば\nかりの迷惑集団めっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ちょっとー、迷惑集団ってなによー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020042" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ちょっと、傷つく……しょんぼり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020022" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「事実だろう！　お前たちも魔女を名乗るのなら、もっと知的に行動をできな\nいのかっ」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員" ]},
		{"command":[ "SETTEXT", "「市街や公園で遠慮なく魔法を使って大暴れして……たちが悪いにもほどがあ\nる！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「なっ……あなた、この私を知的ではないと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020033" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「魔法の研究に身を捧げ、常日頃研磨を怠らない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020034" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「魔女の世界に生まれ落ちた革命的天才児、この氷結のセレニティ・クラウン\nを愚弄しましたね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020035" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「許しません！　客観的に考えて、許す理由など一欠片もありません！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020036" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「うわー……ティアがマジギレしてるー。っていうか、逃げるんじゃなかった\nっけ？」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00004001_01", "5", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_040_010021020043" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……ティアも、短気なところあるから－」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_010021020023" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「無駄口は終わりです、おふたりとも！　さあ、可及的速やかにこの無礼者ど\nもを殲滅いたしましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_010021020037" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
