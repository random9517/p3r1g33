		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、出して……欲しいっ、どんな風でもいいっ……あなたの欲望\nを……全部、この身で……受け止めたいっ、あくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、んちゅぷっ……私もっ……もうっ、オマンコ……限界にな\nってるっ、もうっ、このままイクっ、イクからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はひぁっ、中でもっ……外でもっ……出してっ、熱い……精液っ……またっ\n、びゅくびゅくしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「うくぅぅぅぅぅぅんっ！　あぉぉぉぉっ、また中っ……オマンコっ……出て\nるぅぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁ……イ、イッてるっ……オマンコずっとイッてるっ……はひっ、気持ち\nいいのっ……止まらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ、いっぱいになってるから……隙間からどんどん溢れてしまってる…\n…イヤだ、勿体ない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「まだ出るから……大丈夫……？　う、む……だ、大丈夫ではない気はするが\n……はぁ……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、あぁ……終わった……んっ、全部出してくれたということで\n……いいんだよな？　んむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「まだ、もう少しそのままでいさせて欲しい。あなたのオチンポの感触……味\nわったままでいたいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコの中で……あなたの精子がいっぱい泳いでる感じがする…\n…んふ……受精……してくれたかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、あなたに癒やしの時間をと思っていたが……私の方が癒やされてし\nまったようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「こうして肌を触れ合っている時間が、どれだけ幸せなものか……あなたと共\n有できていればいいんだが……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、少し一休みしたら、また続きをしよう。夜は長い……もっともっとあ\nなたに癒やされて欲しいからな……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁんっ！　あっ……身体にっ、熱いのっ……びゅくびゅくっ……出\nてるぅっ……んくぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふぁ……精液浴びてる……おっぱい……顔にまで飛んできて……なんて元\n気なんだ……んちゅぷっ、はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふっ……トロトロザーメンが美味しい……りゅぷっ……この味ぃ……私を\n虜にさせるんだ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、まだびゅくって……全く……どれだけ出すつもりなんだ……あなたの\nオチンポ……逞しすぎるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅぅ……あぁ……落ち着いた……のか？　これで出し切ったという\nことで……いいんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んふ……ヌルヌルだ……全身ザーメンまみれにされてしまった……あぁ……\nこのヌルヌルが気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「もう、何回イカされたのかも分からない……それだけ、あなたのオチンポに\n溶かされてしまった気がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「十分に癒された……？　そ、そうか……そういう風に言ってもらえると……\n私も、嬉しい。ちゃんとご奉仕できていただろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、その……なんというか、私の方がよっぽどご奉仕されてしまったよう\nな、そんな気分だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「まだ、続きを……？　ふふ……分かった。一休み終わったら、まだまだ私の\n癒やしを味わってもらうぞ……んちゅっ……」", "NORMAL" ]},
