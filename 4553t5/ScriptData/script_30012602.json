		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、待っていたぞ。うむ、その……すまないな、貴重な時間を取らせてし\nまって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604101" ]},
