		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「今日は……その、だな……最近、とても忙しくしていただろう？　やっぱり\n、色々と疲れが溜まっているんじゃないかと思って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「本当にささやかではあるんだが、私が……あなたを癒やしてあげることは出\n来ないかと……そんな風に思って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだろう……私の気持ちを受け取っては貰えないだろうか？　そ、そうか\nっ……うむ、すぐに準備しようっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「服を脱ぐ？　あぁ、そうだ。今日は私の全身を使って、癒やしてあげたいん\nだからな……あなたの服も脱がしてしまうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふっ……なんだ……もう、オチンポもしっかり勃起している\nじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000126_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「その気になっているオチンポを……まずは優しく撫でて行くからな……んふ\n……リラックスしていてくれ……するぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ……オマンコの入り口のところで……ゆっくり、優しく……オチ\nンポを撫でてやる……マンズリというんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「敏感な場所同士だからな……いきなりではなく、まずはじっくりと……気分\nを高めあって行こう……んっ、はぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「濡れてる……？　あふっ……それはそうだ……もう、ここに呼んだ時から…\n…私はもうオマンコを濡らしていた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「今……こうして、オチンポと触れ合っているだけでも……どんどん新しい愛\n液が……湧き出してしまってるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……んっ、どうだ……オチンポの方は……やっぱり入れないと物\n足りないか？　ちゃんと気持ちよくなっているか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……よかった。私一人だけその気になっても仕方ないからな……\nは……んっ、あふっ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……だが、んっ……この状態だと……ちょっと滑ると、そのまま入って\nしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「そう……私がほんの少し腰を落としたら、もうそれだけで……あっ、はぅん\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ、あぁっ……本当に……あっ、ひっ、入ったぁ……んくぅっ\n、オチンポっ……ずぶってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ち、違う……本当に、あっ、わざとじゃなくて……あひっ、あぁっ、もう少\nしじっくりするつもりで……あっ、あぉっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ダメ……あっ、いきなり太いの、一気に入れたらっ……待ってくれっ、あぉ\nっ、もうっ、いきなりっ……あ、くぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「は……んっ、あふっ……はぁ、はぁ……あぁ……い、今の……あっ……すま\nない……その、先に……イッてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「信じてくれ、本当にそんなつもりじゃ……んっ、気にしない？　このまま…\n…あ、あぁ、もちろんだ……では、このまま続けさせてもらう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「うんっ、あふっ……あっ、はっ、少し緊張していたのかも知れない……私の\n方もリラックスしなくてはな……あ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ゆっくり腰を動かして……奥へ……入れるぅ……んっ、くぁぁ……オチンポ\n……すごいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁん……待っててくれ……じっくり、気持ちよくさせていくからな……私\nのヌルヌルオマンコの感触……楽しんで欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「は、んふっ、このヒダ肉の……よじれているところぉ……ぐりぐりっ……オ\nチンポに擦りつけてぇ……動くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んはふっ……！　亀頭のエラが張ってるとこに……あふっ、オマンコの……\n好きなところが……当たってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んぁっ、あぁっ……どうだ……？　んっ、ちゃんと気持ちよく\nなってるか？　私のオマンコ……緩くないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……あふっ、それならいいんだ……精一杯……オマンコでおもて\nなしするから……いっぱい感じて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、リクエスト……？　う、うむ、なんだろうか。そう無茶なこ\nとでなければ、なるべくしてやるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「え……キ、キス……！？　あ、あー、それは……その、そう、だな……確か\nに、しても……いいかも知れないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「唾液交換まで……わ、分かった……あなたがそこまで求めるなら……んっ、\nあぁん……んっちゅ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んむぅ……れろ、ぴちゃ、んちゅぷ……れりゅ、れろ……んっ、えろ\nっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……何だこれ……あぁ、んちゅっ……い、いつものキスと……んりゅ\nっ、全然……違ぅ……んちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ、んっ、あぁ……舌を絡ませて……舐めあうらけれ……オマンコが…\n…何倍も気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あはぅ……んんっ！　上と……下でっ、ごりゅごりゅっ……してぇっ……あ\nひぉっ、ジンジンひゅるうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んちゅぷっ、んぁっ……もっと舐めて……私の舌ぁ……ペロペロし\nてぇ……あなたの唾液飲ませてぇ……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポも……あぁっ、もっと突き上げてっ、はぁんっ、出したく……なっ\nてるっ？　ならっ……このままっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだっ、きゅんってするからっ！　いっぱいっ……私のオマンコにっ……\nあなたの新鮮ザーメンっ……ドピュって出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぅんっ……！　あぁっ……あふぁっ、来た……中出し射精っ…\n…は、始まってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぉぉぉぉ……びゅくびゅくっ……オマンコの奥……子宮に届いてぇ……は\n……ひぁぁぁ……イ、イクぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅ……はぁぁ……あふぁ……んっ、一緒にイケた……オチンポと\n一緒に……オマンコ……幸せになれたぁ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふ……あぁ……あなたも、癒やされたのだったら何よりだが……まだ……\nオチンポは硬いし……続きができそうだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、私も……もっとあなたにご奉仕したい……繋がったまま、抜かずにい\nっぱいオマンコしたい……構わないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「分かった……今度はもっとスケベに腰を回して……あなたのオチンポに尽く\nしていくぞ……んっ、あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら……んっ、ふっ……！　中に精液がいっぱい入って……くちゅくちゅっ\n……音がっ、してるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あふんっ、ゆっくりかき回すと……はひぁ……あっ、ヒダの違うところに当\nたって……んくぅ……気持ちいいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと身体を支えてくれるか……？　んっ、そうだ……手を握ってくれて\nいればいい……これで、腰を回してぇ……あ、ぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「おぉっ、はぁぉっ……あぁ……繋がってるところぉ……丸見えで……動かし\nてるぅ……はぁ、あひっ、ひあぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ぱっくりオマンコ広げて……いやらしくオチンポを咥えこんでいるところ…\n…全部見せてしまってる……ん、くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいに決まってる……！　けど、あなたになら……私の恥ずかし\nいところは……何でも見せてしまえるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「だから、あぁっ、どれだけはしたない女だと……スケベな女だと罵られても\nいいっ……もっとオチンポに尽くしたいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁんむっ、んちゅぷっ……ま、またキスぅ……はぁ、んちゅぷっ……あっ\n、おっぱい揉みながらなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「イヤじゃない……んっ、嬉しい……りゅぷっ、あなたに……私の身体中、ど\nこでもいっぱい愛して欲しい……あっ、あぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、オマンコもぉっ、もっとキュンってするぅっ！　はぁんっ、オチン\nポにキスしてっ……しっぽり締め付けるのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000126_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「んむぅっ、あちゅぷっ……はぁぁ……んっ、あぁ……一緒に気持ちを高めあ\nっていくの……もっと、ちゅぱっ、もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「ヌルヌルの中っ……好きなだけかき回してぇっ……はぁんっ、包み込んでい\nくから……あぁっ、は、激しいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぅんっ！　はぁっ、あっ、オマンコ裏返ってしまうっ、オチンポさ\nれてっ……飛んじゃうからっ……あはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｇルナテミス" ]},
		{"command":[ "SETTEXT", "「はひっ、あなたもっ……またっ、あぁっ、イキたくなってるっ……？　私の\nっ……オマンコピストンでっ……出したくなってるっ？」", "NORMAL" ]},
