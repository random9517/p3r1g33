{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふふ……さあ、ダーリン。二人きりになれましたわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「少し強引にさらってしまうような形になってしまいましたが、それも仕方な\nいのです……このように私を開発したのはダーリンなのですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅ……今ではもう自然に身体が疼いてしまって……どうにも抑えきれな\nいことも多いのですから……責任を取って頂かないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……そんな訳で、ダーリン……そこに寝て下さい。はい、私が万事取り\n仕切りますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あら……頼もしい。もう、オチンポ……ガチガチになって下さっているよう\nですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……はい、私ももう待ちきれずに、オマンコが濡れてしまっていますわ\n……でも、今日は……そうではありませんの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「まずは……こうして……んっ、ふっ、お尻の谷間で……んんっ……オチンポ\nをお扱きする所からですわ……んふっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、こういうのを……尻コキというのですよね？　中々加減としては難し\nいですが……んっ、お尻にしっかりとダーリンのオチンポを感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あっ、んむっ、んっ……はぁっ、あっ、んっ……オチンポ、\n熱いですわ……今すぐにでも突き入れて欲しい位に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「でも、少しだけ我慢です……まずは、じっくりと腰を回して……ゆっくりお\n尻の肉に感覚を伝えて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、んふっ……ほら、勃起も一番大きくなって来ました……そろ\nそろ、よろしいようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「いえ、このままオマンコにではありませんわ……んふっ……今日はそのすぐ\n上の方に……こちらにお願いしたいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、人間はこちらの……排泄の穴でも、そういう行為をすると伺いました\n。アナルセックスというのですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、一応……私自身の手で……お尻の穴はほぐしておりますので……きっ\nと、ダーリンのオチンポを受け入れられると思います……どうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、それでは……ゆっくり腰を落として参りますわ……あっ、んんっ、は\nっ……んくっ……あぉっ、おっ……ほぉぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁぁ……狭い入り口を……こじ開けられてぇ……オチンポが……お尻の穴\nに……入って……行きますぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……おぉぉぉっ、ほぉぉお……ひ、広がるぅ……こ、これは……オマ\nンコの時と……全然違う……感覚ぅ……あ、ぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「メリメリ……広がってぇ……あっ……ひぃぃぃ……思ったよりもキツく……\n感じます……あっ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あ……いえ、大丈夫ですわ……ダーリンにご心配を掛けるようなことは何も\n……んっ、ちゃんとオチンポを感じております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ほら……一番奥まで埋め込まれました……あぁ、ダーリンの\nオチンポがぶっすりと私のお尻を貫いております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ、ムズムズする感覚です……肛門が広がるというのは、これほどまでに\n落ち着かないものだったなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「オチンポの硬い所が中の粘膜を擦り上げて……柔らかい所がしっとりと吸い\n付いて……く……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、動かして下さい……どうか、私のはしたないお尻を……ズボズボとか\nき回して……あっ、あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぉっ……あぁぁ……ダーリンの太いオチンポっ……お尻の中でグ\nリグリされてっ……おりますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あっ、ひっ……このっ、内側からお尻の粘膜をほぐされていく\n感覚……あぁっ……首の後ろがぞわりとしてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ほぉぉっっ、おっ、ふっ……目の前に、軽い閃光が走るような……おぉっ…\n…い、今のっ……はっ、あぉっ、おぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……はひ……確かに、入り口の肛門が……一番敏感になって\nおりますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「続けて……オチンポを出し入れされるとっ、んぁぉっ！　お尻っ……浮き上\nがってっ、あぉぉぉっ、す、すごいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あふぁっ、はひぁっ……あぁぁっ……気持ちいいです……今度はもう少し奥\nの方を……ぐっとほじって下さいませ……あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あっ、おぉっ、おひぉっ、おぉんっ！　それっ、それですぅっ……ダーリン\nのオチンポがっ……お尻を通り抜けて来るぅっ、感じぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はあっ、あひぉっ、ひっ……あぁっ……足が震えますっ……身体が熱くなっ\nてっ……オチンポのことしか考えられなくなるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はひっ、んひぃっ……かき回されるっ……はいっ、もっとパンパンってっ、\n激しく打ち付けてっ……あぁっ、アナルがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンポを……ぎゅっと挟み込んでっ、はいっ……ちゃんとお尻\nの穴っ……キュンっと締め付けますっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅっ、ダーリンも気持ちいいですかっ？　よかったっ……あぁっ、私の\nお尻……存分に犯し抜いてっ……このまま気持ちよく射精なさって下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はいっ、中がいいですっ……お尻の中にそのままぁっ……はいっ、私のケツ\nマンコにっ……熱いのビュクビュクっ、お漏らし下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁひぃぃぃぃぃぃんんっ！　あっ、あぉぉぉぉっ……出てるっ……中にっ\n、いっぱい……チンポミルクっ……出されてますわぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「くぅぅぅん……あぁっ……お尻に精液を感じます……とぷんって……お腹の\n中をいっぱいにされておりますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……んくっ……あぁ……これがアナルセックス……はぁ……んっ\n、なるほど……生殖でなくとも、このような享楽があるのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふぅっ……はぁっ……何とも、これは……病みつきになってしまうような気\n配がありそうです……あぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ダーリン……その、お願いなのですが……まだ、もう少し……続けていただ\nけますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「一度、精液をたっぷり頂いて……お尻の穴が……より敏感になってしまった\nみたいで……もっとお尻を犯していただけませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい……ダーリンのオチンポに征服されて……欲張りなお尻の穴は、もっと\nダーリンのオチンポを感じたがっているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「どうか、このふしだらな穴をたっぷりと躾けて頂いて……私に浅ましいよが\nり声を上げさせて下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あひぉぉっ！　あぁおっ、はいっ、そうです……これが欲しかったんですっ\n、あぁぉんっ、ケツ穴がいいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んはぁっ……はい……さっき出して頂いた精液を……しっかりオチンポで腸\n壁に塗り込めて下さい……じゅぶって……恥ずかしい音させてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「おひっ！　あぁっ、そこですわっ！　深くっ……オチンポめり込ませてぇっ\n……くぅぅんっ、あぁっ、効きますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……こうして……後ろから身体を抑え込まれて……排泄の穴を犯される\n背徳感……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「くぅ……んっ、ダーリンのオチンポの前に委ねてしまう……この感じ……あ\nぁっ、私は……とても幸せを感じますっ、あぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はいっ、ちゃんとオチンポも喜んでいただけるように……ケツ穴っ、キュン\nと締め付けますっ……こ、これで……いかがですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁんっ……ありがとうございますっ、しっかりと入り口を閉じてっ……オ\nチンポを絞り込んで……あぁっ、喜んでいただきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「うんっ、んくぅんっ……ダーリン……キツくありませんか？　丁度いい加減\nで……お尻を閉じるのは……中々難しくて……あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぉっ……おぉっ……はいっ、ちゃんと……ダーリンが、リードして下さる\nっ……んふんっ、嬉しいですっ……あぁっ、オチンポぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はいっ、奥も好きですが……やはりっ、オチンポが肛門を通り抜けていく瞬\n間の気持ちよさが……ビクビクしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あはぁっ、はぁんっ……オマンコと違うっ……力が抜けていく瞬間に……ズ\nボッと来る感覚っ……はぁぁ……気持ちよくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ、んくぅんっ、もっとオチンポして下さいっ！　蕩けきった、私の浅\nましいアナルにっ……しっかりオチンポを分からせてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あくぅっ……あぁっ、はんっ、あぁっ、もうすぐ……イキますっ！　ダーリ\nンのオチンポにアナルを犯されてっ……イキそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ……んくぁっ、ダーリンもですかっ？　あぁっ、嬉しいですっ……ど\nうか……お好きな時に出して下さいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はいっ、このまままたケツ穴に流し込んで頂いてもっ……お尻の肉にぶっ掛\nけて頂いても構いませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「どうか……思いっきりかき回してっ……イッて下さいっ……！　あひぉっ、\n私もっ……ケツ穴っ……イグっ……イキますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「おほぉぉぉぉぉっ！　おぉぉっ……また中に出てるっ！　ケツ穴中出しキメ\nられてっ……おぉっ、ケツアクメ……するぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「おふぁっ……押し寄せて来ます……あぁ……精液浣腸が……私のお尻を全部\n満たして……すごい量……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁぁ……まだ……あぁっ、まだびゅくって……はぁぁ……からだ……溶け\nてしまいますぅ……んへぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あふぁ……はぁ、はぁ……はぁ……あと少しだけ出そうですか……？　はい\n……んっ、私が搾り出して差し上げます……んふぅぅっ、ふぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁ……出て来ました……いっぱいのアナルに……また、ビ\nュクって……気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「全部出ましたか……？　あっ……オチンポが抜けます……んんっ、あふっ…\n…お尻……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お尻の穴……まだ力が入らない……閉じきってくれません…\n…精液が垂れて……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……すみません、はしたない所をお見せしました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「でも、ここまで気持ちがいいものだとは思いませんでしたから……今までに\nない発見でしたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……またダーリンと深い関係になってしまいました……これからはオマ\nンコとお尻……共々愛して下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃぃっ！　お尻にっ……掛かってるっ、濃いのっ……びゅくびゅ\nくっ……出てっ……おぉっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁっ……精液のシャワー……今度はお尻のお肉に……たっぷり降り注いで\n……あはぁぁ……この粘り……うっとりしてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204402" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んく……オチンポ、もう抜けてるのに……んんっ……ずっとイッてる感じ…\n…続いてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はふぁ……まだ少し射精されますか……？　それでは、私のお尻にオチンポ\nを直接つけて……はい、そのままシコシコして下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あはぁんっ……生あたたかいオチンポと……精液の感触……たまらないです\n……んんっ、あっ、また……出て来ました……ザーメンこんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、終わりましたか？　んふ……いっぱい出して下さいましてあ\nりがとうございます……お疲れさまでした、ダーリン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00023002_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……あふっ、私も……何度もイッ……あぁ……まだお尻の感触が少し変\nです……ムズムズが残って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あふ……やっと少し落ち着いた感じがします……なるほど、人々がアナルセ\nックスに夢中になる……経験してようやく意味が分かりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「そうですね、でも、ずっとお尻ばかりというのも考えものです。オマンコも\n平等にしていただくのが筋というもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「という訳で、これからもどちらもたっぷりと愛して下さいませ……楽しみに\nしていますわ、ダーリン……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}