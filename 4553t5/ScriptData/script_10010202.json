		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　周りの風景が、さっきと全然違うぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102020002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あれれれ？　マッポーサムライもいなくなっちゃった！？　逃げちゃったの\nかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102020002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「危ない！　伏せて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102020002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「おおっ、と！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102020003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「マッポーサムライのヤツ！　どっかに隠れて撃ってきたのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102020003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「違う！　あそこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102020003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "ＥＤＯ隊長" ]},
		{"command":[ "SETTEXT", "「通信手！　本部からの連絡は！　応援はまだかって、せっついてやれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ＥＤＯ隊員" ]},
		{"command":[ "SETTEXT", "「航空部隊がこっちに向かってますが、敵の機動兵器に阻まれ近づけないそう\nです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ＥＤＯ隊長" ]},
		{"command":[ "SETTEXT", "「だったら、あたしらだけでやるしかない！　撃て撃てっ！　襲来者をこれ以上\n近づけるな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「原住民どもめ、そんな原始的な武器で我らに対抗するつもりか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「制圧せよ！　一気にたたみこめ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なに、あれ？　あの人たち、なにやってんの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102020004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いや、そりゃ戦ってんだろ。なんで戦ってんのかは知らないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102020004" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どっちかがヴィランで、どっちかがヒーロー？　うーん、よくわかんないな\nあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102020004" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「とにかく、もうすこし様子を見ましょ。場合によっては、どっちかに手を貸\nし――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102020003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わわわっ！　撃ってきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102020005" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「うひゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102020005" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おい！　ホク！　あいつらどっちもヴィランじゃねえか！　オレたちに向け\nて撃ってきやがったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102020005" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうだよ！　あーしら、何にもしてないのに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102020006" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え！？　二人とも待ってよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102020004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うわあ！　あの人たち、どっちもすごい武器持ってるよ！　ちょっと近くに\n行って見てみたい！　いや、戦ってみれば性能もわかるはず――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102020006" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとゲンまでなに言ってんの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102020005" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ごちゃごちゃうるせえ！　行くぞオラァーーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102020006" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「イエーーーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102020007" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「イーーーーーハァアーーーー！　イッピカイエェーーーー！」", "NORMAL" ]},
