{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「今日は手伝ってくれて、ほんまおおきに！　おかげさんでみんなに回転焼き\n配れたわ。お礼になんでもしたるさかい、遠慮なく言うてや！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「……へ？　ウチにフェラして欲しい……？　あ、アンタなに言うてんの！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「フェラ言うたらアレやろ……お、男の人のオチンチンを……その、口に咥え\nてちゅぱちゅぱする奴やろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　そ、そない恥ずかしいこと、ウチようできへん……わけやな\nいけど……！　あ、アンタやったら別にええっちゅうか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あーーー、もう！　女は度胸と愛嬌や！　アンタのお願い聞いたるわ！　う\n、ウチに任しとき！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んっ、はああぁ……すごいニオイやね……こんなん、今まで嗅いだことない\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「それにえらい変な感触がするわ……硬いくせに、妙に柔らこうて……握って\nると、変な気持ちになってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ……このタマみたいなんは、ちょっと硬い言うか……掴みづらいけど、\nなんかおもろいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「そ、そない痛そうな顔してどないしたん！？　ウチ、オチンチンになんかし\nてもうたん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチンをぐにぐにされるのは気持ちええけど、タマを強く掴まれると痛\nいんか……？　か、堪忍な……ウチ、男の人のモン触るの初めてやけん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ほんなら、気を取り直して……咥える前に、まず軽くオチンチンをシコシコ\nすればええんやったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……ビクビクしてはるけど、こないな感じでええんかな……？\n　い、痛かったら、遠慮なく言うてや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「せや……！　タマの方も触らなあかんかったね……優しく、撫でるように揉\nんで……んっ、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「この力加減を調整するの、回転焼き作る時に似てるなぁ……なんや、えらい\n愛おしく見えてきたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「わわっ！？　オチンチンの先端から汁みたいなん出てきたで！？　大丈夫な\nん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「先走り汁言うんか……気持ちええと、オチンチンから出てくるんやね……あ\nははっ。気持ちええなら、ウチも嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチン、いっぱい気持ちようなってな……ウチ、アンタのために頑張っ\nてシコシコしたるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「お礼いうのも確かにあんねんけど……ウチがアンタに、エッチなことしてあ\nげたい思うてるんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ……！　手でするんやのうで、口でせなあかんかったね……！　なんや\n夢中になってもうたわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ほな、咥えるで……八重歯に当たって痛いかもしれへんけど、堪忍な……ん\nっ、くちゅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んぐっ、んむううぅ……！　ちゅぱっ、ちゅ、れろっ、ぐじゅ……ど、どな\nいや……？　気持ちええか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あむっ、じゅぷ、じゅぽっ……もっと舌をオチンチンに絡めて、吸い付くよ\nうにすればええんやね……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ちゅぱっ、ぐちゅ、じゅるっ、ちゅぷ……！　この先走り汁\nいうの、ネバネバして美味しないなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチは甘い方が好きなんよ……ぐちゅ、ちゅ、ちゅぷ……れりゅ、れろっ、\nじゅる、じゅぱ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ぷはっ……はああぁ……オチンチン、どんどんかたなってくるな……血管も\n浮き出て、ガチガチになっとるで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「なんや知らんけど、タマもえらい動きよるし……でも、それだけウチの手と\n口を気に入ってくれた言うことやろ……あむっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅぱっ……あむっ、んむっ……れりゅ、ずちゅ……んっ、んっ、ち\nゅぴっ、ちゅぷ……！　ちゅ、じゅるっ、ずちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んくうぅ……フェラいうんは、顎がいとうなるな……でも、アンタのため思\nうたら、苦やないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ずっと口ん中でオチンチンビクビクさせて、悦んどったやろ……？　せやか\nら、ウチほんま嬉しいんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「アンタの精子やったら……飲んでも構わへん思うぐらいに、愛おしいわ……\nんっ、ちゅ……じゅるっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んっ、あむっ、れろっ、ぴちゅ、ちゅぴっ……！　んっ、んんんっ！？　お\n、オチンチン、さっきより激しく脈打ってはる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「タマの方もえらい動いて……！　な、なんやこれ……！　んっ、ぐちゅ、ち\nゅぱっ、じゅるううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「しゃ、射精の合図なんやね……！　うん、ええよ……ウチの口に出して……\n！　全部受け止めたるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「じゅぞっ、んじゅうるぅ……！　ふぶっ、あもっ、ちゅ、じゅぷうぅ……！\n　ちゅっ、ちゅぱっ……！　じゅる、じゅぷ、ずちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチン膨らんでる……！　ええよ、いつでも……！　ウチの口ん中、ア\nンタの精子でドロドロにしてっ……！　あっ、ああぁ……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んぐうううぅ……！　んくっ、んんっ、んくうぅ……！　くっ、ふああぁ…\n…じゅる、ちゅぱっ、ずっ、ずちゅうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「これが、アンタの精子なんやね……！　ごくっ、んっ、ごくん……！　こ、\nこない出るなんて、聞いてへんよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「それに、熱うて……ネバネバのドロドロで……！　回転焼きの生地みたいや\n……じゅずうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んんん～～～～～っ！　ま、まだ出るん……！？　ウチの口、もう入らへん\nのに……！　ちゅぱっ、ずっ、ぢゅちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、じゅぷっ、ぢゅぱっ……はぁ、はぁはぁ……ぎょうさん溜め込んど\nったんやね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はあああぁ……どや……？　アンタの精子、ぜーーーんぶ飲み込んだったで\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103201" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「正直、にごうて美味しゅうなかったけど……アンタの赤ちゃんのモトやと思\nうと、好きになれたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「せやけど、こんな濃くてドロドロの精子、お腹ん中に出されたら……絶対妊\n娠してまうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちょ……！　なんでまたオチンチン大きくしてはるん……！？　え……？　\nウチとのセックスを想像したら、またシたくなったん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　そないなこと言われても……！　で、でも……アンタが苦し\nんどる姿は、見とうないわ……ええよ……もう一回シよか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あむっ……んっ、んむうぅ……ちゅ、じゅ、ちゅぱっ……こんな感じでええ\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「出したばっかりで敏感やから、もっと優しく舌で撫でまわして欲しいん……\n？　んっ、ちゅ……れろっ、れりゅ……こう、かいな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「この傘みたいなとこをくちゅくちゅして、先端を舌先でクリクリすればええ\nんやね……ちゅ、ちゅぱっ、れろっ、ずりゅ……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅ……んぶっ、んんっ、あむっ、んむっ……！　さっきよりも\nニオイがキツくなっとるな……んっ、ずちゅ、れろっ、ぺろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチの唾液と、アンタの精子が混ざってるニオイと味や……そう聞くと、な\nんかエッチな感じが強なるな……ちゅ、ちゅぱっ、れりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んんっ……興奮したん……？　オチンチン、舌の上でビクビク跳ねながら、\nエッチなお汁振りまいとるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「そない暴れられたら、ちゃんと咥えられへんよ……ちゅぱっ、ちゅく……ず\nちゅ、ちゅ、じゅぷっ、ぢゅるっ、ずちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「いっぱいオチンチン舌でペロペロして、口ん中でちゅぱちゅぱしながら、タ\nマ揉み揉みしるから……もっと、気持ちようなってや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「じゅるるっ……じゅぷ、ずじゅっ……はぁ、はぁ……れろっ、れりゅ、んっ\n……うむっ、んんっ、むううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちゅるるっ……ちゅ、ぐちゅ、じゅぞっ……！　オチンチンの裏側、気持ち\nええんやね……舌と口動かすたびに、反応しとるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あむっ……んっ、んむっ……！　れろれりゅ……ちゅ、ぢゅぱっ……オチン\nチン膨らんで……！　我慢せんと、全部出してええから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「アンタのドロドロして、濃くてクサイ精子……ウチに頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅ、あぶっ……！　はぁ、はぁ……！　ビクビクする感覚が段々\nはようなってる……！　で、出るんやね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちゅぷ、ずっ、じゅぞっ……！　あむっ、れろっ、ぺろっれりゅ……！　ぐ\nちゅ、じゅずっ、じゅぷっ、じゅぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　え、ええよ……！　好きなとこに出して……！　んっ、ん\nむうっ、んじゅるうううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んぐっ！　んっ、ぐむっ！　んむうううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、れりゅ、ずりゅ……！　ドクンドクンて脈打ちながら、精子が口\nん中出てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「二回目やのに……味も、ニオイも……さっきより濃くなってるよ……！　ち\nゅぱっ、ちゅ、じゅぞおおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごく、ごくん……！　ううぅ……！　喉に張り付いてきよる……\n！　飲み込むのも一苦労や……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチンの中に残っとるのも……吸い出したるから……ずっ、ずちゅ……\nちゅ、ちゅりゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……これで全部やね……ほんま、どれだけ出すねん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「お腹ん中、アンタの精子でいっぱいや……暫く精子の味とニオイが離れそう\nにないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「……あっ！？　味とニオイが精子のままとかアカンやん！　ウチの作る回転\n焼き、どないして味見すんねん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「回転焼き作れんようになったら、ウチ困ってまうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「アンタがウチの代わりに、回転焼き作ってくれるん……？　そ、そんなん、\n初めての共同作業やん……って、なんでもあらへん！　気にせんといてや！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「きゃあああぁ！？　きゅ、急にオチンチン引き抜かんでよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと……！　か、顔に精子が……！　んくうぅ……や、やめっ…\n…！　顔にかけんといて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あううぅ……！　ねちゃねちゃした白い液体が、顔いっぱいに……！　濃い\nニオイも、鼻から突き抜けてくるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「も、もう堪忍してや……！　これ以上精子かけられたら、ニオイがとれへん\nようになる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　ほんま、どんだけ出すねん……ウチの顔、妊娠させる気\nかいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ううぅ……いろんなところに精子飛び散っとる……まるでカスタード……い\nや、生クリームやな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「なっ、なに人の顔見て、オチンチンビクビクさせとんねん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「精液まみれの顔がエロくて可愛い……？　そ、そないなこと言われても、反\n応に困るがな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「でも……エッチなんはともかく、アンタに可愛い言われるんは嬉しいわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「また時間があるときにしたるさかい……今日はこれぐらいで堪忍してや……\n」", "NORMAL" ]},
