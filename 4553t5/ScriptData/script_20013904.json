{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「っというわけで～♪　パイセン♪　おとなしくあーしらに精気……吸われて\nもらいまぁす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760001" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「ほら……力を抜いて。痛くなんかしないよ。気持ち良くするだけ……♪　あ\n～～～～ん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760001" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あやしい気配をぷんぷん撒き散らし、サキュバスと化したアヌビスとアーマー\nンが駆けてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とんでもない性欲モンスター達ですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「逃げろ逃げろ逃げろ！　多勢に無勢だ、かないっこないだろっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は後ろも振り返らず、全速力で逃げ出した……のだが、もちろん二人は後を\n追ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……もう諦めて、相手をしてさしあげるというのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022760002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「バッ、バカか！　あんなの相手したら枯れ果てて死ぬだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「追いかけっこ？　でも逃がさない……♪　早く入れてほしい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760002" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「たまには冥界の闇に、どっぷり溺れて浸かってみるのも一興ッスよぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760002" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あっという間に囲まれたぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "元から、戦闘能力に秀でた女傑たちなのだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は、必死で二人を避けたつもりが、行き先を……出入口をＡルナテミスとま\nりあに先回りされてしまっていた！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　やっぱりこっちに来てくれたぁ……。私とシたくてたまらないん\nですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022760001" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、ちがう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「最後は私を選んでくれると信じていたぞ。さあ、この胸の中に飛び込んでく\nるがいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これが絶体絶命ってやつか……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "逃げ道を失った俺が、次の手を考えているとサキュバス４人は何やら激しく言\nい争いはじめた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん。極上の精気……あなただけに独り占めさせるわけにはいき\nません。ここは私が美味しくいただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022760002" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ええいっ、邪魔をするな！　カツマとするのは私だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022760002" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「……パイセンに、最初に目をつけたのはあーしじゃないッスか？　ね、アヌ\nビス様。こっちがするのが先ですよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760003" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「うん。譲るつもりはない……退かないのなら、こちらにも考えがある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760003" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の肉体を奪い合う４人に、危機感を覚えたのだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジュンジローがハイハイ！　とばかりに割り込み、大きな声で注目を集めた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆様の真摯な気持ち、よぉぉっくわかりましたぞ！　それならば……ここは\n大岡裁きにいたしましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「オオオカサバキ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760004" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人の最も大事な部分を持って、それを引っ張り合うのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「冗談だろ……とんでもない提案をしてんじゃねえ！！　ジュンジロー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "怒りにまかせてジュンジローを捕まえようとしたものの、それより先に俺の股\n間がぎゅっと誰かに握られる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……これでいいのか？　んっ……大きくなってきたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このサイズなら全員で引っ張れそうですね。えいっ……！　こうでしょうか\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022760003" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うあああああ、本気でチンポを伸ばすやつがあるかぁあああ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「オオオカサバキが何かはわからないけど……大事なことなら、頑張る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760005" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ヤると決めた時はヤるッス！　えい！　えい！　こうッスか！？　こうッス\nかぁ！？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760004" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぎゃああああああああ！　ウッソだろ全員正気かぁああああああ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "悲鳴を上げる俺本体のことはスルーして、サキュバス４人は股間のモノに群が\nり、躊躇なくそれを引く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「もっと……もっと引っ張らないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760006" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あれれ？　なんか太くってうまく引っ張れないかもッス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760005" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「であれば根元を強く握って……こうだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「皆さん、下品ですよ！　……ここは私に任せてください。はぁ、はぁ、優し\nく……優しくしますからね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022760004" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……おかしいですな。大岡裁きなら痛がっているご主人を見かねて皆が手を\n離すはずですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022760005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今のこいつらにそんな理性あるわけないだろぉおおお！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "泣きわめく俺、男の大事な部分をオモチャにする４人の手。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぎゃあああああ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "争うサキュバスたちに、チンポを引かれ続けてどれくらい時間が経っただろう\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ありゃ？　いつのまにか……外が暗くなってるッス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760006" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「夜か。いや……もう深夜だな。職員たちも皆帰ってしまったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022760005" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「午前０時の鐘……ですね。そんなに長く争っていたなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022760005" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「午前０時！？　ってことは……アヌビス様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760007" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「うん……。ハロウィン……終わっちゃったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760007" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すると、アヌビスの詠唱はハロウィン当日限定だったのか……突如、全員が正\n気に戻った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ、あーしは今まで何を……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010022760008" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わ、私は皆さんを止めようと思ってしただけですから……！　本当です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010022760006" ]},
		{"command":[ "SETCHARA", "0", "char_00001404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今更もじもじ恥じらったって無駄だ！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマの大切なところ……。握ってしまった。すまない……どうしても譲り\nたくなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022760006" ]},
		{"command":[ "SETCHARA", "0", "char_00000124_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺にも心があることを、一度でいいから思い出してほしかった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「大丈夫？　ここ……腫れて辛くなったりしてない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760008" ]},
		{"command":[ "SETCHARA", "0", "char_00008104_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "心配そうに俺の股間に手を伸ばすアヌビスに、ゾクリと背筋が震えて飛びのい\nてしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「も、もう触らないでくれえ！　気持ちだけはもらっておくからっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「そう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010022760009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不思議そうに首をかしげるアヌビスから、今度こそ俺とジュンジローは脱兎の\nごとく逃げ出した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}