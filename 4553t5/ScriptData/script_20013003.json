{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、いたわっ！　おーーいっ、るーるなーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あら……マーガレットさんに、セレインさん……えっと、カツマさんまで。\nどうしたんですか、皆さんお揃いで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おう、実はさ、流々那に聞きたいことがあったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私に……？　はい、何でしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えっとね、流々那はバレンタインの武器のこと知ってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっ？　バレンタインの武器……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そう、バレンタインの武器！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320003" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっと……ごめんなさい、ちょっとどういうことなのか、よく分からないの\nですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そりゃそうだろうよ……違うだろ、聞くのはチョコのことだったろ？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あっ、そうだったわ！　ごめんなさい、武器じゃなくてチョコのこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320004" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうそう、チョコが武器になるって話なんだけどさ、知らないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「え、えっと……チョコが……武器、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからお前は、話をややこしくするな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「えー、だって、そういう話だっただろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「違うわ！　武器じゃなくて、バレンタインだろ！　バレンタインのチョコ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、流々那。つまりだな、こいつらにバレンタインが何をする日かっての\nを教えてやって欲しいんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……バレンタイン……ですか。その、何となく最近耳にすることはある\nのですが、実はよく存じ上げなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「思えば流々那どのは、異なる世界からいらしてるのですから、知らなくても\n不思議はないかも知れませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022320001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……ですが、ここ最近、街中の皆さんがよくお話しされているようなので\n、私もどういうことなのか気になっていたところです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320008" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「お話の流れから察するに、バレンタインのチョコがどういうものかと……そ\nういうことでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう！　それ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「それで、それを武器に用いると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そこは忘れて欲しい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「何でだよー、武器は欲しいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうよ！　武器は大事よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、こいつら……わざとややこしくしようとしてるのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「よく分かりませんが、何か私にもお手伝い出来ることがあるのでしょうか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320011" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おっ、なら流々那も手伝ってくれるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうね、人手はいくらあっても嬉しいわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320006" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、私の力が必要ならぜひ、ご協力させていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320012" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「やったわ！　さて、そうと決まればまずは……そうね、チョコを手に入れる\nところから始めましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「手っ取り早くチョコを手に入れるなら、確か購買部に売ってたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なるほど、購買部ね！　なら、さっそく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320008" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうだな、さっそく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320007" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「……じー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320008" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「……じー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320009" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんだよ、なんで２人揃ってこっちを見るんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「だって、私、金持ってないしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320009" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「奇遇ね、私も持ってないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320010" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、だからって、なんだって俺を見るんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320010" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022320011" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、そんな目で見てもダメだ。金は出さないからな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぬぅ……こいつ、思ったよりガードが硬いぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320012" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうですよ……とても楽しそうなお話ではありますけど、こういう形でカツ\nマさんに頼ってしまうなんて申し訳ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320014" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ……流々那……いや、別にお前が謝ることじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「バレンタインの催し……とても楽しそうだとは思いますが、カツマさんに負\n担を掛けてまですることでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う……ぐ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「お力になれず残念です……せっかくのお誘いですが、今回は……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "5", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ！　分かったよっ、今回だけだっ、持っていけっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「えっ……ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022320017" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな顔されたら、どうにもなんねぇだろ。気にしないで買ってこい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぶーぶーっ、なんか私達の時と態度が全然違うぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022320016" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何で同じになると思ってんだよ！　せめて、セクシーがどういう意味か調べ\nてから言いやがれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ、何とも賑々しい限りですな、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022320003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……でも、ま……いいさ。悲しい顔されるよりは……楽しそうな方\nが、な」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}