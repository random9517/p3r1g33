{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "001_0203101" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さて、下僕よ。今、貴様がなぜこのようなことになっているか、もちろん分\nかっているだろうな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_02" ]},
		{"command":[ "PLAYVOICE", "001_0203102" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何を不思議そうな顔をしている！　この戯けめ！　これは貴様へのお仕置き\nだ！　近頃の貴様の増上慢ぶりはさすがに目に余るぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203103" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「肩書をカサに来て、私達が逆らえないのを良いことに、あちこち好き勝手に\n呼びつけたり、かと思えばそのまま放置をしたり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203104" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「部隊の金を私的に使いこんで、プレゼントと称して女達への貢物にするなど\n……言語道断！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203105" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イヤらしい道具をこれ見よがしに見せ付けて、あまつさえ、その道具を使っ\nて、あんなことやこんなことまで……ハ、ハレンチな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_01" ]},
		{"command":[ "PLAYVOICE", "001_0203106" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よって私が皆を代表して、貴様にお仕置きをしてやろうというのだ！　どう\nだ、何か申し開きはあるか？　言いたいことがあれば、聞いてやろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_02" ]},
		{"command":[ "PLAYVOICE", "001_0203107" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……きぃさぁまぁっ！　何を偉そうに、開き直ったような顔をしている、こ\nの痴れ者め！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203108" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたい貴様！　私の下僕のくせに、他の女どもにまでイヤらしい目を向け\nるとは、一体、どういうことだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203109" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、もうガマンならん！　今日という今日は、徹底的に貴様をお仕置き\nしてやる！　泣いても喚いてもやめてやらんからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203110" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「誰が貴様のご主人様なのか、その身体にイヤというほど教えこんでやる！　\n覚悟するがいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_01" ]},
		{"command":[ "PLAYVOICE", "001_0203111" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そら、そら、お前のココを足でぐりぐりと踏み潰してやろう。男の大事なも\nのを足蹴にされる気分はどうだ？　苦しいか？　悔しいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203112" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「年下の女に見下されながら、アソコを踏みにじられる屈辱を存分に味わうが\nいい。そら、もっと踏んでやろう。ほ～れ、ぐ～りぐ～り……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203113" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「足の下がぶにゅっとして気持ち悪いな……男というのはどうしてこう、どこ\nもかしこも醜悪なのか……いっそのこと、本当に踏み潰してしまうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203114" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたい、こんなモノがあるからいかんのだ……二度と使えないようにして\nしまえば、コイツももう他の女に手は出せまい……よし、潰すか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_02" ]},
		{"command":[ "PLAYVOICE", "001_0203115" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そら、どんどん痛くなっていくぞ……貴様の粗末なものが潰れて、二度と使\nいものにならなくなるぞ、いいのか？　そら、そらっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203116" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ、その情けない顔は……くぅっ、潤んだ瞳で見上げるな、醜い！　息\nもするな！　貴様と同じ空気を吸っていると思うだけで虫唾が走るわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203117" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたいなぜココをこんなに固くしている！　足の下でお前のモノがビクビ\nクと震えているぞ！　もしや貴様、コレを踏み潰されて感じているのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203118" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「年下の女に罵られ、蔑まれ、足蹴にされて感じるなど、はぁ、はぁ、貴様が\nそこまでの変態とは思わなかった。見損なったぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203119" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、チンポを震わせて返事をするな、気色の悪いブタめ！　そうだ貴様\nはブタだ！　醜いブタめ！　こうなればもう、手加減などしてやらんぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203120" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の全体重をかけて、貴様のチンポを踏み潰してやる。本当に潰れてしまっ\nても知らんからな……はぁ、はぁ、もっともっと、苦しめ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_01" ]},
		{"command":[ "PLAYVOICE", "001_0203121" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……どうだ、痛いだろう？　苦しいだろう？　泣いてもいいんだ\nぞ？　喚き散らして、許しを請うてみたらどうだ？　ええ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_02" ]},
		{"command":[ "PLAYVOICE", "001_0203122" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ、これでもまだ気持ちいいのか？　痛くされて感じるなど、気持ちの悪\nいヤツめ……ふぅ、ふぅ、私は今、心の底から貴様を軽蔑しているぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203123" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の足で、貴様の節操なしのチンポを去勢して、女に生まれ変わらせてやる\n？　どうだ嬉しいか？　嬉しいならワンと泣いてみろ、この駄犬めっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203124" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、んんっ……気持ちの悪い顔を向けるな、吐き気がするわ！　物\n欲しそうな目をしおって……なんだ、もっとチンポを痛くして欲しいのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203125" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「汚らしいマゾブタめ！　ふぅっ、ふぅっ……いいだろう、ならば力いっぱい\n、貴様のチンポを蹴り飛ばしてやる！　いくぞ、いい声で鳴け……そらっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203126" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……！　情けない声で鳴きおって、チンポを蹴られて感じたのか、こ\nの浅ましいブタめ！　もっとだ、もっと無様に泣き喚け、そらぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203127" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ……！　くぅっ、浅ましいオスブタめ、はぁ、はぁ、チンポがパン\nパンに腫れ上がって、今にも破裂しそうにビクビクと震えているじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203128" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私にチンポを蹴られて、イってしまいそうなのか？　気持ちの悪い奴め……\nんふぅぅっ……いいだろう、そらっ、イけ、イくがいい……！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203129" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「チンポを足蹴にされて射精するなど、犬にも劣る畜生め！　貴様はもはや人\n間ではない、醜悪でおぞましい、ただのブタだ、汚らしいオスブタだっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203130" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そらっ、そらっ、イけ、イってしまえ！　年下の女にチンポを蹴り飛ばされ\nて、無様に射精しろ！　そらっ、そらっ！　イけ、イけっ、イけっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0203131" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うひゃあっ！？　足の裏に、熱いのがっ……！　くひぅっ、いっぱいかかっ\nてるっ……！？　ふぁっ、どぷ、どぷって……んふぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_04" ]},
		{"command":[ "PLAYVOICE", "001_0203132" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あ、あぁっ……ドロドロの精液が、飛び散って……ふぅぅっ、私の\n足を、汚している……ふぁぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_05" ]},
		{"command":[ "PLAYVOICE", "001_0203133" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ、このぉ……気持ちよさそうな顔をしおって……！　どれだけ射精する\n気だ！？　女にチンポを踏みつけられるのが、そんなにいいのか、変態め！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203134" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ならば、そら、そらっ！　チンポを蹴られながら、射精しろ！　口の緩んだ\n水風船みたいに、チンポを踏まれてみっともなく精液を吐き散らすがいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203135" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふひゃあっ！？　また、こんなにっ！？　くっ、このっ、このぉっ！　出せ\n、全部出せっ！　金玉が空っぽになるくらい、精液を出し尽くせ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_04" ]},
		{"command":[ "PLAYVOICE", "001_0203136" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ようやく、おさまったか……？　まったく、どれだけ出せば\n気が済むんだ……ふぅぅっ、汚らしい、ブタチンポめ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203137" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「犬のしっぽみたいにチンポを振り回しながら、ふぅ、ふぅ……くぁっ、こん\nな、溶けたチーズみたいにこってりとした、精液を撒き散らしおって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203138" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぁっ、こんなところにまでべったりと……くふぅぅっ、オスくさい精液の\n臭いが、ここまで立ち上ってきて……んっ、んんっ！　……ふぅ、ふぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203139" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見ろ……貴様の汚らしい精液で、私の足がこんなにも汚れてしまったぞ……\n？　そうだな、責任を取って……舐めてキレイにしてもらおうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_05" ]},
		{"command":[ "PLAYVOICE", "001_0203140" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ、はぁ、はぁっ……どうだ、自分の精液の味は美味いか……？　ごちそう\nさまでした、と言ってみろ……そら、言え……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203201" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふんっ、ずいぶんといい面になったじゃないか……ええ？　ついでだ、その\n醜い顔にも、貴様の精液を塗りたくってやろう、そぉら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203202" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅっ……んんっ、どうだ、今までの行いをきちんと反省したか？　\n……よし、それでは、今日のところはこれくらいにしておいてやろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203203" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……などと言うとでも思ったか？　愚か者めっ。今日のお仕置きはこんなも\nのでは済まさないぞ！　またチンポを踏んでやるっ！　そら、そらっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203204" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イったばかりのビンカンチンポを足の裏で踏み潰されるのはどうだ？　はぁ\n、はぁっ、精液がヌルヌルして、たまらないのだろう？　もっとしてやる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203205" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ、いいぞ……んんっ！　もっと貴様の、苦しげで、無様な顔を、私に\n見せてみろ……っ！　そらっ、そらっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203206" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今日という今日は、誰が貴様のご主人様なのか、イヤというほど分からせて\nやるからなっ……！　どうだ痛いか、反省しろ、このだらしないチンポめ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203207" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「覚えの悪い無節操な下僕チンポには、このくらいでちょうど良いんだ！　え\nいっ、えいっ！　どうだ？　はぁっ、はぁっ……反省したかっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203208" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これに懲りたら、もう二度と悪さをしないと誓え！　肩書を利用して女を呼\nびつけたり、イヤらしい道具を使ってハレンチなことをしないと、誓え！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203209" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そして、私をほったらかしにしたまま他の女のところへ行ったり、他の女と\nイヤらしいことをしないと、そう誓うんだ！　そら、言え、言わぬか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203210" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、強情な奴め！　この私の下僕……いや、奴隷の分際で！　ならばも\nっと、このだらしないオスブタチンポを痛めつけてやるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_04" ]},
		{"command":[ "PLAYVOICE", "001_0203211" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そら……ココはどうだ？　む、思ったよりコリコリしているのだな……ふぅ\n、ふぅ、踏みつけたら簡単に潰れてしまいそうだぞ……どうだ、怖いか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203212" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ココが潰れてしまったら、もう二度と男として使い物にならなくなるからな\n……そら、そら……貴様のチンポを、ただの排泄器官にしてやろうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203213" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、いいぞ、その顔だ……んんっ、貴様の玉を足の指で挟んでやる……こ\nのまま力を込めたら、ナッツのように簡単に潰れてしまうだろうなあ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_05" ]},
		{"command":[ "PLAYVOICE", "001_0203214" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、イイっ……またチンポがふくらんできたぞ……んんっ、こんなの\nでイってしまいそうなのか……見下げ果てたヘンタイめ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203215" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、ダメだ……ふぅ、ふぅっ……私の命令があるまで勝手に果てることは\n許さん……！　いいか、漏らすなよ？　ご主人さまの命令だからな……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203216" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そら、そらっ……どうだ、イきたいのにイけないのは苦しいか？　んふぅっ\n、イきたくば、浅ましくおねだりをしてみろ。いいか、こう言うのだぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203217" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ボクはご主人さまにチンポを足蹴にされて精液を漏らす醜いオスブタ奴隷で\nす。どうかこの汚らしい奴隷チンポを蹴飛ばして無様に射精させて下さい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203218" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ、ほら、言ってみろ。言え、言うんだ！　ふぅ、ふぅっ…………んふ\nぅぅっ、よし、お待ちかねのチンポ蹴りだ……存分に味わえ、そらっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203219" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そらっ、そらっ、どうだ、気持ちいいか？　気持ちいいと言え！　ふぅっ、\nふぅっ、好きなだけ私が、お前の奴隷チンポを、蹴り飛ばしてやるからなっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203220" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「イく時はイくと言うんだぞ！　そらっ！　女にチンポを蹴飛ばされて、みっ\nともなく果てるがいい！　無様に精液を撒き散らせ、射精しろ、イけっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0203301" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぁああっ！？　あっ、あぁっ……！　足に、精液が、また……くふぅっ…\n…！　んあぁっ……！　ダメ、私も、イっ……くぅっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203302" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅぅっ……！　はぁっ、はぁっ……、ふぁっ、あっ、あっ……また、いっ\nぱい……んんっ、熱くてドロドロの精液が、私の足にたっぷり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_11" ]},
		{"command":[ "PLAYVOICE", "001_0203303" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……んふぅっ、ふぅぅっ……そんなに私の足が気持ちいいのか…\n…？　愚かな下僕め……！　ならば、そら、もっと踏んでやる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203304" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぁっ！？　また、いっぱい……身体の方にまで……！　ふぅぅっ、そら\nっ、そらっ……！　もっと無様に、みっともなく、精液を吐き散らせ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000102_01_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0203305" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、熱い……！　んふぅぅっ、いいぞ……そら、そらっ……私の\n足でチンポを踏まれて、んんっ……心ゆくまで、射精しろっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_10" ]},
		{"command":[ "PLAYVOICE", "001_0203306" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅっ……どうやら、落ち着いたようだな……んんっ、まったく……\n見ろ、これを……こんなところまで、貴様の精液でベタベタだぞ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203307" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「満足そうな顔をしおって……私の足で踏まれるのが、そんなに良かったのか\n？　こんなにも射精するなど……ふふ、可愛い奴め……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_11" ]},
		{"command":[ "PLAYVOICE", "001_0203308" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……さて。では、続きといこうか。ん？　何を驚いた顔をしている。当然だ\nろう、これはお仕置きなのだからな。まだまだこんなものでは済まさぬぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203309" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様が泣いて喚いて、鼻水を垂らしながら、ボクは貴方様の従順な下僕です\n、奴隷です、許して下さいご主人様！　と懇願したとて、止めてはやらん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203310" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「声を枯らして泣き叫んで、心の底から私に服従を誓うまで、ひたすらこのオ\nスブタチンポをいじめヌいてやるからな……んっ、ふぅっ……楽しみだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
