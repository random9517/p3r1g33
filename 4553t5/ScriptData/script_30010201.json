        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0203401" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「きゃあっ！？　ぷあっ、なあっ、わぶっ……！　まさか、精液がこんなとこ\nろにまで……んぷあっ！　こらっ、やめろっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203402" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぶあっ！　貴様っ、わざと私の顔にっ……あぷっ！　くぅぅっ、この、や\nめろっ、やめないかっ……ぷあぁっ！　んぶぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203403" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅぅっ、オス臭い精液が、私の顔にかかって……んんっ、くっ、ダメだっ\n、私もっ……んっ、んんぅぅっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203404" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「っ、ふぅ、ふぅっ……くっ、このぉっ……！　いいかげんにしろっ！　ナマ\nイキなブタチンポめっ、そらっ、そらっ、こうしてやるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203405" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「射精できなくなるまで、何度でも踏みつけてやるっ！　さっさとその金玉か\nら精子を出し切って、空にしてしまえっ！　このっ、このぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_07" ]},
		{"command":[ "PLAYVOICE", "001_0203406" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅっ……ふぅぅっ、やっと止まったか……くっ、まったく、とんで\nもないダメチンポめ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203407" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなに精液を撒き散らしおって……！　くあぁっ……顔中が貴様の臭くて\n汚らしい精子で、ベタベタではないか……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203408" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それに、よもやこの私が……ふぅ、ふうっ、貴様の精液を顔に浴びせられて\n、そのままイってしまうとはな……とんでもない屈辱だったぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "still_00000102_01_08" ]},
		{"command":[ "PLAYVOICE", "001_0203409" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何か、申し開きはあるか……？　……そうか。ではさっそく、続きと行こう\nか……今日は貴様が泣いて喚いても、止めてはやらんからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0203410" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そのチンポと金玉が真っ赤に腫れ上がって、雀の涙ほどの精液もでなくなる\nまで、徹底的にいたぶってやるからな……覚悟しろ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
