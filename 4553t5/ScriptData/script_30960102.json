		{"command":[ "SETIMAGE", "0", "still_00009601_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104302" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、すごい！　二回目なのに、さっきとおんなじぐらい……んっ！\n？　んんんっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104303" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あれ！？　僕のも、なんかピクピク動いて……隊長さんのを搾り取って\nる……すごい……！　僕の、すごい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104304" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああ……ふぁああ……隊長さん、気持ちいい？　そっか……よ\nかった。僕も気持ちよかったよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104305" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はああ……そっか。これが中出し……気持ちいいもんだねえ……気に入った\nよ。あ、でも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104306" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ？　隊長さん？　二回も中に出しちゃうとさ、やっぱり僕、妊娠し\nちゃうかもしれないよ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104307" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうかな？　できてないのかな？　うーん、そのへんどうなんだろ。あ！　\nそういえば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104308" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あのね、ウサギはね、とっても多産なんだって。だから、男の人と付き合う\n時には気をつけろって。先生に言われてたの、今思い出したよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104309" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えへへへ……できちゃっててもいいよね？　隊長さん、僕と一緒に子どもた\nちを育ててくれるもんね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104310" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そうなると僕の妹たちは、隊長さんにとっても妹だね！　隊長さん、妹たち\nもよろしくね？　へへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "096_0104401" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え！？　抜いちゃうの！？　それって、どういう……ふぁあああん！　あ、\nああああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104402" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「わ、わわわわっ！　かかってるぅ！　隊長さんの熱いのが……僕の顔に……\n胸に……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104403" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んあっ！　あ、あ、ああ……まだ出て……ふあぁあああ……！　すごい臭い\n……！　おまけにべとべと……んああああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104404" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「も、もう……隊長さん……！　なんでこんなことするの……？　おかげで僕\n、全身ベトベトじゃない……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104405" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え……？　僕はまだ修行中の身だから？　それとどういう関係が？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104406" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ！　そ、そっか！　ウサギは多産だから、妊娠しやすいかも知れないって\n……そういえば、先生にもそう教わった！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104407" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そっか。修業中の身で、子供を持つのはまだ早い、ってことか……さすが隊\n長さん。ちゃんと考えてたんだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104408" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でも、僕、隊長さんとだったら、家族になって子供たちを育ててみたいなあ\n……なんて。はははは……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104409" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「う、ううん！　何でもない！　気にしないで！　ひとりごとっ！　そう！　\nなんでもナッシン！」", "NORMAL" ]},
