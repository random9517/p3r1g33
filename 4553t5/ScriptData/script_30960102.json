		{"command":[ "PLAYVOICE", "096_0104410" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ、隊長さん？　こういう修行に、また付き合ってほしいな……いい\nでしょ？　えへへへっ」", "NORMAL" ]},
