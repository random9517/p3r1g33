		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああああああ～っ！　イエス！　オーイェッ！　出てる！\n　出てるよぉっ！　ふあああん！」", "NORMAL" ]},
