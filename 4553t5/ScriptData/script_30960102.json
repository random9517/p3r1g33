{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "PLAYVOICE", "096_0104101" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あの……さ？　隊長さん？　僕がここに呼び出されてさ、こんな風に、胸丸\n出しで、ベッドに寝かされてるって……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104102" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「つまり、そういうことなんだよね？　そういう理由で、隊長さん、僕を呼び\n出したんだよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104103" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だよねえ？　隊長さんのそれ、すっかり準備オーケー！　スタンバイ！　っ\nて感じだし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104104" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「う、ううん！　別に。その……嫌、ってことはないよ。なんていうか、その\n、興味は、あったしさ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104105" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それに、団長さんだったら……えと、その……嬉しいし。えへへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104106" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うわっ！　なに！？　今、隊長さんのがピクンって跳ね上がって！　え？\n　興奮した？　早く、僕の中に入りたい……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104107" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫かな……！？　そ、そんな大きいの。いきなり入れて、僕、壊れ\nちゃったりしないかな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104108" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　大丈夫？　もうこんなに濡れてるって――ひゃぁんっ！　い、いきな\n　り、そんなとこ触らないでえ！　んんん！　んっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104109" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああ……ほ、ホントだ。隊長さんの指、僕のアソコにちょっと触\nっただけなのに、そんなに濡れて、糸を引いて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104110" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「……うん。僕、興奮してた。ここに横になって、隊長さんのギンギンに大き\nくなったそれを見てるだけで……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104111" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「わ、わかった……！　僕もニンジャだ！　覚悟を決めたよ！　隊長さんのそ\n　れ……僕の中に――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104112" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ひゃうううん！？　は、入ったぁ！？　ん、んんんんっ！　あ、あ、あああ\n　っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104113" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、ああああっ！　すごい……！　僕の中、隊長さんのでいっぱいになっち\nゃって……キ、キツいよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104114" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「キ、キツいけど……大丈夫。そんなに痛くない……動いて、大丈夫だと思う\n……で、でも、ゆっくり……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104115" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、んんっ……んっ……はぁっ……そう……ゆっくりお願い……あ、あ\nああっ……んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104116" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あっ……はぁああん……あんっ！　んっ……隊長さんのが、\n僕の中で、こすれてる……んんんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104117" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あああっ！　はっ！　くぅううっ……んんんっ！　　た、隊長\nさん、ぼ、僕、なんだか変な感じ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104118" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「なんだか、頭がぼーっとしてきちゃって……僕の中にある、それのことしか\n、考えられなくなってきちゃって……んんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104119" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああ！　こ、これ、すごい！　セックスって、こんな感じなん\nだ……あああああっ！　あんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104120" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ、隊長さん？　もっと、大きく動いても大丈夫だよ？　僕、なんだ\nか慣れてきた……えへへへへっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104121" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オーケー！　レッツゴー！　あ、あ、あ、おおおおおおっ！　き、きたっ！\n　隊長さんのが、グイグイって！　はああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104122" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああああん！　あんっ！　はんっ！　ゴリゴリの硬いのが、中で暴れて……\nはあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104123" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「う、うん！　大丈夫っ！　キツくない――んんんんっ！　やっぱキツい！　\nでも、それがいいっ！　んんんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104124" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふあ、あ、あ、あ、ああんっ！　ひっ！　い、今、奥の方にこつんって……\nふあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104125" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ？　隊長さん！？　隊長さんも、気持ちいいの！？　だ、だって、\n隊長さんのが、中で……あああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104126" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんの、中でどんどん硬くなってるよぉ！　オー！　イッツハード！　\nふぁああん！　あああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104127" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああん！　すごいよぉ！　隊長さん、すごいよお！　これ、気\n持ちいいよお！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104128" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「イエス！　オー、イエッ！　僕、感じちゃってるよぉ！　ぼ、僕、大丈夫な\nの！？　こんなに感じちゃって……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104129" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ？　隊長さん！？　もっと、もっと突いてぇ！　もっと、勢いよく\n……はああああん！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104130" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ、くるっ！　隊長さんのが、ガンガン攻め込んでくる！\n　オーマイスシ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104131" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ど、どうしたの……？　隊長さん？　も、もうイキそう……？　イクってつ\nまり、出すんだよね？　精液……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104132" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オ。オーケー！　隊長さん、イッちゃって！　僕。隊長さんのイクとこを見\nてみたい！　っていうか、体感したいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104133" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、ああああっ！　そうっ！　ガンガン来て！　僕、大丈夫だから！　だか\nら……隊長さんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104134" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！　ふぁあああああっ！　隊長さん！　イッて！　僕の中で\nイザ！　いざカマクラぁあああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104135" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ！　あ、あ、あああああっ！　で、出てるっ！　僕の中で、隊長さんのが\n！　ビュルルって！　あ、ああああーっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104136" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、まだ出てる……まだ……びゅくっ、びゅくっ、て……ふぁああ\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104137" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「すごいよ、隊長さん、こんなにいっぱい出るなんて……！　まるで精液タン\nクみたい……ふああああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104138" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はぁああ……す、すごかった……これがセックス……これが中出し……噂に\nは聞いてたけど、すごいものだった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104139" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ふああああ……すごい。僕の中、隊長さんのでいっぱいになっちゃった……\nアンビリーバボー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104140" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ね、隊長さん。ぎゅってしてくれる？　ぎゅって……だってウサギはさ、寂\nしくなると死んじゃうから。えへへへへ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104201" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あれ……？　隊長さん！？　どしたの？　なんか、隊長さんのそこ……\n、またおっきくなってるけど！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104202" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え！？　また興奮してきた！？　僕があまりにエッチでかわいいから……？\n　そ、そうかな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104203" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「もう一回？　もう一回、これを入れるってこと？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104204" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オーケー！　大丈夫！　一度やって、感覚はつかめたから、次はもっと上手\nにできると思う！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104205" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「団長さんのラビットパワー、もう一度僕に見せてよ！　オーケー、レッツゴ\nー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104206" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んあああああっ！　いきなりっ！　あっ、あっ、ああああっ！　す、すごい\nっ……！　いきなりパワー全開……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104207" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああああんっ！　なんかいいっ！　さっきより気持ちいいっ！　慣\nれてきたから？　それとも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104208" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああっ！　そ、そっか！　僕の中、ヌルヌルしてるんだ！　さっき\n、隊長さんが出したのがまだ……あああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104209" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああん！　あんっ！　あ、あれ！？　あんっ！　なんか、\n腰が変……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104210" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あん！　あんっ！　あああんっ！　腰が！　腰が勝手に動いちゃうよぉ！　\nふああああん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104211" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「感じてるから？　気持ちいいから？　だから腰がひくひく反応しちゃうの？\n　ああああん！　そ、そっかぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104212" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「イエス！　イエス！　イエスッ！　僕の腰が、隊長さんのアレを迎えに行っ\nちゃうっ！　はあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104213" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「気持ちいいんだもん！　もっと、もっと突いてほしいんだもん！　だから…\n…はぁあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104214" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「はっ、はっ、はあああああ……んっ！　あっ！　あああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104215" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さん、気持ちいい！？　気持ちいいの！？　イェイッ！　僕も気持ちい\nいっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104216" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ああんっ！　あっ！　アレが！　隊長さんのアレが！　元気に奥までこんに\nちはしてるっ！　はああああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104217" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んああああん！　グッド！　隊長さんのあそこ、やっぱり硬くて熱くてコリ\nコリしてて……ベリーグッドだよぉ！　ふあああん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104218" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あ、あん！　はああんっ！　あん！　んんんんっ！？　あああん\n！　硬いのが暴れてるぅ！　これ気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104219" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「た、隊長さん？　どしたの？　急に……動きが早くなって、あ、あ、あ、あ\nあああああっ！　気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "096_0104220" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え！？　出ちゃうの？　また出ちゃうの！？　オーケー！　ヒアウィーゴー\n！　アンド、カミング！　アイムカミーングッ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
