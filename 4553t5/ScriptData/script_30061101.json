		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「いらっしゃーい。んふふっ、待ってたわぁん。ほらほら、こっち来て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103101" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ずっと、楽しみたかったんだものぉ。今日は時間もたっぷりあるしぃ……思\nいっきり、いいコトしちゃいましょぉー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ほらほら、どんなプレイがしたいのかしらぁ？　今日のダイヤナちゃんはテ\nンション高いしぃ……結構お好みのことさせてあげちゃうかもよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「思いっきりイジメてあげるのもいいしぃ？　ダイヤナちゃんのこと……気持\nちよくしてくれてもいいけどぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んー？　ふふーん、やっぱりおっぱいがいいんだぁ。ダイヤナちゃんの、お\nっぱい……触りたいのねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あんっ……！　んんっ、いきなり……思いっきり来るじゃない……その図々\nしさ……嫌いじゃないかもねぇ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000611_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「でも……手で掴みきれない位、おっきいでしょぉ？　んふふ……ダイヤナち\nゃんのこと……ちゃんと気持ちよく出来るかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んんっ……！　んふっ、狙うところは……決まってる？　どういう意味かし\nら……んっ、あっ、んくっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ……いきなり、乳首……掴んで来るのねぇ……？　あふっ、ん\nんっ……ホントに、遠慮なしの図々しさねぇんっ……あっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぅっ！　あっ、しかもっ……んくっ、そんな……ぎゅってっ……強くっ…\n…あっ、ひぁっ、んくっ、あっ……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ちょっ……いくら何でも……引っ張りすぎっ……いっ、痛いでしょっ……あ\nくっ、んんんんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「やっ、な、なんで……あっ、爪が……ぐって食い込んで……ひぅっ、あっ、\n何……これっ、あっ、ウソ……強いのにっ……くっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「なっ……ダイヤナちゃんが……Ｍっぽいって……何、適当なこと言って……\nひぃっ！　乳首っ……それっ、あくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あぁっ、やだ……コリコリさせないでっ、おっきくなって\nるのっ……感じやすくなってるからっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「待って……落ち着いてからっ、なのっ、にっ……あぁっ、またっ、激しくぅ\nっ、あひっ、あっ、あぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「やっ、同時にっ……そんなにされたらっ、ひっ……あぁっ、ダイヤナちゃん\nっ、もうっ！　すぐイッちゃっ、イッちゃうっ……んんんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、あっ、ふっ……ウソ……あっという間にイッちゃった…\n…何よこれ……めちゃくちゃ強かったのに……気持ちよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「わたし……イジメられる方がいいなんて……そんなこと……うぁっ……オ、\nオチンチン……すごいことになってる……ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ここからが……本番……どうするの……？　あっ、んんっ……！　オチンチ\nン……おっぱいの中にっ……はっ、うんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんに……パ、パイズリさせるのね……？　んくっ……い、いい\nわ……すればいいんでしょ？　んっ、こ、こういう……感じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ぜ、全然物足りないって……何を調子に乗って……んぁっ！？　あっ、あく\nぅっ……ち、乳首……ひぁんっ、だ、ダメェっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「わ、分かったからっ、ちゃんとオチンチンっ……よくするからっ……待って\n……んっ、乳首……つ、強くしすぎないでぇっ……あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、あふっ……んふっ……こ、これ位……ならっ、どうっ……？\n　あっ、んくっ、はふっ……あぁっ……く……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「何これ……あぁっ、オチンチン……ギチギチに反り返ってる……ダイヤナち\nゃんのおっぱいの中で……すごく暴れたがってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぁっ……これを……ぎゅって挟めばいいのね？　んんっ、あふっ、んくぅ\nっ……あぁっ、うあっ、ぐちゃぐちゃにっ……なってるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　ひぁっ、乳首……まだ……そんなにっ、あっ、ひぃっ\n！　弄りながらっ……なんてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「オチンチンが擦れてっ……あぁっ、乳首……コリコリされてっ！　何これっ\n、いいのっ……ひぁぁんっ、おっぱいすごく気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、腰……振ってるのっ？　ひゃふっ……んくぅっ、あぁっ、ダイヤ\nナちゃんのおっぱいっ……犯してるのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あぁっ、ダメっ……直接……乳首っ……擦るの反則だからぁっ\n！　いっぱいするっ、いっぱい擦るからっ、ま、待ってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「くぅっ、んっ、はぁっ、これでっ、いいっ？　んっ、するわよぉっ、ちゃん\nと……おっぱいズリズリしてるっ、オチンチンパイズリしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んくっ……はあうっ……あぁっ、オチンチンっ……いいのっ\n？　ズリズリしてっ、そろそろイキそうなのねぇっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいのっ……もう何でもいいからぁっ！　出したいならっ、出して\nっ……！　オチンチンいっぱいドピュドピュしてぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「きぁぁぁぁぁぁぁんっ！　んぁっ、か、顔にっ……掛けてるっ！　精液っ…\n…いっぱい出されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ……こんなっ、思いっきりぶっ掛けるなんてっ……んはぁっ……\nんぷっ……ちゅぷっ……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ、はぁぁ……んっ……あぁ……ドロっとしてる……生臭いの、\nベトベトにぃ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「オチンチン……あぁ……いっぱい出された……はぁ、はぁ……あぁ……おっ\nぱいの谷間も……ドロドロになっちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んく……ダイヤナちゃんに……こんなことするなんてぇ……あなた……結構\n……ヤバいのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「まだ……ここまでは本気じゃない……？　どういう……あっ……な、何……\n？　またオチンチン膨らんで……こ、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「咥える……フェ、フェラしろって言うのっ？　今、出したばっかりじゃない\nっ……あっ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「わ、分かったわよぉっ、分かったからっ、乳首っ……ぐりぐりしないでっ、\n感じやすいからっ、弱くなってるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぶっ、ふぐっ……んふぅぅっ、くぽっ、むぐっ……んじゅっ、りゅぷっ、\nむぐ……んふぅっ……ふっ、んぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぁ……ザーメンの味が……残って……んりゅっ、むぐぅっ……ドロドロに\nなっへる……ちゅぱ……んりゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ちゃんと……唇で扱けって……わ、分かったわよぉっ……こ、こう……らろ\nっ？　んじゅぽっ、あぶっ、んじゅっ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「それで……お、おっぱいも……動かす……注文が……んっ、多いのよっ……\nこ、これでっ、んっ、ろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……オチンチン……じゅぷっ、めちゃくちゃ……膨らんでる……\nおっぱいの中で……暴れまわってるじゃないのぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「きゃぅんっ！　あっ、んぁっ、ち、乳首ぃっ……また、ゴリゴリってっ……\nひぁっ、擦れるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ！　あぁっ、やぁんっ、気持ちいいっ……おぐっ……オチンチン\nっ、擦れると……おっぱいっ、ムズムズするぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、こんなっ、乱暴に乳首……されてるのにぃっ！　んぁぁっ\n、ぐいって引っ張られてっ……伸びちゃいそうなのにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んふぅっ……きもひぃぃっ！　おっぱいっ……メチャメチャにさ\nれるのがっ、ダイヤナちゃんっ、ひゅごくいいのぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁんっ、もっと動かしてぇっ、りゅぷっ、オチンチンっ……吸うからぁっ\n、んじゅぅぅぅっ、ふぐっ、じゅるるっ、んじゅっ、ずずぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「おぷっ、んぶぅっ……オチンチンの味ぃ……また濃くなっへるっ、んんっ、\nお汁……新しいの滲んで来てるっ……んりゅぷっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「もっと……頬を窪めろっ？　むふぅっ、もうっ、これ以上はっ……ふぐぅっ\n……ダイヤナちゃんの顔っ……やらしくなっひゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
