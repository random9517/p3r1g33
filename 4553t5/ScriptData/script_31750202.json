{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、パパ……すっごく興奮してる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だよねぇ……じゃなきゃ、こんな外なのに……そんなにチンポビンビンにさ\nせて、ヤムのお尻撫でたりしないよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「別にヤムは何もしてないよ？　ちょーっと、むらむらーっとする気分になる\n『ふぇろもん』みたいなものを出しただけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「パパの理性がちゃんとしてるんだったらぁ……これ位の誘惑……どぉってこ\nとないよねぇ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なーんて……もう、オチンポお股に挟んじゃったし、ここでやめられるワケ\nないよねぇ……だってパパだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、どうするの……？　したいんでしょ、ヤムのちっちゃいオマンコ使っ\nて……ズボズボってして、チンポ気持ちよくなりたいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いいよ、ヤムは。どうしてもーってお願いするなら、させてあげてもいいん\nだけどなー、どうしよっかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ……んふふっ、服も……脱がされちゃってるし……もう歯止めなんて\n全然効かないって感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあ、聞かせてよ。ヤムにお・ね・だ・り。ロリオマンコにチンポ入れさ\nせて下さいーって、お願いしてみせて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あははっ、やっぱり言っちゃうんだー。ほーんと、ヤリたいに正直なんだか\nら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、いーよ。もうすぐそこにあるんだから、入れちゃお？　ビンビンの勃\n起チンポ……ヤムのオマンコに入れなさいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁっ……あふんっ！　んっ、あぁぁぁ……来たぁ……入ってっ\n、んっ、チンポ……来たぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっふ……この姿だと……パパのチンポ、結構大きくて……あふっ、いい感\nじぃ……んくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふぅ……んっ、ね、ヌルヌルしてるでしょ……ヤムのオマンコ……ずっと\nいい感じに待ってたんだからぁ……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もう入れちゃった以上、取り返しはつかないから……ヤムと共犯で、いっぱ\nい気持ちいいコトしなきゃ……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、そぉっ、まずは……ゆっくりぃ……あんっ、中をかき回す\nトコからぁ……あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、ホントは……ちっちゃい子なら……キツキツのオマンコの方\nがいいんでしょ……？　それでイジメたいんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「違うの？　気持ちいいなら何でもいいって感じ？　んっ、それなら……まぁ\n、ヤムでも大丈夫ってコトね……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まだまだヤムのちっちゃオマンコキツくなるのに、そんな必死な顔して大丈\n夫ぅ？　こうして、んふっ……！　きゅんって……ほらぁ……あ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ねっ、ちゃんと……オチンポ……ギュウって締めつけ……出来るでしょ？　\nはんっ、こうされるのいいって知ってるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムも……んっ、しっかり……チンポの感じ分かるの……結構好き……♪　\nだから、もっとグリグリって……大きく動かして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、はんっ、あぁっ、そうっ、そう……そんな、感じぃ……あっ、はひっ\n、あっ、はぁぁぁぁんっ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「人間の姿ってヘンなのぉ……何か、意識してなくても……勝手に、声……出\nちゃうしぃ……お尻……揺れるしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……何よ、おっぱいも触りたいんだ……んっ、パパってホン\nトにいい度胸してるもんね……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「これってさ……んっ、もし……知らない人が見たら、すぐつーほー案件なん\nでしょ？　こーんなちっちゃい子に、えっちなことしちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それ位のことは知ってるわよぉ……でも、そんなことより、もっと気持ちい\nい方がいいんだもんねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だからぁ、いいよ……細かいことは気にしないでぇ……もっとヤムの中っ…\n…オマンコ、ズンズン突いてぇっ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、あぁんっ、すごっ、出たりっ……入ったりしてるっ、やらし\nー音っ、ぐちゅってしてるっ、あぁんっ、これっ、面白いー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、ほらほらぁ、もっと頑張ってぇ……まだ、強くしていいからぁっ…\n…おっぱいもイジっていいからぁ……あんっ、そこぉっ、もっとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、んんっ！　あっ……なぁにぃ……尻尾まで……触りたいのぉ\n？　これって、人間にないトコなのに……興奮しちゃうワケぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そんなに敏感なトコでもないけど……んんっ、さすりたければ……さすれば\nぁ？　はぁっ、んふっ、あっ、んっ……くぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふぁっ！　何かっ……またチンポっ、あっ、膨らんでっ……いい感じに……\nはぁんっ、なって来てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、はんっ、あぁんっ……もしかして、もう……出ちゃいそう…\n…？　射精でしょっ……チンポ……出るんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、んんっ、それならっ……絶対中に……出すのっ……ねっ、オ\nマンコの中っ……いっぱいにぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらぁっ、我慢出来ないんでしょっ……？　出しちゃいなさいっ……奥にっ\n……せーえきっ、ちゃんと出すのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁぁぁぁぁぁぁんっ！　来たっ……せーえきっ、出てっ……来\nたぁっ……びゅくびゅくっ……してるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ！　んふぅっ、これが中出しぃ……んんっ、ちゃんと……きもちいい\nー……これぇ、いいじゃん……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、オマンコも……キュンってなっちゃう……んっ、チンポ……\nもっとぎゅって握っちゃう感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んはっ……あ……止まった……？　んっ、もっと出るかと思ったけど……こ\nんなもんなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「で、どうだった？　ちゃんとヤムのちっちゃーなオマンコ味わったんだから\n……満足してなきゃダメよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んくっ……そういう意味では……全然……満足しきれてないみたいね……は\n、んふっ……こーんな幼いカ・ラ・ダ、まだ味わいたいんだぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だって、まだまだオチンポ……コチコチのままだもの。まだ出せるのに終わ\nりなんてヤムが許さないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「オマンコも……これからだって言ってるしぃ……中にいっぱい出してくれた\nから、もっとトロトロになってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「この中……もっと突いたら、すっごく気持ちよくなるよぉ……？　ぐちゅぐ\nちゅの中をオチンポが泳いだら……いい感じだよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、そぉっ、はぁんっ、くぅっ、んふぅんっ、さっきよりっ…\n…あっ、もっとっ、強くぅっ、んはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、ひぁんっ、まだっ……出来るでしょっ、強くぅっ、お尻っ\n……ぱつんって当たる位にぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁんっ！　そっ、そぉっ、それでっ、ぐりぐりっ、回すのっ！　あんっ、\nあぉっ、くぅんっ……はっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やば……あっ、さっきより……中ぁ……ジンジンするぅっ……んっ、ふっ、\n本気のオトナチンポっ……はぁんっ、いいっ、感じぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらぁっ、ここも触っていいからぁっ、おっぱいでもっ、尻尾でもぉっ、ヤ\nムの感じるトコ……いっぱいしてぇっ、あんっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁっ……おっぱいっ……いいよっ、ぎゅって……先っぽ、つま\nまれるの……あぁっ、いいっ、感じぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁっ、はぁぁ……カラダ……燃えるぅっ……ドラゴンの時とっ…\n…違うのっ……これがっ……いいのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、どうしたの……？　誰かに見つからないか……気になっちゃってる\nのっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「誰かに……見られてもっ、聞かれてもっ……どうでもいいでしょっ？　大丈\n夫っ、ちゃんと……ヤムが守ってあげるからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だからっ、余計なコト考えないでっ……ヤムのオマンコに集中してっ……あ\nんっ、ちっちゃいカラダのマンコっ……ズンズンしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　そぉっ、それぇっ……あぁっ、ヤムのオマンコがいいっ、ヤム\nのオマンコッ……気持ちいいのっ、はんっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ぐりぐりされてぇっ、あぁっ、じゅくじゅくになってぇっ……はぁんっ、止\nまらないっ……きもちーのっ、続いてるぅっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ……パパも……息が荒くなってきてるっ……ほらほら、また出した\nくなってるんじゃないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00017502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いーよ……また、いっぱい出しちゃおっ……また中に出したい……？　それ\nとも、ヤムにぶっ掛けしたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
