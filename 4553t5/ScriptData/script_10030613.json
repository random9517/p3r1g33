{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「いらっしゃ～い。なんだかお疲れね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「久しぶりに、ヒリついた現場だったからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115470002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「まあ、それほどシリアスにはなっていないとおもうが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115470003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「さて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020115470004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ～、やはりこの姿がいいのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「今回はいったいなにをしていたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「刻の女王と対面することになってしまってのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あやつには、余が生きていることはもう少し隠しておきたかったのじゃが…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あら、正体がバレちゃったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470003" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あやつほどの実力者が、余の変装を見破れぬわけがなかろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まいったのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「困ったふりをしながら、余裕そうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470004" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあのう。あやつ、余を攻撃する絶好の機会にもかかわらず、手をだしてこ\nんかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なにか、まだ考えがあるのやもしれん。もう少し、泳がせてみるかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そんなに余裕でいて、手遅れにならないかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「刻の女王っていうくらいだし、本気を出したらす～っごく強いんでしょ～？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なぁに、心配はいらんじゃろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「というわけでＭ．Ａ．Ｍ．Ａ、いつものをたのむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010115470009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「は～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115470007" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470001" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「まさか、ルナルバースが生きておったとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「しかしあの素振り……私が刻の女王であることを見破ったうえで、わざと見\n逃したのだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あやつとしても、私を攻撃する絶好の機会だったはず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「なのに手を出さなかったということは、なにか別の考えがあってのことだろ\nうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ルナルバースは油断ならぬ。ここは慎重に様子を伺うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ジェスタよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「は～い。女王様、お呼びですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115470001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ベルガマスクという者について、調べておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470008" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おけまる～。でも、調べるだけでいいの～？　お望みなら、暗殺なんかもし\nちゃうけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115470002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いや、ベルガマスクの行動を調べるだけでいい。手を出そうとするなよ？　\nあやつは、お前の手に余る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470009" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふ～ん、ボクのこと心配してくれるんだ。女王様ってばやさし～。惚れる～\n。一生ついてっちゃお～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115470003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「じゃ、女王様から授かった任務、遂行するね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115470004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "ルナルバース……。あの行動の真意を見定める必要がある。もう少し泳がせて\nおくか……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115470010" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}