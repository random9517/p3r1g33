{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0187" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「よくきてくれたな。お前を呼んだのはほかでもない、ひとつ頼みがあるから\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前の花嫁になるにあたり、ふさわしい奉仕がしっかりできるのかどうか、\n見て欲しいのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さあ、こちらへこい。花嫁らしい奉仕といえば、やはり膝枕だと思うからな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……どうだ、私の膝枕の心地は。さらにこちらも、しっかりと面倒をみ\nてやらないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前のチンポ……甘く勃起しているではないか。ふふっ。どれどれ、母の手\nでそっと包んでやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020103_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こうして、ゆっくりと……やさしく、しごいてやるうちに……。チンポがど\nんどん硬くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「熱も増してきている……。ふふっ、もどかしそうにピクピクと震えて、かわ\nいい反応だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ。どうしたのだ、いつのまに母の乳に吸いついて……。んくっ、舌で乳\n首を……んっ、んふぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「吸い付きながら、舌先で母の乳首をもてあそぶなど……。あんっ、母も、感\nじてしまうではないか……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、そうやって……吸われたら……っ。あんっ、乳首が硬くなって\n、ますます感じるように……んっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そ……そうか……。夫婦なのだから、お互いに気持ちよくなろうと、そうい\nうことなのだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……それに気づかないとは、母もまだまだだ……。ああ、お前の口で、\n母の胸をたっぷり愛撫してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私も、お前のチンポをもっとしごいて、気持ちよくしてやろう……。ふふっ\n、先ほどより、勃起しているようだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こうやって、チンポをしこしこしごいて……。んっ。いきなり乳首を強く吸\nうなんて。……さては気持ちよかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そのように、同じような快感を、母に返してくれるのだな……。んっ、それ\nなら母も、応じなければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ガチガチになった愛しいチンポを、やさしくしごき、ゆっくりと撫で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「この時間を楽しむように、じっくりと快感を高めていこう……。ンッ！　お\n前の舌も……とても、気持ちいいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「舌が、乳首を転がして……よだれまみれにされてしまっているな……。舌先\nで、つつくような刺激も……ああ、痺れるようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それにしても、こうして乳を吸っている姿は、夫というより赤子のようだな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ。なに、気にすることはない。私はお前の妻であり、母なのだから。\nお前が赤子のように甘えることに、なんの問題がある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それに私だって、このように甘えられるのが嬉しいのだ。だからもっと、求\nめてよいのだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んくっ！　そうだ、もっと母の乳首に……ああ、まだ母乳などでないのに、\n必死に吸い付いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「本当に、お前はかわいいな……。んっ、私も、お前のチンポにたっぷり奉仕\nしてやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「熱く滾ったチンポをしごいて……。ああ、ますます大きくなって、亀頭もパ\nンパンになっているぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「真っ赤に充血して、苦しそうだ……。鈴口をぱくぱくさせて、先走りまで垂\nらしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「このヌルヌルを、手にまぶしてもっと激しくしごいてやろう。ふふっ、どう\nだ、気持ちいいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ、さらに激しく、胸を……！　ああ、そうか、お前が感じているだけ\n、母のことも感じさせてくれる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「乳首を吸ったり、甘噛みしたり……。んっ、ああっ、そんなに責められると\n、母の方が感じすぎてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ならば私も、もっと激しくしごこう。お前が気持ちよく、母の手へ射精でき\nるように……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「この、限界まで膨れ上がったチンポから、愛おしい子種をびゅくびゅくと放\nてるように……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、限界か？　いいぞ、いつものように射精するがいい。母の手へ、思\nう存分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、そうだ、母の乳を吸いながら、チンポからお前のミルクを……！　母\nが、しっかり搾ってやるから、さあ、だすのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんんぅうっ！　あっ、ああっ、でてる……！　手の中に、熱い精液が大量\nに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……。いつもながら、濃厚な精液だな。こんなにもべっとりと、ゼリー\nのような精液が手にくっついている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ここまで、お前の精液の匂いが漂ってくる……。本当に、いやらしく……そ\nして、母のことを昂らせる匂いだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、すまない……。お前が乗っているのに、ついふとももを動かしてしま\nった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前に奉仕しながら、どうも膣奥から蜜を溢れさせてしまったらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それで、どうだろうか？　母は、妻としての奉仕をできていただろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もう一度してほしい？　そうか、この奉仕をもっと味わいたいということだ\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいだろう、お前のチンポもまだまだ元気のようだからな。このまま続けて\n、母も妻としての奉仕を学ぼう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「このまま、精液まみれの手でチンポをしごいて……。ふふっ、ぐちゅぐちゅ\nといやらしい音がしているな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前もまた、母の乳首を……んっ、最初から激しく舌が動いて……。あっ、\nんんっ、すごく……気持ちいいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、さっきよりも乳首の感度が、増しているようだ……んくっ、そうやっ\nて舐めまわされると、快感が走る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私も、チンポをしごく手を休めず、またお前を射精に導いてやらねばな。こ\nうして、ヌルヌルをまぶしながら、全体を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、お前もまた、感じているようだな。腰がふるえてしまっている。そ\nのまま、私からの快楽に身をゆだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ンッ！　そうだな、夫婦なのだから、ふたりで一緒に気持ちよくならないと\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「また、母ばかりが先走ってしまうところだった……。ああ、もっと私の胸を\n気持ちよくしてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、そう……乳首を激しく……。舌で、あんっ、つついて、転がして…\n…んっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「上手、だぞ……。はぁ、はぁ……。お前に、たっぷりと乳首を舐られ、蕩け\nてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふぅ、すまない……気持ちよすぎて、腰がくねってしまう……。乳首だけ\nで、どんどん気持ちよくなってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ……お前のチンポもしごかないと……。ンッ、熱いチンポ……\nしこしこ……ふふっ。どんどん硬くなれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「手の中で、ビクビクと震えている。しごかれて、また射精しそうになってい\nるのが伝わってくるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと激しく、チンポをしごいて……。んくっ、応じるように、お前の舌も\n動いて……はぁ、ん……く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「今度は私の方が、お前に乳首を責められてイッてしまいそうだ……。んぁっ\n、そうやって、執拗に乳首を……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「舐めて、吸うだけではなく……ンッ、乳輪をなぞるように、巧みに舌を動か\nして……責められては……ぁ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私ももっと、手を動かそう。お前がまた気持ちよく射精できるように。腰を\n震わせて、ふふ、また精液がこみあげてきているのだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、その返事に、乳首を強く吸われ……っ！　あっ、んくっ、そんな\nにされたら、母は……もう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「胸を責められ、イ……イク……ッ！　あっ、ああ……っ、お前の舌が、気持\nちよすぎて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、射精しそうになってるチンポとともに、母は、イクッ、イッて\nしまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303219" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「また、好きなようにだすがいい。母に、お前の射精を見せてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　ああっ、イッくぅうううぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、乳首……乳首で、イッてしまった……。お前に舐められ\nて、イッた……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前も……また、たっぷりと射精したな……。先ほどと同じくらいの濃い精\n液が、こんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ンッ。こ、これ。イッたあとの乳首を、いつまでしゃぶっているのだ……。\nんくっ、は……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「まったく甘えん坊だな。だが、それもよい。こうしてたっぷりと甘える時間\nも、お前には必要なのだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「だが、こんなに吸われてイかされ続けては、乳首が開発されてイキ癖がつい\nてしまうかもしれないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……ふふっ。チンポが跳ねたぞ？　想像してしまったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そんなお前の素直なところは美徳だな。ふふっ、このチンポも、手の中でま\nた硬くなり……ずっと可愛がってやりたくなる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前もまた、母の乳首を吸っていたいのか？　それなら、お前の満足するま\nで母は乳首を差しだそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「赤子のように乳を吸う愛しい夫よ。いつかは母の母乳を飲ませてやりたいな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ！！　あっ、ああ……っ！　イクッ、イッくぅうううぅぅぅ～～～\n～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あっ、ああ……っ！　すまない、思わず手に力が……。ンッ！　なんて勢い\nで精液が……さっきよりも、すごく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「は、母の顔や……胸まで飛び散るほどの勢いで、お前の熱い精液が、飛んで\n……かかって……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「乳首でイかされたうえに、精液までかけられたら……っ！　んっ、んくぅっ\n！　また、イかされてしまうではないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それにしても、２度目なのにこれほど精液を飛ばせるとは、そんなに母の手\nが気持ちよかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、お前に満足してもらえたのなら、母は妻としての自信がついた。あ\nりがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それで……お前はまだこうして、母の膝の上で横になっていたいか？　ああ\n、もちろんかまわないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、こうしているとやはり赤子の世話をしているようだ。よしよし、甘\nえん坊なチンポの世話も、母に任せよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「夫が身をゆだねる止まり木となるのも、妻としての役目であろう。存分に羽\nを休めるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私は、お前のために、妻としての奉仕を学んでいこうと思う。これからもよ\nろしくな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0303410" ]},
		{"command":[ "WAITINPUT" ]},
