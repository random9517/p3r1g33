		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁん……精液……掛かってます……あぁ、身体中が精液まみれにされて\n……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……視線がいっぱい刺さっています……あぁ、はしたなく母乳を飛ばし\nて……オマ〇コからも汁を垂らして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ヌルヌルの精液が絡みついている……いやらしい姿……あぁ……私の恥ずか\nしいところ……全部見られてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あぁ……やっと、母乳が止まりました……射精も……お、終\nわりましたか……？」", "NORMAL" ]},
