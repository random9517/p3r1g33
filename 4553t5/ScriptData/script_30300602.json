		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もう降ろしていただいてもよろしいですか……？　そ、そんな……もう少し\nこのままなんて……」", "NORMAL" ]},
