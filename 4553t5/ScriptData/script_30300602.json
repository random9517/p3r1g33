{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0084" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んーっ、本当にいいお天気で、絶好の海水浴日和ですね。お日様の光が、と\nても気持ちいいですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604101" ]},
		{"command":[ "SETCHARA", "0", "char_00003006_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「日焼けですか？　ふふっ、その辺は普通の人と同じではないので、そこまで\n心配することはないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「日に焼けた私を見たかったですか？　ちょっとそのお願いは叶えてあげられ\nませんが……他にして欲しいことはありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604103" ]},
		{"command":[ "SETCHARA", "0", "char_00003006_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、今日連れてきて頂いたお礼に、何か一つ言うことを聞くなんていうの\nはいかがでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「えっ……海の方を見る？　えっと……こちら側を向くということでしょうか\n。はい……きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604105" ]},
		{"command":[ "SETCHARA", "0", "char_00003006_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……び、びっくりしました……いきなり……こんな、脱がされて……あ\nんっ、抱えられるなんて……えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003006_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ビキニ姿でムラムラして……ずっとしたかった……まぁ……それで……今、\nオチ〇ポがもう、こんな状態だったんですのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お日様の下で、見せつけるようなエッチがしたい……んふ……こんなに鼻息\nを荒くお願いされたら断ることはできませんわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……あなたの、ギンギンに勃起した逞しいオチ〇ポを……どうぞ、私の\nオマ〇コに入れて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「実は私も……んっ、そんな風になることを少しだけ思って……オマ〇コ……\n濡れ始めています……ですから、このまま中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、んっ……あっ！　あふぅぅ……入っています……あっ、はぁぁん\nっ、オチ〇ポっ……オマ〇コにめり込み……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604111" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁぁ……んんっ、はぁっ、すごいです……串刺しにされてしまったみたい\nに……んくっ、私……重くありませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか……でも、この状態だと……私の方からは、ちゃんと動けるか\nどうか……全部お任せしてよろしいのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……でしたら、あなたのお好きなようになさって下さい……私のオマ〇\nコ……たっぷり可愛がって下さいませ……あ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あっ、はぁん、あっ、あぁっ、ゆさゆさっ……揺れてっ……\nオチ〇ポがっ、いっぱい……擦れ……ますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……声が……そ、そうでした……今日は、周りの方も近くにいら\nっしゃるんですよね……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こ、こんな所を見られたら……私も、は、恥ずかしくて……あんっ、見られ\nたいなんて……そんな、ことは……あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……あぁっ……母乳が……あふっ、は、はい……その、ドキドキすると…\n…自然に乳首が疼いてしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、なるべく……声は我慢して……あっ、ひぁぉっ！　あっ、オチ〇ポっ\n……そこっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604119" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……す、すみません……んんっ、声が……あっ、自然に、あぁ…\n…んっ、ふっ……出てしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、この体位……いつも以上にオマ〇コに深く……オチ〇ポがめ\nり込んで……はぁ、んっ、中が広げられるみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、あぁっ、こ、声を……抑えたいんですけどっ……止まらなく\nてっ……あひっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……もっと足が広がって……こんな……繋がってるところが…\n…全部、丸見えになってしまってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「い、いえ……今……正面の海には誰も……で、でも、どなたかが潜っていら\nして急に顔を出されたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私のいやらしくオチ〇ポを咥えこんでいるところが……あぁっ、隅々まで見\nせることになってしまいますっ……あ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……ま、また母乳が垂れてしまいます……はひっ……恥ずか\nしいのに……おっぱい止まらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604126" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、はぁっ、身体が……揺すられてっ、ぴゅっぴゅって……母乳\n飛んでしまいますっ……はしたないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくっ……んむぅっ、我慢……しないと……はふっ、んんっ、あぁっ、で、\nでもっ……あんっ、これぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……これっ、あひっ、好きっ、ですわっ……！　下からオチ〇\nポっ、ズボズボされるのがっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604129" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁっ……見られてしまうかもしれないのにっ……ドキドキ\nしてっ、あぁ、いいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……オチ〇ポがいいっ、オチ〇ポ気持ちいいですっ……！　あぁっ、見\nられるかもしれないのにっ、気持ちよくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、身体……揺らされるとっ……オマ〇コっ、擦れますっ……！　また\n、激しくされたらっ、熱くっ……なってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あうっ、んんっ、くぅんっ！　あぁっ……オチ〇ポっ、膨らんでっ……あひ\nっ、そろそろっ、ですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604133" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、分かりますっ、オチ〇ポ出したがってるのっ……もうすぐって……\nビクビク震えているのっ、分かりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、出してっ……下さいっ！　熱いのっ……オマ〇コの中にっ……この\nまま直接流し込んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁんっ、私もっ……もうダメですっ、はっ、んひぃんっ！　オマ〇コっ…\n…イキますぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんんんんーっ……！　あぁっ……出てます……いっぱい、精液……子宮に\n直接届けられてますぅ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……んくぅぅ……お外で中出し……はぁぁ……気持ちよすぎます\n……んふぁ……オマ〇コ……イッたままです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……オマ〇コの中があなたの精液でいっぱいになりまし\nた……あふっ、少し垂れてしまってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604139" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……いっぱい出して下さってありがとうございました……私も、すご\nく……感じてしまいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「でも、とても気持ちよかったです……結局声も我慢できずに……少しはしゃ\nいでしまいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ずっと持ち上げたままでお疲れでしょう？　降ろしていただけますか……あ\nっ……あの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ……オ、オチ〇ポが……オマ〇コの中で、また……大きく\nなって……こ、このまま……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……まだ出し足りない……ふふっ、しょうがない方ですね……今日は\nいつも以上に欲しがりになられているんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もちろん、あなたが満足されるまでお付き合いしますわ……逞しいオチ〇ポ\n……続けて下さいませ……あっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あぁっ……オマ〇コの中の精液が……ぐちゅぐちゅっ……か\nき混ぜられます……あふっ、あ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604206" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ずっと、あっ、支えたままなんて……お疲れでしょうに……あぁんっ、ゆさ\nゆさっ、されてっ……オマ〇コっ、擦れます……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「軽い位ですか……？　ふふっ、本当に逞しいのですね……私もちゃんとご奉\n仕しないと……んんっ、んっく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、お尻を引き締めると……この格好でも、なんとかオチ〇ポを締め付け\nることができるみたいです……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私も、んっ、あなたのオチ〇ポにもっと悦んで欲しいですから……はぁっ、\nふっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、はぁっ、あっ、あぉっ、はっ、んぅっ、くっ、あっ……あぁ\nっ……あ、ひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604211" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ、あの……し、視線を感じます……ど、どなたかに見られてしまっている\n……あっ、みたいです……は、ひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「い、今も……あっ、海の方から……あっ、木陰のところにもっ……あっ、そ\nんなっ……あぁっ、い、いやっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「わ、私が声を上げてしまったから……あっ、それは、そうなのですが……こ\n、このまま続けてしまうのはっ……あ、ひぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そん、なっ……あっ、もっと……激しくっ、あっ、あひんっ！　い、いけま\nせんわっ……また声が……は、恥ずかしいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁおっ！　み、見せつけるなんてっ……そんなっ……あぁっ、オ\n、オマ〇コっ……こんなに丸見えにさせたままなんてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、あぁっ、激しいっ……ダメですっ、こんなにされたらっ、\n見られながらっ……イ、イッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あひぁっ、あぁっ……！　あぁっ、母乳を出すとこまで見せるなんて\nっ……本当に恥ずかしいのにっ、も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「でもっ、声がっ……抑えきれなくてっ……！　あぁっ、オチ〇ポをいやらし\nく咥えこんでいるところもっ、」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、もう駄目っ……あひぃんっ！　イキますっ！　み、見られながらオ\nマ〇コセックスっ、イッちゃいますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁんっ！　あっ、あぁぁっ……中出しっ……二回目ぇっ……は、\nひぃぃっ……ん！　母乳もっ……出ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁ……全部見せてしまってます……は、恥ずかしい……あぁ、\nでも……気持ちよすぎてぇ……はふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁ……物陰から、じっと見られてて……あぁ……視線が……オチ〇ポと\nオマ〇コの中心に注がれてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ひくひくって……いやらしく動いてるオマ〇コ見られて……あぁ……お汁…\n…母乳も止まらないです……んぁふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……射精……終わって……はぁ、はぁ……あっ、ふっ……母乳も\n……やっと落ち着きます……はぁ……んっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604305" ]},
		{"command":[ "SETIMAGE", "0", "still_00003006_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こんなはしたない姿を誰かに見せてしまうなんて……あぁ……お願いします\n……も、もう足を閉じさせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ずっと、オチ〇ポを咥えたオマ〇コを丸出しにしたままなんて……んっ、恥\nずかしすぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私の乱れ姿が新鮮……も、もう……あんまり困らせないで下さい……あなた\nにだから見せているんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ、またオマ〇コ……ひくんって……私……本当に変態なのかも\n知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この気持ちよさを知ってしまったら……元に戻れなくなってしまいそうです\n……んふぁ……」", "NORMAL" ]},
