		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……恥ずかしかったです……い、今もまだ……こんな大股開きで……オ\n、オマ〇コを見せびらかしたままなんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0604407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「普段と違う反応を楽しんで……？　もう……意地悪ですわ……この恥ずかし\nい姿は、あなただから見せているんですよ……？」", "NORMAL" ]},
