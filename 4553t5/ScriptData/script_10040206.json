{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そのころ、時間城では……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「アナザー・オボロくぅ～ん？　この前の戦闘以来、なんだか元気がないらし\nいねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「アナタには関係ないです。放っておいてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いやぁ、女王陛下の道化師ともなると、そういうわけにもいかなくって。メ\nンバーのコンディションに気を使わないとねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「いつから道化師はマネージャーを兼任するようになったですか。大きなお世\n話です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おやおや、困ったねえ。刻の女王陛下に、なんてご報告したらいいのかなぁ\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……？　どういうことです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「女王陛下はキミに、新たな力をくださるっておっしゃってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「新たな力？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そう。元気のないキミのために、ＥＤＯに勝てる力をくださるって！　でも\nねぇ～いらないんなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……相変わらずくだらない冗談ですね。その力を得るために、私にどうしろ\nというですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580005" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「な～んだ、やっぱり必要なんだね？　そういうことなら、まず……ウサギ跳\nびで城の階段を３０往復ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580006" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だから～。新たな力を得るためには、器となるキミの肉体を鍛え直す必要が\nあるって、女王陛下がね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……それで、ウサギ跳びですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580007" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まあ、そういうことだね～。ほら、パワーアップにはさ、やっぱり特訓が必\n要なんだよね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……わかりましたよ。やればいいんでしょう。やれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116580008" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うんうん！　そういうわけで、がんばってねぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116580009" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}