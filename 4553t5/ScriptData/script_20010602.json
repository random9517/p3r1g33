	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「くっ、逃げられましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110001" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だね。僕たちから逃れるとは、中々に強敵だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110001" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ここは深追いしない方が得策だ。だがここに留まると、戦いの音で誰かが来\nてしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110002" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「一旦どこかに身を隠す必要があるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、音が……みんなが戦っているみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110002" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それなら今の内に逃げて――いや、死体と現場の確認をしに行こう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110004" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なるほど、今なら確かに行けますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110003" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ピンチをチャンスに変えるのも探偵の力さ。行こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110005" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そんな……死体が消えているなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110006" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あの黒い影が持っていったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110004" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「つまり死体が狙いだったのか？　……迂闊だった。まさか殺す事が目的では\nなかったとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110007" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「っつ！？　さっきの黒い影！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110006" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ゲンナイくん、今度こそ捕まえるんだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110008" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「けどいいんですか、ここを荒らしてしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110007" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「明確な犯人が分かったから大丈夫だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021110009" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そ、それでいいのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021110008" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
