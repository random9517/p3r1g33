	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「あーもうっ！　こんなに相手が多いんじゃ、やってらんないっ！　いちぬけ\nたー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「わたしももう帰るー！　おまえら、おぼえてろよー！　ばかばかばかーっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「待て！　逃げる気か！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ひとまず放っておきな。それより誰か、校内を見回ってきとくれ。襲来者（\nインベーダー）が残ってるとやっかいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「たしかにね。それだったら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「って……なんであたしがおまえと見回りしなきゃならねえんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「それはこちらのセリフです。どうしてあなたと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ほむら！　そこの物陰です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「おう！　隠れてんのは誰だ！　出てきやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340002" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「うううう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「リーダー、大丈夫ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「なにが『大丈夫ですか？』だ……戦闘が終わってからのこのこ現れて……う\nううう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114340002" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「いや、まあ、あたしらもいろいろありまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「でも、助けに来たんだからいいっしょ？　いいよねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「――って、やっぱり襲来者（インベーダー）か！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340003" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者たち" ]},
		{"command":[ "SETTEXT", "「うひゃあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114340003" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "9", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00090201_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00090301_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00090401_01", "3", "CENTER", "600" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「み、み、見つかっちゃった！？　ど、どうする！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114340003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ど、どうするったって……あ、そうだ！　降伏しましょ！　降伏！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114340003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あんた頭いいな！　そう！　とりま、降伏！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114340003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「だーっ！　なにが降伏だ！　私は決して、降伏などしないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114340004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ちょっとリーダーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114340004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「いや、だけどおまえ……怪我してんじゃねえか。ボロボロだぞ、オイ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340004" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「だ、だからなんだ原住民め……！　貴様らなどに負けはしないぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114340005" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あくまでもやろうってのか。いい根性だ。だったらこっちも手加減は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340005" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「奔れ！　蒼氷斬！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者たち" ]},
		{"command":[ "SETTEXT", "「あひいいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114340006" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00090201_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00090301_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00090401_01", "3", "CENTER", "600" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「って、おおーいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340006" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「なんですか、ほむら。そこでぼーっと突っ立ってないで、手を貸してくださ\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「『手を貸して』じゃねえよ！　こいつら、失神しちまったじゃねえか！　あ\nたしの獲物になにしてくれてんだぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340007" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「手間が省けたのだから、問題ないはずですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「手間とかそういう問題じゃねえよ！　いまの見てなかったのかよ！　すっげ\nえ熱いシーンだったろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340008" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「あたしとリーダーとやらの見せ場だったんだぞ！？　こっから殴り合って分\nかり合って、熱いライバル関係をだなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340009" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そういう非論理的な展開は、昭和で滅びました。そんなことより、手伝って\nください。彼女の身柄はＥＤＯで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「うるせー！　黙りやがれーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340010" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ちょっと！　なにをするんですか！　だいたいですね！　そんなことだから\nあなたは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「レッドとブルーが、ケンカを始めました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00006301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……わかってる。わかってるぞ。見ればわかる……あいつらときたら、もう\n、ホントに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114340002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あはははは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010114340002" ]},
		{"command":[ "SETCHARA", "0", "char_00006301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちょっと！　誰か手の空いてる子！　ひとっ走り行って、あいつら止めてき\nて！　東風ちゃん、行ける！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114340003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「わ、わたしですか！？　無茶言わないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010114340003" ]},
		{"command":[ "SETCHARA", "0", "char_00006301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だよねー！　やっぱ無理だよねー！　しょうがない！　現地部隊に連絡！　\nただいまをもって任務を変更する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114340004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「全戦力を投入し、ほむらと氷華のケンカを止めろ！　ケンカを止めて、あい\nつらと襲来者（インベーダー）を私んとこに引っ立ててこーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114340005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「は、はいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010114340004" ]},
		{"command":[ "SETCHARA", "0", "char_00006301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0173" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「って、長官は言ってるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「まあ、放っておくわけにもいきませんしねえ。止めに行きますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010114340002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それがいい。では、屋上へ向かおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114340002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「やれやれだ……まったく、あいつらときたら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114340001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ７世" ]},
		{"command":[ "SETTEXT", "「修羅姫も人のことは言えないであるがな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「この冷血女ーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010114340011" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「この単細胞ーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010114340009" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・レッド" ]},
		{"command":[ "SETTEXT", "「だからおまえは――」", "NORMAL" ]},
