{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「ぐふっ……！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふう……最近は襲来者（インベーダー）が多いです。これでは勉強もままな\nらないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「倒しても倒しても、どんどん湧いてくる……まあ、そのおかげで赤点回避余\n裕って感じだけどね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「もう疲れたよぉ……いい加減、ゴロゴロしたい……！　休みたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540001" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「急！　休めば鈍るですよ。赤点回避のために、こういうコツコツとした努力\nも大切なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「コツコツ努力かー……いっちばん嫌いな言葉だなー…………って、何これ？\n　福引券？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あっ、それ知ってる……今、商店街で配ってるヤツで、１０枚集めると１回\n抽選を受けられるらしいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540002" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「さっきの襲来者（インベーダー）が落としたモノみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「しかもご丁寧に１０枚の束でなんて……誰かから奪ったものかもしれません\nし、交番に届けるですよ！　で１割せしめるです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「えー……こんなの届けても、どうせ持ち主なんて現れないよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そうだよ……それにもし持ち主の人が現れなかったら、福引券がムダになっ\nちゃうじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540003" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「破！　急！　私達は、この世界を正すため、戦っているですよ！　進んで善\n行を行い、赤点を脱する……それが若苗家の使命！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そんな大層なお題目で戦ったことないでしょ？　ってか普段から頑張るあた\nし達への、ささやかなご褒美ってことにしない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「それに１回の抽選でいいモノなんて早々当たるってワケでもないし……役得\nだと思ってさ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んー、けど落とし主が真剣に探してる可能性もあるですよ？　さすがにそ\nれは気の毒です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「福引券をなくして困る人なんて、居ないと思うけどなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「じゃ、姉さんがその人を探して謝っといてね。ほら、急、抽選に行きましょ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと……！　待つですよ、二人ともー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}