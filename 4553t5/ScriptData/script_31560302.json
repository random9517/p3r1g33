{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「よ……良かった。ここにいてくれたか……！　隊長……すまないが、今少し\n……相談にのってもらえないだろうか？　他の者には話せない内容なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00015603_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「さ……最近、身体が異常に火照って仕方ないんだ。こういう時……こちらの\n世界の人間は、ど、どうやって抑えているか知っているか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「前に……オナニーというものを教えてくれたことがあっただろう？　だ、\nだが……それでは足りないのか、すぐに身体が元に戻ってしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「性的な衝動を消すには他にどんな方法がある？　教えてくれ。そして……\n可能なら、暇なら……補助してくれるとありがたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふむ。ふむ、なるほど……そんな方法が……！　ああ、たぶん理解は出来た\n。が……心配だから、実際に試してみてもいいだろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁ、はぁ……。い、言われた通り胸を出して……おまえの股間\nの上にまたがったぞ。ここから……どうするのだったか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015603_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「もう一度教えてくれ。うむ。まずは素股……そうだったそうだった。互いの\n粘膜をよく濡らして、なじませることが大事……なんだったな。ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふ、ぅ……っ。ん、ふ……。くぅ……、んん……。んッ……んん……。あっ\n♪　……ふぅっ……ふ、ぅ……んん……んっんん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「これでいい、のか……？　ぁっ……♪　ま、股をこすりつけるだけで……\nなんだか、卑猥な事をしている気分になってくる……悪い事をしているような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「落ち着かない……。んん……！　それは集中していないから？　そ……そう\nかもしれないな。もっと粘膜の……接触に集中、して……。ん、ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……んぁっ♪　……あ……！　お、おかしな声をあげてすまない……。え？\n　嬌声は我慢するな？　その方がチンポも喜ぶから？　そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なら……我慢はやめておく。素直、に……。はぁっ……はぁ、はぁ……おま\nえのコレの感触を楽しんで……なじませるように……。あふっ♪　んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ぴ……ぴちゃぴちゃと、ア、アソコが濡れてきているのがわかるか……？　\n私の花弁が、……蜜で潤って……おまえのオチンポにキスしてい、る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「くちゅ、くちゅ、ちゅぷ、ぷちゅと……♪　あ……あぁ……♪　素股……\n素股はとても気持ちがいいんだな、でも……少し、少し足りない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っぁ……あの……これは相談なんだ、が……っ。はぁっ……はぁ、そろそろ\n……少しだけ入れてみてもいいか？　先っちょだけでいい、から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「入れたい……っ。これ……オチンポ、オマンコで咥えこみたい……！　これ\n以上焦らされたら私は、私はどうにかなってしまう……。なぁ、いいよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……んんんん……っ♪　へ、返事を聞く前に挿入っ……してしまった…\n…！　あぁぁ……♪　ごめんっ……ごめん、もう我慢できなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ！　で……でも……！　チンポがデカすぎて……、あうっ、太すぎて、\n硬くて……う、うまく動けない……。アソコが拡がってミチミチだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ……ふ、ん、ふぅっ……ふぅうう……っ！　こ、これは想定外、だ……！\n　チンポが凄すぎて身動きが取れない、なんて……ん～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「は、腹に一直線に突き立てられた肉棒……っ。ん、くぅうう……！　腰を\n揺らすだけじゃあだめだ、尻を上下させ、ないと……あっあっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こ、れ……！　とても恥ずかしい格好で、恥ずかしい動き、だ……！　あっ\n！　奥の奥まで、子宮口まで突き刺さったチンポ、を……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「全身でシゴいていく感じ……ぃ……！　はぁっ……ふぅううっ……うぅうう\n……！　ずりゅぅうって膣内全部えぐられて、ひゅ、ひゅごいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ……、ぅ……♪　うぅ……、うっ……うっ……くふ……っ♪　はぁっ、\nはぁ……チンポの形、はっきりわかる……突き刺さっている、のが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「もっと……もっとこの太い肉棒を楽しむには……っ、あぁあ……！　何……\nっ？　こ、腰を回して、気持ちいい部分を探す？　なるほどぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……！　こう……？　こう、か……っ？　あっ……！　今っ！　今、\n気持ちいいところにこすれ……ああっ！　こ、これは、これはまずいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「自分で……自分でオマンコ操作して、腰っ……お尻っ、回すの……中毒的な\n快感があ、る……ぅう……！　あっ、こっちっ……今度はこっちっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁううっ！　こっちはどうだぁ……！　ッあぁっ！？　あぁ……ああああ\nっ！　い、いや、だ……感じすぎ、る……おかしくなるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「チンポの太いところっ……亀頭で中をグリグリしたりぃ……っ、あっ♪　\nあっ♪　んひっ……今まで知らなかったところにも気持ちいいところ、が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そう、か……そうかぁ……！　この体勢だと……あぁっ♪　正常位とかいう\n体勢、とは違う部分をえぐられて……今までオチンポを知らなかったところ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「快感に無垢だった部分のオマンコが刺激されて……まったく別の気持ち良さ\n、なのかぁ……！　あぁっ！　痺れ、る……やめられない……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「オマンコ、勝手にギュウギュウ締まって……あっ！　も、もしかして、この\n状態で上下にピストンしたらそれも新しい快感なんじゃ……？　っふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「中をぉ……！　締め、て……ゆるめてぇ……っ、締めて、ゆるめ、て……♪\n　あっ！　あッ！　あっ、あっ……やっぱり♪　やっぱりぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「いつもと違うところに届く……あっあっあっ！　私、私のオマンコぉ……\n隊長のチンポをがっちりホールドして離さないんだ、それで、こすれるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「隊長っ……！　隊長にもわかる、だろう！？　オマンコの中ぁ……締めたり\nゆるめたり、キツくなったりフワフワになった、り……！　ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「も、もうめちゃくちゃで……！　気持ち良すぎる、イくっ……イくっ！　\nああっ！　隊長も！　精液出してくれっ……まずは一回……ん～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私のっ……一番奥！　このぷちゅぷちゅした子宮口めがけて出してくれっ、\n熱く煮えたぎった膣内をしずめて、くれ……お願いぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ッひゃっ……あっ？　あっ、んふぅっ！？　ふぅううっ！？　精液っ、精液\n出たっ……！　無理やり私が出させたぁっ……！　ああっ！　すごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「お……おまえの、生命力の源が……私の膣内に注がれていく……ぅっ。もの\nすごいエネルギーを感じ、る……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んくふぅうううっ……！　あつっ……あっついぃ……ッ♪　こ、れを……\n子種を、アソコを締めて吸い上げるんだな……っ。ん～～～～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふ、は……っ♪　あぁ……私の一番深い場所に、最奥におまえの出したての\n精液がはりついて……。身体が歓喜に震えているぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ……少しだけ身体が楽になったような気がする……。でも、最初とは\n別に、今度は……中出しをされた事での興奮が襲ってきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……もう一度、もう一度さっきの快楽を味わいたい……♪　この\nまま続けてしちゃダメか？　……んふっ♪　あ……♪　隊長～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえもすっかりその気じゃないか♪　だったら……このまま続けるぞ……\n？　ふぁっ……ぁっ……精液でタプタプのおまんこで……、あっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そのまま抜かずに、前後左右ぅ……あんっ！　上下、に激しく動いて……。\nあっ♪　あっぁっうっ♪　んん？　この体勢は騎乗位というのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「騎乗位……あぁ……！　私は騎乗位が好き、かもしれない……！　自分で\n好きに動けて、おまえを一方的に感じさせられて……自由で気持ち良くて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ずっと……ずっとしていたい……！　っぅ……♪　んッ……んんっ……！　\nあははっ……凄くギシギシいってる……隊長が揺れてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「腰を振るの止められない……。あんっ♪　は、激しすぎたら教えて……。\nオチンポ抜けたら大変、だし……あっ♪　んっんっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「だめ……だ、気持ち良すぎて逆に動けなくなってきたぁ……。ぅ……、これ\n以上したら、オマンコが麻痺してヘンになる……。って、あんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「し、下から突き上げるなっ……！　あぁっ！？　あぁ！？　や……だ、本当\nに今っ……駄目だからっ、あっ……イキそ……イキそうだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ごちゅごちゅ突き上げるのやめ、へ……やめへぇ……っ♪　あうっ！　い…\n…嫌がってる顔じゃない？　オマンコもヌレヌレになってる？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「い……言うなぁ、そんなことぉ……！　って……そんな事を言いながら、\n腰を止められない私がいけないんだ、が……！　あっ、あぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ひっ……ああっ！　隊長、が動くと奥まで……奥まで簡単に届く、自分じゃ\nっ……こ、怖くてためらうようなところまでズブっとハマるぅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こん、なに気持ちいいことをしないと身体の火照りが発散できないなんて…\n…あっ！　あっ！　私は、わたひはどうかひてる……どうかしてるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んひっ……ひぃっ……ひぃいっ♪　んぁああ……！　オチンポすごいっ、\n凄すぎる……っ！　気持ちいい、気持ちいい……イキ、そうだ……ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「せっかく……こうして協力してくれてる、のに、私が先にイクなんておこが\nましい……！　でも、でも……うううっ、もう、もう……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ッくぅうううう……！！　くふぅううううっ……！　あぁ！　絶妙なリズム\nで、最高の強さで私のオマンコが突き上げられてる、こんなのイクぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「わ、私だけ……イかせてもらうなんて良くない！　だから……オマンコいっ\nぱい締めるから、だから私の肉襞で、気持ち良く、なってくれ……ぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぁ……おまえのチンポが感じるのは、ここか？　ぁっ……こういう動きを\nすると精液出せそうか？　すごくキツくて気持ちいい？　良かったぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おまえの、おまえの精液を恵んでくれっ……！　私っ……私、ずっとイッて\nいるから！　イってるマンコに精液を注入して……流し込んで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ねえ……っ、一緒に……一緒にイこう……！？　あっ、私……私はもう、\nすぐだから……同じタイミングで精液出してぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んふぅううううっ……！？　あふっ、あふぁああっ……！　あ～～～～っ♪\n　あぁああっ、はぁああ～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んッ……くぅううう……！　くｘふううう……！　子宮、口……精液がノッ\nクしてる、何度もっ……何度もぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ……っ、イっくぅっ……！　もう一度、私の方も達してしまうぅ……！　\nはぁあっ……！　ごめ、ん……イクっ……イカせてもらうぅっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「う、ぁあああ……あぁ……！　あぅ……！　な、長ったらしく、しつこく\nイキ続けてすまないぃ……。絶頂が止まらないんだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「膣内にっ……中に精液を直接注がれると……いつまでも、いつまでも熱と\n余韻が凄くて……エコーがかかったみたいに何度でもイケてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んぁ……んはぁああ……♪　あああああ……♪　い、いつも……私ばかり\nイキ狂ってしまってすま、ない……。はぁ、はぁ、はぁあ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「意識が何度もトんでしまうほど、おまえの射精は気持ちがいいんだ……。\n狭いオマンコの中を、精液で満杯にされるこの気持ち……ぬくもりぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「これが女として……地球のメスとして最上級の喜びであることくらい、私に\nもすぐわかった……♪　ああ、でもまいったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こんな快楽を知ってしまったから……。もう、元の自分には絶対に戻れない\n……♪　おまえとおまえの身体を経験する前の私には……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「常に刺激的で、私の知らないことを教えてくれる隊長を……。はぁっ、はぁ\n、私は……これから二度と、手離せそうにない……。フフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ひゃっ……！？　ああっ……！　なっ……なんだっ……！？　こ、こんな\nところにまで精液がかかるなんて……！　飛ばし過ぎだろうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ぶびゅっ、びゅぶぶぶって……すごい勢いで飛んできて……！　あっ！　\n待てっ……待て、飛ばし過ぎだっ……！　あっ♪　あっぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁ……♪　噴水のように次々に舞い散る精液を……私が身体で受け止める\n……。この達成感は、何事にも代えがたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「この強いぬめり、ナメクジみたいにプルプルとしたジェル状の精液……。\nぷーんと立ちのぼる臭いにまとわりつかれると……。んん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ♪　い……今残り汁をかけたな！？　はぁっ……、二度目にも常識外れ\nな量を出して……。おまえは本当に男らしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015603_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ほらっ……空になるまでちゃんと出したか？　最後まで浴びるから……。\nんっ。チンポをぷるぷるさせて出しきって……。いいぞ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っはぁあああ……♪　あ……あれぇ……？　本当だ……身体中がすっきり\nして……。頭もなんだか、軽くなったような気がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。お、おまえの教えてくれることは……いつも有益で、正し\nくて……ひゅごいな……♪　頼って、信頼していてよかった……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……で、も……これは体力をすごく使うし……いささか気持ちが良すぎるよ\nうな気がするな。若干頭が悪くなったような……。でも、いいか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「騎乗位……これからも、しっかり覚えておかないと……。また、身体が火照\nったら頼らせてもらうと思う。その時はよろしくお願いするぞ……」", "NORMAL" ]},
