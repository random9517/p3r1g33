{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩、こんなところに呼び出してどうしたんですか？　まさか～？　私\nとデ・エ・ト♪　したかったんですか～？　って、ええっ、そ、そんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「俺の持っている、秘密のデカい武器を……お前にだけ見せてやる、ですとぉ\n！？　見たいです！　見たい！　見せてくださいっ！　……わっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「『これが俺のデカい武器だ』って……！　ぼ、ぼ、ぼ、勃起した隊長先輩の\nおチンポじゃないですか！？　た……確かにデカいし究極ですけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んも～。そんなに自信満々に見せつけられたら、笑っちゃいますよ～。でも\n、こうなったら、私の巨大武器も見せる必要がありますね……？　それっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んふふふふ～♪　ラヴリエータちゃんの超巨大武器……。このおっぱいの威\n力はどーですか～？　隊長先輩のおチンポには負けますけど～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「なかなかおっきくて、ボリュームあって……。ずしんって感じでイイと思う\nんですよね～？　ほらほらほら♪　余裕でおチンポを挟めますし、って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ごくっ……。た、隊長先輩のおチンポ……先っちょが谷間からハミ出してる\nんですけれども……？　な、なにコレ……ホントに巨大武器じゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ええ～……？　巨大武器マニアとしては見逃せないサイズですよ～……。っ\nていうか、すでに……かなり気になってます。好きになっちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……。デカい上にムレムレで……っ、暑くて、太くて、し\nかも硬い……。こ、これは攻撃力激高のおチンポです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あ、あの……も～っとよく観察したいんでぇ……。私のおっぱいと対戦させ\nてみてもいいですかね～？　せっかく挟んでサイズ計測してるんで～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「このおチンポの強さ？　を調べるために、パイズリさせていただきま～す。\n……っんっ♪　あああ……、これスゴいぃい……。本当デカいです～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、こんなの好きになるに決まってます、たまらない力強さ……♪\n　あぁあああ、おチンポってこんなにも巨大武器だったとは～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……えっ？　もちろんおチンポなんて見たのは初めてですよ。っていうか、\nニンゲンの存在自体疑ってましたし。他の種族とは関わりないですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「初おチンポがデカすぎて……ホント、興味津々にならざるを得ないですね～\n……。どれどれ……んっ、おっぱいをなすりつけて……揉んでみましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁああ……♪　おっぱいのお肉がとろけてしまいそうなくらい熱\nいです……♪　谷間がポカポカになってきましたぁ……。っんっんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「っていうか、私がパイズリしてたら更に巨大になってきてません？　あぁあ\nあ～♪　ありえないですよ、まだ最大サイズじゃなかったなんて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ヤバすぎます、こんなの知ったら一生忘れられませんってぇ～……！　あぁ\nあ、好き……♪　デカいおチンポ超好きぃ……好きぃいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「パンパンに膨らんだコレ……。もっと強くパイズリしてみましょう……。ン\nンンッ……！　上下にこねくりまわして～……ふんっ、ンンッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あああっ！？　すっごい反応してますっ！　なんですかこのビクビクって！\n　……気持ちいいと脈打つ？　えぇええっ、超巨大面白武器じゃないですか！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「気に入りましたっ……。好きから大好きにグレードアップしました！　んん\nんっ……もっと調べたいです、このおチンポのこと、知りたいぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あっ、ぁっ……んぁあっ、ぁっ……！　挟んでシゴくのも大変な\nくらい、ご立派で……堂々としていて……うっとりしてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「っていうか、コレって本来はぁ……おっぱいじゃなくて、もっと違う場所に\n入れるモノなんですよね？　いやいやいや、このサイズは無理ですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「私の巨大おっぱいですらっ、あっ、扱いきれないのにっ……！　あっ♪　こ\nんなデカくて硬いモノ……っ。身体の中に入れるとか無理です……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「だって見てください！　太すぎますしぃっ……はぁっ、はぁ、長さもエグい\nですよねっ？　……あっ♪　全てのニンゲンがこうなわけないですしっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「もうこれはっ……♪　私のおっぱいと巨大武器対戦をするために、神様から\n与えられた武器ってことで……あっ、ま、間違いないですねっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んんんんッ……。あ、あの……。パイズリとかするのも初めてなんですけど\n……。これってちゃんとできてます？　あっ、おチンポは反応してますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「なにぶん大きすぎて……んぅっ、一度に刺激するのがっ、ムズかしくて……\nううっ♪　……ん？　ちゃんと感じていると？　亀頭を見ろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ！　このちょっと濡れてるのが気持ちイイって証拠なんですか？　かう\nぱー……？　さきばしりじる？　へぇええ……感じると濡れちゃうなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「女の子と似てるかも……。可愛いですね！　んふふふっ、もっと、もっと気\n持ち良くしてあげますよー♪　それっ、それ、むにっ、むにむにっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んんんっ？　小さく小刻みにこするのと、……んんっ！　大きく大胆にシゴ\nくのと……どっちでも喜んでるみたいですけど？　えっちなんですねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ガチガチのおチンポを、柔らかくておっきなおっぱいでこすられると……っ\n、天にものぼる気持ちでしょう？　あぁ、反応が良くて楽しすぎます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「もーっともっと感じてくださぁい♪　んんっ、んん～♪　強く挟んでぇ、ぐ\nにぐにぐにぃ……♪　あははっ、ピクピク止まんないですねぇっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「えっ？　出そう……ってなんですか？　出る？　何が出るんですか！？　せ\nいえき……？　なんか名前は聞いたことあるような無いようなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ニ、ニンゲンのおチンポのことはまだ勉強中で詳しくないんですよぉっ……\n！　わ、なんか、おチンポがまた太くなって……暴れてますっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「わ……わかりました！　何か出るなら出していいですからっ……！　あっ！\n　あぁっ！　力強くおチンポをこすりつけてこないでくださ……あぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「うわわっ……！？　おチンポから謎の白い液体が飛び出して……！？　な、\nなんなんですかこれっ……！　攻撃の一種にしては痛くないですし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ、で、でもどんどん撃ち出されてきますっ！？　あわわわ、ええっ？　\nど、どうすればいいんですか！？　胸で受け止めろ！？　は、はいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「谷間に溜めておけばいいんですね……っ！　わ、わわわ……！　なんかあっ\nたかい……っ。それに嗅いだことのない臭いがします……！　ううううっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルしてるし、んぁあ……っ。私の自慢のおっぱいがドロドロに……。\nこれがせいえきなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩の超巨大兵器を、私のおっぱいが限界まで気持ち良くして昂らせた\n時にだけ出るご褒美のお汁……？　つ、つまりエネルギー砲……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「私のパイズリで隊長先輩のおチンポにエネルギーが蓄積され、それが爆発し\nたということですか！？　お……おぉ、そ、それなら納得です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「そういえば精液……。聞いたことがあります。赤ちゃんを作る時に必要なモ\nノだったはず……。つまり、爆発的な生命エネルギーの塊っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「なるほど！　デカい武器からは大量に精液が出る、当然のことかもしれませ\nんねっ……。であれば、もう一度……私にチャンスをもらえませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はいっ。隊長先輩のデカすぎる武器……。まだまだ猛り狂って硬いままです\n！　仕組みがわかった以上、チャレンジせずにはいられません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「さっきよりも……。一度目の精液よりも、もっともっとたくさんのエネルギ\nー！　放出させてみせます！　私もおっぱいも本気出しますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「限界を超えて……おチンポを感じさせて、大きくさせてみせますっ……。そ\nれじゃ、失礼しますね……！　っんっ……ほら、まだやる気っぽいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「おチンポも、私のおっぱいをもっと味わいたいですよね～……。んんっ♪　\nうあっ……、精液のデロデロが、おっぱいにまとわりついて……んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「おチンポを上手にすべらせてくれてますっ……。あっ♪　ぁっ、な、なんだ\nかこっちまで気持ち良く……！　あっ♪　精液って便利ですねぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「このヌトヌトする感じ……、ぁっ♪　見た目にも、感触的にもエロっぽくて\n……。はぁ、はぁ、にゅるにゅるしてるとおっぱいが敏感になりますねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「この、妙に生臭い臭い、も……♪　慣れてくると、クセになるといいますか\n……。あっ、あぁ、やっぱりエロいですよ……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ふんっ、ふんんっ……♪　どうです……っ？　一度経験をして、パワーアッ\nプしたラヴリエータちゃんの覚醒おっぱいは……っ？　んんっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「動きがなまめかしくなってきてる？　ん、ふふふ♪　そうでしょうそうでし\nょう、実は……二度目のパイズリ、これ結構こっちも感じてしまいまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「みょ、妙に腰が落ち着かなくて……♪　いやらしい動きに自然となってきち\nゃい、ます……♪　んふっ♪　おっぱいを、くねらせていないと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「気持ちいいのが、一か所に溜まっちゃって……ちょっとどうにかなっちゃい\nそう、ですので……っ。あっ、うねらせてます……。あっ、んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……ん？　私が感じている方が、おチンポも反応する？　そ、そうなんです\nかぁ……。でも、ホント恥ずかしいので……あんまり見ないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「って！　恥じらったら反応してるぅっ！　……え、えへ……♪　そういう武\n器……なんですね。やだなぁ、パイズリ、照れちゃうなぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「わ、私のことは見ないでおチンポの感覚に集中しちゃってくださいよぉ……\n。気持ち良さ、まだ足りませんか？　んんっ、これならどうですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「むにゅううっ、ぐにゅううっておっぱいでおチンポ刺激し続けますっ……。\nあっ♪　またピクッて反応したぁ……。ちょっと感度良すぎですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「反応してくれるのは嬉しいですけど……。っんっ♪　隊長先輩、私が欲しい\nモノ……わかってますよね？　もうすぐそれが溜まりますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ああっ、ワクワクドキドキしちゃいますっ……。くださいっ、隊長先輩の一\n番スゴいの……私の胸にくださいっ、さあ、出してくださいっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ひぅあああっ！？　エネルギー放出ですっ！　爆発ですっ、爆散ですっ……\n！　うぁああっ、二回目なのにすっごい勢いぃい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「これは成功と言っていいのではぁっ……！？　あっ！？　私のパイズリっ…\n…一度目よりも上手くいきましたよねっ、だからこんなにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ♪　んっ、ううぅうっ……♪　おっぱいを押さえてもぜんっぜん\n止まりません……！　さすが隊長先輩の超ドデカ兵器ですぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ええ、ええっ！　どんどん放出してくださいっ、精液っ……たっくさん出し\nてくださいっ……！　あっ♪　あっ、胸にかけてくださいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　限界まで大きくなった巨大なおチンポからっ、溜めに溜めま\nくった精液エネルギーを放出してもらえるなんて、感謝ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んっ♪　私のおっぱいも、この対戦結果に満足してますよぉっ……！　んぁ\nああっ、すっごいです、真っ白な精液……こんなにいっぱいぃい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ふはぁあああ……♪　隊長先輩のドデカ兵器……たっぷり堪能させていただ\nきました……。素晴らしい勝負をありがとうございます……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「やっぱりですけど、大きいことって良い事ですよね……♪　いいことしかな\nいですよね……。いや、このおチンポをオマンコに入れるのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「正直ちょっと怖いですけど……。パイズリならこの巨大さだけを、気軽に楽\nしく体験できるって気付いたので……積極的にパイズリしますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「それなら私も隊長先輩のスゴい武器をじっくり見れますし、隊長先輩も気持\nち良くって……お互い得しかないですもんね、えへへへっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ、出ました……っ♪　って、わぷっ！？　飛距離がスゴすぎてっ……！\n　隊長先輩ぃいっ！　胸じゃなく顔にかかってます、わ、飛ばしすぎぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「えっ！？　ええええっ！？　おっぱいに溜まるくらいに出してくれただけで\n感動してしまったのに……あっ、ぷっ、勢いまで増しますか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「伸びしろありすぎですよっ……。っていうか、底が知れません、隊長先輩の\n本気が恐ろしいですっ……！　あっ、ぁっ、ネバネバしてますぅうう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あひゃっ！？　油断したところに一撃っ……！　あわわわっ、こんなにかけ\nられたら取れなくなっちゃいますよ！　あっ、熱いですっ、臭いですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、喋っていたからお口にもちょっと入っちゃいました……！　ふぁ\nあああ、苦いぃいいい……！　なんでこんな味なんですか、精液ってぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あぅっ、んぅっ、ん～～～～～っ……♪　あああああ、顔にまと\nわりつく精液の、このもったり感……。忘れられないこの感触……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「でもっ……！　はぁ、はぁ……♪　どうです？　一度目よりも二度目……！\n　私のパイズリの技術が上がったと思いませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩のドデカいおチンポもスゴいですけど、私だってそれに追いつける\nよう、努力は惜しまないつもりです！　ああ……巨大兵器……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩のドデカ武器にふさわしい、ドデカおっぱいになれるよう……これ\nからも精進しますので、ぜひともお付き合いをお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「え？　武器だって言っておチンポを見せたことは怒らないのか、ですか？　\n実際に大きかったので問題ありません。見られて良かったと思ってますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}