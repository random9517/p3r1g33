{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "059_0104101" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あ、あの、隊長。ここで、ですか？　いえ、嫌というわけではないのですが\n、誰か来るとも限りませんし……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104102" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「え？　じゃあやめるって……そんな。ここまで準備しておいて、今さらそん\nなこと言うなんて、意地悪です」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104103" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「そもそも、隊長は昔からそういうところがありますよね。おかげで、小官は\nいつもいつも苦労させられて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104104" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「今でこそ平気ですが、卑猥なプレゼントをされる度に、どれだけ小官が恥ず\nかしかったか、おわかりですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104105" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「なのに、いざとなると小官の気持ちに気づかないふりをしたり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104106" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「今回だって、小官が覚悟を決めて参上したら、やっぱりやめるだなんて、本\n当に隊長は意地が悪すぎます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104107" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「だからお願いです、隊長。小官に、隊長を感じさせてください。一番深い場\n所で、隊長を、感じたいのです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104108" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あ！？　ん、んんん、ああ！？　入って来た。入って、来ましたぁ。あ、あ\nやっと……んんん！　ずぶぅって、奥までぇ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104109" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「は、はい、嬉しいです。だって、隊長殿を、一番深い場所で感じられますか\nら。小官の、一番、深い場所、でぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104110" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああ！？　動いてるぅ。んん～！　隊長の、ペニスが、小官の中、\n出入りしてぇ……はううぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104111" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「それに、後ろから抱きしめられたら、隊長の匂いが……血と、硝煙の匂いで\nす。戦場の、匂い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104112" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「後ろから、ずぶずぶ、突かれて……それと一緒に、硝煙の匂いが、感じられ\nてぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104113" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「はうぅぅ！？　感じ、ます！　お腹の奥が、疼き、ます！　ずぶぅって、入\nって来て、ごりごりって削りながら出て行ってぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104114" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「そこに、硝煙の匂い、包まれてぇ……ああ、あ、ふあぁ。ぞくぞく、止まり\nません。頭、真っ白になるぐらい、感じ、ますぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104115" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ひうう！？　た、隊長の、ペニス、大っきくなった！？　中で、大っきくぅ\n！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104116" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「嘘！？　まだ、大っきく！？　そんな、大っきいペニスで、中、あ！？　あ\nああ！？　ひうううう！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104117" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「す、凄い、です……凄、い、凄すぎるぅ。ぐぼぐぼって、エッチな音、して\nますぅ。小官の、あそこから、卑猥な、音がぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104118" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「それに、どんどん、エッチな匂いも、濃くなってきてぇ……ふあああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104119" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「隊長の、硝煙の匂い、と、エッチな匂い、混じって、どんどん、頭、痺れる\nぅ。身体中が、痺れて、来て、ますぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104120" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「隊長！　隊長！　隊長！　もっと、ください！　もっと、してください！　\nペニス、奥までぇ！　思いっきり突いてくださいぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104121" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「ひああ、あ、ああ、ああ！？　乱暴に、なった！？　腰の動き、乱暴にぃ！\n　ペニスが、あちこち、中、擦るぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104122" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「いえ、やめないでください！　そのまま、続けて欲しい、です！　もっと、\nもっと、隊長を、感じさせて、くだ、さいっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104123" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「もっと、隊長の、ペニスと……あぁぁ、エッチな、匂いぃ。青臭いのと、硝\n煙の匂いが混じった、匂いぃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104124" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「頭も、お腹の奥も、全部、全部、ずきずきって疼いてぇ……痺れるぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104125" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「このままだと、小官は……小官、は、もう！　もうぅ！　んんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104126" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んああ！？　隊長のペニスも、また、びくって震えながら、大きくなってる\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104127" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「それに……あ、あ、あ、あ、あ、あ、あ！？　動きも、どんどん、激しく、\nなって、きてぇぇ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104128" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「もしかして、隊長も……？　あ、あは！　じゃあ、一緒に！　お願いです、\n隊長、一緒にぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104129" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅ、ん！　んんんんんん！　来る！　来ますぅ！　気持ちいいのが、お\n腹の、奥、からぁぁぁ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104130" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「イクぅ！　イクイクイク！　イキ、ますぅ！　隊長！　隊長！　隊長！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104131" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あああ！？　んああああああああ！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104132" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「あんんんんんんんんんんんんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104133" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「はう、はうう！？　イッてるところに、精液がぁぁ！？　熱い！　熱いぃぃ\n！　はうんんんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104134" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「んああ、あっ、はぁ、はぁ、はぁ……ふあぁぁぁぁぁぁぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104135" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「い、イキ、まし、たぁ……小官、隊長の、ペニスと、体臭で……硝煙混じり\nの体臭で、イって、しまい、ましたぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005901_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104136" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「は、はい、気持ち、良かった、ですぅ。こんなに、激しく、イッた、の……\n初めて、でぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104137" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「まだ、頭、ぼーっとして、ます。それに、身体、力、入らない、ですぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104138" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「お腹の、中、たぷんたぷん、で……暖かいのが、赤ちゃんの部屋、いっぱい\n、ですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104139" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「こんなにたくさん、精液、中出しされたら……妊娠、しちゃうかも、しれま\nせんね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "059_0104140" ]},
		{"command":[ "SETNAME", "筒井隊員" ]},
		{"command":[ "SETTEXT", "「もしそうなったら、ちゃんと、責任、取ってくださいね……隊長。ふふふふ\nふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}