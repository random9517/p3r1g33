	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃ～～ん♪　来たよー、この部屋でいいのかなっ？　あっ、いたいた\nー！」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "PLAYVOICE", "v2_190_0104101" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んもー！　今夜は二人で晩酌しようって約束してたのに～。いなくなるから\n、びっくりしちゃったよ。それで……ここで飲むの？　違うの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104102" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ま、おねーさんは隊長ちゃんとイチャイチャ出来たらなんでもいーんだけど\n……って、あっ……♪　そ、そっちはベッド……だけど？　んっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あははは……。そっか……隊長ちゃんがしたいこと、わかっちゃった。晩酌\nとかじゃなくて……こっち？　そっか、そっか……。いーよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私も、そろそろ……ね？　こーゆーロマンチックな……？　オトナな展開、\nあってもいいかなーって思ってたから……ジャストタイミングだったかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104105" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ……。脱がすの？　へへへー……いいけどー……♪　だったら、私も隊\n長ちゃんの服、脱がしちゃうよー？　ズリズリー……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104106" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「すご……♪　もうこんなになっちゃってるんだ……。ふふふ、ズボンがひっ\nかかって脱がしにくいよ……。で、も……もうすぐ……。ごくっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104107" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ひゃ……、やっぱりぃ♪　ギンギンで、天井向いてそそり勃ってるぅ……。\nんっ……こ、こんな凶悪なの見せつけられたらおねーさん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「濡、れてきちゃう……。ね、準備とかいらないから……すぐに入れて？　愛\n液のシロップ足りなかったら、お、おっぱい揉んでくれればすぐだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……あっ、た、隊長ちゃん……♪　隊長ちゃんの逞しいの……\n私のおまんこに……って、あっ♪　こ、こらっ、すりすりしない、で♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019001_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
	{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「焦らさないで入れてよぉ……！　おちんちん、おまんこの入り口になすりつ\nけてニュグニュグするだけなんてー……あっ、せ、切ないから、やだー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ……あっ、も、もぉ……！　入れてーっ……い、入れ、てよ…\n…お願い……。おねがい、おあずけしないで……待ってるのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……入れてくれる？　あはっ、嬉しい……。ん……。そう、そこ……その穴\nにズブって……。あっ……そう♪　そう、そのまま……来てぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ンッ、んんんんんん～～～～♪　んああああ♪　入っ……入っちゃった♪　\n奥、まで……おねーさんの一番奥の奥までズボッってきちゃったああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ……ひぃん♪　あっ、あっ、あ……おちんちん、硬くて大きくて……入\nっただけなのに、みゃ、脈打ってるのわかって……好き、か、も♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「なんかね？　なんかね……？　隊長ちゃん、の……これっ、このおちんちん\n、私のにぴったりなの……すんごくしっくりきちゃって……あああッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「頭の中♪　ピンクになっちゃ、う♪　セリカおねーさん……おちんちん好き\nになっちゃう、大好きかも、好きかも……も、っと……もっと知りたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんちんのこと、もーっと知りたいぃ……♪　あっ♪　とん\nでもない長さ、で私のアソコの中一突きにしちゃってる、し………あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「中がぐーって拡げられてるの、わ、かるんだよ～……。これって容量いっぱ\nい、限界～ってこと、だ、よね？　私の中いっぱいいっぱいで……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ゆっくり……ゆっくり動かしてみてぇ♪　あっ……そ、そう♪　そう、やっ\nて……中っ……♪　あー……なんかひっかかってる、そこ、そこぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃぁんん♪　おちんぽのでっぱったとこ♪　私のイイとこにぴったり\n合ってるぅ……感じるとこ、ぐちゅぐちゅしてる……はぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「そ、うなんだ♪　こういうことなんだぁ♪　セックスっ……セックスする時\nっ……女の気持ちいいとこ、男のおちんちんがひっかくんだぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「う、ん……っ、うん♪　うんうん……♪　生命の神秘ってスゴ……いぃ♪　\n快感♪　計算されつくしてるぅう……それとも、隊長ちゃんがすごいのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんちんが特別イイの？　女の感じるとこ、狙う悪いおちん\nぽなのぉお？　あっ……すごっ、すご、すご、すごいぃいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「まだにゅくにゅく、にゅぷにゅぷゆっくりしてるだけなのにぃいい……ああ\nあああ♪　脳天にビリッ、ビリッてくる……快感があがってくる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「こんな状態で、全力出されたら……本当にどうにかなっちゃうかも……あっ\n♪　おちんちん、強すぎだよ……これっ、本能に訴えかけてくるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……んん？　私のおまんこも名器だって？　あり、がと……♪　おちんぽ包\nみこんで、あったかくて、ヌルヌルで最高？　やーだほめ過ぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「で、も♪　それも私が隊長ちゃんを好き、なのと……このぶっといおちんぽ\n、おちん、ぽが最強すぎるせい……それに反応しちゃってるんだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「それとも私達……セックスの相性がいい、のかな……？　だったら嬉しいね\n……。あっ……んぅう、なん、か……またじれったくなってきちゃっ、たぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「も、う激しくしていいよ……あっ♪　ゆっくりするのも、脳みそとけてくみ\nたいでイイんだけど……私、私、おちんちんの本気、知りたくなっちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「名器おちんちんで全力出してずっぽんずっぽんしてくれる？　う、うん……\n私、も♪　私も上手くできるかわかんないけど動く、から♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「腰揺らすからリードについてきて……♪　ッ……あはっ……♪　あぁっ♪　\nああっ♪　あっ♪　あっ♪　やぁだぁ♪　恥ずかし……この動きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「男の人誘って腰振ってっ……馬鹿みたいだけど……んあああっ♪　それがク\nるの、気持ち、いい♪　気持ちいい♪　あっ、隊長ちゃん隊長ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんぽ、どんどん激しくなってきたぁ♪　んあああああッ♪\n　あーっあっ♪　ひぃいっ！　こんなに！？　こんなにイイのぉおお！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「常軌を逸してるぅうう♪　名器おちんぽ、私のおまんこを一瞬で虜にしちゃ\nった、下剋上しちゃった、あっ、自分のモノにしちゃったぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっあぁっ♪　あぁっ♪　あぁ、あぁっあぁっ♪　気持ち良すぎて……上手\nに腰が揺らせ、ないよ、こんなの初めて……ハマっちゃうよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おまんこ♪　気持ちいい……おまんこすっごい気持ちいい♪　脳内快楽物質\nバンバン出ちゃう、分泌してる……んあああっ！　あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んっ！　し、締めつけすぎぃ？　そんなこと言われても……わ、かんないよ\n、自分で操作できないのぉ！　勝手におまんこすがりついちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんちんしぼっちゃう、絞りあげちゃうぅ……！　んあああ\nっ！　だってそれが、女の本能だもんんっ、あぁ、離したくないもんん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……ん、え？　おまんこ良すぎてぴゅっぴゅしちゃいそう？　い、いいよ、\nまずは一回……かるーくぴゅっぴゅして、あっ、私もイク……からっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んぅうううううう♪　あふぅっ、んふーーーー♪　ぴゅっ♪　ぴゅっ♪　ぴ\nゅっぴゅしてる、ぴゅっぴゅしてるぅうう……んあああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「い、きなり中出しぃ……っ♪　男らしいよ、かっこいいよ隊長ちゃんん♪　\nあぁ……私のおまんこの中でトクトク、トクトク流れてくる……ぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あ、つい……熱い粘液たまんないぃ……♪　これが中出し……初めての、一\n生一度初めての生中出しなんだぁ……思ったよりも……アソコに響くぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ……あっあっ、あはっ……あぁ……♪　ねえ、まだ抜かないでね？　今\nのはお試しのビューでしょ？　次が本番、全開のビュッビュだよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、はぁっ♪　おねーさん……セリカおねーさん、今の中出\nしでスイッチ入っちゃった。お試し射精でじゅわじゅわキてるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「このまま……このまま、隊長ちゃんとぬっちょぬっちょのぐっちょぐっちょ\nして♪　おまんこの中の精液かきまぜてもらうの、それで、それで……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「今度こそ、孕ませのビューしてもらうんだから♪　……うんっ、そうと決ま\nったら……ああっ♪　こっちもペースあげてくよ、ついてきなさぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、あんっあんっ！　ンッンッんっんんっ！　んふぅっ♪　んん\nっ♪　んんっ、んん……！　もっと強く脚掴んで、広げて、体重かけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「全身っ……で私のおまんこ貫いて、容赦なく串刺しにしてぇ♪　んぅ\nうううーーーっ♪　そぉ♪　一番おくぅうううー♪　えぐってぇ♪　ひぃい♪\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっぐっ、んっぐぅっ♪　んひぃいっ、ひぃっ♪　先出し精液のニュルニュ\nルが……ぁ、おまんこの中で絡まって、広がって、塗りつけられてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おねーさん頭チカチカするぐらい夢中になっちゃうっ、あーーー♪　隊長ち\nゃんの精液って媚薬♪　みたい、私に効くぅ、盛り上がっちゃう～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んふぅうっ♪　ふーっ♪　ふぅうっ♪　あっ、快感でカラダっ、燃え上がっ\nちゃう……はしたなく腰振って、ケダモノみたいに貪って……あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おねーさん、さすがに恥ずかし、い♪　恥ずかしいのにやめられないぃ……\n！　見られたくない、けど、見てほしい……複雑だよぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おまんこも、喜びすぎちゃってウネウネ動いて……あっ、濡れすぎて雫がぽ\nたぽた落ちちゃってるし……私、本当にエッチ好きなのかも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「エッチすぎなセリカおねーさんのことっ……嫌いにならないで♪　いっぱい\n気持ち良くするから……あっ、見逃し、て♪　それで、それで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「興奮してくれたら、このおまんこの中っ……このアツアツおまんこの奥にド\nクドク精液おくりこんでほしいの♪　本気のお汁ぶちまけてほしい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んんんんー……ああ♪　おねーさん♪　おねーさん……もう♪　もう、隊長\nちゃんのおちんちんのことしか考えられな……い、だめ♪　だめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「正直に言って、イ……イキそうだよぉ♪　イ……っちゃう♪　イッちゃうぅ\n♪　ねぇえ♪　イクときご褒美ほしいの、ご褒美ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんの本気の精液っ、セリカおねーさんのおまんこに出して♪　欲し\nい……の、欲しいから、こっちも本気で……、んんんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おまんこうねらせて、おちんちん絞るから♪　だから……ちょーだい♪　お\nねーさんのおまんこ……あっ、もう限界♪　今だよっ、今ちょうだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んふぅううううう～～～♪　キ、てる、来てるぅ……本気の二発目……！　\nあぁあああッ♪　耐えられない、イッ……くぅ、イクぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ああああッ♪　隊長ちゃん！　隊長ちゃんの本気っ、本気ひゅごいぃ……っ\n♪　ドクッ、ドクッ……奥の奥に……赤ちゃんの部屋にかかってるよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「やぁっ……妊娠♪　妊娠しちゃう♪　でも……やめてほしくないのっ……！\n　ぜーんぶ、ぜーんぶ出してほし……い、あっ……あったかい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んーーーーー♪　美味しいよぉ、隊長ちゃんの全力の中出し、染み入るぅ…\n…。んんっ……あは、まだ出てる……元気元気ぃ、誇らしいねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「わかる……？　おねーさんのおまんこの中……隊長ちゃんの本気のお汁でた\nっぷたぷだよ……。あっ、動かないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ちょっとでも動いたら……あっ♪　腰をズラしたら、溢れちゃう……から…\n…♪　しばらく栓してて、そのままぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……ううううう♪　今ね、背筋が……カラダがブルブルゾクゾクしちゃった\n。大好きな隊長ちゃんと大好きなエッチして、中出ししてもらって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「それって最高に幸せなんじゃないかって思ったら……へへへ。なんか笑い、\nこみあげてきちゃって……。でも、笑っちゃダメだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あはっ、あははは♪　やだ、漏れちゃう、漏れちゃう……！　隊長ちゃん、\n出し過ぎなんだよー……♪　出してって言ったの、私だけどねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ここまでの量、もらえると思ってなかったからラッキーハッピーだなぁ♪　\n１００点満点……ううん、１万点の完璧なエッチ、ありがとね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「やっ、ああああっ……！　なんで抜いちゃうのぉ！？　あっ……も、戻って\nきてっ、だめだよ別のとこじゃあっ……きゃぁんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっ！　そんなぁっ……なんで外に……！　んんんッ！　ひゃうっ、だめ、\nかかってるっ、かかってる、けど……！　んーっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ああああ……！　隊長ちゃんの、隊長ちゃんの貴重な本気の精液がぁ……、\n私の中に入ってきてくれなかったよぉ、それに、それに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あっんっ！　服とかにかけるのはナシだからぁ……！　あっ！　どうせなら\n、裸のとこにかけて……っていうかアソコに、おまんこにかけてよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あんんっ……んっ……んううう……！　すっごい……！　プルプルでビチャ\nビチャの精液……量も熱さも完璧なのにぃ……あつぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「最後の最後で特大の裏切り行為だよ～！　私……私、超期待してたんだよ！\n？　おねーさんのおまんこの中、きゅうきゅう切なくて泣いてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「一回中に出したでしょって……そ、そうだけど！　もっと欲しかったの！　\nんぅ……外出しも気持ちいいけど、新感覚で悪くないけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「空振りしちゃったおまんこがウズウズしっぱなしだし……。そのくせこーん\nなにいっぱい出すんだもん！　ちょっとくらい中で欲しかったの～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ぐすん……。身体がニュルニュルになるのは……まあね？　イヤじゃないし\n……新鮮というか新感覚だけど……でも、でもー……うー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ネバネバが肌にはりつくし、ニオイもキツいしー……。っていうか！　やっ\nぱり中に欲しかったぁ！　艦長命令にすれば良かったかもー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_0104410" ]},
