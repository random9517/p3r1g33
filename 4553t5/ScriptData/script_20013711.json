{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「きゃぁぁぁぁぁぁぁぁーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よぉしっ、ヒットしたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヒットしたけど、壁にも当たって……く、崩れるっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まずいですぞ、ご主人！　この揺れはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……なに……？　ふむ、そうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、ルナテミスっ！　何をボーっと突っ立ってるんだっ、崩れるぞ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「案ずるな！　こっちに来いっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こっちって……さっき入ってきた所とは逆……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こちら側にも出口があるらしいっ、行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ……お、おぉいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こちらだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「揺れがどんどん大きくなってきた！　かなりヤバいぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「大丈夫ですかな……インクレディブル・スクワッドの皆さんもまだ中に……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おーーーーいっ、主殿っ……ルナテミス殿っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おお、イグニス！　大丈夫だったか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うむ、白熱した戦いだったのだが、そう言ってられる事態でもなくなったよ\nうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「あっ、いた！　おーいっ、こっちこっちー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「皆さんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ミラ！　ルシオラも無事だったかっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「なんとかねっ！　でも、話は後っ……とにかくここから出ないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「すす、すみませんっ！　私のせいでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？　よく分からんがっ、とにかく急げっ！　崩れるぞっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「分かっている、こっちだ。早く行くぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650007" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当に外に出られた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……ふはぁー、危機一髪だったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ、なんとか一命をとりとめましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「鎧が教えてくれたのだ。こちら側が一番近い道だとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650008" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「鎧が……そう言えば、途中までずっとしゃべってたけど……今も、会話出来\nるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、私が身につけてからは、全く口を利くことはないな。ただ、さっきの\n出口は、頭の中に直接伝わるように知らせて来た感じだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へぇ……しかし、まぁ、見事に崩れちまって……いいのかな、これ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「す、すみませんっ……！　私のせいで大変なことに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきも言ってたけど、何かあったのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「こっちはまぁ……ほら、ニンジャの二人とバトルしてたじゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022650004" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、露出度の高い姉ちゃん達二人か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「姉ちゃんが、やっぱりあのカッコ恥ずかしかったみたいでさ……相手が、そ\nれに付け込んで精神攻撃を仕掛けてきて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022650005" ]},
		{"command":[ "SETCHARA", "0", "char_00017002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「精神攻撃……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「いいおっぱいしてるねぇーとか、もうちょいではみ出そうとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022650006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「その……余りにも恥ずかしくて……かくなる上はと、遺跡の中で大爆裂魔術\nを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022650004" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あぁ……なるほど。まぁ大丈夫だ。うちの姫さんは、最初から何も考えずに\n似たようなことしてたから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「崩れるべくして崩れる運命だったということですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022650004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何にせよ、与えられた使命である、古より伝わる伝統の鎧を入手できたのだ\n。成果としてはこれ以上のものはないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650010" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ……ビキニアーマーＶＳビキニンジャ、今日のところはビキニアーマー\nの勝利ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022650005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。ビキニアーマー隊、見事任務達成だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022650011" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「清々しい勝利だな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00016703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「完全にＢ級映画のタイトルじゃねぇか……てか、いつ出来たんだよビキニア\nーマー隊……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぅ……もう着替えたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022650005" ]},
		{"command":[ "SETCHARA", "0", "char_00016902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0191" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぁ、はぁ、はぁ……うぐ……死ぬかと思ったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いやー、参った参った。流石に、こんな場所で生き埋めにされるのは勘弁だ\nからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「ちょーっと、弄り加減を間違えちゃったかね。あそこまで、バーサークされ\nるのは計算外だったかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「何とも脆い遺跡だった。興が削がれてしまったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……ぐぬぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずいぶんとご機嫌ななめだな。まぁ、仕方ないさ。恥ずかしくて動けないな\nんてのは自分の問題だ。己で解決するしかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「言われなくても分かってますっ！　今日の不覚……絶対に、何倍にもして返\nしてやりますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022650004" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「ふはっ……頼もしいこって。なら、暫くはビキニンジャスタイルに慣れる為\nにそのままって感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「そ、それは……くぅぅぅっ……知りませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022650005" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ま、せっかくここまで来たんだ。最後は軽く遊んで帰るとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「お、いいねぇ。何と言っても泳ぎ足りない感じだったし。セレーナ、泳ぎは\nどうなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022650003" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「遠泳には心得がある。勝負なら受けて立つぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022650002" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「おっし、じゃあひと泳ぎしようぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022650004" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほれ、しけた顔してないで、行くぞオボロ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022650004" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「…………はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022650006" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}