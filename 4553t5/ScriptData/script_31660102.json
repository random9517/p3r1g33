		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ……とうとうしちゃうんだ。色々えっちなことされてた時から……きっ\nとこうなるって思ってたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ……やっぱりいざってなると、ちょっと緊張しちゃうかも……でも、\nお兄さんなら優しくしてくれるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104102" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「もう、私の準備は出来てるよ……うん、オマンコも……中……じゅくじゅく\nになっちゃってる感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「からだ……ちっちゃくなってるから、入り切るか心配だけど……でも、キツ\nキツな分……気持ちよく出来ると思うよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うん……もう我慢出来ないから……入れちゃう……ね？　んっ、腰……落と\nしちゃう……からぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、はっ、あぁぁぁぁぁぁぁっ……くぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あっ、ふっ……入ったぁっ……あぁぅ……オチンチン……根元\nまでずぷって……してるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……んっく、おっきい……けど……熱くて……ヌルってして……ちゃ\nんと、ハマってる……かもぉ……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんんっ……入った……よっ……お兄さんのオチンチン……オマンコの中に\n、全部……埋まってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……動いてないのに……お腹いっぱいになってて……でも、ダメだよ\nね……これだけじゃ、意味……ないんだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、オチンチン……気持ちよくなってもらって……ドピュって……射\n精してもらわないと……んぁふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うん……そろそろ、大丈夫だと思う……お兄さんは、じっとしてて……私が\n動かしていく、からぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あっ、はぁっ……んっ……あぁっ……こうしてっ……腰ぃ……\nぐりぐりっ……回してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ひぁっ……んっ、あ、ひっ！　んっくぅぅぅ……うんっ……あぁっ、こ、擦\nれるぅ……太いオチンチン……当たってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、でも……もっと痛いと思ってたけど……全然平気……じわって、痺れ\nる感じで……ちゃんと、気持ちいいかもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、んっ、ねぇ……どう、かな……？　お兄さん……ちゃんと、\nオチンチン……気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そりゃあ……気になるよぉ……だって、ヘタだったら……もうこれっきりで\n……いらない子になっちゃうかも知れないじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「そんなことしないって言っても……結局、オチンチンは正直だから……自然\nに呼ばれなくなっちゃうなんて……そんなのヤダもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「でも……んっ、今のとこ……その心配はないのかな……？　ふふっ、お兄さ\nんの顔……ちゃんと嬉しそうになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっく……いいよぉ……もっと、気持ちよくしてあげるぅ……んっ、ふっ、\nんくっ、んふっ、はっ、うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ほらっ……どぉっ？　オマンコが……んっ、出たりっ……入ったり\nしてるのぉ……見えるでしょぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ぬぷって……んふぅっ、やらしくてぇ……恥ずかしい音してぇ……どんどん\n気分が出てきちゃうのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ、んっ、腰回しちゃう……んんっ、はぁぁ……オチンチン…\n…ぐりぐりぃ……擦れるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、すごい……オマンコもぉ……どんどんヌルヌルになって来ち\nゃう……お汁……溢れて止まらないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んぁっ、お兄さんもっ……動きたくなっちゃってる……？　んんっ、い、い\nいよぉ……下から……ずんって突いてもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ぐちょぐちょになってるオマンコぉ……お兄さんのオチンチンで、いっぱい\nっ……ぐいって突いてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁーっ！　これっ、あっ、効くっ……んんんっ、太いのっ、気持\nちいいトコに擦れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁぁんっ、お兄さんの本気ピストンっ……すごいっ、はひぃっ、\nあぁっ、オマンコっ、感じるぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、締まってるっ？　んっ、はぁおっ……ダメ……あぁっ、この\nまま一気にイッちゃうかもぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「一番奥のトコっ、こつこつくっつけるのっ……んひっ、気持ちいいのっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁっ、んっ、こんな短い間にっ……お兄さんのオチンチンに……オマンコ\n開発されちゃってるっ……んぁぁっ、いひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あっ、んくぅんっ、中でっ……オチンチンビクビクしてるっ……これっ、も\nうすぐっ……なんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「出ちゃう……？　んんっ、気持ちいいの、いっぱい出ちゃうっ？　来てっ…\n…出してっ……はぁっ、びゅびゅってしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「私もイクからっ、お兄さんと一緒にっ……イッちゃうからっ、もっと、ずん\nずんしてっ、はぁぁぁっ、あっ、もぉぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁーーーーっ！　入ってるっ……んんぅっ……熱いのっ、\nびゅくびゅくんって……中にっ……出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……オマンコ……どぷって来てる……はぁぁぁんっ……私も……イ\nッて、るぅぅぅ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あっ……ふぁっ……あぁ……すごい量……オマンコ……飲みき\nれなくて……溢れちゃってるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁぁ……まだオマンコずっとジンジンしてる……オチンチンがみ\nっちり擦れたままで……気持ちいいのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、ねぇ……んっ、私のオマンコ……ちゃんとご奉仕出\n来たかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふっ、よかったぁ……私も……お兄さんのオチンチン……いっぱいハマっ\nちゃったかもぉ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、中でまたピクってしてる……ふふ……まだまだ終わりたく\nないって思ってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ううん、そういう言い方はずるいよね？　ホントは私の方が、まだ終わりた\nくないなーって思ってるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ほら……今も、オマンコ……ひくひくってしてるの、分かるでしょ？　この\nまま、オチンチン抜かないで……続きして欲しいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「だから……もっとオマンコしていい？　私も……もっと頑張って……オチン\nチン気持ちよくしてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あんっ、んふっ、おっけーだね。じゃあ……このまま２回目ぇ……はっ、ん\nふっ、はっ、うんっ、んくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……この……奥までズッポリされてる感じぃ……はぁぁ……病みつ\nきになっちゃいそぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「オマンコのなかっ……精液でヌルヌルにしてくれたから……はぁっ、ずりゅ\nって滑って……あぁぁー、いい感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はっ、もっと……動くねぇ……はっ、ふっ、んくっ、あっ、あ\nぁっ、はぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、ふっ、んくんっ……あぁっ、声……出ちゃうっ……あぁん\nっ、全然っ……我慢……出来ないよっ、これっ、はへぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、そこっ、あぉぉっ、オチンチンでっ……グリグリされてるのぉ\nっ、オマンコっ、オマンコの奥ぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「やっ、はぁぁぁんっ！　こんなっ、ずりゅずりゅされたらっ、もっ、すぐイ\nッちゃうっ、オマンコダメになっちゃうぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫ってっ……大丈夫じゃっ、ないよぉっ、あぁっ、もっとっ、あっ\n、ちゃんと……リードしてあげなきゃっ、なのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「こんなっ、こんな風にされたらっ、私っ……あんっ、ダメになっちゃうっ、\nはぁっ、んっ、お兄さんのことっ、からかえなくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんっ、いいのっ！？　メロメロな私も……いいってっ……そんなっ、こと\nっ、言われたらっ……あぁっ、ホントにわらひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、してるっ……オマンコひくんってなっちゃうっ！　だってっ、オ\nチンチンでいっぱいされて嬉しいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「お兄さんと一つになってっ、あっ、気持ちいいトコぐちゅぐちゅこすり合わ\nせるのっ……好きっ、好きぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ？　お兄さんもっ、喜んでくれてるっ？　ならっ……んんっ、\nいいっ、けどぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンチンがビクビクって！　また出たがってるの分かるぅっ、い\nいよっ、もっ、我慢っ……しないでっ、はっ、んぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ひぁっ、私もイクっ、またイクからっ……はひっ、一緒っ……一緒がいいっ\n、お兄さんと一緒にイキたいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「だからっ……んぁんっ、来てっ……新しいのいっぱい出して！　お兄さんの\n精液っ……びゅびゅって全部射精してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅんっ！　出てるっ……んんっ、お兄さんのっ……新しいのがっ……\nまた、オマンコ……届いてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「びゅくびゅくって……熱いの……蕩けて……はぁぁぁ……んんっ、中……い\nっぱいで……妊娠しちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、イクっ……またイッてるっ……んんっ、オマンコ幸せにイ\nッてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……まだ中出し終わってない……もう、入り切らないのに……お兄\nさん、絶倫過ぎるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁぁ……はぁ……はぁ……終わった……？　よかったぁ……これ以\n上されたら、精液お漏らししちゃうとこだったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んっ……えっとね……お願い……このまま、暫くの間……こうしてて欲しい\nかな……なんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うん……ぎゅってくっついていれば、それでいいの。今まで……こんな気持\nちになったことなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふ……お兄さんの胸……おっきくて安心する……私……ずっと逃げてるば\nっかりだったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「でも、お兄さんなら……任せちゃってもいいって……そんなこと……思っち\nゃったりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「えへへ……重い、かな？　でも、私……お兄さんにもうベッタリだから……\nこれからも……よろしくね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ、あぁっ……あぁっ……どうしたの……んっ、からだ……掛け\nたいのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「うんっ、いいよっ……私も……お兄さんの精液浴びたいっ……からだ、ベト\nベトのドロドロにして欲しいからっ……掛けてっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁぁんっ！　出てるっ……あったかいのっ……びゅくびゅくって\n……いっぱい……出されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んんっ、私もイクっ……精液ぶっ掛けられてっ、はぁぁぁんっ、イってるっ\n、オマンコっ……幸せにイッてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……はぁ……もうすぐ終わりそう……？　ちゃんと最後まで出してね\n……オチンチンくっつけて、拭いちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「はふぅ……あぁ……精液まみれになっちゃった……中からも外からも……お\n兄さんの匂いでいっぱい……だよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00016601_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ふふ……ちょっとだけ、こうしてていい？　お兄さんの匂いに……包まれて\nたいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「でも、すごかったぁ……こんなことされちゃったら、もう私……完全にお兄\nさんにメロメロになっちゃうよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ね……最後、一緒にお風呂入ろ？　ちゃんと背中流してあげるから……ねっ\n、ねっ？」", "NORMAL" ]},
