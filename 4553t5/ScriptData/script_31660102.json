		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「また、したくなったらいつでも言ってね。私も……いつでもおっけーだから\n……ふふっ」", "NORMAL" ]},
