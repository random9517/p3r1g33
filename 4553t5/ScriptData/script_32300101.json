{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さて……ここでしたら、一切の邪魔が入ることなく、じっくりと楽しむこと\nが出来ますわ、ダーリン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「イルルがたくさんお世話になっておりますし、私も妻としての務めをしっか\nりと果たしていかないとならないと思いまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「くすっ、そう緊張なさらなくて結構ですわ。ダーリンは、ただリラックスし\nて、私の肉体を堪能していただければいいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「そうですね……例えば、イルルでは中々難しいこちらなどはいかがですか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ……はい、どうぞご遠慮なく、この胸の中……ええ、私のおっぱいに\nダーリンのオチンポを挿し込んで下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……はい、ずっぷりと……中に……はぁぁんっ……んふふ、もうコチ\nコチで……とっても逞しいオチンポですわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「それで、私のおっぱいの中はいかがですか？　中々自分ではどの程度のもの\nか勝手が分からないのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あ、ふっ……どうやら、ちゃんと……気持ちよく感じて下さっているようで\n……何よりですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「それでは、本格的にパイズリを始めさせていただきます……んっ、あふっ…\n…んっ、んむっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「左右のおっぱいを手で支えて……ぎゅっと強く内側に押し込む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「熱くなったオチンポにめり込ませるようにして……ぎゅっ、ぎゅっと……続\nけてしてあげると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、腰が踊ってしまいますか？　何とも可愛らしいオチンポですわね…\n…もっともっと気持ちよくなって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「続けて、おっぱいを……大きく上下に……滑らせて……はっ、んんっ……オ\nチンポの剥けている部分と重ならせる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ……！　ふふ……このピリッとする刺激……私の方にもちゃんと気持ち\nいいのが伝わって来ますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「今のをもう一度してみましょうね……んんっ……あふっ、うんっ……んんっ\n……ふっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「いかがですか……私のおっぱい……楽しんで頂けていますか？　あふっ、良\nかったです……オチンポが返事をしてくれていますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「これだけ可愛い反応を見せて下さいますと……もっとオチンポに悦んで頂き\nたいと……そう思うようになりますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ、んっ……んふぅぅっ……ふふっ、オチンポに息が掛かると\nくすぐったいでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「分かりやすくオチンポを浮かせて……とっても可愛らしいですわ……ふぅぅ\nぅっ、んっ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「改めてこうして鼻先を近づけると……とても扇情的なにおいがします……す\nぅっと息を吸い込んで……あぁっ、ダーリンのオチンポのにおい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ……んっ、はふっ、こんなオスの強いにおいを嗅がされたら……私も\n、もう我慢が出来ません……失礼いたしますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁんむっ、あむっ、ちゅぱ……れろ、ぺちょ……ちゅぽっ、んちゅぷっ…\n…えろっ、れろぉ……んりゅっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もう少しじっくりとも思いましたが……どうせおしゃぶりもする予定でした\nから、前倒しになっても仕方ありませんね……れろ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ええ、お口でも……ダーリンのオチンポ……愛でさせていただきます……ぴ\nちゃ、んちゅぷっ、れろ、れろぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、ちゅぷっ……人の姿になっていても……少し舌がざらりとするれひ\nょう……？　れろ、んっ、れる……れろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「普段では味わえない刺激を……ちゃんと感じ取って頂ければ……れろ、ちゅ\nぱ……ぴちゃ……ちゅぷっ、んちゅぷうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、気持ちいいですか。良かった……もちろん、おっぱいの方も引き続\nき楽しんでいただきますわ……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「こうして……ぎゅうっと押し込んで……おっぱいを潰すようにして……その\nまま、ズリズリと……オチンポを扱いていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んふっ……あぁ、これは……私も気持ちよくなってしまいま\nす……はっ、んっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あっ……オチンポの方からも、もうじわっと先触れのお汁が浮き上がって来\nましたね……これも舐め取らせて頂いて……れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ふふっ、じわじわ湧き出して……ダーリンのお味がします……\nんっ、どんどん出して下さいね……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んちゅ……あぁ……奥からどんどん溢れてくる感じ……これはおっぱいで搾\nり出してあげないといけませんね……んっ、はぁんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……腰がビクビクして……我慢できなくなってますか？　いいですよ、\nダーリンのお射精……直接お口の中に出して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぴちゃ……れろ……んっ、濃厚なザーメンミルク……ごっくんさ\nせて……栄養をつけさせて下さい……んっ、ふっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ほら、もっともっとおっぱいを感じて……乳首もちょんとくすぐって……あ\nぁっ、出ますね……どうぞ、オチンポっ……出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……ちゅぷっ、んむっ、こくっ、んじゅっ、ちゅぷっ、んくっ、んち\nゅぅぅぅ……はぁんっ、元気なミルク……出て来ましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「こんなにたっぷり……ちゅぷっ、あぁ、美味しい……れろ……舌が止まらな\nくなってしまいます……んちゅっ、ちゅぷっ、んちゅぅぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んくっ、こくっ、んくっ、んくんっ……んふっ、あぁ……若返るような滋味\nですわ……ダーリンの生命力を頂いてしまうような背徳感……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、ちゅぷっ……んっ、はぁ……ごちそうさまでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「素敵でしたわ、ダーリン♪　それでこそ、私の見初めたお方……イルルもい\nい人を捕まえました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さて……一息つこうと思いましたが、これは……思いの外……オチンポが元\n気なままのようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……確かに、歴戦の猛者であるダーリンにとって、最初の一発はほんの\n挨拶のようなものでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ええ、お任せ下さい。ちゃんと残りの分も、しっかりと気持ちいいお射精の\nお手伝いをさせていただきますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「まずは、オチンポの先についている残り汁を……ぺろっ、れろ……丁寧に舐\nめ取って……んちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「綺麗になりましたら、改めてオチンポをしっかりと包み込んで参ります……\nんっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁん……熱い……やはり、ダーリンのオチンポ……生命力の塊というよう\nな力に満ち溢れていますわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「こうして、おっぱいを重ねているだけで……私にも力をおすそ分けしていた\nだいているような……そんな気持ちになって来ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「先程の精液のぬめりにも手伝って頂いて……乳首も……程よく先端に当てて\n……んぁっ、あふっ、んっ……く……んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……敏感な場所を擦り合わせるだけで……身体が火照って……発情を深\nめて行きますわ……んんっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「待ちきれない……んむっ、ちゅぷっ、また……オチンポ……味わわせていた\nらきまひゅ……りゅぽっ、ちゅぶっ、じゅるっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んむぅ……精液の味と、オチンポの味が……程よく混ざって……あぁ、口の\n中から……どんどん涎が湧いてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ちゅぱっ、んちゅぷぅ……んっ、おいひいっ……舌が止まらない\nれふわ……んちゅるっ、れろ、ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ……腰が跳ねて、んふっ、ダーリンも私のおっぱいを貪って\n下さっていますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい、どうかご遠慮なく、私のおっぱいを犯して下さいませっ……その、立\n派なオチンポで、ズリズリして下さいっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はんっ、ちゅぱっ、あぁっ、また新しいお汁が滲んで来ていますわっ……オ\nチンポがその気になっていらっしゃる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「嬉しいですわ……私のパイズリで、ダーリンが興奮して下さってる……あぁ\n、もっとオチンポ感じて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅぱっ、えろっ、れろぉっ……はぁ、私も……興奮が募って\n……このまま、あっ、おっぱいで達してしまいそうですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もし……んっ、お許し頂けるならっ……一緒に絶頂まで……達してっ、はい\nっ、お射精と一緒に……イキたいですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁん、ちゅぷっ、このまま……お口の中にもう一回れもっ……顔に掛けて\nもっ……お好きなようにっ、なさってっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「いっぱいびゅくびゅくっ、お射精なさってっ……！　ダーリンの精液っ……\n私にっ、浴びせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅぅっ！　んぐっ、おぷっ……んんっ、こくっ……んぐっ、んくっ\n……んくんっ、んっ……こくっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぷっ……はぁぁ……先ほどと変わらない……いえ、ともすればそれよりも\n濃い位のドロリとした精液……あぁ……ちゅぷっ……美味しいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「この際ですから……残さず出し切ってしまって下さい……全部飲ませて頂き\nますから……こくっ、んくっ、んちゅぷっ、んんっ……んはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ……素晴らしい味です……ちゅぱっ、ぴちゃ……れろ……ん\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……やっとお射精も落ち着いて来ましたね。んっ……いっぱい出されて\n何よりです……お疲れさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あ……お待ち下さいね……ちゃんと綺麗に後始末をしませんといけませんか\nら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……れろ、んっ……ほら、こんな所にまだ精液を残して……勿体ない\nですわ……ぴちゃ……んちゅっ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「れろ、んっ……ちゅぱ……はい、これでよろしいですわ。ふふっ、どういた\nしまして。夫のオチンポのお世話は妻の嗜みですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ダーリンがお求めになるならば、これからも誠心誠意、あらゆる場所を使っ\nてご奉仕致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「また、しっぽりと……母娘共々可愛がって頂ければ嬉しいですわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あっ……お顔にっ……いっぱいっ……新しい精液っ……出て…\n…ますわぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……先ほどよりも、もっと元気な……子種が……んんっ、顔\n中に広がって行きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっと浴びせて下さい……んふぅ……顔にパック出来るくらい……いっぱい\n掛けて……んんっ、においを染み込ませてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ぴちゃ……んちゅ……あぁ……美味しい……れろ……んっ、いつ\nまでも舐めていられる味ですわ……ちゅぱ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ……最後の一滴まで出してくださいね……あふ……ようやく、お射精も\n終わりそうです……はい……お疲れさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あ、そのまま楽になさっていて下さい。後は、オチンポをしっかりと後始末\n致しますので……ぴちゃ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ、汚れてる所がここにも……いけませんね、オチンポの身だし\nなみはしっかりとしておきませんと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ぴちゃ……ええ、これだけしておけば大丈夫でしょう。ダーリン\nのオチンポにはいつでも素敵でいて欲しいですから」", "NORMAL" ]},
