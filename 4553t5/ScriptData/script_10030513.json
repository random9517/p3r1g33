{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なにしてんの？　こんなところで正座して、首から看板ぶら下げちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350001" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なになに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350002" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「『わたしは母の大事なカツマを危険な目に遭わせました』……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「え、つまり反省中なわけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350004" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そうなんだよ。ボク、真面目に反省中。女王様の命令だからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「今回はうまくいくと思ったんだけどなぁ。やっぱりカツマそのものだったか\nらかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほかになにを考えていたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350005" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ん～、女体化？　ニセカツマとして女の子型ロボを送り込もうとしていたん\nだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「いや、無理あるでしょ。男のカツマと女のメカカツマが入れ替わるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350006" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「誤認識させる催眠だから、理論上はいけるよ。それに、女カツマと女幹部の\nＴＳレズ需要はあると思うんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「誰目線よ、それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350007" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクが見たい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「欲望丸出しね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350008" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「欲望と肉棒はさらけださなくっちゃ。そっちの方がおもしろいよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「どっちも人前に晒すのはほどほどにしないと、痛い目みるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350009" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……なにやら騒がしいと思えば、まったく懲りていないようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115350001" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひっ、女王様！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350008" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「女王様、なんでこんなところに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010115350010" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちょっとジェスタの様子を見に来たのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115350002" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうもこれだけでは反省が足りないようだな。膝の上に重石でも追加するか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115350003" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、その……それはもう拷問になっちゃうので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350009" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクとしては、亀甲縛りくらいのソフトなプレイで勘弁してほしいな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350010" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「反省はＳＭプレイではないぞ、愚か者めが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115350004" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひぃいん、ごめんなさぁぁいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115350011" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ふぅ……。こちらレディ・ホープ。目標を始末しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000612_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あの防犯カメラに写っていたのが、カツマさんそっくりのロボットだったな\nんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000612_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「時間帝国はこんなものを用意して、いったいなにをするつもりだったのかし\nら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115350003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「考えるのは後にしましょう。本部に帰るわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115350004" ]},
		{"command":[ "SETCHARA", "0", "char_00000612_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}