{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まさか知らないんじゃないだろうねえ、神聖なる儀式にして崇高な競技『乱\n杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』を！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ぬう、『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「知っているのであるか、珠魚？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0146" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「唐（とう）の時代、高僧にして武術家であった杰李威（じぇ・りい）は――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「男女を問わず、志ある者はすべて弟子にとるっていう、当時としては先進的\nな人物だったんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「その弟子たちの中でも特に、とある尼僧たちは非常に優秀な武術家だったん\nだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「その反面、血の気がとてもとても多くてね。周囲との諍いが絶えなかったそ\nうなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そこで杰李威（じぇ・りい）が、彼女たちの暴力性を発散させ、仏の道に適\nった戦い方を教えるため編み出したのが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「尼僧たちは狂喜乱舞し、競技に熱中した。試合中に暑くなって、僧衣を脱い\nでしまうほどにね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860008" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それ故に、下着姿こそがこの競技における正装とされたんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "～流根書房（るねしょぼう）刊『ドキッ☆まるごと下着！尼僧だらけの武闘大\n会』より～", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「さすがは珠魚。博識であるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113860002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「そんな、深い愛と思い遣りの精神に溢れた競技だったとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつらはどうして全員、今の話を真に受けられるんだろうな……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「嘘を嘘と見抜けない人でないと、このゲームをプレイするのは難しいですぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ええい、何をこそこそと話している！！　この戦場に、あたしたちと闘おう\nって猛者はいないのかい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113860002" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ふ……今の言葉、聞き捨てならないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020113860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様の相手は、ここにいるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！？　何いきなり変身してんだっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああも挑発され、かつ悠久の歴史を誇る競技と聞かされては、受けて立つし\nかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113860002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや別にいいと思うんだがなあ、エファの意味わからんノリに付き合わなくて\nも。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ショルダーアーマーには、ショルダーアーマーをぶつけるのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「学園長まで。唐突に現れてそんな、けしかけるようなことを」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「古事記にもそう書いてあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113860002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当でござるかあ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「流根書房（るねしょぼう）刊の『古事記ｖｓ日本書紀　～最古の婚活はどっ\nちだ～』にそうありましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020113860003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "嘘くせー！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「学園長のお墨付きとあっちゃ、応援しないわけにはいかないよねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113860010" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「うむ。これは本大会における、公式の競技となったのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113860003" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なるのかよ……なってしまうのかよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "一般の皆様、応援席でドン引きしてるんじゃないか……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "などという俺様の懸念を余所に、エファの連れてきたチームと、修羅姫を先頭\nに教師陣がだらだらと、校庭の中央に進み出る。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「良い面構えね。あたしたちの婚活、その生け贄に相応しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113860003" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんの話か未だによくわからないが、負けてやる義理はない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やってみせるがいい、この独女（どくじょ）め！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113860004" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}