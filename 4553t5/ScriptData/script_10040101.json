{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやー、この前はびっくりした！　一時はどうなることかと思ったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ホントよね～。いきなり偽情報で敵の基地に誘い込まれたと思ったら、円盤\n少女ちゃんたちに襲われたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様とアナザーが融合してハイパーになったり、ドラグソードがア\nルティメットになったりねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そういえばルナテミスたち『元に戻れない』とかいって大騒ぎしてたわね。\nふふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、それは言わない約束だ！　本当に戻れなくなるかと思ったんだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんだかんだで元に戻れてよかったよね！　あ、でもさ、ルナテミス……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あのときって……どんな感じだったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「融合している間のことか？　そうだな、戦闘力が格段に上がったというのは\nもちろんだが、お互いの思考がな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな、アナザーの考えていることが全部、私にまで伝わってきたんだ！\n　あれはびっくりしたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「違う違う！　私が聞きたいのは、そういうことじゃなくて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ！　ドラグソードホームランをどうやって繰り出したか、っていう話か\n？　あれはな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうでもなくて、あの……その……あのときルナテミスたち、３人でキス…\n…してたじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……フュージョンのことか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あの、あの……あのな……？　つきみ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「イチかバチか、最後の手段で試してみたんだが、まさかあそこまでうまくい\nくとは思わなかった。いや、驚いた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116390003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんないーかげんなノリであんなことを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかしもっと驚いたのはだな、ルナテミスの唇が思いのほか柔らかかったこ\nとで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116390004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って、アナザー！　今そういう話はしてないだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いや、その話！　聞きたかったのはまさにそういうところ！　アナザー！　\nキスについてもっと詳しくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やめろぉーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｄr.サイレーン" ]},
		{"command":[ "SETTEXT", "「なるほど……百合営業。これはいけるかもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルカプトラ7世" ]},
		{"command":[ "SETTEXT", "「ワンチャンあるのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おまえらどっから出てきた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そんなことより舌は！？　舌は入れたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「舌っておまえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「アナザー×ルナテミス本……夏あたりに出るんじゃないかしら。フフフフ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様ら、いいかげんにしろーっ！　どっからともなく湧いてきて、勝手なこ\nとをいうんじゃなーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116390012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなことはともかく、ハイパー化という現象自体には興味があるわね。人\n格の主導権は、どちらが握るのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「せ、攻めと受けってヤツ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「つきみ。落ち着いて。っていうか、どこでそんな言葉を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116390003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあ、キスの話は置いといてだ。ハイパー化で格段に強くなるのはいいけど\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしのアナザーは時間帝国側だからね。うっかりハイパー化しちまうと、\n時間帝国側の戦力になっちまうかもねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116390003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あたしはそもそも、あんなヤツとキスとかしたくないなー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ……！　私にもアナザーがいれば、カツマとキスできるチャンスが……\n！　私にはまだ、ダークしか出てきてない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「待って待って！　自分のアナザーとでなければ、ハイパー化できないとは限\nらないじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116390004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんさえいれば、女子２人のどんな組み合わせだってハイパー化でき\nるかも……そう、例えば私とつきみだって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116390005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「な、なんでそうなるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116390007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。皆さんあちらでガールズトークだか設定考察だかに興じておられま\nすが、ご主人は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと……スケバンサンダーからの請求書は確認したから経理に回すとして\n、ダイアンサスの修理代と宇宙への出張旅費と……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おやおや、それどころではなさそうですなあ。また書類仕事に追われて、ま\nったくお気の毒で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへー！　グダグダ言ってねえでお前も手伝えー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「常識というものを働かせていただきたい。愛らしいわんこに経費の精算だの\n書類の記入だのができるとお思いで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116390003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……！　こういうときだけペット面しやがって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー、そういえば先ほど、長官がおっしゃっておりましたな。報告書も早く\n出せと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116390004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかってるよ！　途中までは書いてあるんだ、途中までは……えーと、どこ\nまでだっけ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、そうか。『ファウンデーション』で、警備の時間帝国兵と戦闘になって\n……えーと、あれはたしか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}