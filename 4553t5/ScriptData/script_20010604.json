		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「みんな、ゾンビになってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021130001" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ぼ、僕の推理を超える展開……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130001" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「す、すごい……何でゾンビになってるの！？", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021130002" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）の仕業なのか？　それともどこかの組織の仕業なの\nか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130002" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「興味深い……すごく研究したい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021130003" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「くそっ、これが探偵の宿命なのか！　事件が起きてからでないと何もできな\nい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130003" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「せめて、仇は僕が――ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130004" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵ボス" ]},
		{"command":[ "SETTEXT", "「ここは我々の拠点にするには、ちょうど良い場所だな」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵部下" ]},
		{"command":[ "SETTEXT", "「はい。ここのホテルは廃業予定で、当面は買い手もいないですから大丈夫で\nす」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵部下" ]},
		{"command":[ "SETTEXT", "「辺鄙な場所のせいで人目にもつきにくいですし、敷地も多いですから実験な\nんかにも使えます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵ボス" ]},
		{"command":[ "SETTEXT", "「ふははははっ！　いいじゃないか！！　これなら我々の本拠地の移転先とし\nてはピッタリだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵ボス" ]},
		{"command":[ "SETTEXT", "「ここに移った暁には、まずは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「お前達かぁぁぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130005" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵ボス" ]},
		{"command":[ "SETTEXT", "「ぐああああああっ！！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵部下" ]},
		{"command":[ "SETTEXT", "「ボスゥゥゥゥ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「犯人め……ようやく姿を現したな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130006" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵ボス" ]},
		{"command":[ "SETTEXT", "「な、何だお前達は！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「みんなにした事……僕は絶対に許さないぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021130007" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「どうやってゾンビにしたのか教えなさい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021130004" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
