{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0194" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "今日も今日とて、俺とジュンジローは任務に駆けずりまわっていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし。あと１人！　とっとと倒して終わりにしてやる！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　今がチャンスですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が、敵の最後の１人を倒そうとした瞬間……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご、ご主人っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "力みすぎたのか、うっかり足元にいたジュンジローを踏んでしまった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぐぇええっ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "体勢を崩した俺を、すかさず狙う敵の攻撃。　", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "激しい一撃に真正面からぶつかってしまった俺は、前のめりにぶっ飛ばされて\nしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うああああああああああっ……！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「や、やばい……。目の前が真っ暗に……」", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おい待ってくれよ……。……俺は死んだのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「トホホ、最後の最後にこんなドジを踏んじまうとは……。我ながら、運の無\nい人生だったぜ……無念」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、現世に残してきたパソコンのデータはどうなる！？　あの中を見られ\nたら一貫の終わりだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに、こんな親不孝な状況のままで死ぬなんてありえないだろ！　親……\n親、親といえば……」", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ！　最近のお袋の記憶が濃すぎて、頭痛が……っ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020104_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEINCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダメだ、まだ俺は死ぬわけにはいかない……！　あ、でも……意識が……。\nああああ……」", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ゆっくりと暗転していく意識にのまれた俺は……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETTEXT", "目を開けると、まったく見知らぬ場所にいた。", "NORMAL" ]},
		{"command":[ "FADEINCHARA", "0", "NORMAL" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんだここは……？　ん？　もしかしてここは時間帝国か……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「違いますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700001" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！？　と、突然話しかけてくるから驚いただろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「……非礼については深くお詫びいたします。ですが、その勘違いだけはどう\nしても許せません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「ここは冥界……。絶！　対！　に！　時間帝国とは違う場所です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうなのか……すまん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「いえいえ。こちらこそ、突然申し訳ございませんでしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700004" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今、ここは冥界だって言ったよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700005" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「冥界って……死んだやつの世界ってことだよな？　つまり俺は死んでるって\nことなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「いいえ。まだ正式には死んでいないようですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700006" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何！？　本当か、それなら蘇る希望もまだあるってことだよな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「もちろんです。ですが、ここは死と生の狭間……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700007" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「ここに長時間居座ってしまうと、そのまま死者になってしまいますから……\nその点、お気をつけくださいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700008" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ！　じゃ、じゃあすぐに蘇らないとまずいじゃないか！　お、お、俺は\nどうしたらいいんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「どうするっつうか、てめぇがこのまま死ぬか生きるかを選別すんのがあたし\nらの役目なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700001" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「冥界に降りた魂の案内が私たちの仕事……。つまり、私たちがダメって言っ\nたら、ダメです。かわいそうですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700001" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！　また新しい冥界人が現れたぞ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA","1" ]},
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「冥界人って……。地底人みたいに言わないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700002" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「おい、てめぇ。蘇りてぇならあたしらに逆らわねえ方が身のためだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700002" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぐっ……。確かに、余計なことをするのはヤバそうだ。黙っておくか……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？？" ]},
		{"command":[ "SETTEXT", "「ありがとうございます。それでは、改めて、自己紹介させていただきますわ\n。私たちは、誇り高き冥界の３女神……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700009" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「姉妹同盟【エリニュス】のアレクト、ティシポネー、メガイラです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700010" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "0", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　んん、ちょっと待ってくれ。誰が誰だって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私が長女のアレクトですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700011" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んで、あたしが次女のティシポネーだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700003" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……三女のメガイラ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700003" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふーん。また３姉妹か……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ま、またとはなんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700012" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……最近見た姉妹も、３人でモイライシスターズ！　っていう３姉妹だ\nったからさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「３姉妹の次に３姉妹ってなると頭が混乱しちまって……。そんなに３姉妹ば\nっかり覚えられないなって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「であれば私たちの方だけ覚えていてくださればいいんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700013" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「モイライシスターズのことは、お忘れになってくださってかまいませんよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700014" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そういうわけには……。な、なんで、さっきからこんなに対抗心メラメ\nラなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ～。わりぃなあ。アレクト姉は、そんくらいバチバチにモイライシスター\nズをライバル視してるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700004" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ～。めちゃくちゃおしとやかそうな見た目してるのに、中身は結構激しい\nんだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私、いつもこんなに血気盛んではございませんのよ？　私１人の話であれば\n、いくらでも誰にでもお譲りします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700015" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ですが、姉妹のこととなれば話は別なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700016" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へえー。妹思いのお姉さんなんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「うふふふっ。お誉めにあずかり光栄ですわ。もう、あと少しだけお待ちあそ\nばせ。そうすれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700017" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私たち【エリニュス】が、シスターズ枠の需要を満たす彼女らを超えて……\n姉妹売りの代表格になってみせますから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700018" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……って意気込んでるけど、向こうはこっちのことなんてまるで知らないっ\nぽい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700004" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「一体どうしたら、私たちを真の３姉妹だと認めてくださいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700019" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アレクトにそう聞かれて、俺はハッと我に返った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、んなことはどうでもいいんだよ！　すぐに、俺を生き返らせる許可を\nくれ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、冥界の３姉妹！　俺とジュンジローを生き返らせることってできるか\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「俺とじゅんじろー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700005" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ、ここに来る直前に間違って踏んづけちまった犬なんだが！　って…\n…あれ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あー……えっとな。犬はここには来てねぇみてえだぞ。つまり死んでんのは\nてめぇだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700005" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええええっ！　良かった、の、か？　俺だけってのがどうも納得いかないが\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前らは俺に認めてもらいたいんだよな！？　生き返らせてくれたら認めな\nくもない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なにとぞなにとぞ、と必死にお願いする俺を見つめる３姉妹。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00028701_01", "3", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……それには条件がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700006" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "待ってましたとばかりに言い放つティシポネーに、俺は必死で頼みこむ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な……なんだ？　できることならなんでもするぞ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「もうすぐ開催される『悪の女幹部人気投票』に参加させてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700006" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あくのおんなかんぶにんきとうひょう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「その晴れ舞台で、あたしたち【エリニュス】の存在を知らしめること。これ\nが蘇らせる条件だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700007" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ。条件……についてはよくわかった。だが、『人気投票』っていう\nのがよくわからん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あら。ご存じではありませんでしたか？　人気投票と言えば、実力を示す唯\n一無二のビックイベントですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023700020" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか……。初めて聞いたなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「しかも今回の人気投票は、今までの人気投票とは一味違うってぇウワサなん\nだぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023700008" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て待て待て！　そもそも、今までの人気投票を知らないんだが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「『〇〇にしたいキャラ』……っていう、各テーマに沿っての投票なんだって\n。面白いよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023700007" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ、全然会話をしてくれねぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "つらつらと人気投票の話を続ける３姉妹を、自由に喋らせながら俺はなんとか\n生き返る方法について考えた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「死んでもなお、こんなよく分からない奴らに巻き込まれるなんて……ついて\nないな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも、それ以外に蘇る方法がないなら……。こいつらにやるしかないよな…\n…！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}