{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふう～～……日差しが肌を刺すようです。けど風が気持ちいいし、波の音も\n最高です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「これってやっぱ水着姿が一番似合うロケーションですね！　水着を着るＴＰ\nＯ、ちゃーんと考えるべきかもしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「それで？　今日はここで遊んで帰るですか？　実はいい感じのスイカがここ\nにありまして──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　その前にスキンケア……？　隊長、なんだか意識高い系の女子みたい\nですねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええっと、じゃあ日焼け止めローションを使うですよ。え？　ええ、もちろ\nん、しっかりと塗ってあげるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「…………は？　え？　胸を使っておちんちんに塗り塗り…………？　えええ\n……わ、わかったです……は、恥ずかしいですけど、頑張るです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303106" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……いい匂いですぅ……。え？　あ、おちんちんのことじゃありません\n……このローションの香りです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ヌルヌルして、トロトロしてて……はぁぁん、肌触り、最高ですね……これ\n、多分高級品ですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んで、ここに塗るですか？　おちんちんの日焼けなんて、心配する必要ない\nんじゃ……まあ、いいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええっと、おっぱいを使ってヌリヌリすればいいですか？　わかりました…\n…それじゃ始めるですよ……よいしょっと──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……谷間にローションをたっぷりと滴らせて……と。ふぅ……ヌル\nヌルして、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁぁん……おちんちん、カッチカチです……うわぁ、谷間の中で破裂しち\nゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「少し、恥ずかしいです……最近水着姿で、ずーっと谷間を丸出しですけど…\n…こうしてマジマジ見られると……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　見られるのが嫌いなのか、です？　まあ、多少は恥ずかしいです。け\nど、これも修行の一環ですから！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「見られて緊張しつつも、平常心で身体を動かすことが出来るように……と、\nお亥さまのお考えなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「なので、このローションおっぱいヌリヌリも、立派な修行になるのです。見\nてて下さい、新たなフォームの威力を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええっと、まずは左右のおっぱいでしっかりと挟んで……と。んしょっと…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ヌルヌルが谷間に広がっていく……おちんちんがにゅむにゅむして\nる……あはぁ、変な感触です……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ほら、ほらほら、見て下さい……おちんちんが、トロトロになってるですよ\n……うわぁ……すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ほら、もうすっかりローションまみれです……ふふ、これならもう日焼けの\n心配はありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　まだ終わりじゃない？　これ以上おっぱいでゴシゴシしたら、変なの\n出ちゃうですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「私のおっぱいにも日焼け止めローションを塗らなきゃいけない、です？　そ\n、それって……つまり……精液……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うう、わかりました。じゃ、じゃあ、もっと隊長さんに気持ちよくなっても\nらうです……ん、ん、はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「おちんちんが、ツルツルする……ん、はぁ、にゅるにゅるが、肌に染み込ん\nでくるみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああ、おちんちんが、バキバキに大きくなってる……ん、ふぅ、先っちょが\nプクプク膨らんで……ああん、ちょっと可愛い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、どうです？　気持ちいいです？　水のように、変幻自在……\nそれが新フォームの効果です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「剣技もおっぱいも、水のように操ること……そこに極意があるはず、です…\n…ん、はぁ……はぁ……んんん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　気持ちいい、ですか？　はぁ……はぁ……それじゃ、このまま続ける\n、です……はぁ、ふぅ……いつでも、出して、下さいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……んん、はぁ……あああ、水着の下で、乳首が擦れて……んぁ、はぁ…\n…変な気分になっちゃう、です……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ……はぁぁん、おちんちん、気持ちよさそうに、震えてる……あ、あ\nあ……すごい……血管がこんなに膨らんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「きゃうぅぅ……震えてる、です……おちんちんの中、精液が駆け上がって、\nくる……あ、ああ、出されちゃう……あ！　んひぃっ、きゃうぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃひぃぃ！？　あはぁっ、出てる……いっぱい出てるです！　白い粘液の\n塊が、噴水みたいに噴き上がってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「きゃうぅ……あはぁぁっ！　あちこちに飛び散ってる……あぁあん、あった\nかいのが、肌にぶつかってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、ああ……こんなにお日様が照ってるのに……エッチなドロドロで汚され\nてるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……ひうぅう……熱いぃ……精液が、肌に染み込んでくる…\n…ん、ふぅ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ……ローションの匂いと、精液の匂いが混じり合って……はへぇぇ…\n…頭の中に染み渡ってくる、みたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はふぅぅ……深呼吸するだけで、身体がジンジンしちゃうで\nすよぉ……はー……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「谷間の中でビクビク震えてる……ふぅ、まだこんなに硬ぁい……ひょっとし\nて、全然満足してないです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふふ……わかってるですよ。まだローションを出し足りないのでしょう？　\n任せて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……もっと水のように、身体を動かさねば……。では、もう一\n度始めるですよ……よっこいしょっと──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……んん、はぁ……はぁ……あああ、全身から汗が溢れてるです……はぁ\nん、日差しが強くて、身体が蕩けそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、ふう……ローションが無いと、日焼けして真っ黒になっちゃうです……\nもっと、いっぱい塗り伸ばさなきゃ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……精液が、すごい……ん、んん、汗と、精液と、ローショ\nンと混ざり合って……おっぱいとおちんちんがグチャグチャです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「くんくん……はぁ、ふぅ……くんくん……はぁぁ……空気の中に、精液が泳\nいでいるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「潮風と、精液の匂いって、ちょっと似てるような気がするです……はぁ、ふ\nう……んん、はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……はふぅ……ニチャニチャ、音がするです……潮騒と混じ\nり合って……すごくエッチに聞こえる、ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ……おっぱいが、ジンジンする……ん、はぁ……アソコも熱\nくなって来た、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うう、せっかくお亥さまに用意してもらった水着で、こんなことしてるって\n知られたら……私、怒られちゃうかも……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「でも、古人いわく『エロ見てせざるは勇なきなり』です……すべきときに何\nもしないだなんて、サムライの名折れですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、ああ、すごぉい……またビクンビクンしてる、です……んん\n、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「イキそうです？　え？　もうちょっと激しいほうがいい……？　わかったで\nす……はぁ、はぁ……どっこいしょっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふん、ふんふん……ふぬぅぅぅぅ……ど、どうです？　私のおっぱい使い…\n…まるで水のように滑らかで、変幻自在でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぇ？　全然そんなことない……？　あれぇ……おかしいなぁ……でも、ん\n、ふぅ、隊長さん、気持ちよさそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「この調子で、ずんずん行くですよぉ……はぁ、はぁ……んん、ふぬぅぅぅぅ\n……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010103_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ……すごいすごい……おちんちんが、また弾んでる……はぁ……\nふぅ……ふふ、ビクビク震えて……ああん、なんだか愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああぁん、私で気持ちよくなってる……はぁ、ふぅ……それも、これも、こ\nの恰好のおかげです……んん、はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
