{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あくっ……！　こ、こらっ、離しなさいよっ！　ちょっ……アンタっ……何\nしてんのっ、くぅっ……離せったらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムのことを何だとっ……人間の分際でっ……くぅっ、な、何でっ……！　\nヤムが本気出したらアンタなんて全然なのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「イルルが……何かしたのねっ……！？　くぅっ……い、いやっ！　あ……足\nっ……閉じさせなさいよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あくっ……ウソ……振りほどけないっ……な、何なのこれ……全然……違う\nっ……ヤムの力……出してるのにっ……くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　な、何で……チンポも……ナニよソレ……そんな、おっきす\nぎ……ヤバ……ま、待って……まさか、そんなの入れる気じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「い、今のヤムのじゃ……は、入り切らないし！　冗談でしょ？　ギャグにな\nってない……！　ヤムの足くらいあるじゃない！　あっ、やめっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぎっ！？　んぅっ……あっ、んくぅぅぅぅぅぅぅぅんっ！　あぐっ……く\nっ……んぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いきなり……し、してくれるじゃないのっ……ふっ……んぐぅぅ……そーい\nう、乱暴なのが……アンタの趣味ってワケね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……でも、ヤムは……この程度のチンポでベツに……大して感じ\nたりしないし……お生憎様でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「な、何を……鼻息荒くさせてんのよ……首の後ろに掛かって……キモいんだ\nけど……え……ちょっ……な、何……その手の動き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「や、やめなさいよっ……アンタ、何考えて……あっ、あひぃっ！　ひっ……\nんんっ、ど、どこ触ってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やめっ、あっ、お、おっぱいとかっ……！　誰の許しを得てっ……勝手にっ\n、してっ……はぁんっ、あはっ、あぁっ……あぉぅっ、おっ、ぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほ、ほじくり出すとかっ……じょ、冗談っ……くっ、あひっ、あっ、らめっ\n……おっぱいっ、するなっ、あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぅんっ！　あぉぉッ！　チ、チンポもっ……！　ひぐっ、一緒にっ……あ\nぐっ、う、動かされるぅっ、んぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちがっ……感じてっ、なんかぁっ！　アンタなんかのチンポでっ……うひぃ\nんっ！　はぁっ、なっ……何っ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ……何でっ……あぁっ、チンポがっ……んぁっ、ひ、響くぅっ！？　う\nぁっ、あくぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ……そんな……ヤムがっ、こんなチンポぐらいでっ……んくぁ\nぁぁっ、どうにかなるなんてぇっ……あひぁっ、おっぱいやらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ウソ……あっ、ちくびっ……出て来ちゃうっ……！　ヤムのおっぱいっ……\n出て来ちゃうっ……あっ、んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「や、やらぁっ、コリコリされたらぁっ、あひぅっ、気持ちっ……よくなっひ\nゃうっ、あひぁっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んひっ！　あっ、オッ……オマンコもぉっ……きゃうっ、ひゃっ……んっ、\nやらっ……お汁っ……出てくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……やらっ、あぁっ……そんなっ、人間ごときにっ……ヤム\nがっ……こんななっちゃうなんてぇ、違うっ……違うのにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いひぃっ！　はっ、激しいっ！　チンポっ……強くてっ……！　んぁぁっ、\nらめになるぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ……はへぁっ、やらっ、太いっ……くぅぅんっ、ズボズボっ……される\nっ、あひぁっ、待って！　こんな筈じゃっ……ないからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、んぁぁぁっ！　ちくびぃっ、へんにっ……はん、ヤムっ……あっ、ら\nめっ、ホントにっ……も、もぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はひぁっ、イ、イクっ！　イッひゃうっ！　ヤムのおっぱいイクぅっ！　オ\n、オマンコもイクぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ……ぁっ……あふぁ……はぁ……あ……くぅぅぅ……い、今のは……う\nくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うぅっ……覚えてなさいよっ！　これが終わったら……アンタなんか絶対に\n……コロす……うひゃいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あひっ、ま、また乳首らめぇっ！　こ、コリコリしらいでっ、敏感になって\nるのっ、弱いトコらからぁっ、んぁっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「わ、分かったわよっ！　感じてっ……感じてるっ！　アンタの指でっ……お\nっぱいっ……気持ちよくさせられてるっ、ヤムはウソ言ってたから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほらっ、ちゃんと言ったからっ、あくぅんっ！　チンポもっ、あっ、どちゅ\nどちゅしにゃいでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まだっ、今っ……まだイッてるのっ、お、終わってないからぁっ、んぁぁぁ\nぁっ！　おくっ、ドスドスたたいひぇっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、チ、チンポっ、ビクって来てるっ！　これっ、しゃ、射精\nっ……するのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひっ、うひぃっ、出るの待ってっ！　またイクからっ……んひぃんっ、奥に\nっ来ちゃっ……はひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁぁぁーっ！　なきゃっ……出てるっ……！　びゅくびゅく\nっ……せ、せーえきっ、オマンコ……出ちゃってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁぁん……うそぉ……きもひぃぃの……ヤムのからだ……どぉにかなっち\nゃってるぅ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……まだ……出てる……あぁ、出されたまま……ぐちゅぐちゅさ\nれてるぅ……ヤムのオマンコ……もう入らないのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……お、終わった……？　やっと……射精止まったの…\n…んっ、くふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ……あぁぁぁ……はぁ……あぁ……オマンコ……精液でドロドロにされち\nゃった……うぁ……中ぁ……ぐちゅぐちゅしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うぁぁ……あ、溢れてきてる……んっ、オマンコから精液漏れちゃう……は\nぁぁ……トロトロのが……止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まさか……人間のチンポにこんな風にされるなんてぇ……んふぁぁ……どう\nなってるのよぉ……あふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふぅ……も、もういいでしょ……終わったんだし、さっさと離しなさいよ\n……こんなに出すなんて……頭おかしいんじゃないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「え……ぁっ……何でっ……お、終わりじゃないのっ？　またチンポ……んぁ\nっ、は、始まってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「何でよっ……んっ、どういうことっ……？　ま、まだ……躾がいるってっ…\n…何よそれっ、ヤムはアンタの子供ってワケじゃないんだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んひっ！　あっ、だっ、だからっ……おっぱいしないでっ！　あんっ、もう\nヤムがそこ弱いの知ってるでしょっ！　い、意地悪しないでったらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「気持ちよくなるからってっ……もう、なってるしっ……んっ、あぁっ……指\nが……しつこいのよぉ……んんっ、ジンジンするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぁっ、また乳首ぃっ……くぅぅんっ……ずっと痺れてるのにぃっ……あぁ\nぁ……押しつぶしちゃやぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ウソ……こ、このままイクまでとか……そんなのっ、ホントに……あっ、ん\nぁぁぁんっ！　あっ、つまむのっ、あひっ、はひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やらっ、声っ、出したくないのっ、こんなっ……可愛い声とかっ、言うなぁ\nっ！　あんっ、あぁんっ、出ちゃうんだからっ、んぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、んへぁぁぁっ、やらっ、またおっぱい痺れるぅっ、はひんっ、またイ\nクっ、くぅぅぅんっ、おっぱいイクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……ま、またイッちゃった……ヤムのおっぱいダメになってるの……\n痺れ過ぎてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ……はぁんっ、やっ、そのまま……腰揺らされてるぅ……あぁっ、うん\nっ、くぅんっ……そんな、チンポに馴染んでなんかっ……ないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひっ！　んぁぁっ！　んっ、今のはっ……そういうのじゃっ……なくてっ、\nあひぉっ、あぉっ、あっ、あぁっ、や、やっぱりっ……らめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はひっ、さっきからっ……どんどんっ、らめになってるっ！　チンポっ、あ\nぁっ……感じすぎてぇっ……ひっ、おひっ、んひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あぁっ、生意気言ってごめんなさいっ、謝るからっ……ちゃんとごめんなさ\nいするからぁっ！　ヤムのオマンコもう許してぇっ……んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃっ！　あっ……イ……くぅぅ……っくっ、んふぅぅ……あぁっ…\n…っく、んぁぁふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あぁ……チンポ……また出るの……？　だって……そんな感じになってる…\n…震えてるの……分かるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_02_07" ]},
