{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「こんばんは……。隊長さん、どうしたんですか……？　今夜はオフの予定だ\nったと聞いていますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「もしかして、寝付けなくてお茶したい、とか……。まさか、寝物語に絵本を\n読んで欲しい……とかではないですよね？　えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『組織存続のための大切な話がある』？　だ、大事なお話ですか！？　私が\nお相手でよろしいんですか？　艦長か副艦長を呼んできたほうが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103103" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『今はオペレーターの強化をしている』？　あ……では、私……ですね。え\nえと……強化、オペレーターの強化とは？　滑舌とか？　発音とか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「はい。メンバーとの連携力を高める特訓……。なるほどです。確かに、連携\nは大事ですよね。互いのことをよく知っていないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「いざという時、数秒のタイムラグが発生してしまって。それでピンチになっ\nた経験……正直あります。つまり、そういうことをなくす訓練ですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……わかりました。それで、何をすればいいですか？　私に出来ることなら\nなんでもします。……パイズリ？　パイズリってなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103107" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「お菓子のパイ……？　えっ！？　おっぱいのパイ！？　お、おおおおおおっ\nぱい！？　おっぱいで隊長さんの股間を気持ち良くする！？　なんで！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『男と女の連携は肌で覚えるしかない』？　えーっ！　す、すみません。今\nまで艦内に女しかいなかったもので知りませんでした。へえー……おっぱい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103109" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「って、じょ、冗談ですよね！？　それってエッチなことじゃないですか！　\n……へ？　ベッドに寝そべれ？　ま、待ってください！　……きゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103110" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「きゃ、きゃあああああ！　いつのまに！？　いつのまに私のおっぱいが露わ\nになって……！？　た、隊長さんのおちんちんが目の前にぃいい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103111" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019201_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「む、無理です無理です無理です！　私、キスもしたことないんですよ！？　\nなのにおっぱいでおちんちん……挟むなんて無理です、無理ですー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『俺がリードするから』？　そ……れなら……？　あの……本当に私、何の\n経験もなくて！　まだ恋もしたことなくて、なのでわからないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……わからない……んですけど。隊長さんがやけに自信満々なので……。そ\nの、ゆ、ゆだね……てみます。胸……怖いことはしないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「んっ……！　ふわぁ……！？　あっ、あ……！　し、信じられない……。私\n、おっぱい……おっぱい見せちゃってる、隊長さん、に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「形とか変じゃないですか？　あっ……す、すごく真剣な目……。は……恥ず\nかしいです……。あんまり見ないでください……。んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『両腕でぎゅっと胸を左右から寄せるように』？　こうですか？　……わ…\n…、た、隊長さん……あの、あ、の……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちん、ちん……。おちんちん、おっきすぎて……？　私の胸からはみ出し\nちゃってますけど、こんなのでパイズリ……出来てるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『チンポは前後に動かすから平気』？　ち、ちんぽ！？　あっ……おちんち\nん、そうですか……。おっぱいをズリズリでパイズリ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「じゃあ……ど、どうぞ……？　ずりずり……？　ん……！　んっ……あっ…\n…あ……！　や、やだ……なんかすごく……エッチです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さん、の……おちんちん……。私の胸の間をくにゅ、くにゅって出入り\nして……。先っちょがぴょこ、ぴょこって目の前に迫ってきて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ちょっと勢いがついたら……唇に当たりそう、で……。あっ、こ、困ります\n……。ファーストキスがおちんちんなんて……破廉恥です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……ん……！　んん……ん……！　ふぁあ……。なんだか不思議です。男の\n人が、私の胸で……腰を振ってる……。こ、こんなの初めてです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「気持ちいいものなんですか？　私……？　私、は……恥ずかしいのが強すぎ\nて……。感覚がまだ麻痺してます、た、ただ……そのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちんって、腕みたいに太いんだなぁ……とか。ほ、骨……みたいに硬\nいんだなぁとか……客観的に観察しちゃって、それで……それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「若干やらしい気分にはなってます。だって、私でこんなに大きくしてくれる\n人……。きっと隊長さんしかいないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「それに、本物のおちんちんって……んっ、でこぼこしてて……輪郭が卑猥で\nす……。ん、でっぱってるところも、あって……怖くって……。ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「それ、なのに、私のおっぱいをぷにゅぷにゅ移動して……。ひょうきんなと\nころも、あって、……あっ♪　ちょっと可愛くて……。ん、ん、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「この子を気持ち良くしてあげたいなって、なん、か……母性本能が湧いちゃ\nって……。あの……！　だ、だから私も胸、動かします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「こ……こう、ですか？　んぅ……こ、こんな感じ……？　両腕ではさんだお\nっぱい……っ、潰して、おちんちんムギュッてして、上下……に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「いっちに、いっちに、って、……あっ！　今……おちんちんがピクって……\n。この動き？　こういうのが好き？　うん……、うん、うん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「い、いっぱい気持ち良くなっていいか、ら……。私の胸で安らいで、癒され\nて……♪　んっ……はあっ、は、ぁ……♪　はぁっ、はぁ、は、ぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ぐいっぐい来るぅ……！　どんどん力強く、おっぱいっ……！　おっぱい、\n突き上げてきて……♪　ふぁあっ、暴れん坊、です、暴れてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……この子、乱暴……！　でも……隊長さんが気持ちよさそうだ\nから、いい、か、な……？　あっ……私のことはいいですからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちん……気持ち良くすることに集中しちゃってくだ、さい……！　ん\nふっ……ふぅっ……ふぅっ、ふぅうっ……♪　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「連携……連携出来てます、か？　あっ、私の胸、隊長さんと特訓できてます\n、か……？　『もうすぐ結果が出る』？　あぁ……楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「たのし、み……♪　んぅっ……ん、んんっ！　上半身どころか全身が揺れて\nます……。私のおっぱいも、汗……？　でヌルッとし、て♪　あうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「胸がふわふわ……、ふわふわしてき、ました……。あっ、隊長さん……！　\n隊長さん、おちんちんが上を向いて……あっ、膨張、して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『胸に出すぞ』？　……ふぅううっ♪　は、はい……！　どうぞお好きなよ\nう、に……あっ！　あっ、わ、私……私……もう何も考えられなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「れん、けい……ぃ♪　隊長さんとこの子と、おっぱいで連携することしかわ\nからないです……！　自由に、自由にしちゃってくださ……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「んぅ！？　わ……！　わ、わ、わぁああ……！？　大変っ……！　隊長さん\n！　隊長さんっ……おちんちんから何か飛び出して……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「こ、これが連携の結果……ですか？　特訓の成果……？　な、なんでしょう\nこれ……。ドロッとした白い液体が次々……。あっ！？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「壊れた蛇口みたいに……！　止まらないです！　わ、私の胸の上に広がって\n……あぁあああ……。大丈夫なんですか？　お身体……ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『男は気持ち良くなるとこうやって精液が出る』？　せい……えき？　あっ\n……！　精液！？　初めて見ました、これが……これが精液……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おっぱいでクニクニするだけでも出ちゃう……んですね？　精液って……。\n赤ちゃん作る時の液だって、保健体育で習ったので、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「パイズリとかで出るものだと思ってません、でした……。い、いいのかな…\n…。大事な、赤ちゃんの素……。精液、胸なんかに出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……もったいない、ような……？　『定期的に出すものだし、またすぐに作\nられるから平気』？　ほっ。だったら良かったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「精液……。せい、えき……。精液って、出る時気持ちいい……んですよね？\n　ちょっと想像つかないです。体液を出して快感……？　うーん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「身体に毒だから、外に出るとスッキリするんでしょうか……？　え、気にな\nるならもう一度見てみるかって……？　ぁ……じゃ、じゃあ、それで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「もう一度出して……ください。気持ちいい液、精液……。私の胸、このまま\n使っていただいて……いいので。んっ……！　あ、あ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちんが、精液の上をすべって……ッ♪　ヌル、ヌル、ヌルヌル、にゅ\nるっ……にゅるって……あ！　あっ、ヌメヌメがすごいです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちん、ヌメヌメ、ヌメヌメしてて……！　それをっ……私の胸でこす\nってる、から……！　私の胸も……。肌もニュメニュメして……はぁう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「何……！？　何、なにぃ！？　さっきよりゾクゾクしますっ……精液の臭い\n、ぷんと香って……それを嗅ぐと……！　あっ♪　あっ……なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おっぱいの奥から……気持ちいい感覚があがってきて、集まって、きて……\n♪　あっ♪　あっ♪　乳首っ……むずがゆくて……あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……ご、ごめんなさい！　いやらしい声出ちゃ……あんっ！　あんっ！　あ\nんっ！　おっぱいで……おっぱいで赤ちゃん作ってる、みたい、すごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちん、さっきみたいにすぐ硬くなって……ぇっ！　太いのが、太いの\nが私のおっぱいゴリゴリ貫いてる！　はぁんんっ、貫かれて、るぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、あっ、あっあっ！　パイズリ……っ、パイズリって、おっぱ\nいでするエッチ、なんですね、あっ！　恥ずかしい……恥ずか、し……い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「私っ、おっぱいで赤ちゃん作ってるっ……あか、ちゃんん♪　あっ♪　あっ\n♪　エッチなことしてる、おちんちんでグチュグチュされちゃってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「き……もちいい……！　あぁううっ♪　はぁんん！　あん！　あんっあんっ\n……♪　おっぱいでするエッチ気持ちいい、気持ちいい、気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「もっとしたいっ……ズチュズチュズチュズチュ気持ちいい♪　あーっ♪　あ\nああっ……！　隊長さん、隊長、さぁんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっああああああっ……！　精液っ……せいえきぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「や、やぁあ……！　こぼしちゃいやです、胸の中に……！　胸の中に全部注\nいでくださいっ……。外じゃだめです、中に、中、に……ああああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ドプッ、ドプッ、ドプッ……♪　っぁあああ……♪　あったかいのが流れ込\nんでくる……！　私のおっぱいの中にビューって、ビューって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あ、は……あはは……♪　あったかい練乳みたい……。私のおっぱいの谷間\nに封じ込められて……デロデロしてる……。プリプリしてる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「さっき教えてもらったこと……。本当でした。隊長さん、精液出す時に『ん\nっ』って気持ちよさそうな声出して……だらしない顔してました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「精液をおっぱいに出すのはすごく、すごく気持ちいいことなんですね……。\nそして、私と隊長さんとの連携の結果……。はぁっ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「そう思うと、なんだか……嬉しいです。胸はビリビリ痺れちゃっていますけ\nど……。あの。何度かすればコツはつかめると思いますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「また……パイズリしたくなったら、してもらってもいいですか？　『今度は\nスミレのリードで』？　きゃぁ……♪　は、はしたないです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「で、も……。はい。わ、わかり……ました。今度は今日教えてもらったこと\nを活かせるように、私からします。パイズリ……させてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『パイズリにまで真面目で素直』？　あはっ……。これは性格ですからね。\nそれがパイズリでも、全力を尽くす性分なんですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ひぃああああっ！？　あっ……あっ、へっ？　へっ……あっ……顔……？　\n顔におちんちんを近づけて……何を？　……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「んむぅ！？　むぅっ……あぷっ……んんんっ……！　んぅうう！？　え？　\nえ？　精液が……精液が私の頭に……顔に……？　んんんんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『出てくるところをちゃんと見てろ』？　あっ……精液、精液がおちんちん\nから出てくるところを見せてくれてたんですね！？　で、でも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さん……！　私の顔にかけたら、目の前が……真っ白でよく見えま、せ\n……ん。あっ！　熱っ……きゃっ！　きゃあっ、んぷぷっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あ、あああああ……ドロドロです……。臭い……っ、臭いしなんか粘り気が\n……！　ん……！　泥のパックみたいに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「けほっ！　ちょっと口にも入っちゃました……。けほっ、けほ……！　う\nぇっ……苦いです、苦すぎます！　ぺっ、ぺっ……！　へっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「口に入った分は飲むように？　んぐ……！　で、でも……精液、あのっ、精\n液ってとても苦くて……！　複雑な生命の味というか……まずいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『それでも飲んでほしい』？　……う、うう……。わ、わかり……ました…\n…。なんなんでしょう、一体全体全てが急すぎてついていけない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……ごくっ……。ごく……。ぷは……。こ、これでいいですか？　え？　顔\nについたぶんも舐めて、飲むところを見せてほしい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「そ、それはさすがに無理です～～～！　隊長命令？　そ、そんなーー！　う\nう、ちゅる……ごくっ、ごく……ちゅる……。苦ぁああああいいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}