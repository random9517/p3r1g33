{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というわけで、力を貸してくれ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なにが『というわけで』だよ。こっちは忙しいんだ。他を当たってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「他って、こんなことお前たちしか頼れないって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「無理だって。こっちの接客があるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「別に料理を作ってほしいわけじゃない。ただ、優勝できそうな料理の作り方\nを教えてくれれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いやいや、なおさら教えられねぇよ。企業秘密だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこをなんとか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "居酒屋正義の屋台までやってきたのはいいが、交渉は難航していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この居酒屋、最近はスイーツも扱い始めたらしく、それが学生たちにウケてい\nるらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「グルメコンテストというイベントがあるのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そうなんです。カツマと一緒に優勝したくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000002" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマが優勝するって言ったから、私もできることをなんだって手伝いたい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私にとっては、こういう学園祭って初めてだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふむ……。ほむら、ここはひとつ頼みを聞いてやったらどうでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000003" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいおい、イグニスまでそんなことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「知恵を貸すくらいならいいではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000004" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁ、わかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、力を貸してくれるのか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お前のためじゃねえ。その嬢ちゃんのためだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで、どんな料理を？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな……。簡単な酒のつまみとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「屋台で売るものとしては間違っちゃいないかもしれないが、相手は学生だか\nらな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「冗談だよ。学生が相手なら、アレだ、スイーツとかいいんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「スイーツ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「甘味ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000005" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうそう、例えばこういうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ほむらは伝票の裏にすらすらとペンを走らせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「パンケーキだ。これくらいなら作れるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うん。作れる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、意外と絵がうまいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「意外ってなんだ。失礼な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ほむら、ありがとう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、おう。ま、頑張れよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那に頭を下げられて、ほむらは照れているようだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマ、足りない材料を買いに行こう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000007" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「急いで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114000008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい。そんなに手を引っ張るなって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那に手を引かれ、俺は商店街へと買い出しに行く。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いいですねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000006" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな。ったく、青春しやがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000013" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いいですねぇ……パンケーキ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000007" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そっちかよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000014" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「完成したら私たちも食べに行きますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114000008" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……まあ、様子をみるくらいなら、な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114000015" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}