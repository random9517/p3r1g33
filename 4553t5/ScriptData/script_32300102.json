{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ダーリン、ようこそいらっしゃいました。というわけで……大人しくしてい\nてくださいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……心配なさらずとも、食べてしまったりはしませんよ。もっとも、別\nの意味ではダーリンを頂いてしまうことになるのですが♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「とにかく、ダーリンは動かないでいて下さって構いません。委細、私が全て\nやってしまいますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっとも、既にダーリンのオチンポは、その気になっていらっしゃるようで\n……ふふっ、何とも頼もしい限りですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ですから、今日はじっくりと一日、閨（ねや）を共にして……イルルの妹を\n作ってしまいましょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「弟の可能性……？　ああ、もし、そちらが望ましいということでしたら、ま\nた考えますが……やはり女の子が可愛いですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さあ、とにかく私はダーリンの赤ちゃんが欲しいのです。なので、オチンポ\nさんにも頑張って頂きますわ。んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あふぁっ……んんっ、入って行きます……ダーリンの熱いオチンポが……ゆ\nっくり私のオマンコを掻き分けて行きますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「このまま腰を落としきってぇ……あふっ……一番深いところまでぇ……届き\nました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……んっ、ダーリンのオチンポ硬いですわ……んんっ、グッと……\nオマンコを押し広げて……どんどんめり込んで来ています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あら……んっ、あらあら……私のオマンコの中で……ダーリンのオチンポが\nどんどん大きくなっていってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふふっ……色々仰っていても、やはりお身体は正直ということなのでしょ\nうね。ちゃんと私のオマンコで悦んで下さっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「となれば、私としても張り切らざるを得ませんわ……ダーリンには極上のひ\nとときを過ごして頂きたいですから……あんっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、んふっ、少しずつ激しく……オマンコの肉で、オチンポを\nお扱き致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「うんっ、あっ、ふっ……いかがですか……ずりゅずりゅっ……皮が擦れる感\nじ……お分かりに、なりますかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふっ……んっ、私も……ダーリンのオチンポの熱を直接感じて……とても\n……あっ、気持ち……いいですのっ……あふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっと腰を回して……んんっ、オマンコの中を馴染ませてぇっ……あくっ、\nはぁっ、太いオチンポが埋まる感覚……たまらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、んふふっ……ダーリンは、イルルのような若くて瑞々しいオマン\nコの方がお好きなのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「でも、しっかりと熟した……深みのあるオマンコも……じっくりと味わって\n頂きたいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ほら……んっ、ヒダの一つ一つが……丁寧にオチンポの幹と絡みついて……\nこうして……きゅんっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁふっ……今の……とても気持ちいいです……んんっ、もっと味わいたい\nと思いませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　ふふっ、オチンポでお返事なんてダーリンったら……♪　承知\nしました……たっぷり楽しんで下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あっ、はっ、あんっ……はぁっ、ほら……ダーリンのオチン\nポを……私のオマンコがぱっくり食べてしまってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あら……でも、視線はこちらのおっぱいの方に感じますわね\n……ふふっ、揺れるところを見たいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「構いませんわ……少し恥ずかしいですが……このおっぱいも、ダーリンのモ\nノなのですから……お好きなように愛でて下さいませ……あ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「うんっ……はい……ぎゅっとして……おっぱい愛して下さいませ……私もオ\nマンコを……ぎゅっとして……オチンポを愛しますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁ、ダーリンの硬いオチンポいいっ……中で……どんどん\n膨らんで……熱くなっていきますわっ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、すごいっ……腰が止まらないですわっ……オマンコが欲しが\nってっ……どんどん……激しくなって行きますのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ほら……んんっ、この一番奥の部分にぐりっとオチンポを当ててぇ……何度\nも腰を前後……させてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ、痺れますっ……私の気持ちいいところっ……ずっとオチンポで擦ら\nれてる感じぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もっとオマンコの中でキスしましょうっ……あぁんっ、ダーリンのオチンポ\nとクチュクチュするのっ……すごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あんっ、はんっ、あふんっ、ほら……いかがですか……？　私と一緒に……\n永遠の快楽を共に分かち合いましょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「どんなことでもしてさしあげますっ……私の……あらゆる力を捧げて……ダ\nーリンを真の男に致しますわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　あっ、あぁっ……！　ダーリンのオチンポっ……下から突き上\nげられてぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はふっ、あ、あくまでもご自身の力で……私をイカせるとっ……あぁっ、ダ\nーリン逞しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁっ、来るっ……オチンポ震えてっ、はひっ、お射精なさってっ……オマ\nンコの中にっ、全部出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁんっ！　あぁっ……出てるっ……奥までっ、ダーリンの精液っ、\nびゅくびゅく来てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……ゾクゾクします……んんっ、熱い子種を直接流し込まれていく感じ\n……あぁ……イルルの妹が出来ちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁ、んふっ……あぁ……落ち着きました……ふふ、徹底的に私がおもてな\nしをする筈が……逆にオチンポでおもてなしをされてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ですが、ご堪能頂けたのなら何よりです。ふふ……私もいつになく燃えてし\nまいましたわ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んっ……さて……まだまだダーリンのオチンポは、私の中で漲っていらっし\nゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふっ、もちろんこれで終わるなんて野暮は言いっこなし……続けて、私の\n身体を味わって頂きますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ！　うくんっ……あぁっ、ほら……オチンポもその気でとっても頼も\nしい……それでは早速……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふっ、はんっ、あっ、あんっ、はぁんっ……先ほどとは……少し、違う場\n所に……オチンポが当たっていますわっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふんっ、うくんっ、はぁっ……出していただいた精液を……オマンコの中に\n塗りつけるようにっ……亀頭を動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んくぅっ……オマンコもどんどんその気になってっ……新しいお汁が溢れて\n止まらなくなっていますのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はふっ、あぁっ、じゅぷっと……はしたない音がしてしまっていますっ……\nあぁっ、オチンポとオマンコの擦れ合う、いやらしい響きぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「こうしてまぐわっている実感が伝わると……乳首もしこって……お肌がピリ\nピリと痺れて……オチンポの感覚がよりはっきり伝わって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁっ、どんどん品がなくオチンポを貪ってしまいますっ……腰が……止ま\nらなくなってっ、くねくねさせてしまいますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、あぁっ、ダーリンからも突き上げがっ……！　あっ、あぁ\nっ、嬉しいですっ……オマンコも悦んでしまっていますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「そこっ、あぉぉっ！　そこはっ、弱いところですわっ……はひっ、ご、ご遠\n慮なく、お突きになって下さいませっ、おうっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、幸せですわっ……このまま永遠にこうしていたい位っ……\nダーリンのオチンポっ……味わい尽くしていますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっとかき回してっ……私もっ、強くオチンポッ……締め付けます\nからぁっ、はぁっ、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁっ、こ、これ以上は……あぁっ、イッてしまいますわっ……オマンコ良\nすぎてっ、このまま……最後までっ、あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　あぁっ、それですっ、あっ、その突き上げぇっ！　何度もされ\nたらっ、あひっ、たまらないですわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁっ、上がってきますっ、気持ちいいのっ、グリグリ来てっ！　またっ、\n私も……高まって参りますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ぎゅっとおっぱいを握りながらっ、腰を回してっ、あひっ、はいっ……感じ\nる場所っ……突き回してっ、あっ、あぁっ、も、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ダーリンもっ……イキそうなのですねっ？　はいっ、共に……最後の瞬間を\n迎えたいですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「また……中出しされてもっ、身体にぶっ掛けて頂いてもっ、大歓迎ですから\nっ……どうかっ、このまま激しくオチンポ動かしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、オマンコいいですっ、もう我慢出来ませんっ……あぁっ、\nイクッ、イキますっ！　ダーリンと一緒にイキますぅっ！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あひぉぉぉぉっ！　中っ……あぁっ、また……熱いのがっ……びゅくびゅく\nっ……出て……いますわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ひぁぁっ……イってますっ！　ダーリンのお射精でっ……私のオマンコもっ\n……いっぱいイッてますっ……くぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁぁ……もっと流し込んで……着床させて下さい……ダーリンの赤ちゃん\n……しっかりと種付けさせてぇ……ふぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ、残っている分も出し切って……オマンコ全部満たして下さいませ…\n…中に欲しいです……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あんっ……今……とどめの一発が出てきましたわ……んんっ！　奥に……び\nゅって当たるの……気持ちいいです……あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅ……全部出しきってしまわれましたか……？　良かったです……もう\n少しだけ、このままじっとしていましょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はい……こうして、ちゃんと胎内に精液を馴染ませてあげるんです……ダー\nリンの精液を……しっかりとお腹の中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「それにしても、やはりダーリンの精力は素晴らしいものでした……私の方が\nよっぽどたっぷりと栄養を頂いてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ……さて、お射精も落ち着いたようですね……本当にお疲れさ\nまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふふ……すくすく育ってくださいね……ダーリンの赤ちゃん……楽しみです\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　からだっ……熱いのっ……いっぱい掛かって……ますぅ\nぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んぁぁぁ……さっきよりも……もっとすごい量……んぁふっ……いっぱい出\nて……止まらないの……んぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁんっ……むわっとする精液のにおい……お射精がまだ続いてて……はぁ\nぁ……止まらないですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00023001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ちゃんと出し切ってくださいね……全部……んちゅぷっ、あぁ……濃くて美\n味しい……ダーリンのザーメン……もっと浴びたいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はぁっ……んんっ、今ので……全部でしょうか……？　はぁん……ちゅぷ、\nありがとうございます……本当にお疲れさまでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「んふぅ……顔の周りがベトベトです……このマーキングで……私は完全に支\n配されてしまうのですね……んぁふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ……ちゅぷっ、でも、ついてしまってるのはもったいないです……ちゅ\nぷ……どうせならオマンコの中か……直接飲みたかったかも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「でも、ダーリンの精液なら皮膚から吸収しても、素晴らしい効果が得られる\nかも知れませんね……ふふ……大満足ですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「後は……そうだわ、後ほどお風呂をご一緒しませんか？　色々と溜まった汚\nれを洗い流さないといけませんし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「その気になれば、またしっぽりと……夜はまだまだ長いですから……ね♪」", "NORMAL" ]},
