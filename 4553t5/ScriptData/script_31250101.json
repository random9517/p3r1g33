{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「失礼しますわ。ええ、連絡を受けて、参りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「……分かっています。隊長の力のことも、これからなにをするのかも。そう\nいったことも承知の上で、仲間になったわけですしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ですから、今さら行為の内容そのものにどうこう申しませんわ。ただ、こん\nな方法に頼らなければならない自分が不甲斐ないだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さて、それではさっさと始めましょうか。どうせやらなければならないのな\nら、早く終わらせてしまうに限りますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「まったく、さっそくこんなにペニスを勃起させて。もしかして、わたくしが\n来るまで、ずっとズボンのしたでかたくしていたのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「なんてはしたない。こんなのがわたくしの隊長だなんて、ため息しか出ませ\nんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さあ、その汚いイチモツをこっちに近づけなさい。わたくしの足で、してさ\nしあげますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あら、まさか他の場所でしてもらえると思ってましたの？　それは少し高望\nみしすぎではないかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「こんな汚いものには、わたくしの足だって、分不相応ですわよ。それっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふ。なんですの？　今の悲鳴。もしかして、踏み潰されるとでも思いま\nして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「……それも良いアイデアではありますけど、残念ながらわたくし、血で汚れ\nるのは嫌いですの。あと、あの匂いもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ですから、安心なさってくださいな。ほら、こんな風に……ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あはは。ヒクヒク震えてますわよ、隊長の勃起ペニス。おまけに先っぽから\n透明なのが滲んでますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの足に……足の裏に、ほら、我慢汁、ぬらぬらってくっついてしま\nったじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「まるでペニスが泣いてるみたい。気持ち良くて泣くなんて、情けないと思い\nませんの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「まあ、確かにわたくしの足はこんなにも美しいですから、触れるだけで感激\nして泣いてしまうのも、仕方のないことかもしれませんけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふ。どんどん透明なのがあふれてきますわ。この透明なのが出る場所を\n、指で……それっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、どうですか、隊長。足の指で尿道口を擦られる感触は。あはは。答え\nなくても、その顔で何が言いたいのか分かりますわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「擦ってあげる度に、びくびく震えて、泣きそうな顔して……あはは。そんな\nにわたくしの足が気持ちいいんですのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「じゃあ、こうしてあげたらどうなるのかしら？　足の裏で挟んで、扱いて差\nし上げますわ。ん、ん、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あはっ！　ますます泣きそうな顔に。おまけに、ペニス、どんどん膨らんで\nきてますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「血管も浮き出て、ぴくんぴくん震えて……青臭い匂いまで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……わたくしの、足で、こんなにも感じるなんて！　気持ちよさ\nそうな顔、してっ！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふ。なんだかこれ、ぞくぞくしますわ。隊長のその顔を見てると、わた\nくし、ぞくぞくが、止まりませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、ほら。もっと良い声で鳴きなさい。わたくしの足に、その汚らしいチ\nンポ汁を擦りつけてみなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あは。どんどん、ぬるぬるが……これ、足の裏に、擦れて、くすぐったくて\n……ん、ふあぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それに、匂いも……青臭い匂いが、あふれてきてますわ。おかげで、頭がぼ\nうっとしてしまいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んくっ、ん、はぁ、はぁ、はぁ……ふ、ふふ、ふふふふふ。これは、思いの\n外癖になりそうですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、もっと良い声で鳴いてください、隊長。でないと、ここで止めてしま\nいますわよ？　パワーアップ？　そんなもの、いりませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それよりも、隊長が涙声で最後までして欲しいとお願いしてくださる方が、\nとっても嬉しいですわ。ぞくぞくしますの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あははははは！　本当におねだりしましたわね。プライドはないのかしら？\n　みっともないですわよ、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ですけど、いいですわ、このまま最後まで気持ち良くしてさしあげますわ。\nわたくし、約束は守る女ですの。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、ほら！　ん！　ほら！　どうです？　わたくしの足……足の裏で、乱\n暴に擦られて……あはは！　ペニスが暴れてますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「もうイクんですのね？　泣きそうな顔になって……あぁ、隊長のその顔、意\n外と可愛いかも。ほら、もっと鳴いてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んあああ！？　びくって……熱いの……来たぁぁ！　んんんんん！　びゅく\n、びゅくって、足に！　足にぃぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふふふ。びゅくびゅくって、白いのがこんなにたくさん。見てください\n。わたくしの足、白いのでどろどろですわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ええ、これ全部、隊長の気持ち良くなった証拠ですわ。熱くて、臭くて……\nふふふ。まだペニス、どくどくしてますのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「びゅっ、びゅって、遅れてまだ精液が出てきてますわ。あぁ……足に全部か\nかって、本当に熱いですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの足をこんな風に汚したのは、隊長だけですわよ。そして、泣きそ\nうなイキ顔をわたくしに見せたのも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さて。それではわたくしの仕事はこれでお終いですわね。ではごきげんよう\n。隊長。ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あら……？　あらあらあら、これは随分と不思議ですわねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「今しがた、あれだけ射精なさったのに……どうして、このペニスは節操なく\n勃起したままなのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、お答えになって下さいな。正直に仰って頂ければ、わたくしとしても\n、色々と考えなくもありませんわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、どうなのです？　わたくしの足が、そこまで病みつきになってしまっ\nたのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうなのですね。つまり、もっと強く……さっきよりも惨めな姿を\nわたくしの前で晒したいと……そう仰るのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そうですわねぇ……そこまで仰られるなら、わたくしとしても多少考えなく\nもありませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、ではこうしましょう。その格好のまま、腰をもっと上へ突き出してみ\nて下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「精一杯の服従のポーズを見せて頂ければ、そのご褒美として続きをして差し\n上げますわ。さあ、いかがいたしましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふっ、ふふふふっ、あらあらぁ……もう少し迷う位されるかと思ったら、\n即、言う通りにしてしまいましたわねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「仮にも隊長ともあろうお方が、そこまでプライドを捨ててしまってよろしい\nんですの？　他の隊員が見たら、引いてしまいますわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ですが、言う通りに出来た子には、ちゃんとご褒美で躾けてあげないといけ\nませんわね、ほぅら……これがお好きなんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、またそんな情けない顔をする……ふふ、よっぽどペニスを足蹴にされ\nることが、気持ちよくてたまらないんですのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「このだらしなくぶら下がった睾丸……こちらも圧迫してあげましょうか。こ\nうして……ぎゅうっと……ふ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「痛いですか？　でも、それがお好きなんですよね？　一応は部下であるわた\nくしに、無様な姿を晒して、悶えるところを見て欲しいのでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「もっとタマをぐりぐりってさせてあげますか。ほら……ギリギリまで押しつ\nぶしてあげますねぇ、ふふっ、苦しそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、隊長の情けないお顔を見ていると、本当にゾクゾクして来ま\nす……。それだけでも、十分隊長には存在理由がお有りですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さあ……また切なそうにしている、ペニスをいっぱい可愛がってあげましょ\nう……いっぱいまで皮を剥いて……ぎゅうっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふっ、ふふふふふ、また歯を食い縛っちゃって。あぁ……チンポ汁を出し\nたい出したいって、ずーっと訴えかけていますのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さあ、観念してしまいなさい。どうせ我慢した所で無駄なんですから、また\nみっともなく射精する所を見せてご覧なさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「このビクついたペニス……しっかり踏み込んであげますから、さあ……早く\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ！　また私の太ももに、掛けるおつもりですのね？　はぁ……んっ、\nよく狙いなさい……ペニスの向きはこちらですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　またっ、出てきましたわっ！　足にっ……太ももにもっ……隊\n長の精液がっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふぅ……何ですの、これは。さっきよりも多いなんて……全くどれだけ欲\n情していたのか……つくづく呆れた方ですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ですが、この生命力だけは認めざるを得ませんわね……これなら、確かにわ\nたくしの力にもなりそうですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ああ、まだ奥に少しだけ残っているようですね。ええ、中途半端に残さず、\n出し切ってしまいましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そうです……びゅくっと……ふふ、これであらかた出し尽くしましたか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あぁ……見て下さい隊長。わたくしの足が、前にも増してドロドロになって\nしまいましたわ……本当にどうしてくれるんでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「いっそ、ご自身で舐め取って頂くのも……ふふ、ですがまぁ……この感触…\n…そう悪いものでもありませんわね……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さて……これで私の役に立ったのなら、隊長も本望でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「今日はぐっすりと眠れるのではありませんか？　ええ、心安らかにお休みな\nさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、ふ……どういうつもりですの？　そんなに腰を浮かせて……わたくし\nの顔を狙っていらっしゃるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ……面白いですわね、ええ……せいぜい頑張って届かせてご覧なさい。\n隊長の精一杯の噴水ショー、見せて頂きますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁんっ！　あっ……飛んでっ……んぁぷっ、本当に顔に飛ばして来ま\nしたわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「まさかと思いましたが……これだけの勢いで私の顔まで汚すなんて……ええ\n、確かに隊長は見事な生命力をお持ちのようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……ちゅぷっ……んっ、味も濃厚で……えぇ、力にはなりそうですわ\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「もう少し出そうですか？　もう遠慮なさらずに、さっさと全部出しきりまし\nょうか……ほら、扱いてあげますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふっ、ほら……まだこんなに残ってた……びゅるびゅる出して……今度こ\nそ大丈夫ですわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふぅ……収まりましたか。呆れんばかりの隊長の性欲……しっかり見せて頂\nきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ですが、まぁ……これで私の役に立ったのなら、隊長も本望でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「今日はぐっすりと眠れるのではありませんか？　ええ、心安らかにお休みな\nさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
