{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さん、私を呼びました？　トレーニング……えっ、奉仕？　何ですか、\nそれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103101" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00013001_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「え、えっちな事ですか！？　それは恥ずかしい……あ、でも、気にはなるか\nな……前に本で読んだだけだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00013001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「わ、分かりました！　私、やります！　お姫様は、何でもできないと困るの\nで。だから色々と教えてくださいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00013001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「わあっ、そんな乱暴に……逃げないためには必要なんですか？　なら我慢し\nます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103104" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「それで、これが男の人のチンポ……わぁ、大きくてビクビクしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「え、これを舐めるんですか？　それで精液を出ださせて、全部飲んだら終了\n？　確かフェラチオっていうんですよね？　私知ってますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「舐めれるかって？　も、もちろん舐めれますよ！　舐めます！　これぐらい\n私にだってできます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「れろっ、ちゅ……れろれろ、ん、じゅ、ちゅ……ん、れりゅ……こ、こんな\n感じですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「え、もっと舌を使うんですか？　えっと……れろれろっ、ちゅ、れりゅ、ん\n、んんっ……ちゅ、ん、れろっ、んっ……ちゅりゅ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「舐めるたびに震えて……ん、変な感じです……ちゅ、れろ、ちゅう……んれ\nろ………れりゅ、んはぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「優しくしないと駄目だと思ってたんですけど、強く当ててても大丈夫なんで\nすね……私のアソコとは……あ、いえ、何でもないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あ、えっと……そ、そうです、すごい臭いです。舐める前から臭いがしてて\n……良い臭いじゃないのに、何故か臭いたくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ん、それに臭っていると、もっと舐めたくなってきて……れろっ、ん、れろ\nれろ……ちゅ、ん、んんっ……じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「それに、不思議な味もして……舌で舐めるとお汁が出てきますよ……りゅ、\nん、おしっこじゃないんですよね？　これが精液……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あ、違うんですね。もっと舐めないと出てこないなら……頑張って舐めます\n。れろ、ちゅ、んん……ちゅ、れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ん、じゅる、れろ、ちゅ……ん、せっかくだから、ちゃんと出して欲しいで\nす……気持ちよくなって欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「れりゅ、ん、れろれろ……ん、じゅるぶ、じゅ、ん、ちゅ、れろ……じゅる\n、ずちゅぅ、ん、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「まだまだ固くなって……チンポってすごいですね……こんな風になるなんて\n……じゅぶ、れりゅ、ん、れりゅれりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「これでどうですか？　……気持ちいいですか？　よかったです。でも、こん\nなに大きいと舐めるの大変です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「え、咥える？　えっと、チンポを口の中に入れるんですか？　それだと全部\n舐めれますけど……あ、そ、それもフェラチオなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゃあ咥えますね……はむっ、んんっ……大きい……口には入りますけど、\n全部は無理です……こんな大きいの、全部咥えれないですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゅぶ、れろ……ん、ちゅ、じゅうるるる、んはぁ、じゅぶぶぶっ、ちゅ、\nん、んんっ、じゅちゅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゅぶぶぶっ、はぁ、ん、本当に大きい……はぁ、じゅぶ、ん、んんっ！　\nはぁ、こんな大変なんだ……はぁ、じゅるるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「こ、こんな感じでいいんですよね？　……ふぅ、良かったです。ん、じゅる\nるっ、ちゅ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「で、でも、やっぱり隊長さんは、全部咥えて欲しいんですか？　……ううっ\n、わかりました。じゃあ咥えますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ん、はぐっ……んぐうっ！　ぐっ、じゅぶぶ、んんむぅぅぅっ！！　はぁ、\nぐぅ、んんんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「喉の、奥に……ぐっ、はぁ、んんんんっ！　じゅぶ、そんな乱暴に……ん、\nじゅぶぶぶっ、ん、むうぅ……ぐうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「少し、苦し……んぐぅ、んんっ、はぁ、じゅるるるっ、じゅぶ、じゅむぅ…\n…おえっ、んうううっ……げほげほ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「っはぁ……ん、ここまでしないと駄目なんですね……でも、また固くなって\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さん、さっきから私の顔見てますけど……もしかして、私を見て興奮し\nたんですか？　わわっ、変態じゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「でも何か興奮してくれたのは、嬉しいです……ん、またビクビクして……ず\nりゅ、ん、じゅるるっ、はぁ、じゅぶぶぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁ、んんっ……じゅぶぶっ、ちゅう、れりゅ、ん……・はぁ、えっ？　イ\nキそうなんですか？　それって、精液出すって事ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「わ、分かってます……ぜ、全部飲むんですよね……じゅ、ん、だから、ちゃ\nんと私の口の中に、精液だしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さんの精液……ん、じゅる、私に、ください……ん、イッテください…\n…じゅぶぶぶっ、ちゅ、りゅるる、じゅ、ん、んむぅ、じゅるるるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　んぐうっ、ん、ごほっ……すごい、勢い……ん、はぁ、んむ\nぅ、はぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ごくっ、ん……飲まないと、息が……ん、じゅるるるっ、はぁ、ん、んぐっ\n、じゅるるるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ごくごくん、じゅるるっ、はぁ、これが精液……すごいですぅ……ちゅ、じ\nゅるるっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……ようやく止まりました……こ、こんなにいっぱい出るなんて、\nすごいビックリしましたよぉ……口の中が精液でパンパンになって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「それに熱くて口の中が火傷したんじゃないかと思ったし……まだベタベタす\nるし、変な臭いがずっと残ってるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ちょっと思っていたのと違います……前に読んだ本は、もっと幸せそうで…\n…あ、いえ、なんでもないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゃあこれで終わり……え、もう一回？　二回やるのが当然なんですか……\nというか、まだ出るんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「でも、確かにチンポは大きいままで……出したのに、全然変わってないです\n……まだここに精液が溜まってるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「わ、分かりました！　ちゃんと最後まで出してもらいます！　一回目ので、\n何となくわかった事もありますし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゃあ舐めますね……ん、れろっ、ちゅ、ん、れろれろ……じゅるっ、ちゅ\n、ん、ちゅちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ここの先っぽを舌で擦ると、チンポ、すごいビクビクします……ここが弱点\nなんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「へへっ、この周りもですよね？　れろりゅ、れろれろ……ちゅ、ん、れりゅ\n、れりゅりゅ、んむぅ、ちゅ、ぐちゅ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅっ……ん、ちゅ、ん、れりゅ、んっ……じゅ、れろれろ……れり\nゅ、れろん、ちゅ、れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「れりゅ、ん、舐めると、どんどん汁があふれてきます……本当に溜まってる\nんですね……じゅるっ、ん、しかも濃いままですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅい、ん、はぁ、んんっ、じゅ、ちゅちゅ、れろれろ……じゅ、れ\nろりゅ、れろ……ん、ふぁ、じゅ、ちゅ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「どうですか？　気持ちいいですか？　……へへっ、気持ちよくて良かったで\nす……ん、咥えてもっとして欲しいんですか？　わかりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はむっ、ん、じゅるるっ、ちゅ、れろ……はぁ、ちゅるっ、ん、じゅるるる\nっ、ちゅむっ、ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「咥えた後でも、舌を使うんですよね……れりゅ、んんっ。じゅむ！　れりゅ\n、じゅっむ、ん、れろれろ……じゅ、じゅぼ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゅむ、ちゅ、れりゅ……唇で、こうやって擦ると、気持ち良さそうに震\nえて……じゅ、ちゅ、れりょ、じゅぶぶぶぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ん、さっきみたいに奥まで……んぐっ、じゅ、じゅぶっ、ん、じゅるっ、じ\nゅ、ちゅ、んんっ、ちゅ、はぁ、ん、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゅび、んはぁ……ん、んっ……げほっ、ん、やっぱり少ししんどいですけ\nど、これで気持ち良くなるなら……じゅ、ちゅ、れりゅ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「んんっ、じゅるるっ、じゅ、じゅぼ、ん、ちゅ、んむぅ、んんんっ……はぁ\n、じゅぶ、じゅぼぼっ、んん、じゅむぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「また膨らんで……ん、出そうなんですか？　はぁ、ん、いいですよ、出して\nください……じゅ、じゅぶぶぶっ！　ちゅ、じゅ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「私の口の中、精液でいっぱいにして……じゅる、ちゅん、じゅる……濃くて\nネバネバしたモノで、いっぱいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「どんどん濃いお汁が出てくる……ん、れろりゅ、ん、もっと勢いよくいっぱ\nい出してください……ちゅ、んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「じゅうるるるっ、んはぁ、ちゅ、んん……じゅるるっ、じゅむっ、んんんん\nんんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "外して射精","LABEL1","そのまま射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あっ！　なんで急に抜いて……あんんっ！　熱い、ん、これ、精液！？　あ\nあっ、いっぱいかかって……はぁ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「顔中が熱いし、ベトベトして……ん、それにすごい臭いがする……わっ、髪\nにまでかかってる……こんなところまで飛んでるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「精液って、かけられたら、こんな感じになるんだ……ん、身体がちょっとポ\nカポカしてきて、ちょっと変な気分になりそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「正しい反応なんですか？　そ、それならよかったです……あ、そ、そうだ、\n隊長さん、何で急に抜いたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「……え？　二回目は顔にかける？　そ、そうなんですか？　お決まり、なん\nですか？　わ、わかりました。ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「それにしても、さっき出したのに、まだこんなにいっぱい……はぁ、すごい\nです……これが男の人なんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁ、隊長さんの臭いがする……ん、私、すっかりマーキングされちゃいま\nした……何かドキドキが止まらないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「これでトレーニングは終わりですか？　え、また次も、その次もあるんです\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ど、どうしよう……またマーキングされて、いっぱい臭いがついちゃうかも\n……でも、そういうの、ちょっと良いかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あ、あの、またトレーニングお願いしますね！　その時は、またいっぱい出\nしてもらえるように頑張りますから、色々と教えて下さいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「んぐっ！　ぐううっ、ん、んんんっ！　ふぐっ、ん、んんんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ごくっ……はぁ、ごくごくっ……ん、んんっ、じゅぷっ、じゅるるるるっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「っぷはぁ……すごいです！　一回目と変わらないぐらい出てましたよ……さ\nすがにそんな事はないと思っていたので、ビックリしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「う～、やっぱり変な味です。けど何かクセになりそうな気もするんですよね\n……濃厚で粘っこくて、すごい飲みごたえあって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「え、まだチンポについている精液も全部舐め取るんですか？　　確かに綺麗\nにしないと気になりますよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ちゅる、れろ……れりゅ、れろれろ……ちゅ、じゅるっ……ん、自分の唾液\nなのか、隊長さんの精液なのか、分からなくなってきました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ちゅるるっ……ん、これでどうですか？　言われた通り、全部舐め取りまし\nたけど……合格ですか？　良かったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁ……ん、何か口の中が、まだ粘っこくて……ん、口の中、隊長さんの味\nがずっとしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「変な味なのに、嫌いになれない……それに、こんなにたくさん飲まされて…\n…また欲しくなったら、どうしよう……えっ？　飲ませてくれるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「えっと……じゃあお願いします。でも隊長さん、私がこの味を好きになった\nら、ちゃんと責任取って下さいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}