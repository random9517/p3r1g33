		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こんなに勢いよく精子が飛び出るなんて……！　んっ、あぐっ……！　しか\nもこれ、さっきよりも濃い臭いを感じますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩のザーメンが直接センサーに届いてるから、おっぱいに出される\nよりも気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、んんっ！　こんなの、イクの我慢できませんっ！　また、イ\nッちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、あはぁ！　イクッ……イッ、イキますっ……！　カツ\nマ先輩のザーメンで汚されながら、イクッ……あんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ふっ、あふぅ……！　えへへ……カツマ先輩の精液で、おっ\nぱいも顔もベトベトです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「精子の臭いもどんどんボディに染み込んできてて……これじゃあ、本当にカ\nツマ先輩の専用機になっちゃいますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ……？　ノゾミはもう、カツマ先輩のモノ……？　そ、そそそっ……！\n　それって、本当に専用機ってことじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「い、いえっ！　イヤだなんてこと一切ありませんっ！　むしろ、凄く嬉しい\nですっ！」", "NORMAL" ]},
