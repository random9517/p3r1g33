		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁっ……！　またいっぱい谷間に向けて出されてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203301" ]},
