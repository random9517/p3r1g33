		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「濃厚なミルクがどぴゅどぴゅ出て……！　ノゾミのおっぱいを汚してますっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それにいやらしい臭いもさらに濃くなって……！　んっ、はああぁ……！　\nこれ、またイッちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩の精子の臭いで……身体の奥が疼いてっ……！　あっ、来るっ…\n…！　気持ちいいの、溢れてきますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
