{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あ、あのっ！　今日は以前メンテナンスしてもらったお礼もかねて、ノゾミ\nがご奉仕させていただきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「いっぱいオチンポを気持ちよくしてみせますので、カツマ先輩はリラックス\nしててくださいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「では、失礼して……！　んっ、ふっ……！　こうしておっぱいでオチンポを\n挟んで、思いっきり胸を寄せて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あとは……両側から圧をかけながら、上下に揺すったりすればよかったはず\n……！　んっ、んっ……！　あっ、くっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ど、どうですか……！？　ちゃんとカツマ先輩のオチンポ、気持ちよくでき\nてますか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのおっぱいは他の子より少し小さいから、あんまり気に入ってもらえ\nないんじゃないかと不安だったので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そ、そんなっ！　十分大きくて可愛いおっぱいだなんてっ！　そんなに褒め\nても、何も出ませんよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「でも、ノゾミのおっぱいを可愛いって言ってくれたのは、素直に嬉しいです\n！　お返しに、いーっぱいズリズリしてあげますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ふっ、あっ……！　擦れば擦るほど、オチンポがノゾミのおっぱ\nいの中で、どんどん熱くなっていってますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カリのところが谷間に当たると、おっぱいがオチンポの形に沿って、いやら\nしくひしゃげますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　おっぱいの動きに合わせて、オチンポがビクビク跳ねてる\nっ……！　大きな棒が谷間で暴れる感じが……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そんなに動かれたら、ズリズリしにくいですっ……！　もう少し落ち着いて\nくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「……ノゾミのおっぱいが気持ちいいから、オチンポが勝手に反応するんです\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「な、なるほど……！　そうなんですね……！　ですが、これ以上暴れられる\nと大変なので、もう少し圧を強めさせてもらいますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「腕の出力を上げながら、おっぱいの根本あたりにオチンポが来るようにして\n……んっ、はあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こうやってすっぽり谷間に埋まる感じにすれば、さっきよりも動かしやすい\nですし……何より、カツマ先輩のオチンポを強く感じます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、あっ……！　んっ、ひっ、あふっ……！　はぁ、んふっ、くっ\n……あっ……！　ふっ、あふっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ……！　オチンポの先端から、ヌルヌルした汁が出てきましたね\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「確かこれ、オチンポが感じると出てくるエッチな汁……なんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ……！　カツマ先輩の汁が谷間に広がって、ぐちゅぐちゅっていやらし\nい音もしてきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ……？　この汁に塗れながらオチンポを擦られると、もっと気持ちよく\nなるんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「わかりました！　では、オチンポやおっぱいにカツマ先輩の汁を塗り込みな\nがら、シコシコしていきますね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んふっ、はっ、くうぅ……！　あっ、あっ……！　ひっ、あんんっ……！　\nはぁ、ひっ、あぅ……くっ、んんっ……んはぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「エッチな汁をかき混ぜながらおっぱいを動かすと、濃い臭いがしてきますね\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「オチンポの香りといいますか……凄く男の人って感じの臭いがして、何だか\nクラクラしちゃいますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　このエッチな臭いを嗅いでたら、もっとおっぱいでご奉仕\nしたくなってきちゃいました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩のオチンポ汁もドクドク溢れてますし、このまま一気にスパート\nをかけさせてもらいますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「上下に揺らすだけじゃなくて、おっぱいをグニグニ動かしながら左右にも振\nって……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「身体全体を動かしながらオチンポを谷間に擦りつけたりすると、もっと気持\nちよくなれるんですよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅっ！？　激しく動いたら、オチンポのビクビクももっと激しくなっ\nてきました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「オチンポが何回も小刻みに動いて、先端がヒクヒクしてる感じがしますっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これが射精しそうっていう合図なんですか……！？　でしたら、このまま射\n精してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのおっぱいで感じてくれたなら、おっぱいに向けてびゅるびゅる精子\nを出して欲しいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩の子種を感じさせてくださいっ……！　おっぱいで妊娠するくら\nい、いっぱい出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、あっ！　オチンポの奥からドクドクって波が来てるっ……！\n　出してっ！　ノゾミのおっぱい、いっぱい汚してくださいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「きゃうぅぅ！？　こ、これがカツマ先輩のザーメン……！　ぐちゃぐちゃの\nドロドロで、凄くネバついてます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「オチンポが跳ねながら、小刻みに汁が飛びでてます……！　おっぱいから抜\nけ出すくらいの勢いで、激しくビクビクしてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「それにこの臭いっ……さっきの汁よりも、濃くていやらしい香りがしますっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「異臭センサーが異常を訴えてきてるのに……もっと嗅いでいたくなります…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「これ……本当に凄いですっ……！　こんな感覚、初めてで……！　んっ、あ\nっ、あっ……！　んんんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……！　ノゾミがご奉仕しないといけないのに、精液\nの臭いで軽くイッちゃいました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさいっ……！　イッちゃダメって思ってたのに、おっぱいに出\nされてるのがカツマ先輩の精液だと思うと、我慢できなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミがイッてくれて嬉しい……？　あの、えっと……！　な、なら……も\nう１回、おっぱいでオチンポをシコシコしていいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「カツマ先輩のオチンポもまだ満足してないみたいですし……ノゾミも、もっ\nとオチンポで気持ちよくなりたいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「い、いいんですか……！？　ありがとうございます！　では、もう１度おっ\nぱいでオチンポをスリスリさせてもらいますねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ！　あっ、ふっ、んんっ！　精子が谷間に広がってるせいか、さ\nっきよりも滑りがよくなってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ズリズリするたびに、カツマ先輩の子種がオチンポと谷間にべったりと引っ\n付いて……ヌルヌルした感触が心地いいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　オチンポも１回目より激しく跳ねて、谷間で暴れまわって\nますねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「さっきあんなに精子を出したのに、まだノゾミのおっぱいでこんなに感じて\nくれるなんて……凄く嬉しいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「嬉しすぎて、カツマ先輩のオチンポに触れてるだけで……また身体の奥が疼\nく感じがしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「こうしておっぱいを寄せて、亀頭のところを撫でると……はぁ、んんっ……\n！　エッチな声が止まりませんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00024802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのおっぱい、カツマ先輩の形になっていってますっ……！　臭いもた\nくさん染みついて……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「なんだか、カツマ先輩の専用機になってるみたいですっ……！　あああっ！\n　か、カツマ先輩を独占できるなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、んふっ……！　だ、ダメっ……！　感じて気持ちよくなる前に\n、カツマ先輩をイカせないとっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「オチンポをこうやって根本からすくい上げて……！　一気に下に下ろしたり\nしてっ……はぁ、んんっ！　あっ、あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「乳首を亀頭に押し当てたりしながら、ズリズリ擦って……！　いっぱい、オ\nチンポに刺激を与えないとっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　乳首でオチンポを刺激しながらシコシコすると、オチンポの\n震えがさらに強くなってきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「そろそろ、イキそうなんですかっ……！？　でしたら、またお好きなところ\nにびゅーびゅー精子を出してくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「どれだけ出されても、全部ノゾミが受け止めて見せますので……！　ですか\nら、どうぞ好きなタイミングで射精してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
