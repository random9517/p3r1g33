		{"command":[ "SETIMAGE", "0", "still_00024802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミのおっぱい、そんなに気持ちよかったですか……？　えへへ……それ\nなら、嬉しいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「ノゾミもカツマ先輩を気持ちよくできて、凄く嬉しいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「おっぱいでして欲しいときは、いつでも言ってくださいね。カツマ先輩のた\nめなら、悦んでご奉仕しますので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_248_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ノゾミ" ]},
		{"command":[ "SETTEXT", "「えっ……？　なら、もう１回して欲しい……？　勿論ですっ……！　カツマ\n先輩が満足するまで、何回だってお付き合いしますね！」", "NORMAL" ]},
