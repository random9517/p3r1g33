{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ……！　強い威圧の力を感じます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120001" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「カツマさん！　彼女が不審者で間違いありませんね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい！　こいつが……こいつが聖夜の不審者です！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「気をつけてください！　そいつ、幻術を使うんです！　それでカグヤもやら\nれて……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の叫び声にも、ダークサンタ・マスターは冷徹だった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……何を言っている。何度も言うが、私は何もしていない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そいつが勝手にダメージを受けているだけだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「わ、私がカツマとカップルだなんて……。そ、それに誘っているわけじゃ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「でも……もしカツマがそうしてほしいなら……それなら、私……。んんん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「好きにして……。私があなたのプレゼント……。ああ、いいの……あなたに\nだったら何をされても構わない……強く抱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ああ……カグヤさん。こんなにも幻に囚われて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120003" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから幻ではないと言っているだろう！　忍術だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120003" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「不審者さん！　クリスマスで幸せそうなカップルをぶち壊しているのはあな\nたですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120004" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それについてはその通り！　当然だ。それがこの日の楽しみだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120004" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんてやつだ！　結構可愛い顔してるくせに、中身がドロドロしすぎだろう\nがっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「か、かわ……。……え、ええいうるさいうるさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120005" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "激怒していたダークサンタ・マスターは、突然バッ、と後ろに飛び下がった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……なんだ？　この気配は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120006" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いたです！　あそこ、あそこに学園長とカグヤがいるです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおっ！　兎子にエファ、そして姫様！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「商店街の人々を撒くのに少々時間がかかってしまいました。ですが、ここか\nらは私達も参戦するわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ、はぁ……。よ、ようやく見つけたわ……。そいつが…\n…そいつが不審者ね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいぞ！　援軍が来ればこっちのもんだ！　この人数なら確実に勝てる……\n囲め、囲め！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふぅーむ？　それなりに、人を集めてきたようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120007" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ええ、そうです！　不審者の正体がわかった以上……逃がしはしません！　\n……覚悟しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「プッ……、フフフ、クフフフ……ハハハハ！　覚悟！？　誰が覚悟なぞする\nものか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120008" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お前ら１人１人を倒すことは、今の私には容易いぞ。だが、７対１は少々骨\nが折れるのでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もはや、手加減してやれんぞ。本気で術を出させてもらう……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「外道忍法……漆黒聖夜！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120011" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うああああああああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くぅうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とてつもない破壊力で、黒いサンタの幻術は俺達を一網打尽にする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「だ、駄目ですぞ！　私どもでは手も足も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022120001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クソッ、７人がかりでこれかよ……！　こいつ、カップルに何の恨みがある\nんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「きゃッ……！　このままでは、服が破れて……脱げてしまいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120005" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはそれで見てみたい！　が……こっちが不利なことに違いはないぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「きゃあああっ！　ス、スカートがめくれるです！　短いスカートがあだにな\nりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「やだっ……髪の毛がグチャグチャに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アハハハハハ！　負けを認めるか！？　でなくば永遠に、私がお前達を襲い\n続けるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120012" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさに絶体絶命の大ピンチだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひたすら幻術に翻弄される俺とジュンジローだったが、学園長だけは……もじ\nもじしているカグヤを見据えて、力強く言い放つ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「……カグヤさんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120006" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「今、彼女に……ダークサンタ・マスターさんに対抗できるのはカグヤさんし\nかいません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴女に渡した服は、見せるためにあるんです！　貴女が見てほしい人は誰で\nすか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「この服を……見て欲しい人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「そうですっ！　負けてはなりません、貴女にしか出来ないことが必ずあるは\nず……きゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120009" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "頼みの学園長も、もう長くは立っていられない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それくらいに、ブラックマジシャンマスターの幻術は圧倒的なパワーを持って\nいる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「貴女が、彼女を倒すのです！　カグヤさん！　しっかりなさい、カグヤさん\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120006" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園長の必死の訴えに、カグヤはようやく我に返ったらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私は……守らなきゃいけない。この町のクリスマスと、大切な人達を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「見えた……！　月影流忍術奥義・散多の術（さんたのじゅつ）……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "散多の術、それは文字通り己を散らし、多く増やす忍術のようだった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000213_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「にゃ、にゃにっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120013" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カグヤが２人、３人、４人……。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00000213_01", "0", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00000213_01", "0", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00000213_01", "0", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿な！　こんな高度な忍術……私の他に使える者がいるものか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120014" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「出来る。大切な人を守るために、私の忍術はあるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120009" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00000213_01", "0", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00000213_01", "0", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00000213_01", "0", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "多すぎる分身で不審者を戸惑わせたカグヤは、もうすっかりいつもの冷静さを\n取り戻していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいぞ……！　そのままやっちまえ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「征矢抜刀・散多斬り（せいやばっとう・さんたぎり）」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「っぐぅうううううっ……！　しまった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120015" ]},
		{"command":[ "SETCHARA", "0", "char_00010005_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "トドメを刺された黒いサンタは、ドロンと黒い煙に包まれる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お、おぼえてろバカップル！　またクリスマスにイチャイチャしてたら、邪\n魔してやるからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022120016" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "捨て台詞を残し、その場から慌てて立ち去るダークサンタ・マスター。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……勝った、の……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120011" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ええ、そうですよ！　やりましたね！　貴方達は私の自慢の生徒です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120011" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大喜びする学園長に、俺とカグヤはぎゅうううっと両腕で抱き締められた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120012" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おおおおお！　凄まじく幸せな弾力が！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……カツマ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120013" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いやっ！　なんだ、そのっ！　お前のおかげで勝てたぜ、カグヤ！　あ\nりがとうな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なんだかごまかされた気がするけど……、うん。勝てて良かった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120014" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぼよんぼよんと半端なく弾む学園長のおっぱいは、ところどころ破れたセクシ\nーな衣装によってその威力を倍増させてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「真の不審者はアンタですよぉおお、たまんねええええ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「むううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120015" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「悪は滅びました。これでようやく、この商店街に穏やかなクリスマスが訪れ\nましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120012" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやあ、恐ろしかったですなあ。こんなこと、もう二度とごめんですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022120002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。とんでもねー敵だったぜ……。一体正体は誰なんだ……ダークサンタ\n・マスター」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「さっき本名を名乗ってたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120016" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "呆れるカグヤは、ふと、自分の頬に落ちてきた冷たい感覚に顔を上げた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あ。雪が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120017" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あら。本当ですね。ロマンチック……ホワイトクリスマスです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120013" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひらひらと舞い降りる白い粉雪を見上げ、俺達は束の間の平和をしっかりと味\nわうことにした……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「って、綺麗にしめてるんじゃないっ！　私達の衣装がボロボロになってしま\nったじゃないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「これは……クリーニングじゃ修復出来なさそうね。ちゃんと修理してもらわ\nないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「まったく。巻き込まれて酷い目にあったです……。この責任は、あなたにと\nってもらうとしますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022120003" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺か！？　俺も頑張ってたろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「でもまあ、衣装の修理費くらいは払ってもらわないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうですそうですっ！　それから、バイト代としてたっぷりプレゼントも買\nってもらおうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えええええっ、横暴な……！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「うふふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020022120014" ]},
		{"command":[ "SETCHARA", "0", "char_00002603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "プンプンしている幹部達、雪に手を伸ばす学園長とカグヤ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだわ。私達が商店街の皆様からいただいた貢ぎ物も、持って帰っ\nてちょうだいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060022120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000308_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それはいいですね。あっちにまとめて置いてありますから、よろしくお願い\nします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022120004" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いつのまにそんなことになってたんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_ETC0022120016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "驚愕する俺をよそに、３人のミニスカサンタ達は次々にプレゼントの山を手渡\nしてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「これも、これも、これも、これもです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050022120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐええっ、こんなに持てないって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_ETC0022120017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「１つでも落としたら承知しないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070022120005" ]},
		{"command":[ "SETCHARA", "0", "char_00000112_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_ETC0022120018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……私も持つから大丈夫」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120018" ]},
		{"command":[ "SETCHARA", "0", "char_00000213_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっと荷物を俺から奪い取り、カグヤはすたすたと歩き出す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こういう力仕事は任せて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120019" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいのか？　ほとんどカグヤが運んでるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_ETC0022120019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「最初に言ったでしょ。何があってもカツマを守れるようにって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010022120020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ありがとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_ETC0022120020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "感謝する俺を見て、カグヤは何故だか嬉しそうだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}