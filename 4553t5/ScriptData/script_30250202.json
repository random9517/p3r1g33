{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……ふふ……じっとしてな……余計な真似をしたら、そのままチンポを\nちょん切っちまうからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「何、大人しくしていりゃ悪いようにはしないよ。要は、私の疼きをお前さん\nの身体で晴らしてやろうって、それだけのことなんだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204102" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それだって、元を正せば、お前さんのいかがわしいモノが原因なんだから、\n当然、責任を取る覚悟は出来てるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「実際、ちゃんとチンポはおっ立ててるじゃないか。ふふ……どれ……ちょっ\nと、軽く馴染ませとくかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……ふふ……ちょうど私のスジの所と……擦れてるだろう……？　素股\nってやつだ……どうだい、オマンコが濡れてるの……分かるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「このまま、ずぶっと一息にチンポをハメたら気持ちいいだろうねぇ……オマ\nンコも、じゅくじゅくして、準備も出来てるしねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こうやって……入り口の所で腰を回して……ふふっ、チンポの先がもどかし\nいかい？　あぁ、私も同じだよ……すぐにでもハメたくてウズウズしてる……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「でも、まだだよ。お前さんのチンポは、まだバイブでしかない。私の気分で\n、使うかどうかを決めるただの道具なんだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ちょっと焦らす位のことも、楽しみの中に入れておかないと……さっさと終\nわらせるだけじゃ性に合わないからね……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……いい顔をするじゃないか……思い通りにならない余裕のない表情…\n…それが、私を興奮させる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ハメたいかい……？　チンポの先が、ずっとその気になったままで辛そうじ\nゃないか……ふふっ、可愛いねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうする、おねだりでもしてみるかい？　疼きチンポをどうにかして下さい\nってねぇ……ふふっ、冗談さ。そんなモノを聞いても仕方ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あんまり焦らしても可哀相だしね……私の方も、そろそろしっかりと幹全体\nを味わいたくなってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ……入るよ……くぅ……んっ……おっ、ふっ……んっ、はぁぁぁぁぁぁ\nぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……どうだい、オマンコがしっかりチンポを咥えこんだだろう？　特\n等席で、よーく見えるはずだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「私のマン肉がくぱっと割れて、チンポが挿し込まれてる瞬間だ。ふふ……遠\n慮なくジロジロ見てくるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「しっかり腰に踏ん張りを効かせておくんだよ。すぐに漏らしちまうようなこ\nとがあったら、二度とそのチンポが使えなくなると思った方がいいからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さて……それじゃ、本格的に味見をさせてもらおうかね……ふっ、んっ、う\nんっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふむ……硬さはしっかりあるようだね。私はフニャチンよりは、こっちの方\nが好きだから、まずは及第点にしといてやろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「後は熱量か……まぁ、こんなもんってとこかね。せっかくオマンコで受け止\nめてやってるんだ……しっかりチンポも応えてくれなきゃねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……気持ちいいかい？　まぁ、一応はこれでも、しっかり身体は鍛えて\nいるからね。このチンポに圧を掛ける位はどうってことない……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んむぅ……ほら、肉ヒダがチンポにみっちり絡みついて来るだろう？　今…\n…マン汁をチンポ全体に浴びせてる真っ最中ってことさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「もっと動かしていくよ？　ふっ、はっ、んっ……んむっ……ふっ……んんっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら、どうした、そっちも腰を使っていいんだよ？　下からチンポを突き上\nげて……バイブ程度の動きはしてみせるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ、そうそう……そういうことだよ、ちゃんと……しっかり\n子宮に当たるように……狙いをつけて、ぐっと押すんだ……ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうしたら、こっちも……ちゃんとご褒美をやるからね……うくんっ、ほぉ\nら……オマンコの２段締めだよっ……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら……どうだいっ……チンポとオマンコがぎゅっとくっついて……んっ、\nふっ……ヌルヌル擦れて……粘膜同士のキスを重ねてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁんっ、チンポの先と……根元の方で……別々に、んっ……気持ちいいの\nが来てるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「力加減を調節すれば……あふっ……同時に締め付けも出来るし……あっ、も\nっと……みっちりくっつけられる……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ、もっと腰を使うんだ。チンポしか取り柄がないなら、せめてそこだけ\nは頑張らないとねぇっ、ふっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おや、何だい。その評価じゃ気に入らないのかい？　ふふ……おっぱいだけ\nはじっと見ながら不満そうにされてもねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こいつに触りたいなら、気合を入れて突き上げるんだよ……んっ！　あぉっ\n！　そうそうっ、もっとだよっ……んっ、もっとだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……あぁ……チンポが膨らんできてるのが分かるよ……我慢なん\nかするんじゃないよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くぅんっ……いいよっ……このまま出すんだっ……！　子宮に当たるように\nっ……直接流し込むんだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ……来るよっ……あぉっ、あぁっ、くぅぅんっ！　イ……イク\nッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……あぁ……くぅぅ……オマンコに広がってく……んくぅぅ……た\nっぷり出てる……精液の味だ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くぅうん……膣の中が……いっぱいにされていく感じ……久しぶりだ……あ\nぁ、いいねぇ……ずっと忘れていた感覚だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ、く……まだ、出るんだろう……？　変に止めたりしないで……しっか\nり吐き出しちまわないとね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、ゆっくり収まっていく……終わっちまうのが少し名残惜しい\nね……んっ、ふぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ、だけど、やっぱり中出しはいいね。オマンコの中で、活きのいい精子\nが泳いでる感じが残ってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「でも、まぁ……たかだか一発出した程度じゃ、まだまだてんで物足りないね\n……すぐ続きに入ろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「別に何の不満もないだろう？　射精した後でも、ちゃんとチンポはしっかり\nおっ立ったままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうなんだい？　私のオマンコ……もっと味わいたいと思わないかい……？\n　んっ、ふふっ……チンポの方が分かりやすい返事をくれてるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ、単なる肉バイブなんて言われたくなきゃ、もっとしっかり私のオマン\nコを悦ばせるんだ。まだまだ、お前さんはこんなものじゃないんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ……ふっ、そうそう……小手先の技なんかに頼らないで、も\nっとズンッと……強くオマンコを突くんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「Ｇスポットを擦りながら……もっと奥にっ……子宮の入り口を小突いてっ…\n…はぁんっ、身体がっ……ビクって跳ねるっ……だろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それをっ、休まないでっ……続けてっ、繰り返してっ、あひっ！　あぁっ…\n…ぶっといのがいいっ！　チンポっ、ゴリゴリされるのぉっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁんっ、生意気だけどっ……んっ、やるじゃないかっ……くぅぅ\nんっ、やっぱり、女を泣かせた回数だけは一人前みたいだねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「その調子で……私のオマンコも泣かせてみせなっ、あぁっ、あぉっ、くぅう\nんっ、んふっ……私もっ、しっかりお返し……するよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、くぅっ……ほらっ、どうした……？　顔が情けないことにな\nってるよ？　ふふ……責めるのは得意でも、責められるのは苦手かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あひぉっ！　んっく……ちゃんとっ、反撃してくる辺りは……分かってるじ\nゃないか……あふっ、あっ、んくぅぅ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「もっとだよ……もっと腰を暴れさせるっ、チンポの先をっ……子宮に当てて\nっ、何度も擦れっ！　はぁんっ、いいぞっ、止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふっ……弾むおっぱいが気になるかい？　見たければ存分に見ていいよっ\n……その代わりっ……もっとチンポするんだよっ！　チンポいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、そうそうっ、そうやって突けばっ……自然にゆさゆさ揺れ\nるんだからっ……もっと、激しくしてっ、いいんだよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁっ……また、ビクビク来てるっ！　んっ……そろそろ２発目……近づい\nて来てるねっ……はっ、んっ、んぁぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「今度はっ……どうするっ？　奥にもう一発中出しするかっ？　それとも……\n私の全身にマーキングをするかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「特別だっ……私をイカせたら、好きな方を選ばせてやるっ……あぁっ、んぅ\nっ！　そうだっ、本気のチンポスパートっ！　あぉっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいぞっ、イクっ……はぁぁんっ！　オマンコッ……下僕のチンポでっ、イ\nクッ……おぉぉぉんっ！　オマンコッ……イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅんっ……！　今のは……良かったよ……んっ、ふっ……私が先に\nイカされるなんてね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「約束通り、お望みの場所に出してごらん……このヤンチャチンポは……どう\nしたいんだい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、また中がいいんだね？　そんなに私のオマンコに中出しするのが良\nかったって訳だ……いいよ、遠慮はいらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「このまま、思いっきり……中出ししちまいなっ……んふっ、んむぅぅぅっ…\n…んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁぁっ！　あぉっ……出てきたっ……あぁっ、子宮に……新しいザーメン\nが流れてくる……んぅっ、私のオマンコ……悦んでるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204303" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んはぁ……受精する位の量を出すんだよ……ふふ……案外、この一発であっ\nさり孕んじまうなんてこともあるかも知れないねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そうなったら、それはそれで面白いかもねぇ……ふふ……冗談だよ。そんな\nに慌てるこっちゃない。だから、気にせず出し切っちまいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おふっ！　そうそう……ドピュッと出る精液がオマンコのヒダに当たる感触\n……こいつがいいねぇ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さて……射精も収まって来たみたいだね。腰も、流石に頑張りすぎて動かな\nくなってきたようだしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、チンポが抜けて……ドロっと汁が溢れて来てる……んふっ、\nちょっと勿体ないね……よいせっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……中々いい汗をかいた。お前さんも、単なる肉バイブってことはな\nかったよ。そいつは認めていい所だったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「まぁ、まだ若いんだ。これ位は頑張ってもらわないと……また私の興が乗っ\nたら、いつでも相手できるようにチンポを磨いておくんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、今度は身体にマーキングしたいんだね？　いいさ、男はそれ\n位欲張りじゃなくっちゃね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいよ……好きなタイミングで遠慮なくぶち撒けなっ……あっ……チンポ抜\nけるっ、はっ、んぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁっ、出てきたっ……！　んぷっ……ふふっ、さっきよりもっ\nと出すじゃないか……いいザーメンシャワーだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、れろ……うん……見た目通り、ドロドロだねぇ……こく、ちゅぷ\nっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ、粘っこい感じが喉に残る……やっぱり薄いよりは、これ位濃くなきゃ\n話にならないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どれ、身体に塗り拡げて……ふふ、カピカピになっちまうのを指で触るのが\n楽しいんだ。あんまり同意は得られないけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぅ……そろそろ打ち止めかい？　チンポも、だいぶお疲れになったようだ\nねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00002502_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「よいせっと……ふふっ、さっきの汁が垂れて来たよ……あぁ、こんな感じに\nなったのも久しぶりだねぇ……まぁ、たまには悪くないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さて……中々いい汗をかいた。お前さんも、単なる肉バイブってことはなか\nったよ。そいつは認めていい所だったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「まぁ、まだ若いんだ。これ位は頑張ってもらわないと……また私の興が乗っ\nたら、いつでも相手できるようにチンポを磨いておくんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0204410" ]},
