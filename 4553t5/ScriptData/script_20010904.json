{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「いくぜぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190001" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「うわっ、なんてパワー。ちょっと、いつもより気合い入ってるんじゃない？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021190001" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「いい加減、アンタの悪だくみをぶち壊さないといけないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190002" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「異世界にまで進出して、侵略しようだなんて、ほっとけないね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021190002" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今度はトタンの方が押されている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ブリキ１の一撃の方が、トタンの攻撃よりも重く強烈だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "トタンの鎧とブリキ１の手甲がぶつかり合い火花を散らす。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あああ……トタン……トタン大丈夫か……。トタン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021190001" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「不安そうに見ているくらいなら援護すればいいんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「彼らは彼らなりのルールの中で戦っているのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021190001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「おらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190004" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「きゃああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021190003" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ブリキ１の一撃がトタンの装甲を抉る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ああっ、鎧がへっこんだー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021190004" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「トタン！　よくもトタンを……！　ソルダー兵っ、溶着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021190002" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あたりで倒れていた機械の兵士が、巨大な兵士に合体した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、巨大化とかマジかよ……。あれが暴れたらヤバいんじゃないか！\n？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「問題ないでしょう。所詮は巨大な雑魚兵士。ブリキ１が苦戦する要素はあり\nません。そもそも巨大化は負けフラグだと昔から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちの身の安全の話だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "体が思うように動かない状態では、落ちてくる瓦礫を避けるのも困難だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "巨大兵士" ]},
		{"command":[ "SETTEXT", "「ぐおぉおおおおおん！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うなり声を上げてビルを倒壊させる巨大兵士。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「わあああっ！　ちょっとちょっと、これ私たちもヤバい系だよー！　あいっ\nたぁっ！　頭に石がぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021190005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「さあ、トタン、退くよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021190003" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ああもう、クラッドってば待ってよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_010021190006" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ああ、待ちやがれ！　……って、一般人と犬がいるのに、放っておけないか\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190005" ]},
		{"command":[ "SETCHARA", "0", "char_00011601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「一撃で板金屋送りだ鉄クズ人形！　はぁああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「散打擂虎躯（サンダーストラック）ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_010021190007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ブリキ１の拳が巨大兵士の胴体に風穴を開ける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「電撃を纏った必殺の拳……。まさしく必殺技ですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。なに呑気なこと言ってるんだ。瓦礫に埋まって死ぬとこ\nだったんだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……って、なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや？　なんだか空気のよどみが消えたような。体が軽いですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021190004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それだけじゃない。あれだけ破壊され放題だった街が何事も無かったかのよ\nうに元に戻ってやがる。どうなってるんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ、お約束の光景でございますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021190005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよお約束って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「おい、あんた大丈夫か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021190001" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "1", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「お怪我はありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021190001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "変身を解いたふたりがカツマの元へ駆け寄る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、大丈夫だ……。あんたたちはいったい……この世界の人間ではなさそ\nうだな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ああ、アタシたちはあのクラッドやトタンを追ってシコリンにこの世界に送\nられたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021190002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「シコリン？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「石凝姥命さまという女神様です。詳しくは本人に聞いた方がいいかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021190002" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「女神様がこの世界に来てるのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アタシらをこっちに送って、本人はこの世界を守ってる本部？　ってとこに\n行ったんだと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021190003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしたちもそこへ行かないと。ご存じありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021190003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、これはまさか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。ご存じもなにも、俺はその組織の一員だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「ガチでか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021190004" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「なんてこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021190004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}