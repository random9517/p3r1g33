        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
        {"command":[ "WAITMOVE" ]},		{"command":[ "PLAYVOICE", "103_0103101" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あのー……呼び出されたから来たんだけどさぁ、一体何？　まあ、ボク、忙\nしいわけじゃないけど、自分の時間は大事にするタイプなんだよね」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00010301_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },		{"command":[ "DISPNAME", "TRUE" ]},		{"command":[ "DISPTEXT", "TRUE" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103102" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「へぇ？　一緒にトレーニングぅ……？　うーん……そーいうの、好きじゃな\nいなぁ……やらなきゃ駄目？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103103" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「疲れるの、好きじゃないし……え？　疲れない？　むしろ楽しい？　ふ～ん\n……じゃあ、やってみてもいいよぉ？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103104" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「へ？　恥ずかしいことをするけど、それがトレーニングになるの……？　よ\nくわかんないけど、まあとりあえず始めてみようよぉ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010301_01", "2", "CENTER", "0" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103105" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「……どうして、おちんちん出したの？　ねえ、こんなの出してどーする気ぃ\n？　ねえ、まさか……ひょっとして──」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103106" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「……もう、本当にこんなことさせるなんて、信じらんない。こーいうのセクハ\nラって言うんだよ？　知ってるぅ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103107" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん……あぁん、動かさないでぇ……顔にピタピタあたっちゃう……。あうぅ\n、変な匂いがするぅ……くんくん、くんくん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103108" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「え？　臭いかって？　うーん……想像よりは臭くない、かな？　でも全然匂\nいが無いわけじゃないけどね」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103109" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「それで？　ボク、これをどうしたらいいの？　このまま、お顔でスリスリす\nればいいの……？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103110" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ええ～～……お口でぇ？　うーん……でもトレーニングなんでしょう？　ま\nあ別にいいけどさぁ……んー……はぁむ──」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103111" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「れろ、れるれろ、ねる、れろん……んひゃぁ、変な味ぃ……これがおちんち\nんの味なのぉ？　うわー……頑張ったら、なんとか食べられそうだね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103112" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ねるん、にゅるれろ、んちゅ……ん？　ああ、ホントに食べたりしないよぉ\n……んちゅ、ねろれろ、にゅるる……でも、噛み付くぐらいはしたいな……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103113" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「え？　だめ？　れろん、ぬるる、ちゅぬぅ……いいじゃん別に……怪我させ\nないからさぁ……え？　絶対駄目？　うーん、ケチぃ……れろれろ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103114" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ぴちゃ、ぬる、れろん、ぬるぬる……んふぅ……それで？　こうして、ずー\nっと舐ればいいの？　れろれろ、んちゅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103115" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ふえぇ？　もっと全体的に舐めるの？　ふーん……まあいいけど……じゃ、\nいっくよー……せぇの──」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103116" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「んれろ、れろれろ、先っちょ……すべすべして、舐めてて気持ちいい～……\nんちゅねる、れろん、にゅるる、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_03" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103117" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ねろ、ねろねろ……んん、この膨らんだところ……れろれろ……その下のく\nぼみ……んんぅん、味と匂いが濃くなってる……ねる、ぬれろぉ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103118" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん、んん、ねるん、ちゅぅ、れるぬるるぅ……んふぅ、ここ、裏筋って言う\nの？　ふ～ん……れろろろろ……うふふ、気持ちよさそうだねぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103119" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん、んん、はあ……先っちょのくぼんだところ……少ししょっぱくなってる\n……れるれる、ねるる、にちゃ、れろぬるぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103120" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「これ、我慢汁って言うんだぁ……ねるれる、ちゅぬ、れろれろん……んふふ\n、ネトネトしてて、ちょっと美味しいかもぉ……？　ふふふ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103121" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「はぁ……舐めてるだけじゃ、我慢できなくなってきちゃったぁ……んはぁあ\nむ、むぐ、もごもご……れる、にゅる、ちゅちゅる、れろん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103122" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あはぁ……おちんちんが口の中で、いっぱいになってるぅ……ねるん、にゅ\nるにゅる、ちゅぼ、ちゅるじゅるぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103123" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あむ、むぐ、もごもご、むぐぅ……んふふ、美味しい……これ、楽しいねぇ\n……どんどん口が動いちゃうぅ～～……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103124" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん？　え？　もっとゆっくり……？　あぁん、でも、口が勝手に動いちゃう\nの……ねろれろ、むぐ、じゅぼ、ちゅぶぐちゅ、ちゅぼぉ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103125" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あはぁ……はぁ……え？　なぁに？　おしゃぶり音で、よく聞こえない……\nちゅぶじゅるじゅぼぉ……ぐじゅじゅぼ、ちゅちゅじゅぼぉ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103126" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あはぁ……隊長、気持ちよさそう……れろにゅる、ぐちゅじゅぼぼ、ずるれ\nろ、ずずちゅぼちゅぐつぅ……はぁ、んんぅん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103127" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「おちんちん味と、おちんちんの匂い……はぁ、はぁ……くせになっちゃうか\nもぉ……ねろれろ、ぬるる、ちゅぼぐちゅ、ぴちゃくちゅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_03" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103128" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん、んぐぅ……んはぁ、根本まで入っちゃい、そう……んぐ、ぐぶぅ、じゅ\nぼじゅぼ、ぐぼぉぉ……ングっ、げほ、ゴホっ……はぁ、はぁ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103129" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あふぅ、苦しかったぁ……ああん、涎がこんなに溢れて……あぁん、ボク、\nなんだかすごくエッチだよぉ……んちゅ、れろ、れろれろ、ねろん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_02" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103130" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん、れろ、ぬるぅ……はぁ、ふぅ……隊長、おちんちんがビクビクしてるぅ\n……ねぇ、一体どーしたのぉ？　あむ、むちゅ、れろ、ねろん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103131" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「イキそう？　じゃ、もっと激しくしてあげる……んちゅ、ちゅぶちゅぶ、じ\nゅぼれろ、ぬる、んちゅちゅるじゅるぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103132" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「イクと、おちんちんから何か出すんだよね……？　ぴちゃ、ぴちゃぴちゃ、\n出したいの？　れろれる、ぬるれる、ちゅぬ、ぴちゃぁ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103133" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「え？　ちょっと待って……だって？　どうしてぇ？　れろれろ、ぬるん、ん\nふふ……待たないよ～だ……じゅるれろ、くちゅ、ちゅるじゅるぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_01" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103134" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「んあむ、ちゅぼじゅる、れろちゅろ、ずる、ずるぢゅるるぅぅぅ……ん？　\n何？　我慢、できない……んふ……ちゅるじゅるれろぉ……！！！」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103135" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ひゃ！？　ひゃぐっ、んぐ……んっ、んん……げほっ、ごほっ……はぁ、は\nぁ、んん、んんん～～～……ゴクン……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103136" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「はー……はー……んぁむ、ちゅる、れろれろ、んぁあ、やぁん、いっぱい出\nてるぅ……うぇぇ、ごほぉっ……やだぁ、出しすぎだよぉ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103137" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「んぁむ、ちゅる、れろれろ……んちゅぬる、ゴクン……んん、はぁ……はぁ\n……あぁん、これが、せーえきぃ……？　うえぇ、変な味ぃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103138" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「んふぅ……はぁ、はぁ……あはは、まだジンワリ、染み出してる……んちゅ\n、ちゅる、ちゅぞぞぞぞ……ゴクン……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103139" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「あはぁ……変な味だったぁ……これで終わりぃ？　んー……これ、ほんとに\nトレーニングなの？　よくわかんなかった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103140" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「はぁ……はぁ……少し疲れちゃったぁ……え？　もうちょっと続ける？　ん\nー……まあ、いいけどー……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103201" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん～～はぁむ……んちゅ、れろ、ねろねろ……んふぅ、精液の味が、いっぱ\nい残ってる……れろ、ねろれろ、にゅる、んちゅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103202" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「え？　味がしなくなるまでペロペロすればいいの？　うん……いいよ……れ\nろ、にゅるる、ちゅぬ、くちゅ、れろれろねろん……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103203" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん、んん……んあぁむ、もごもご……んちゅ、ちゅぽん……んふぅ、精液味\nって不思議～……変な味なのに、あんまり嫌いじゃないんだよねぇ」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103204" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ねるん、れろれろ、んちゅぅ、ちゅるる……んふぅ、まあ、好きってわけじ\nゃないけどね……ふふ、ねるれろ、ぬるる、ちゅぬん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_05" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103205" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「れろ、ねろねろ……んはぁ、精液味、まだオチンチンに残ってるぅ……んれ\nろ、れろ、ここ、この傘の下のくぼんだ溝のところ……ん、んん、れろん」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103206" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「はむ、んちゅ、れろれろ……はぁ、ふぅ……この裏筋のところも味がする…\n…滴って、垂れていっちゃったんだね、きっと……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103207" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ねろ、れろれろ……んふぅ、オチンチンの根本……毛の生えたところに精液\nの塊はっけーん……ん、んん、ちゅるる、ゴクン……んふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_06" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103208" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「はぁ……うふふ、精液探し、ちょっと楽しい……ん？　これ、お掃除フェラ\nっていうんだ……ふーん……憶えておくね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010301_01_04" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103209" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「れろ、ねろぬちゅ、ぴちゃ、れろれろ……はぁ、んん……すっかり精液味、\nしなくなっちゃったぁ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103210" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「う～～ん……なんだか寂しい……れろ、れろぬるる、ちゅちゅる、ねえ、次\nの射精、まーだぁ？」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103211" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「えー、まだもうちょっと掛かるの？　ふ～ん……じゃあボク頑張るぅ……れ\nろ、にゅるる、じゅぼ、じゅるれろ、ちゅちゅぅ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103212" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「はぁ……んん、早く、射精、しないかなぁ……れろぬるる、もごもご、じゅ\nぶ、れろぉ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103213" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「ん？　やっぱり精液好きなのか、だって？　ううん……違うよぉ……れろれ\nろ、ぴちゃん……んん、ちゅぽ、じゅぼぉ……」", "NORMAL" ]},		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "103_0103214" ]},		{"command":[ "SETNAME", "急" ]},		{"command":[ "SETTEXT", "「慣れてきて、平気にはなっちゃったかなぁ……ねろれろ、ぬるる、ちゅぶっ\n、ぴちゃぁ……はぁ、んふぅ……」", "NORMAL" ]},
