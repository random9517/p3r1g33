{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「君に呼び出されたことは何度もあるけど……。こっちから来てもらうのは初 \nめてね。……ありがとう。それで、さっそくなんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00026803_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「相談したいことがあるの。他の人にはこんなこと言えなくて……。もしかし \nたら、もう気付いているかもしれないけど。その、む、胸が……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00026803_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「この変身特有の副作用なのか、デメリットなのか分からないけど……モデル \n元になった子のサイズと同じになってしまったみたいなの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……そう。冗談なんかでこんなこと言わないわ。実際に見て、触って確かめ \nてもらってもかまわない。それで、頼みたいことがあって……こっちに来て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00026803_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ……！　……突然おっぱいを押し付けたりしてごめんなさい。でも、い \nつまでもこのままでいるわけにはいかないの。あまり胸が大きいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「戦う時に邪魔だし、いつもと違う身体で動いて、誤差でミスをしかねないで \nしょ？　だから、早くこれを……おっぱいを元のサイズに戻したいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「その手伝いをしてくれない？　……ええ。おそらく、なんだけど。今は無駄 \nにおっぱいが膨らんで……膨張してしまっている状態なわけだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これを思いっきり吸ってくれたら、余計な分がなくなるんじゃないかって。 \n……ううん？　別に空気が入っているわけじゃなさそうなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「自分の手で揉んでみたり、増えた脂肪を絞り出そうとしてみても何も起こら \nなかったから。あとは、強い力で吸い上げてもらうしかないのかなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「もちろん、無理を言っていることは百も承知だから、君が嫌だっていうなら \nすぐにやめるわ。……え？　むしろ嬉しい？　あっ、そ、そう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……それなら良かった。正直困り果てていたから、すごく助かるわ。……で \n、わざわざそんな重労働を頼む見返りに……。そうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「わ、私も君のオチンポを刺激する……って交換条件はどう？　だって……さ \nっきから、ものすごく苦しそうにパンパンに腫れてるんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「も、もう……っ。あくまでこれは次の戦いのための準備で……。って、お願 \nいごとをした私が偉そうにするのも良くないわね。はじめましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……そう。君は遠慮なんかしないで、私のおっぱいを力いっぱい、口の空気 \nがなくなるまで吸って。乳首？　わ、わからないけど……必要そうなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「好きにしてもらってかまわないわ。……んっ……！　な、舐めるの……？　 \n唾液がある方が勢い良く吸えそうだから？　そ、それはそうかもね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「じゃあ、君の良心にまかせて……おっぱいの吸引を頼むことにして……。私 \nは君のオチンポを、こうして……上下にマッサージしていくわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「っん……っ。ん、んん……！　んぁっ……はぁ、っふ……！？　ふぅっ、ん \nぅう……っ。よ、予想よりもかなり激しい吸いつきね……助かるわ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「た、ただ……、あっ♪　あまり舌を動かされると……おかしな声が漏れてし \nまいそうになる、から……。優しく……。はぁっ♪　あっ、やぁっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「な……なんだか口の動かし方が上手くなっているんじゃない……？　乳首を \nチロチロ舌先で舐めながら……。っんっ！？　くぅっ……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「おっぱい、を、丸ごと吸いこむみたいに……あふっ♪　吸引して……んんん \nっ。そこまで親身になってくれるなんて、すごくありがたい、けど……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ダメ……！　あまり上手くおしゃぶりされると、……あっ♪　こっちの指が \n動かせない……！　おっぱいに気をとられ、てぇっ……♪　ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「手がお留守になって……あっあっあっ！　こんなの不平等だわ、……あっ！ \n　私も努力しなきゃ……。っんぅっ！　こんなにしてくれてるんだからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「一方的にしてもらうなんて、良くないから……。……んっ……。こ、こう… \n…かしら？　強く握りすぎていない？　動かす速度はどれくらいがいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　はぁ、はぁっ、はぁ……♪　フフ、そんなに必死におっぱいをし \nゃぶってくれるなんて……。んっ、母性本能がくすぐられるわ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ねえ……？　もしかして、君ってこういうのが好き……なの？　はぁっ、赤 \nちゃんみたいですっごく可愛い……♪　あっ♪　あっ、んん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「よちよち、おっぱい上手にちゅーちゅーできて偉いねぇ……♪　っんぁっ… \n…！　な、何？　もっと熱心に吸いつきはじめて……！　そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そうなんだ……。やっぱり赤ちゃん扱いされながら、褒めてもらうのが好き \nなんだ。じゃあ、お礼にたくさん褒めてあげる。……んぅっ、んっんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長……とってもおっぱいの扱いが上手、よ……♪　あっ、すごく感じる… \n…！　あっ♪　ぅっ、ぁっ♪　オチンポもカチカチでかっこいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_03" ]},
	
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「うんうん、オチンポ気持ちいいね……♪　我慢しなくていいから、全部私に \n任せてね……♪　ここ？　こっちかな？　先っちょこすられるのがいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　隊長の赤ちゃんも、こんな風に私のおっぱいを吸うのかしら… \n…？　あっ、あぁ、妄想が止まらなくなってきた……あぁ、吸って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長がどうしてもって言うなら、嫁に行って毎日おっぱい吸わせてあげても \nいいしっ……。あぁあっ♪　赤ちゃんにもおっぱいちゃんとあげるわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「だか、らっ……もっと♪　もっと吸って、私のおっぱいを独占して……！　 \nっあっ！　き、気持ちいい……！　それにオチンポを掴む手が……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「止まらないの、隊長のオチンポから透明な、ヌルヌルしたあったかい液体が \n溢れてきて……。あっ♪　あっ、手のひらが気持ちよくて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ♪　隊長……っ♪　どう？　私のおっぱい、縮みそう……っ？ \n　あっ、オチンポはどんどん膨らんできてる……これってもしかして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「うん、もちろんいいわよ……！　精液を出したくなったらこのまま出して、 \n……あっ！　私も、私のおっぱいももうすぐイク、から、あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　えっ？　あっ、あっぁっ……！？　こんな、ま、真上にま \nっすぐ飛ぶなんて……！　勢いがすごすぎて驚いちゃった……っ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「わ、私も今ちょうど一緒にイッているから……！　だから今のうちに、全力 \nで吸い上げて！　あっ……！　胸が、おっぱいがジンジンするっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ……！　だめ、だめっ……！　またイッて……あああああっ♪　隊長の \n精液の臭い、あたたかなぬくもり……！　あっ、いやっ♪　こんなのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あ、たまがバカになってしまいそうで……！　あっぁっ！　すごい、こんな \nにたくさん精液を撃ち出して……そんなに気持ち良かったのっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「嬉しい……！　私もっ、私もおっぱい、たまらなく気持ち良くて……！　余 \n韻がいつまでも深まって止まらない……！　あっ、また、またイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……ふぅううう……っ……♪　はーっ、はーっ、ご、ごめんなさい……。イ \nキながら、思いっきりおっぱいを隊長の顔に押し付けてしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「呼吸、できなかったんじゃないかしら？　自分の唾で溺れそうになっていた \nりしない？　っぅ……、イクと一瞬、我を忘れてしまって、無我夢中で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……最後にギュッとオチンポの根元を握りつぶしてしまったから……。もし \nかしたら、全部精子が出せなかったかもしれない。そのお詫びに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あと少しだけ、このまま続けてもいい……？　おっぱいも……胸も、まだ膨 \nらんだままだし……。妙に疼いて身体が熱くてじっとしていられないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……もちろんこちらの不手際だから……隊長はそのまま楽にしてて。んっ… \n…♪　あっ、精液がまだちょっぴり尿道に残っていたのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ぴゅぴゅっと溢れ出た分が、私の手に絡まって……んんっ、オチンポがにゅ \nるにゅるになってきたわね。んっ、んっ、これ……すごくやりやすいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「これならさっきよりもっと気持ち良くしてあげられそう……♪　はぁっ、は \nぁっ……。あ……♪　隊長、感じてくれているのね。また硬くなってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私、隊長のオチンポ好きよ。太くて、強くて……カッコイイもの。雄々しく \nそそり勃ったオチンポが、ヌルヌルの精液でぬめり輝いて……。はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅ音を鳴らしながら、刺激するのがどんどん楽しくなってきた… \n…。んっ、んぅ……ここ、反応がいい気がする……。裏筋……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……っあ……ッ！？　あっ、隊長、私のおっぱいも吸ってくれるの……っ？ \n　あっ♪　フフフッ、じゅるじゅるすごい音たててむしゃぶりついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「そん、なに喜んでくれるなら……このデメリットも、悪くないかもね……♪ \n　あっ……！　い、いいっ……！　隊長の口の中、真空になってるみたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私のおっぱい美味しいっ……？　あっ♪　あっ、んぁああっ……！　す、ご \nい……！　っんっ♪　身体がゾクゾクしてきた、お腹が熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ものすごくもどかしい気持ち……！　あっ……あっ！　や、やめないで、も \nっと吸って……！　あっ♪　乳首も舐め回して……気持ちいいぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……えっ？　私、自分が気持ち良くなると……隊長のオチンポを握る手がい \nやらしく動くの……？　ち、違うの、これは……。んぁっ！？　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「いやぁ……っ♪　言わないで、……あっ♪　んふっ……！　あっ、あぁっ… \n…！　し、仕方ないでしょ、ついつい力がこもってしまうのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「でもそれは、た、隊長が……！　んんんっ！？　ん～っ！　そうやっていや \nらしく舐めしゃぶってくるからでしょうっ……！？　っくぅっ、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あっぁっ、やだ……♪　腰をくねらせ、ちゃう……っ。オチン \nポ握る手が震え、ちゃう……っ。あっ……♪　あっ、あんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……か、可愛い声なんて出してないわ！　や、やめてよ……♪　んっ……、 \nそ、それより隊長だってそろそろ射精したくなってきたんじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「うん。今回はきちんと全部絞り抜いてあげる、から……。あっ、いいよ…… \n出して！　おっぱい吸いながら……あっ！　おっぱいが痙攣してるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303219" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私も……我慢できない、隊長のオチンポいじりながらイクけど軽蔑しないで \n……！　あっ、無理、絶対にイクっ……！　もうだめぇえええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303220" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「イッ、クぅううっ……！　あああああっ！　み、見ないでぇ……っ、恥ずか \nしいっ……！　あっぁっああああああああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303301" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ♪　また噴水みたいにびゅっ！　ビュルッて精液が真上に撃ち上がって \n……！　２回目なのに嘘みたいに元気なのね……っ♪　あっ、次々にっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んっ、あうっ……！　私の手にいっぱいかかってる……。いいわよ、このま \nま続けて出して……！　っんんんっ♪　おっぱいも忘れずに……ぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、ああああっ……！　イクのが終わらない……！　隊長のオチ \nンポもずっと脈打ってる、精液ってこんなに出続けるものなのっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あ、濃い臭いが部屋中に広がってく……♪　精液のむわっと鼻をつく臭い… \n…！　こんなの嗅がされ続けたら、頭の中がピンク色に染まってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「きゃっ、もうそれ以上おっぱいを刺激されたら……！　んあああああっ♪　 \n感度が高まりすぎて、何度でもイッちゃうっ！　あっ、あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……はぁああああ……♪　良かった、今回は最後の一滴まで出しきれたみた \nいね……？　何度も失敗したらって心配だったからホッとしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「私の胸……は、今のところはあまり大きさは変化していないみたい。まあ、 \n元々やぶれかぶれのいきあたりばったりな策ではあったから、いいんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ふぅ……。これからも、モデルチェンジするたびに相手の特徴が現れてくる \nんだとしたら、大変ね。……ねえ、隊長？　もしそんなことになったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「また……相談してもいい？　他の人には秘密よ、言えるわけないわ。だから \n隊長と……これからも２人で解決したい。いいわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　あっ！？　な、何……！？　あッ……！　身体に精液がびゅる \nびゅるかかってる……！　もぉっ、そ、そっちにそんなに出したら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303401" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あっ♪　精液がこびりついて取れなくなるから……！　っんっ！　もしかし \nてそれがいいの？　あっ♪　だったら仕方ないわね……好きにしていいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「っんくぅうう……♪　ネバネバした汁がたくさん肌にくっついて……。これ \n、洗っても臭いが残るし、粘り気の感触が忘れられないし、困るのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「なのに……嫌なはずなのに、どうしてぇっ？　私、興奮してる……。隊長の \n精液浴びせられてドキドキしてる、おっぱいが高鳴って止まらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「んんっあっあっあっ！　浴びせて……っ、約束したんだから！　今回は最後 \nの一滴まで出し終わるまでオチンポから手を離さないって……！　んふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「あ、熱いっ……！　火傷するかと思ったわ、あっ……！　い、いいから！　 \n気にしないで出して！　ちゃんと受け止めるからっ……ちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「……見て。こんなにドロドロのびちゃびちゃになってしまったわ……。２回 \n目の発射なのに、１回目より量が多いなんて……さすがね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00026803_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「隊長にはいつも驚かされてばかりよ。……え？　胸のサイズ？　あ、あぁ、 \nそ、そうだったわ。副作用の解消のためにしてたことなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「いつのまにか、母性本能とわけのわからない愛しさが湧いてきてしまって、 \n普通の恋人同士みたいに行為に没頭してしまっていたわ……恥ずかしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「実際、効果があったかどうかは調べてみないとわからないけど。協力してく \nれて助かったわ。ほ、本当にありがとね……頼りにしてるわ、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}