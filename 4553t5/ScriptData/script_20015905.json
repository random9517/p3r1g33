		{"command":[ "SETNAME", "市民Ｄ" ]},
		{"command":[ "SETTEXT", "「街の平和を守ってくれてありがとうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「これは……皆さんが、こんなに祝福してくれるなんて……」", "NORMAL" ]},
