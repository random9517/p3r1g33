		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「不思議な感じです……力が湧いてくる……まるで、本来の力が戻ってきてい\nるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023840002" ]},
