		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "市民Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、あのっ！　危ないところを助けてくれてありがとうございました！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あぁ……よかった。ご無事でしたなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023840007" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "市民Ｂ" ]},
		{"command":[ "SETTEXT", "「いやー、戦ってる姿、カッコよかったです！」", "NORMAL" ]},
