		{"command":[ "SETTEXT", "「よい。あの場で急いて、実りが少なくなってはつまらぬ。それよりも、裂け\n目の方はどうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023840007" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「にひひ、なかなか順調じゃないですかね？　もう少ししたら、結構いー感じ\nになってるかなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023840005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そなた達も、分かってくれているようで何よりじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023840008" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ふふ……ちゃんと意志があることは承知しております。それを見極めさせて\nいただこうかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023840003" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「だが、いつまでものんびり見ているつもりはないぞ。分かっているだろうな\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023840003" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
