		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はーいっ！　民の為に、私たち頑張りま～す！」", "NORMAL" ]},
