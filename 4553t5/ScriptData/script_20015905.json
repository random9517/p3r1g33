		{"command":[ "SETCHARA", "0", "char_00028301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿者！　私は、すぐに浮かれるのはどうかと思っているだけだ」", "NORMAL" ]},
