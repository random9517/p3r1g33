		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「レイア……お前も感じているのか。私も、どこかにあった違和感が薄れてい\nるような気がする……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023840001" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
