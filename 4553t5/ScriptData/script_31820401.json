		{"command":[ "SETIMAGE", "0", "still_00018204_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああん、なんだかもっとあなたのオチンポを味わいたくなってきちゃいまし\nたよ」", "NORMAL" ]},
