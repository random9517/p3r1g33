		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、濃厚ザーメンくるぅ……っ！　お、オチンポから……いっぱ\nい。また……こんなにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぶぅっ！　あ、あふれちゃう……もったいない……。で、でも……こんな\nに一気に、飲みきれないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふぅ……んっ、んくぅ……っ。んぐっ、んぐぅ……。できるだけ、飲みま\nす……んっ、じゅじゅじゅじゅぅ～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はぁ……。２回目なのに、すごくたくさん射精しましたねぇ……\nんふふっ、気持ちよかったんですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしも、気持ちよかったですよ……。お口に射精されて、こんなに感じち\nゃったの、初めてかもしれません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「サキュバスの身体だからでしょうかね……？　ふふっ、なんだか得した気分\nですよ♪」", "NORMAL" ]},
