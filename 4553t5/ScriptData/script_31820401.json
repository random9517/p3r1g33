		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お腹空かせたサキュバスにぃ、ごちそうザーメン、もっとくらはいぃいいい\nぃぃぃ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぅうううぅぅぅ～～～～っ！　んっ、んんっ、んふぅっ、んくぅ\nううううぅぅぅ～～～～っ！！」", "NORMAL" ]},
