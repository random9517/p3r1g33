		{"command":[ "SETIMAGE", "0", "still_00018204_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふふ、これはサキュバスとして必要なエッチですから、浮気ではありませ\nん♪　心配ご無用です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「さぁて。サキュバスの身体と人妻のテクニックで、あなたのことをも～っと\n虜にしちゃいましょうかね～♪」", "NORMAL" ]},
