		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ、起きました？　突然すみません。こんなところに連れ込んでしまって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「サキュバスになったせいでしょうか。どうにも空腹が収まらないんですよね\n～。ちゃんとご飯食べてるんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「なんといいますか、胃袋がふたつある、みたいな？　片方の胃袋がつねに空\n腹な感じでして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「というわけなので、とっても美味しそうだったあなたを誘拐しちゃったって\nわけなんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403104" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふふっ♪　サキュバスに誘拐されたらナニされちゃうか……想像できます\nよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「サキュバスのご飯といえば、そう、オ・チ・ン・ポ♪　あなたのオチンポ…\n…ほら、こんなに硬くなってますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403106" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あはっ、サキュバスに襲われちゃうのに、期待して勃起させて……その方が\n、わたしとしてもヤりやすくていいですけどぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403107" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああ……もう、オチンポ見ているだけで、わたしもどうにかなっちゃいそう\nです……それじゃあ、いただきま～す♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403108" ]},
		{"command":[ "SETCHARA", "0", "char_00018204_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「まずはおっぱいで挟んで……ンッ、すっごい熱ぅ……アツアツですね、おっ\nぱいにオチンポの熱が伝わってきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「どうです……？　やわらかいおっぱいにぎゅ～っと挟まれて……ンッ、これ\nだけで、感じちゃってますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「谷間でビクビク反応しているオチンポ感じますよ……。んふっ、ああんっ、\nどんどんおっきくなってませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいが気持ちよくって、オチンポ膨らませて……あんっ、先っぽなんか\n、パンッパンになってます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「これだけでイッちゃいそうになってるオチンポ……んっ、すんすん……ああ\n、とってもいやらしい匂いですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「すん、すんすん……。ああ、たまらない……飢えたサキュバスの身体に染み\nこみますよ……美味しそうなオチンポ臭……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「匂いと、おっぱいで触れるだけじゃ満足できません。お口でも味わわないと\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん……れろ、れろれろ……。んちゅ、ちゅぶ……ちゅ、ちゅ、れろぉ……ん\nっ。れろ、れろれろ……んれろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁ……この舌にピリッとくるような味ぃ……たまりませんね……んっ、れ\nろ、れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んでも……今日はなんだか、亀頭の味が濃いような……。んれろっ、もしか\nして、溜まってるんじゃないですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふっ、れろれろっ、濃厚オチンポ汁が溜まってるとなるとぉ……なんとし\nてでも射精してもらわないと、ですよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んちゅっ、べろべろぉっ、サキュバスですのでぇ、んれろっ、濃いの、たっ\nくさん射精して欲しいんですよぉ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ごちそうオチンポ前にして、どんどんよだれが溢れてきちゃいます……んれ\nろ、れろれろ、ちゅぷぷぅっ、精液……くださいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「なんで我慢しちゃってるんですかぁ？　サキュバス相手に遠慮なんかしなく\nていいのにぃ。そっちがその気なら、こっちも奥の手ですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁ……むっ♪　オチンポ……ンッ、咥えちゃいます……んちゅっ\n、じゅるる……じゅぶぶぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「よだれたっぷりのお口でぇ……んじゅるっ、先っぽ、しっかり咥えちゃいま\nした……んっ、んじゅるるっ、じゅぷぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ、んぶっ、んぶっ！　んじゅるっ、じゅぶっ、じゅぶっ、じゅ\nぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「唇を……カリ首のところに密着させて……んじゅぶっ、舌ぁ、べろべろぉっ\nて、動かして……んじゅるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「先走り……出ちゃってますよぉ……。じゅぶっ、舌にくる苦みが、ンッ、と\nっても美味しいですぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んじゅっぷ、じゅっぷ、じゅるるっ、じゅぷぷぅっ！　どんどんよだれが…\n…んじゅっ、オチンポ、ベトベトにしちゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「竿を伝って……おっぱいまで……。ンッ、ほらぁ、おっぱいもこんなにヌル\nヌルになっちゃいましたぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいで竿を……お口で亀頭を……。んっ、んじゅっ、たっぷり気持ちよ\nくしてあげますね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んじゅぷっ、じゅるっ、じゅるっ、オチンポが、ンッ、口の中で暴れるぅ…\n…じゅるっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「精液……じゅるっ、だしちゃって、くださいぃ……っ！　じゅるっ、じゅる\nるっ、んっ、じゅぶっ、じゅちゅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んんっ、精液っ、じゅるっ、精液ぃ……吸いだしちゃいます、\nからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　んっ、んふぅっ、んっ、んくぅ……んっ、ふぅうううぅぅぅ～\n～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んくっ、でてるぅ……っ！　口に、いっぱい、あなたの精液……んふ\nぅ、どんどん、注がれて……ますよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……すごいぃ……。口から鼻に抜けていく男の人の濃厚な匂い\nぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「空腹の身体に染みわたります～♪　んっ、じゅぷ、ちゅるるぅ……。ん、な\nにしてるのかって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それは当然、お掃除ですよ♪　たっぷり射精したオチンポを、綺麗にしてあ\nげないといけませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「尿道の中にだって……んちゅちゅっ、まだ、精液が残ってるかもですしぃ…\n…ん、ちゅちゅぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オチンポ……丁寧にペロペロして……精液……みんな舐めとっちゃいますか\nら……んっ、れろれろぉ……んれろぉ……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「どうしましたぁ……？　れぇろっ、お掃除フェラ、お嫌いでしたかぁ……？\n　んっ、ちゅぅ、そういうことでは、なさそうですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「れろ、れろぉ、オチンポがまた……硬くなってきましたよ……んふっ、そう\nですよね……溜まってたんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「一発射精したくらいじゃ、オチンポおさまりませんよねぇ♪　れぇろ、れろ\nれろ……ぉ……んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしも、あなたのオチンポがあまりに美味しかったので……。精液がもっ\nと欲しくなっちゃってるんですよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「たしかにわたしは人妻ですけど……サキュバスになっちゃってるので。食事\nは浮気に入りませんよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それに、一度あんなに射精しておいて……いまさらそういうこと、言いっこ\nナシです♪　んちゅ、ちゅぷぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふぅ、またオチンポ……ンッ、しっかり咥えちゃいましたぁ……♪　んっ\n、んっ、ちゅぶっ、ちゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403207" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、一回射精したあとなのに……んふぅ、すっごい……また、こ\nんなに大きく勃起してぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぅ……んじゅるっ、じゅぶっ、じゅちゅちゅぅっ！　オチンポ立派ぁ……\nんっ、じゅぶっ、じゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「また、しっかり、お口とおっぱいとで、オチンポしごいてあげますねぇ……\nんっ、んじゅぶっ、じゅぶっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んぶっ、んぶっ！　じゅるるっ、んっ、んじゅっ、んじゅっ、\nんじゅっ、んじゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オチンポだけじゃなくて、腰までビクビク震えちゃってますね……んっ、じ\nゅるっ、いっぱい気持ちよくなっているようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「またたくさん射精してくれるの……期待しちゃいますよ♪　んっ、じゅぶじ\nゅぶぅっ、んふぅ、じゅぷっ、じゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「精液欲しさに、じゅぷっ、おもわずがっついちゃいますぅ……んっ、じゅぶ\nっ、舌も、おっぱいも……激しく動かしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふっ、んっ、んぶぅっ、じゅるるっ、じゅぷっ、じゅぷぅっ！　んんっ、\nまた……イッちゃいそう……ですかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふっ、遠慮なく、たっぷり射精しちゃって、くださいねぇ♪　だって相手\nはぁ、サキュバスなんですからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いっぱい射精して欲しくて、ンッ、こんなにいやらしい顔で、オチンポちゅ\nぱちゅぱしちゃってるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「また、おっきくなって、限界が近そうなオチンポから、ドロドロ精液、びゅ\nくびゅくだしてぇ……♪」", "NORMAL" ]},
