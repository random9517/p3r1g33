{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「隊長！　来たですよ！　序です！　この、覚醒することですごく沢山強くな\nってしまった、サムライテールの長女です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、すみません。ちょっと声が大きかったですか？　もう夜中だっ\nて言うのに……最近調子よくて、声の通りもいいんですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「まあ、それはともかく……今夜はどういうご用件なんです？　ほう、ほうほ\nう、なんと……トレーニング……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んー。私にトレーニングって必要です？　だってほら……覚醒して、ビック\nリするぐらい強くなってしまいましたですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええ？　恥ずかしさを利用した画期的トレーニング……？　ふむふむ、それ\nはちょっと興味あるですね──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00010102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……と、そんなこんなで、隊長の口車に乗って、私自慢のおっぱいを使って\nこんなことになってしまったわけですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203106" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00010102_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、もう……隊長ったら、困った人ですっ……エッチなこと、この私に…\n…覚醒を果たした最強のサムライにこんなことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふええ？　覚醒した理由……ですか？　そ、それはその……サムライとして\nの使命感を燃やしに燃やした結果でして──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あううぅ、知ってるなら言わさないで下さいよぉ……テストの点数が悪すぎ\nて、落第しちゃったんですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「お亥様がテストの点数を上げてくれるっていうから、一切勉強しなかったん\nです……そしたら、私、お亥様の想像より成績が悪かったみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……ん、んん……はぁ……で、赤点ラインにちょうど１点だけ達してなくっ\nて……で、気がついたら、覚醒してたんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ……失敗をサクセスストーリーに変えてしまう、天賦の才……き\nっとこれが覚醒の秘訣ですね！　あーっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そんなことより、ん。ん、ふぅ……私のおっぱい、どうですか？　立派でし\nょう？　覚醒した時、数センチ大きくなったみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、こーんなことも簡単にできちゃうんです！　ほら、ほら……男\nの子の憧れ、パイズリですよ～……むふふ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……んふふ、どうですか？　気持ちいいでしょうー……♪　おっきくな\nったおっぱいは最強……すなわち、私最強ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「へ？　どうして、おっぱいが大きくなったのか、ですか……？　そ、それは\n、まあ、実力にふさわしい姿に進化したっていうか、なんていうか──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふえ？　太った……？　ちょ、ちょっとぉ！　隊長といえども言っていいこ\nとと、言ってはいけないことがあるですよ？　ぷんぷんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「まあ、私は覚醒したですから、心に余裕とゆとりと隙があるので軽～く聞き\n流しちゃうですけどね……ん、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「へ？　心に隙があるのは駄目だろう……ですって？　もう、細かいこと言い\nっこなしですぅ……それより、ほらぁ、もっと感じて下さいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「気持ちいいでしょう？　ほらぁ、ここでぎゅーっと締め付けちゃうですよ…\n…よいしょっと……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁん、おちんちん、すごいことになってるよぉ……こんなに先っちょを膨\nらませて……はぁ、はぁ……ああん……すごくエッチですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……んん、興奮してるのか、ですって？　するに決まってるじゃ、ない\nですかぁ……んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「だって、だってぇ……私、こういうことするの、まだまだ慣れてなくって…\n…んっ、はぁ……なんだか、ドキドキが止まらないですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「隊長が、私で、気持ちよくなってる……そう思ったら、身体が、いっぱい熱\nくなっちゃうです……ん、はぁ……あぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「やだぁ、そんなに見ないで下さいですぅ……乳首が、ジンジンしちゃいます\nぅ……えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「乳首、ビンビンですねぇ……こんなに、尖っちゃってるぅ……隊長のおちん\nちんとおそろいです……ふふふ、なーんちゃってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……あはぁ、谷間に汗かいちゃった……なんだか、ん、ふぅ……谷間が\nぬるんぬるんして来たですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ、見て下さい……オチンチンから涎が溢れてる……我慢汁、ですね？\n　うふふ、覚醒したサムライは、なんでもお見通しなんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああん、隊長が、気持ちよく、なってるぅ……はぁ、んん、頭が、ぼーっと\nしてきちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふふ、精液が恋しいですぅ……ああん、精液……精液欲しいよぉ……はぁ、\nはぁ……隊長、いつ私にザーメンミルクをくれるんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あぁん、もうすぐ、ですかぁ？　はぁ、はぁ……待ち遠しいですぅ……んっ\n、ああぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んしょっと……はぁ、ふぅ……あはぁ♪　谷間の中でビクンビクンして\nるぅ……オチンポ、谷間で暴れてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、ああ……隊長、エッチな声上げてるですぅ……はぁ、はぁ……そんな声\n出されたら……私、もっと興奮しちゃうですぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んんぁ、はぁ……はぁ……あぁああん……い、いいですよぉ……出して\n下さいっ、はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「谷間の中、隊長のおちんちんミルクでいっぱいにして下さい……はぁ、んん\n、んん～～～～～……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「きゃん！？　ひゃうぅん……はぁ、あぁぁあん♪　こんなに、いっぱぁい…\n…はぁ、はぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「谷間が、白いので溢れてる……生暖かいトロトロでいっぱいになってるぅ…\n…んふふ、すごぉい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ、見て下さい……私の顔まで、ドロッドロです……もう、最強の覚醒\n戦士の顔をこんなに汚しちゃうだなんて……悪い人ですねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……いっぱい出しましたねぇ……まあ、覚醒した私は、この通り\n、エッチ方面でも有能だってことですねぇ……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、ほら、まだ残ってる……しっかり最後の一滴まで出しちゃいましょうね\n……隊長……よーいしょっと……ふぅ、お疲れ様でーす♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……？　んん？　あれれ……やだぁ、隊長ったらぁ、まだこんなに大きく\nさせてるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、この覚醒ビューティサムライの私の魅力にメロメロみたいです\nね……ええ、わかります。むしろとーぜんのことですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……えへへ、続きしますよね？　しちゃいますよねー？　この\n大きなおっぱい、気に入ってくれてるですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んふ、むふふ、じゃあやっちゃいましょう……だって、仕方ないですよね～\n……こんなに大きいんですもの……よいしょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ん、ふぅ……はぁあん、谷間がトロトロしてて……ん、ふ\nぅ、ゴシゴシするの、気持ちいいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ……おっぱいが、ジンジンしちゃうぅ……ん、ふぅ……あぁあん、駄\n目ぇ……精液の匂い……むせ返りそうですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……精子が空中を泳いでるみたいですぅ……あぁあん、興奮、\nしちゃうですぅ……んぅ、んくぅ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「隊長♪　気持ちいいでしょう？　ね？　これが覚醒の効果です……私は最強\nです。強いだけじゃなく魅力的なわけです……うふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁふぅ……このままなら、必ず……はぁ、うふぅ……必ず落第地\n獄から抜け出せるはずです……んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あああ、にちゃにちゃ音がするですぅ……やぁあん、すご\nぉくエッチぃ……はぁ、ふぅ……んんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「隊長……また我慢汁溢れ出させてる……はあ、先っちょが精液と我慢汁と汗\nでテカテカしてる……うふふ、かっこいいいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……はぁ……もっと激しい方がいいですかぁ？　それとも、もっと\nゆっくりネットリ責めた方が嬉しいですかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えへへ、私、奉仕するの、大好きみたいですぅ……ああ、やだぁ、興奮して\nます……今、すごく、んん、私も感じてるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああん、駄目ぇ……隊長、そんな目で、私を見ないで下さいですぅ……ん、\nふぅ……あはぁぁん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「やだぁ、いっぱい感じちゃうですぅ……身体を滴る精液の感触すら、気持ち\nいい……ああん、ナメクジが身体を這ってるみたいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、あああん、息をすると、精液の味がするぅ……ん、ふう……\n鼻から妊娠しちゃいそう……すー……はー……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふえぇぇ……？　そろそろ、イキそう……です？　ん、んふふ……我慢しな\nくたって、いいんですよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「また出して下さい……精液で、私をドロドロにして下さいですぅ……はぁ…\n…はぁ……うふふふ……精液、楽しみぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「いいんですよぉ……このまま出してくれても。この覚醒戦士のおっぱいと顔\n、もっとドロドロにしたいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「それとも……ん、ふぅ……飲ませたいですぅ？　ふふ……隊長のエッチぃ…\n…私、決められません。隊長が決めて下さいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひやあああん！！？　すごい……っ、こんなにぃ……はぁ、はぁ……隊長っ\n、いっぱい出しすぎですぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……はふぅ……顔が、顔に……精液……いっぱぁぁい……♪\n　はぁ……ふぅ……出てる……まだ出されてるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「精液が、張り付いてるぅ……ああん、ドロドロが滴って……おっぱいが真っ\n白になってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あはぁ、見て下さい……すっごくエッチぃ～～～……やぁぁん、出しすぎで\nすぅ……はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「顔も、おっぱいも……ううん、私の全部が精液まみれですぅ……あぁん、せ\nっかく覚醒した私なのに……こんなにみすぼらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふふ、汚されると、興奮しちゃうですぅ……うふふふふ……どうです？　隊\n長も興奮するんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「覚醒して、超強くなったサムライを……ザーメンでベトベトにできる……う\nふふ、ああん、私が男だったら、きっと最高に楽しいと思うです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……あぁん、まだチョロチョロ出てる……先っちょから、エッ\nチなミルク、まだまだ溢れてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うっふっふ……隊長……ひょっとして、私のこと好きです？　隠さなくたっ\nていいんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えへへ、曖昧な返事ですね……でも、いいんです……すっごく楽しかったで\nす……♪　また、こーいうことしましょうね！　約束ですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぶぅ！？　んぐぅ……んぁむ……むぐむぐ……んん～～～～～……ゴクン\n……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んふぅ……変な味ですぅ……苦いようで、しょっぱいようで……やっぱり苦\nい……美味しくはないけど、こーふんする味ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あむぅ、んちゅ、れろれろ……ゴクン……あふぅ……まだ出てるですよ……\n？　あぁん、もう、どんだけ飲ませたいんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……顔が、ドロドロですぅ……ひゃうぅ、髪の毛まで絡みつい\nてるですぅ……はぁぁん……隊長のエッチぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……んんん～～～……ゴックン……はふぅ……全部、飲みましたですぅ…\n…ん、ん、まだ少し、喉に引っかかってるです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「オホン……ん、んん……せーえき飲むと、なんだか……喉が渇くです……隊\n長、お茶……一緒に飲みません？　はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふえぇ？　私の吐息が、精液臭い……？　あぁん、そんなこと言われても困\nるですぅ……飲めっていったの、隊長なんですよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「だって、だって、あんなに出すんですもの……２回目なのに、あんなに濃く\nて、多くて……匂いもすごい……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うふふふ……精液の味と匂い、思い出したら……興奮してきちゃったですぅ\n……はぁ、ふぅ……今日は、これでお仕舞いですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00010102_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うぅん……せっかく覚醒した私と一緒にいるのに……意地悪ですぅ……わか\nりました。また、エッチなこと、私として下さいね？　絶対ですよ……？」", "NORMAL" ]},
