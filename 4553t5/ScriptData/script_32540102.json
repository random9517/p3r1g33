{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はいはいはい……♪　ま～た今夜も、二人っきりの密室に……わたしを呼び\n出して、閉じこめて……。ほんっとうに隊長さんはいやらしいのです～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00025401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「なんですか？　エッチなことがしたいのですか？　ま～ぁそんなことだと思\nいましたよぉ。おしりでも見せてあげましょ～か？　ふりふり～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00025401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……な～んて♪　いくらなんでも、獰猛なケダモノ！　淫獣！　と有名な隊\n長さんでも、さすがにそこまでの横暴なことは……。って、ひゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00025401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あれぇ……？　あれあれあれ～？　もしかして、わたしの予想……。ズバリ\nドンピシャで大正解だったのですか～？　ふふ、ふふ、うふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「いたいけな可愛らしい女の子を連れ込んで、エロざんまいとは恐れいるです\nね～♪　どうしてもって泣きながらお願いするなら考えてあげなくも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「うきゃぁっ！？　な、なんなのですっ！？　いきなり乙女のおしりっ、しり\nっ……！　ヒップを平手打ちにするなんてぇ！　あうっ！　痛いぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「うぁあああ～んっ！　力づくで言うことを聞かせようとするなんてぇえっ、\nオトナのすることではないのです～っ！　やめるのです、やめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んはぁううううっ！？　痛すぎです～……って、……あ、あれ……？　そん\nなに……言うほどの苦痛ではありませんね……。でも……うううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「おしりぺんぺんだなんて屈辱的です！　それにっ、叩かれたところがヒリヒ\nリしますっ！　熱いんですっ！　や、やっぱり叩かないでください～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……へ？　日頃の態度が悪すぎる……？　だから、しつけとお仕置きを兼ね\nて……ぺんぺんを続けるぅ！？　えっ、ええっ、こ、困るです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「っあぁうううっ！？　隊長さぁん！　男の人のおっきなおててで叩かれると\nっ、ひ、響くんです、身体に響いちゃいますから！　それに、ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あううう！　あんっ！　あんっ！　きゃんっ、あんんんっ！　ちっちゃな子\nみたいで恥ずかしすぎます～っ！　謝ります、謝りますからぁ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「エラそーなことを言ってご、ご、ごめんなさいぃ……！　はぁ、はぁ、こ…\n…こんなものでいいですか？　あひぃっ！？　だ、だめなのです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わ、わかりましたぁ！　叩くのやめてくれたら、なんでもしますです！　な\nんでもするから許してくださぁいいい～！！　ひぇええええ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……え？　おしりを叩かれて、お股が……アソコが濡れている？　ち、ちち\nちがいます、これは……！　っぁ……。は、はい。正直に言いますです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「そ、そうです……！　叱られて、いじめられて濡らしてました……。う、う\nぅう……。これからは良い子にしますから。だからご褒美ください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ちんちん、欲しいです……。隊長さんのそれ、わたしのここに入れてくださ\nい……！　う……、ここ、じゃわからない……ですか？　う、うぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「おまんこ……！　おまんこに入れてください！　は、はやく……っ！　ちゃ\nんと言ったんですからご褒美を与えるのは当然のことなのですよ！　うっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んんんん～っ♪　んはぁあああっ♪　ちんちん！　ちんちんっ……♪　あは\nぁああっ♪　隊長さんのデカデカちんちん、おまんこに入りましたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「イイ、です……ぅっ♪　あああっ、こ、これがちんちんを入れる感覚……な\nのですねぇっ♪　ひぃ、ひぃ……♪　んぇっ？　し、知っていましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「知識、ではもちろん知っていたのです！　ですがっ……あぅうっ♪　実践は\n初めてですからぁっ……！　か、感じるところがたくさんあるのですうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ♪　あぁあぅっ♪　目で見るちんちんよりぃ……っ、実際に中\nに入ってきたちんちんの方が大きく感じるのはなぜなのでしょうぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あ……ううう……！　う、動かすのならゆっくり、にしてほしいのです……\nぅっ。少しずつぅ……やさし、くぅ……！　くぅうっ、んっ、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしの小さな身体の中、ぺたんこのおなか、の奥で隊長さんのちんちんが\nゆっくり動き始めましたぁ……。ぁ……こ、こういう感じ、なのですねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あぁ～……っ。んっ？　あっ……？　あぁ……！　なるほど、なるほどなの\nです……っ！　少し怖いですが、なんとなくっ、は、把握してきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「っぁ……♪　ちんちんがこすれて、中で摩擦が起こるたびに……んぁうぅっ\n♪　快感が……き、気持ちいい感覚が生まれて……広がって……あぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「こ、この穴にはちんちんをいれるべきなんだって、わたしに教えてくるので\nす……っ。あっ♪　ここに、奥までちんちんを入れて……あっぁっうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「往復させて、中を掻き回して……あぅうっ♪　そうやって気持ち良くなるん\nだって、お、教えられているみたいなのです……！　っはぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「よ、予想してた快感より……甘くて強い快感です……！　あっ♪　こ、これ\nは……わかります、人々がハマってしまうのが……。っあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとずつ早く動かされると……！　おまんこの中に快感がどんど\nんどんどん、じわじわと蓄積されて……んぁああっ、新感覚ですうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ふ、あぁ……♪　あんっ、あぁっ……！　うぅっ♪　あっぁっあっぁっ……\n！　も、もっとしてください……っ！　激しくしても平気ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「いえっ、激しくしてほしいのです！　あぁあっ、き、気持ちいい……！　気\n持ちいいですぅ……！　はぁっ、おなかの外からでもわかりますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ボコッておなかが盛り上がるくらいっ、大きいのが入っていますですぅっ！\n　太いので突かれて、んいぃいっ♪　快感に、襲われてぇええ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ゾクゾクが止まらないんです……！　っぁっ！？　今っ……中でちんちんが\n膨らんで……？　こ、これはまさか……？　っあっ！　や、やはりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「こ、これはお仕置きだから……このまま中に出す……！？　あっ！？　ち、\n膣内射精をするということですか！？　あっぁっ、ど、どうすれば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はぁううっ♪　わ、わかりました……！　中に出してもいいのですっ！　で\nすから……このまま抜かずに、もっと気持ち良くして欲しいのですぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はひぃいいっ♪　あひっ！？　ひぃっあぁっ！？　あッ……！？　これっ…\n…！　今出てますです！？　あっ！　びゅぶって流しこまれてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はぁんんっ♪　これが中出しぃっ……！　膣内射精、おまんこへのせ～えき\n注入ぅううっ……！　あひぃっ、そんな量入らないですぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしのおまんこっ……！　狭くて小さいのですっ、隊長さんのっ……！　\nデッカいちんちんも入っているのに、更にせ～えきだなんて……あふぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしの赤ちゃんのお部屋っ♪　子宮の入口、がっちりちんちんでホールド\nされて！　穴に直接撃ちこまれてます！　はうんっ♪　あっぁっあぁッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あつぅうういいい～～っ！　い、イヤなのです、子宮の中にたっぷりドロド\nロの粘液が溜まっていくのがわかるのです……！　重たく感じるくらいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「大量のせ～えき……！　全然止まりません、ちんちんもまったく小さくなら\nなくて……！　あっ♪　むしろどんどん力強くなってきているようなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっ！　出しながらちんちん、押しこんでくるなんて卑怯ですよぉっ……！\n　あっ♪　イッちゃいますっ！　イキますですっ！　んああああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　ああぁあああっ……！　あうぅううっ♪　イッちゃいますぅうう\nっ！　イキますぅううっ……！　あふぅっ♪　あうっ♪　んふぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……不思議ですっ、誰にも教わっていないのに……！　勝手に身体が、おま\nんこがせ～えきを吸い上げようとしてうねってます……！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ダ、メ……ぇっ♪　射精中のちんちんを刺激するなんて……！　って、あふ\nぅっ！　ま、まだするのです！？　許可なく腰振り再開してますよねぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「っひあぁああっ！？　きゃふぅっ！？　あふっ！？　んんっふっ！？　あう\n～～～っ！？　またおしり、おしりペンペンですかぁっ、ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わかりましたぁ！　抵抗しませんっ、自由にしてくれていいのですっ！　エ\nッチしていいですから、おしり叩かないでくださぁいいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あひぃんん！！　腫れちゃいますっ、おしり絶対真っ赤になってます！　見\nなくてもわかりますぅうっ！　あ、あ、ジンジン熱をもって……ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっ♪　べっ、べつにっ……このままするのがイヤだなんて言ってないので\nすぅ！　なのに、なのにおしりを叩くし、強引にするしぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「信っじられません～っ……！　でも……。あっ♪　さっきよりもっと気持ち\n良くしてくれるのなら、許しますっ……！　あぁっ……す、すごいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「おまんこの中の、せ～えきのヌルヌルで……！　ちんちん、すべりが良くな\nってます……！　びっくりするくらいスムーズに中を往復して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ♪　ふぅうっ♪　い、いいですよぉっ……！　気持ち、イイです\n……！　一回目よりもずっと、ムラムラしますぅ……。続けてくださいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あッぁっ、んはぁあっ、あっ♪　慣れてくればくるほど……快感\nが上昇してきます、あっ♪　な、なんなのですかこれは……っ。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「はぁああっ♪　知識だけではわからなかったのです！　ちんちんがこんなに\nスゴいなんて……っ、あっ♪　あっ、大好きになってきましたぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ちんちんをおまんこに入れて、中で動かしてもらっているだけなのにぃい…\n…！　こんな単純作業で、あっ♪　こんなに気持ちいいとかヘンですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、あひぃっ、あああっ、うぁあああ……！　なんでも言うことを聞い\nてしまうのです、ちんちんに身体を、脳を支配されていくのです～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっうぅうっ♪　んぅううっ♪　気持ちイイ……っ、気持ちよすぎですぅう\nっ……！　あっ……目の前がチカチカして……。こ、これは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「まさかわたしも、イクのですか！？　短期間に二度も！？　ふぁあっ……は\n、恥ずかしいですが……隊長さんと一緒なら、いいです！　イキますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あぅっ、ううっ！　お願いします、一緒に……一緒にイッてください！　は\nぁっ♪　あぁっ、も、もうイキます！　わたしもうイクですからぁあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ふぁあぅううううッ♪　イクイクイクですぅううっ……♪　あっ♪　隊長さ\nんのちんちんも、震えてますよ！　喜んでますっ……あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「嬉しそうにびゅーびゅーせ～えき出しちゃってますですよぉ～っ♪　あはぁ\nっ♪　良かったですぅううっ、わたし一人じゃなくってぇえええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「うんんんっ♪　どぴゅっ、どぴゅっておまんこの中……せ～えきが注入され\nてくるのがよ～くわかります……！　あはっ、そんなに良かったんですかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「わたしのちっちゃなミニミニおまんこ♪　んぁんんっ♪　中がいっぱいにな\nって、逆流して溢れ出しちゃうくらいにぃっ……あっ、出てますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「どびゅーっ、びゅぶぶぶっ！　ぶびゅーっ、びゅるるるって……♪　あッ♪\n　あっぁっ♪　こんなに激しくしゃせ～して恥ずかしくないんですかぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「は、ぅっ♪　ふぁうううっ♪　出すのは二回目なのにっ……一回目よりたく\nさんあっついのを出してしまうなんて……ほんっと～にヘンタイです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んんんっ……♪　どうですか……？　ぜ～んぶわたしのおまんこの中に入っ\nちゃいましたよ……。隊長さんのせ～えき、ごちそーさまでした……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……楽しかったです？　わたしは……ぷふふ、楽しかったです。でも、その\nかわりに～……おしりがものすごぉ～っく腫れてしまいました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「まったく……女の子の真っ白なおしりに、赤い手の跡をつけるだなんてさい\nあくなのです！　叩かれてあんなにしおらしくなっていたのに、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あははっ、あんなの演技なのです～♪　って、ひぃっ、ごめんなさいごめん\nなさい！　エラそうにしたかっただけです！　もう叩かないでください～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「んぁふ！？　わっ……！？　えっ、ふゃあああっ！？　な、なぜぇっ！？　\nど～しておまんこの中に出さないのですぅううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あっ！？　あっ、せ～えきっ、二回目のせ～えきが！　無駄になってしまう\nのです！　待って……待ってください、も、もう出ちゃってますぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……あうっ！　えっ？　今回は中に出すのではなく、外に……あっ♪　わた\nしの身体にかけたかったのですか！？　そんなのおかしいですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんできないようにするなら一回目から、外に出していたはずなのに…\n…！　今回ばっかり急にちんちんを抜くなんて……！　あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ええええっ！？　避妊とかではなく、ただ見たかったのですかぁっ！？　わ\nたしがせ～えきでヌルヌルになっているところを！？　ヘンタイです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　ヘンタイの隊長さんのせ～えき、量が多すぎて……！　あっ！　\n避けられないです、全部かかっちゃいます……くやしいですぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「あ、あぁあああ……。結局ぅ、ぜ～んぶ外に出してしまったのですね～……\n！　別に、出したいところに出せばいいとは思いますですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025401_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「でも～。なんだか消化不良と言いますか、イキきれなかったと言いますか～\n……。ううう。おしりはペンペンされるしさんざんなのです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「……めちゃくちゃ気持ち良さそうにしてたのに、ですか？　そ、それとこれ\nとは別問題なのです！　むしろ気持ち良かったからこそというかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マルーシャ" ]},
		{"command":[ "SETTEXT", "「ああああ、もう！　いじわるな隊長さんにはど～せ女の子の気持ちなんてわ\nからないのです～！　つ……次は絶対中に出してくださいねぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_254_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}