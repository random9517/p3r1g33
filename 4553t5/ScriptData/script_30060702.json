		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「うぅ……その……突然、すみません……。なんだか、身体が……疼いちゃっ\nて……そのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704101" ]},
		{"command":[ "SETCHARA", "0", "char_00000607_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「自分で、シても……全然火照りが収まらなくて……だから、あなたに……お\n願いしたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　あっ、ああ……すっごいオチンチン、おっきくなってます……\n。ごくり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅ……。オチンチン、擦りつけて……。ああ、ンゥ……そこぉ…\n…熱いオチンチンでなぞられるの……いいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「で、でもぉ……そのオチンチン、やっぱり、な、中に、欲しくて……ああ…\n…その……お、オマンコ、にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぅ……。こ、こういうときって、未来のわたしはどういう風におねだりし\nていたんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「教えてくれるんですか？　え、えっと……なになに……？　そ、そんなこと\n言っちゃうんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぅっ、ああ……っ。やぁあ……オチンチンで擦られると、どんど\nんオマンコが切なくなってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わ、わかりました……。はぁ、はぁ……。あなたに教えてもらったとおり…\n…い、言いますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あ、あなたの勃起したオチンチンを……園子の……ンッ、エッチなオマンコ\nに……奥まで、ずぶって……入れて、くださいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああぁっ！　本当に一気にぃっ！　おおっ、オチンチンがっ、\nオマンコにきちゃったぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「とっても、ぶっといオチンチンに……オマンコ、ああぁっ、いっぱい拡げら\nれちゃってる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、くぅ……。キツいって……そ、それは当然です……！　だ、だって…\n…わたし、初めてなんですからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「初めてなのに……っ！　で、でも……気持ちいい……。オマンコ、あなたで\nいっぱいになってるの感じて……気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ひゃぁあっ！？　ま、待って、動くのは……もう少し、オマンコが慣れてか\nらじゃないと……んぁっ、ああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ああっ！　オチンチンがっ、ンッ、わたしのオマンコを、出た\nり入ったり……しちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、感じちゃうっ！　感じちゃってます！　オマンコが勝手\nにっ、ンッ、オチンチンをぎゅうって、締め付けて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「オチンチンの形……っ、先っぽとか、デコボコとか……ああんっ！　ぜ、全\n部ぅ……感じちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あ、あ、う、うぅ……！　気持ちいい……気持ちいいです……！　んぁあっ\n、あなたのこと……すごく、感じてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「オチンチンで、オマンコたくさんゴシゴシ擦られて……んっ、初めてのオチ\nンチンに、オマンコ拡げられて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、気持ちよく、なっちゃって……んっ、んくぅ……っ！　頭の中……\n真っ白になっちゃいそう、です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んふぅっ、はぁっ、はぁあっ！　ああっ、あなたも……んっ\n、わたしのオマンコで気持ちよくなってますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「キツキツで……う、うねってる……。ああっ、オマンコ……んっ、んふぅ…\n…エッチなお汁も、でちゃっててぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んやっ、は、恥ずかしいです……っ！　んっ、んふぅうっ！　ぐちょぐちょ\nのオマンコ、ああっ、ずぼずぼって、されて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンが、激しく動いて……ああっ、ああっ、エッチな音……\nオマンコからいっぱい、しちゃってるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、激しくされるの……す、好きかも……。オチンチンで、オ\nマンコ乱暴にされるの……好きぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　エッチなオマンコ、勃起オチンチンでずぼずぼホジホジされ\nるのっ、とっても気持ちいいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ああっ、あなたのオチンチン、中で、お、おっきく……ンッ、\nああっ、ますます、膨らんで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こ、このまま、中に……っ！？　ちょ、ちょっと待ってくださいっ、中は、\nその……だ、ダメですって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、だ、ダメっ、中は……んぁっ、に、妊娠しちゃうかもしれな\nいのに……んっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ちょっと、待って、腰を……んぁあっ、動かすの、止めて……あっ、あっ、\nああっ、んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「なんでっ、ますます激しくなってるんですかっ！　ほ、本当に、わたしに中\n出しするつもりなんですかっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「そんなのっ、んっ、やめさせないと、いけないのにっ！　んぁっ、ああっ、\nだめっ、オマンコ気持ちよすぎて、抵抗できないぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、このままじゃ本当に、この人の精液がオマンコの中に注が\nれちゃうのにぃ……ああ、ああ……ダメ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ダメ、あ、あ、あ、ああ……っ！　あはぁああぁぁんっ！　出てるぅっ！　\n中にっ、オマンコに精液っ、いっぱぁいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「熱いのがっ、オマンコの奥にいっぱいぶつかって……っ！　んっ、ああっ、\n痺れちゃうっ！　ビリビリって、キちゃうぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はぁあ……はぁあ……ほ、本当に……中出しされちゃった……。男の人と…\n…初めてのセックス……そのうえ、中出しぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ひ、ひどすぎます……こんなの……。む、無理やりされて感じてただろうっ\nて、そ、そりゃあ……うぅ……まあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わたしだって、初体験とか初中出しの理想ってあったんですよ？　もうちょ\nっと、ロマンチックな方が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「で、ですからやり直しです。その……まだ、火照りもおさまらないので、付\nき合ってください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ！　あなたのオチンチン、まだまだ中で、すっごく硬くって…\n…！　んっ、ああっ、あはぁあ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「たくさん中出しされたっ、ぐちょぐちょのオマンコっ、ああんっ、たくさん\nっ、かき回して……んっ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、オマンコすごいっ！　んっ、んくっ！　ますます、感じちゃ\nって……ああっ、んっ、んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいのにっ、でも、気持ちよくて……っ！　あっ、ああっ、わた\nしも……腰、動いちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、どうして、こんなにぃ……っ！　あなたの、オチンチンで…\n…んっ、気持ちよく、なっちゃって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「オマンコ、びちょびちょ濡らして……んぁっ、乱暴にオチンチンでずぼずぼ\nされて、感じまくって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こんな……淫乱みたいに、なっちゃうなんてぇ……っ！　あっ、ああ……っ\n！　でもっ、オマンコ気持ちいいの……逆らえないのぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　あなたのオチンチンがっ、ますます激しくオマンコ突い\nてぇっ！　んっ、奥っ、ゴリゴリっ、してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「それっ、んっ、頭の中、真っ白になるくらい気持ちよくなっちゃいますっ！\n　ああっ、ああっ、ああ……っ！　あはぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、また……イッちゃいそうに、なってる……！　オマンコ、\nまた……イかされちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あっ、あなたも……また……射精しちゃいそう、ですか？　んっ、また、わ\nたしにっ、中出しする、つもりで……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んんっ、そんなのっ！　ああっ、中出しっ、二回もされたら本当に妊娠しち\nゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「赤ちゃん、出来ちゃうかもしれないのにぃ……っ！　んぁっ、ああっ、でも\n、でもぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わ、わたし……あ、あなたの、精液が、欲しくて、たまらなくなっちゃって\nます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「あなたと一緒に、気持ちよくなって……。ああっ、あなたと一緒に、イキた\nいって、思っています……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、だからっ、今度は一緒に、イキましょうっ！　ねっ、ああ\nっ、たくさん、オマンコ締めますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「淫乱乳オバケの発情マンコっ、思いっきりぎゅうってオチンチン締め付けて\nっ！　ああっ、あなたのこと、感じさせて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、いっ、一緒にっ！　いっ、イクッ、イクッ、ああっ、イきましょう！\n　んっ、んっ、あっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、イクッ、イクッ、わたしもうっ、なにか、キちゃって……\nあっ、あっ、キて……きてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「精液っ、ああっ、あなたの精液ぃっ！　わたしにっ、またっ、たくさんだし\nてぇえええぇぇぇええぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　ああっ、あはぁあああぁぁぁああぁぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「出てるっ、出てますぅ……っ！　あっ、あっ、また……ドロドロのアツアツ\n精液ぃ……っ！　んっ、んぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704302" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「いっぱいっ、オマンコにっ、注がれて……っ！　イッ、イクッ、わたしのオ\nマンコ、中出しされてイキまくって……んっくぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、止まらない……っ！　なかなか、射精止まらない……っ！\n　オマンコから溢れるくらい、中出し……されちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んぅ……んふぅ……。すっごい……。たくさん、射精しましたね……。はぁ\n……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わたしの中……あなたの中出し精液でいっぱいになっちゃってますよ……。\nふぅ……本当、孕んだらどうしましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……そ、そのときは、ちゃんと責任を取ってくださいね？　私には、おっぱ\nいしか取り柄がないかもしれませんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「でも、こう見えて尽くす女なんですよ？　大好きな人には……ちゃんと、尽\nくすタイプなんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「エッチな奉仕だってがんばりますし！　あなたが気持ちよくなることなら、\nなんでも覚えますから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「……って、もしかして同じようなことを未来のわたしも言っていましたか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、んんぅ……っ！　はぁっ、はぁあああぁぁぁああぁぁんんつ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「ああっ、す、すっごい……っ！　んっ、ああっ、ドロッドロの濃厚精液がっ\n、わたしに……たっくさんかかってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、すっごい臭いぃ……っ！　んっ、んっくぅっ！　やっ、こ\nのエッチな臭いだけでっ、ンッ、またイク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅうううぅぅぅっ！！　あっ、ああ……はぁ……。気持ちよかった\n……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こんな……頭の中……おかしくなるような匂い……んぅ……ドロッドロに汚\nされながらイクの……クセになりそうで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「とっても濃い……あなたの匂いに全身包まれて……んっ、あうぅ……さっき\nから、何度もイッちゃってるんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000607_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。わたしのこと……こんな淫乱な女の子にして……どう責\n任を取ってくれるんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「わたしは……あなたのこと、好きになっちゃったので。もう、一生ついてい\nくつもりですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「なんですか、その顔……。わたしは、もう元の時代に戻ることは出来ないん\nですから。ちゃんと責任を取ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0704409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "園子" ]},
		{"command":[ "SETTEXT", "「こんなにセクハラして……こんなにエッチな身体にしたんですから……最後\nまで、面倒をみてください」", "NORMAL" ]},
