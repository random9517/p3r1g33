	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はははははっ！　ざまぁみやがれルナテミス！　いつまでもでけぇ顔して威\n張り散らせると思ったら大間違いだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へん！　いくらでっけぇルナテミスだって、私たちにかかりゃこんなもんさ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「態度と図体が大きいばかりで、知恵が足りませんでしたね。あのルナテミス\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマをいじめるルナテミスは、許さない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとみんな！　ルナテミスって言い過ぎ！　そりゃ、あのルナテ\nミスはウザかったけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……………………………………！　つきみまでそんなことを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ！　ご、ごめん！　ルナテミス！　そういうことじゃないの！　偽者！　\n偽者の話だからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105190002" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……もういい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105190003" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もういい！　よーくわかった！　皆が私のことを普段からどう思っているの\nか、よーくわかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「え！？　え！？　あの、ルナテミス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020105190004" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと落ち着いてくださいよ、姫様！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何が落ち着けだ、これが落ち着いていられるかっ！　だいたいお前が一番『\nルナテミス』と連呼していたではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私がお前に何度『あれは偽者だ』とツッコんだかわかるか！？　私も覚えて\nいないが、とにかくかなりの回数だぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、あの、それは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕だけではない！　全員そうだったじゃないか！　もういい！　わかった\n！　おまえたちが私のことをどう思っているか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今回と言う今回はよーくわかったっ！　私は、私は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう、やってられるかぁ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190012" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ！　ちょっと姫様！？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あーあ、怒っちゃった。ダイヤナちゃん知～らない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ルナ様、へそ曲げると後を引くからなぁ……どうなっても知らねえぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010105190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、機嫌を直してくれるまで平謝りするしかないだろうねえ。カツマ、行っ\nといで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人のキレのいい土下座を久しぶりに鑑賞できそうですな。ワクワクして\nまいりましたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……かっこいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、どうかご無事で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう、どうも……って！　みんなして俺に丸投げかよ！　てか、なにお\n前ら『自分は関係ないでーす』みてえな顔してんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それは決まってるじゃないか。だってお前は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010105190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "一同" ]},
		{"command":[ "SETTEXT", "「みんなの隊長だから～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090105190001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "-600" ]},
	{"command":[ "SETCHARA", "1", "char_00000201_01", "8", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "2", "char_00001201_01", "8", "CENTER", "200" ]},
	{"command":[ "SETCHARA", "3", "char_00001401_01", "8", "CENTER", "600" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
	{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010105190002" ]},
	{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
	{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなときだけ隊長扱いしやがってぇ～～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0058" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当にすんませんでした」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結局、俺は一人でルナテミスに謝りに行かされた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいんだ、どうせ私なんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190013" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスは座り込んで『の』の字を地面に書き、完全にいじけていた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「みんな、私の事が嫌いなんだろう……私の事をボケナスビだと思っているん\nだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190014" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そんな事ないですよ！　みな、ルナテミス様の事が好きですし、ボケナ\nスビなんて思ってませんよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマは『一人でもウザいのが３００人以上』とか言っていたし、ダイアナ\nは『ルナテミスうざいっ！』って言ってたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190015" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0059" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それに誰も『偽』をつけてくれないし……お前達がどう思っているのか、よ\nく分かったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190016" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0058" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うわっ、言われた事、全部覚えているのか……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どれだけ根に持っているんだ。面倒だな……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……今、面倒臭いと思っただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190017" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、別に……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「声が裏返ってるじゃないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190018" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0059" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しまった！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「声に出てるじゃないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しまった！　あまりの勘の良さに、つい本音が……！？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あの、みんな本当に――」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさい、うるさい、うるさい！！　みんな嫌い、大嫌い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私なんか、私なんか……うわああああああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105190021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスは、耳を塞いで、完全に話を聞かなくなってしまった。", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひ、姫さま、話聞いて！　本当にすんませんでした――！！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この後、へそを曲げたルナテミスが機嫌を直すまで、半年分ぐらいの土下座を\n２時間近くもするはめになった……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「隊長なんか、もう辞めてぇよぉ～～～っ！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
