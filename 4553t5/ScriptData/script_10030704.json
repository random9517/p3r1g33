		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ドラゴニック・パワァァァァァッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「いくぜぇっ！　サンダァァァァッ！　チェェェェェェンッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいまてっ、こんな狭いところでそんな大技つかったら……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスの剣と雷をまとったスケバンサンダーの鎖がぶつかり、衝撃波が洞\n窟の壁に当たり亀裂を生じさせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まずい、この音は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「洞窟の奥から水が流れてきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やばい、地下道が水没する！　逃げるぞみんな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「てめぇ、お宝のヒントが水の底じゃねぇか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115520002" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと！　もとはといえば貴様が邪魔してきたからだろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああもう、姫様落ち着いてくださいって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだぞ。こうなれば、別の入り口をさがすしかないだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「この惑星の赤道沿いにあるけば、なにか見つかるかもしれません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115520002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「けっ。まあいい、とにかく宝は先に見つけた方のものだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115520003" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「望むところだ。私たちのほうが先に見つけてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「宝探しの素人に負けるかよ！　ここで休んでいてもいいんだぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115520004" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「すぐに宝を見せびらかしに戻ってきてやるよ。じゃあな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115520005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「言わせておけば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーから姫様、落ち着いてくださいって。少し冷静になりましょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前、悔しくないのか！　なんだかよく知らないやつにああまで言われたん\nだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115520005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……そうですけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、あのスケバンサンダーというやつに宝を奪われるわけにはいかな\nくなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わたしたちは彼女とは別の方向を探索してみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115520004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115520003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「きっと、この近くに別の地下への入り口があるはず」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。ほら、行きますよ姫様」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "というわけで、惑星の赤道周辺を探索して数分……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんもない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁ……疲れた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「熱くて溶けちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "赤道付近というだけあって、昼間の日差しはかなり強い。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主ら、なにをしているのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まさかインクレディブル・スクワッドまで来ているとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あーっ、偽物！　それに、オボロまで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115520002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……今回はあの変なニンジャはいないようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115520001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおい、こいつらまで探しに来ているのかよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
