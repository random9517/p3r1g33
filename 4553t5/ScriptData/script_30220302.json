		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「勃たなくなるくらい、セックスしまくろうじゃないか。キミのこと、もう逃\nがさないからね」", "NORMAL" ]},
