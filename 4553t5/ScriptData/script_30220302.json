{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミ、実験の時間だ！　先だって、キミには手コキで射精してもらったわけ\nだが、もっとほかのところで精液を受け止めたくなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「……みなまで言わなくたってわかるだろう？　つまりは、こういうことだよ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふふふ、キミの服も脱がせてしまったし、これで準備万端だよね。こうして\n押し倒してしまえば、キミも抵抗できないだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002203_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そしたら、あとはキミのオチンポを挿入……って、あ、あれ？　うまくいか\nないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「うぅ、うるさいな。こういうこと、経験がないんだから仕方がないだろう。\n実際にやってみるのは初めてで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「……というか、こういうことは男であるキミがリードすべきなんじゃないか\nい？　うん、きっとそうするべき！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だから、キミはボクのことをリードしたまえ。ふむ、まずはキミのオチンポ\nにボクのオマンコを擦りつければいいんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、こうかな？　んふっ、オチンポに、オマンコを押しつけて…\n…あんっ、だんだん、硬くなってきてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んぁあっ、んっ、んくっ。キミの勃起を、ああ、オマンコで感じる……んっ\n、んふぅ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だんだん、下半身がうずうずしてきた……んっ、ふぅ……。はぁ……オマン\nコも、濡れてきているって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そ、そりゃあこうやって、性器の粘膜同士を擦りあわせていれば……んふぅ\n、当然の反応を、返すよ……ああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミのオチンポだって、ンッ、ボクの愛液を塗られて、ますます硬く、大き\nくなっているみたいだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そろそろいいだろう、だって？　もしかして、いよいよボクのオマンコの中\nにキミのオチンポを挿入しちゃうのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああ、いいよ。ボクのオマンコはもう十分に濡れているだろうし……。それ\nに、ボクももうキミのオチンポが欲しくてたまらなくなってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「こういうときは、キミにおねだりすればいいんだよね？　ふふ、この天才美\n少女科学者のオマンコに、キミのバッキバキのオチンポを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁあああぁぁぁ～～～～っ！！　い、いきなりオチンポが、ずぶっ\nて……はいってきて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああっ、頭の中が……真っ白になるような感覚がやってきて……！　はぁ、\nはぁ、ボクは、いったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「イッた……？　キミのオチンポが挿入されただけで、オーガズムに達してし\nまったっていうのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「これ……初めてだっていうのに……。まさか、こんなに簡単にイかされてし\nまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それに、初めては痛いって聞いていたけど、そんなに痛みもない……。なる\nほど……こういう初体験も、あるんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「おっと、これでおしまいじゃないだろう？　腰を動かして、もっとボクのこ\nとを気持ちよくさせてよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あっ、そうそう、あはぁんっ！　腰を、ああっ、突き上げて…\n…んっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「思いっきり、ずんずんって、きてっ！　あっ、あっ、すごい……んぁあっ、\n硬いのが、奥まで届いてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キツキツのオマンコ、んぁっ、こじあけるみたいに何回も、何回もぉっ！　\nあっ、あっ、オチンポで、んくっ、突いてっ、あはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「いいっ、いいっ！　オチンポ、オチンポ気持ちいいっ！　あっ、ああっ、も\nっとして、もっとぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミのオチンポが、ああっ、オマンコをゴリゴリってするのを、感じるよぉ\nっ！　ああっ、んひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「すごく、気持ちいい……初めてなのに、あっという間に気持ちよくなってし\nまってる……！　んっ、ああっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「頭の中が、おかしくなりそう……！　ああっ、ボクからも動くからね。んっ\n、オマンコ締めながら、腰、振るよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　あっ、ああっ、これ……！　一緒に動くと、さっきよりも深い\nところにオチンポ刺さって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「快感で、頭の中がいっぱいになる！　ああっ、腰が勝手に動いちゃうぅっ！\n　ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「オマンコの締り、うねり……感じるかい……？　はぁ、はぁ、キミのオチン\nポに、ボクの中が勝手に、しがみついているんだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「な、なに？　そんなにされたら射精してしまうって？　このままってことは\n、中に？　膣内射精ってことかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、いいよ、中に射精すればいいじゃないか。ここまでしたんだから、ボ\nクも中出しに興味があるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だから、ほら、こうやって蠢いているオマンコに、キミの精液を、どぴゅど\nぴゅって射精してしまえばいいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「うん、きて……射精して、中出しして……！　キミのザーメンをオマンコで\n味わわせて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んふっ、ああぁぁぁああぁぁ～～～～っ！！　びゅくってきた！　熱い精液\nが、きてっ、オマンコの奥に……きて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「イクッ、イッ、イク……ッ！　中出しっ、精液子宮に浴びながらイクッ、イ\nッちゃう、イかされるぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ひぃっ、ひぃっ、イクッ、まだイッてる……！　精液がオマンコに染みこむ\n……んっ、こんな感覚なのか……んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああ……あまりの衝撃で、頭の中がまだクラクラしてる……。気持ちよすぎ\nる……孕まされる快感……たまらないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。この満足感……実験が成功したとき以上かもしれないな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それで……キミのオチンポはまだまだ勃起しているか。うん、見込み通りの\n持久力だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「まあ、ボクみたいな美少女とセックスしているわけだし、一度で萎えちゃう\nわけがないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だからもう一回。んぁあっ！　ちょっと動いただけでさっき以上の快感だよ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、そうか……イッたあとだから、感度が上がっているんだね……\nより気持ちよくなれるわけだ。好都合！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、腰振っちゃうね！　あああっ、オマンコがさっきより滑らか\nに動く……んっ、んくっ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミのザーメンとボクの愛液が混じって、んぁっ、動くたびに、ああ、かき\nだされて、溢れてきちゃってる……！　んぁっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なんていやらしい光景ぃ……。で、でも……すごく興奮しちゃう……！　ん\nぁっ、腰が、止まらなくなっちゃうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んひっ、はっ、はぁあんっ！　キミも動いちゃうんだね。ボクのオマンコ、\n思いっきりずぼずぼってしちゃうんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ひっ、ひっ、突きあげ、すごいぃっ！　ああっ、子宮が、亀頭で持ち上げら\nれているみたいだよっ！　んぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「オチンポ、きてっ、きてるっ！　アアッ、奥にまでっ、何回もボクの一番奥\nを、乱暴にノックしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んひっ、そのたびに、オマンコ反応して、キミのオチンポをぎゅうっと締め\nつけて、んぁっ、オチンポのこと、もっと感じちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「これっ、これすごい……セックスが、こんなにすごかったなんて……！　ん\nひっ、あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、頭の中が快感でいっぱいになっちゃってる……！　もう、\nこれしか考えられなくなりそうだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミのオチンポに夢中になってしまってる……！　んぁあっ、オマンコが、\nキミのオチンポに吸い付いてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、キミのオチンポがますます膨らんで……！　射精しそうに\nなってるんだ……わかるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「さっきもそうだったから……キミのオチンポが射精の寸前に膨張したの、わ\nかってたから……んっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「いいよ、また射精しそうになっているなら、キミの好きなところに射精すれ\nばいいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクはもうどこだっていい！　キミのザーメンを浴びながらイキたいんだ。\nもう、イキそうなのずっと我慢してるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だからボクをイかせて。キミのオチンポでイかせて！　キミのザーメンでイ\nかせてぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、もう……イクッ、イクッ、イッちゃう……あっ、ああ……\nイッくぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んふぅううっ！　はぁっ、はぁっ、ああぁっ！　んはぁあああぁぁぁ～～～\n～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「また中にっ！　オマンコの中にっ！　んひっ、ひぃいっ！　いっぱい注がれ\nる！　ザーメン、くるぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ！　ああっ、またイかされるっ！　子宮いっぱいに、キミの\n子種を注がれてイクぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、まだまだビクビクって、オマンコの中でオチンポが跳ね回っ\nて、んくっ、射精……続けてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクのオマンコが、精液を搾るように動いてるって？　そんなこと言われて\nも、オマンコが、制御できないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「バカになってる……！　オマンコが、中出しされて、気持ちよすぎてバカに\nなっちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。天才のボクが……オチンポ相手に、こんなにバカになっ\nちゃうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「オチンポが気持ちよすぎて……んふぅ……これがセックス……すごいな……\n興味深いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そしてこの精液……どれくらい中出しされたら、ボクは孕まされてしまうん\nだろうね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふふっ、興味が出てきちゃった。キミ、もちろんボクの実験に付き合ってく\nれるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304310" ]},
