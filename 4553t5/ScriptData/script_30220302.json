		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ひぃんっ！　急にオチンポを抜いて……んぁっ、ああっ、勢いよくザーメン\nが、噴きだしてぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、すごい……！　なんて勢いの射精っ、アアッ、精液が、ボク\nの身体に……んひっ、あっ、ああ……かかる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああっ、熱くてドロドロの精液……いっぱい……っ！　こんな……ボクのこ\nと、真っ白になるまで射精するつもり……んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「イクッ、イッちゃう……！　精液ぶっかけられながら、イッちゃうよぉおお\nっ！　ああっ、ああ……っ！　んはぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ……ああ……。キミの精液で……ボクの身体がこんなに汚れてしまった\n……んふぅ……キミの臭いが……すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「中も、外も……キミのザーメンまみれにされて……んふぅ……こんなに幸せ\nな気持ちになるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミのことを……ただの実験相手にしておくにはもったいないって思っちゃ\nうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミと一緒に、この気持ちいい行為をもっともっと追及していきたい気分だ\n……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「まだまだ時間もたっぷりのこっているし、キミのオチンポも勃起し続けてい\nるし……」", "NORMAL" ]},
