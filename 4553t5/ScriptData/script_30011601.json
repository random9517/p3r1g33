{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……んっく……ほ、ほら……早く入れなさいよ……オチンポ……おっぱいの\n中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……入ったわ……太い……オチンポが……おっぱいの中に……\n埋もれていくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぅ……んんっ……ど、どう？　やっぱり、このスーツだと……男っていつ\nもより興奮……するものなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「って、聞くまでもないみたいね……こんなに分かりやすく膨らませて……こ\nの節操なし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……誰でもそうなる訳じゃない……ふ、ふん……また、適当に調子のいい\nこと言って……そんな言葉でどうにかなる私じゃないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「適当じゃない……本気も本気……神に誓って……あぁ、もういいわよ、別に\nそこまで意気込まなくても……別に、私だってちょっとからかい半分だし……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「少なくとも、今の貴方が私のスーツ姿に興奮して、オチンポ我慢出来なくさ\nせてることは分かってる……いやらしいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こんないやらしいオチンポは、しっかり射精してあげないと、周りにも悪影\n響だものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……な、何よ、せっかくならもう少しらしいことがしたいって……どうい\nうこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……つまり、私が人質を取られていて……脅されて、仕方なく……パイズリ\nする……そういうこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……つくづく男ってのは、そういうのが好きなのね……いいわよ、ここ\nまで来たらお望み通りにしてあげようじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それで……どうしたら、人質を解放してくれるの？　な……私のおっぱいを\n使わせろと……断ったら、どうなるか……この卑怯者っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、好きにすれば、いいわ……んっ、ふっ……その代わり、必ず約束は守\nりなさいよ……？　あっ、んぅっ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「べ、別に……感じてなんか……いない、わ……こんな一方的にされて……ん\nっ、感じるわけ……ないでしょう……んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「違う……い、今のは……ちょっと、乳首が当たってびっくりしただけ……は\n……んふっ、感じてるのとは……違うん、だからぁ……あ、ひっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅ……あぁ……それより、さっさと終わらせたら……どうなの……\nどうせ、んっ、すぐ射精するような……フニャチンなんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、んっ……や、やだ……何を大きくさせて……あっ、オチン\nポ……まだ膨らんで……ひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁっ……めり、こむぅ……熱いのが……んっ、おっぱいの中に…\n…入り込んで来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、んんっ……別に、よ、様子が変わったりなんかは……あっ、\nはぁんっ……違う……私は……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「か、感じてる訳じゃ……んっく……あぁ、オチンポ擦れるぅ……おっぱい…\n…んっ、形が潰れちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁっ、あぁんっ、どうして……んくっ、あぁ……さっきより身体\nが……熱いわ……な、何をしたの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「何も……してない……んっ、私がいやらしいから……そ、そんなことぉっ、\nあひっ、はぁんっ、あっ、乳首にオチンポ、押し付けないでぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ……あぁ……いやぁ……身体が……んっ、変な感じになって…\n…来てる……あぁっ、熱いの……感じ……始めてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だ、ダメよ……こんなところ……人質には見せないでっ……私の恥ずかしい\n所なんて……あぁっ、み、見せちゃ……ダメェっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、やぁ……そんな、乳首……引っ張っちゃ……んんっ、感じる\nっ……あひっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んんっ、くぅぅ……あぁ、すごい……激しく擦られてぇっ……あ\nひっ、あぁっ、私……どうしちゃったの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くう……ダメよ、レイジョーピンクの誇りに掛けてっ……負ける、訳には…\n…あぁ……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、気持ちいい……いやっ、違うの……あぁっ、こんなオチンポが擦れ\nて気持ちいいなんてこと……許されないのにっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、そんなに激しく動かされたらっ……あっ、あぁっ……皮が\n……めくれ上がって……んっ、す、すごいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いや、どうして……目が離せない……んっ、オチンポ……ずっと見ちゃって\nる……あぁ、先端から……汁が滲んで来てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「く……んんっ、すごく震えてる……あぁ、これ……まさか、だ、出したくな\nってるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ダメよ……射精なんて絶対に許されない……くっ……ま、また人質を……卑\n怯なことをっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……そんな止められないっ……オチンポがっ……あぁっ、激しすぎてっ\n……！　あぁっ、出されるっ……掛けられちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「来るっ……来ちゃうっ、はぁんっ、オチンポ激しくてっ……出るのっ……あ\nぁっ、精液……出ちゃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……出てる……おっぱいに、んっ、中出し……されてるぅ……おっぱ\nいが……熱いの……んはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ドロドロだわ……んく……精液が、へばりついて……あぁ……とれなくなっ\nちゃう……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……収まってる……んふ……はぁ……はぁ……はぁ……あ、ふっ……は\nぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さて……と、こんな感じでよかったの……？　その、いっぱい出してるから\n……間違ってるとは思わないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ良かった……あ、そ、そう……分かったわよ、そんなに力説し\nないでも伝わったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね、私も……ちょっと新鮮な感じがして……悪くなかった、かも……ち\nょ、ちょっとよ！　ちょっとだけだからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「って……まだ離れないで、何を当たり前のように、おっぱいを動かしている\nのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ま、まだ……要求は終わってない。んっ……ここからが本番って……そんな\n勝手な……あ、あひっ……ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ……確かに、精液で……さっきより、中が滑りやすくなって……いるけ\nどっ……んっ、あっ……くぅんっ、はっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今……どんな状態になってるか……？　なんで……私が、そんなこと言わな\nくちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「また、人質……んっ、わ、分かったわよっ……全く、んっ、ワンパターン…\n…なんっ、だからぁっ……あっ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今は……んっ、貴方のオチンポが……出した精液で……おっぱいが、汁まみ\nれに……なっているわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それを、オチンポ自体で……まんべんなく……塗り拡げられているような、\n感じになってる……すごく、ヌルヌルしてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、今度は……強くおっぱいを……押し込まれて……あぁっ、\n太い……オチンポを……挟んでるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、乳首……さきっぽが……ヌルヌルのオチンポと……擦れてるぅ……\nあぁ、そんな押しつぶすようにしたら……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、ダメ……今は、敏感になってるの……そんな、集中的に……\nコリコリ、されたらっ……あっ、んぁぁぁっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……声が出ちゃう……んっ、うぅ……身体を支配されて……好きなよう\nにされているのにっ……感じて……来ちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くぅ……ちょ、調子に乗ってぇっ……少し私が本気になれば、貴方なんて…\n…ひとたまりもっ、きゃふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、指で弾かないでっ……コリコリの乳首……あぁ、こねられるのっ……\n力……抜けちゃうからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んっ！　あぁ……こんなことで屈したりはっ……でもっ、あくっ……ま、ま\nた射精されちゃったら……私……逆らえなくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ダメ……ダメよ……あぁ、またジワって……亀頭が……滲んで来てるのっ…\n…あぁっ、そんな……ダメぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、あっ……あぁっ、激しくなって来てるっ……！　おっぱい\n犯されてるっ！　オチンポ……震えてるの、分かっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……負けちゃうっ、レイジョーピンクがっ……敵に捕まって……\nそのままっ、犯されてっ……射精されちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、私も……感じてっ……おっぱいイキそうになってるのっ\n！　このまま、されたらっ……もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……出るのねっ……？　んっ、ビクビクが大きくなって……うぅっ、\n私をまた汚すつもりなのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どこよ……どこに出すのっ？　こうなったら……何だっていいわよっ、どこ\nでもっ……出せばいいじゃないのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「また……胸に出すのっ？　す、好きにしなさいっ……あっ、はぁっ……んぁ\nぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、出て……来てる……んふぁ……熱い……おっぱいが、オマン\nコみたいになっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ、あぁ……嘘……私、おっぱいに精液出されて……気持ちよくなって\nる……おっぱい、イッちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁ……まだ、そんな勢いで……どれだけ出したら気が済むのよ……んくぅ\n……本当にヌルヌルまみれで……おかしくなりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あともう一発だけ……？　も、もう……分かったから、さっさと出しちゃい\nなさい……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……スーツがドロドロになっていく……うぅ……こんなに汚されるなん\nて……くぅ……悔しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んふっ……今度こそ……終わったみたいね……どうなの、これ……少しは満\n足した？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「わ、分かったから。思いっきり満足したのは伝わったわ。全く……本当に、\n男の欲望をまざまざと見せつけられた気分だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「でも、その……何ていうか、役になりきることで……その普段とは違う自分\nを楽しめるのは……思った以上に、よかったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あ……あくまで、たまによ！　本当にたまになら……ま、またしてあげても\n……いいから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……か、顔をこっちに向けろって……まさか、あ、浴びせるつもりなのっ\n……？　くぅっ……す、好きになさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あぷっ、んんっ、顔にっ……濃いのが……ドロって……いっぱ\nいっ……出てるぅぅっ！　んはぁぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……はぷっ、んっ……あぁ……イッてる、私も……んちゅぷっ、ザーメ\nンシャワーを浴びながら……おっぱいイッちゃってるのぉ……んぁふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……ま、まだ止まらないで出てるじゃない……どうなってるのよ、こん\nな欲望まみれにさせてぇ……んぁぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……また、出てきた……んちゅぷっ、はぁぁ……れろ……濃い味ぃ……\n濃すぎて……喉を通っていかないじゃない……んく、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「うぅ……胸も顔も……汚されて……あぁ……こんな屈辱……許されないわ…\n…んくぅぅ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さて、と……。射精……終わった？　とりあえず、今日はこれで終わりよ。\nこんなので……本当によかったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1603407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000116_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
