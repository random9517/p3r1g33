		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いつもの採石場に移動した。時間帝国側は幹部二人に大勢の兵士たち」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180007" ]},
