		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕たちも時間帝国の人たちも、タヌキ像を壊されたくないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「彼女のいう通りに場所を移動しなくちゃいけなくなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180006" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
