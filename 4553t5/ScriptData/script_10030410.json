		{"command":[ "PLAYVOICE", "v2_001_010115180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ……！」", "NORMAL" ]},
