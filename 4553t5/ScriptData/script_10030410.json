		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふむ、この間の決着をつけようではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「時間帝国は二人だけ……ってわけじゃないみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ワームホールが開いて、どんどん兵士がやってきている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まずいな……こんな狭いところで戦ったら、民間人に被害が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お前ら！！　ケンカするなら他所でやれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115180001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いつもの採石場にでも行って戦ってこい！　二度も店の前でドンパチしたら\n、いますぐこのタヌキ像をぶっ壊すからな！」", "NORMAL" ]},
