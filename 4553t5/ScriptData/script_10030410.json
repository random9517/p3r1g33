		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「対するのは、グレート・ルナリアムの面々か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「人数ではこっちの方が圧倒的に多いけど、向こうは少数精鋭って感じだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115180009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここで勝った方があのタヌキ像を手に入れる！　それで問題ないな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、問題ないぞ。命が惜しくなければの話じゃがのぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それはこっちのセリフだ！　鳳雛、今回は隠れないで戦闘に参加しろよ……\nって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115180003" ]},
