{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さん？　何をするんですか？　……ひょっとして、エッチなトレーニン\nグですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104101" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「い、嫌なわけじゃないですけど……むしろ、すごく興味があって……いえ、\nなんでもないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「私はここに寝転がっていればいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あの、私、お姫様だから……その、優しくてください……隊長さん、とって\nも興奮していて……その、あそこも……チンポもギンギンですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「さ、早速入れるんですか……ど、どうぞ！　私、我慢してますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はうっ！？　は、入ってきた……あれ、あんまり痛くない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「違和感はありますけど……嫌じゃない……むしろなんだか、体の中で隊長さ\nんの熱いチンポを感じられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あん、ああんっ……い、いきなり動かないで……びっくりしちゃいますから\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「い、痛くないです……けど、何かすごくジンジンして……ん、気持ちいいの\nかな？　初めての感覚で、よくわからないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「だからもっと動いてください。隊長さんも動きたいんですよね？　……あ、\nんっ、はぁ、ああん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あうん、ウンウゥゥ～～ン……は、激しい……ギチギチのチンポで、私のお\nマンコ突かれる～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……でも……あん、あん、うんっ……や、やっぱり気持ちいいか\nも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あんあん、あはんっ……ふぅ～～～んっ……あっ、あっ、すごい……腰が、\n腰がこっちまで来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さんの腰が、すりすりって私の股をこすって……気持ちいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あんあん……あはん、あんあん……あああーっ、今度はパンパンって……そ\nれぇ……っ、気持ちいいっ、です～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あはぁ～～～んっ、いいです、気持ちいいです……はぁはぁ、これ思ってた\nよりすごいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さん……私にもっとおマンコトレーニングしてください、お\n願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……ああっ……私の中熱くなってます……隊長さんのチンポのせい\nでもう私の中ぐちゃぐちゃです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さんも気持ちいいんですか？　私のマン肉が肉棒に絡んでくる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ぐっちゅぐちゅの、らぶじゅーすまみれの、やわにくがしめつけてくる……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「よ、よくわかりませんけど、あっ、あっはん……！　私のおマンコで興奮し\nてくれてるなら、嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「も、もっと激しくしてくれても……あんあん、はぁ～～～んっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ほんとに激しい……っ、んふうぅぅぅーん、あっ、あっ……おマンコの奥ど\nぅくんどぅくんって……ガンガン腰振って、突かれてます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あうっ、あうんっ……あ、あー、これ駄目、駄目ぇーっ……おマンコ感じす\nぎて、膣がひくひくしちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「に、肉食チンポで、肉マンコ貪られる……うっ、うぅぅーっ、ガンガン掘ら\nれて、えぐられて、愛液いっぱいぎゅうぎゅう搾りだされちゃうー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……乳首ビンビン……？　だ、だって隊長さんがこんなに乱暴なト\nレーニングするからです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「そんなの……乳首勃起、抑えられるわけないじゃないですか……感じちゃう\nのは許してくださいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ううぅっ、隊長さん……？　腰の動き早くなってないですか……なってます\nよね、ねえ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「これってひょっとして……あんあんっ、やっぱりそうですよね……出ちゃう\nんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「私のおマンコで出したいんですか……このまま中で？　お、奥に出しまくる\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「待って、待ってください、私心の準備が……んああぁぁぁ～～～っ、あはん\n、ふぅん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さん聞いてますか？　ああ、駄目、夢中で聞いてくれないで\nす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ああ、男の人の体って大きくて……ぎゅっと抱かれてると、安心して……お\nマンコが余計ひくついちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「もう駄目です……私もイっちゃいます、出して……私の奥にいっぱい、隊長\nさんの玉々からっぽになっちゃうくらい出してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「んぐぅぅぅ～～～、ひぃーっ、ひぃ～～～……出てます、あああーっ、奥に\nどくどくって、びゅーって注入されてます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ひっ、あっ……ああ、私のおマンコがぐびぐび隊長さんのザーメン飲んでま\nす……ううっ、子宮が熱いですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ああ、感じちゃう、子宮で直接隊長さんの熱々精液感じちゃう……はぁー、\nはぁーっ、ああ……まだ出てますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁー、ああぁ……と、止まった……隊長さん、全部出ちゃいました……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「よかった……気持ちよかったですか？　ふふ、それは嬉しいです……そんな\nに興奮して全部出しちゃったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「これでおマンコトレーニング終わりですか……？　え、そんな、私は物欲し\nそうな目なんてしてません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「もう一回頑張ってくれるんですか？　あの、私は隊長さんがトレーニングし\nてくれるなら断る理由はありませんけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あんっ……いきなり挿入、っ……それにまだまだ固いまま……？　隊長さん\nひょっとして、まだまだ元気なんじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あんあんっ……やっぱりすっごくびくびくして、まだまだ出したりないみた\nい！　すごいです、さすが隊長さん……鍛え方が違うんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁ～ん、あんあん……あっ、ああぁぁぁ～……こんなにいっぱい突かれた\nら、私腰が壊れちゃいますよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「うっ……ああ、今度は深いところで腰をぐりぐり……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ひうっ！？　ああ、それそれ～～～……グリグリされるの来ちゃう、来ちゃ\nいます、はっ……あっはぁ～んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ひぃ～、ひいううぅぅ～～……お、おマンコの奥、駄目なところに突き刺さ\nって……あひゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「うっ、うっ……お漏らししちゃうかと思いました……だって何度も弱いとこ\nろを重点的に……あう～～～、そこそこーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ひあっ……あっ、あっ……胸がドキドキして苦しいです……興奮でおマンコ\nに血が集まって、マン肉全体でチンポ感じてます、感じちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あんあん、いっぱい突いて……もっとたくさんしごいて……隊長さんのもっ\nともっとおマンコトレーニングよろしくお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あはん、うふん……うっ、うっ……私もおマンコで吸収しますから……隊長\nさんがチンポで教えてくれたこと、たくさん学んで気持ちよくします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「だから……あんあーんっ……うん、うんっ……こ、こうですか？　こうやっ\nてマン肉でチンポを絡めとって、しぼったら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あっ。いま隊長さん、声出してませんでした？　ふふ、私のおマンコでさっ\nそく感じちゃったんですか……もっとがんばります……ええいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あっはん、はぁん～……ひうっ、あっ……ああっ！　おマンコギチギチにし\nめたら、私まで感じちゃって……あ、ああっ……らめぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「うっ、い、イキそう……まだまだ隊長さんが満足するまで我慢しないと……\nああーんっ、うっ……でも駄目かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「だってだって、気持ちいいんです……隊長さんのチンポ、おマンコで感じて\nすぐイっちゃいそうになります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「もうなんなんですか、このチンポ……気持ちよすぎますよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「いい加減にしてください……こんな気持ちいいチンポでおマンコイキ我慢し\nろなんて、このトレーニング過酷すぎます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、イっていいですか！？　イカせて……お願いです、もう駄目……\nああ、あっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「イクイクゥーッ、イっちゃいます、我慢できなぁ～～～いっ……イクイク、\nいひっ……イっぢゃうううううぅぅぅっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "外して射精","LABEL1","そのまま射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「うふんっ、あ、やだ……なんで、抜いて……ああんっ、かかってる、かかっ\nてます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁーん、体中に隊長さんの熱く臭々のザーメンぶっかけられてるーっ、あ\n、熱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「うっ、うっ……やぁーん、中に出して欲しかったのに……はうっ、べちゃべ\nちゃって……うっ、いつまで出してるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「それに部屋もすごい匂い……くんくん、隊長さんの匂いでいっぱいです……\nはぁ～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「そんなに私の体やおっぱいに精液ぶっかけたかったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ま、まあこういうのも悪くないですね……なんだかかけられた部分が熱くな\nって……はぁはぁ、興奮しちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「特に乳首にかかったの、あっ、あっ……塗りぬりしたら、んっ、また気持ち\nよくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、これでおマンコトレーニングは終わりですか？　あっという間に\n終わっちゃいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「私ちょっと物足りないかもしれません……あっ、ごめんなさい！　催促して\nるわけじゃないんですけど……あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「またよかったら、いろいろ教えてください！　私隊長さんの言うことならな\nんでも聞いてがんばりますから……よろしくお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あはぁ～～～～ん～～～っっ……熱ぅ～～～いっ、おマンコにじゃぶじゃぶ\n出てるーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「熱湯ザーメン、シャワーみたいにぶちぶち、ぶちゅちゅ～って、おマンコの\n奥っ……子宮に直接出されてる～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はあ～、はあ～……すごい……子宮でまたイっちゃうっ……ああ、さっき出\nされた精液とお腹の中がぐるぐる混ざり合ってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「びゅ～～～って、出てる……まだ出るんですか……あああー、すごいチンポ\nって女の子のおマンコさえあればいつまでも元気なんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ああ、はぁはぁ……お腹に手当ててください……私の子宮プールで隊長さん\nのザーメン元気に泳いでますよ……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はあ～、私このトレーニング大好き……だって、とっても気持ちいいんだも\nん……隊長さんに乱暴にされればされるほど興奮して安心しちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「え！？　またトレーニングしてくださるんですか？　嬉しい……私これ好き\n……もちろん隊長さんのことも好き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00013001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「あと隊長さんのチンポも……はあんっ……また私の膣ではねましたね、いま\n……ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「次も、もっと激しくトレーニングしてくださいね？　私も、もっと隊長さん\nに気持ち良くなってもらえるよう、頑張ります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ふふ……今度は隊長さんどんなことしてくれるんだろう？　ああ～、楽しみ\nだなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_0104410" ]},
