{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「さて、隊長。あなたがどうして、私にお仕置きされているのか……当然把握\nされていますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……なんて、そんなに怯えないでください。ちょうど、任務の休憩時間が重\nなっていましたから。せっかくですので親交を深めようと思っただけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それが、なぜパイズリに……ですか？　はぁ……。あなたを喜ばせようと思\nってのことですよ。そうは見えない？　……なぜでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私はご奉仕というものをしてみようと努力しているのですが。ん……、先ほ\nど、携帯で『真夏のビーチドキドキＨ体験談』というものを見ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そこに、書いてあったことを実行しているだけです。データいわく、いつも\nと違う格好で、いつもより大胆なプレイがオススメだと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そういえば、あなたも私の胸をチラチラ視姦していたな、と思い出したんで\nす。解放的な夏の思い出、カップルのイチャイチャご奉仕」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私はこういうことには疎いので……今まで積極性が足りなかったと反省して\nいます。ですので、今日はその分徹底的にご奉仕させていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303107" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……ン……。ん、ふ……ふぅっ……ふぅう……。日焼けオイルを胸に塗りた\nくり、そのままペニスに広げていく……。面白いやり方、ですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00005003_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「頭の固い私、では想像もできない柔軟なプレイ……。勉強、に、なりますが\n……。ぅ……、これは少し恥ずかしい……です、ね……。はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「乳房の柔らかさ、と……ふぅっ、オイルのヌメりとで相当気持ち良くなって\nもらえると書いてありましたが……実際はどう、でしょうか。……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いい、ですか……？　であれば躊躇していても仕方ありません。全力で……\nんっ、ニュルニュルさせていただきます。ン、ぁ……あ、ふぅ、う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「上半身全体を使っ、て……。あぁ……♪　淫靡に身体をくねらせながら、ペ\nニスに胸をこすり、つける……。んふっ……ふぅ、ふぅ、ふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「軟体動物のように、肉棒の上で妖しく蠢いて……隊長を誘惑する、昂らせる\n、たぎらせる……。あっ……、その反応、いいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もっと私に見せてください。感じているあなたの顔を……。んっ……私好き\nなんです、あなたが反応するのを見ているのが……。は、ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「普段は見られない表情を見たい……。それがどんなに情けなくて、恥ずかし\nい顔でも。むしろその方が感じるんです。……あっ、胸でされて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そもそも大きなオチンチンを、必死に硬くしている姿だとか……。あん、こ\nわばった両脚、足の間で震える睾丸……全部、全部愛おしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「でも、少々鼻息が荒いですね……？　ん……ローションパイズリがお気に召\nしたご様子ですし……。もっと速度をあげて、積極的にからませて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「は、ぁ、あ……あぁ……♪　乳首ごとペニスをこねこねしていきま、す……\n。あっ……！　私の体温があがっているのがわかります、か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「これ、隊長のせいですよ。心臓に一番近い部分で、……あっ、赤子にミルク\nをあげるための大切なふくらみで、陰部を、男性器を扱いているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それに今日は外、で……。はぁっ、人気の多い海で、しているんです。誰か\nに見られるかもしれないというスリル……いっそ見られたい欲求」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「肌が火照って、あン……っ、自然と昂ります。乳房も熱で柔らかく蕩けて…\n…あなたのモノを欲している。オイルがなくても吸いつくほどなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……そこにローションを足したりしたら……。わかりますよ\nね？　もうニッチャニチャヌッチュヌチュで、気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あ……、あ……私も……私も気持ち良くなってきました。太いモノでマッサ\nージされているみたいで……。は、ぁ、とても気持ちいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あたたまったオイルが摩擦を減らしてくれる、おかげ、で……あっ♪　オチ\nンポと胸との境界線がだんだんわからなくなって……、っあぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「溶けあう、ようです……♪　あっ♪　もっとまとわりつきたい……あんっ♪\n　肉竿だけでなく、玉袋までいっしょくたに混ぜ合わせたい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「は、ぁっ、あぁっ♪　あぁんっ、あぁ、あ、あ……♪　ユサユサ揺らしてい\nるだけで、……あっ！　乳首に電流が走って……痺れ、ます……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたにも、わかるでしょう……っ。あぁんっ……♪　乳頭が、硬くしこっ\nて勃起♪　してしまっているのが……ほら、もっと攻めますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふぅっ……ふぅっ、ンン、んっ……んっ……あぁんっ♪　は、ぁ……あぁっ\n、あぁ、あ……っ♪　んんっ、んん……あぁんん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あら……？　腰が逃げていますよ。どこに行こうというのです。フフッ、私\nが逃がすとお思いですか？　っん、ちょうど面白くなってきたところです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「腰が抜けるまでお相手しますよ？　むしろ、腰を寄せて突き上げてください\n……。ええ、ニチュニチュ音をたてながら……あっ、ぁっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はっぁっ！？　コレっ……これすごい、です……ッ。相乗効果が……んぁあ\nああっ♪　あぁ……！　んッ……ぉっ♪　おっ♪　ぁっ、あぁ……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「隊長、隊長も感じているようですね。あ、は……裏筋までピンとはりつめて\n……。精液、上がってきたんですか？　射精したい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……それでは一度出してみましょうか。それで、そのまま勃起せずにいられ\nたならこれで勘弁してあげます。そうでなければ……。ッん、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「精根尽き果てて、精液が枯れるまでどこまでも追い詰めてさしあげますよ。\n……くす……。さあ、精液を放出してください。私の胸に……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「びゅるっ、びゅるっ、びゅる……。いいですね？　いつもしているみたいに\n出すんです。さ、じっと見つめられながら……どうぞ？　出してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ッあ……っ♪　あっあぁっ……！　あっ、あっあっ♪　出ました……出まし\nた……♪　胸の中に……、ドクドクと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふ、ンン……♪　上手です、はしたなくビュルビュル吐精出来ていますよ…\n…♪　腰を震わせて、ペニスをヒクつかせて……そのまま出し続けて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「う……♪　拒んでいたわりに、随分と量を出すじゃないですか？　ねえ……\n苛められるのが好きなんですよね？　私に射精管理されるのが♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「でなければ……。あっ♪　こんなにもこってりとした、ドロドロの精液を吐\nき出すわけがありませんよね。見てください、溜まった子種を♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「メレンゲが作れそうな量ですよ……。さぞ射精を楽しみにしていたんでしょ\nうね。睾丸から直送されてきた、作り立ての臭い精液……見事です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……そして、隊長？　どうやら、あなたのオチンチンは更なる攻めを欲して\nいるようですよ。これだけ出してまだ、私の胸に甘えてきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「自分から亀頭をなすりつけていますよね？　尿道に残った種汁を、谷間に…\n…肌に塗りつけて、もっともっととおねだりをしています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「これは……このままおしまいにしたいとは到底思えない態度ですよね？　し\nてほしいのでしょう？　気を失うほどの肉竿攻めを……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「かまいませんよ。もう二度と、私の身体以外でイけなくなるくらい……。こ\nの味を刻みこんであげたいと思っていたところです。……それ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あ……♪　精液とオイルで潤滑油は豊富ですし……♪　このまま見ていてあ\nげます。あなたの欲深い、貪欲なペニスが快楽に満たされるところを♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふっ……ぁっ、ぁっ、あっ……♪　あな、たのような変態には私の体重をか\nけた、パイズリプレスがお似合いです……！　苦しいくらい圧迫、して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「逃げ場を失った後で、にゅりにゅりズリズリ乳房でペニス全体をこねくりま\nわす……。あっ……♪　磨き上げて、いく……。んっ、んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「一方的に、自分の最も大切な部分をなぶられる気分はどうですか？　っんっ\n、人体の急所を、捕獲されてネチネチニチニチ刺激されて……フフフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「オイルと精液とでいやらしく照り輝いた男根……。艦賞しているだけで、サ\nディスティックな気持ちになりますね。どうぞ、存分に喘いでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「女の子のように、感じるところを弄り回されて……情けない声を漏らしてく\nださいね？　ここには他に誰もいません。私だけが見ていますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……部下に、水着の私にオチンポをズられて気持ち良くなっているところ…\n…たくさん見せてください。っ……ふ……♪　何もとりつくろわず♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もっとして、もっと苛めて、と子どものように泣きわめきなさい……♪　そ\nうしたら、私は……私は、感動して、同時に快感を覚えます♪　んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　ゼラチンのようにブリュブリュとした精液が、私の胸に絡み\nついてくる……♪　しつこくて、臭くて、卑猥な香り……ああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こんなに触れていたら、次第に私の身体にしみこんで……あなたの臭いがこ\nびりついてしまいます、ね……。その責任をとってください……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「責任をもって、この極太オチンポで私の胸をグチュグチュするんですよ……\n♪　グチュ、グチュ♪　グチュ、グチュ♪　もっと音をたてて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「腰を振りなさい！　ぐっちゅっ、ぐちゅ、ぐっちゅぐちゅっ♪　私もそれに\nこたえてニュルニュル、にゅるにゅる……。あ♪　膨張しましたよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あらあら……。また射精欲求に捕らわれているんですか？　どうしようもな\nい淫乱チンポですね。本能に忠実すぎます。でも、いい……ですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええっ、出したければどうぞ……♪　精液が尿道口から飛び出す瞬間から、\n私の胸に……放物線を描いて着地するところまで全て監視しています♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「部下の私に見られながら、お外でしーしーしましょうね……♪　くすくすっ\n、恥ずかしい人……。射精大好きな隊長の射精を見守ってあげますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「３、２、１……ほらっ！　今ですよっ……！　我慢の足らないドスケベペニ\nスから、白い精液……噴水のように発射しなさい！　これは命令ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……ふぅううっ♪　ううっ……んんんっ♪　んんッんん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あっあぁっ、ああああっ……♪　良くできましたね、上手にピュッピュでき\nましたねぇ……隊長……！　素晴らしいですよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ、ええっ……！　どんどん送りこんで、ください……ふぁああっ♪　私\nの胸の谷間、胸の間にビチュビチュ精液を解き放つのですっ！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私もぉ……ッ、私も協力、しますから……っ♪　胸を、胸を押し潰して、ひ\nしゃげさせながら……ぐにぐに肉竿を刺激して搾ります！　ん、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あっ、あああ……♪　あああああ……っ♪　出てる、出てる、出ています…\n…！　あふっ！　乳房を孕ませんとするくらい……あああああ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ンッ！　ふぅっ、ふぅうううっ……！　お、終わり……ましたか？　ああ…\n…！　垂れてしまいそう、乳首にまで白濁液が絡まって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「二度目とは思えないこの量……嬉しいです……♪　質も良いですよ、肌触り\nでわかります……。なんと男らしい、理想の精液でしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ここまで粘着力の強い、臭い種汁であれば……膣内に射精していたら確実に\n妊娠してしまっていたでしょうね……。胸ですら、ゾクゾクしますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あ！　ま、まだ動かないでください。じっくりと精液の臭いを嗅いで……は\nぁああ♪　この感触を楽しみたいんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……何を照れているんですか。知っているでしょう。私が、あなたが思って\nいるよりずっと……。あなたの全てを、体液ごと愛していることなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あっ！？　何をするんですっ……私の胸から逃げ出して……！　もうっ、勝\n手な真似を……！　んっあっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ンぷ……！　うぁ、むぅ……っ、うう……っ？　か、……顔に？　あっ、だ\nめ……駄目です、無駄にするなんて……。ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「せめて、口についた分だけでも……んっ、飛び込んできた量だけでも飲ませ\nていただきますから……！　っぁふ……♪　れろ……ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……ぅ……お、オイルと混じって強烈な味、れふ……。あっ♪　そんなに顔\nにかけたら……まだらに日焼けしてしまい、ます。だめ、だ……めぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んぁっあっぁっあっ……♪　もう……！　……え？　文句を言いながらも嬉\nしそう……ですか？　そ、それは……。あ、あなたのものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それを浴びれば当然……。な、何を言わせるんですっ……！　顔射をしても\nらったら笑みが浮かぶのは、女として普通の反応ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「わ……私がおかしいわけではありません……。それに、出した側が言うこと\nではないでしょう、ここまでベッタリ白濁を塗り付けておいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フフ……でも、面白かったんじゃないですか？　いつも戦場では、無表情で\n冷たい顔をしている私を……思う存分種汁で汚せたのですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「たまにはそうやって、ハメを外していきませんと……。最近のあなたは、隊\n長は働きすぎでしたから。私なりのケアをさせていただきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「少しは……気が楽になりましたか？　いえ、いいのです。お役に立てるなら\nパイズリくらい……毎日だってしてもいいくらいなんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}