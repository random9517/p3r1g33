		{"command":[ "PLAYVOICE", "v2_261_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、は、はい……特に、乳首が……すごく、感じやすくな\nってて……また、して欲しいかもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ、んんっ……！　おねだり……ですか……う、上手くできるか分かりませ\nんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お願いします……私の……興奮してビンビンに、飛び出た……エッチな乳首\nを……先輩の指でいっぱい弄ってください……」", "NORMAL" ]},
