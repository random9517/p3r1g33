		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ふぁ、はぁ……あぁ……出し終わりましたか……？　は、はい……お疲れさ\nまでした……」", "NORMAL" ]},
