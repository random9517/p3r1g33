		{"command":[ "PLAYVOICE", "v2_261_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……熱くなってます……あ……膨らんでる……まだ大きくなるん\nですね……これ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「上手くできてるんですか……？　は、はい……よかったです。この調子で…\n…するんですね？　はい……」", "NORMAL" ]},
