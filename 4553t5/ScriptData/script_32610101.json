		{"command":[ "PLAYVOICE", "v2_261_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「今の状態で舐める……は、はい……失礼、します……ぴちゃ……んちゅぷっ\n、ちゅぱっ、れろ、ぺろっ、ちゅぷぅぅ……」", "NORMAL" ]},
