		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「分かってきたかも知れません……気持ちいい感じ……はぁ、んっ、おちんち\nんも……そうなんですね……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
