		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そういうわけじゃない……ほっ……あの、でしたら……そのどうして……？\n　えっ……トレーニング、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103102" ]},
