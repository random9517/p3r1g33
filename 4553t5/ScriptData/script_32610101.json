		{"command":[ "SETIMAGE", "0", "still_00026101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「やっぱり、その……おちんちんって……おっぱいで包み込むと……気持ちい\nいものなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「私は……んっ、その……硬いのが当たってる感じは分かるんですけど……よ\nく、分からなくて……」", "NORMAL" ]},
