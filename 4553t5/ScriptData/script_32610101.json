		{"command":[ "SETIMAGE", "0", "still_00026101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はぁんむ……んちゅ……確かに……さっきより、思い切って……おちんちん\n……舐められてる感じが、します……んちゅぷ、ぴちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
