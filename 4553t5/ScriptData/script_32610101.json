		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁ、私……いやらしいの……はぁ、でも、先輩のおちんちんがす\nごいからぁ……じゅぽっ、じゅぷっ、んちゅぷっ……」", "NORMAL" ]},
