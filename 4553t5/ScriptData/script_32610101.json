		{"command":[ "PLAYVOICE", "v2_261_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「一緒に動かすの……難しいですね、んっ、片方に意識を持っていかれると…\n…すぐ、動きが止まっちゃって……ん、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「でも、んっ、とにかく……おっぱいだけは、あっ、ふっ、動かしておけば…\n…んんっ、少しずつ……気持ちよくなっていく感じ……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……んっ、ふぁ……あぁ……ぬるって……滑ってます……私の唾液\nと汗が……おっぱいとおちんちんに絡んで……ぴちゃ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はぁっ……ちゅぱっ……えっ、私の……根暗な性格の原因が分かった……？\n　ほ、本当ですか？　どういう理由で……ち、乳首……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「私の……先端が陥没してるから……？　気持ちが前に出て、こない……そ、\nそんなこと……言われましても……あひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……んんっ、ち、乳首ぃ……あっ、そんな、コリコリって……\nあっ、あぅんっ、されたらっ……はぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「や、やだ……からだ、あっ……ムズムズします……はぅっ、んんっ！　あぁ\nっ、乳首……乳輪のとこっ……くすぐったくてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
