		{"command":[ "PLAYVOICE", "v2_261_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「私、上手く……できてましたか？　は、はい……よかったです。えへへ、ち\nょっとだけ自信がついたかも知れません……」", "NORMAL" ]},
