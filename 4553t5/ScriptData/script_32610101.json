		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「力の加減はもうちょっと強く……はい……んっ、これで、いかが……ですか\n……？　はぁっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「私の……お、おっぱいで……ちゃんと、感じて……くれてるんですね……な\nんだか、少し……嬉しい、かも……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んっ、あふ……んんっ……そろそろ……次の段階？　はい……ど、どうすれ\nば……えと、舌で、おちんちんを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「こ、こうですか？　んっ、ぴちゃ……れる……れろ、ちゅぱ……んちゅっ、\nれろ……えろっ……れろぉ、れりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ……ふう……変な味……んっ、ちゅ……少ししょっぱくて……鼻がツンと\nして……ぴちゃ……これを濡らして、いくんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
