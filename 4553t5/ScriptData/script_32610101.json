		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は、ひっ……あっ……はいっ、舐めますっ……んくぷっ、はぷっ、んむっ、\nじゅぷっ、ぴちゃ、んふっ、んりゅっ、れる……」", "NORMAL" ]},
