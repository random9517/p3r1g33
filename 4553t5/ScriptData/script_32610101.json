		{"command":[ "SETIMAGE", "0", "still_00026101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ふぁ……エッチな舐め方しちゃってる……おっぱいズリズリしながら、一生\n懸命おちんちんに吸い付いて……乳首、コリコリでぇ……」", "NORMAL" ]},
