{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},		
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出して、いったい何の用？　私、早く任務に行きたいん\nだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「えっ……オチンポが腫れて人前に出られないから、助けて欲しい？　オチン\nポって、腫れたりするものなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「人が困ってるのに、どうしてそんなにも冷静なのかって言われても……そう\nいった知識は、本で読んだくらいしかなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと、そんなに暴れないで！　分かった、分かったから！　オチ\nンポが腫れて、すごくつらいのね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「まったく……それで、私にどうして欲しいの？　言っておくけど、あんまり\n無茶な要求には応えられないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、ふっ……えっと、おっぱいでオチンポを挟んで欲しいって言\nわれたけど、これであってるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026801_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「もっと強く、オチンポを挟み込んで欲しいの？　わ、わかったわ……んっ、\nしょ……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁっ……なに、これ……すごく熱い……それに、太くて、ヘンなニオイも\nするっ……あっ、ぐっ、んくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「このままおっぱいを上下に擦って、先端から白い液体が出れば、腫れが治ま\nるのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あふっ、んんっ……こういうことはしたことがないから、よく分からなくて\n……でも、隊長がそう言うなら、そうなんでしょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「とにかく、おっぱいでゴシゴシしてあげるから……その、白い液体？　って\nいうのが出そうになったら、ちゃんと言ってちょうだい……ふっ、んふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、ふっ……んっ、あっあっ、はふっ、あひゅ……これ、擦れば擦\nるほど、熱くなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「それに、ビクビクって動いて……んんっ！　すごく苦しそう……本当に、腫\nれてしまっているのね……はっ、んぐっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ひゃ、あぁんっ！？　おっぱいの間で、オチンポが跳ねてっ……もしかして\n、痛かった！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい……もっと優しくするから……え？　今みたいに激しくし\nた方が、早く腫れが引くかも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「わかったわ……それなら、もっと激しく、おっぱいを上下に動かしてあげる\n……んっ、しょ……ふっ、んっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あぐっ……ふっ、あっ、あっ……うぐっ、んはぁっ……あっ、ひっあっ……\nんっ、はぁぁっ……うぐっ、ふっ、はふっ……んっ、あっ、はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁっ！？　オ、オチンポがさっきよりも、大きくなってきてる…\n…本当に、大丈夫なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「えっと……おっぱいでシコシコしながら、舌で先端を舐めれば、白い液体が\n出やすくなるの？　そ、そうなのね。なら、そうしてあげるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「アイスを舐めるときみたいに、ペロペロすればいいのね……んっ、分かった\nわ……いっぱい、舐めてあげるから……んっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んちゅ……ぺろっ、れろっ……ちゅ、ぢゅ……んっ、ちゅぱっ……ぴちゅ、\nじゅ……んぷっ、ちゅぱっ……れぢゅ、ぢゅちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ、んぱぁっ……私がアイスを舐めるときって、こんな感じだけど……ど\n、どうかしら？　何かおかしなところはない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あの……き、亀頭？　っていうところと、先端の割れ目のところを……舌で\nグリグリしたり、ベロベロしたりすればいいのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「よく分からないけど、イメージはできるから……この赤くなってて、デコボ\nコしてるところを、舐めまわせばいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「そんなに難しいことじゃないわ……んっ、ちゅぷっ……ちゅぱっ、ぢゅる…\n…んっ、ちゅ、ちゅ……じゅぶっ、ちゅぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「れろれろっ、ちゅ……じゅぶっ、ちゅくっ……んっ、ちゅ、ぱっ！　ぴちゅ\n、ぢゅぶるっ……じゅ、んぶっ、ちゅぶっ……ちゅ、じゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んぷっ、ちゅぶぶっ……オチンポの先端から、ヌルヌルした汁が出てる……\nふぇ？　もっと激しく舐めて欲しいの？　別に、いいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あんまり強くしたら、痛いんじゃないかと思ったのだけど……強い刺激の方\nが、腫れが引きやすいのね……じゅぶ、ぢゅぴっ……んっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんなに腫れてるのに、刺激が欲しいだなんて……オチンポって、ヘンなの\nね……ちゅぱっ、くりゅ！　ずちゅ、んっ、ちゅぱっ、んじゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ぢゅぶぶっ、ぴちゅ、んちゅ！　ずっ、ぷちゅ……れろっ、ぢゅろっ、ちゅ\nぱっ、んぱっ！　ぴちゃ、ぢゅぴっ……ぢゅ、ぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　オチンポが谷間で跳ねまくってるっ……んぢゅ、ちゅちゅ\n！　じゅ、あぷっ、れろれろっ……じゅぶぶ、ちゅぶ、ずっぷぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ……んぷっ、じゅぶぶっ！　おっぱいも、もっと動かさないとぉ……れ\nぢゅぢゅ、じゅ、んぶっ！　くちゅ、じゅぞぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「うぷっ、ぢゅぶっ！　割れ目のところから、ずっと透明な汁が出続けてる…\n…ね、ねえ。本当に大丈夫なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぱっ！　ちゅちゅ、れろっ！　んっ、んぐぅっ！？　オチンポのビク\nビクが、もっと激しく……いったい、どうなって……んぢゅうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！？　ちゅ、んぷっ！　れろっ、ぢゅぶっ！　やっ、なに……オ\nチンポの奥から、何かこみ上げてきてるっ……ちゅ、くちゅるうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あぶぅぅっ！？　んぢゅるっ、ちゅばっ、じゅぶぶっ！？　あっ、やっ！　\nな、なにこれぇっ！？　白いのが、びゅーびゅー出てるっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「これが腫れの原因なのっ！？　えっ、ちょ……私の口に入ってきてっ……ぢ\nゅぶっ、じゅぐっ！　んっ、あぐっ、ぢゅぶぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んぐっ、んぐぐっ！？　これ、どうすれば……！？　ちゅ、あぶっ！？　な\n、なに！？　そのまま口に含みながら、オチンポを舐めればいいの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「わ、わかったわ！　隊長の言う通りにするから……んちゅぷっ！　ぢゅ、ぐ\nぶっ！　ちゅちゅ、じゅ！　ぴちゅ、じゅぶぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んじゅるっ……れろっ、ぢゅぶぶっ！　うっ、おぶっ！？　ぢゅ、じゅぼっ\n！　ちゅ、ちゅじゅ、ぴちゅるうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、はぁぁぁっ……ろうにか、白い液体は止まったみひゃいね…\n…んっ、ぐちゅ……うぶっ、うべぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「口の中が……ドロドロらわ……そりぇに、しゅっごく臭い……ね、ねえ……\nこりぇ、どうしゅればいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ふぇ……飲み込んれも、問題ないのね？　そ、そう……なりゃ、飲み込むけ\nろ……んっ、ちゅ、んぐっ……んくっ……ぐっ、うぐぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こくっ……ごくっ、ごっくん……うぇぇっ……苦くて、ひどい味がするわ…\n…こんなのが溜まっていたら、オチンポが腫れるのも納得ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ふぅ……とりあえず、白い液体は出たみたいだし、これで終わりに……え？\n　まだ、全部出し切ってないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「今度は、おっぱいでオチンポを搾るようにしながら、オチンポの先端を重点\n的に舐めて欲しいの？　うぅ……わ、分かったわ……んっ、ちゅく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぱっ……れろれろっ、じゅぶっ、れろぉ！　ぴちゅ、ずずっ、くちゅ\n、くりゅりゅ！　ずっ、んぷっ……ちゅ、ぷぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ、んぶっ……確かに、オチンポの中に白いのが残ってるわね……これを\n、搾り出せば……んっ、あっ！　ちゅば、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ぢゅぢゅるっ、じゅぶっ、ちゅばぁ……んちゅ、ぷちゅ、ぢゅっぷっ！　れ\nぢゅ、くちゅ、んちゅ、ちゅ……ちゅぱちゅぱっ、んべろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あぶっ、んぶぶっ……奥の方にあるのが、全然出てこないわ……もっと激し\nく舐めながら、おっぱいでシゴかないと……んふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んちゅるっ！　ちゅ、んぱっ！　ちゅばっ、じゅるるっ！　ぢゅろっ、れろ\nっ！　ぴちゅちゅ、ずっ、んぶぷっ！　ちゅちゅ、ちゅろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「じゅぞっ、ちゅろろっ！　んんっ！　白いのが、どんどん溢れてくるっ……\nこのまま、搾り尽くしてあげるわ……ちゅ、んぱぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あふぅ！？　やっ、あっ！　オチンポ動かさないでち\nょうだいっ！　舐めにくいじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ちゅちゅ、じゅ……私の舌とおっぱいが気持ちいいから、自然とオチンポが\n動くの？　そ、そう……気持ちいいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「隊長に褒められるのは……すごく嬉しいというか……胸の中で、幸せな気持\nちが膨らんでいくの……んっ、ちゅちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるっ……ヘ、ヘンなことを言ってしまったわね……とりあえず、\n今は隊長のオチンポの腫れを引かせないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「れろろっ、んぱっ、ちゅぶっ、んちゅ！　ちゅぱちゅぱっ……ずっ、れろろ\nっ！　ぐりゅ、ずりゅ！　ずぶぶっ、じゅ、んぱっ！　ちゅ、ぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ぢゅろっ、れろぢゅ……んっ、んっ！　また、オチンポがビクビクしてきて\nる……透明な汁も、どんどん溢れてきてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ずずっ、ぢゅずぅ！　んっ、ぱっ！　これ、さっきみたいに白いのが出るっ\nて合図よね？　あの臭くてドロドロしたのが、びゅーって出るのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あぷっ、ぢゅぶぶっ！　んっ、ぢゅぽっ！　出して、いいから……またさっ\nきみたいに、いっぱい出して！　んちゅちゅ、ちゅ！　んっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ぐぶっ！？　ぢゅ、ぐぶふぅっ！？　あぐっ、ちゅ、ぼっ！　おぶっ、じゅ\nるるっ！　んりゅ、ちゅぱぱぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ずぶっ、じゅぱぁっ！　また白いのが、口の中にぃ！　ぐぐぐっ、ぢゅ、じ\nゅぞっ！　ちゅ、じゅばっ、ずぶぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「え、えっと……まずは、口で受け止めて……じゅぞぞっ、ぢゅ、ぞぞっ！　\nちゅ、んぐっ、ちゅ！　ぴちゃ、ぷちゅるっ、ちゅぶぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あぶっ、んぐぶっ！　白いのが出続けてる間も……オチンポを舐めて……お\n、おっぱいで、シゴいてぇっ……ちゅ、んぶぶっ！　じゅろっ、れろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、れろぉ！　ぐぷっ、んっぷっ！　ちゅぱちゅぱっ、じゅ、ぞぞっ\n！　れろっ、ぺちゅ、にちゅるっ！　ぐちゅ、ずりゅうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んぅ、んぱぁぁっ……あぶっ、くぷっ……うべぇ……口にょ中……しゅごく\n気持ち悪いぃ……早く、飲み込まにゃいとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ぢゅぐっ、ちゅぐっ……ごくっ、んっ……ぢゅ、ぢゅぞぞっ……んぐっ、ん\nぐっ……ごっくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あふっ、はぁ、はぁ……んっ、あはぁぁぁっ……まだドロドロしたのが残っ\nているけど、気持ち悪さはかなり減ったわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「えっと、どうかしら？　オチンポの腫れは、治まった？　それとも、まだ白\nいのが出てきそうな感じかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「どうせなら、最後まで付き合うわ……隊長が苦しむ姿を見たくないし……何\nより、隊長の助けになりたいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「きゃあぁっ！？　ちょ、ちょっと！　どこに出して……あぶっ、んっ！　あ\nぐっ、んんぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんなの聞いてないわっ……と、止めてっ！　この白いの、一旦止めてちょ\nうだいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「そ、そうだわ！　おっぱいを緩めれば、勢いも弱まるはず……くっ、ふぐっ\n！　あっ、あっ！　あぐっ、んくぅ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁっ！？　な、なんで！？　おっぱい緩めたのに、白いがびゅるびゅ\nる出てくるわ！　もうシコシコもしてないのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「臭いもすごくて……頭がクラクラするっ……ほ、本当にやめっ……あっ、あ\nっ！　んふっ、くっ！　あっ、あはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……こんなにドロドロにして、どうしてくれるの？　すごく迷\n惑なんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「な、なに？　私のおっぱいと舌使いが気持ちよかったから、オチンポから白\nいのが止まらなかったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「そ、そう……それなら、仕方ないわね。隊長のオチンポの腫れも引いてきた\nみたいだし、良かったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「えっと……また腫れたときは、今みたいにおっぱいでシゴきながら、オチン\nポをペロペロして欲しいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「隊長がそう望むなら……応えてあげるのも、やぶさかじゃないわ。またオチ\nンポが腫れたら、声をかけてちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}		
	]
