{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「結婚！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「結婚……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「結婚ねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだあ、揃いも揃って」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "何か新しい任務があるというから、顔を出してみれば。揃いも揃ってなんだ、\n口々に『結婚』って。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「カツマ、ひょっとして何も聞いていないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「所詮は下僕ね。重要な作戦の子細を伝えられていないなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私たち選ばれし者だけが、今度の作戦にはふさわしいのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「悪かったなあ。なんだよ、作戦と結婚に関係があるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それは……っ、その……意識せざるを得ない、というだけの話で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "意識？　ますますなんだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「長官からの命令でね。私たち３人、ウェディングドレスを着ろって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ……？　ウェディングドレスって、あの、花嫁が着る？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ、だから結婚？　いやしかし？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どこぞの誰かと政略結婚でもしろっていうのか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そんなわけないでしょ！　襲来者（インベーダー）に見せ付けてやるのよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ？？？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あいつらに見せ付けて……どうすんだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「長官が仰るには、何も拳で語り合うばかりが戦いを終わらせる手段ではない\n、平和的な交渉も試みるべきだ、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「知的生命体なら必ず、その……愛という本能が備わっているはずだから、っ\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……愛、ねえ。それで、ウェディングドレス？　奴等を誘惑でもしろ\nって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「色仕掛けが通じるならとっくに、って気もするが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まったくね。カツマさんじゃあるまいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや俺も別に、こいつらのウェディングドレス姿に鼻の下を伸ばしたりはしな\nい……よなあ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そういえばこの前、妙な光と音で奴等とコンタクトを取ろうとしたよな\n。あれも失敗してたが」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あったわねえ。わけのわからないメロディを流している内に、ドカンと一発\n喰らってたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「私たちにも理解できないシグナルとリズムでしたから、襲来者（インベーダ\nー）には尚更意味不明だったのでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920005" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それなのに、また、ですものね。……長官、何か悪い物でも食べたのかしら\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「圧力もあったみたいですよ。反戦団体とスポンサーからの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「はい。『襲来者（インベーダー）と共存し隊』や『処分より捕獲を推進する\n党』といった、政党や市民活動ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920006" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「平和的に解決しろなんて、絵空事だと思うのだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "めんどくさい、世界の平和を守る、正義の味方ってやつは。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ましてや俺たちなんてそもそも、悪の組織だぞ？　そこまで義理立てしないと\nいかんのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ、いかんのか。何しろスポンサー様だから。世の中、金を持っている奴が最\n強なんだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とはいえ、同じ言葉を話す俺たちだって、正義と悪、男と女じゃ、相互理解は\n難しいっていうのになあ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「マンマ・ミーア！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「学園長！？　いきなりなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「知りませんか？　結婚を祝福する、有り難い言葉です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それをなぜ今、唐突に叫んで現れたのか、というのが問題なんだが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「今度の作戦が上手くいくよう願を掛けるには、うってつけの言葉だと思いま\nせんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920003" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「私も、もう何年か若ければ、率先して参加したいところなのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やめてくれ。いろんな意味で打撃力が高すぎる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「学園長は、今度の作戦に賛成なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「もちろんです。良い作戦だと思いますよ、『花嫁衣裳大作戦！　ドレスｄｅ\nデート』は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920005" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな作戦名だったのか。なんか、レトロな雰囲気が香ばしく漂っているなお\nい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）も、我々の文化には興味があるはずです。戦略・戦\n術的に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「相手の思考や文化を学ぶことで、思わぬ弱点や隙を見いだせるものですから\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ならばあちらがこちらへ関心をもったところで、逆に懐柔してしまおうとい\nう発想も十分理に適ったものかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それにですよ。自分の色気ひとつで敵を落とせるなら、悪の組織としては誉\nれでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ハニートラップのひとつもこなしてみせてこそ、女幹部たり得るのではあり\nませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「た、確かに、身体を武器とせよという修行もありますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920007" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）を口説き落とすのが目的ではないと思うのですけど\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021920008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「奴等と結婚させられるなんて、まっぴらご免よ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021920008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「私も、結婚するなら……その、普通にお付き合いから始めたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920008" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういう問題でもないだろうが――。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「と、敵襲か？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「学園長、お話はここまで。仕事ができました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何をしている下僕！　さっさと出撃するわよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「この際、敵が救いの神」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021920009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こいつら、揃いも揃って、この場から逃げ出す口実だと判断したな？　瞬時に\n変身しやがって。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、お仕事には違いないな、仕方ない。いくぞ！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はい、行ってらっしゃい。ただし――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920011" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「大事なのは愛――マンマ・ミーアの精神です。くれぐれもそれを忘れないよ\nうに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020021920012" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}