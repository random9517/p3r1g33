		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "用意されたセットに登場する明日楽。そこに桃花が演じるアクレイジョーがや\nってくる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002803_01", "0", "CENTER", "0" ]},
