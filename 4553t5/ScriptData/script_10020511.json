		{"command":[ "SETTEXT", "出番が来るまでは俺も観劇でもしているかと、客席の方へとやってきた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "練習といっても、俺は俺が出てくるラストシーンの練習しか参加していないか\nら、冒頭は台本上でしか知らない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「ああーっ、もうこんな時間だー。悪の女幹部が始まってしまうー」", "NORMAL" ]},
