		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人は本当に最後の方しか練習に参加していませんでしたからなぁ」", "NORMAL" ]},
