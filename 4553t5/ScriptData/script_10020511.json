		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁーっ！　いぃぃやぁぁっ！　んぁああぁぁっ！　やぁぁっ！　\nだぁぁっ！　たーすーけー！」", "NORMAL" ]},
