		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁっ！　ああぁっ！　くはっ、はぁあああぁぁぁっ！　あああっ、\nああぁぁあぁっ！！」", "NORMAL" ]},
