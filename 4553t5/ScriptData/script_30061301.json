		{"command":[ "SETIMAGE", "0", "still_00000613_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんの身体に、たくさんマーキングされてるぅ～。こんなに熱い\nのかけられたら、火傷しちゃいそうだわっ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303302" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あはぁぁんっ！　まだ出てるぅ～♪　２回目なのに、すっごい量……\nさすが、ダイヤナちゃんが見込んだだけのことはあるわねっ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303303" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あはぁぁんっ……射精が終わっても、まだビクビクしてる\nわぁ……このオチンチンを見てると、ヘンな気持ちになってきちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303304" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もっとご奉仕したいって気持ちが、溢れて止まらないのぉ……イッたばかり\nだけど、もっとシコシコしていいかしらぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303305" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほらっ……さっきもオチンチンの奥に、ザーメン残ってたでしょ～？　それ\nもぜーんぶ、搾り出した方がいいと思うの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303306" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「大丈夫よぉ～。優しく、丁寧にシゴいてあげるからっ……んっ、あふっ！　\nあっ、ふくっ……あっ、んふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303307" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁぁんっ♪　搾れば搾るほど、おしっこの穴から精子が出て来るぅ♪　ん\nっ、はぁぁっ……ニオイもすごく濃くて、素敵よぉ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303308" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちゃんと綺麗に、お掃除してあげるっ……んっ、ちゅ……れろっ、ちゅぱっ\n……ちゅちゅ、ぴちゅ……れぢゅるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_14" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱぁっ……あなたが望むなら、いつでもご奉仕してあげる♪　ム\nラムラしたら、ダイヤナちゃんを呼んでちょうだいねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303310" ]},
		{"command":[ "WAITINPUT" ]},
