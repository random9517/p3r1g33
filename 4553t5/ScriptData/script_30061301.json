{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　ダイヤナちゃんに呼び出されて、びっくりしているみたいだけ\nど……別に怒ってるワケじゃないから、安心してちょうだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あのね、今のダイヤナちゃんには、願いを叶えるスター・クリスタルの力が\nあるけど……愛情は力に頼らないで、自分でどうにかするものだと思うの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303102" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だから、あなたにいっぱいご奉仕して、ダイヤナちゃんのことを好きになっ\nてもらおうと思って♪　えいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……すっごく大きなオチンチン。ダイヤナちゃんのおっぱいから、\nハミでちゃってるぅ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303104" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あらぁ？　おっぱいに挟んでるだけなのに、イッちゃいそうなのぉ？　うふ\nふっ♪　感じてくれて、すっごく嬉しいわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303105" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも、まだご奉仕は始まったばかりよ。オチンチン、い～っぱい気持ちよく\nしてあげるからぁ……ダイヤナちゃんに、身を委ねてちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あふっ、んくっ……はぁ、あっ、あはぁっ……どうかしらぁ。ダイヤナちゃ\nんのおっぱい、気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303107" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたのためなら、おっぱいでオチンチンをスリスリするの、全然イヤじゃ\nないのっ……むしろ、もっとしてあげたいのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303108" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こうやって、上下にシコシコしたりぃ……おっぱいをグニグニって、いやら\nしく動かしたりしてぇ……んっ、あっ、あはぁぁぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303109" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、んくぅ！　オチンチンが谷間で、小さくビクビクって跳ねてる\nぅ♪　ダイヤナちゃんのおっぱいで、気持ちよくなってくれてるのねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「感じてくれて、すっごく嬉しいわ♪　もっともっと、ご奉仕したくなっちゃ\nう♪　んっ、はっ……あくっ、んくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303111" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はふっ、んっ……あっ、あっ♪　ひゃ、あんんっ！　くっ、んっ……あっあ\nっ、んふっ♪　んっ……んっ、あはぁぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「擦れば擦るほど、オチンチンがヒクついてくるぅ……それに、いやらしいニ\nオイも拡がってきて……あっはぁぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303113" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁんっ♪　オチンチンの先っぽから、エッチなお汁が出てきてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_09" ]},		
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのこと、お嫁さんにしてくれるっていうならぁ……こ～んな\nことも、してあげるんだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303115" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……ぺろっ、れろっ……んっ、ちゅぱっ……れろっ、えろぉ\n……ぢゅ、じゅぐっ、ちゅるっ……ちゅぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ぴちゅるっ……ちゅ、ぱっ！　うふふっ♪　オチンチン、もっと硬\nくなってきたわね。ダイヤナちゃんの舌、気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303117" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……あなたの感じてる顔を見ていると、興奮してきちゃうっ……も\nっとご奉仕したくなっちゃうっ……んちゅ、ちゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303118" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「くちゅるっ、ぢゅぷっ……れぢゅ、じゅぶっ……ぴちゃ、ぷちゅる、ちゅち\nゅ……んちゅ、じゅぱっ、ちゅ、ぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「じゅる、ぢゅぢゅ……んぷっ……この透明でエッチな先走りのお汁……ペロ\nペロして、舐めとってあげるっ……んっ、ちゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303120" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちゅるちゅ、じゅぶっ……れろれろっ、ぴちゃっ、ぷちゅるっ♪　ちゅく、\nじゅ……ぴちゃ、ぷちゃぁ……んっ、じゅ、んぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303121" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あふぅ……舐めても舐めても、どんどん溢れてくるぅ～……ダイヤナちゃん\nのフェラチオ、気に入ってくれたのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……気に入ってくれて、すっごく嬉しいわぁ♪　お礼にぃ～……\nもぉ～っと激しく、ペロペロしてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303123" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅるるっ！　ぴちゅ、ちゅくぅ！　んっ、ちゅ……ちゅ、ぢゅ\nぢゅ！　ちゅるっ……れろっ、ぺろっ……んちゅぷぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_09" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「くじゅ、ぢゅ……あはぁぁっ……オチンチン、ガチガチに勃起してるぅ♪　\nダメぇ……こんなの、もっとご奉仕したくなっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303125" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぢゅるっ！　ちゅ、くちゅ！　んっ、んっ！　ちゅぱっ、れろれろっ！　\nぢゅ、じゅぷっ、ぴちゅるっ、れじゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ！　どうかしらぁ～？　おっぱいと舌で同時にご奉仕される\nの、たまらないでしょ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303127" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「好きなだけ、感じてくれていいからね♪　先っぽだけじゃなくてぇ……カリ\nのところも、ペロペロしてあげるから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「くちゅりゅ、ぢゅ、ちゅぱっ！　んちゅ、れぷっ、じゅぶっ！　ちゅ、ぴち\nゃ、べろっ、ぢゅぱっ……ちゅちゅ、んちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303129" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンを舐めたり、キスしたりしてると……ダイヤナちゃんも感じてき\nちゃうっ♪　んっ、れぷっ、じゅぶぶっ……ちゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303130" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁっ……おしっこの穴も、ホジホジしてあげるわね♪　んっ、く\nりゅ、ぢゅるるっ……れろっ、じゅ、ちゅぱっ、じゅぽっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぷっ、ちゅちゅ……くっ、ぢゅ！　れぷっ、じゅぶっ……ぴちゃ、んっ、\nんんっ♪　ぢゅ、ぽっ……ぴちゃ、ぷちゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303132" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　ぢゅ、んぷぅ♪　オチンチンがビクビクしてるぅ♪　もう\n、出ちゃいそうなのぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303133" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いつでも、好きなときに出していいからぁ……ダイヤナちゃんの顔でも胸で\nも、出したいところに、ザーメンびゅーびゅーしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303134" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぶっ！　ちゅぱっ、れろっ！　んっ、あっ、あぁ！　オチンチン\nが激しくヒクついて……あぁん♪　きてっ！　精子、びゅーってしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_09" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁぁんっ！？　んっ、ちゅくっ！　あんっ、すごぉいっ！　こんなザー\nメン出してくれるなんてぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのおっぱいやおクチに、いっぱい熱いのかけてくれるなんて\nっ……はぁ、んっ、あっあっ！　んふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303137" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「射精中も、おっぱいシコシコしながら、ペロペロしてあげるっ♪　溜まって\nるの、ぜーんぶ出しちゃっていいからねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_12" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷぷっ、ちゅ、ぱっ！　れろっ、ちゅく……んっ、あふっ、ちゅ\n、ぢゅ、じゅぷっ……あふっ、あくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303139" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら、精子のニオイと感触だけっでイッちゃうぅ♪　あっあ\nっ、んふっ、くっ……んくぅぅぅ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303140" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……こんなにたくさん出してくれるなんてぇ～。ダイヤナちゃん\nのおっぱい、そんなに気持ちよかったの～？♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_10" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃっ♪　オチンチンが、またビクッてしたぁ～♪　うふふ。まだ出したい\nって、言ってるみた～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303202" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ねぇ～。どうして欲しい～？　もっとオチンチン、気持ちよぉ～くして欲し\nくなぁ～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303203" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのこと、好きになってくれたらぁ～……さっきよりも激しく\n、オチンチンをシコシコ、ペロペロしてあげちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303204" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁんっ♪　オチンチンで返事しないでぇ♪　もぉ～、ちゃんと言葉で言\nって欲しいのに……まぁ、いいけどねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303205" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、もう１回オチンチン気持ちよぉ～くしてあげる♪　気持ちよす\nぎて、倒れても知らないからぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303206" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ、れろっ、ちゅぷぷっ！　ぴちゅ、ぢゅぴっ……ぴちゃ、れろっ\n、えろぉ！　ちゅちゅ、んっ、ちゅぱっ、ちゅくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_11" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅぢゅ……んぷっ！　うふふ♪　最初からおっぱいシコシコし\nてぇ～、オチンチン、ナメナメしてあげちゃうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303208" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「我慢なんてしなくていいのよぉ～。気持ちよかったら、声を出して喘いでも\nいいんだからねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303209" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　おしっこが出るところも、舌でホジホジしてあげちゃうんだか\nらっ～♪　んちゅ、くりゅ……ちゅ、くちゅ、ぐりゅうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303210" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「じゅぐぐっ、れぢゅ、じゅぱっ！　んっ……ぢゅ、ぷっ！　ぢゅぶぶっ、ず\nずっ、れろれろっ、ぐりゅ！　ずぷっ、ちゅ、ぱっ！　んぷぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_12" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁん♪　おしっこの穴の奥に、まだ精子が残ってるわぁ～。これも\nぜ～んぶ、ホジり出してあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303212" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぢゅぶぶっ！　ぐっ、ちゅぷっ！　んちゅ、ぢゅく、ちゅぱぁっ！　んっ、\nんっ！　ちゅちゅ、ぷちゅ……れろっ、ぺろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_11" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぱっ！　舌だと奥の奥まで、届かないわぁ～。これはもっと、\nおっぱいでシゴいてぇ～……オチンチンを搾り上げるしかないかなぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303214" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんんっ！　れちゅ、んふっ、んっ、ぢゅぶぅ！　くりゅ、ずりゅりゅ！　\nにちゅ、ぴちゅ、ぷっちゅ！　ちゅぱちゅぱっ、んっ、くりゅりゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_13" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ！　ザーメンに混じって、また先走りのお汁が、たぁ～くさん出\nてきてるぅ～♪　オチンチン、すっごく気持ちいいのねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303216" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほらっ♪　我慢しないで、いっぱいダイヤナちゃんのご奉仕で感じてっ♪　\nれろれろっ、ぴちゅ、ぢゅぢゅ、んっ……ちゅぱっ、くちゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303217" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぷっ、ぢゅ、ぴちゃっ！　くっ、ちゅ、ぢゅぶぶっ！　んちゅ、ちゅぱっ\n！　ぴちゃ、ぶちゅ、れりゅじゅ！　じゅぱっ、んぱぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_12" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ♪　んふぅっ♪　またオチンチンがビクビクしてるぅ～。そろ\nそろ、イキそうなのねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303219" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「また好きなところに出してぇ～♪ダイヤナちゃんのこと大好きって気持ち\nザーメンで伝えてちょうだぁいっ♪ちゅぱっ、ちゅちゅ！ぴちゅるうぅぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、んちゅううぅっ♪　あっ、あっ！　熱いザーメンが、びゅーびゅー吹\nき出て、おっぱいにかかってるぅ♪", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303301" ]},
