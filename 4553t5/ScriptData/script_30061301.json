		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きゃあっ♪　また熱いザーメンが、顔にかかってきたぁ♪　あっ、んんっ！\n　あふっ、あっあっ！　んふぅ♪", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「濃いニオイが、いっぱい拡がってるぅ～♪　ダイヤナちゃんの顔が、あなた\nの精子まみれにされちゃってるわぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303402" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなの、ダイヤナちゃんはあなたのモノって言われてるみたい……あはぁ\nん♪　すっごく嬉しいわぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303403" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もっと出してっ♪　あなたのザーメンで、ダイヤナちゃんのこと、真っ白に\n染め上げて欲しいのぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303404" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ！　あっ、あっ！　まだ出てるっ……あはぁんっ♪　こんなの\n、ニオイでイッちゃいそうになるぅ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303405" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひゃふっ、んんっ！　あっあっあっ！　んふっ、ぐぐっ……あっ！　んっ、\nんくぅぅぅ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303406" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……顔に精子かけられながら、イクなんてぇ～……やっぱりダイヤ\nナちゃんたち、相性バッチリかもぉ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_01_16" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　オチンチン、まだまだ元気なままねぇ～。もしかして、出し足\nりないのぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303408" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「続きをして欲しいならぁ～……ダイヤナちゃんのことをどう思ってるのか、\nちゃんと言葉にして言ってちょうだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1303409" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そうしたら、フェラチオやパイズリだけじゃなくてぇ～……もぉ～っと気持\nちいいことも、してあげちゃうんだからぁ～♪」", "NORMAL" ]},
