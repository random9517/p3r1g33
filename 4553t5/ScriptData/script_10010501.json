		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まさか、あのルナテミスが偽物だったなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010008" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
