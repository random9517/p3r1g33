		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミス、お帰りー！　シロクマ姫の星って、どんな――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
