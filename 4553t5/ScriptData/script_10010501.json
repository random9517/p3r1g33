		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オボロか！　偽物は見つけたか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010016" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あちらです！　セレーナさんが追っていきました！」", "NORMAL" ]},
