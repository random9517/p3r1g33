		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見てわからなかったのか！？　まったく、これだけ毎日顔を合わせておきな\nがら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010015" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうりで、行動がおかしいと思ったぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！」", "NORMAL" ]},
