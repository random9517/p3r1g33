		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？　姫様？　どうかしたんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ただいまー！　みんな元気ー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105010002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナちゃん、お仕事がんばってきましたー！　みんなも一日がんばろうねっ\n♪　あははははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "な、なんだ……？　何が起こった……？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ル、ルナテミス……！？　だよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やだぁ、私に決まってるじゃないの。つきみさんったら、何言ってるの～？\n　ふふふふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「つきみ……さん！？　ルナテミスどうしちゃったの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　ルナテミス様が、大変……！　とっても変！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105010001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん……！　ダイヤナちゃん怖い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだな！　姫様、午後からは非番でいいですから！　とにかく、今す\nぐ医務室へ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ！　そうだ！　あたし、ちょっと用事を思い出しちゃったぁ！　ごめんね\n、みんな！　それから、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんすか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あとでね？　ちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010007" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0053" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "い、いきなりほっぺにキス！？　ルナテミスが！？　なんじゃそりゃっ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010105010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁああああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105010001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ル、ル、ルルルルルナテミス様……っ！　カカカカカカツマに何を……っ！\n　フヒ、フヒ、フヒヒヒヒヒヒッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105010002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_010" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カ、カグヤちゃん怖いっ！　目が怖いっ！　落ち着いて、ルナ様いないから\nっ！　もう行っちゃったからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105010004" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんなんだ……なんなんだ今の……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスが……ルナテミスが変だ！　いったい、ルナテミスに何が起こった\nんだ！？　まさか、出張先で変なモノでも――", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「大変だ、大変だ……大変だ大変だ！」", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010008" ]},

	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ルナテミス……っ！　よくもまたノコノコと……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010105010002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まさかまた、カツマに何かよからぬことをしようと……！　たとえ相手がル\nナテミス様でも私は私はわたわたわたわたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010105010003" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　まりあ姉ちゃん落ち着いて！　カグヤはバグらないで！\n　っていうか、二人とも目が怖い！　怖いよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい！　今ここに、私が来なかったか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010105010005" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うわあああ～～ん！　またルナテミスがおかしなこと言ってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010005" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「また！？　またということは、ここに私が来たんだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010010" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃ来てますよ！　っていうか、あんた自分のことを誰だと思ってるんで\nすか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「誰って、決まっている！　私がルナテミスだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちゃんとわかってるんじゃない！　ってことはつまり、ルナテミスはここに\n来てるってことだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010105010006" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だからそうじゃない！　私が来る前に、私が来なかったか、と聞いてるんだ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010012" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、来ましたって！　来て、さっき出てったばっかりじゃないですか！\n　それで戻ってきたんでしょ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「出ていった！？　出ていったのか！　それを早く言わんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010013" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、何言ってるんですか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このボケナスビ！　そいつは偽物だ！　追えーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010105010014" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
