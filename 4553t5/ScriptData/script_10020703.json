		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700001" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「フゥーッ、フゥーッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700001" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふたりとも一度落ち着いてくれ！　そもそも、そこのサメ女は本当に生徒を\n襲ってたのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「生徒を襲う？　アタイが？　んなことするわけねーだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700002" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「騙されるなカツマ。相手はサメだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700002" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや。少なくとも話ができる時点でただのサメじゃないだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "会話ができるってことは、もしかしたらこのサメがなにか知っているかもしれ\nない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あんた、名前は？　……っていうか、どこかで見たな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ん？　テメーは隊長じゃねーか。こんなチェーンソー女とつるんでなにして\nんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700003" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「誰がチェーンソー女だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700003" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「あぁん？　テメー以外のどこにいるって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700004" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあまあ落ち着け！　話が進まない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……チッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700005" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……すまない。頭に血が上っていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700004" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすがご主人。クセの強い女性の扱いは手慣れたもんですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こんなこと、手慣れたくない人生だった！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それで、お前は……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「マリッサだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700006" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マリッサ、なんでお前はこんなところに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああ、なーんか最近アタイの縄張りが荒らされてる気がしてね。見回りして\nたんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「縄張りを荒らされてる？　サメの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そうだ。そもそも人を襲うなんてするわけねーだろ。サメの縄張りを荒らす\nのはサメだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「本当か？　本当は民間人に手を出しているんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700005" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「してねーって！　同じこと説明させんなよ。腕だけじゃなく頭までポンコツ\nか？　あぁっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700009" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「言わせておけば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700006" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「血の気の多いやつらだなあ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "血気盛んすぎて手に負えない。逆に血の通ってない幽霊のほうがマシかもしれ\nねえ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……って、なんだ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不意に顔を上げると、校舎の中をスーツ姿の女性が駆けていくのが見えた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、今の見たか……って、ディアナ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "周りに確認しようとしたら、ディアナが単独で校舎の中へと突入していくとこ\nろだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「どうしたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113700001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、校舎に不審な人影が……ディアナが一人で中に……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「でも、ほかに誰もいないはずだよな？　ま、まま、まさか幽霊が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んなわけねーでしょうに。だいたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113700001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "兎子があきれてため息をつく。そのときだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0151" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "空間の裂け目が、兎子の背後に発生していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「兎子さん……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113700002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わ、わ、わわわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なんですか、みんなして青い顔して。まるで幽霊でもみたかのような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113700002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「幽霊なんかじゃない！　サメだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700007" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「サメ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113700003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "兎子が振り返ると、鋭い歯をギラリと光らせる、サメのバケモノ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さ、さ、ささささしゃしゃしゃしゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113700004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「シャメだーーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113700005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「こいつだな！　アタイの縄張りを荒らしてたのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_010113700010" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「初めて見るタイプのサメだが関係ない！　サメ、殺す！　覚悟しろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_010113700008" ]},
		{"command":[ "SETCHARA", "0", "char_00012701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "サメに真っ向勝負を挑むマリッサとスーザン。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ディアナのことも気になるが、まずはこのサメの相手をしてからだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}