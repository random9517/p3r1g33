{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええい、クソッ！　重い！　多い！　クソ面倒い！！　もっとペーパーレス\n化を推進しろってんだ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ご主人。あなたはいつもいつもいつもいつも不平不満ばかりですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……などと言い合いをしながら、俺はクソ大量の書類を抱えて、冴島長官の元\nにやってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おーい、冴島長官。書類、提出しに来ましたよ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ご苦労……そこに置いておいてくれ…………は～～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021550001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんです、そのあからさまなため息は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……いつものアレだ。あの騒音と同衾し続けなきゃならない私のストレス、\n想像できるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021550002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………おいおい、また大騒ぎしてるぜ、あの二人」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……仲がおよろしいことですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "司令室代わりのこの大部屋は、つねに騒がしい。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その騒がしさをさらに騒がしくさせている一角があった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ったくよぉ！　お上品なこと言ってんじゃねーよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……そうやって怒鳴るのは、痛いところを突かれた証拠でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ざけんなっ！　痛くも痒くもねーってのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふむ、エレガントな物言いだね……だが、声量と語調と表情と、その他もろ\nもろ全てが間違っているね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……鳳雛さん。あなた、それで仲裁しているつもり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「もちろんだ。僕の灰色の脳細胞が告げている……『夫婦喧嘩は犬も食わない\nよ？』ってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「誰が夫婦だ！　このエセ探偵が！　すっこんでろ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「今のはいいね……でもエセ探偵呼ばわりは、法律が許さないよ。無論僕もね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……混ぜっ返すだけなら、どこか行ってくれませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550005" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんなんだ、ありゃ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……さあ。当人たちに伺いたいものだが、割って入るのも面倒臭くてな……\nはぁ～あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "また大きなため息をつく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あんな騒動が数メートル先で展開されれば、たしかにため息の一つも付きたく\nなるだろう。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……大変ですね」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お悔やみを申し上げましょう、ご主人……何か甘いものでも添えて――む？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……ふむ、仮面戦隊マスカレードが担当している地区に、謎のニンジャ集団\nが現れたと報告が入った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……仮面戦隊マスカレードの地区……？　おい、その当人が目に前にいるっ\nてことは……その地区、ノーガードってことじゃねーか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。急がねばまずい……氷華、ほむら、すぐに向かってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021550005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「かしこまりました。さあ、ほむら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550006" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うっせぇ……今の、俺にゃあ関係ねぇよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「…………氷華、単身で出撃いたします――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550007" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「カツマ、鳳雛……氷華のバックアップを頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021550006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、任せな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……ニンジャだって？　聞いたかい、カツマくん！　スシ・テンプラに並ぶ\nニホン名物……この目で見るのが楽しみだねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうか？　まあいい……いくぞ、ジュンジロー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いまいち頼りにならない鳳雛とジュンジローを携え、俺は氷華のあとを追った\n。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}