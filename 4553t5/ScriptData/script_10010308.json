{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふぇええ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ったく……。勝つには勝ったけどボロボロだぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「敵の何人かは取り逃がしてしまいました。増援を連れて戻ってくるつもりで\nしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんということだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが、解せませんね。バカ犬たちが先走って勝手なことをするのはいつも\nのことですし――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んだと、コラ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「誰が犬だ、オレはウサギだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「『バカ』はスルーなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「戦闘中にあの程度のコント――もとい、混乱が起きるのはいつものことでし\nた。なのに、なぜ今回に限ってこのような損害が？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「やはり、隊長不在のせいかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……そうだな。その影響は大きいと思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「隊長か……やはり隊長が必要か……！　ミス・パープルの言う通りにクリス\nタルで召喚するしかないのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「より正確に言えば、カツマ不在の影響だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ？　何言ってんだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんがいなくなっても、そんなに戦力は下がってない気がするんだ\nけど～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたいあいつは、まともな指揮などしていなかったではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマの指揮能力や、戦闘力は問題ではない。カツマの持つ力が欠けている\n、ということが問題だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それは例の、ハンドレットムーンとやらのことを言っているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ。ハンドレットムーンが与えし力……『エンブレム・シンテシス』の\nことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「エンブレム……シンテシス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そういや、そのことについてきちんと説明してもらってないねえ。どういう\n力なんだい、そりゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「簡単に言えば、力を合成する能力だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「力を、合成……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そう。我々の持つ特殊能力を、合成し、強化する。場合によっては、新たな\n力を生み出す――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それが、エンブレム・シンテシス。カツマの持つ能力だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080007" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あいつに、そんな力が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「信じらんな～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もちろん今のカツマが、その力を使いこなせているとは思わない。だが――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「無意識にでもカツマは我々の能力を合成し、戦闘力を底上げしていたのだ。\n彼が不在の今、私はそれを痛感している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080009" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうか……インクレディブル・スクワッドには、やっぱりカツマさんが欠か\nせないんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103080003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……そうだ。我々の隊に、カツマは欠かせない。そして、カツマ自身もカツ\nマなりに努力していた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……やはり、昨日の私は少々言い過ぎたな。カツマに気合を入れたかっただ\nけなのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080011" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん！　なにがエンブレム・シンテシスだ。そのような力、我々には必要な\nい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080012" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「怪しげな合成能力などなくとも、我々個々の力は十分以上に強い！　役立た\nずの下僕など必要あるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私の話を、理解してくれていないのか……！　私が言いたいのは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080013" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「Ｍ・ザ・ブルーの予想通りだ！　先ほど取り逃がした襲来者（インベーダー\n）が、増援を連れて戻ってきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103080003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「やはりですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103080002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「パトロール部隊からは『敵は母艦らしきものを伴う』との報告も入っている\n。ただちに出動し、迎撃せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103080004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「了解！　インクレディブル・スクワッド、ただちに出動する！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103080014" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから！　どうして貴様が毎度毎度号令を出すのだーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
