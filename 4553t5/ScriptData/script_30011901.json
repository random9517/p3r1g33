{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私にいったいなんの用事かしら？　くだらないことだったら承知しませんわ\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903101" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「えっ、マッサージをしてくださるの？　あなたがそんなことを言うなんて、\n明日は槍でも振るのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903102" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「まあ、せっかくですし、マッサージくらいだったらさせてあげてもよろしく\nてよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……って、なんで服を脱いでいますの！？　マッサージのときの正装？　ご\n存じないのかって……ば、バカにしないでくださる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903104" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それくらい知っていますわ。さあ、無駄話をしている暇があったらマッサー\nジをはじめなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903105" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふぅっ、い、いきなり胸に……。ンッ、両手で、力いっぱい鷲掴みにしま\nすのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000119_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ここに一番疲れがたまりやすいんですの？　ふ、ふぅん……。ンッ、それで\n、胸を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「で、でもこれ……本当にマッサージなんですの？　た、ただ破廉恥な行為を\nしているだけのような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「なっ、別にいやらしい気分になってなどいませんわ！　た、ただのマッサー\nジなのでしょう？　なら……平気……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぅ……ふぅ……。それにしても、この……胸にあなたのモノが当たってい\nますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「熱いモノを、わ、私の胸に押しあてるように……んっ、んくぅ……。ちょ、\nちょっと……胸にソレ、擦りつけていません？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ヒッ！　ま、待ちなさいっ！　その棒を、わっ、私の胸の間に……！　ああ\nっ、入れるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「む、胸で挟んでしまいましたわ……。んぅ……あふぅ……。肌が触れて……\nや、やけどしそうなほど、熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それに……すごい匂いですわ……。こ、これ……ちゃんと洗っているの……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「先っぽもパンパンに膨れて……うぅ……それに私の胸が、容赦なく擦りつけ\nられていますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んくぅ。んはっ、ふぅ……んんぅ……。私の胸を動かすだけではなく、あ、\nあなたも腰を動かして、ソレで胸を刺激して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「な、なんです？　ちゃんと言えですって？　私の胸に挟まっているコレを…\n…そんな破廉恥な言い方で！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あ、甘く見ないでもらえるかしら？　そんな、卑猥な言葉を言うくらい、私\nにとって造作もないことですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それこそ、朝飯前ですわ。簡単すぎて、赤子どころか生まれてもいない子供\nの手を捻るような……うぅ、前置きが長すぎるですって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ち……チンポ……チンポなのでしょう！　私の胸に挟まっている、あなたの\n……チンポ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「くぅ～……。ただのマッサージですのに、こんな辱めを受けるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぅっ、あっ、ンン……ッ！　そんなにぎゅっと、胸で……挟み込んで、動\nかして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「パンパンになった、チンポが……ンッ、さらに、熱くなって……。んふぅ、\n胸が……ますます、熱いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それに……なんだか、胸の間がヌルヌルとしてきましたわ……。あなたのチ\nンポから、汁がでていますわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「が、我慢汁……ですって？　私の胸が気持ちいいから、チンポから溢れてき\nている……って、な、なに気持ちよくなっていますの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あなたねぇ、これはマッサージなのでしょう？　なのに、どうしてマッサー\nジしている側が気持ちよくなっているのですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ちゃんと私のことも気持ちよくしなさい……んくぅっ！？　さらにぎゅっと\n、胸を、掴んで……んぁっ、んはぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「強く胸を揉まれてっ、んくっ、ぴったりとチンポを挟むように圧迫されて…\n…んっ、私の胸を、なんだと思って……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そんなに腰を、押しつけて……ああっ、ああんっ！　胸に、腰を打ちつける\nように……チンポ、擦りつけて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、胸に、チンポ擦れて……んっくぅ、こんなマッサージ、知らない…\n…んっ、ああっ、ああ……っ！　はぁっ、はぁあ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁ～～～っ！　なっ、なんですの！　胸の中に、なにか\n、出されてるぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「わ、私の胸に……いったい、なにをだしたんですの！？　まさか……おもら\nしをしたのですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。いや、でも……。このドロっとした感じは……それに匂\nいも……これはオシッコではありませんわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「このドロドロも……マッサージに必要なものなんですの？　それで、これを\n出すために、先ほどはあんな腰振りを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ま、まあ、そんなことだろうと思いましたわよ！？　ふん、バカにしないで\nくださる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ほら、呆けていないで続きをなさい。まだマッサージは続いているのでしょ\nう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「このドロドロしたものが肌についているのは不快ですけど、マッサージとい\nうのなら仕方ありませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……な、なにがおかしいの？　というか先ほどから、なんだか笑いをこらえ\nているように見えますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「そんなことをしている暇があったら、はやくマッサージの続きをなさい。私\nは全然気持ちよくなっていませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「気持ちよくなりたいのか、ですって？　当然ですわ。マッサージとは、そう\nいうものでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んんっ！　また胸を揉んで……んっ、ああっ、胸ばかりですわね。ほかのと\nころには目もくれず……はぁんっ、あぁっ、んっくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「チンポが、また動いて……あんっ、胸を擦るっ、んっ、なんだかさっきより\nも大きくなっていますわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ドロドロを出された胸の間を、ンッ、チンポが、ああっ、かき混ぜるように\n出入りしてっ、んっ、ふぅっ、ふぅっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「胸も、ぎゅうぎゅうと、アンッ、リズミカルに揉まれて……んっ、このマッ\nサージ……なんなんですの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「気持ちよくなってきたか、ですって……？　んっ、そんなこと聞かれても、\nああんっ、よくわかりませんわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「た、ただ……。んぁっ！　胸が……んっ、んくぅ……奥からジンジンと熱く\nなるような……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、そんなにまた、激しく……っ！　んんっ、わ、私の胸を捏ねるよう\nに……ああっ、んっ、んはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「胸だけではなく、腰まで動かして……はぁんっ！　チンポが、音を立てて胸\nの間を、出入りしてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「チンポを感じろって、そんなの……嫌でも感じますわっ！　んぁっ、この硬\nくて熱いチンポ……肌に、擦れるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「か、感じる……感じて……んっ、んんぅっ！　胸で……チンポを挟んで、擦\nられるの……ああっ、んっ、んっくぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「もっと、もっと強くしても、いいですわよ……？　んぁあっ、そうやって、\n胸に指を食い込ませて……あっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「強めに揉まれると、んっ、全身に痺れるような感覚が……ああっ、だからっ\nてそんなに、何度も強く……んっ、はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「な、なかなか、上手ですわね……。んぁっ、手と、チンポで……胸をほぐさ\nれて……はぁ、はぁ……とても……いいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「身体が火照ってきてしまいますわ……。んふぅっ、んっ、んんぅ……はぁ、\nはぁ……んっくぅ……ああっ、ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「え、エロい顔になってきたですって！？　そんなことありませんわ！　たし\nかに感じては、いますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……って、そんなことはどうでもいいですわ。もっと力いっぱいマッサージ\nしなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ああっ、いっぱい動いて……！　んっく、チンポをもっと擦\nりつけるように……はぁっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私もなにか、んっ、こみあげてくるような……ああっ、ああっ、なにか……\n身体が……痺れてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、もっと胸を、んっ、気持ちよくなるように、めちゃくちゃにして…\n…ああっ、ああっ、そうされたら私……んっ、んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「くる……くる……ああぁっ、なにか……キてしまいそう……！　はぁっ、あ\nあっ、ああ……ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　ああぁっ！　あはぁあああぁぁぁああぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ああっ、またぁ……っ！　胸の中で、チンポがビクンビクンと震えてる……\nはぁ、はぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「先ほどのように、んっ、ドロドロが……ああっ、胸の中に、いっぱい……で\nて……る……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「本当に、ひどい匂いですわ……。このドロドロ……。でも……んぅ……この\n熱を肌に感じると、たまらなく身体が火照るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。なんなんですの……このマッサージ……。すごく、不思\n議な気分ですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「へぇ……パイズリというんですの……。い、いや、知ってましたわよ！？　\nちょっとあなたを試しただけですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「ふふん。それにしても、パイズリマッサージとはとても気持ちのいいもので\nすわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「このドロドロも……えっと……きっとマッサージの効果を高めるものなので\nしょう？　ふふ、そうに決まっていますわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……だったら、もっと出した方がいいですわよね？　あなたもそうは思いま\nせんこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それじゃあ、もうちょっとパイズリマッサージを延長させてもらおうかしら\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああぁっ、ちょっと急になにを……んっ、んんぅうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「チンポから、んぁっ、いっぱいドロドロしたものが飛び出して……んっ、し\nかもこの、すごい臭い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「こ、これ……あなたはこれを私の胸に出していたんですの……！？　んはぁ\n……こんなに……ネバネバした、いやらしいものを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁ、はぁ……。息をするたびにぃ……ひどい臭いが、鼻の中に\n入ってきて……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「わ、私のパイズリが気持ちよかったからですって？　ちょっと待ちなさい、\nあなたマッサージではなく、パイズリをしていたのですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「私のことを騙しましたわね！　そのうえ、胸だけではなく顔まで、ドロドロ\nにするなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000119_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「……え？　パイズリという名前のマッサージ？　……ええ、もちろん知って\nいましたわよ。パイズリ、ああ、パイズリですわよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「パイズリくらい知っていますわ。この私が、パイズリを知らないわけがない\nでしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それにしても、あなたはパイズリが上手なのね。これからは毎日してほしい\nくらいですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスD" ]},
		{"command":[ "SETTEXT", "「それに、マッサージの効果を高めると思えば、このドロドロも我慢できます\nし。ふふっ、これからもよろしく頼みますわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1903410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
