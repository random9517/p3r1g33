{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_003" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ワームホールというのはだな――」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_090102100001" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「よろしければ、私からご説明いたしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100001" ]},
        {"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　いきなり人が出てきたぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "てか、このお姉ちゃん誰だ！？　また話が面倒になるんじゃねえだろうな……\n？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え！？　これってもしかしてホログラム！？　こっちの世界ってすごい！　\n何もない空間にこんなリアルな映像を投影できるなんて！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "098_010102100001" ]},
        {"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いえ、これはわたしたちの世界のものではないと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……ミス・パープルか。こんなところにまで出張ってくるとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「これも、次元管理局の業務の一環ですので。冴島長官には、すでにお話を通\nしてあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ＥＤＯには接触済み、ということか。相変わらず手回しのいいことだ。まあ\nいい、簡潔に説明を頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……なんだ？　A・ルナテミスは、このお姉ちゃんと知り合いなのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「承知しました。では、まず基礎の基礎から。まず皆様が現在お住いの世界は\n『多元宇宙』の一部であり――」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "072_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「その世界のほかにも、いくつもの世界、より正確に言えば『次元』が並行し\nて存在している、ということはおわかりいただけますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、ＳＦ苦手……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう一人の私が出てきてしまった以上、信じないわけにも行くまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「現に私たち、他の世界に来ちゃったわけだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「では、ご理解いただけたことにしてお話を進めます。本来、異なる次元同士\nは交わらず、文字通り平行して存在しているものですが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100005" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「時としてなんらかの要因により、複数の次元が接触してしまい、混乱を生じ\nる場合があります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100006" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんらかの要因？　そいつはたとえば、異次元の連中が侵略戦争をふっかけ\nてきた、みたいな場合かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そうです。あるいはもっと軽微な事例。たとえば今のように、ワームホール\nが予期せず開いてしまう、などですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100007" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そうしたことから起こる混乱を収拾するため、多次元間で結成された『次元\n管理局』という組織が存在します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100008" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「つまり、あなたはその組織の一員だということですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「次元管理局に所属しているわけではありませんが、そこに協力する企業の者\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100009" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「彼女はクリスタル・コンツェルンの開発主任だ。何をしている企業なのかは\n……今にわかる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で？　そのクリスマス・コンツェルンが、どうして俺たちに多元宇宙の説明\nを？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。『クリスタル』ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっせえ！　わかってるよ！　ちょっと間違えただけだっつーの！　とにか\nく、なんのためにここに来たんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「あなたたちのお役に立てるのではないかと思いまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100010" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「と、言いますと？　どのように？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「クリスタル・コンツェルンでは次元間防衛装備の製造・販売、あるいは人材\n派遣なども手掛けておりまして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100011" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「この世界で必要とされるものを、納得のお値段で提供できるのではないかと\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100012" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、つまり武器商人かい。そういったもんを長官さんたちに売りつけよう\nと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「必要とされるサービスを必要な次元に迅速にお届けする、というのが当コン\nツェルンの理念ですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100013" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあいいや。それで？　今回のワームホールとやらについては、どんなこと\nをしてくれるんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そうですね。それが本題なのですが……ワームホールが自然に開く、という\nのはいわば次元同士の軽微な接触事故でして――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100014" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「通常、ごく短期間の極めて小規模な接触の後、それぞれの次元は通常の状態\nに復帰します。今回もそのようですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100015" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え！？　じゃあ、私たちが通り抜けたワームホールも、もう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「はい、消滅しました。したがって、次元管理局としては対応を行いません。\nそれぞれの次元に影響がほとんど出ておらず、その必要がないからです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100016" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待って！？　影響大ありじゃない！？　だって私たち、異世\n界に来ちゃってるんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ええ。個人レベルでの影響は、決して無視できるものではありません。そこ\nで我々クリスタル・コンツェルンでは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100017" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、この話っぷりはなんか嫌な予感がするぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「緊急時の次元間移動などをサポートする『ワームホール保険』をおすすめし\nております！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100018" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんじゃそりゃぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "やっぱりか！　やっぱり売り込みか！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「また、保険適用外の次元間移動も有償で承っておりますので、そちらのご利\n用もご検討ください」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "072_010102100019" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「有償！？　お金とるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんなんだ。この宇宙規模――いや、多元宇宙規模のセコさは。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「はい。長官様にお渡ししたパンフレットに、料金一覧と詳しいサービス内容\nが記載してございますので、ご一読の上ご検討ください」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "072_010102100020" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「なお、お支払いはクリスタルでお願いいたします。ご利用、お待ちしており\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "072_010102100021" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……と、言うことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そう言われましても」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「っていうか。なに……？　なんなのよ！　あれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わ、私たち、自分の世界に帰れないの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「どうなるの！？　ねえ、あーしたちどうなるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、俺に聞くな！　ミス・パープルとやらが言ってた通りなんじゃねえの\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「その話がわかんなかったから聞いてんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかんねえのに威張るな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んだよ！　オレがいつ威張ったってんだ！　だいたい、お前はどうなんだよ\n！　あの話、わかったのかよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちょっと、ウタ！　やめなさいって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んだよ、ホクは口出すんじゃねえよ！　このままオレたち、元の世界に帰れ\nなくなってもいいのかよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お前たち、やめないか！　我々がこの世界に来たというのは、それなりに意\n味のあることかも知れんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「意味？　どゆこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そういえば、先生はどうしてここに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100005" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お前たちに知らせに来たのだ。どうやらマッポーサムライは我々の世界だけ\nでなく、この世界のスシも狙って――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「長官、隊長、緊急事態です。その付近の回転寿司店で、謎の怪人が暴れてい\nるとの通報が入りました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「怪人だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「はい、現場からの報告では、サムライのような姿の女性だとか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「サムライ！？　あいつだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100006" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「どうやら、早くも動き出したようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「了解した。すぐにインクレディブル・スクワッドと現場に向かう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "秘書" ]},
		{"command":[ "SETTEXT", "「現場の位置情報はこれより転送します。それでは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「皆、聞いての通りだ。すぐに現場に向かうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちょーっと待てっ！　マッポーサムライはオレらの獲物だ！　お前らはちょ\nっかい出すんじゃねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102100005" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうそう！　あーしら、ずっとあいつを追っかけてきたんだもんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そういうわけで、ここは手を引いてほしいんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、そうか？　そういうことなら、任せても――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「よくねえ！　この世界は私らの縄張りだぞ！　縄張り荒らしは、私らの手で\n懲らしめる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102100001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおい！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "妙なところでイヌ科の本能出すな！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いいからお前らはすっこんでろってんだよ！　お前らの敵う相手じゃねえ！\n」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "097_010102100006" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それは聞き捨てならないねえ？　あたしらの力を疑ってんのかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「我らの実力は、嫌と言うほど見せつけたはずだが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102100002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ああああああ、エファナティカと姫様まで。やめてくれ、これ以上面倒は起こ\nさないでくれ……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「見たから言ってるんだってば！　キミらじゃ無理無理！　プロに任せて！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "099_010102100005" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「……悪いけど、あなたたちを危険にさらすわけにはいかないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100007" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様！　どこまで我らを愚弄する気だ！　ならば改めて、我らの力を見せて\nやろうではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102100003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと姫様！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「いかん！　お前たちやめなさ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "sbg_0030" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},				
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「どうしてもっていうなら、腕ずくでも止めるわ！　スクールガール・ミュー\nタント・ニンジャ・ラビッツ！　いざカマクラ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102100008" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "SETIMAGE", "0", "sbg_0031" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「ラビットパワー！　イェーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_910102100007" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおーい！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッド！　攻撃せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102100004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それ、俺の役目ーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}