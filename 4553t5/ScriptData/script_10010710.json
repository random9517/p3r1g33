{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "器用に俺達三人を地下室に投げ入れ、猿たちは意気揚々と去っていく。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそぉ……また延々と運ばれて、今度は監禁かよ……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それよりさっきの話だ、本当にここは札幌なのか？　であれば、人がいなけ\nればおかしいだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは、私もさっき考えていたの。私たちが宇宙に出ていたほんのわずかの\n間に人類が滅び、猿が栄えるようになったとは思えないわ。と、すると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「やはり、ここは元の世界ではない、ということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういえばワタクシ、『ウラシマ効果』というものの話を聞いたことがあり\nますぞ。これはもしや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ！　こないだ観たアニメの話だな！　未来の警察がどうのこうのって…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アニメの話はいい！　それよりウラシマ効果とはなんなのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「私も聞いたことがあるよ！　宇宙船が光速に近づくと、船内では時間の流れ\nが遅くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「その間に地球では、船内の人たちから見てすごい速さで時間が進んでしまっ\nているの。昔話の、浦島太郎のようにね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「で、では私たちも……遠い未来の札幌に到着してしまったと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さよう。そういうことかも知れません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あるいはもっと単純に、事象の地平線を超えてしまい別次元に飛ばされた、\nということも考えられる。猿が札幌を支配する次元にだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それでは救援は期待できないということか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「その上、逃げ場もない。一生、このまま地下室に閉じ込められて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、そんなのは嫌ーっ！　こんなところで死ぬとか嫌よぉーっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「その通りだ！。なんとかして脱出しなくては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺達は、絶望感にかられながらも脳を絞って打開案を話し合った。が……その\n間にも隙間風は吹き込んでくる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「この寒さ、なんとかならないのか！　下僕！　隙間に身体をねじこんでこの\n風を食い止めろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな軟体動物みたいなことできませんって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゃあビローンと広がって、この牢全てを覆い隠せ！　寒い！　寒い寒い！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなことできたら人間失格ですって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「猿どもを一網打尽にするには……信仰している時計台を破壊すべきなのか？\n　でも、待てよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「運ばれて来る途中……遠くにおかしなものが見えた気がする。我々の乗った\nロケットによく似たなにかが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もしかして、それ、本当にロケットなんじゃない！？　もしかして、私たち\nのロケットのほかにも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここにたどりついたロケットがあるのかもしれん、ということか？　と、す\nるとそれを奪って……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100006" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロケットを奪って帰る……ってどこにだ？　それに打ち上げるって宇宙にか\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな……無理がある。そもそも、打ち上げの方法もわからない……。こ\nれはボツ案か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんとか通信機を見つけられないのか？　それで元の世界……冴島長官たち\nに通信を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様……時空を超えた救援メッセージを出す方法なんて、ウチには\n見当もつきませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う、ううーむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あー、もう！　なにかないのかい！　なにか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「うーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107100003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どよんとした空虚な静寂の中、次第に俺達は黙りこみ……寒さで意識も薄れて\nいく。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とほほほ……こんなことなら、長官の言いなりになって、出撃なんかするん\nじゃなかった……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、思わずぼやいたその瞬間！　俺はあることに気が付いた！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "いや……待てよ？　ここが未来の北海道だとすりゃ……長官はもういねえ。\n超絶ブラックな職場のＥＤＯも……もうなくなってる", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "てことは、だ！　わざわざあの労働基準法ガン無視環境に戻る必要もねえ…\n…！　帰る必要なんかねえじゃん！　そうだよ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "今だったら、他の連中も寒さと不安で判断力が鈍ってる！　ここは一発、う\nまいこと口車に乗せて……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "よし！　チャンスだ！　俺の人生、ついに好転のチャンスがめぐってきた！\n　やるしかねえ！　このビッグチャンスに乗るしかねえっ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……？　なんだ、下僕。何か言いたいことでもありそうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107100009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、いえ！　え、えーとですね！　姫様！　それにみんな！　俺たちは、大\n事なことを見落としてたぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大事なこと……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107100004" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ！　俺たちはここから逃げることばかりに気を取られてた。でも、そ\nれは次の段階だ！　今はまず、やらなきゃならんことがある！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「と、いいますと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いま必要なのは、帰る手段じゃない。ここで生きのびる手段だ！　そいつを\n確保した上で、ここの状況をもっとよく見極めるんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なるほど……一理あるね。アンタにしては、悪くない考えだ。だけどねぇ、\nどっちにしても、ここからは逃げ出さなきゃならないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もちろんそうだ。そのためには武器がいる！　そのうえで、あったかい食い\n物を確保する。まずそれが、目先の目標だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あったかい、食べ物……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107100003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あったかい食べ物……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107100002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺も含めて全員の腹が、同時にぐぅ～っ、と鳴る！　そうだよ……！　出発前\nにラーメンを食い損ねてから、なにも食ってねえんだった！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ど、どうすればアツアツの食べ物が手に入るんだ！？　どうすればいい！？\n　もったいぶらないで教えろよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107100001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「落ち着け落ち着け！　ちゃんと考えてある！　いいか？　猿どもは、俺達を\nすぐに殺さずに、捕まえてこうやって監禁している」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ということは、いずれ何かに使うため……必ずここにやってくるはずなんだ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど。そこを狙って……ということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107100008" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ！　いいな、チャンスは一度だ。みんなでタイミングを合わせて……\nっと！　噂をすれば猿が来たぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿３" ]},
		{"command":[ "SETTEXT", "「キキー……ウキキキー……」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿４" ]},
		{"command":[ "SETTEXT", "「キキキッキウキー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ひたひたと、部屋の前までやってきた猿が、鍵を扉に差し込み、開けたその瞬\n間！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今だ！　絶対に逃がすなぁ！！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うぉおおおおおーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107100004" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

