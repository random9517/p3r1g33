{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ！　りょ……両脚が動かないっ……！　隊長、アマルガメイ\nトの四肢を拘束できる技術など、どこで手に入れた……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「な、何をニヤニヤと見ているのだ！　早く解放しろっ！　……こんな……こ\nんな淫らな格好……許されるわけがないだろうがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……貴様が離す気がないというのなら、こちらも本気を出すぞ！　……んぎ\nっ……んぎぎぎぎっ……！　くそっ、ビクともしないだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「本当に……どうしようもないのか！？　……っぅ……！　や、やめてくれ…\n…！　最近、ずっと身体が熱くて……。その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「こんな風に足を開かされていると……！　た、隊長の視線だけで……。……\nああ……見ないでくれ……。戦士として恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長だって我の女陰なぞ見ても楽しくはあるまい……。と、それはなんだ？\n　それ！　隊長が手に持っているものだ！　……『バイブ』……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ……バ、バイブ……！？　まさかそれを我の股間にあてがう気じゃ……\n、ッあっ！？　あああああっ、あああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あぐっ、んぐぅううっ！　ビリビリっ……ビリビリ電撃のような刺激が……\n！　あっ！　あっ！　そんなに強くしていない……だと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ではなぜ、我の身体がここまで感じているのだっ……！　はぁっ？　肉体の\n開発が終わったから……？　我の身体が隊長を求めている、から……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「おかしなことを口にするな、んぁあああっ！？　ああっ！？　やめっ、離し\nている途中でバイブっ、バイブやめろっ……やめっ、ああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「い、いやらしい水音がする……！　愛液が飛び散って……あっ！　やめ、や\nめてくれぇ……！　羞恥で死んでしまう、あっ、あうっ、あううっ、あうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ブルブル……ブルブル振動が膣内にまで響いて……。あ！？　だめだっ！　\nそっちは！　そこはクリトリス……ああああッ！？　りゃめ、りゃめっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「クリトリスっ、バイブあてられる、と……んああああ！　脳まで痺れるぅう\nうっ、あっ！　あっ！　脳天から爪先まで太い快感が駆け巡ってぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あひっ！　あひっ！　自分ではどうすることも出来ないぃいい！　あっ！　\nあっ！　やめ、やめてくれ、やめ……うあああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっ！　あーっ！　……イくイくイくイクぅううっ！　あぅう\nっ！　あうっ！　あうううっ……！　腰がガクガクして……ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あ、イ……。……ん？　急にやめてどうした？　……え？　飽きた？　もう\n帰る、だと？　ま、待て……こんな状態で一人にするなぁ！　隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長っ！　火をつけるだけつけて立ち去りなぞ許さ……！　あっ！！　……\nえ……？　ど、どこに行った？　我は動けんのだぞ？　ずっとこのまま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「このまま放置されたまま……？　……そうだ、トタンに緊急連絡を……。ハ\nハ……こんな姿、見せられるわけが、ない……。どうしろと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……う……。こんなところに、永遠にいろというのか……。せめて下着を履\nかせてくれ……。空気に接しているだけで、股が……うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……ん？　た、隊長？　……隊長！！　も、戻ってきてくれたんだな！？　\n良かった……！　た、頼む、もうこれ以上辱めないで、くれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「出来ることはなんでもする、だから……！　この拘束を解いて、ふ、普通に\n抱いてほしい……。見てわかるだろう？　ずっと潤んで、濡れていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「このままでは部屋に戻れない……。こんな肉体に改造してくれたのは貴様な\nのだからな！　……何？　おねだりをすれば抱いてやる？　お、おねだり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「馬鹿を言うな！　我は戦士、アンチ・アマルガムの気高きアマルガメイト…\n…！　普通の女のような、可愛げを見せる必要など……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「……おねだりをしなければ、一生そのまま放置する？　今度はもっと長く？\n　う、ぅ……あああ……。わ、わかったっ！　わかった、い、言うから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「つ……強くあるべき戦士、のくせに、隊長に肉体を開発されて……。任務中\nもいつも濡らしている、この卑しい我に……慈悲を……ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「婉曲的な言い方ではわからない……？　……肉の茎を！　だ、男根を膣内に\n入れて欲しい！　ちんぽ、ちんぽを……まんこに入れてくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我の浅ましいおまんこが隊長の鋼鉄のような、巨大なちんぽを欲して……も\nう、ずっと！　ずっと辛いんだ！　頼む、頼むから……ください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あッ……！！　んんんんぁっ！　あああああっ……！　すっご……ッ、ぬる\nんって……ヌルンって一突きで奥まで……ぇ、ああああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ああっ、あぁ……！　バイブより何倍もいい……！　あっ！　頼む……！　\nクリトリスを潰すみたいに、強引に出し入れしてくれ……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「凄い……すごい、すごい、すごい……！　はっきりとわかるっ……。中で…\n…膣内で、あっ！　まっすぐそそり勃って……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我を串刺し、にしている……！　まるで高温に熱された鉄の棒を入れられて\nいるみたいだ……！　奥の奥まで、突き刺さって……たまらないぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　……も、もう……我慢しなくていいだろう？　隊長はその\nままでいい、我が、我が動くから……！　あっ……んぐぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ちょうどいいところに、刺さる、あっ♪　ここっ、ここっ、ここ……！　あ\nあっ、いいっ……いいっ！　貪欲すぎると、け、軽蔑しないでくれっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「自分でも欲望が、劣情が止められないのだ……！　あっ！　あっ！　隊長…\n…っ、隊長のちんぽっ、肉の茎……我にぴったりで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「相性が良すぎる……！　それにっ……放置され、おねだりさせられ……バイ\nブでさんざん焦らされたせいで、中がトロトロに溶けていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「一こすりごとに、ゾクゾクするほど快感がせりあがってくる……！　膣粘膜\nから全身に悦楽が広がって……あぁああっ、く、狂ってしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ、あッ、あっ、あぁああ……！　腰を、腰を少し揺するだけで無限に快\n感が……！　あっ！　あっ、あっ……隊長……隊長……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長のモノも……！　肉茎も負けじと我のアソコをかきまわしてきますっ！\n　あっ！　感じているのですね……同じ、です、我も……我も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「イ……く、イく……！　んひぃいいいっ！　隊長、隊長もイってください！\n　絶頂の真っ最中に、精を、精を注がれたいのです……おねだりっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「おねだりして、いくらでも腰を振りますから、だから……くださいっ、くだ\nさい……！　奥に、膣奥に射精してほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あ、りがとうございます……！　ありがとうございますぅううっ……！　あ\nっ！　ビュルビュルと膣奥に精液が分け入ってきて……あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「脳が溶けそうなくらい……気持ちいい……ッ！　こんなものっ、もう、化学\n兵器ではないかっ！　あっ！　女を壊す強靭な兵器……兵器ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ああ……出しながら、出しながらジッとしていてくれ……っ！　我はもう、\n完全にスイッチがオンになってしまった……淫売になってしまったっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ヘコヘコと、あっ♪　カクカクと腰を振るのがやめられん……っ！　んぉっ\n、んはっ、んぁおおお♪　尻を振って肉棒をねだって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「信じたくない……でもっ、体力が続く限り、あっ♪　隊長のモノを逃がした\nくない……♪　隊長……聞こえますか、ズチュズチュグチュグチュとっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我の、我のドロドロまんこが卑猥な音をたてながらッ……隊長のちんぽ、ち\nんぽを休ませるヒマもなく再び強制勃起させて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「どこまでも、どこまでも貪っておりますっ！　あ、ああああああぁああ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あと少し……あと少しだ、け……♪　ハハ、隊長……先ほど射精したばかり\nだというのに、こんなに……♪　どんな訓練を積んでいるのか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長の底無しの体力、を知ってしまったら……♪　隊長のこの、太く荒々し\nい男根をおぼえてしまったら……他ではもう満足できないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　それどころか……、あっ♪　一人でしても絶対に達せない\n♪　コレでなければ……っ、コレじゃなければ、我はもう……っ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んっあっ♪　あっあっ♪　あっ、あぁ……ひぃいっ♪　角度を変える、だけ\nで……あっ♪　いくらでも楽しめそうだ……あっ、ここも……イイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「い……い♪　イイ……イイっ♪　腰が跳ねる、んくっ……♪　頬が勝手に緩\nんでくる、真面目な表情を保てなくなっている……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んぁっ……はぁっ、はぁっ、はぁっ、はぁ……あぁ……♪　隊長……今我は\nきっと、情けない、恥ずかしい顔をしているのだろうな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「だが、隊長もかなりのもの、だぞ……♪　ケモノのように息を荒げて……♪\n　ハハ、互いに快感をおさえきれずに、野獣になってしまっている♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我のアソコが、ぎゅうぎゅうと隊長のモノを締めつけているのがわかる、だ\nろう♪　キツく狭くなったそこを……無理やりこじあけられる瞬間っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んぉおおお♪　その瞬間、身体が痙攣して……達する♪　あッ……あっ♪　\nちんぽをねじこまれるのが好きで、好きで他には何も考えられな……い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ズコズコと肉穴を攻められると、己が発情した雌であることを思い出す……\nそれで♪　蜜が滲み出してくる……ちんぽを迎えにいってしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ、あッ、あっ、あぁああ……！　たい、ちょ……隊長、我はすごく、す\nごく大きな絶頂がきそうだっ……頭が真っ白になるくらいのが……きそうで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「その時、一番締めつけるから……！　ちんぽ締めあげて、はしたない声をあ\nげる、からっ♪　だからその時は……またっ、また入れてほしいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ちんぽ、ちんぽ、ちんぽ、精液……♪　ちんぽから出る精液っ♪　ちんぽ狂\nいの我に……あぁあんっ！　どうか、どうか恵んでくれ……欲しい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んひぃいいいいいいい～～っ♪　キた、キたキタキタぁあああ……♪　イク\nっ……イクっ……ああっ♪　相思相愛だなっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっんっ、んっ、んっ……！　ちゅうちゅうと子宮口が、子宮へと精をおく\nりこんでいる……吸い上げて奪い取っている……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んぐっ……んぐぅっ♪　ぐぅっ……♪　す、まない……♪　イキ汚くなって\nしまうくらい……良かった、本当に良かった……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「視界がグラグラ揺れるっ……あっ、下半身が麻痺しているっ……♪　我のア\nソコの中でごぷごぷと精液が波打って……ああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「こ、ここ、興奮しすぎてしまったのか、頭に血がめぐってしまった……。戦\n士のくせに冷静さを失って、肉棒に真剣に奉仕してしまった……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ハハ……二度も直接精を注がれてしまっては……♪　これは妊娠しているか\nもしれないな♪　でも……それでもいい♪　気持ち良すぎた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長のモノが孕ませ棒だからいけないのだぞ……♪　あんなもので中を、奥\nをつつきまわされれば……。女は、メスはみな狂乱してしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「精液が欲しくなり……♪　一滴でも多く子宮にとりこみたくなってしまうの\nだ……。それほどまでに危険で、魅力的なちんぽ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「こんな危険物は、心得のある者、強者にしか扱えまい……。……そうだろう\n？　ゆえに、これからも……我がずっと使ってやるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「だ、から、貴様も……隊長も、他の者には使用せぬよう。我がいくらでもし\nてやる、だから……だから、また誘ってほしい。約束だぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「んああああああっ！？　ああっ……ああっ！　全身に……全身に精をブチま\nけるとは……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あぷ……っ、んぷ……。我が目を疑うほどの量を吐き出して……♪　隊長の\nモノは限度というものを知らないようだ♪　頼もしいばかり……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　いいぞ……いいぞ、好きなだけ、好きなところにかけると\nいい……♪　我としては、二度とも膣内でも構わなかったのだが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00012001_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長が、全身にぶっかけたいというのならば……受け入れるだけだ♪　我は\n、我はもう……隊長の言うことを聞くことしかできないくらい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長と、隊長の肉茎に心酔している……。あっ♪　びちゃびちゃと、放物線\nを描いて……我の身体に飛沫を散らす白い体液……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我のアソコで感じたから、……射精したくなるほど高まったから精が飛び出\nしたのだと思うと……その想像だけで、ゾクゾクしっぱなしだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「今まで……この素晴らしい体験を、性交を知らなかったことを悔いる……♪\n　我は戦いのみのために生まれてきたと奢っていた。だが……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「隊長との、肌と肌でのぶつかりあい……。胸が高鳴り、全身が歓喜するほど\nの悦楽……。これを経験して、悟ったのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「我のもう一つの存在意義、それはこうして……隊長の精を浴びること♪　隊\n長と交わり、激しく求めあい……快楽をどこまでも追及すること♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「フフ……♪　新しい楽しみができてしまった。隊長……罪の味を我に刻み込\nんだのだ、責任をとってこれからも抱いてくれよ……♪」", "NORMAL" ]},
