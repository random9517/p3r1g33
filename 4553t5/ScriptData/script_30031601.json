{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この部屋に呼び出しとは、いったいなんの用なんだい？　……まあ、大体予\n想はつくけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603101" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ……。さっきから視線がいやらしいねぇ。なんだい？　こんな姿になっ\nたあたちに興奮してるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603102" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へぇ……図星って感じだね。まったく、どうしようもない変態だね。あきれ\nちまうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こうなると、お仕置きが必要なのはあたちじゃなくてあんたの方じゃないか\nい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この姿になるといろいろと不便でねぇ。イライラしても正義じゃソフトドリ\nンクしか飲めないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「となれば、この憂さを晴らすならあんたへのお仕置きが一番だよね。ほらっ\n、さっさと脱ぎな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603106" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さてと、これからどうしてやろうかねぇ。ん？　苦しそうな顔してるじゃな\nいか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000316_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それなら、抜け出してみればいいだろう？　あんたはオトナなんだからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それとも、小さくなってるあたちの力にすら負けるのかい？　はぁ～、情け\nないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「で、こんな状態なのにしっかりチ〇ポは勃起させてるんだね？　どれどれ、\nここを責めてやろうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ、ガチガチになってるねぇ。ほらほら、最初っから思いっきりいくよ\n？　しっかり我慢しないと、どうなるかわかるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたのチ〇ポからでるくっさいロリコン汁が、顔にひっかかっちまうんだ\nよ？　ははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらほらほら、チ〇ポを小さな手にしごかれまくって、どんな気分だい？　\n手の中ではビクビク震えてるみたいだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それに、あたちの目の前にある尻穴はヒクヒク震えてるねぇ……。あ、そう\nだ。ここも弄ってやろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んちゅぅ……んれぇ……。ん？　なにやってるのかって、あんたの尻穴を舐\nめてやってるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こうやって……ンッ、きゅっと締まってる尻穴にぃ……舌を、差し込んでや\nるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ、チ〇ポがビクッと反応したねぇ。あたちがこんなことをするとは思\nわなかったかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「今回はあんたを思いっきり責めてやりたい気分なんだよ。ほら、このまま情\nけなく射精しちまいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぶ、じゅぶっ、じゅるるるぅっ！　この辺だろ？　前立腺ってや\nつはさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ここを、舌で責めながら……じゅぷっ、思いっきりチ〇ポをしごいて……れ\nろっ、れろれろれろぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポが膨らんできたねぇ。それに、手にはべっとりと我慢汁までついちま\nってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この汁をチ〇ポにぬりたくりながら、もっと激しくしごいてやるからねぇ。\nふふっ、凄い量だね、ぐちゅぐちゅいってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「尻穴も、んっ、きゅうきゅうって反応して、あたちの舌を締めつけてきてる\nじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんな姿の女に尻の穴を責められて、気持ちよくなってるようだねぇ。あき\nれるほど変題だよ、このド変態！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、ほらまた嬉しそうにチ〇ポをビクつかせてさぁ……。そんなふうに力\nを抜いちまっていいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んじゅるぅ、んれろ、れろぉっ。ほら、油断したところをさらに激しく責め\nてやるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「前立腺も、んじゅるっ、れろっ、グリグリ舌でいじめてやるよ。ンッ、腰が\n跳ねてるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポのほうも、思いっきりしごいてやるからね。ほらほら、小さな手で、\nしっかり竿を握ってさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルの我慢汁まみれの勃起チ〇ポを、シコシコシコシコ、手コキの速度\nもあげてくよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「れろれろれろぉっ、んじゅるっ、じゅるじゅるぅっ！　暴れようとしても、\nしっかり身体を押さえてるから無駄だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そして、チ〇ポはしっかりあんたに向けてるからね。んれろ、れろれろぉっ\n、もう限界なんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、それならだしちまいなっ！　くっさいザーメンを自分\nの身体にぶっかけるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、だせ、だせ、だせ……！　あたちの前で、無様に射精しちまいな……\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　ああっ、あはぁっ！　でてるでてる！　手の中でチ〇ポが震え\nて、くっさい汁がびゅくびゅくでてるねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「尻穴も締まって、舌が食いちぎられそうになったよ。ははっ、それにしても\nすごい量をだしたねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなにドロドロのねばっこい汁……。本当はこれをあたちのマ〇コにだす\nつもりだったんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でも、今日はあたちの憂さ晴らしにつきあってもらうから、あんたが溜めて\nた精液は全部手で搾らせてもらうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……なんだい、妙に嬉しそうじゃないか。ああ、変態のあんたには、こんな\nことでもご褒美になっちまうのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だったら、これはご褒美なんかじゃないってことをわからせてやらないとい\nけないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「小さくなってもあたちはあたちのままだからね？　あんたが悲鳴を上げるま\nで、チ〇ポから精液を無駄撃ちさせてやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるるぅっ！　手始めにまた勃起させないとねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「射精後の甘い勃起チ〇ポも……んっ、じゅるるぅっ、れろぉ……。こうやっ\nて、また前立腺をしげきしてやれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉら、またバキバキになっちまって。いいのかい？　このままじゃ、また\nあたちの手で搾られちまうよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このチ〇ポをあたちのマ〇コにぶち込みたければ、精々我慢しな？　ほら、\nまた手コキだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さっきだした精液で、チ〇ポがますますヌルヌルになってるねぇ。こうやっ\nて、さきっぽやエラの部分をこするのはどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「腰が反応しちまってるね。そんなんじゃすぐにイかされちまうよ？　ほら、\nぬめりにまかせてカリ首をぐりぐりってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、そして前立腺もしっかり責めてやるよ。れろっ、れろれろっ、尻の方\nから精液を押しだしてやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるるっ、じゅぶっ、じゅぶっ、じゅるるぅっ！　ほらほら、チ〇\nポがビクンビクンいってるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「れろれろれろれろぉ……っ！　ぽたぽたと、先走り汁がまた、垂れてきてい\nるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたちになすすべなく、チ〇ポだけじゃなく尻の中まで好き放題責められて\n、気持ちよくなってるんだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どうしようもない男だね、あんたは。すこしはあたちに抵抗する素振りでも\nしてみたらどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ははっ、無理かい？　睨んでるつもりだろうけど、大人の男がする顔じゃな\nい、情けない顔になってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいねぇ、その顔、ゾクゾクするよ……。特別に、このままどこに射精する\nのかを選ばせてあげようかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「またイキそうになってるだろう？　どうする？　２度目の射精を、さっきみ\nたいに身体にぶっかけるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それとも、あんたの顔にぶっかけるか……ほら、小さくなってもあたちは気\nが短いままなんだから、選びな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだい、悩むようなことかい？　なら、限界まで責めてやろうかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、じゅぶっ、じゅるるっ！　ほらほら……んじゅるっ、チ〇ポ\nが膨らんで、精液がこみあげてきてるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、早く選ぶんだよ……。あんたのくっさい変態汁を、どこに浴びたいか\nさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、さあ！　じゅるるっ、んっ、じゅぶじゅぶっ！　もうイくんだろ？　\nまた、精液をだしちまうんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたがドロドロになるとこ、最後まで見ててやるから、あたちに責められ\nながら果てなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ああっ、また身体にかい！　チ〇ポから精液がびゅくびゅくでて\n、ほら、さっきよりも量が多いじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、最後の一滴までしぼってやるからね。あたちの手で……んっ、\nしごくの、やめないからねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら……まだでる、まだでるじゃないか……！　チ〇ポがびゅくんびゅくん\nと、ザーメンの塊を垂れ流してるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ……すごいねぇ……。こんなにドロドロになるくらい、精液をだすなん\nてさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いつもより多いんじゃないかい？　あんた、あたちが小さいから余計に興奮\nしたんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、なんて男だよ……。それなら、もっともっと搾ってやらないとい\nけないねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたちだからいいけど、あんたみたいなのがほかのやつに手を出したらたま\nんないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたのチ〇ポから精液が枯れるまで、このまま責めさせてもらうよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もちろん、マ〇コはなしだ。我慢できるようになるまで、ハメさせてなんか\nあげないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さ、覚悟しなよ？　あんたが鳴いても喚いても、あたちはやめてあげないか\nらね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ははっ！　ほら、お望み通り顔にかけてあげるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うわぁ、すっごいねぇ。２度目なのに、ベトベトのゼリーみたいな精液がで\nてるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000316_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それを顔面に浴びて、どんな気分だい？　くくっ、あんた、すごく無様な顔\nしてるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「鼻の中に、自分のくっさい精液がはいってくるだろう？　あははっ、鼻提灯\nまでつくってるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それで……チ〇ポはまだまだ硬いままだねぇ。こんな目に遭って、興奮して\nいるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「自分の精液を自分で浴びて、チ〇ポを萎えさせるどころかますます硬くする\nだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「とんでもない変態だねぇ。ああ、こんなやつを部屋からだすわけにはいかな\nいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたがしっかり反省するまで、あたちが責任もってお仕置きしてやらなく\nちゃいけないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、なにチ〇ポをビクつかせて、尻穴もきゅっと締めてるんだい？　さら\nに責められるのを想像して興奮したのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく……。まあいい、あたちの憂さ晴らしも兼ねてるんだ。最後までつ\nきあってもらうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1603410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}