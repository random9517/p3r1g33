{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0189" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はー、泳いだ泳いだー。やっぱり、思いっきりカラダを動かすってのはいー\nよな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203101" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なんだよー、もうヘバッたのか？　体力ねぇなぁ、そんなんじゃいざって時\nにやられちまうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203102" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのペースに合わせたら、誰でもこうなる？　ははっ、それはちょっとあ\nるかもなー。ま、一休みするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203103" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……けど、ホントに貸し切りみたいに誰もいないな……オレたち二人きりか\n……え、っと……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203104" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、なぁ、ちょっとそこ……岩場の方……行かないか？　何でって……いい\nからっ、ほら、こっち……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……しょっ……ほ、ほら……開放的な気分になると……色々ムラムラす\nるだろ……？　だ、だからさ……オレが、してやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000412_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「急に発情って……バ、バカ……そんな事言うと、してやらないぞ？　ってか\n……お前だって、もうチンチン……硬くさせてるじゃんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「大体、ビキニだからって……ずっとチラチラ見てただろ。男の視線なんてモ\nロバレなんだからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まぁ……お前が見る分には……いいけど、さ……と、とにかくっ……んっ、\n動かしてくぞっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、うぁ……チンチン……おっぱいの中で、どんどん大きくなって\n来る……何だよ、結局期待してたんじゃんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「仕方ねぇな……んっ、ほら……もっと腰を前に寄せて。こうして……挟まれ\nるの……気持ちいいんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うぁ……でも、やっぱり、こんなアップで見ると……やっぱすげぇな……こ\nの割れてる所から……いっぱい精液が出るんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱいの中で……ムクムクしてるの分かるし……熱くなってる……\n疲れたんじゃなかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンは別……みたいだな……今、しみじみと実感してるよ……んっ、あ\nぁ……でも、オレも気分……出てきたかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁっ、んっ、さっき海入ったし……汗もかいてるから……よく滑\nるよな……んっ、く……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「乳首……立ってる……？　バカ……分かってるよ……いちいち、言わなくて\nも……ここ、押し付けて欲しいんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、そりゃあ……オレからしようって言ってるんだ……興奮して……立\nつに決まってるだろ……んっ、ほら……チンチンとキス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぅ……あぁ、何か……むわっとにおいが強くなってきた……んすぅぅ……\nんふっ、くんくん……うぁ……臭いな……チンチン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「臭いのに……んっ、すぅぅぅっ……何だか、嗅いじゃうんだ……これ、ヤバ\nい……んっ、クセになるにおい……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これ、もっと扱いたら……におい……強くなるのかな……んっ、おっぱい…\n…本気で擦っていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んんっ……ヤバい……マジでにおいが濃くなってく……あぁ\n……こんなの待てないだろ……はぁんむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぷっ、ちゅぷあっ……咥えちまった……んりゅぷっ……口の中……んっ、\nしょっぱいのが……広がってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「りゅぽっ、んっ……あっ、ちゅぷっ、んちゅるっ……んはぁっ、あふ……で\nも、パイズリには……フェラがつきものだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「別に、そうでもない……？　い、いいんだよっ、オレがやりたいって思った\nんだから……それで……ちゅぷっ、んちゅぷっ……ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ、んりゅっ、れろ……こうして舐めながら……んっ、チンチンをズリズ\nリしてく……んぁ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、ドキドキするな……んっ、こんな外で……おっぱい丸出し\nにして……チンチンしてるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいに……決まってるだろ……。そもそも、ビキニだって……本来の\nオレじゃないんだからな……そこは、分かっとけよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「でも、それだけじゃないから……お前になら、ちゃんと……してやりたいな\nって思うから……こんな、パイズリ……してるんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「って……何か恩着せがましいな……へへ、細かいことは気にしないで、チン\nチンに意識……集中させてくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れる……じゅぽっ、んちゅぷぅ……くぷっ、んぱっ、あんむ……えろ、れろ\nぉ……ちゅぱ、んちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んはぁ……ねっとりした汁が出てきた……んっ、先走り……んちゅるっ、パ\nイズリ……感じてるんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、オレも……何かさ……乳首だけじゃなくて……もっとおっぱい全体が\nムズムズして……止まらないんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、チンチンのにおいも……どんどん広がってる……んっ、はぁ\nっ……これ、もうすぐ……出るんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……一気に搾り出してやるからなっ……んっ、おっぱい……感じてくれ\nっ……はぁっ、あっ、ひっ、んぁっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぷっ、んむ、ふぉらっ……咥えたからっ、んりゅぷっ……後は……じゅる\nぅっ、のまへてっ……くれぇっ……んじゅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ！　ふぶっ……んぐっ、出たっ……んっ、じゅるっ……射精\n……ひてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こくっ、んっ……んくぅっ……あぷっ、あぁ……ん、全部……飲んじまうか\nらな……こくっ、んっ、こくんっ、んふっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まぁまぁの量だったな。んっ……れろ、ど、どうだった……？　あんま、よ\nく分かんないから……勢い任せだったけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そ、そっか、これだけ出したんだからな。まぁ、気持ちよく出来たんなら…\n…うん、よかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……開放的な気分の今だけ特別だ。へへっ……感謝しろよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「で……気のせい、じゃないよな……？　お前のチンチン……さっき以上にビ\nクビクしてるんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……分かってるよ。まだ、出し足りないって言うんだろ？　そんな期待に満\nちた顔をされたら、もうイヤって言えねぇよな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「てか、オレも……もっと、このチンチン……したいって思ってる……おっぱ\nいとチンチン……パイズリしたいって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まだ……先っぽに精液ついてるな……こいつをちょっと塗るみたいにして…\n…はぁっ、んっ……動かしていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んくっ……はぁ……あっ、精液……ねとねとだ……乳首にもついて……よく\n滑るな……ふっ、はっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレの汗も……？　あぁ、これだけ……カラダくっつけてりゃ、火照って…\n…出てくるさ……お前のチンチンの周りも……濡れてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んくっ、はぁっ……あっ、いい感じ……か？　うん……最初の時より……動\nけてる感じはする……やっぱり、大きく動かすのがいいんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぐにゃって……おっぱいが……形変わるの……自分でもやらしいって思う…\n…意識すると……恥ずかし過ぎるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぅ……んっ、それでなくても……ビキニ……気になるのに……あぁ、今は\n全部見せちまってるんだよな……オレ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ダメだ……考えたら……動けなくなる……んんっ、目の前のチンチンのこと\nだけ……考えて……そしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いいやっ、フェラしちゃえば……んっ、じゅぷっ、くぷっ……紛れるっ……\nんりゅっ、じゅぽっ、くぷっ、んぱぁっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぱっ……精液の味と……チンチンの味と……色々混じって…\n…はぁんっ、エロい味がしてるぅ……じゅぷっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「りゅぱっ……んふっ、チンチンがビクビクしてる……こ、こら……あんまり\n暴れたら……おっぱいからはみ出るだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「しっかり押さえて……はぁ、んっ……っくぅ……根本を……ぎゅぎゅって…\n…圧を掛ける……んふぅっ、くっ……はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、脈打ってるチンチンと……乳首とぉ……擦れまくって……ち\nゅぱっ、はぁ……りゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「熱い……あぁ……陽射しも強くて……汗……止まらない……はぁ、ちゅぱっ\n、んんっ……オレ……発情しちまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、なぁ……また出そうなんだろ……？　今度はどうした\nいんだ……？　また、飲ませてくれるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それとも……顔にいっぱいザーメンシャワー……浴びせる気なのか……？　\nちゅぱっ、んっ、あぁんむっ、りゅぱっ……どっちがいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレは……りゅぷっ、もう、どっちでもいい……お前のチンチンがいっぱい\n射精してくれたら……なんれもいいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「らからっ……んりゅぷっ、オレのおっぱいでイッてっ……また、ドロドロミ\nルクっ……いっぱい……らひてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ！　あぷっ……んぱっ……れてるっ……んんっ、こくっ、んくっ、\nんふぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、また……ヤバい勢い……こくっ、んくんっ……どんどん出\nて、口の中……広がるぅ……じゅるっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……生臭くて……ヘンな味なのに……んちゅぷぅ……もう、オレは…\n…この味がやめられないんだ……こくっ、んぐぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んふっ、んぶっ……くるひぃ……んっ、あ……れも、らいじょうぶ……ら…\n…ちゃんと全部……飲めるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こくっ、んくっ……んんっ、んっく……んっ、こくんっ……んふぁぁぁぁっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁ……どうだ……？　ちゃんと全部飲めたぞ……れろ……\nちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、何だよ、別にフツーのことだって……そんな、頭なんか撫でなくたって\nいいんだぞ……んっ……なんだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まぁ……イヤじゃないけどさ。ん……あぁ、待ってろ……後始末、ちゃんと\nしなきゃいけないんだろ……？　れろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……ん、出来たぞ。わ、分かったって……だから、頭は撫でなく\nても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くそ、何か子供扱いされた気分だぜ……今日は特別なんだからな、そこんと\nころ……分かっとけよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁっ！　んぁっ……はぁっ、んっ……顔っ……めっちゃ……掛かってる\nし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「どれだけ出してるんだよ……んちゅぷっ、ふあっ、まだ出る……んんっ、本\n気で……ぶっ掛けて来てる……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふはぁ……むわっとするぅ……ダメだってぇ……このにおい……オレ……冷\n静じゃいられなくなるんだってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……あぁ……チンチン……頬に直接ぅ……何でもいい……全部出し\nて……オレに塗りつけてぇ……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あふっ、んふぁ……はぁ……あぁ……やっと収まってきた……射精終わった\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ、はふ……えと、最後は……お掃除するんだよな……待ってろ、\nぴちゃ……んちゅ……れろ、ぺろ……んっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ほら、これでいいだろ、綺麗になったぞ……んっ、いいよ……オレがしたく\nてしたんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000412_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……でも、何か……随分思い切っちまった気がする……こんな、陽の光\nの下で……いくら誰も来ないからって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だ、誰か覗いてた……？　バカ、そんなこと言うなっ、大丈夫……大丈夫な\n筈だからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ビキニ戻さないと……ほらっ、もう終わったんだからなっ、ジロジロ見るん\nじゃないっ、このスケベ！」", "NORMAL" ]},
