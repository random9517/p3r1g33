{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おぉ……これが古より伝わる伝統の鎧の……何だか力が湧き上がってくるよ\nうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「くっ……まさかとは思いましたが、伝統の鎧というのがこんなにも下らない\nものだったなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん、選ばれなかった者の負け惜しみだな。この鎧の素晴らしさが分からな\nいとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「選ばれなかったワケじゃありません！　こんな恥ずかしい装備、こっちから\n願い下げですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶっちゃけ、今のお前が着てるやつとそこまで変わらんような気もするが…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「そこの何も分かってない変態は、黙りやがりなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おぐっ、ど直球の罵倒は割と効く……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「とにかくっ！　こうなったからには、そんな鎧など必要ないということを思\nい知らせてやるまでです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん、面白い。私も、ちょうどこの鎧の力を試してみたかったところだ。\n一勝負してみるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640003" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「この馬鹿げた島に来てからずっとイライラしていた所です。溜まった鬱憤…\n…晴らさせてもらいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「上等だっ、行くぞっ、どぅぅぅぅぅりゃぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「展開っ！　月光覇斬の陣！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「衝撃波の連続か？　面白いっ、薙ぎ払ってやるっ、そりゃぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふんっ！　野蛮そのものの動きっ……いろいろな奴を思い出させてムカつき\nますねっ、はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふんっ、はっ、やぁっ、そりゃぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まぁ、鎧だからさ？　実際のダメージがどうかとか、そういう感覚って\nのは本人にしか分からないものだと思うんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、何を言いたいのかは何となーく分かるのではありますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶっちゃけ、動きとか、戦い方とか……別に、あんまり変わんねぇよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ですから、例えそう思っても、こういうキーイベントでそれを言うのはタブ\nーですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ってことは、お前も薄々思ってるんだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まぁ、大体いつものルナテミス様……い、いえいえ、私には躍動し、相手を\n圧倒するルナテミス様の姿が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、それもなんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「くっ……このっ！　ひぁっ！　マフラーが……邪魔でっ……んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640008" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そらそらそらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「完全に、向こうがやりにくそうにしてるって言うか……まぁ、完全に相手の\nアレは恥ずかしがってる動きだよな？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「妙齢の女性の恥じらい……実にいいものですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「毎度思うけど、犬でもそういう感性あるのかよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「無論本命はメス犬ですぞ。しかし、男の浪漫はご主人の元、しっかりと理解\nしているつもりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「うぐっ……は、速く動くと……水着がズレそうで……だ、だから、なんでこ\nんな格好で戦ってるんですか、ウチは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640009" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうした、動きが鈍いぞ？　私のよく知る奴はもっとちょこまかと、すばし\nっこい奴だったがな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640008" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「くっ……誰と……比べてやがりますかっ……ウチは……ウチですっ！　式神\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640010" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふんっ……！　やっと動きがマシになったか？　なら、もっと本気を出さな\nいとなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640009" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……まぁ、プラシーボ効果なのかも知れないけど、とりあえず楽しそう\nではあるよな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「普段どれだけビキニな格好に慣れているか……そのビキニ熟練度の差が出て\nいますかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ビキニ熟練度ってなんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「来るか……！　ならばこちらはドラゴニック・ブラストっ……ブラストッ…\n…もう一発ブラストぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640010" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「闇雲に撃っても当たりませんっ！　発破っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022640012" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何か……派手な光弾が飛びかうバトルになって来たな……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですな……ですが、なかなかクリーンヒットはせずに壁が次々とダメー\nジを受けているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな……って、うぉっ、あぶなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「流れ弾がこっちにも飛んできてますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべぇ……見境がなくなってる……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くそっ、かなりちょこまかとっ！　ドラゴニック・ブラストっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640011" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……何となくイヤな音が聞こえているような気がしますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022640009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……っていうか、こんな古い遺跡の中で、派手な衝撃波が飛び交いまく\nってたら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まだまだぁっ！　続けて出すぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640012" ]},
		{"command":[ "SETCHARA", "0", "char_00000114_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい……ちょっと揺れがやばいぞ！　大技は使うなよ、ルナテミス！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「分かった！　これで決めるっ！　ドラゴニック・ビキニスラーーーッシュ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022640013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「思いっきり大技ァ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}