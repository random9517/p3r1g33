		{"command":[ "SETNAME", "ザ・ショットガンズ" ]},
		{"command":[ "SETTEXT", "「はぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "LEFT", "0" ]},
