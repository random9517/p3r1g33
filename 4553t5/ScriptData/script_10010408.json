		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……行くぞ、アナザー。試合が始まる。まずはマグナシアと……そして、決\n勝ではお前と決着をつける！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
