		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様……大丈夫なのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010104080001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ……エファナティカ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「案ずるな！　屁のツッパリはいらん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おお……！　言葉の意味はよくわからんが、とにかくすごい自信だ！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「さあ、いよいよ始まります、プリンセストーナメント本戦！　第一試合は、\n予選を勝ち抜いてきた１６人のプリンセスによるバトルロイヤル！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「優勝最有力候補との呼び声も高い、マグナシア・カイザー・ナックル姫をは\nじめ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「女性人気ナンバーワン！　限りなくプリンスに近いプリンセス、高円寺クリ\nス選手！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「見た目はお子様！　でも戦闘力は決して侮れないシロクマ姫！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「そして今回最大のダークホース！　友情パワーで並みいるライバルを撃破し\nてきた、ルナテミス選手とアナザー・ルナテミス選手によるタッグチーム！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「名付けて『ザ・ショットガンズ』！　この面々が、今回の注目選手といえる\nでしょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って！　呼び方変わってる！　『Ｗ（ダブル）ルナテミス』とかいうネーミ\nングはどこいった！　あと、友情パワーってなんだぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「落ち着けルナテミス！　ゴングが鳴るぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104080005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘッドホンプリンセス" ]},
		{"command":[ "SETTEXT", "「行くわよぉっ！　まずは、ザ・ショットガンズを仕留めてあげるわ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレーのプリンセス" ]},
		{"command":[ "SETTEXT", "「辛口でいきま～す！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "知恵の輪プリンセス" ]},
		{"command":[ "SETTEXT", "「私の知恵に勝てるかしら！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「来るぞ！？　アナザー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
