		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「な、なに！？　私、今忙しいんだけど！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104080001" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ここは、私たちもチームを組みましょう！　タッグチームと戦うには、それ\nが一番です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104080002" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「ルナテミスたちと、ってこと？　それは……たしかにいい考えかも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104080002" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「では決まりですね！　行きましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104080003" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「むっ！？　おいアナザー！　クリスとシロクマ姫も手を組んだようだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080010" ]},
