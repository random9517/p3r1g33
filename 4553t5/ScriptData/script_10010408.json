{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0049" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ヘーイ……マグナシア……ドッチガセクシーダイナマイトカ、勝負シマショ\nウ……ウフフ……ファイト、ファイト……トッテモタノシイネ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080001" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　しっかり！　最終予選に勝ったんだよ！　もうすぐ本戦の試\n合が始まるんだよ！　お願い！　気をたしかに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104080001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「スリーサイズはともかく、体重、体脂肪率まで観衆の前で発表されたショッ\nクが、かなり尾を引いているようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010104080001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「おまけに、多元宇宙に生中継されているんですものね。それはダメージも大\nきいはずです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010104080001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「頼みますよ、しゃっきりしてくださいよ、姫様……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まずいな。このままじゃルナテミ――いや、賞金が……。", "NORMAL" ]},

		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「さあ、スタジアムの方では、間もなく始まる本戦の準備が始まっているよう\nですが――おっと！？　これはなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「ああっと！　リングです！　スタジアムの床から、リングがせりあがってき\nました！　そして、リング中央には大会委員長が――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "大会委員長" ]},
		{"command":[ "SETTEXT", "「本戦第一試合、種目を発表します！　『どっきり！　王女だらけのバトルロ\nイヤル』！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「おおーっと！　第一戦は１６人のプリンセスが入り乱れるバトルロイヤル！\n　王族だけにバトルロイヤルだーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべえやべえ！　もう、試合の準備始まってるぞ！　ちょっと姫様！　頼む\nから立ってください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうだよ！　ルナテミス！　このままじゃ試合放棄になっちゃう！　そんな\nの嫌でしょう！？　だからお願い！　立って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010104080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　もう一度立ち上がれ、ルナテミス！　マグナシアを倒し、この私\nと決着を付ける気があるのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104080001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「立て！　立つんだ、ルナテミスーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0050" ]},
