		{"command":[ "SETNAME", "三人のプリンセス" ]},
		{"command":[ "SETTEXT", "「きゃああああ～っ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「ザ・ショットガンズの見事な連携攻撃！　ライバル三人を、まとめて脱落さ\nせたぁ～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「なるほど……さすがですね。シロクマ姫さん！　ご相談があります！」", "NORMAL" ]},
