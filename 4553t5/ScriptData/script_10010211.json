		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「グワーーーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102180001" ]},
        {"command":[ "SETCHARA", "0", "char_00014501_01", "3", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「うむうむ！　よくやったぞ、みんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「待って。マッポーサムライがいない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「たしかに……姿が見えない。もしかして、今ので吹き飛んだのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ううん。爆発に紛れて逃げたんだと思う。いつものやり口だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「たぶんあいつ、まだこの世界をあきらめてないね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……迷惑な話ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "まったくだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「に、しても！　おまえら、なかなかやるじゃん！　あそこまで戦えるとは思\nってなかったぜ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "097_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あんたらもな！　けっこう強いじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「えへへっ！　だって、ここで勝ったらスシ７割引きだもんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だよねー！　ねえねえ！　さっそくみんなで食べに行こうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うん！　あ、でも、ちょっと待って！　そのまえに締めないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180003" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「締め？　なんの話だい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしら、いつも事件を解決すると４人で締めてんの！　あ、そうだ！　よ\nかったら、みんなも参加して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102180003" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふ、面白そうだな。では、その締めとやらに参加させてもらおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ありがと！　それじゃ、さっそく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「本日の白洲はこれまで！　これにて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0031" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "全員" ]},
		{"command":[ "SETTEXT", "「一件落着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_910102180006" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「一同のもの、立ちませーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180007" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},		
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「イェーイ！　今回もクールに決まったぁ！　それじゃさっそく、スシ食べに\nいこー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おう！　いこいこ！　あそこの回転寿司屋、エビフライの握りとかあるんだ\nよなー！　私、あれ好きなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180008" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしは玉ねぎサーモン食べたいなー！　マヨと玉ねぎがサーモンに合うん\nだよねー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「寿司もいいが、サイドメニューでタコ焼きやから揚げもあるはずだねえ。私\nはそれをつまみに、一杯やるかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ひいいいいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102180006" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……って、どうしたのだ？　貴様たち。さっきからおかしな声を上げて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だ、だって……！　あなたたち、ちょっと趣味が悪すぎ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ？　どういうことだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102180003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だからー！　スシで揚げ物は邪道でしょ－！？　許されるのはアボカドとロ\nーストビーフまで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んだとぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それに、サーモンにマヨはありえねえだろ！　ソイソースとワサビの立場が\nねえじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なに言ってんの！？　おいしいんだよ！？　あれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あとさー、サイドメニューはやっぱり、甘いものがいいと思うんだよねー。\nあるいは茶わん蒸しとかー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102180007" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　それじゃ酒のつまみにならんだろうが！　そもそも、人の好みに\nケチをつけるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102180004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だからって！　いくらなんでも限度があるでしょー！　私たち、スシにはす\nっごくこだわりがあるんだからー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102180006" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だーっ！　もう頭に来たっ！　お前らなんかと、寿司食いに行けるか！　７\n割引クーポンは、全部こっちでいただく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ちなさいよ！　それとこれとは関係ないでしょ！？　クーポンは\nよこしなさいよ、クーポンは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010102180009" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うるさいね！　お前らに食わせる寿司はないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010102180005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「なんだとてめぇ！　やんのか！　いざ、カマクラ―ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102180006" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「まったく、あの子たちときたら……。いや、お恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、こちらの連中こそ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、こんなことになるんじゃないかとは思ったけどな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これというのも隊長であるご主人の、不徳の致すところですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、てめ！　どっから出てきた！　さては、またどっかで日和ってやがった\nな、この駄犬！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「日和ったとは心外ですな。わたくしは皆さんの戦いを見届け、今後の教訓と\nして記憶に残そうと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010102180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいかげんにしやがれ！　このアホ犬ーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
