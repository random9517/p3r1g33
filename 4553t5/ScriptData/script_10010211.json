		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さすがに、人選ミスだった気がしてきた……隊長もメンバーも……」", "NORMAL" ]},
