{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "095_0103101" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……アタイを呼び出すたぁ、いい度胸じゃねーか。ああ！？　まさかここで\nアタイとタイマンてつもりじゃねーだろうなぁ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103102" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……ふん、わーってるよ。テメーは一応ヘッドだからな。言うことを聞いて\nやるよ。で？　何させよーってんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103103" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……奉仕、だと？　それ、エロい意味……だよな？　テメー……マジで言っ\nてんのか？　なんでアタイが、旧人種の哺乳類なんかと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103104" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ああ！？　ビビってねーよ！　やらねーなんて言ってねーだろうがっ！　ナ\nメたことヌカすとブッ飛ばすぞ、テメー……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103105" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「で、何をどーすりゃいいんだ？　……アアン！？　口でチンポをしゃぶれだ\nとぉ！？　なんで、そんなことしなきゃなんねーんだよぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103106" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ああ！？　気持ちいいから……だとぉ？　くそっ……これだから哺乳類の旧\n人類はバカでオロカでクソなんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103107" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ま、待て……やらないと言ってねーだろう！？　テメーはクソだが、ヘッド\nだからな。命令なら仕方ねー……やってやんぜっ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103108" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……けど、他のオンナにも、こんなことさせてんじゃねーだろうなぁ……？\n　はぁ？　やらせてるに決まってるだろう、だとぉ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103109" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「くっ……とんでもねーヤローだぜ……ま、まあいい。アタイが旧人類と違う\nミュータントだってこと、思い知らせてやるぜ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103110" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ほら、チンポこっちに向けな！　って……結構グロいな……哺乳類のチンポ\nって……よ、よし、それじゃあ始めるぞ──はぁぁぁむ」」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103111" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「んぐ、むぐ……れろ、れろれろ……変な匂いがすっぞっ……なんだ、コレ…\n…は？　これがチンポの匂いだと？　くせぇな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103112" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ねるれる、ぴちゃ、れるる、んちゅ……アタイはサメ育ちだからな、鼻が効\nくんだよ。ねろねろ、れる、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103113" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ぬちゅ、れろん……はぁ、ふぅ……知らねーのかよ？　サメは一滴\nの血でも数キロ先から匂いを嗅ぎつけんだよ……れる、ねろん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103114" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「海水浴をする時には気をつけな……空腹のサメが数キロ沖から狙ってるから\nな……ぴちゃぴちゃ、れろ、れるん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103115" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「で？　どうなんだ？　れろれろん、ぬるる……アタイの舌使いは……んちゅ\n、ちゅぬる、れろ、れろれろ……」」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103116" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ？　変な感じだ……だとぉ！？　ねろ、んれろれろ……ったりめーだ！\n　アタイはミュータント……旧人類のサルどもと一緒にすんじゃねぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103117" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ねろ、れろれろ……口がサメになってんだから、違ぇのは当たり前だろう？\n　ねる、ねろねろ、れろ……文句言うなってーの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103118" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ？　文句言ってない？　褒めたつもりだと？　はっ。調子の良いこと言\nってんじゃねえっての……まあ、続けてやるけどさ……れろれるれる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103119" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はむ、んちゅ……ねる、れろれろ……ああ？　なんだよ、チンポがビクビク\nしてやがんぞ……はぁ？　歯が当たってビックリする……だと？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103120" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「へっ、いちいちビビってんじゃねーよ……んぁぁむ、ねろねろ、にゅるにゅ\nる、ちゅぼ、じゅるじゅるちゅちゅぅ……はぁ、ふぅ……」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103121" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ぬるる、ねるれろ、ちゅちゅぅ……それで？　これ、どーやったら終わるん\nだよ……ねる、れろ、れろれろ、ちゅるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103122" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「なんだと？　射精したら終わる……？　バカにすんじゃねーよ！　射精とか\n精液とか、一応知ってるっての！　ねろ、ねろねろ、れるん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103123" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅちゅる、れろ、れるん……はぁ、ふぅ……卵に白いの、ぶっかけ\nるんだろ？　交尾なんて見慣れてるってーの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103124" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「え？　魚類と哺乳類じゃ生殖方法が微妙に違う……だと？　んなことわかっ\nてるってーの……れろ、れるれる、ぬるん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103125" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はむ、んれろ、んちゅ、ちゅるる……あふぅ、アタイをバカだと思ってナメ\nてんだろ……まあ、実際バカだけどよぉ……ねろれろ、にゅるう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103126" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「と、とにかく、このまま続けていいんだな？　わかった……ねれれる、ちゅ\nるる、ぴちゃ、ぴちゃ、くちゅ、にゅるれろん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103127" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はむ、むぐむぐ、じゅぶぐちゅ、れろ、ちゅちゅぬるぅ……はぁ、ふぅ……\nなんだ？　気持ちいいだと？　そりゃよかったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103128" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「口の形が違うから、新鮮だ、だと？　ふん……こんなことのためにミュータ\nントになったわけじゃねーんだけどよ……れる、れるれろ、ちゅちゅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103129" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「んぐぅ、んぶぅ！？　ん、んん……なんだ？　ビクンビクン、してっぞ……\nはむっ、んちゅ、ぬるぬる、れろん……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103130" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ？　イク？　出す？　なっ、なんだかわかんねーけどこのまま続けっぞ\n……ちゅる、れろ、ねろねろ、にゅるじゅるれろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103131" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「んん！？　口の中で、硬く、デカくなって……んっ、んんっ、じゅぶれろ、\nちゅるちゅる、くちゅじゅるぅ……ねろぬるる、れろん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103132" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「れろ、れるれる、んちゅちゅる、じゅぶくちゅ、ずるずる、ちゅちゅずるじ\nゅるぅぅ……ん、んん！？　チンポが震えてる……ん？　んんぅ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103133" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「おぶっ！？　げほっ、おえぇぇっ……て、テメー……なんだ、こりゃぁ……\nこ、これが、精液……？　ん、んんん……ゴクン……ゴクゴク……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103134" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はふぅぅ……はぁ、はぁ……うえぇ、変な味……匂いは……んん、くせー…\n…けど、それほどでもねぇな……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103135" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「んぐっ……んっ、んん……まだ、出る……ゴク……ゴクン……んん、はぁ…\n…はぁ……んん～～……うぇぇ、喉にひっかかる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103136" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ってか、どーいうつもりだよ……はぁ、はぁ……産卵……いや、妊娠させる\nためにぶちまけるんじゃねーのかよ……ったく……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103137" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ああ？　気持ち良かった……だと？　くそ……間抜けな顔\nしやがってぇ……ムカつく野郎だぜぇ……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103138" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「で？　もうお仕舞いか？　はぁ、はぁ……そーか……それならいい……った\nく、こんなことで、ホントにパワーアップするんだろうな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103139" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「間違いなくパワーアップする……だと？　ふん……こんな簡単なことで、強\nくなれるとは全然思えねーけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0103140" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「…で？　続きは……？　はぁ？　これで終わり？　ちっ……まあいい……ま\nた付き合ってやっていいぞ。また呼べよ！　わかったな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}