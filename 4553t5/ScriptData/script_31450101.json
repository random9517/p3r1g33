		{"command":[ "PLAYVOICE", "145_0103101" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「拙者と勝負したいなどと言うから来てみれば……おのれ！　騙したな！　」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103102" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「何、そうではない？　お主と拙者……ど、どちらが先にイクか勝負ぅ……！\n？　い、いいだろう。そんな勝負、聞いたこともないが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103103" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「負けはせん。お主はその、あれだ。い、一生懸命……手を休めず、あ、あれ\nだ。それを触って……うっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103104" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うるさいっ！！　見て分からんか！？　初めてだ！！　男とセックスなどし\nたことがあると思うか、拙者が！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103105" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「う……は、恥ずかしいぃっ。なんて恥ずかしいことを大声で……ば、馬鹿者\nっ！　人並みに恥の概念ぐらい持っておるわ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103106" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「くっ、どうして拙者がこのような阿呆に……ま、まあいい、とにかくすれば\n良いのだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103107" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「勝負だからな……せ、せーのでいくぞ？　よし……はじめ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103108" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うぅ、くっ、くぅぅ……ん、んんっ。やめろ、拙者を見るな馬鹿者ぉっ……\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103109" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ふぇ……！？　おっぱいが綺麗……！？　ややや、やめろ、そのようなたわ\n言を……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103110" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うぅ、本当に……だと？　っ……！！！！　お、オマンコもだなんて、見る\nなぁ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103111" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「遊んでないから綺麗なピンク……？　言っておることが分からんが、普通は\nこんな色ではないのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103112" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うぅっ、くっ、んんぅ、何……もっとおっぱいを揉めというのか？　不公平\nだと？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103113" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「こうか？　こうすれば……あぅん！　んっ、んん！　いいのか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103114" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ち、乳首も……いや、ここはいいだろう。ここは勝負と関係ないはずだ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103115" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「逃げてなどおらぬ！　良かろう、乳首など触ったところですぐに絶頂など…\n…くっ、ん、んあぁ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103116" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「か、可愛い……！？　可愛くなどなーい！！　せ、拙者が可愛いわけないだ\nろー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103117" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「とっとにかく、次に可愛いなどと言ってみろ、その……しごいてるアソコ、\n蹴ってやるからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103118" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「えっ……な、名前ぐらい知っておるわ、そ、そのぉ、おち……オチンチン、\nだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103119" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「うぅっ、お主……拙者が恥ずかしがる顔を見て楽しんでおるのではあるまい\nな……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103120" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「手が止まっているぅ！？　お主だって、さっきからスローペースになってお\nるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103121" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「や、だから乳首はそんなに強くしちゃいけないんだって本当に……お手本？\n　やめろ、触るな……んああぁぁ！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103122" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「つ、つまんだりこねくり回しっ……たりぃ、やめ、やめやめ、やめっ……！\n　ダメぇぇ……んああぁぁん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103123" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁーっ、はあぁ、これぐらいしないと認めない……だと？　うっ、うぅ…\n…分かった」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103124" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「こう、だな？　乳首をくりくり弄って……やぅぅ！？　い、弄ってぇ……\nはぁー、はあぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103125" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「おっぱいごとこねくり回して……ふあぁー、はぁぁ、な……はぁぁ！？　オ\nマンコをもっといじれ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103126" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やめろっ触るな！　お手本などいいから、やんっ……！？　あぅぅぅ！？　\n指ぃ入れるなぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103127" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「クリトリス、も……いじめろ、だなんて……こ、こんなの拙者の方が不利で\nはないかぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103128" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁー！　はあぁ！　い、いいだろう……それでも勝つのは拙者だ、くぅぅ\nん……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103129" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「乳首ぃ……あぅぅ！　オマンコに指ぃ、はぅぅ！？　く、クリトリス……は\nひぃぃ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103130" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「こっ、これでいいのだろう……はぁー！　はぁぁ！　ど、どうした……お主\nのオチンポも心なしか限界に近いようだぞ……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103131" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「な、何？　本当に限界……？　精液がびゅっびゅって出て、拙者のカラダに\n……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103132" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「そんなことをしてみろ、お主の……お、お主のぉ……ふあぁ、はあぁ、くぅ\nぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103133" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「そっちより先にイク、ものか……イクッ……んあぁぁ！？　あくぅ、んああ\nあぁぁ…………！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103134" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「い、イッたか、だと？　イッてなどおらん……おらんのだ！　やっ……オチ\nンチンがビクビクしてる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103135" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ひゃううぅ！！？　あ、熱い……これが精液……？　んあぁぁん、なんてい\nやらしい匂いをして……おるのだ……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103136" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「やっ、やめろ！　いま触られたら……あっ！　やめ……！　ああああぁぁ～\n～～～っ！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103137" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、た、確かに拙者の負けだ……さ、先にイッておった……だが\n次は決して負けん！　え、今すぐ勝負の続き……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103138" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「ふああぁぁ……ま、またオチンポ大きくなってきてるし……お主、バケモノ\nか？　拙者が可愛いから勃ってきた……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103139" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「また可愛いって言ったな！　可愛くない！　強くてかっこよくてりりしいの\n！　ううぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "145_0103140" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「な、泣いてなどおらん！　しょ、勝負の続きだな……次こそは、その……負\nけないんだから……な？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}