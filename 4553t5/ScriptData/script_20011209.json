{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ジャングルで鳴らしたカツマたちビキニバズーカ隊は、目的のデータを回収\nしたが襲来者（インベーダー）に見つかり、脱出して廃墟に逃れた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021440001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「しかしいつまでも隠れてる彼女たちじゃない。おだてればなんでもやっての\nける命知らず。不可能を可能にし、巨大な敵を粉砕する彼女たち――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021440002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「特攻娘、ＢＢチーム！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021440001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "7", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "7", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "7", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、なんか言ったかおまえたち！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「いーえ、なんにも？　気のせいじゃないスか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「そんなことよりアーニー！　弾持ってきてアーニーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「装填しました！　敵は７時方向です！　外さないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「外さないわよ！　あいつら、動きがのろいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021440003" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言ってアディーがバズーカをぶっ放すと、そのあたりに固まっていた襲来\n者（インベーダー）たちがまとめて吹っ飛ぶ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はい、命中！　ホント、戦争は地獄よね！　ふぅはははははーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021440004" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……アディーが怖いぐらいノリノリだ。しかし、彼女の奮闘にもかかわらず、\nこちらはどうも分が悪い。それというのも……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「東風！　宵待！　そっちはどうだ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「ダメです……！　どうしても見つけられなくて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「あの塔のあたりに潜んでるのは、間違いないんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あのあたりに、敵の狙撃手が潜んでいるが、どうしてもあぶり出せない。そろ\nそろ弾丸の残りも厳しくなってきたことだし、無駄弾は撃てない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし……しょうがねえ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長！？　どこへ行くんです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺がオトリになる！　あいつが撃ってきたら、そこを狙ってぶち込め！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ダメです！　危険ですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからって、このままじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そうだね。このままじゃ身動きが取れない。隊長に、あいつを釣り上げても\nらうしかないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021440002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんな……！　隊長を犠牲になんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021440003" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「誰が犠牲にするって言ったよ。あたしが一緒に行く」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021440003" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「隊長、あたしが走ったら走れ。伏せたら伏せるんだ。そうすりゃ生き残れる\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、しかし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あんたひとりを危険な目にあわせやしないよ。あたしたちはＢＢ嬢。生きる\nも死ぬも一緒だ、そうだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021440005" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……そうだったな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ふっ……わかってんならいいさ。いいか、走るぞ。あたしにくっついて、お\n魚くわえたドラ猫みたいに走れ。いいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021440006" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わかった！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「それじゃ行くよ！　ゴー、ＢＢ嬢！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021440007" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ホントなら感動的なシーンのはずなんだが、どうもこのかけ声がなあ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「昨日の夜、すべてをなくして湿地の泥にまみれていた。今日の夕方、命を的\nに廃墟で敵を追っていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021440003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「明日の朝、ちゃちな信義とちっぽけな好感度が、瓦礫の街に渦を巻く。ここ\nはパロディネタのおもちゃ箱。怒られなけりゃなんでもやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「次回『戦火の勇者』。次のイベント、そんな先のことはわからない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021440005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "EXIT" ]}
	]
}