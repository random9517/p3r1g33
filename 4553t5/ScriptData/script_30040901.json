		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「う、うんって……そんな真顔で頷くとこじゃっ……な、なんか恥ずかしいだ\nろっ！」", "NORMAL" ]},
