{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「う……うぅぅーっ……こ、これで……いいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「バ、バカっ……恥ずかしいに決まってるだろっ……バレンタインの衣装が見\nたいとか……調子のいいこと言っておいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「結局、見せてるのって……これ……普通に……お、お尻じゃんか……しかも\n、そんなにじっと覗き込むようにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ……ムッチリしてるとかっ……んんっ、い、言うなぁっ……\nへ、変態めぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「み、魅力的……だ、だからって……そーいう風に言うのもっ……な、なんか\n恥ずかしいしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅぅーっ……お前はいっつもそうだ。私を恥ずかしがらせることばっかし\nて……それで……あっ、うぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほ、ほらぁ……も、もうそんなにチンチンを大きくさせてぇっ……な、何見\nせつけてるんだぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「う……何にもしてないのに……めちゃくちゃ大きくなってるじゃんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あれか……？　私のお尻を見て……そんなに……興奮したのか……？　そ、\nそうか……そうなんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わ、分かったって……ちゃんとチンチンの面倒を見ろって言うんだろ……？\n　いいよ……して、やるからさ……どうすりゃいいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んなっ……こ、この格好のまま……足で……しろってのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「別に……出来なくはないけどさ……足で……チンチンを擦れってことだよな\n……？　お前って……ホント、変態だよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「コレくらい普通……本当か？　私があんまり知らないからって適当なこと…\n…あぁっ、いいよっ、分かったからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、しょ……こ、こういう風に……足で……挟んでやればいいんだよな…\n…？　んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それで……このまま、足を動かして……んっ、チンチンを……擦ってやる…\n…ふっ、はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こんな、感じか……はっ、んふっ……ちょっとコツがいりそうだな……んっ\n、ふっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903116" ]},
	    {"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぁっ……ま、まだ大きくなる……めちゃくちゃ……チンチン勃起してる…\n…んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ストッキングで擦られる感じがいい……うぅっ、なんかいちいち言うことが\nキモいぞ……こっちはなんか変な感じだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「でも、気持ちいいんだ……こんな風に、足で……チンチン弄られて……ふっ\n、んんっ……感じてるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、別に……キツくはないぞ。体は鍛えてるからな……これ位のポーズは\n平気だ……その、は、恥ずかしいのは恥ずかしいけどな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もっと強くしていいのか？　分かった……しっかりチンチンを捕まえて……\nこうして……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んぁっ、ぬちゃぬちゃ言ってる……何だよ、これ……もう我慢\n汁……出してるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私のお尻を見て……そんなに興奮するなんて……全く、本当に仕方ないやつ\nだっ……はっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふるふるっ……揺れるのがっ、エロい……お、お尻がかっ……だ、だから、\nそういうことは言わないでいいんだってばっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぅっ……んっ、このスキモノめっ……いいさ、せいぜいいっぱい見とけば\nいいっ……ほらっ、ほらぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、ぬ、濡れてる……？　あぁっ……んっ、ホ、ホントだ……私\nも、いつの間にか……濡れて、来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だって……これは、お前のチンチンが気持ちよさそうにしてて……んっ、皮\nのところ……ぐちゅぐちゅしてるうちに……ドキッとして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はんっ……だから、一緒だ……んっ、お前のチンチンと同じ位に……私の…\n…オ、オマンコも……興奮してるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……それを……こんな格好で……ああ……間近に覗かれてぇ\nっ……はっ、んぁっ……ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もっと激しくして欲しいのかっ……んんっ、仕方ないやつだっ……こう、だ\nろっ？　チンチン……こうされるのがいいんだろっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、分かるぞっ……ぐちゅぐちゅが大きくなって……チンチンが嬉しそ\nうにしてるのっ……分かるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほらっ……お尻……見たいんだろ……こうしてっ、上下……左右に……フリ\nフリするのがっ……いいんだろっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そ、そりゃあ……恥ずかしいのは恥ずかしいけどっ……けど、それでお前が\n興奮してくれるのは……う、嬉しいと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「とにかくっ……もっと強くチンチンッ……シコシコしてやるっ……んんっ、\nはぁっ、指先に力を入れてぇ……先っぽ、ぎゅって握ってっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ビクビクしてるっ……チンチン、もう出そうなのかっ？　んっ、い\nいぞっ、そのまま出しちゃえっ……はっ、んふっ、あっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁっ！　あっ……出てきたっ！　ドロドロしてるのっ、足にっ……\nあっ、掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ……ふぁ……すごい量……太もも……ベトベトにさせられてるぅ……ん\nふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「噴水みたいにビュルって飛ばして……そ、そんなに良かったのか……んっ、\nふぅっ、はぁっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……ストッキングにも染みてきてる……ホントに好きなだけ出\nしてくれたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「まぁいいけどさ。それだけ気持ちよかったってことなんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……うぁ……結構出したよな……なのに、全然……小さくなってないぞ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「というか、前よりなんか大きくなってないか……？　気のせいか……？　や\n、やっぱり気のせいじゃないよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「う……わ、分かってるよ、そんな目で見ないでも……続き……して欲しいん\nだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「全く……ずっとお尻も見たままだし……どんだけスケベなんだ、お前は……\nほ、ほらっ、行くぞっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……んくっ、さすがに……一回出したから、まぁまぁ敏感になってるみ\nたいだな……はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンが……ヌルっとして、滑りやすくなってる……ちゃんと指先を引っ\n掛けてやらないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もっと、深く食い込ませるのがいいのか？　分かった……こうして、ぎゅっ\nと……こ、これ……痛くないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「これ位……食い込ませるのが……少し痛いけど……気持ちいいのか……んっ\n、分かったぞ……強すぎたら、ちゃんと言えよな……ん、ぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふっ、あぁ……精液が滑る……はぁ……んんっ、足でぐちゅってする\nの……こ、これぇ……いやらしいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「何だか……私もからだ……ポカポカして……はぁぁ……んっ、ますますエッ\nチな気分になって来てるぅ……はっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お前のチンチンも……そうなってるんだな……こうして、足の指を食い込ま\nせてっ……ぐにぐに弄るとっ……ほらっ、震えてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、私のお尻を見て……こんなにチンチン震わせて……本当にスケベなヤ\nツ……ほらっ、こうして揺らされるのがいいんだろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……あふっ、いいぞ……見てっ……お尻……フリフリしてる\nところっ……見て……いいからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……私もっ……はんっ、止まらないっ……チンチン扱くのっ…\n…あぉっ、止まらないっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……私っ……凄いことしてるっ……いやらしいポーズでっ……\nお尻っ……振りまくってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ビンビンのチンチンをっ……何度も扱いて、んくぅっ、そんな気持ちよさそ\nうな顔……されたらっ、もっとしてやりたくなるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、汁がまた浮いてきてるのかっ？　はぁっ、んっ……また射精\nしたいんだなっ？　分かったっ……いいぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「このままっ、出すまでっ……思いっきりしてやるっ……チンチン気持ちよく\nしてやるからっ、あっ、ふぁっ、はっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほらっ、出したくなってるんだろっ？　好きなだけっ……どこでも掛けてい\nいからぁっ、あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もう一回っ……思いっきりっ、全部……出せぇっ……あっ、ひぁぁぁぁぁっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁぅっ！　あっ……また……掛かってるっ！　足にっ……太ももっ、熱\nいのっ……また出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ウソだろ……あんなに出してたのに……まだ、あっ、そんな量出しちゃうの\nか……はぁ……どんどん出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……べとべとだ……うぁぁ……精液が……どんどん染み込ん\nでいってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、も、もうこうなったら……全部出してくれ……んっ、そうだ\n……チンチン……太ももに押し付けて、精液擦り付けてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルしてるの気持ちいい……はぁ……んふっ、あぁ……また出たっ……\nんんっ、あっ……べっとりしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はふぁ……収まったのか……？　ホントに遠慮なく出したよな……少し足が\n疲れたぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「でも……結局、衣装が見たいとか言って、見てるのはずっと私のお尻ばっか\nりだったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふん、知ってるよ、そーいうやつだってのは。まっ、私のお尻は魅力的だか\nら見とれるのもしょうがないけどなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「う、うんって……そんな真顔で頷くとこじゃっ……な、なんか恥ずかしいだ\nろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ったく……仕方ないやつなんだからな……全く……本当に困ったやつだ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁぅっ！　あっ……また……掛かってるっ！　あぁぁっ、お尻っ……直\n接掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……びゅくびゅくっ……溢れてぇっ……私のお尻っ……ドロドロに\nなってるっ……あぁんっ、取れなくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁっ……ふっ、精液のにおい……すごい……あぁ……私も……こ\nれ……イ、イッてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルしてるの気持ちいい……はぁ……んふっ、お尻……変な感じになっ\nてるの……けど……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……全部出しちゃえ……下手に残したりしないで……お尻にチンチンつ\nけて……精液……塗りつけてくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はふぁ……あぁ……終わったのか……？　んっ、あぁ……べっとりだ……本\n気でマーキングされちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お前……ホントにお尻好きだったんだな……衣装とか結局全然見てなかった\nだろ……ずーっと視線が同じとこでバレバレだったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0903407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふん、知ってるよ、そーいうやつだってのは。まっ、私のお尻は魅力的だか\nら見とれるのもしょうがないけどなっ」", "NORMAL" ]},
