		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ま、また次っ？　し、知らないっ……！　まっ、どーしてもって言うならっ\n？　ちょっとだけ、考えとく……」", "NORMAL" ]},
