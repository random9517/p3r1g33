{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーら、こっち。こんだけ離れたら、もう祭りの客も来ないから寝っ転がっ\nても大丈夫だし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まーったく、そこまで強くもないのに、ガブガブビール飲むから。ホラ、ヤ\nムのヒザの上……安心するっしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はいはい、分かってるし。他の幹部から、色々イジめられて、ストレス溜ま\nってるってんでしょ？　聞いてる、聞いてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もう……分かってくれるのはヤムだけとか……調子いーこと言っちゃって…\n…そんなにヤムに甘えたいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……いーよ、そんなに甘えたいなら……ヤムに甘えても……。ま、まぁ、今\n日はお祭り……付き合ってくれたし？　特別っていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……しょ……ほら、おっぱい見せたげるから……元気出しなさいよ、パ\nパ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちょっ……そんなガバって起きないの！　分かりやすくがっつき過ぎっ！　\nてかっ、ホントに元気にさせてるのなんなのっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……あぁー、まぁ……確かに？　ヤムのおっぱいで興奮するのは……ムリな\nいけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「前……めっちゃ膨らませてるじゃん……。じゃあ……こういうの……どう…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……ヤムの尻尾で……チンポ……シコシコ、してあげる……んっ、ふっ\n……どう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「わ……めっちゃ反応するし……ふふーん、どうなの？　ヤムの尻尾……結構\nチクチクすると思うんだケド……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「へぇ……それがアクセントみたいに思っちゃうんだ。なるほどね……んっ、\nこんな感じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「わっ……ビクビクしてるし……ふーん、やっぱり敏感だし……触られるの、\n大好きなんだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっしょっ、んっ……いーよ、もっとシコシコしちゃうから。んふっ……こ\nんな外なのにチンポガチガチにさせて……仕方ないパパなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ね……パパ……んっ、こういうときは……おっぱい吸いたいんでしょ……そ\nんな、おっきくないけどさ……ひゃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「こ、こらっ……がっつくなって！　甘えさせるって言ったケド、そんな強く\nしたらやめるからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んもう……ほら、ゆっくり吸えばいいの……全く……何でヤムにそこまで言\nわせるの……ダメダメでしょ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、そうそう……んっ、ちょっとヘコんでるけど……ちゃんと吸ったら\n……出て、くるし……あっ、そのミルクは出ないケド……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「分かってる？　ホントに……？　じゃあ……続きしたげるし……んっ、ふっ\n……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ホントにチンポ気持ちよさそう……ふふん、マジでカラダはしょーじきって\nやつじゃんね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、ついでに……こっちの方もイジったげる……パパの乳首……けっこー\n敏感なんじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、ピクってした……やっぱり、ヤムの爪が結構効くんだ。ほれほれ～ふ\nふっ、ここがいーのっかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ……！　まーた、おっぱい強めに吸うし～。んっ、でも、今くらいの\nは……へーき、かな……んっ……は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「なら、お返しに……んっ、ぎゅうって……ほぉらっ……くちゅくちゅー、し\nこしこー、こりこり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どう……？　んふっ、チンポ……どんどん膨らんでるね……息も……ちょっ\nと荒くなって来てるじゃん……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「は？　ヤムも……？　んっ、別に……ヤムは……んんっ、普通……位……だ\nし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「でも、ちょっと……いい感じになってるカモ……んっ、だって……ヤムの尻\n尾コキで……パパ、興奮してるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そーいう気分って、やっぱ伝わるし……なんか、もっとしてあげたく……な\nんて思ったら……結構、んっ、クルかも……あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぁっ……ナニ、舌……使ってんの……んもうっ……マジ、イタズラ好き過\nぎだし……は……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そういうイタズラっ子には……せやっ……んっ、ほれぇ……こうだしっ……\nふふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほーら、尿道のトコ……めっちゃ敏感でしょー？　チンポが気持ちいい～っ\nて、分かりやすく跳ねてくるしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「このままシコシコし続けたら……んふっ、びゅくびゅくって……出ちゃうっ\nしょ……チンポからせーえきぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……いーよ……どうせ、もう我慢なんて出来ないんだし……思\nいっきり出しちゃって……いいんだから……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、このビクビク震えてるチンポから……パパのザーメン……思いっきり\n出しちゃうのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、ヤムの尻尾コキで……いっぱいっ、出しちゃえっ……んっ、\nふぁっ、あぁっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！　あっ、出た出たっ……んんっ、ひぁっ……めっちゃ飛ばして\n来るんですケド……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁぁ……尻尾……ドロドロになってるし……ガチじゃんこれ……すごい量\n出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ナニ……どんだけ溜めてたワケ……？　気持ちよくなりすぎ\nでしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ……止まった……はぁ……すご……ヌルヌルする……パパのにおいするし\n……くんくん……んふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どう……ヤムも、ちゃんと甘えさせてあげられたっしょ？　パパも、少しは\n元気出たんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ……そっかぁ、めっちゃよかったんだ。それで、まだチンポ……全然\n収まってないってコト？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あー、ベツに言い訳とかしなくていいし。パパがドスケベで、節操なしのチ\nンポってコトは今更言わなくても知ってるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だから……まだ、甘えてれば？　ちゃんともう一発分の射精の面倒くらい…\n…見てあげるし……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はっ、おっぱい？　言っとくケド、どんなに吸っても、ミルクとか出ないか\nら。それでもいいなら、まぁ……このままでいいケド……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……分かった、分かったから……心配しなくてもおっぱいは逃げないか\nらっ、ったく、どれだけストレス溜まってたんだか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「こーいうの、何て言うんだっけ？　ヤムがいないとダメになるタイプみたい\nなの……んっ、夢中でちゅぱちゅぱしちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……元気出しなさいよ……ヤムが、もっとチンポも扱いてあげるから…\n…尻尾……すっかりハマっちゃってるみたいだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、もう乳首めっちゃコリコリじゃん。いっぱいイジられて、チンポ\nと連動するみたいに震えてるし……かーわいいのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほぉら……よしよし……チンポ、気持ちいーでしょ？　こんな風にしてもら\nえるなんて……感謝してもらわないとだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうって……分かってるから……そんな、半泣きで甘えなくても\n、ちゃんと可愛がってあげるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら、いーこいーこ……ヤムがついてるでしょ。全く……いいトシした男が\nメソメソすんなし……調子狂うじゃんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、そんなコトより……こうして、チンポの方に集中した方がずっといい\nでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムの尻尾……めっちゃ器用なんだから……根元の方をギュッとおさえて…\n…先っぽを、くにくにイジって……んふふっ……ほーら感じてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはっ……チンポがビクビク跳ねっぱなし……カラダもモジモジさせちゃっ\nてー、パパのクセにかわいー動きなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「このまましたら、またビュルって出ちゃうんじゃない……？　いいの？　こ\nんなトコで、また射精しちゃうなんて……恥ずかしくないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふーん、そっかぁ……恥ずかしいのより気持ちいい方取っちゃうかぁ……\nにひひっ、いーよ……じゃあ、出すトコ見てあげるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……！　ふふっ、まーたおっぱいチュウチュウして……ヤムの集中乱そ\nうと思ってもダメだかんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それより……パパのおっぱいの方も、コリコリさせて……んふっ、分かりや\nすい位に腰が跳ねちゃってるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「出したいんでしょ……？　いーよ……ヤムが、ぜんぶ、ぜーんぶ搾り出して\nあげるから……ほーら、ほーら、我慢なんかやめなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムの尻尾で、んっ……チンポから、いっぱいせーえきっ……どぷどぷ出し\nちゃえっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひぁんっ……！　あっ……また出てるっ……んんっ、ヤムの尻尾……またド\nロドロにされてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「すご……溢れて止まらないじゃん……さっきより……出てるまであるし……\nうぁ……粘っこい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっふ……はぁ……はぁ……どれどれ……ちゅぷっ、んぁ……マジで濃いし\n……ヤムにされたの、そんなに嬉しかったワケ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「な、なーに、真顔で頷いてるんだかっ！　マジ、そーいうトコはパパ……堂\n々としすぎ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ……やっと、収まって来た……ふぁ……尻尾、こんなにしてくれちゃって\n……本当にしょーがないんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……おっぱいも、もういいでしょ？　ホントにずっと吸ったままでいそ\nうだし……ふやけちゃうっての……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あーあ、もう情けない顔しちゃって……んふふ……ホントにヤムのテクに、\n完全敗北って感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「でも、スッキリ出来てよかったでしょ。一応、これでお祭りの分はチャラだ\nから。ちゃんとヤムに感謝してもらわないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「また甘えてもいいか……？　はぁ、今終わったばかりで、もうそれ言うの？\n　全く……ホントに情けないパパだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そんなの……まぁ……ダメってワケにいかないでしょ……一応考えとくし…\n…そ、それでいいでしょっ、はい、おしまいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ひゃぅっ……！　あっ……尻尾……外れてっ、んぁっ、はぷっ……ちょっ…\n…せーえきっ、掛かってるしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ナニこれ……さっきより派手に出てるんですケド……んぁっ、あふっ……ド\nロっとしてるぅ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅぷっ……これ、濃すぎぃ……髪の毛にも……ま、まだ出てるぅ…\n…んっ、はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「すご……こんなニオイ嗅いだら……ヤムも、そのまま変な気分になっちゃう\nし……んはぁぁ……あ、ふっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅぱ……舐めきれないじゃん……コレ……んふぅ……って、せっか\nくの浴衣にまでかかってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あーもう、いいって。どーせ洗濯するんだし……それより、いつまでおっぱ\nい吸ってんの……もう、出ないって言ってるっしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00017503_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「全く……ちょっと甘えさせたげると、マジで際限なく甘えて来るとか……こ\nれだからパパは残念とか言われるんでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま、スッキリしたんならいいケド。ちゃんとヤムの優しさに感謝してもらわ\nないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「え？　お詫びにまだお祭りに付き合ってくれるって？　へえ、そう……そん\nなにヤムと一緒にいたいんだあ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあねえ、ヤムが満足するようなエスコートしてくれたら、また慰めたげ\nてもいーよ？　どう？　あははっ、じゃあ決まり！　さ、行こっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}