{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んっ……ぁ……。はぁ……はぁ、はぁ……なんで？　なんでこんなことする\nん？　隊長さぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「う、うちを拘束して、恥ずかしい姿にして辱めるやなんて……。ンッ……い\nつものあんさんと雰囲気違って、ちょっと怖いわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ……？　セックスするのはかまへんけど……。ふ、普通に自由にさ\nせてくれたらええやない？　その方がお互いに楽し……って、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「い、いややわぁ……！　うちがまだ話とるのに、……あっ！　あっ！　さ、\n触らんといて……！　最近、うちの身体おかしいんよ、ずっと熱くって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「普通にしてても疼いて疼いてしゃあないの……。あ、あんさんが開発……と\nかいって、やらしいことばっかしはるから……だから……！　あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「今、胸とかアソコとか、触られてしもたらどうにかなってまう！　少しさわ\nさわぁってされただけで……し、失禁してまいそうや……なんなのん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「これっ……こんなのおかしいやない？　はぁっ……はぁ、はぁ……。うちの\n身体、どうなってしもたの？　自分の身体やのに全然制御できへん……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んふぅう！？　ぁっ……！　堪忍え！　後生やから、おっぱい……胸は\n揉まんといて！　……あっ！　いややぁ、いやぁ、ややぁ……あんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　あぁ……あぁ♪　そんな……下から揉み上げるように……♪　\nあぁんっ、つ、強く握らんといてぇ……感じてまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あっ、ぁっ……いやぁ……いやぁあ……♪　声？　うちの声が\n甘くなっとる？　そ、それは……き、気持ちええから……あっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぐにぐにおっぱい揉まれるの好きやのぉ……！　あんさん、めっちゃ上手い\nんやもん、こんなん抵抗できへん……それに……それに、……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「乳首……！　いっつも指先でクリクリしよってからに……っ！　あっ♪　お\nっぱいはジンジンして……。乳首はキュンッキュンッてときめいてまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んーぁあ……♪　あぁ、あああ……♪　クリクリ……♪　とんがった乳\n首、クリクリされて、つままれて、伸ばされて……！　あ、あかん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「乳首いじりながら股間なんかいじったらあかん！　……あっ、やぁっ！　だ\nめ……だめなんよ、ぬ、濡れてるから……！　あっ！　指、指だめぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んんーっんん……！　あぁあ♪　指でクチュクチュしたらだめやんかぁあ…\n…♪　あっ♪　おっぱい、おっぱいもめっちゃ揉んでるしぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ひぁ、あっ、ぁっ、あぁ……！　ややの、ややのぉ……！　あーっ……！　\nおまんこの音、聞こえるぅ……エッチなおツユの音、すごいしとるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「恥ずか……しい♪　恥ずかしいわぁ……♪　うちがこんなに一方的に……あ\nんっ！　攻められて、愛撫されるなんて……！　うちは攻めの女やのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「でも、でも、むっちゃ気持ちええ……っ♪　あっ、ぁっ、隊長さぁんの指…\n…！　長くてゴツくて、……全然うちのと違うのん、男らしくって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んああああっ！？　ああっ、ああああっ！　やぁっ……！　お潮漏れてもう\nたぁ！　……っ、ねえ……ねえ、うち、焦らされるの苦手なん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「胸とかアソコをいじくりまわしてばっかやなくて……あッ♪　おちんぽ入れ\nてやぁ、わかるやろ？　ぐしょ濡れになって潮噴いとるの……あぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「意地悪せんといてぇ……！　あ……♪　うん♪　うん♪　乳首ひねりながら\n……あぁあん♪　愛液でベトベトのおまんこを指で拡げて、ぁ、んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぴゅっぴゅっておツユ出たところぉ……いつでもええから……。ねえ、欲し\nいぃ……♪　おちんぽ欲しいんや……。もう、もっこりしとるやん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「入れて、うちの中に入れてぇ……♪　……んっ♪　……そ、そうや……。う\nち、壊れてしもてもかまわへん……だから、だからはよう……。ああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「アッ、ぐぅっ、んぐぅうう……！　ふ、太いぃいいっ……！　ふと、い……\nぃ！　えぇえ？　嘘やろ？　見た目よりずっと太い、熱……いぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ッああああああ……♪　イッてまう♪　じっくりトロトロ熱された身体っ、\nうちのおまんこ……！　一撃で屈服させられてまう……！　やぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「イ……くぅう♪　イクぅうう♪　ああああ……！　ご、極悪非道のデカマラ\nおちんぽやない……っ！　女泣かせの、悪いちんぽやぁ……あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちの身体、めっちゃ喜んで……！　か、勝手にイキ続けるのが止まらんの\nっ……！　あーっ……！　う、嘘やろ、嘘やぁ……しっくりくるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちのまんこに隊長さぁんのちんぽっ、ぴったりやの……！　あっ……あっ\n、信じられへん……。うち、うち、初めてやのにイッてしもた……ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ううん、イカされてしもた……。っはぁ……っ……♪　こ、こんなことある\nん……？　って！　あっ！　ま、またおっぱい触りながら……だめぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁっ、ああ……！　気持ち、ええ……！　気持ちええよぉ……！\n　あかんわぁ、頭が真っ白になって……♪　……え？　何か言うた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「『いやらしいドスケベおまんこの一番奥で射精してください』？　そ、そん\nなん言ってる余裕ないんよ、本当に本当に……イキっぱなしやのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……『卑猥なことを言うのが好きなんだろ』？　そ、それ、は……あんさん\nをからかいたくて……って、あッ♪　あッ♪　わかった、わかったからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「動かん、といて……ぇ♪　入れただけでイってまうのに動かれたら一貫の終\nわりやぁあ……！　わかったからぁ、言います、言いますからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「い……いつも下ネタばっかり、言う、て……頭の中常時ドピンクなドスケベ\nのうちは……ッ、おまんこの一番奥っ、いちばん……お、奥ぅ、奥っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「赤ちゃんを作るところにあっつい精液びゅるびゅる注いでいただきたいんど\nすぅう……！　精子、精子欲しいんえ、ザーメン、ザーメン欲しいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ……！　ゆっくり、ゆっく、り♪　二人で腰動かしながら……あぁ♪　\n密着射精して欲しい……ぃ、中出しなんて怖い、怖いけどぉ……お」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「く……ください……くださひぃ……！　ぅ……あーぁあ……、あー……あぁ\nあ……♪　赤ちゃんのお部屋っ……お部屋にかけて欲しいんよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ミルクぅ……♪　赤ちゃんミルク、ゆーっくりちんぽで抽出して……あっ！\n　うちっ、のっ、一番やらしいところにかけて……かけてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「全部受け止めるからぁ……！　ごくごくぅって気持ちええくらい豪気に飲み\n干したるさかい……！　あっ……♪　んはっ、ぁっ、欲しいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……ンッ♪　で、出そう……？　あぁああ……♪　ええよ、ええよ、ぶちま\nけて……！　ややわぁ、うち、めっちゃドキドキして……あぁあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「い、ぁ、あ、ぁ、ああああぁあ～～～～♪♪　あぁ……こうなん♪　こうい\nう感じ……なん、あぁんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっつい……♪　お腹ん中、隊長さぁんのがドクドク流れ込んできとる……\n。あっ！　あっ！　これが種付け……これが中出しなんえ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「すごい……すごいわぁ……♪　……あんっ♪　あぁ……！　一番奥……一番\n奥に命中しとる、あっ♪　それが気持ちよぅて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んんん～～～～……♪　おまんこの中の匂いが嗅げへんのが残念やけど……\n、これだけ出してもろたら、すぐに……うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うちから、あんさんの精液の臭いが漂うてきてもおかしゅうない……。……\nはぁっ、はぁ……。うち、あんさんの臭いに染められてしもた……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「くっさいくっさい、粘り気の強い匂い……。でも、んっ……念には念をや…\n…。もっともっと、この臭いで満たして、この匂い塗り付けて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「せやから……。ぁ……♪　『中出しされてもまだまだ満足できない、ラスト\nノートの貪欲おまんこに、精液おかわりお願いするわぁ』……♪　そぉれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　あは……あぁ、わか、るぅ……？　おまんこグニュグニュ動いて、\nるやろ……。絡みついて、おちんぽ欲しがって……あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「これ、な……？　もらった精子を吸い上げながら……ぁ♪　まだまだ飲めま\nす、注入してくださぁいっておねだりしてるんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「は、ぁ……せやから……。動い、て……。今度はゆっくりじわじわやなくて\nいい……うちを壊す勢いで……来て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「っ……は、ぁ……はぁ、はぁ……あぁ……♪　なんてええ子なん……。うち\nのおまんこの言うこと聞いて、すぐにぶっとく復活して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あっ♪　柔らかいアソコをえぐり倒すいき、おいでピストン……してくれて\nはる♪　あぁっ……あぁ、聞こえるぅ？　さっきの精液ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ぐっちょぐっちょってひどい音たてて……あっ♪　うちの中に塗りたくられ\nとる……ぅ、あっ！　あぁ！　なんなん？　なんなんこれ……はぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「硬い、のが♪　素早く出入りするだけで……摩擦でおまんこがビリビリくる\nわぁ……♪　あぁ……あぁ、そう、そう、なんこれがセックスなん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「激しい……ぃっ、激し、いぃ……♪　あっ♪　どんどんちんぽが逞しゅうな\nって……あぁあっ！　うちのおまん、こ♪　おまんこ壊れるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うぅ♪　はぁ、はぁ、はぁっ……ええよ♪　うち、あんさんにやったら……\n隊長さぁんのデッカいおちんぽにやったら壊されてしもてもええ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「やから、やからいっぱいほじってぇ♪　白濁まみれの出したておまんこっ、\nあっ、あはっ♪　ヌチョヌチョおちんぽ出し入れして欲しいぃい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……ん、ふ……！？　あらっ……？　う、嘘……うそぉ……！　なんか今、\n中でぶわっと膨らんで……！？　まだおっきくするつもりなん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ッ……あ……！　嬉しい、けど……嬉しいけどこれ以上はうちがもたへんよ\nぉ……ああっ！　ぶっといので抜き差し続けられたら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「イッ……てまう、イッてまうぅ！　今度はさっきの比やないわぁっ……ほん\nまに、ほんまにどっかにイッってまう……！　ああああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_12" ]},
		{"command":[ "WAITINPUT" ]},

