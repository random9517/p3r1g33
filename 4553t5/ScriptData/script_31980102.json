		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あ……ら？　隊長さぁん、イッとるうちからおちんぽを抜いて、何を……。\nえっ……！？　きゃ、きゃあっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あぁんっ、ややわぁ……ッ！　うちの身体に……っ、体中に白濁を……！　\nあっ、熱いん……！　熱いんよぉ……！　のぼせてまう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「あッ……あっ、あ、あ……っ……。そやのね……っ、こうやって鉄砲みたい\nにピューピュー撃ち出されて……うちを狙って着地して……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こ、こんなに元気な汁がアソコに出てたなんて信じられへん……っ。目で見\nてみると、どえらいことやわ……。ホントに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「……んっ、ん……！　ごくっ……。……え……？　今、喉を鳴らしたか、や\nって？　そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「う、うち……。この香りに弱いのかもしれへんわぁ……。欲望の煮詰まった\nような、淫らで妖しい香り……。こんなん、あかんのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「こんな極上の香り、この鼻に覚えこまされたら……当分忘れられへん……。\nそれに、ドロドロのミルクスープを浴びせかけられたみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。それが、雫が身体をつたって降りていくその感触で、か、\n感じてまうの……。あぁ、ああ、ややわぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「うち、ますます変態ちっくになってしもうてぇ……♪　こんな女、もうあん\nさんしか可愛がってくれへんやろ、困るわぁ……♪」", "NORMAL" ]},
