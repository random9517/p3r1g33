		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「イっク……イクっ……！　あああっ、二度目の中出しっ、すごい、すごいわ\nぁ……っ！　うち、うち、無理やりイカされて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ああああっ……♪　あぁおおおぉお♪　びゅく、びゅく、って赤\nちゃんの部屋に精液……精液注入されて……あぁあん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「子宮が真っ白になっちゃうぅ……っ！　孕んでまう、孕んでまう……！　こ\nれ以上出されたら……。……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「す、ごい……っ♪　満タンになるまで射精、射精しはるなんて……ッ。あっ\n！　ち、違うんね？　満タンになっても……まだ……！　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「もう入らへん、もう入らへんよぉおお……♪　ん、ん、んんんんーーーーー\nッ……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00019801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ひゅぅうう……っ……。はぁ、はぁ、はぁ、はぁああ……♪　い、いややわ\nぁ……♪　息をするのも忘れてもうてた……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「回数を重ねるごとに……新しい快感がほとばしる……♪　セックスがすごい\nのん？　それとも、隊長さぁんがすごすぎるのん……？　はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「た、隊長さぁん？　気持ちよく出せた……やろか？　うちは……うちは……\n♪　も、もう言わせへんといて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「初めてやからこんなに気持ちええこと、ブッ飛んでしまうようなこと……。\nもうやめられへん、完全にハメられてしもうたよぉ……♪」", "NORMAL" ]},
