		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「は、ぁう、あ、ぁ、あぁああっ……！　あ……かっ、んぁっ……あぁ、ああ\nああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_0104301" ]},
