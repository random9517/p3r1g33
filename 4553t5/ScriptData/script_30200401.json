{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おい。そなた、なにをしているのだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「パイズリをしてるって……そういうことを聞いているのではない。我が聞い\nているのは、なぜこんなことをしているのかということである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我とエッチなことをしたくなったから……？　まったく……今はメンテナン\nス中であるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「メンテナンスが終わったら相手をしてやるのである。だから早く胸から手を\n離して、オチンポを抜くのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403104" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「……我の話を聞いているのであるか？　いつまでも胸を揉んでないで、早く\n離せと……んっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ち、違うのである！　今のは感じたから出た声ではない……！　あっ、こら\nっ……！　そんなに強く揉まれると……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……！　オチンポの熱が谷間から伝わってくるのである……！　\nあっ、やっ……！　あああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だ、ダメであるぅ……！　そんなに触られたら、感じるのであるっ……！　\nんくっ、はぁ、あっ……んふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くうっ……！　我が動けないのをいいことに好き勝手にして……！　あ、あ\nとで憶えておくのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「酷い目に合わされるなら、今のうちに楽しんでおくだと……！？　ちょ、ち\nょっと待つのであるっ……！　あはあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　オチンポがおっぱいに擦りつけられているのであるっ……！\n　あっ、んんっ……！　根本までぐっぽり入り込んで……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ひくっ……！　擦られるたびに、オチンポが大きく、カタく\nなっているのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　おっぱい揉まれすぎて、感じるのであるっ……！　我の乳首も\n大きくなっているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んくっ、あふうぅ……！　揉みながら乳首を弄られると……んっ、あっ！　\nあっ、やっ、んひいぃ！？　か、感じすぎるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、はああぁ……！　メンテナンスのために下半身をパージしてる\nせいで、よりいっそうおっぱいで感じるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「マシンファラオである我をこんな道具のように扱うとは……！　んっ、くっ\nあっ、うくうううぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の魅力あふれる身体に興奮する気持ちは理解できなくはないが……くうう\nぅ……！　やはり人間とは愚かであるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんなこと、我が相手でなければ絶対にしない……？　な、なにを言ってい\nるのであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「確かに我は機械で、人間の法は適用されないのだが……！　え……？　そう\nいうことではないのであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我とだから、こういうことがしたい……？　それはつまり……我に好意があ\nるからこそ、ということであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「お、おっぱいでオチンポを擦りながらそんなことを言われても、嬉しくない\nのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが……その気持ちは嬉しく思うのである……もうはじめてしまっているこ\nとだし、少しくらいなら付き合ってやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　特別に、もっと強く胸を揉むことも許してやるのであ\nる……乳首も好きなだけ弄ることを許そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ただし、ちゃんと我のことも気持ちよくするのである……！　そうでなけれ\nば、すぐにでもやめさせるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……！　急に動きが激しくなったのであるぅ……！　あっ、く\nふっ、んんっ……あふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、くふっ、ひううぅ……！　オチンポの汁が谷間に溢れているのである\n……！　んっ、くっ……ヌルヌルが広がっているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それにエッチなニオイも濃くなって……んんっ……！　ここからでも、感じ\n取れるのである……！　あふっ、あんっ、あはぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　オチンポの段になっているところが、谷間でズリズリ擦れて\n……んくうぅ……！　それ、気持ちいいのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あふっ、んふううぅ……！　あっ、あっ……！　ひうっ、んくっ…\n…あっ、うぐっ、んはあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「乳首ももっと弄って欲しいのである……！　揉みながら、クリクリって撫で\nまわして欲しいのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああああぁんっ！　パイズリされながらおっぱい弄られるの、気持ちいいの\nであるっ！　頭に気持ちいいのが届くのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふくっ、あんっ、あんんっ！　オチンポが谷間で暴れているのである……！\n　イキそうなんであるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　遠慮せずに出していいのである……！　パイズリで射\n精することも織り込み済みであるからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我のことを好いているのであろう……？　ならその気持ちを受け止めるのも\n、王の務めである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あっ……！　いっぱい出して欲しいのである……！　我のおっ\nぱいで、気持ちよくなって……んんんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あくううぅ……！　谷間にザーメンがどぴゅどぴゅ出ているのである\nぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポがビクビクと脈を打って……！　あっ、あっ……！　谷間で暴れま\nくっているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああっ、ふっ、あはぁ……！　ザーメンのニオイがこんなに……！　肌に染\nみ込んでくるのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「射精前とは比べ物にならないくらい、ニオイも濃くなってきて……すううぅ\n……！　はああぁ……嗅いでいると、頭が変になりそうであるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　最後までしっかり出すといい……！　オチンポの奥に残\nっているのも、全部出すのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「しっかり出せとはいったが……まさかこれほど大量に出すとは……正直、驚\nきである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もし下半身が繋がっていたら、ザーメンの感覚で感じすぎて、絶対にイッて\nいるのであるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「たくさん出したようだし、そろそろ離れて……ん？　どうした？　なぜまだ\n我の胸にオチンポを挟んでいるのであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もう１回我の胸でパイズリさせて欲しいだと……？　こんなに出したのに、\nまだシたいというのであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「仕方のないヤツであるな……わかった。あと１回だけ、我の胸を使うことを\n許して……ひゃあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ば、バカ者……！　許可を出すと同時に動くヤツがあるか……！　少しは加\n減をするのである……んひっ、あっ、くふぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　おっぱいでオチンポが擦れるほど、ザーメンのニオイが強く\nなってくるのであるぅ……あふっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、ひぐっ、ひゃうぅ……！　あっ、あっ……！　あんんっ！　今そんな\nに強く胸を揉まれたら……ひぐっ、あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我のおっぱいが気持ちよすぎて、腰がとまらないだと……？　くっ、んっ…\n…！　本当に仕方のないヤツであるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……我ももっと感じたいのである……少し乱暴にしてもいいから、いっ\nぱい胸を揉みながらパイズリするのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　んふっ、あふっ、あぐうぅ……！　ああっ、本当に乱暴\nにされているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっぱいを揉み潰されながら、乳首を弄られて……！　んんっ……！　オチ\nンポを擦るためだけに、使われているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「カリが擦れると、おっぱいが刺激されて気持ちいいのであるぅ！　それ、も\nっとして欲しいのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ、あっ、んっ、あああぁ！　くっ、あっ！　んんっ！　下半身がないの\nに、イキそうな感じがするのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっぱいのあたりがジンジンして……頭の方も、気持ちいいのがずっと鳴り\n響いている感じがするのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んんんっ！　オチンポが膨らんで、ビクビクしているな……\nそなたもそろそろイキそうなのだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「このまま最後まで激しく擦って、我をイカせて欲しいのである……！　気持\nちいいので、我を満たして欲しいのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あああぁ！　最後の最後で、そんな打ち付けるようにガンガン\n腰を振るなんて……！　ああっ、ひっ、あはあああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あぐっ、ふっ、んくううぅ！　イッ、イクのであるぅ！　気持ちいいのが、\n胸が溢れてきているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああっ！　そなたもイッて欲しいのであるっ！　胸でも顔でも、好きなと\nころにザーメンを出して……あっ、あっ！　ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あぐうううぅぅぅ！　またおっぱいの間にいっぱい出ているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポが上下に動きながら、いっぱいザーメンをびゅるびゅる出して……\nんんっ！　射精の感覚が伝わってくるのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あああっ！　そんなっ、射精してるときも胸を揉んで、動かす\nとは……！　それ、刺激が強すぎるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「射精の動きとオチンポを擦る動きが合わさって……気持ちいいのがとまらな\nいのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひっ、うぐっ、あはぁ！　イクッ！　イクのであるっ！　おっぱいで感じる\nのであるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はああぁ……んっ、あっ……すごく気持ちよかったのである……そなたはど\nうであるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ホホホ……そうか。そなたも気持ちよかったのだな……それはなによりであ\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……それでは約束通り、これで終わりに……なんであるか、その寂しそ\nうな顔は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もう１回出したいと言ってもダメである。我はまだメンテナンスの途中なの\nであるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403309" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「仕方のないヤツであるな……ではメンテナンスが終わったら、もう１回付き\n合ってやるのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！　ザーメンが顔にまで飛んできているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「２回目なのに、こんなに勢いがあるとは……！　くっ、あっ……！　さすが\nはそなたのザーメンであるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅぷっ……！　味もかなり濃厚である……これを直接味わわされ\nたりでもしたら、たまらないであろうな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ、ああぁ……！？　また勢いよくザーメンが噴き出て……！？　なんで\nまた急に興奮しているのであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我がザーメンをすするところを見て興奮したのか……？　ば、バカ者っ！　\nそんなことで興奮してないで、早く射精し終えるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403405" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……まったく、そなたの性欲には呆れるばかりである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だが我のエッチな仕草を見て興奮してくれたのは……嬉しく感じているので\nある……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「人間と機械という大きな違いはあれど、そなたにとってそれは些細なことな\nのであると証明しているように感じられるのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……！　またオチンポがおっぱいの間で跳ねて……んっ、あっ\n、ああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「続きはメンテナンスが終わってからである……今度はちゃんと下半身で……\nオマンコで相手をしてやるのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0403410" ]},
		{"command":[ "WAITINPUT" ]},
