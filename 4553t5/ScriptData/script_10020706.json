{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0165" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ひーーーーー……はーーーーーー……かひゅーーーーーー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113730001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とりあえず、グレーテルはベッドに寝かせておくか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうね。じゃあ、ディアナちゃんはこれで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「なーに逃げようとしてるんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だ、だってぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "保健室から抜けだそうとしたディアナを椅子に座らせて、逃げないように拘束\nする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、あらためてあの幽霊のことについての尋問がはじまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あの幽霊の正体を知っているようですけど、あれはあなたの仕業なんですか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「つーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あと、サメもです。あのおっかないサメはなんなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「つーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なにか知っていそうなのは間違いないのだが、話すつもりはないらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "徹底的に黙秘を貫いている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……なかなか口を割りませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「じゃあさ、しゃべりたくなるようにすればいいんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふむ、バカ犬にしては冴えているのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "指をぽきぽき鳴らしながらディアナに近づくセレイン。身の危険を感じたのか\n、ディアナの顔色が変わる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「な、なになに？　痛いことするの？　暴力反対～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「だったら早く白状したほうが身のためだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてセレインはディアナに手を出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そーれっ、こちょこちょこちょこちょーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁああんっ！　ダメダメダメぇ～っ！　ディアナちゃんくすぐられるの\nは弱いの～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "背後に回り込んだセレインがディアナの脇腹をくすぐる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やめてっ、ンッ、ああっ、あはぁんっ！　ひっ、ひっ、はっ、はっ、はぁあ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「知ってること話すまで、やめないんだからなー！　こちょこちょこちょーっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、話さないっ、話さない～っ！　んひぃいっ！　ひゃっ、ひ\nゃめぇえんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730008" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「その調子です。絶対になにか知っているはずですから、しゃべるまでやりな\nさい、バカ犬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "兎子のやつ、いつにもまして厳しく追及しているな。サメにかなりビビらされ\nてたし頭にきてるのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひぃっ、はっ、はっ、はぁあんっ！　やめっ、んふぅうんっ、んはぁっ、は\nぁっ、あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730009" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それにしてもセレインのくすぐり……ありゃちょっとした拷問だぞ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「どうだー、知ってること、洗いざらい吐きたくなってきただろーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、吐かないぃっ！　んひゃんっ！　絶対にぃ、んひっ、んひぃいんっ\n！　あはんっ、はっ、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730010" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ひゃっ、んひゃあああっ！　んひゅぅ、はぁ、はぁ、はぁあんっ！\n　あっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「強情ですね。もっと力いっぱいくすぐるのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730007" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わかったー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃぁあんっ！　やっ、やぁんっ！　んひぃっ、んひぃっ！　はぁっ、ンッ\n、あっ、あはぁっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730012" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはんっ、あっ、やっ、あぁんっ！　んふぅっ、はぁっ、はぁっ、あはぁっ\n、ンッ、んひゃぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなくすぐり責めを受けてなお、ディアナはなかなか白状しなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……それにしても、声だけ聞いてるとちょっとエロいな。身体を捩らせるたび\nに胸もぶるんぶるんしてるし。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、鼻の下がのびてますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……の、伸びてねーし！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「んぅ……騒がしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113730002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、グレーテル。気が付いたか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グレーテルがむくりと身体を起こした。その顔は、もともと青白いがさらに血\n色が悪くなっている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そんな！　あの手はなに！？　ま、窓に！　窓に～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113730003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「窓……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グレーテルの叫び声に、俺たちの視線は窓へ向かう。すりガラスに手形。こち\nらを覗いている人影。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「き、来ちゃダメ！　逃げて～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040113730014" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ディアナが叫ぶと、窓の外の人影が逃げていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ええい、なにしてるですか！　あの人影を捕まえるのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730008" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そういう肉体労働はセレインにやらせろよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「バカ犬ならあそこです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050113730009" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「オバケこわいオバケこわいオバケこわいぃ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040113730007" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "縮こまって椅子の下に頭だけ隠している。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああもう、仕方ねえな！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結局俺が追いかけるのかよ！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}