		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「とりあえず、お腹減ってない？　ゴハン、食べに行く？」", "NORMAL" ]},
