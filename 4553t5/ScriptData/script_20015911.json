		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「にひひっ、なるほど、そっかー。帰り道分かんなくなっちゃったかぁ」", "NORMAL" ]},
