{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0203" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅっ……小癪な……！　もう少しというところで、また邪魔をしおって…\n…！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何もかも貴様の思い通りにはさせん。それだけの話だ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ルナテミスさんっ、アナザーさんっ！　今ですっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ヤツは足止めをしたっ！　後はお前たちの仕事だ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ……！　貴様らまで小賢しいことをっ……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ここまでお膳立てをしてもらっては、いがみ合う理由もないな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん、たまに協力する位はどうということもない！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おぉっ、珍しく２人が息をピッタリあわせて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「行くぞっ！　はぁぁぁぁぁぁーーーっ、ルナリアム・ヴァルキュラス！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私も行くぞっ！　喰らえっ……ヴァルキュラスレイドっ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うぐっ……！　ぐっ、うぁぁぁぁぁぁぁーーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「や、やりましたかっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あんまりフラグになるようなことは言わん方が……って、いやこれは……本\n当に効いている！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あの人の装甲が崩れて、また元の姿に戻ろうとしています……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くう……今回はまんまとしてやられたわ……。よもや、貴様らまでヴァルキ\nリーとなって出し抜かれるとはな……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「だが、これで終わらせるつもりはない。この借りは、いつかきっと何倍にも\nして返してやるからのう……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「むーん、今回はぁ、引き分けにしといたげるかぁー。でーもー、次はもっと\n困らせちゃうかもしんないからねー、ばーい！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、おい、こらっ！　……行っちまった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「放っておけばいい。どうせ奴らとは違う形でまた会うだろう」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。それよりも今は次元の裂け目だ。奴の変身が解除された影響か、\n一気に小さくなっているぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「残された時間はもう少しか。今度こそ邪魔はもう入らないな？　いよいよ、\n本当にお別れだな？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「名残惜しいです……でも、素敵な体験でした。ミッドガルドに戻っても、こ\nこでの経験を活かして、頑張ります！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こっちで、あれだけ人気者になったんだ。向こうでもまた派手にやってくれ\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「はい、いろいろ試してみようと思います。皆さんもお元気で！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「まぁ……美味いものを、色々と食べさせてもらった。その、世話になったな\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そう言えば、熱心にレシピを聞いていたな。向こうで同じ材料が揃うかは分\nからんが、色々と試してみるといい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ま、まぁな……ただ、私は別にそこまで食い意地は張っていないぞ。いいな\n！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「フン、どうだかな。以前、戦場で糧食のことで揉めていた所を見ていたぞ？\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「余計なコトを言うなっ！　貴様は大人しく捕まっていろ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「フェンリルと言ったか。次はもう少し違う形で出会いたいものだ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「私は御免だ。２度とこんな面倒に巻き込まれるのはお断りだからな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「そんなことを言ってますが、彼女は、案外こちらの世界の音楽なんかを楽し\nんでいたんですよ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「し、知らんぞ！　お前も変なことを言うんじゃないっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あの方にこの世界を献上できなかったのは残念だけど、いいお土産話ができ\nたわ。久しぶりにレイアと一緒にいられたし……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「フレイア様……これ以上困らせないで下さい。ミッドガルドまではご一緒し\nますから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、レイアも気苦労が絶えないな。帰っても何かと大変だろうが、しっ\nかりな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ありがとうございます。私達の紡いできた未来の先に、このような素晴らし\nい世界があるならば……人の世はきっと大丈夫だと思えました」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「どうか、皆さまにも神のご加護がありますように。どうか、お元気で……！\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「行ってしまったな……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なかなか面白い奴らだった。神々というのも思ったよりずっとフランクだっ\nたな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「すっかりこっちのペースに乗せちまった感はありますけどね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「かなり騒がせてくれたが、お陰で新しい技も習得できたし、新形態にもチェ\nンジできるようになったからな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ、まだヴァルキリーになれるんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「次元が閉ざされたから、さっきまでのような異常な力にはならんだろうが、\n格好だけなら近いものになれると思うぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あれなら、我々も悪というより正義の側で見られるのではないか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……それは素行的にも無理があるかと……あだっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん、せっかく神の加護をもらったのに、失礼なことを言うな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うちがどんな組織か、分かってたんですかね……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まぁ、正義も悪も見方によって変わるものだ。あの瞬間、志を同じくしてい\nた。それだけで十分だろう」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「先達の生き方に学び、新たな時代を作るのは我々の役割ということだな！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おぉ……何か、結構もっともらしいこと言って纏めに来ましたね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕……よっぽど減俸されたいようだな？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや違いますって。ありがたいお言葉、肝に銘じます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「さて、我々も戻るとするか。ヴァルキリー特務隊の任務完了だ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうした、下僕。さっさと戻るぞ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……何だろうな……？　何かもう一つ忘れてるような気がしたんだが……何\nだったか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「下僕ー！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はいはいっ！　今行きますっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0194" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んー、この辺が裂け目の跡かぁ……次元を繋げるアイディアは悪くなかった\nと思うんだけどなぁー」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「上手く調整したら、また広げるコトはできそうだけど……今のまんまだと、\nあんま変わんないかな……また新しいコト考えて……ん？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！　やっと戻って来られた……あ、あれ？　みんなどこ……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ね、ねぇー、みんなー！　スクルドのこと忘れてない？　やだよー！　コラ\nボでもこんな扱いなんてやだー！　ねーってばー！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミ……ナニしてんの？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぇっ……？　あっ……あんたはっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミ、確かヴァルキリーの……え、もしかして帰りそびれちゃったとか？」", "NORMAL" ]},
