		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ！　待て、オボロ！　逃げる気か！　待ちやがれーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114980004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「セレーナ、深追いするな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114980001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だってオボロが！　あ！　行っちゃった！　くっそぉ～～っ！　おい！　そ\nこの変な忍者！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「……？　ウチですか？」", "NORMAL" ]},
