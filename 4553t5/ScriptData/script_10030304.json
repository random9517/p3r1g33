		{"command":[ "SETCHARA", "0", "char_00000511_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おまえに決まってんだろ！　なんで邪魔したんだよ！　なんでオボロを逃が\nした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114980006" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そんなの、ウチには関係ないです。あのウサギが勝手に逃げ出したまでです\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114980006" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんかお前、気に入らないヤツだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114980007" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチも、あなたのようなアホ犬は好きになれません」", "NORMAL" ]},
