		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「……むむ？　どうしたハルノブ。いつもにも増してノリが悪いぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114980003" ]},
