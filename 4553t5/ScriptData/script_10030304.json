		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「ミナサン、ドーモ！　ハイッパー・マッポーサムライ・ウィズ・ハルノブ、\nデス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114980002" ]},
