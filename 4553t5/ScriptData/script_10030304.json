		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………なんだ？　なんなんだ？　この光景。どっかで見たことあるような\n……」", "NORMAL" ]},
