		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「わかりません……ですが、なんだか妙な感じが……。なんでしょう、この感\n覚は……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114980004" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「…………増援が来てしまったのでは、そろそろ潮時ですね。引き揚げるです\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114980005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん！　しかたないのう！」", "NORMAL" ]},
