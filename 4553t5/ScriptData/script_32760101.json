{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「おや、どうしたどうした。なんともしょぼくれた顔をして……わしでよけれ \nば話を聞くぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「なに……？　女幹部連中に振り回され、上司から無茶振りをされ……舟券は \nことごとく外し……いいことがないと落ち込んでおるのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そうか、そうか、それはしんどかったのう。うぅむ、わしにはこうして抱き \nしめてやることしかできぬが……ほれ、いい子じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「どうだ、少しは落ち着いてきたか？　おぉ、いい大人がこんなにも甘えて… \n…んふふ……よしよし、可愛いのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「まったく……いかん……いかんぞ……そんな風に縋りつかれると、どうにも \nわしは弱いのじゃ……もっと甘やかしたくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「これ、あまり頭をぐりぐりとこすりつけては、着物が乱れてしまうではない \nか。……んぅ、ほらっ、胸が出てしもうた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ん？　どうした、そんな物欲しそうな顔をして……。あいにく大きくはない \nが、吸いたければ吸っても良いぞ……？　皆には内緒にしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ……！　んふふっ、そうそう……ほれ、落ち着くじゃろう？　 \nその気になれば、母乳も少し出してやれるでな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あふっ……ほれ、慌てることなく落ち着いて吸ってみるとよい。んっ、ふっ \n……そうそう……うむ、なかなか悪くないといいがのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そうかそうか、落ち着くか。うむ、いい子じゃ……色々と大変なことがあっ \nたろうからな……今は全部忘れるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……おっと……そんなことをしているうちに……これは、そな \nたのチンチンが膨らんでおるではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「斯様な起伏の乏しい身体でも、そなたはしっかりと肉欲を覚えるということ \nか。まあ、そうさせたのは他ならぬわしじゃしな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ならば……こうして……んっ、ふふ……どうじゃ？　少しキツいようなら言 \nうがよい。尻尾でされるなど、他ではなかなか味わえぬからのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「こう見えて、かなり繊細な動きが出来るのじゃ。チンチン全体に巻きつけて \n……ゆっくりと回してやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「おぉ……びくびくと震えておる……こんなにも元気になって……気持ちいい \nみたいじゃのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「よしよし……そのまま、おっぱいを吸っておくがよい。一緒にチンチンをあ \nやしてやるからな……ついでに頭も撫でてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふふっ、こどものような扱いは心外か？　わしからすれば、そなたは本当 \nに可愛い孫のようなものじゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「それに……このチンチンは、立派に男を主張しておる。こんな逞しいモノを \n持っておるのに蔑ろにすることはないからの、安心しておくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「さあ……少し強めに動かしていくぞ……ほぅれ……こんな感じはどうじゃ？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふふ……チンチンの亀頭……皮のムケたところ……ついでに根元に……こ \nこ、キンタマまで満遍なくほぐしてやると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「力が抜けてしまうじゃろう？　男の一番大事な場所じゃ……こんなにも身を \n預けてしまえば、そうなるのは自然なこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「とにかくチンチンはわしに任せてしまうがいい。そなたが今、気にするのは \nこっち……んふっ、乳首じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、そうじゃな……夢中で吸って……反対側もよいぞ……？　んっ、 \n手で揉んでみるか？　まあ、あまり揉み心地は保証せんがな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103123" ]},

		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　ふっ……大きさは気にせぬか……んっ、それなら、好きなだ \nけ吸って揉んでを繰り返すといい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あふっ……んんっ、舌が熱い……こんなに夢中になって、んぁっ、転がされ \nると……わしも……息が乱れてしまう……あふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんっ、先端が引っ張られるぅ……あぁっ、乳首……切ない感じが広がって \n……んくぅ……はぁっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あふ……んふぅ……いい香りがする……？　ホッとする甘い感じ……？　ふ \nふ……何じゃろうな？　古来より、龍の香は強壮に効くと言うが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「なに、毒ということはない……ちょっと感度が良くなって……精が尽きぬほ \nど出るようになるくらいじゃ。害はないので心配には及ばん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ……そのチンチンから先走りが滲んできたな……どれ、もう少し尻尾を \n大きく動かしてみるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「おっと、ビクッとしたな……ここがそなたの弱いところか……？　ふふっ、 \nすまんすまん……お返しの乳吸いはお手柔らかに頼むぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ふっ……んんっ、まぁ、元気がある方が男らしいからの……んふ、 \n下手な遠慮はせん方がいいか……あふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……いらぬ心配じゃったな……ならば、わしも遠慮なく……ずりゅずり \nゅと扱くぞ……ほれほれ、この辺りが絶妙じゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、どうじゃ……そろそろチンチンも限界が近いのではないか？ \n　もうビクビクが止まらなくなっておるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふっ……汚すことなど一切気にせんでいいからな……？　わしの尻尾で感 \nじたなら、そのまま身を任せて出してしまうがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そうじゃ……もう少し強くするぞ……ふふっ、声が上擦っておるぞっ……さ \nあ、出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　んふっ……おぉぉ……これは大量に出てきておる……ふ \nふっ、よいぞ……その調子じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、わしも……たっぷりとおっぱいを愛でられて……んっ、は \nぁぁ……イッて……しまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あふっ、ふはぁ……ふふっ、たっぷりと出せたな。ほんに、男らしいチンチ \nンよの。よしよし、よう頑張った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「若い男の精液……んーっ、ちゅぷっ、なかなかの甘露よの。ふふっ、わしの \n方が堪能してしまったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、多少なりともそなたの癒やしになったのならよかったが……そう \nか、そうか、それはよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ん……ふっ、それにしても……まだわしのおっぱいから離れるつもりはなさ \nそうじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「全く、そなたは本当に甘え方を心得ておるというか……そんな風にされれば \n、もっともっと甘やかしたくなってしまうではないか……のう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……チンチンも、たっぷり出したとは言え、まだしっかりと硬さを保っ \nておる……続けてシコシコして欲しいんじゃな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ならば、今度はこの精液をねっとりと絡めて……んふっ……もっと滑りやす \nくしてやろうな……うりうり……んむぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「どうじゃ、イッたばかりのチンチン全体に、じわりと染み込んでいく気持ち \nよさがあるじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「もっとしてやるからな……シコシコ……くちゅくちゅ……ふふ、敏感な亀頭 \nがまたビクッとしておる……可愛いのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「わしの尻尾も、チンチンの脈動をいっぱいに感じて……どんどん気持ちよく \nなってしまっておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「もちろん尻尾は、重要な場所じゃからな……。ん……そなたの感じている表 \n情を見ているだけでもムズムズして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「こうして扱いてやる程に……はふっ……身体も疼いてしまう……んんっ！　 \nしかも、あっ、おっぱいが……んっ、吸われてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「何度もチュウチュウされると……じゅわっと……母乳も滲んで……はぁんっ \n、少し味が分かるか……？　ふふっ、遠慮なく飲むがいいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「わしの母乳を味わうと……また精力が満ちて、出る精液の量も増えるからの \n……チンチンも敏感になるかも知れんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ほれ、この感じ……どうじゃ？　おぉ、ふふっ、いい具合に効いておるか。 \nくぅー、可愛いのぉ……胸がキュンキュンしてしまうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……ほれ、もっとたんと吸うがいい。キンタマもさすってやろうな \n……他にして欲しいことはあるか？　ナデナデがいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうかそうか……頭を撫でられるのもいいが、やはりチンチンを撫 \nでられる方が今はいいみたいじゃな……よいよい、任せておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、ほぉれ……ずりゅずりゅっとチンチンが鳴っておる……出した \nくなったらいつでも出していいからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そなたの濃密な精液を、わしももっと感じたい……ふふ、精液まみれの尻尾 \nが、図々しくもおかわりを欲しがっておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「こんな卑しい婆のために、若いチンチンも頑張ってくれるか？　んふぅ…… \n好きなだけおっぱいを吸っていいからの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「また元気に射精して……そなたの、精液を……あふっ、んぁっ……思う存分 \n出し切ってくれ……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぅっ……乳首も切ない……また、わしもイキそうじゃっ… \n…んふぁっ、あと……もう少しっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「さあ、出せっ……そなたの、濃厚……トロトロ精液っ……思いっきりっ…… \n出してしまえっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　あふっ……出たっ……元気な射精っ……どぷどぷっ……飛ん \nでおるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「これは、またなんとも活きのいいことじゃ……んんっ、尻尾が精液まみれに \nされて……まだ降り注いでおる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、龍の香気も上書きするほどの、この濃厚な精液の匂い……は \nふぅ……頭がクラクラする魔性の香りよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふぁ……乳首もずっと吸われて……感覚がおかしくなっておる……気持ち \nいいのがふわふわ続いている気分じゃ……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あぁ……やっと射精も止まったか……ふふ、続けて出したが、今の方が多い \n位だったかも知れんな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ……まだおっぱいは夢中のままか。全く……そなたが、ここまでの甘え \nん坊だったとはわしもちょっと予想外だったぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「とは言え、わしはこう素直に甘えられるのに弱いからのう……どうしても、 \nよしよししたくなってしまうのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんっ……もう少し吸っておきたいか。よいよい、こうなったら気が済むま \nでずっと吸っていればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……つくづく甘やかしがいのあるやつよ。油断していると、わしの方が \n骨抜きにされてしまうかも知れんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ん、満足したか？　よしよし……また辛いことがあったら、いつでも頼るが \nいい。わしが精一杯に癒やしてやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふぁっ！　あぅんっ……！　精液がっ……身体にっ……浴びせられておるっ \n……！　あぷっ、んふぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そうか……尻尾が外れて……んんっ、溜め込んだ分が一気に出て……まるで \n……洪水のように溢れ出ておる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふはぁぁ……このドロリとした強い精気の塊よ……ちゅぷ……直接味わうな \nど……贅沢の極みよの……んふぅ……美味なり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「それにしても……顔どころか……髪の毛にまで届くとは……龍の香気が少し \n効きすぎたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ、ようやく射精も収まったようじゃな……いやはや、大した量を出した \nのう……身体中が精液まみれになってしまったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……乳首も長く吸われたせいか、少し赤くなってしまっておる。あぁ、 \nもちろん気にすることはないぞ、わしが望んだことでもあるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「何というか……わしは、そのこうして甘えられることが好きなのじゃ。そな \nたの素直さにキュンキュンしてしまってのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「しかも、こんなにたっぷりの精液まで出してくれるのじゃ……自然に尻尾コ \nキも捗るというものよの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「どれ、満足したか？　おお、それはよかった。まだまだ、これからそなたに \nは頑張ってもらいたいからの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「うむ、またして欲しいと思ったらいつでも呼ぶがいい。わしが、存分に甘や \nかしてやるから……のう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0103410" ]},
		{"command":[ "WAITINPUT" ]},
