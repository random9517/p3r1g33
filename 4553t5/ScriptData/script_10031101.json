		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「イヤーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_100116110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「グワーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おお、なんたるワザマエ！　カグヤは手も足も出せず防戦一方だ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ……！　このままじゃ……アレを使うしか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……………！？　なに……？　これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「なにって、説明したじゃん。君のパワーを３０００倍に強化する新装備だよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ウソ！　絶対ウソ！　だってこれ、お尻に穴が開いてて、しかもこんな大き\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「んんー？　『大きな』なにかなぁ～？　キミはその『風羅愚（プラグ）』を\n、ナニに使うと思ってるのかなぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110004" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「え？　そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ンフフフフフ、カグヤクン？　キミはナニを想像しちゃったのかなぁ～？　\nムフフフフフフッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110005" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だ、だって、直径が穴と同じぐらいだから、つい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あははははは！　それでつい、想像しちゃったっていうのかい！　カグヤク\nン！　キミはまったくドスケベ忍者だなあ！　アハハハハハハ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110006" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そ、そんなっ！　私……私はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「まあ、使い方はキミの想像通りなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110007" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……！！！！！　あのねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0185" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「嫌……！　使いたくない……！　あれだけは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110010" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「カグヤクン……聞こえるか、カグヤクン……ボクはいま、キミのヘッドバン\nドに仕込んだ通信機に、直接話しかけている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「珠魚！？　勝手に何を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110011" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そんなことはどうでもいい、それよりカグヤクン、くじけてはいけない！　\n今こそあの装備を使うときだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「嫌」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110012" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そんなこと言わないで！　言っただろう？　あの装備を使えばキミの感度も\nとい強さは３０００倍に跳ね上がるって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あんな変態装備は嫌」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「……あ、そう。どうしても使わないんだ。ふーん、それじゃあ無理にとは言\nえないな。カツマクンは困るだろうけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どういうこと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110014" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「だって目の前の敵を倒さないと、カツマクンと合流できないだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110015" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「……お前、さっきから誰と話してるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_100116110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「カツマクンは頼りにしているキミと分断されたまま、苦しい戦いを強いられ\nている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ……カツマ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「オーイ、聞いてるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_100116110004" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「さあカグヤクン！　今こそキミの愛が試されるとき！　吹けよカグヤ！　呼\nべよカグヤ！　カグヤよ叫べ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110014" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あああああっ！　もう！　こうなったら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110017" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「どうにでもなれーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110018" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ゴウランガ！　な、なんだそのコスチュームは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_100116110005" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これが私の新しい力……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110019" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「プラグ忍者カグヤ、見・参！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110020" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「アバーーーッ！　お、お尻のところに大きな穴が！？　っていうか、自分で\n『プラグ忍者』とか言うか！？　恥ずかしくないか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_100116110006" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くっ……！　だから使いたくなかった！　この力だけは、決して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110021" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「そりゃそうでしょうよ！　私だってそんなの使いたくない！　ナンデ！？　\nオシリナンデ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_100116110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「よくやった、カグヤクン！　しかしそれだけでは、そのスーツは不完全だ！\n　さあ、カグヤクン！　風羅愚（プラグ）を挿れろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110015" ]},
		{"command":[ "SETCHARA", "0", "char_00000212_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううううううっ……！　ど、どうしてこんなに太いのを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116110022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いやー、新機能を詰め込みすぎちゃって、つい……でも大丈夫！　キミなら\n入る！　カグヤクン、キミはケツの穴の大きな人だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020116110016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
