		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。そうだ……。あなたに、挿入されただけで、イッてしま\nった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「仕方ないだろう。私の身体は、それほどあなたのことを待ち望んでいたんだ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポと、つながることを……。こんなに淫らな姫だが、許して\nくれるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　お、オチンポで返事を……んんっ、さっそく腰を、動かして……\nんはぁっ、ああぁっ！」", "NORMAL" ]},
