		{"command":[ "SETIMAGE", "0", "still_00000131_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「き、気にしないと、言ってくれるのか？　ああっ、そうか、こうして責め続\nけてくれるのが、その証拠か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、激しくなる……オチンポ、ピストン……ああっ、ああっ\n、ずぼずぼと……っ！」", "NORMAL" ]},
