		{"command":[ "SETIMAGE", "0", "still_00000131_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はやく、あなたのオチンポがほしくて、たまらないんだ……。私のオマンコ\nに、オチンポをぶち込んでくれ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ、ああっ、入ってくる……っ！　お、おお……オチンポ……あな\nたのオチンポ……きてる……！」", "NORMAL" ]},
