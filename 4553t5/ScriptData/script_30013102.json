		{"command":[ "SETIMAGE", "0", "still_00000131_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっ、あっ、こすれるっ。ガチガチのオチンポが、私のオマンコを\n……んぁっ、出入りして……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「は、はっきり感じる。あなたのオチンポの形っ。太さも、凹凸も……んぁっ\n、オマンコをひっかく、カリも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポ……すごく、気持ちいい……。ああ、あなたのオチンポに突かれる\nたびに、こ、声が……ああっ、気持ちよくて……！」", "NORMAL" ]},
