		{"command":[ "SETIMAGE", "0", "still_00000131_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、はしたない、声……はぁっ、抑えられない……んぁっ、ああっ、勝手\nに、出てしまう、あっ、あっ、ああぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「声、だけじゃない。ああっ、あなたのオチンポに反応して、腰もくねってし\nまう。んっ、止まら……ない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、お、オマンコ、もっと……突いて……んぁあっ、ねだってしまう…\n…あなたの、オチンポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000131_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「媚びるように腰を振って、甘い声を出して……。ああ、こんなに淫らになっ\nては、あなたに……幻滅されてしまうかもしれないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3104117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　きゅ、急に深くにぃ……っ！　おっ、おお……オチンポ、ずぶ\nっと突き刺して……ぇ……！」", "NORMAL" ]},
