		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……オマンコをヒクヒクさせて……視線だけで、悦んでしまっている…\n…」", "NORMAL" ]},
