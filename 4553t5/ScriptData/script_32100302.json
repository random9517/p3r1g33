{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、ああっ、あんっ、隊長さん、隊長さん……ふあっ、ああっ、あ\nああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、そこ、気持ちいい……んっ、隊長さん、好き……好き……ふああっ\n、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「もっと、もっと……おっぱいもオマンコもいじって……んんうっ、あんっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、そろそろ……イきそう……んっ、ふっ？　あ？　え？　た、隊\n長さん！？　いつからそこに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「少し前から部屋に……？　ふああっ、恥ずかしい……。何をやってたかって\n、見れば分かるでしょう……うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゃんと説明しろって……隊長さんに抱かれたことを思い出しながら自慰を\nしてたんですよ……分身して……うう、恥ずかしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「言い方がなってないって……ええ、そんな言い方……分かりましたよ！！　\nもう、エッチなんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私は隊長さんとのセックスを思い出して、分身オナニーでオマンコとおっぱ\nいをいじってました！！　これでいいですか？　恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「その触手は……って触手じゃありません、この頭部はしっぽみたいに伸ばせ\nるんです……それでオナニーしてたら世話はないって、分かってますよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それぐらい、しっぽでも使わないといけないぐらい、隊長さんとのセックス\nが気持ちよかったんですよ！！　もう……鈍いんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それで、ここまで言わせたんですから、隊長さんも参加してくれるんですよ\nね？　って、もうその股間を見れば分かりますけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ……それじゃあ、隊長さん、来てください……私たちのオマンコ、隊長\nさんを待ちわびてますよ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あうっ、ふっ……来たあっ！！　相変わらず硬くてギンギンで、熱くて……\nんっ、私たちのオマンコをずりゅずりゅなぞってる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、大きなカリ首が筋をぞりぞりって……ああっ、んっ、ひあっ、\n段差でクリをコリコリしたら……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ひうっ、うっ、あああっ、しっぽ、しっぽが勝手に動いて……んん、おちん\nぽとしっぽでずりゅずりゅって……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んっ、隊長さん、隊長さんっ！！　オマンコずりゅずりゅす\nるのもいいけど、おちんぽ、おちんぽ中に入れてください……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、意地悪、こすられてるだけじゃ、物足りないんです……おちん\nぽ、おちんぽくださいっ！！　オマンコにおちんぽっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ……ああああっ！！　入って、来たぁっ！！　隊長さんのがちがちおち\nんぽ、中に来たあっ！！　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、これ、凄い、んっ、入れられた私と、そうじゃない私の快感が入り混\nじって……んんっ、頭っ、頭蕩けちゃう……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んっ、オマンコ、おちんぽでずこずこピストンされるたびに\n、ふああっ、気持ちよさがばちばちって……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「はあっ、あっ、あっ、んっ、あっ、おちんぽ抜かないで……ひぐっ、もう一\n人のオマンコに来たあっ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、なんだか凄い、気持ちよさの上下が凄いっ、ふああっ、あっ\n、これ、揺さぶられる、頭が揺さぶられるうっ、あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、自分の身体で気持ちいいっ！！　おっぱいがこすれて、んっ\n、はあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、こんな、こんな気持ちよさがあったなんて……隊長さんのおちんぽ\nと、自分の身体と……んあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、やっ、んっ、そんなおちんぽ動かさなくても、一番気持ちいいのは隊\n長さんのおちんぽですっ、分かってます！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あっ、ふあっ、また抜いてもう一人に、んっ、あっ、ああっ、\nあんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、んっ、きゅって締めたタイミングで奥突くの、好きっ、ふっ\n、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、また抜いて、もう一人に……来たっ、あっ、んんっ、ああっ、これ\n、いいっ！！　交互におちんぽっ、いいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、上の私も、下の私も、隊長さんのおちんぽでずぼずぼされてっ、ふ\nああっ、あっ、気持ちいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あっ、イく、イく、隊長さんのおちんぽで、二人とももうイ\nっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、うっ、隊長さんもイいきそうなの、分かりますよ……んっ、おちんぽ\n、中でびくびくって震えてますからっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、あっ、隊長さん、隊長さんのおちんぽ汁、中に、中にいっぱい\nください！！　んんうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、イく、隊長さんおちんぽでイく、イっくううううううううう\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふああっ、なん、なんで抜くんですか、あっ、んっ、おちんぽでまたおまん\nこずりゅって、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「熱い、おちんぽ汁熱い……んっ、平等に二人のマンスジに射精って……どっ\nちも私なんですから……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あ、でもこれ好きかも……オマンコの入り口どろどろにされて……二人の間\nでねばねばに糸を引いて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、でも、やっぱりちょっと物足りない……隊長さんのおちんぽ汁、中に\n欲しかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ほら、私たちのオマンコも欲しい欲しいって、ぱくぱくしてるの、分かるで\nしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽにキスして、おちんぽ汁くださいっておねだりしてるの\n……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、隊長さん、凄い、ぎらぎらした顔してる……私のこと、ものにしてや\nるって顔してます……やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふああっ、んっ、オマンコサンドイッチの中で、隊長さんのおちんぽがまた\n硬くなってるのが分かります……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「二回目、します？　いいですよ。二回でも三回でも、何回でも私の身体で気\n持ちよくなってください、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「でも、そのついででいいから、私のことももっと気持ちよくしてくださいね\n……ひあっ、ああんっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、そんな、いきなり入れて……んんっ、あっ、ピストン凄い、上も下も\n、ピストンでガンガン突かれたら、こんなの良すぎる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふああっ、あっ、んっ、んっ、お腹の奥から、おちんぽでかき混ぜられて、\nじんじんって、とろとろって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「二人分の気持ちよさが混じり合って、あああっ、あんっ、頭がおかしくなり\nそう、んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、ふうっ、隊長さんは、どっちの私が気持ちいい？　上の私？\n　下の私？　あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「どっちも最高って……やんっ、あっ、そんなこと言われたら、オマンコきゅ\nんきゅんしちゃう！！　きゅんきゅんおちんぽ締めちゃう！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふううっ、んんっ、全部、全部気持ちいい！！　隊長さん、好き、好きっ！\n！　おちんぽも、隊長さんも好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、そんな高速でピストンされたら、オマンコ溶けちゃう、おち\nんぽで溶かされちゃうっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、うっ、頭っ、オマンコから頭の中に気持ちよさが、響いて…\n…二人分のオマンコから気持ちよさが……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんのカリ高おちんぽで二人のオマンコほじくられて……ふあっ、ああ\nあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「オマンコも頭も、ぐずぐずに溶けちゃってる、んんうっ、おちんぽ、おちん\nぽ凄いっ、んっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっあっ、また、またイく！！　隊長さんのおちんぽで、二人同時にまたイ\nくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、隊長さんも一緒に……今度も一緒に、イきましょう、んっ、んん\nっ、オマンコ締めますからっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、きゅっきゅって締めたら、おちんぽが悦んでる、んっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、オマンコの中で亀頭が膨らんでるの分かります、熱くなってるのも\n……オマンコで感じ取れちゃうっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おちんぽ汁の準備してるの、オマンコで分かります。隊長さんの気持ちいい\nお汁、オマンコが待ちわびてるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、あっ、隊長さんの顔も、気持ちよさそうに蕩けてきてる！！\n　私たちのオマンコで、蕩けてきてる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「イって、隊長さんもイって、私たちも、んんっ、あっ、イく、イく、おちん\nぽでイっくうううううううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあああっ、来た、おちんぽ汁、オマンコに来たあああっ、あっ、んっ、ふ\nううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、なんでまた抜いて……ふあっ、もう一人のオマンコにも来たああああ\n、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、嬉しい、隊長さんの平等中だし嬉しいっ！！　んんっ、オマンコも二\n人分悦んでるっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、ふっ、ああっ、んっ……隊長さん、平等なおちんぽ汁、あり\nがとうござます……気持ちよかった……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「分身オナニーを見られたときは恥ずかしすぎて逃げたくなったけど、こうし\nて隊長さんに愛してもらえたのなら良かったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、それにしてもこの二人分の気持ちよさ……ちょっと、くせになっちゃ\nいそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんも二人同時に愛してくれましたし、これからは二人同時でお相手し\nましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「え、たまになら？　普段は一人をじっくり愛したい……もう、隊長さんった\nら、くどき上手ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私も一人に全部おちんぽ汁注がれる方が好きかも……隊長さんの顔を見つめ\nながらセックスしたいですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「でも……一人でも二人でも、またいっぱいっぱい抱いてくださいね、あなた\n。ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、また、またおちんぽ抜いた、んっ、ああっ、あうううっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おちんぽを私たちの目の前に持ってきて……ふあっ、あああっ、顔に……ん\nううううっ、顔と眼鏡におちんぽ汁が……ひゃああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあああっ、私たちの誇りある眼鏡に……おちんぽ汁が……んんっ、あっ、\nなんだか、それも気持ちいい……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、匂いと粘つきが……あんっ、あっ、まだ、まだ出るんですか……ひあ\nああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ……んっ……二回目なのに、凄い量でしたね……そんんなに気\n持ちよかったんですか……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「中にもらえなかったのは残念でしたけど、これはこれで……んっ、隊長さん\nの気持ちよさが私に振りかけられてる感じで、嫌いではないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、隊長さんも満足そう。マーキングできて、嬉しいですか？　でも、印\nがなくても私は隊長さんのものですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ん、今の言葉で残り汁が……もうべとべとになってるのに、これ以上追加し\nなくても大丈夫ですよ。やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「気持ちよかった……隊長さんも気持ちよくなってくれて、よかったです。隊\n長さんが望むならいつでもお相手しますから。ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「また……いっぱいセックスしてくださいね、あなた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}