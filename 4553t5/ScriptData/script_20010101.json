{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "sbg_0024" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_018" ]},
        {"command":[ "WAITMOVE" ]},		
		{"command":[ "SETTEXT", "――それは一年前の出来事であった。", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "酉年の２０１９年、『己亥（つちのとい）』の年。新しい時代の幕開けともい \nえるメモリアルなこの時期。", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "若苗家の三姉妹、序（ついで）、破（やぶる）、急（いそぐ）は、テストでの \n赤点の多さに困っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "勉強をすればいいのは分かっているが、それができたら苦労はしない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そもそも、努力しても結果がでるとは決まっていない。それが人生の難しいと \nころである。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "三人は悩んだ末に、近所の神社へ願掛けに行くことにした。困ったときの神頼 \nみとはまさにこの事。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "しかし、今の三人はワラにもすがりたい状況だった。早速テストの点数を少し \nでも良くするために、近所の神社で願掛けに向った三人。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そこで亥年を司る十二支の１人・お亥さま（おがいさま）に出会った。お亥さ \nまによると、今年は６０年に一度の『己亥（つちのとい）』の年らしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "『己亥（つちのとい）』は大きな災いが起こる恐れがあるという。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "土と水の属性を持つ若苗家の跡取りが『悪霊を払う太刀』で変身し、様々な厄 \n災を退治する使命を命じられる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "突然、言い渡された使命――。若苗家の跡取りである序、破、急の三人にとっ \nて宿命だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "確かに厄災を退治することは大切だが、今はもっと重要なことがある。神社に \n来たのだって、テストの点を少しでもよくするためだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "余計な厄介事を押しつけられても困る。華麗にスルーしようとする三姉妹だっ \nたが、お亥さまが待ったをかけた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "報酬として学校の成績を良くしてやると言い出したのだ。思わぬ提案に顔を見 \n合わせる序、破、急の三人。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "面倒事はゴメンだが、悪い話ではない。確実に学校の成績をよくできるのは魅 \n力的だ。三姉妹は渋々ながら災厄退治をすることを決めた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "自分の成績と世界の平和を守るための、三姉妹の秘密の戦いが、今始まる！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "DISPIMAGE", "0", "TRUE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "女怪人が市外にある施設を襲っているという情報を受けた三人。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "これも『己亥（つちのとい）』災いというわけらしい。序と破と急は、大急ぎ \nで現場へ向った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「は～～～～～、めんどー臭いなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010001" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "4", "RIGHTEND", "0" ]},
        {"command":[ "DISPCHARA", "2", "TRUE" ]},
        {"command":[ "SPOTCHARA", "2" ] },
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ま、約束だしねー、それに勉強するより効率いいんじゃない？　これ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010001" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うん！　成績上がるんなら、なんだって大歓迎！　気合い入れて行くですよ \n、破！　急！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010001" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「けどさぁ、なーんか騙されてる気もするんだよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010002" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「マジそれ！　いい感じに利用されて、後でポイッてされる可能性もあったり \nなかったり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010002" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "9", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そんなこと言わないの！　厄災退治は私達若苗家の使命！　頑張るです！　 \nで、成績アップするですよ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010002" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うーん……いきなり使命って言われても困るよぉ。それに、女怪人って…… \n警察に言った方が良くない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010003" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「だよねー。もう逃げられてる可能性もあるしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010003" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「だから、急ぐです！　逃げられたりしたら、私達が赤点地獄から逃げ出せな \nいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010003" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "SETTEXT", "現場から逃げられてしまうと厄介だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "自然と三人の脚はスピードを増していく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "その時、どこからともなく笑い声が聞こえてきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ふははははは！　この貴重なアイテムは我々が頂いた！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ビルの屋上に響く高笑い。あまりに怪しすぎる風貌。三姉妹はすぐ、あれが犯 \n人だと確信した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ、あのあからさまに怪しい人ってさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うん。あの人だね。見分けが付きやすくて超助かっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010004" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "6", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、わかりやすいのは大歓迎！　探す手間が省けたですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010004" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "手には盗み出したと思われるアイテムが握られている。どうやら施設を襲って \nいた犯人で間違いないようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "赤点脱出の切っ掛けが、すぐ目の前のビルの屋上に輝いている──三姉妹は、 \nウッキウキでビルの階段を駆け上がっていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふっふっふっ、これで相手は袋のネズミ……ってかさ、エレベータ使えば良 \nかったんじゃないの……？　ふう、疲れた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010005" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "5", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ほら、破！　気合い入れなさい！　これで赤点の補習授業に追われる生活か \nら抜け出せる……むふふ♪　さあ、行くですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010005" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ、声デカくない？　気づかれちゃっても知らないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010005" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「急ってば、意外と心配性なのね。けど、細かいこと気にせず、どーんと正々 \n堂々名乗りを上げて──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010006" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "1", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ムッ！？　何者だ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……正々堂々名乗りを上げて、正面突破。これ一択しかなさそうね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010007" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あーあ、不意打ちのチャンスだったのに……。『楽して勝つ』があたしの信 \n条なんだけどなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010006" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ってかさぁ、本当にあの名乗りするの？　ボク、イヤだなぁ。なんだか恥ず \nかしいもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010006" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええー？　恥ずかしい……？　お、お姉ちゃん、一生懸命考えたのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010008" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "9", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「おい……何をコソコソ隠れている！　出てこい！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "3" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……いい？　ここに来る前に練習した名乗り、しっかり決めるですよ──せ \nぇの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010009" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "三人は気を取り直し、女怪人の前に立ちはだかる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そして序は、女怪人に向ってビシッと指をさした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人いわく！　天網恢恢疎にしてお漏らし禁止！　公共の場で悪いお漏らし \n厳禁ですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……いきなり出てきて何を言ってるんだ？　警察かと思ったが、どうやらア \nホが来たらしいな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "突如現れた三姉妹を見て、女怪人はやや呆れた様子を見せるも手にした何かを \n背中に回して隠そうとしていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あ、アホッ！？　お姉ちゃんや急ならまだしも、このあたしをアホだなんて \n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "9", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「見て、お姉ちゃん……あの人、手を後ろに回してる。背中が痒いか、何かを \n隠してるかのどっちかだよ。気をつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010007" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "おそらく、襲撃で略奪したアイテムなのだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女怪人をやっつけ、アイテムを取り返す──そして成績アップ！　三姉妹は内 \n心舌なめずりしつつ、正義の炎を燃え上がらせた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「あいにく、お嬢ちゃん達の相手をしているほど暇じゃなくてねぇ……オラッ \n、とっとと帰りな！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふふふ、あははは……あーっはっはっは！　私達三姉妹のデビュー戦を飾る \nにふさわしい悪党みたいですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010011" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「あぁん？　この善良な市民を捕まえ、悪党呼ばわりたぁ、近頃の女学生は口 \nが悪いねぇ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女怪人はとぼけた顔をして、立ち去ろうとする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「その手にしたモノ……置いていくなら、見逃してあげてもいいのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……アアン？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ヒッ！？　あ、あの、血気盛んな姉が、そう言ってるのっ。妹も同意してる \nみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010009" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "9", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……破お姉ちゃんったら、もう…………まあともかく、その手にしたア \nイテム、返して。泥棒しちゃ駄目でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010008" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「泥棒……ねぇ。あんた達、このアタシに因縁つけようってのかい？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "女怪人はフンフンと荒い鼻息を漏らす三姉妹に取り囲まれ、逃げるのを諦めた \nらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「人を悪党だの、泥棒だの、いちいち気に障ること言うじゃないか……あんた \n達には、少しお仕置きが必要みたいだねぇ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "居直ったかのように、薄ら笑いを浮かべて身構えた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "もはや戦いは避けられない──。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "若苗三姉妹は目を見合わせると、こっそり練習していた『お約束の口上』が自 \n然と口から滑り出した。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人いわく！　為せば成る！　為さねば成らぬ！　何事も！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「成らぬは、人の為さぬなりけりはべりいまそかり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010010" ]},
		{"command":[ "SETCHARA", "1", "char_00010201_01", "7", "LEFTEND", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「お呼びとあらば、悪・即・斬！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010009" ]},
		{"command":[ "SETCHARA", "2", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「三人揃って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010013" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「不言行殺三姉妹！　サムライテール！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010014" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「不言行殺三姉妹（ふげんぎょうさつシスターズ）だと！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「人様の貴重なアイテムを簒奪しようとしたその罪、到底看過できないです！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010015" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「月と太陽、その他諸々の神様に代わってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010013" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「普通にぶっ殺しちゃうからね。覚悟だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010012" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ええ……？　そこはもっと、こう……有名アニメっぽい決め台詞をぶっこむ \nところじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010014" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "SETCHARA", "0", "char_00010201_01", "9", "LEFTEND", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「やだよぉ……恥ずかしいもん。それにぶっ殺すのは事実だし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010013" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「何言ってるのよ。破が無理やり某アニメのセリフに誘導してるんじゃない！ \n　パロディ禁止！　わかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010016" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「はぁ……舐められたものだな。目の前で家族会議が開かれるとは……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "怒りを露わにして、鋭い視線を向けてくる女怪人。しかし三姉妹たちは怯むこ \nとなく、怪人を睨み返す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……面倒くさいから、ちゃっちゃと終わらせて、さっくり成績アップさ \nせましょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010017" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うんうん、それがいいよ。物事はなんでも合理的に運ばなきゃねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010015" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ、もう殺していい？　早く殺そうよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010014" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「急……あんた、せっかち過ぎ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010018" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "5", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人曰く、『急いてはことを仕損じる』。焦って大切な『琴』を壊してしま \nい怒られるって意味よ。今のあんたにピッタリね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010016" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「うーん……ことわざで叱られるの、ボク、好きじゃないなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010015" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「……オホン。そろそろ始めていいか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ほらぁ、敵さん、怒ってるよぉ。とっとと殺して黙らせよう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010016" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「本当に凶暴ね、あんた……ま、いっか。さあ、姉さんっ、始めましょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010017" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「オッケー！　私達三姉妹の力、今見せてあげるです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010019" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "序の掛け声と共に、三姉妹は一斉に女怪人に襲い掛かった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「戦闘開始！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010020" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "7", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" , "1" , "2"]},
