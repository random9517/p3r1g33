		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「驚かないのか……とは？　べつにこれくらい……問題ないわ……んっ……\nふぅ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あなたには世話になってるから……お礼もしたかったし……あっ……ふぅ、\nんんっ……ご奉仕ってやつ？　わたしもしたかったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「それに地球人はおっぱいが好きで……おっぱいで、ご奉仕すると喜ぶって\n聞いたから……どう？　あなたも好き？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そう。ならよかった……やり方は、なんとなく知ってるけど……これでいい\n？　もっと強く挟んだ方がいいの……？　わかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「どうしたら、気持ちいいか……教えて。できるだけ……そう、するから……\nんっ……んふぅっ……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「……大丈夫。痛くは、ない……けど……不思議ね……こんなことして、本当\nに気持ちいいの？　あぁ、そう……ならいいけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……んっ、んんっ……強く、擦れた方が気持ちいい……？　そう\nいうもの、なんだな……ンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……しっかり支えておくから……好きに動いて、いい……はぁ、\nあっ、あっ、んっ、あんっ……くふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「それにしても……地球人の生殖器って、こんなに硬くなるのね……そっち\nこそ、激しく擦って……痛くないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んふぅ、んんっ……チン、ポ……？　チンポって呼べばいい？　そのチンポ\n……熱いし、明らかに異常を起こしてるみたいだけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「これが、正常……？　んっ、ふっ……先っぽから、なんか粘液が出てるのも\n……？　そうなの？　我慢汁……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そうなんだ……気持ちいいって……感じてる証拠、なんだ……んっ……だか\nら、さっきから……どんどん溢れてきてるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルしてて、変な感じだけど……これが、気持ちいい……のよね？　\nなら、問題ないから続けて……んっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「好きなように……おっぱい、使っていいから……んふっ……んっ、あんっ…\n…もっと強く擦りつけていいわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっ……！　んふっ……！　す、すごい……おっぱいに擦りつけるたびに…\n…チンポ、硬くなってく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「こんなに腫れてるのに……痛くない、のよね……？　本当に不思議だけど…\n…そういうもの、なのね……あっ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「わたし……？　べつに、わたしは……特には……気持ちいいかって言われて\nも、よくわからない……けど……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「不快感は、ない……けど……あなたが、いいなら……それで、いいから……\nはっ……あふっ……んぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……確かに、おっぱい……火照ってきたかも……チンポが熱いか\nら……それで、一緒に……んっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「それに……チンポで、擦られてるから……摩擦で、胸元が熱くなってる……\nはぁ、あっ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んんっ！　おっぱいの中で……チンポが、動いてる……わたしの、おっぱい\n……そんなに気持ちいい、のね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「よかった……んっ、はぁあ……いっぱい、気もよくなって……チンポ、好き\nに……んあっ……あぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あんっ……あ、あぁっ……！　ヤケドしそう……んっ、熱いっ……興奮、\nしてる……のね……あんっ……あっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁあ、あっ……そんなに必死に腰振って……ンぅっ、おっぱい……好きな\nんだ……あっ、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ！　あっ、あっ……いい、よ……もっと、強く……擦りつけて…\n…ンっ、んふっ……あなたが、好きなように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「気持ちよくなると、射精……するんでしょう？　ええ、それくらい知ってる\nわ……んっ……それを、おっぱいで受け止めるんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「おっぱいご奉仕のやり方は、大体は知ってるから……んぅ、心配せず……\nいっぱい気持ちよくなって……いっぱい出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はっ、はんっ……あはぁっ……おっぱい、熱い……はぁ、ああぁっ……んっ\n、んんっ……くっ……んぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「大丈夫、ちゃんと……おっぱい押しつけて、支えてあげるから……あンっ…\n…あなたは……チンポ、擦りつけて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっんんっ！　はっ……す、すごいっ……そんなに強く、擦って……はっあ\nっ……グチュグチュって……ヤらしい音が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁっ……なんか、生ぐさい匂いも漂ってきて……んっ……んふぅっ\n……もう、出る？　射精……する……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「わかった……しっかりおっぱいで、チンポを挟んであげる……から……はっ\n、んっ……あっ、はぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んんんぅぅっ！　すごっ、いっ……！　あっあふっ……！　出てるっ……\n熱い、のっ……はっあぁぁっ！　あぁっ、んはぁぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「チンポ、暴れてるっ……！　ンンぅぅっ！　おっぱいの中で……跳ねて、\nんっ……あっ、くっ、はぁっ！　あふぅっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ……あふっ……ドクドクって、出てっ……あぁっ……なに、これ……\nすごい、出てるっ……！　あぁっ……あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あっという間に……おっぱいが、精液まみれになってる……んっ……匂いも\n、キツいし……鼻が曲がりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ふぅう……はーっ……はぁはぁ……ホントにいっぱい出たわね……それだけ\n気持ちよかったってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そんなにわたしのおっぱい……よかったのね……ご奉仕したかいがあったわ\nね……ふぅ……まだ胸がドキドキしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「でも、あなたは……チンポ、大きくなったままね……射精したら、小さくな\nるって聞いたけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「なるほど……まだ満足してないってことね。なら、もっと射精させればいい\nのね……わかった、ご奉仕を続けるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……射精、しても……硬く、大きくなったままね……何回くら\nい出せばおさまるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「……そんなに？　元気……？　なのね……つまり、たくさん子孫を残しやす\nい、ということ……なのかしらね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、んんっ……ごめんなさい……余計な話だったわね……またこの\nままおっぱいで挟んであげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「わたしの方からも……動くの？　おっぱい、揺らして……？　こ、こう…\n…？　んっ……難しい、わね……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁあ、あっ……あふっ……チンポを、強く擦りつけられると……上手く、\nおっぱいを……動かせない、わね……んぅンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっふっ……ンンっ……それに、さっき出されたザーメンで……おっぱいが\nドロドロになって、滑る……あふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっあっ……あふっ……んっ、んっあぁっ……おっぱいだけでなく、\n身体中が火照ってくる……はぁあっ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そ、それに……んっ、さっきから……鼻を突く匂いが……くっ、ふぅうっ…\n…ク、クサいっ……んんっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ザーメンのせいで……クサくて、頭までボーっとしてきた……あっ、あんっ\n……んっ、んふっ……だ、だいじょう、ぶ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ちゃんとご奉仕は、するから……はっ、んっ……あはぁっ……おっぱいを、\nぎゅっぎゅって……押し、つけて……ンンぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あぁあっ……！　熱いっ……チンポ熱くて、しかも硬いっ……谷間がヤケド\nしちゃいそう……んっあっ、ああっ……あふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「……ど、どう？　おっぱい……ぐにぐにって、擦りつけて……んっ……はぁ\nあっ、はっ、はふっ……チンポ、包み込んで……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「気持ちいい？　気持ちよく……なってる？　よかったぁ……ああっ、あふっ\n……あんっ、あはぁっ……あっ、あっ、あっくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「んっ、んっあっ……はっ……はあっ！　たっぷり射精できるように……して\nあげるわよ……はぁ、んあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「また、出そうになってきたの……？　いい、わよ……さっきみたいにおっぱ\nいで、受け止めてあげるから……あっ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「満足するまで……好きなだけ、射精して……んっ、ああっ……も、もっと\n楽しみたい、の……？　んぅっ……我慢しないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_0103216" ]},
