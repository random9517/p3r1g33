		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ふぅ……どうにか捕まえた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114220001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「無傷で捕まえるってのは、手間がかかるねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114220001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0156" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "女子学生Ａ" ]},
		{"command":[ "SETTEXT", "「ううう～！　放せ、放せ～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わるいけどそりゃ無理だ。しばらく、どこかの教室でおとなしくしててもら\nうしか――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁああ～～ん、もう～～！どうしてあなたたち、襲来者（インベーダー）\nなんかになっちゃうのよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114220001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダイヤナ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0159" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうやら向こうでも、学生たちが襲来者（インベーダー）に変身させられて\nいるようだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114220001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりあれも、ピンクのガスのせいなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「だと思うけど……でも、おかしいよね？　わたしたちも、ガスを吸い込んじ\nゃったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114220002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）にされていませんね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114220001" ]},
		{"command":[ "SETCHARA", "0", "char_00001101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「おそらく、ガスの効き目はそこまで強力ではない、ということでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020114220001" ]},
		{"command":[ "SETCHARA", "0", "char_00003002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「牛神様！？　どうしてここに！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「学園の危機ですので。それはともかく、あのガスは普通の人間なら襲来者（\nインベーダー）化してしまうようですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020114220002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「皆さんは女幹部やヒーロー。知力はともかく、体力や面の皮の厚さは並みの\n人間と比べ物になりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020114220003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「つまり、並の人間用のガスじゃ効果がないってことかい……後半、ほめられ\nてる気がしなかったけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114220002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0156" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちょっとみんな～！？　おしゃべりしてないで、こっちを手伝って～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114220002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「学生たちが、次々と襲来者（インベーダー）化しているんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114220001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっと、いけねえ！　とにかく学生たちを捕まえろ！　これ以上被害を増や\nすな！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
