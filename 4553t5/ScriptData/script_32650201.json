		{"command":[ "SETTEXT", "「んぁっ、はふっ、射精ぇっ、すごいぃいいぃぃ……っ！　んぁっ、精液が顔\nにまで、届いちゃってます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。２回目なのに、こんなに勢いよく射精してしまうだなん\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様のオナホールが、とても気持ちよかったから……ですよね？　あふぅ\n、自分の精液を顔に浴びてしまうなんて……」", "NORMAL" ]},
