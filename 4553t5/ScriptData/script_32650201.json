		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様の精液の匂いも混じっているような……。もしかして、隊長様もシャ\nナのおちんちんでイッたのでしょうか……？」", "NORMAL" ]},
