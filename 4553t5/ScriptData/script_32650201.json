		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ふたり一緒に射精したから、こんなにたくさん、勢いよく精液がでて、シャ\nナの顔まで届いたのかもしれませんね」", "NORMAL" ]},
