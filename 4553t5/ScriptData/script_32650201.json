		{"command":[ "SETIMAGE", "0", "still_00026502_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、隊長様のオナホール……シャナの精液で、べとべとにし\nてしまいましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様……ど、どうでしたか……？　シャナは、ちゃんと隊長様のことを気\n持ちよくできたのでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様に、以前してもらったようにできるよう、心がけたつもりではあるの\nですが……」", "NORMAL" ]},
