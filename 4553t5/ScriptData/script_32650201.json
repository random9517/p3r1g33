		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あぅっ、あぁっ！　射精しながら、隊長様のことをうごかしてし\nまいますっ、んっ、くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様に、いっぱいびゅるびゅる中出ししてるって想像したら、手がとまら\nなくてっ、射精もとまらなくてぇっ！」", "NORMAL" ]},
