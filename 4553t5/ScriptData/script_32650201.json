		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「最後に、以前と同じようにホテルへとやってきましたが……。隊長様？　ど\nうされたのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「最後の手段を使うしかない？　そ、それはいったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「えぇっ！？　シャ、シャナが隊長様を使う！？　使うというのは、つまり…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そうですよね、隊長様に、シャナのおちんちんを挿れるということ……。い\n、いいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「……わかりました。隊長様を元の姿に戻すために、シャナ、隊長様を使って\nみます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00026502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様に、ローションを注いで……っと。とてもぬるぬるして、ちょっと持\nちにくい、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あ……あうぅ……こんなときなのに、シャナのおちんちんが大きくなってし\nまっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「は、はい……。それでは、挿れ……ますね……。た、隊長様の、穴に……お\nちんちん……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぅ……っ！　は、入っちゃいましたぁ……！　隊長様の、中にぃ……シャ\nナのおちんちん……くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様の中、すっごく、狭くて……っ！　あっ、ふ、不思議な感じがします\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ヒダヒダが、シャナのおちんちんに、絡みついているような感じで……。オ\nナホールって、こういうものなのですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様は、苦しくありませんか？　その……これには隊長様の魂が入っ\nている訳で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「大丈夫……なのですね。このまま、動かしてしまっても、平気ということで\nしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「その……隊長様におちんちんを挿れていると思うと……。シャナは……なん\nだかイケナイことをしている気分になってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい隊長様っ！　隊長様を、動かしてしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぅっ、んっ、すごい……っ！　手でしごくのより、隊長様を使う方が、ず\nっと気持ちいい、です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「でこぼこが、シャナのおちんちんの先っぽを弾いて、ああっ、腰にびりびり\nってきちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ら、乱暴に扱ってしまって、ごめんなさい……！　で、でも、気持ちよくっ\nて止まらないんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、先っぽから、根元まで……んくっ、隊長様に、包まれて、\n締めつけられる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぅっ、あっ、おちんちんをしごくの、気持ちいい……っ！　隊長様っ、気\n持ちいいです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「このオナホールに、隊長様の魂が入っているからでしょうか……んぁっ、中\nが、勝手に動いているような気が、します……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ヒダの、うねうねがっ、んはぁっ、おちんちんをぎゅうっと、締めあげてく\nるようなぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、すっごく気持ちいいですっ、隊長様の中、気持ちよくって、シャナ\n、おかしくなっちゃいそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様だから、大事にしなくちゃいけないって、思っているのに。でも、お\nちんちんもっと、気持ちよくなりたくて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、隊長様……もっと、気持ちよくなってもいいのでしょうか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そうですね、元の姿に戻るためには、いっぱい挿れられて、気持ちを理解し\nないといけないんですもんねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「で、では僭越ながら、シャナが隊長様にいっぱいおちんちんを挿れて、射精\nも……しちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はいっ、もうこみあげてきちゃってるんです……！　隊長様のオナホールで\n、イキそうになってるんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナのおちんちん、ぱんぱんに膨らんで、さっきからビクビクと震えてし\nまっていて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「このまま、射精……隊長様にむかって、射精ぇ……っ！　はぁ、はぁ、でち\nゃいます……精液でるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、あはぁあああぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああ……っ！　隊長様から、シャナの精液、びゅくびゅくってでてき\nちゃってます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「と、とまりません……っ。ひとりでするときより、ずっといっぱい射精しち\nゃってます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……隊長様の、中も……。ぎゅっ、ぎゅぅっと、痙攣している\nみたいに動いて……ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぅ……搾られて、また……奥に残っている精液も、ぴゅるっとでてきてし\nまいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これで、隊長様も元に戻ることができるのでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「どうですか、隊長様。身体になにか、変化があるような気はしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「えっと……まだ、ということは、もっとしないといけないということになり\nますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナは……その……もっと隊長様としたいので……。このまま、使わせて\nもらってもよろしいでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ん……あぁ……。おちんちんが、まだまだ硬いままなんです……。隊長様の\n中が、とても気持ちよくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「も……もっと使わないと……。隊長様が、元の姿に戻るために……はぁ、は\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「また、隊長様のことを動かしちゃいます……んぁっ、さっきより、ぬるぬる\nしてるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、また、すごく気持ちいいのが、おちんちんから全身にひろが\nってきます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、と、止まらなくなっちゃいます……っ！　乱暴に、隊長様のことを\n、ごしごし動かしちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「な、中っ、気持ちいい……っ！　ツブツブ、ヒダヒダ、おちんちんに密着し\nて、こすれるのがたまらなくて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁあっ、隊長様のこと、お、オナホールの姿をしているからって\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「本当に、オナホール扱いして……んぁっ、ご、ごめんなさい、でも……っ！\n　おっ、おちんちんが気持ちよくってぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「くはっ、あっ、ああぁっ、勃起おちんちん……隊長様の中で、どんどん膨ら\nんでいっちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「さっき、射精したばっかりなのにぃ……っ。隊長様のオナホールが気持ちよ\nくって、どんどん、射精したくなっちゃって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、このまま、また隊長様にむかって、シャナ……中出ししてしまいそ\nうです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様でおちんちんをしごいて……んっ、はぁあっ、イッちゃいます……お\nちんちん、イクのぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、隊長様ぁ……ローションを足してないのに、中が、どんどん\nぬるぬるにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これって、隊長様も、シャナのおちんちんで気持ちよくなってくれてるって\nことでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「だ、だったら嬉しいです……っ！　はぁ、はぁ……お、おちんちんがますま\nす、疼いちゃって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様ぁっ、シャナのおちんちんと一緒に、き、気持ちよくなって、く\nださいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナは……シャナは……っ！　あっ、ああっ、もっと激しく、おちんちん\nしごいちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様の中、シャナでいっぱいにしちゃいます……！　はぁ、はぁ、隊長様\nっ、隊長様ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026502_01_06" ]},
