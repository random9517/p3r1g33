		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「うぅ……これくらいでは、まだ隊長様は元の姿に戻らないようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「もっと隊長様のことを使わなければならないということなのでしょうか。隊\n長様、よろしいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
