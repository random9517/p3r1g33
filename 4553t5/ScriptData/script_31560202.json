{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「た……隊長……。大変だ、昨日から身体が熱くて辛抱できないよ……。風邪\nじゃないかと思って体温を測っても、微熱ってほども熱はないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「もしかしたら、こっちの宇宙にしかない流行病にでもかかっちまったのかも\nしれない。隊長はこんな風になったこと……あるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うん。胸と……下腹のあたり。あとはおかしいのは……ま、股のところなん\nだ。ずっとウズウズしていて気持ち悪いったらないよ。……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「調べてみるから任せろって？　ハハ……。おまえは医者の真似事でもするつ\nもりかい？　ま、信用してみるのも悪くないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「う……く……。ンンっ……ンっ……。ねえ……本当にこれが、人間の医療行\n為ってやつなのかい？　ま、股を見てくれとは言ったけどさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015602_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こんな棒で固定されるのは初めてだよ。こんなことしなくたって、脚は開く\nし……。その、なんていうか、ますます落ち着かなくなってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……ねえ……。マジマジ見てないでなんとか言いなよ。戸惑ってる私がバカ\nみたいじゃないか。……へ？　使う道具に迷ってた？　道具、道具って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ああそうか。悪いね、真剣に治療しようとしててくれたのに……オマンコを\n奥の奥までのぞかれて、私は勝手に恥ずかしくなっちゃってさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ！　ソ、ソレが道具……？　まっさーじきと言うんだね。な、なんだか\nデカくて少し怖いよ。それを股間にどう使うのか、説明……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「いいいいいっ！？　アッ！？　う、ウソだろうっ！？　せつめっ……説明ぃ\nいいいっ、イイイイイっ！？　アヒッ！？　あっ！？　アッ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「これっ、これ震えて……震えて！　あっ！？　あうっ！？　アッ！？　あっ\n、あっあっあっあっ、オマンコの粘膜ブルブルブルブルっ、ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あ……穴っ、アソコの穴にあててるのかい！？　……んぁあああっ！　アア\nアアッ、嘘、うそ、ウソ、痺れ……ああっ！　ああーっ、ああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ！　うっ、あっ、アアッ！　だ……ダメだよ、ダメ……ダメ！　こらッ\n、何動かしてんだい！　上にズラしたらそこはクリトリス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んんんんんん～～～～～ッ！？　んひぃいいっ！　やめっ、やめ、やめぇえ\nえっ！　オマメさん、お豆は駄目だよ、あっ、ト、トンじまうぅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっあぅぁあああっ、ああっ、んあああああ！！　お願いだ、お願いだから\n足を閉じさせて……って、またクリぃっ！　ああああああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「クリッ、ぐにぐにしないでおくれっ！　ブルブルでクリトリス、刺激される\nと……んぁひぃいっ、ひぃいっ！　目の前が真っ白になる、チカチカする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「脳天がイカれちまうよぉおおっ！　隊長、たいちょ……ああああっ！　ああ\nあああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「くぅうっ！　あぅううっ！　あうっ、あううっ……！　うぁああっ！　目の\n前、火花がバチバチ……ああっ！　クリッ、クリ壊れるよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「これっ……これ、じゃない治療法はないのかいっ……あうぁああっ！　おか\nしくなるっ、身体もアタマもおかしくなっちまうからぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「っはぁああああっ！　はぁ、はぁ、ハァ……！　ああ……駄目だ、股が悪化\nしてる、なのに自分じゃどうにもできない……なあ隊長、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「助けてくれっ……！　道具で私の身体、……オマンコがタガが外れたみたい\nにびちゃびちゃになっちまった。知らない凄いのが何度も何度も来て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「イカれちまいそうだったんだよぉ……。……え？　それでいい？　この次に\nオマンコを解放する治療をすれば治る？　じゃあそれをやってくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おねだりしてチンポをハメる？　今難しい言葉、新しいこっちの言葉を教え\nられても頭が回んないよッ……おねだり、おねだりってなんなのさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「オチンポ様を入れていただく神聖な儀式？　オッ……おちんぽ様ってアレだ\nろ、隊長の……股間の……スゴいやつ……。あれを使うのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「その方がマッサージ機よりも治療を短縮できる？　効果も高い？　そ……そ\nうなのか……じゃ、じゃあおねだりの仕方を教えてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私はこっちの言葉を知らないから……。……うん、うん。『私は卑しくドＭ\nでオチンポ欲しがりまくりの、淫乱襲来者です』？　そ、それから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「『逞しくて強い隊長様の、太くて硬くて勇ましい……カウパーまみれのちん\nちん、チンポ、ちんこ、おチンポをハメてほしくて我慢できません』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「『私のこの、濡れやすくってだらしのない隊長様専用穴、隊長様だけに捧げ\nるオチンポ挿入専用穴にどうかたっぷり種付けしてください』……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「よ、よしっ、言えたぞ！　これでいいだろうっ……！　さあ、オチンポ様で\n治療してくれ……私の穴、オマンコを早く元に戻してくれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……んうううっ！　あ～～～～っ♪　キタキタキタぁあああ♪　チンポッ…\n…チンポきたっ、オマンコに入っ……入ったぁああ、いいぞぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ほ、本当だ……！　こっちの方が直にキいている感じがす、るぅ……！　あ\nああっ、奥まで届いて……！　これなら治りそうだ、ありがとうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ……これっ、こりぇっ……本当にキく……！　オマンコぐちゅ\nうって鳴ってる……っ！　悪い、成分がかきだされるみたいだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ……、いいよ！　う、動いて……一番奥のトコから入り口まで……悪い\n水分を掻き出しておくれっ……あぁっ、はぁ、はぁ、早く早くぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっあっあふっあっ！　アッ……あっあっあっあぁ……！　イ、イ感じ……\nイイ感じだぁ……！　でも、すっごくもどかしい……だってさぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「自分で動けないから、足っ、固定されて捕まってるから……！　自分から動\nけなくて……隊長にしてもらうの待ってて、……あっ♪　焦らされるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ず、ぷ、ずぷ、ズプズプって入れたり抜いたり繰り返されると……身体がと\nろけそうなくらい気持ちいいよ。ずっと続けてくれ、ずっと、あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……っあぁ、中でチンポが大きくなってる気がする、んだけど……これが正\nしいやり方なのかい？　興奮してるから？　あっ、そう、そうなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お薬？　お薬が出そう……？　よ、よくわかんないけど……隊長を信じるよ\n……っ。あっ？　出すのかい、出すんだね、……出していいよっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あッ！　お薬っ、おくしゅり出たぁ……！　オマンコに、オチンポ様の特効\n薬出たぁああ♪　ありが、とうっ、ありがとう……んああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ドピュドピュお薬出てるよっ……染み込む、染み込むう……！　オマンコが\n喜んでる、隊長は本当にスゴい名医だよぉ……尊敬するぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、あああ……♪　隊長……これで治療、成功したんだよね…\n…？　私のために色々頑張ってくれて嬉しいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ？　今のはオマンコを慰めて、一旦落ち着かせる緊急処置にすぎない？\n　……えっ？　じゃ、じゃあまたこんな風になっちゃうってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それを防ぐには予防でオチンポを入れておいた方がいい？　……あ、あぁそ\nうなんだ……。確かに予防は大事だよね。……頼めるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んんっ……。わ、私も一回だけじゃなくて、あと何度かしておいてほしいっ\nて思ってたトコなんだ。私達、気が合うみたいだ。手数をかけるけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「オチンポ……このまま抜かずに治療、続けてもらっていいかな？　ええと、\nおねだりしたいんだ。私は淫乱？　ってやつだから……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ！　い、いいのかいっ！？　う、嬉しいっ……嬉しい……ありがとう…\n…！　凄いよ、また中でビクビクしてる、硬くなってきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「アッ……♪　あっ、ぁっ、あっ……んんっ！　この治療、なんかクセになる\n……！　んんぁっ……はぁあっ♪　なんか、なんかムズムズするっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「一回目より慣れてきてるから……力いっぱいえぐっていいよ♪　……んぁふ\nぅっ♪　私、頑丈だから……全力で突いて！　あっ、突き上げてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ンッ……ンあああっ……！　薬……薬がオマンコん中で塗り広げられてくぅ\n……。こ、これなら効果が高まりそうだよ……！　ッあっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「最高……さいっこう……♪　隊長、気持ちいいよ……！　あぁっ、チンポっ\nてバツグンの効果をもっているものなんだ、ねぇ♪　気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「これっておまえも……隊長も同じくらい気持ちいいものなのかい！？　それ\nとも……！　んぁああっ、私だけこんなに良くって、よがりまくって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「喘いじゃってるの、かい……！　あぁああっ♪　声……声止められないくら\nいイイんだよ！　今まで生きてて一番気持ちいいんだ、声出るぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「グチュグチュッ……！　腹の中に響いてゾクゾクするぅ……！　永遠にして\nほしいっ……ああっ、ああ……隊長はスゴいねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んくぅううっ！　ま、まただよ……。またオチンポ様が膨らんできてる……\n。お薬が補充されたってことだろう、あっ、出す？　出すんだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ま、たお薬出してくれるんだね……。嫌なわけないだろうっ……こんな気持\nち良くて、病気も治るスッゴイ薬……誰だって欲しいに決まってるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「タイミングなんかいつでもいいからさぁ……っ、隊長の出したい時にオマン\nコ全体にいっぱいかけておくれっ……！　っはぁ、はぁ、はぁあ♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「き、もちいいよぉ……。気持ちいい……！　隊長の治療は気持ちよすぎて…\n…んうううっ！　なんか、好きになってきたかもしれないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「アハハッ、単純な動き、なのにぃい……！　どんどんどんどんオマンコの中\n気持ちくなってくんだよっ、脳がぐちゅぐちゅに溶けて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長のしてることが正しいって、身体が教えてくれてんだ……！　あっ♪　\nあっ、こんなの、気持ちいいのが悪いことなわけないからねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「出してっ……出して出してぇえ……っ！　欲しいんだ、おまえのお薬ぃ……\n！　それがないと、私ダメになるからぁ……入れてくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んくぅうぅッ……♪　出てる、出てるぅううっ……！　おクスリいっぱいっ\n……何回分も出てるよォ、隊長……ぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「アッ、あぁっ♪　あぁんんっ、あンッ……♪　熱いぃ……！　熱いのが一番\n奥にかかって……。あっ♪　お、溺れそうなくらい……！　イイよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「まだ入るっ、まだ入れていいからっ……。あ～～～～～♪　ああああっ！　\nドクドクって、オマンコの中に溜まってく……最高だよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んはぁあああ……♪　はぁああっあっ……！　何コレ……勝手に腰がくねっ\nて……。あッ♪　オマンコがお薬を吸収しようとして、るぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ……♪　ぜ、全部出たかい？　ッぁっ……はぁああっ♪　\nこれで全部……。二度目なのにさ、大量に出してくれて助かったよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ああ……すごくいい気分だ。はぁ、はぁ……たっぷり中に薬が入ったからか\nな。汗もかいたし、スッキリできたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……う、うん……。確かにおかしな感覚はなくなったんだけど……。逆に、\n心臓の鼓動がうるさくなっちまってる気はする、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「さ、さっきまで大丈夫だったのにさ。隊長の顔を見てたり、隊長の身体の熱\nっていうの？　ソレを感じると動悸がするんだ。これはなんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「へェ……。こい……。コレを恋っていうのかい。人間は……。恋……悪い感\n覚じゃないね。身体が疼いた時は焦るけど、なんだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長だったら、きっと治してくれるってわかったからかな……。私の心が落\nち着いてるよ。フフッ……本当にありがとね。隊長……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ！　チンポッ……オチンポ抜かないでくれっ！　あぁっ……、ど、どう\nするつもりなんだよ……んんんんんッ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「う、ぁっ、ああっ、アアアアッ……！？　身体に、皮膚にぶっかけて……何\nするんだいっ……せっかくの薬がもったいないっ……！　あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「い、イヤだ……イヤだぁ……！　身体の外にかけたってしょうがないだろ…\n…！　ん！？　な、なんだいこのニオイ……あっ、悪酔いするっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「かけ、るな……かけるなぁ……！　あつっ……熱いっ……ん～～～～っ！　\n……はぁ、はぁ……。ど、どういう事なのか説明しておくれよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「貴重な薬を、よりにもよって私の外に……。んん？　……中にも外にも塗っ\nた方がいい？　そうすれば完全に予防になる？　……そ、そうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そう、かもしれないけどさ……。正直、私は中に……。オマンコの奥にたっ\nぷり出してもらえると思ってたから……。肩透かしだよ。それに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「この薬、ドロドロヌルヌルしてて粘り気が……。肌にまとわりつくし……。\nはぁっ、はぁ、おかしなニオイが強くて……どうすれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……こっちの宇宙じゃ、いい薬ほど苦いモノ……？　そ、そういうものなの\nかい……。こら、何ニヤニヤしてるんだよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ぶっかけられた私を見てたら笑顔になってしまった？　……もう！　人間の\n感覚ってのはよくわかんないよ……。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「助けてくれたんだよね、ありがとう……。外にかけたことでまた身体がおか\nしくなったら……その時はまた、お薬お願いしてもいいかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}