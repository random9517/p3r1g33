		{"command":[ "PLAYVOICE", "v2_199_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「だって……これ以上にエロくて、幸せで、満たされることなんかねェもん…\n…っ！　ああああっ、セックスっ、セックス好きだァ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシは一生、隊長のオチンポ様にお尽くしして生きてくんだ……！　今決\nめたァ♪　……んーっ……♪　酔っちまうよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっあっあっ……♪　アハハハ、わかるかい……♪　二回も出したもんだか\nら……♪　アタシの身体中から、アンタの臭いがプンプンするよ……♪」", "NORMAL" ]},
