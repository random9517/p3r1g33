		{"command":[ "PLAYVOICE", "v2_199_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「欲望の、肉欲の香り……。この臭い、一生取れないといいのにねぇ……♪　\nそれとも、取れたらすぐに補充して……抱いてくれるのかい？」", "NORMAL" ]},
