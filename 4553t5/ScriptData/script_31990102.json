		{"command":[ "SETTEXT", "「アタシはもう、アンタとアンタのデカマラの虜さ♪　どこにだって無許可で\n出せば……いいっ♪　ん♪　おっ♪　オッ♪　おっ、おっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104219" ]},
		{"command":[ "WAITINPUT" ]},

