		{"command":[ "PLAYVOICE", "v2_199_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「今日は壁があるせいで、感覚しかわかんねえけど……♪　あっ♪　それがま\nた、想像かきたてて……アソコが疼くっつぅか……♪　んんぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……なんかガキの頃、泥まみれになって遊んでた時のことを思い出すぜ。た\nだ……このネチャネチャ、隊長がアタシで出したもんだと思うと……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_12" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「全部かきあつめて、臭い嗅いで、口に入れちまいたくなるけどな……。き、\nきたねぇ？　いや、そりゃきたねえけど。けどさ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシの身体で興奮してくれてさァ……気持ちくしてくれた上に、せっかく\n出してくれたんだ。チンポも精子もねぎらいたいじゃねえか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「確かにくっさくて、ベッタベタで気持ち悪いっちゃ悪いけどよぉ……。……\nんんんっ……。尻にもアソコにも大量にぶっかかってんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「それをこの目で見てみてぇよ……。『想像だけでアソコがヒクヒクしてる』\n？　み、見るなって……♪」", "NORMAL" ]},
