		{"command":[ "PLAYVOICE", "v2_199_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ねっちゃねっちゃ言わされながら、コマされる……ぅうう♪　こんなにこの\n世に気持ちいいことないぜ♪　最高、だ♪　隊長……最高だよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシ、アタシアンタの女になるよォ……♪　だから、だか、ら……ぁ♪　\nこうしていっぱいっ♪　いっぱい抱いて犯して出してくれよなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アン、タの射精専用の穴に、肉穴になるからさァ……♪　……ンンンッ♪　\nンーッ♪　ンーッ♪　チンポ♪　チンポっ、チンポ……キツいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　……また出そう？　キヒヒッ……♪　し、仕方ねぇなァ……♪　そ\nんなにいいか？　アタシの肉穴……♪　好き、にしな……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104218" ]},
		{"command":[ "WAITINPUT" ]},

