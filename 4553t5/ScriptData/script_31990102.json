		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「中出しィ……中出し大好きかよぉっ♪　あはっ、あはっ♪　アタシも好きっ\n、中出し好き……一番スキだぁ、あっ♪　あっ、あ～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「腹ン中どぴゅどぴゅっ……どぴゅどぴゅっ……♪　アタシで感じて、ビュル\nビュル出しちまった証……♪　ああああ、愛しいよぉ、愛しいぃい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「もっ……とぉ♪　もっと奥に、奥に、子宮にかけてくれっ、ブッかけてくれ\nよぉ……♪　いくらでも甘えて、すがって、したいようにさせてやるからっ」", "NORMAL" ]},
