		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……あっ！？　オ、オイッ……！？　射精、射精は……！？」", "NORMAL" ]},
