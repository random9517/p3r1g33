{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長っ……隊長！　なんってことしでかしてくれてるんだいっ！　こ、コレ\nは……コレはなんなんだよっ、壁に、壁に身体が埋まって動けない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「『壁尻』っていう伝統的なお仕置きの一つ、だぁ？　壁に尻がハマってんだ\nから、そりゃあ壁尻だろうけどさ、なんで、なんでアタシがっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ぐ、ぐぅうう……うぐぅう……！　ぬ、抜けねぇ……！　アタシの腕力で割\nれない岩なんて、信じられないよ……って、コラッ！　コラぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「何、尻をぺたぺた触ってんだよっ……！　べ、別に……！　隊長にだったら\nいつだって触らせてやってるだろ、まずはアタシを解放しろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ひゃっ！　アッ……？　あっ……あっ！　ケツ……ケツ、両手で揉みまくっ\nて、んのか……？　やめろ、やめろ、見えないと予測ができねぇんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あ……っ！？　あっ、うぁああ……あぁ！？　尻の割れ目を、ひ、拡げんな\n……！　あっ！　匂いを嗅ぐなっ、……あっ！　あっ、ァッ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ま、マンコに触っ……あっ！？　ケツ！？　どっち、どっちだい！？　……\nくぅううっ……視界がないだけで、愛撫がこんな怖いなんてさ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ね、ねえ！　したいこと、してもいいんだからさァ……勘弁しとくれよ！　\n普通に、フツーにしたらいいだろ……！　……ひゃんっ！　ンッ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「い、イヤ、だぁ……！　アッ……♪　ゆ、指……？　指でなぞって、……あ\nっ！　ケツ揉みながら、マンコになんか入れて……あっ！　ゆ、指ぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぐっ！　くぅううっ……くぅううん……！　クッチュクッチュうる、せぇ\n……っ！　あっ！　コラっ、コラぁ！　ケツの穴いじりながら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「マンコ、かきまわすヤツがあるかよ……。って、うひぃいいっ！　尻に息を\n吹きかけるな！　も、もう意味わかんねぇよぉ、……うぁっ、うああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「い、イジワルしてんのかい……！？　なんの仕返し、なんだよっ……！　い\nつも、いつも特別によくしてやってんの、に♪　ふくッ、くぅっ、くぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ホ、ホントに怒るよっ……。や、ヤダぁ……！　マンコ、マンコから蜜……\n溢れ出して、あ、愛液で隊長の手が汚れちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ン、ぁっ……あっ、ぁっ……。あ、脚……撫でて、ケツ……叩いて？　マン\nコ、くちゅくちゅしやがってぇえええ……！　アッ！　あっあっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「や、ヤベェ……っ！　下半身から力、抜ける……膝がガクガク笑ってやがる\n、アタシが……！　この奈羅苦様が……されるがまま……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あァぁっ……！　や、め……っ、やめ、やめ……っ！　やめてくれよぉ……\n！　あっ！　あっ！　……くひぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「クリッ、クリトリスつまんで伸ばすなァ！　……何がしたいんだよっ……！\n　ヤ、ヤリたいならとっととヤればいいだろうがぁあっ……！　……へ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「『恋人同士みたいに可愛らしくおねだりしてみせろ』？　バッ……！　バカ\nッ、世迷言言ってんじゃねえっ！　こ、恋人っ？　ア、アタシが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシは別に、このまま放置されても……。……んぉあああっ！？　やめっ\n！　マンコ、マンコ手マンすんのやめ、ろよ、あっ！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「クソ……クソぉ……！　……わーったよ……わーったから……！　た……隊\n長……シてくれよ……。ア、アソコが疼いて、か、かゆくて仕方ねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アンタのデカいので、アタシのトロマン犯してくれ……。……なに黙ってん\nだよ、これでもダメなのかい！？　え、えぇと……。ん……、う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「入れて……。隊長の、逞しくって長くて、硬いチンポ……奈羅苦のバカマン\nに優しく突っ込んでください……。避妊とかさァ、ナシでいいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「た、隊長のオチンポでオマンコイかせてくださいっ……。欲しい、欲しいで\nす……チンポ欲しくて、もう……。入れて、入れてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……あっ♪　い、入れてくれるのか……！？　ありがとうっ……ありがとな\n……って、お前……！　なんだよそのチンポ、極悪な形しやがって……ッ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「先走り汁でベットベトじゃねえか……！　ッああああああっ！　優しくぅう\nっ、優しく入れてくれよ、じゃないとマンコ壊れちまう……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ンっ！！　……んふぁああああ♪　ああああっ♪　ヤッバっイ……っ！　隊\n長、隊長のチンポ……ぐりゅんってアタシの中に入っ……んぁああ♪♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ヤッベ硬いぃい……♪　超気持ちいいっ、……んぉぁああっ♪　ああっ♪　\nチンポ♪　チンポぉ……！　隊長のチンポ、ブッ刺さってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「イ……ぐぅ♪　イグぅっ！　……あーっ、ああっ♪　ンンンン……ッ！　エ\nッグいカーブしてやが、るぅう♪　イクッ、イクぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あッ♪　ああああっ♪　最強だよっ……アンタの……！　女殺しの名器じゃ\nないか……！　こんなのアタシですら耐えられねぇ、あっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……んひぅううっ！　ま、まだ動かないでくれよぉ……！　チンポでマンコ\nが拡張されて、それにまだ順応してな……いっつってんのに、あーーー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「腰っ、腰叩きつけるなァ！　あッんっ、あっんんっ！　んんっぉおおお♪　\nヤ……バイ♪　ヤバイ♪　痙攣しっぱなしだ、オマンコがぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　あっあっ♪　すげぇ……すげえよぉおお♪　これがセック\nス……あっ♪　あっ♪　こんな気持ちいいとか、イカれてるっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「脳からあったかい汁出るみてぇだ……！　あっ♪　あっ♪　こんなイイなら\n、そりゃみんなするよなぁ……！　でも、でもさぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んぉっ♪　き、気持ち良すぎるんじゃねえか！？　子作りに……ここまで気\n持ち良さ必要かァ！？　アヘッて戻ってこれなくなっちまうよぉ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっ……！　くぅうううっ……うぐぅうううう♪　なあ……な\n、あ……これっ、なんとかなんないのかよォっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて、ヘンな声あげちまうんだよっ……あぁんっ♪　可愛い女み\nたいな声ぇ……！　ア、アタシに似合わねえ、のに、甘えた声……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　隊長……隊長ぉおお……！　ダメだぁあ♪　マンコ突かれ\nて、突き上げ、られると……甘えた声漏れちまう……あぁああんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「イクッ♪　イく……ぅうっ！　ゴメン、ゴメンなぁ……！　あっ！　アタシ\nみたいな図体デカい怪力女が……こんな声出して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっあっぁっあぁんん♪　気持ちいいよォ……気持ち、いい……！　壁に腰\n、固定されて……ズコズコチンポねじこまれて……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ感じながらっ、アソコ濡らして……っ。オマンコ蠢かせながら\n……イキ狂っちまうぅ♪　ゴメンッ……ゴメン、またイグぅっ、イグぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……ぅ！？　ぁ……！　た、たいちょ……？　隊長……！　なんか、なんか\n腹の中……マンコの奥でなんか出て、る……出てる……？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「じゅわぁーってなんか、あっついのが広がって……あっ♪　マジ、かよ……\nこれっ♪　これ精子だろっ、精子……せい、し……んぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こっちに一言もナシにいきなり中出しィ……！　膣内射精キメるとか、さす\nが隊長……っ、あくどいコトしてくれるぜ……っ♪　ッんんぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あはぁ♪　おかげさまで……アタシっ、不意を突かれて興奮しちまったァ♪\n　いいぜ、いいぜ……中出し♪　マンコの奥に射精……射精ぃ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「許可なくアンタに種付けされたんだって思うだけで……っ、んん……♪　マ\nンコきゅぅうううううって締まっちまう♪　チンポ捕まえちまうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「『キツさが増した』？　あ、あはははっ、わか、るか……？　わかるよなぁ\n……♪　だってアタシにもわか、るもん……マンコうねうね動いてさっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長のチンポにご奉仕してるよ……。あっ♪　……ぎっちり締まったこのキ\nツマン……♪　チンポで掘り進めて、激しく採掘しちまってくれよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「摩擦……スッゲぇんだもん♪　マンコとチンポ、ぐっちゃぐちゃにこすれあ\nって……あっ♪　あっ♪　目の前、星がチカチカしてさぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「これっ……♪　これ、ぜってぇ子作りとかいうレベルじゃねえよ♪　……あ\nッ♪　淫乱同士のガチ対決……！　セックスバトルだろっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……んんんんん……！　んんんッ、あぁ、あぁ、あぁ……♪　クソッ……♪\n　尻揺らすのが精いっぱいで♪　腰振れねぇじゃんかぁ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019901_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「で、も……♪　壁に埋まってるせいでさぁ……♪　多少無茶なピストンキめ\nても体勢崩れなさそうだし……♪　ヤっちまってくれ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「この奈羅苦を……♪　隊長のオチンポ大好き奈羅苦様の、豪傑キツマンを…\n…アンタだけが好きにできるんだからさ、……貫いて、孕ませろよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っアァ……♪　パワー……あるよなァ、チンポッ……♪　メスを屈服させる\n、信じらんないくらいの攻撃っ、喰らわせてきやがるぅう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あァッ♪　あぁっ♪　チンポ、チンポ好きだぜ……っ♪　チンポ気持ちいい\nっ、あは……マンコの中の精液かきまぜられて……っ」", "NORMAL" ]},
