		{"command":[ "PLAYVOICE", "v2_199_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長の精液は全部アタシに注いでくれ……ェ♪　あっ♪　あっ♪　この感覚\nっ、好き……セックス好き、好きだァ……クソぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシ、アタシ、一生、もう隊長の女でいい……ッ♪　中出ししてもらうた\nめにだったらなんだってするっ……するっ、させてくれェ……♪」", "NORMAL" ]},
