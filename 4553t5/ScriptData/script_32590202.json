		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんで、淫魔おまんこめちゃくちゃに突きまくって♪　あっ\n、ああっ、気持ちいいっ、気持ちいいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「身体が熱くなって、感度も上がってるみたいぃ♪　ああっ、あはぁっ♪　私\nの腰も、止まらないのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスだから、しかたないの♪　気持ちいいことには逆らえないのっ♪\n　おちんちんに対して、おまんこは正直なのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁあん♪　また、イッちゃいそう♪　あなたのおちんちんで、またイかさ\nれちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だして、中出しがいいわ。また、あなたに、おまんこから溢れるくらいの精\n液を注がれたいの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「遠慮しなくていいんだからね♪　思いっきりエッチするための不倫旅行なん\nだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「精液ちょうだいっ、中にちょうだいっ♪　温泉であったまったおまんこに、\n温泉よりもあっつい精液ぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私の身体で興奮して、ぐつぐつ煮えたぎったオトコの欲望……おもいっきり\n、吐きだしてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204219" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああっ、ああぁっ♪　ピストン、ラストスパートぉ♪　あっ、あっ、ああっ\n、ああっ♪　イクッ、イクッ、イクッ、イッちゃうぅううぅぅ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁ～～～～んっ！！　きたっ、きたぁっ、精液きてるのぉ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204301" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「熱いのがまた、子宮にびゅるびゅるってきてるぅっ！　あっ、ああっ、母乳\nもでるっ、でるぅっ！　びゅ～って、びゅ～ってぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「イッてるおまんこに、これ、効くのぉっ♪　あっ、あはぁっ、熱いぃ、熱く\nて頭の中、溶けちゃいそうなのぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「真っ白ドロドロ精液で、頭の中まで塗りつぶされちゃうぅ♪　あはぁ、本当\nに素敵な精液ぃ……あなたのおちんちん、最高よぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああ……まだ射精してるうぅ……♪　んっ、んふぅ、こんなにたくさん、お\nまんこに入りきらないわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ねえ……見て……。溢れた精液がお湯に浮かんで、お花みたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「精液もだけど……私も、たくさん母乳だしちゃったのねぇ。透明だったお湯\nが、すっかり濁ってミルク風呂になっちゃったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「浴場のなかも、私たちのエッチな匂いでいっぱい。それほどあなたに夢中に\nなって、エッチしちゃってたのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ねえ……この調子でわたしのことを、もっともっと夢中にしてくれない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「忘れられない不倫旅行にするためにも、時間の許す限り、あなたのおちんち\nんと繋がっていたいわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204310" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああぁあああぁぁぁああぁぁ～～～～んっ！！　おちんちん、抜けちゃって\nる……っ！　精液っ、か、かけられてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204401" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_23" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああっ、イッちゃってる♪　あなたの精液ぶっかけられながら、ああ、母乳\n噴いてイッちゃうのぉっ♪　あっ、ああぁぁ～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。本当、すっごいぃ……♪　まだ射精してるのね。おちん\nちん、びゅっくんびゅっくんしてる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「この精液、みんなおまんこに注いでくれてもよかったのに……。でも、そう\nね。あなたの好きに動いていいって、言ったものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_26" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「それで……私にぶっかけたかったの？　褐色の肌を、このドロッドロの精液\nで真っ白にしたかったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「うふふ、別にかまわないわよ♪　だって、あなたの最高級ザーメンだったら\n、どこにだされたって悦んじゃうもの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_24" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だけど……やっぱり……ああ、だめね。おまんこが疼いちゃってる。ね、わ\nかるでしょ？　腰をヘコヘコ、おちんちんにこすりつけてるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_26" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「うふふ、そうね……さすがにこれ以上、浴場でえっちしたら、湯船のお湯が\n大変なことになっちゃうわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_24" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「発情が収まらなくて、母乳もまだまだとまらないし……。これは、あなたに\n責任を取ってもらわないと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「さ、宿の部屋にいって続きをしましょ。今度は私が好きに動くわよ♪　うふ\nふ、今夜も寝かせないんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204410" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_25" ]},
