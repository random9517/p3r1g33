		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「こんばんは～。またきちゃった♪　……さすがにもう驚かないのね。クール\nぶっちゃってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「なんで男湯に入ってくるのかって？　それは私がサキュバスだからだけど、\nもうひとつ理由があるの。とっても重要な理由」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「せっかくふたりで旅行しているのに、男湯（おちんちん）と女湯（おまんこ\n）、別れてはいるなんて勿体な～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたもそう思うでしょ？　しがらみから解放されて、性欲のままに身体を\n重ねまくる……。そんな旅行にしようって、言ったじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だから、お願い。ここで抱いて。あなたのおちんちんで、私のおまんこをめ\nちゃくちゃに犯してちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ええ、あなたが好きに動いてくれてかまわないから。わかったわ、あなたの\n上に跨ればいいのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「きゃっ♪　いきなりおっぱいを揉むなんて、やんちゃさんなんだから♪　あ\nぁっ、いいわぁ。おっぱい揉むの、上手ぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁん♪　あっ、あんぅ♪　あなたに揉まれると、おっぱいジンジンしてき\nちゃう……。あっ、あぁ……っ♪　母乳……でちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁ、とまらない、母乳がとまらないぃっ♪　んふっ、そうよぉ、いっぱい\n興奮しちゃってたからぁ、母乳でちゃうのぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ほら……ねぇ♪　お湯の中でもわかるでしょ？　おまんこがすっかり濡れて\n、ぬるぬるになっちゃってるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おねがい。おっぱいだけじゃなくて、こっちもぉ♪　人妻サキュバスのはら\nぺこおまんこも、そのおちんちんで気持ちよくしてちょうだぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んふぅ～～～～っ！　き、きたきたぁ♪　ぶっといおちんちん、お湯と一緒\nにおまんこに入ってくるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ね？　言ったとおり、ぬるぬるでしょ？　私のおまんこ、あなたとエッチし\nたくてたまらなくなっていたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「待ってたの、このおちんちん。ああ、だめぇ。じっとしてないでピストンし\nてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「かたぁい先っぽで奥突いて、おっきいカリでおまんこごりごりひっかいてぇ\n♪　あっ、あはぁっ、そう、そう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちん、こすれるぅ……♪　あっ、あっ、あはぁ……っ♪　おまんこに\n感じるぅ、存在感、すっごいのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああ、たまんない♪　サキュバスなのに、簡単におまんこ手玉に取られちゃ\nうの♪　このおちんちん、クセになっちゃう～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　おっぱいも、も～っと揉んじゃうの？　ぎゅぎゅ～って、力い\nっぱい……んっ、痛いはずなのに、感じちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「母乳、ぴゅ～ってだしながら、エッチな声がとまらないの♪　ねっ、ねっ、\nおまんこもしてっ、突いてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あんっ、あはぁんっ♪　下から、ンッ、いっぱいぃっ♪　ガチガチのおちん\nちん、突きあげ……ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「すごく、感じるわっ♪　あなたのおちんちんの形っ、熱いの、出入りして…\n…るぅ……っ♪　んぁっ、あっ、ああぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ピストン、激しい……っ♪　あっ、あなたも、私の虜になっちゃってるのか\nしら？　んっ、んふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「虜になって、夢中になって♪　こんな素敵なおちんちんに気に入られるなん\nて、サキュバスとして大歓迎だから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ほら、お返し♪　あなたがいっぱい気持ちよくしてくれるから、腰を振って\n、おちんちん催促しちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちんを魅了するサキュバスが、おちんちんに魅了されちゃってるの♪\n　ああっ、これってとっても恥ずかしいことなのに、腰がとまらないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おまんこうねって、おちんちんに媚びちゃう♪　あはっ、あなたも感じてく\nれてるのね、ピストン激しくなってくぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「おちんちんが暴れて、んっ、膨らんで……。あはぁ、射精しそうになってる\nのね♪　んっ、私も……イキそうなの……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「パンパンになった亀頭で、子宮ぐいって突き上げられながらイクッ♪　あな\nたのピストンで、サキュバスおまんこイッちゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁん♪　おまんこ責めながら、おっぱいも同時ぃ♪　だめだめイッちゃ\nう♪　オマンコ、耐えられないぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁあっ、オマンコ締まって気持ちいい？　あなたも我慢できなくなっちゃ\nう？　んっ、いいわよ、イきましょ、一緒にぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたの精液、おまんこに注いでぇ♪　あなたとの赤ちゃんできちゃうくら\nい、濃いのびゅ～って、中出ししてぇええぇぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁ～～～～んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁっ、あっ、あっ、ああぁぁ……っ！　すごいぃ……すごいわぁ……お\nちんちん、びゅっくんびゅっくん射精してるぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「濃いのがいっぱいくるっ、子宮にどぷどぷって注がれて……っ！　ああっ、\nイクッ、イク……ッ！　中出しされて、イキまくるぅううぅぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ひゃぁあああぁぁぁ～～～んっ！！　でちゃうっ、母乳もでちゃうのっ！　\nああっ、とまらない、勢いよく、びゅ～って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「中出し射精に負けないくらいの勢いで、ああ、あなたの顔に、母乳ぶっかけ\nちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。お顔、真っ白になっちゃったわねぇ……って、どうした\nの、口をあけて……ンッ、おっぱい揉んで、母乳搾ってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204137" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「もしかして、もっと母乳を飲みたいのかしら？　んふふ、それならぁ、いい\n方法があるわよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんで、もっとパンパンしてくれたら……。きっと、母乳が\nもっとでると思うわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「私を興奮させればさせるほど、美味しい母乳がでてくるから♪　ねっ、もっ\nと突いて、搾乳してちょうだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはぁん♪　そう、そうやって、ずんって突くのっ♪　思いっきりおちんち\nんで、おまんこ突き上げてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああぁっ、母乳、でるぅっ♪　おまんこすっごく感じちゃって、\n母乳も溢れてとまらないぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「はぅんっ、あっ、んんっ、あはぁっ♪　突いて、突いてぇ♪　いっぱい、あ\nなたのおちんちん感じさせてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「全然萎えてない、元気なおちんちん♪　ううん、むしろさっきよりも元気に\nなって、おまんこで暴れてるの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ぶっといおちんちんに、おまんこめちゃくちゃにされて、ああっ、すっごく\n気持ちいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「母乳も、おまんこ汁も垂れ流しになっちゃってる♪　興奮しすぎて、身体が\nおかしくなっちゃってるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ひゃあんっ♪　そ、そうね、おっぱい搾って、母乳、飲んでぇ♪　はぁっ、\nはぁっ、私もがんばって、母乳飛ばすわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あなたのお口に、ぴゅーって♪　んぁっ、本当にごくごく飲んでる。お行儀\nが悪いわよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だけど特別に許してあげる♪　だって、こんなに気持ちいいおちんちんを、\nおまんこにハメてくれてるんだもの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あぁあんっ♪　すごい、おちんちんがますます硬くなってる♪　ピストンも\n、激しくなってくぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00025902_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あはっ♪　湯船のお湯も、激しく波打ってる♪　飛沫も弾けてる♪　いいっ\n、いいのっ、思いっきりピストンしてぇっ♪」", "NORMAL" ]},
