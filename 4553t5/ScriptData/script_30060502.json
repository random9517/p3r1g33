		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃあああああああああああ！　イッてる！　んんん！　ディアナちゃん、\nイッてるの！　ひゃんんんん！」", "NORMAL" ]},
