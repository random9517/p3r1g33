		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あああ！？　おちんちん、どんどん、膨らんでるぅぅ！　びくびくって、広\nげられながらぁぁぁ、あ、あああ！？　イク！　イクぅぅぅ！？」", "NORMAL" ]},
