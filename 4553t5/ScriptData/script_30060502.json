		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「お願い、ダーリン！　また一緒に！　一緒が良い！　一緒に、いこ？　ね？\n　んんんんんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504219" ]},
