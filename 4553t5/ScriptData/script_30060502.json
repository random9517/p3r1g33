		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「おまけに、むわっとした匂いが、頭、くらくらさせてきちゃって……ふあぁ\nあ、だめぇ、これ、脳が、蕩けるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁぁ！？　気持ちいいの、また、来た！　うそ！？　熱いのぶっか\nけられながら、ディアナちゃん、そんな──あ、ふあああ！？」", "NORMAL" ]},
