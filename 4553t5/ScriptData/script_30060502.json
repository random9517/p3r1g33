		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「熱いぃっ！　熱いのが、どくどくって、中に、注がれてるぅ！　あ、ふあぁ\nぁあ！　それ、染みるの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んああああ！　はぁ、はぁ、はぁ、はぁ……はぁぁぁ。しゅ、しゅごいぃ。\nディアナちゃんのお腹、たぷんたぷんに、なっちゃてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「二回目なのに、たくさん出たのね。ダーリンてば、性欲魔神ね。ふふふふふ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やだも～！　ディアナちゃんが可愛いからだって、そんな当たり前のこと言\nわないで～。照れちゃう～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「当然よね。ただでさえ可愛いディアナちゃんなのに、水着姿まで装備してた\nら、無敵よね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「でも、だからってこんなにたくさん中出しして、おまけにまだ抜かないなん\nて……ダーリンてば、ディアナちゃんのこと、妊娠させるつもりでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはは。赤くなった～。やっぱりそうなんだ？　ディアナちゃんに孕んで欲\nしかったんだ？　んふふ、かーわーいー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いいわよ。ディアナちゃん、ダーリンの赤ちゃん、孕んじゃう。だって、大\n好きな人の赤ちゃんだもんね。きっと可愛いわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だから～、これからも、よろしくね。だ～りん♪」", "NORMAL" ]},
