		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「って、あんんんんん！　熱い！　熱いぃぃ！　熱いのが、お肌に……お尻に\n、たくさん！　んんんん！」", "NORMAL" ]},
