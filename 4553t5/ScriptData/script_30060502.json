{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_01" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……も、もう無理ぃ。だめぇ、これ以上は、腰が、たたな\nいわ……もう、許してぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504101" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「これ以上はディアナちゃん、ビーチバレーなんて無理～！　足下動きにくい\nし、ボールは顔めがけて飛んでくるし、何度も転んじゃって砂まみれ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ねえ、もうこんなのやめて、他に楽しいコトしよう？　例えば……って、ん\nふふ。ダーリンたら、どうしてお股のそれ、大っきくしてるのかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ビーチバレーしながら、ディアナちゃんのこと、そんな目で見てたんだ？　\n悪い子ね。でも、悪い子大好き！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、このまましちゃいましょ？　ね？　ね？　いいでしょ？　ハイ決定\n～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やんっ！　んふふ、早速お尻を撫でてくるなんて、ダーリンもすっかりその\n気ね。良かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「──って、ひゃああ！？　だ、駄目！　そこは、お尻の穴、水着の上から、\nそんな風にぐにぐにってしちゃだめ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひうう！？　次は、指、とんとんって、お尻の穴、叩いてる！？　駄目って\n、言ってるのに～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「う、うそ！？　お尻の穴、いじめられて、濡れてるなんてぇ……違うもん。\nこれは、あ、汗！　ビーチバレーの時にかいた汗だもん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「どう見ても愛液だって……うぅぅ、いじわるぅ～。今日のダーリン、凄くい\nじわるだわ。ひょっとして、悪い子大好きって言ったからかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「エッチはいじわるなのいやぁ。優しくして、ダーリン。だって、ちゃんと二\n人で気持ち良くなりたいんだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だから、そろそろ……いいでしょ？　ダーリンを、一番深い場所で感じさせ\nて。ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、ふああ！？　水着、つけたまま、ずらして、そんな……んんん！　入っ\nてくるぅ！　ダーリンのおちんちん、入って、くるぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あんんんんん！　はぁ、はぁ、はぁ。入っちゃったぁ。凄く、奥まで、届い\nてるの、感じるわ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「この格好だからかしら？　ディアナちゃんの一番気持ちいい場所、当たって\nるの。おへその裏側ぁ。あぁ、これ、まだ動いてないのに、もう気持ちいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「お願い、ダーリン、動いてぇ。ディアナちゃんのこと、いっぱいいっぱい、\n気持ち良くしてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ！　んんん！　ひゃああ！　はげ、しい！　いきなり、\nはげしぃぃぃ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ううん！　駄目！　優しくしちゃだめ～！　さっきは優しくって言ったけど\n、おちんちんは、激しいのが、いいの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひああああ！　そう！　それぇ！　がんがん、ダーリンの腰、ディアナちゃ\nんのお尻に当たってるくらい激しいの、好きぃぃぃぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「きゃんん！？　今度は、おっぱい……後ろから覆い被さりながら、おっぱい\n、ぐにぐにってぇ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「駄目なの！　ディアナちゃん、乳首、弱いの～！　きゅって抓られたら、凄\nく気持ちいいの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん！　あそこも、おっぱいも、どっちも気持ちいい！　こんなに気持ちい\nいなんて、頭、真っ白になっちゃう～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「──え？　どうして、動くのやめちゃうの？　だんだん、気持ちいいの、膨\nらんできてたのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「やぁ……動いて。動いてよ、ダーリン。焦らさないでぇ……動いてってばぁ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うぅ、やっぱり悪い子大嫌い！　こんないじわるするなんて、ひどすぎるよ\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「い、いいもん。自分で、動くもん。このまま、むしろダーリンのおちんちん\n、犯しちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ん、んっ、んんんっ！　んっ、しょっ！　ん、ん、ん、んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はうぅ……だめぇ。上手く動けないぃ。一人だと、全然気持ち良くなれない\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃあああ！？　い、いきなり……また、いきなり、動き出したぁ！　あん\n、あ、あ、ああ！　あんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あはっ！　気持ちいい気持ちいい気持ちいいの～！　ダーリンのおちんちん\n、やっぱり気持ちいいの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「もっと激しくして～！　奥まで、ダーリンのおちんちんで、ディアナちゃん\nをいっぱいにして～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああ！　うぅ、も、もっと、感じてたいのに、ディアナちゃん、そ\nろそろ……はううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だ、ダーリンもなの？　うん！　じゃあ、いっしょに！　いっしょにイク！\n　イキたい～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ、あ！　イクイクイクイクイクぅぅ！　気持ちいいとこ\nろ、ごりごり擦られて、ディアナちゃんイク～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んあああ！　熱い！　熱ぃぃ！　熱くて、気持ち良くてぇ！　んあああああ\nあああああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ、はぁ、はぁぁぁ……しゅ、しゅごかったぁ。ディアナ\nちゃん、本気イキしちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん。すっごく、すっごく気持ち良かったよ、ダーリン。ダーリンも、気持\nち良かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「って、聞くまでもないか。だって、たくさんたくさん、出たもんね。白くて\n熱くてどろどろしてるのが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん。ディアナちゃん、ちゃんと感じてるよ。ダーリンの気持ち。全身で、\nいっぱいいっぱい、感じてるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ダーリン、大好きぃ。えへへへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「さあ、それじゃあビーチバレーの続きしよっか。みんなも、そろそろ戻って\nくるだろうしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「って、あれ、どしたのダーリン？　そんなにじっとディアナちゃんのこと見\nつめて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「……って、おちんちん、全然小さくなってない！？　それどころか、さっき\nより大っきくなってない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そ、そうなんだ。エッチして火照ったディアナちゃんを見て、余計にムラム\nラしちゃったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んふふ。ぜーんぜん悪いことじゃないわよ。むしろディアナちゃん、求めら\nれてるのが分かって嬉しいぐらいだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「じゃあ～……もう一回、しちゃう？　あはは、びくん、だって。おちんちん\nが返事してる～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん。さっきので濡れたままだから、すぐにできるよ。ディアナちゃんも、\n今すぐダーリンのおちんちん、入れて欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁ……かたいの、入ってくるぅ。全然、萎えてないのが、あ、ふあ\nぁぁぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んんんんん！　は、入って来ちゃった。また、入って来た。かたくてごりご\nりしてるの、また、中にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あそこ、みっちり埋められてるみたいで、満たされてるって感じ、する。こ\nれ、やっぱり好きぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん。動いてぇ……二回目だから、もうぐちょぐちょだから、遠慮なく、た\nくさん動いてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひゃあああ！？　んあ、あ、あ、あ、あ！　あんん！　激しい！　さっきよ\nりも、ずっと、激し、いぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「本当に、遠慮なく、動いてるぅ！　んんんんん！　ずぶずぶぅって、何回も\n何回も、あそこ、おちんちんで、擦られてるぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ううん！　だめ、やめちゃやぁぁ！　このまま、もっと、もっと！　んんん\n！　奥に、ちょうだい！　もっと奥、欲しいの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ひあああ！？　あ、当たってる！　んきゅんん！　奥、当たった！　おちん\nちんの先っぽ、ディアナちゃんの一番、奥に、当たってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「う、うそ……気持ち良すぎて、また……もう……んんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「だ、ダーリン、も？　ダーリンの、おちんちん、ぴくぴく震えてるの、伝わ\nってきてるよ。ダーリンも、なのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000605_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん！　イクの！　ディアナちゃん、また、イクの！　だって気持ちいいの\n、我慢できないんだもの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504218" ]},
