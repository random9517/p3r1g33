		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「こんなの、信じられない。こんなの、初めてぇ。精液かけられるの、気持ち\n良くって、イッちゃうの、初めてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「う、うん。すっっっっごく、気持ち良かったわ。まるで、ダーリンに包み込\nまれてるみたいで、気がついたら頭、真っ白になっちゃってた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んふふ。さすがはダーリンね。ディアナちゃんをこんなにメロメロにしちゃ\nうなんて。これはもう、一生ついてくしかないわ」", "NORMAL" ]},
