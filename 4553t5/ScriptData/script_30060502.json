		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「んあ、はぁ、はぁ……ふぁぁぁ……うそぉ。ぶっかけられながら、ディアナ\nちゃん、イッちゃった……あふぅ」", "NORMAL" ]},
