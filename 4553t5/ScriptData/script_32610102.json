{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ……先輩、すみません……わざわざ来ていただいて……今日は、どうして\nも先輩にお願いしたいことがありまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026101_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「このところ……ずっと、先輩にいろいろと特訓をしていただいて……その身\n体の方も、か、開発されてしまいまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「お陰で、もう……ずっと身体が疼いている状態が続いているんです……です\nから、そのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ……ふっ……み、見てください……私の……こ、ここ……はぁ、ぁっ、ふ\nっ……どんな風になってますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026101_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あぁぅ……自分からこんなポーズしちゃうの恥ずかしい……で、でも……先\n輩になら見せていいですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そう、です……今日も、先輩と約束をした時から……ずっと、お、おまんこ\n……濡れてて……パンティにも染みちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「だから……先輩のおちんちんで……鎮めて欲しいんです……エッチなこと…\n…あぁっ、せ、セックス……して、くださいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あぁっ、んくぅぅぅんっ！　はぁぁっ、入って……おちんちんっ……奥にっ\n、来ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁぁ……はい、一番奥まで入っちゃいました……中が、もうじゅ\nくって……濡れてたからですよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「入っただけで、ちょっとイっちゃいました……んっ、あ……でも、大丈夫で\nす……その……動いてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あふっ、んんっ、はぅっ、んんっ……！　あ……あぁ、擦られてるぅ……ふ\nぁんっ、あ、う、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は、ひんっ！　これを……うんっ！　ずっと待ってたんですっ……あっ、お\nちんちん……中でいっぱいになって……あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「太いのが……ずぶずぶって出し入れするのぉっ、あっ、あひっ、いっぱいっ\n、感じますっ、うくぅうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んっく……あっ、ふっ、私も……先輩に気持ちよくなってもらわないと……\nんくぅっ、ん、ふっ、あっ、ぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「先輩……私、締め付け……できてますか？　おまんこ……力、ちゃんと入っ\nてますか？　はっ、ふっ、んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「は、はい……今の感じで続けますっ、あぅんっ……は、ぁぉっ、あぁっ……\n気持ちいいっ……おちんちんっ、すごく逞しいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んっ、中で……ぐぐって、押し込まれる瞬間に……ビクってする時があって\n……あくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「それを、何度も繰り返されるとっ……あっ、あぁっ、からだ全体が……熱く\nなって……はぁ、んんっ……おかしく、なりそうですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、あぁ……先輩っ……もう一つ、お願いしても……いいですか？\n　その、まだ恥ずかしいことなんですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んっ、まだ……恥ずかしがって、縮こまってる……私の陥没おっぱい……乳\n首……弄って欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ずっと先っぽ、ムズムズしてて……もう少しで出てきそうなんですけど……\nそれが、もどかしくて……先輩に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ、あひんっ！　あぁっ、はいっ……そ、それぇっ……あっ、周りのとこ…\n…優しく引っ掻かれるの……あっ、す、好きですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ふっ、あぁっ、あぁ……えっちな指……気持ちいいですっ、これ、続けられ\nたら……ムズムズして、あと少しぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　あぁっ……か、顔……出しちゃいました……わ、私のえっち\nな乳首……先輩に出してもらってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、はいっ、摘んでくださいっ……ひぁんっ！　ひ、引っ張られ\nると……ジーンって痺れてっ、乳首いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、もっと……あっ、もっと弄ってください……あんっ、コリコ\nリ転がされると、またおまんこっ……濡れちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んはぁぁぅっ！　また、おちんちんの方も来ましたぁっ、あっ、あぁっ……\nはっ、あぁんっ！　おっぱいと一緒になんてっ、はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あぁっ……！　おちんちんっ、ぐりぐりされながらっ……乳\n首もっ、ぐりぐりされてますっ、はぁぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そっ、そこぉっ、あひっ、おまんこの……弱いとこぉっ……！　あぁっ、お\nっぱいもっ……ビクってしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「し、締め付けてるっ？　分かりませんっ……んんっ、からだっ……勝手に、\n力が入ってっ……おちんちんっ……してるんですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「今の感じで……は、はいっ……自然になっちゃいますけどっ……このままで\n……あぁっ、で、でもっ……こんなのぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、おちんちんがっ、いろいろなとこに当たってぇっ！　おかっ\n、おかしくなっちゃひまふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、あひぁっ！　おっぱいっ、乳首もひゅごいっ！　両\n方ともっ、あっ、気持ちよすぎてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「らめっ、こんなにされたらっ、あぁっ、私っ……またイッちゃいますっ！　\n先輩はっ、ま、まだですかっ？　んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「先輩もっ、あっ、あぁっ、もうすぐっ！？　はひっ、ならっ……あぁっ、中\nに……くださいっ！　おまんこの中に射精してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「そしたらっ、私もイキますからっ！　あぁっ、先輩に中出しされてっ……イ\nキたいっ、おまんこイキたいですっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅんっ！　あぁっ、中ぁっ……ビュルって……はぁぁぁんっ、お、\nおまんこっ……イッてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あぁ……どぷって……いっぱいになってます……精液……子宮まで届いてま\nすぅ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「おちんちんが震えながら……出してるの、あふっ、分かります……はぁん…\n…気持ちいい……出して、いっぱい出してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あ……ふっ……止まりました……今日も、ご指導……ありがとう、ございま\nしたぁ……はふぁ……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はふぁ……はぁ、はぁ、あ……んっ……頭……ぽわぽわしまひゅ……まだ、\nおちんちんが入ってるみたいな感じでひゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「え……間違いでもない……？　それは、どういう……あっ、ひぁぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　またっ……すぐにおちんちんっ……は、入ってっ、あっ、\nはぅっ、んくぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ま、待ってくださいっ……今……イ、イッたばかりでっ……敏感になってて\nっ、あひっ、感じちゃいますっ、あぉっ、だ、だめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あふっ、んくぅっ……！　お、おまんこっ……あぉっ、続けてさ\nれるのっ、よ、弱いですからぁっ、あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「やらっ、こ、これっ……中出しされた後でっ……ぐちゅぐちゅしひゃうっ、\nおまんこっ……かき混ぜる音ぉっ、しひゃいまひゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　あっ、あぁっ、おっぱいっ！　乳首も……ぎゅって引っ張ら\nれてぇっ！　あぁぉっ、そ、それもっ、ぎもぢぃっっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ま、待ってっ……指ぃっ、あっ、両方ともっ……乳首しちゃっ、は、ひっ、\nあぁっ、つ、強い、ですっ！　コリコリっ、らめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ピンと尖ってるからって……は、恥ずかしいっ……こんなにいやらしく、飛\nび出ちゃうなんてぇ……あっ、乳輪……そこぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「先輩……駄目です……そんな上手に、あっ、先っぽ……喜んじゃいますから\nぁっ……あぁっ！　おちんちんもっ……また来るぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026101_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　中の精液……掻き出されちゃいますっ……！　私の……お\n、おまんこのお汁と一緒にっ……びちゃって、溢れて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、止まらないっ……おちんちんっ……されながらっ、おっぱいっ…\n…クリクリされてぇっ……どっちも、よすぎてっ……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「んぅんっ！　はぁっ、中で……ビクビク跳ねてますっ……先輩もっ、はぁっ\n、いいんですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、そうなんですね……は、恥ずかしいですけどっ……嬉しい\nっ、ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、でもっ……これ以上激しくされたらっ、私っ……も、もうっ\n、はぁっ、も、戻れなくなっちゃいますっ……あっ、ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「い、一回……休んでもっ……あひぃっ！　そんなっ、あっ、もっと激しくぅ\nっ！　あぁっ、おちんちんっ、おちんちんがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
		{"command":[ "SETTEXT", "「なかっ、あっ、あぁっ、どんどんっ、速くされてっ……ひっ、止まらないの\nっ、もうっ、本当にもうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_261_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "うらら" ]},
