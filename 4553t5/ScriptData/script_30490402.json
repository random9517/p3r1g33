		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「隊長殿、隊長殿～？　……ああ、良かった。ここにいたのか……。うぅ～、\nヒック……。今な、そこの海の家でビールが半額セールをやっていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「隊長殿にも飲ませてやろう、慰労だと思っていたら……。ヒック、なぜかコ\nップが空になっていてな……。謝りに～きたのだよ！　フフ、うふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……酒臭い？　失礼な……。だが、そーだな、詫びはしなくてはな～♪　何\nか奢ってやろうか～？　それとも……。あ～、こういうのはどうだ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私がお前に抱かれてやる♪　あぁん、冗談ではないぞ～？　酔えば酔うほど\n～、身体が切なくて、燃えて、乾いて仕方がないのだぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「熟れた身体を持て余しているんだ。暇をしているなら付き合ってくれ。そう\nだな……。さっき見つけた穴場があって……。こっちだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ボロンっと乳を露わにして……。ん～～♪　こうして手を突き、尻を振って\n誘惑してみるか……♪　ほら、ほら、食べごろだろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00004904_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「簡単なお使いもこなせないダメな私に、お仕置きをしてくれ……♪　……ん\nっ……♪　ああ、いいぞ。どこでも好きに揉め。痛いくらい……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あぁ……っ、そう、そうだ……。ムリュムリュと胸を……尻を、脚を揉みし\nだいて……。私という女体を味わい尽くせ……。んっ、うまいな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「え……？　尻を叩きたい……。そ、それは……。んっ……？　デカ尻を突き\n出している私が悪い……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んッ！？　はぁんっ！？　ハァッ……ああああっ！？　イヤッ……ああっ！\n　い、痛い……っ、あぁあんっ……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んああああっ！　あぅああっ！　つ、強い……！　尻ッ……尻をそんなに叩\nいたら、取れてしまう……。んぁんん！？　やっ……ふぁ、あぐぁあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「痛い、痛い、痛い……んァっ！！　痛い、のにどうしてだ……！　乾いた音\nが響く、たびに……全身に甘い快感が駆け巡る……走り抜けていく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あふぁああっ！　あぁんっ、あぁ、うう……！　ああッ♪　あっ、ぁっ、あ\nっ、んぁああっ、ああああ……っ！　な、なんだって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ぬ、濡れている……？　いつもより……？　私は尻を叩かれて感じているの\nか……。あぁ、隊長殿に支配された気分になって……。なんて淫らな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「だが……認めざるを得ない……。ああそうだっ……私は感じているっ、叩か\nれることで昂って……ペニスを欲しいと思ってしまっている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「頼む……。乱暴に犯してくれ……！　私の穴という穴をほじって、えぐって\n、奥の奥まで貫いて支配してくれぇっ……。欲しいっ、チンポが欲しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……んくぅうううっ♪　あぁああっ、あああああーっ！　チンポぉっ、チン\nポきたぁっ♪　入ってきたぁ……あーっ、チンポ、チンポぉおお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そうだぁ、これが欲しかったんだぁ！　女の身体のことなんか一つも配慮し\nないぃ、デカすぎて内側からっ、オマンコ破裂しそうなデカマラぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お……いひぃっ、おいしい……っ！　あっ……あぁ……！　全身が波打つよ\nうだ……ぁっ。あっ……初めて入れたわけじゃない、のに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「すればするほど良くなってい、く……っ♪　隊長殿のチンポと、私のマンコ\nの相性が上がっていく……！　あっ、ぴったり、くっつい……てっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んぃいいいい♪　少し動かされるだけ、で♪　簡単に絶頂してしまう♪　あ\nぁ……っ、初めての時にはわからなかったっ、お、お前が……ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私をこんなに良くしてくれるなん、て♪　それに……自分がこんなにも、虐\nげられて感じる変態だったなんて……。ぶって！　ぶってくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「いっ……！？　イグッ……んぐぅうううっ！　あーーっ♪　ぶたれるのいい\nっ、壊れるまでひどくしてくれぇ……！　んあああああっ！　あうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「叩かれると締まる、なんて言うな……あぁっ！　ち、違う……痛みに反応し\nているだけで……！　私が力を込めているんじゃ……な、アアアアッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あひィっ、ひぃっ、ひぃいっ……！　す、すみませんんっ……！　ぶたれて\nイっている変態豚女の分際でぇっ、逆らうなんて……ごめんなさいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「はいっ……そうですぅっ！　私は……美鈴は、部下のぉ……！　お前のチン\nポの下僕ですっ、奴隷です……！　オチンポお慕いしておりますぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404126" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「大好きな……愛するオチンポを気持ち良くするためにぃ、いつでもオマンコ\n濡らして待ってましたぁ！　セックスが好き、……好き……だ、から！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ちゃんと絞めるからっ！　お仕置き……しないでくれ、これ以上罰せられた\nら……イ、イッてしまう、チンポと手のひらにダブルで攻められて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「尻を振りながら……お前を誘い、ながらぁああァっ……！　ぎゅうぎゅうオ\nマンコ締めつけて、絶頂しながらイキ狂う……！　んぉぁああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「ん、は……ッあああっ！？　なっ……！　中出しぃ！？　精子、精子……予\n告もしないで膣内に……！　あっ、ゆ、油断させておいて……卑怯だぞっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404130" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「尻の熱さに、……ぶたれる痛みに怯える私を、極太チンポで貫くだけじゃな\nく……。無許可で中に出すなんて……んあっ、不意打ちはズルい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「熱くてドロドロの、ヌメヌメの精液が私の中に……。アッ！　お、奥、にな\nすりつけるな……ぁ！　子宮口っ、そこは子宮口、だから……やめろお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お前のっ、いやらしい臭いが……ザーメンのニオイがマンコの一番奥に溜ま\nるじゃないかっ……あぁ……！　ぶっといチンポでかきまわすなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「出したばかりなのにどれだけ元気なんだっ！　あふッ！？　なんだと！？　\n出しながらかきまぜている！？　妙なテクニックを披露するんじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「そんなこと、そんなことをしたら……あうぁああっ！　反り返ったチンポが\nえっぐい角度で突き刺さって……白濁汁を泡立てて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「蜜、壺がぁ……白濁で、んうっ……ザーメンミルクまみれになって……んあ\nああっ！　やめろっ、感じている時に突き上げるなぁ！　……イックッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「……イ、イクッ、イクっ……！　イクイクイクッ……！　馬鹿っ、馬鹿者ぉ\nおっ……！　乱暴にすればするほど私が悦ぶこと……。んぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「わかっていて、力任せに腰を振って、挑発して……！　……あ！　アッ、あ\nっ……ヌッボヌッボひっどい音がしているっ、汚い音……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「精子がチンポでかきまわされて……空気が入って、……あああ！　グチュ、\nブリュ、ブビュ、って……恥ずかしい音が聞こえるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「くそっ……くそぉ……！　こんなので……！　辱められながらイクなんて…\n…！　下品すぎるのに気持ち……イイ！　うううぁああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あ、あああああ……。はぁあああ……はぁあっ……。たいちょ、ぉどの……\n。また腕を上げたようだな……。すごく、すごく気持ち良かった……。だが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「まだ……まだ出来るだろう？　私ももっとしたい……。このままチンポを抜\nかないでくれ、おかしくなるまで腰を振るからぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404202" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もっと……もっと叩いてイジめてくれぇええ……あふっ♪　毎日のストレス\n全部ぅうう……吹き飛ぶくらい、イキまくりたいんだ、んああっ、あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あは……♪　誰かが来るかもしれないのに、欲望を優先して……。私は最低\nな長官だな♪　大きな喘ぎ声を出して、アクメして……んぉぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00004904_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……。頭の中が真っピンクになるまでヤりたがっているぅ……\n♪　あは……、股ぐらから大きな水音が響いて……すぐに見つかりそう、だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「なんなら見られてしまってもいいんだッ……♪　見て欲しい……オチンポを\nオマンコにずぷずぷズコズコ入れられている私を見てっ、見てぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「胸を揺らし、て♪　痴女も真っ青のケツ振りピストンをおみまいしている私\nを……あっ♪　あっ、チンポッ、隊長殿の……激しく硬くなっているぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「マゾ女の私に劣情を禁じ得ないのか♪　んふっ……嬉しいぞ、身体の相性は\nバッチリだ、粘膜と粘膜が絡み合って……同じ快感に震えてぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「一つ、一つになって交わり続けよう♪　んおっ……♪　い、今……カリ首が\nっ、亀頭のでっぱりが、膣壁をひっかいた……勃起が強くなった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「私をイかせるのが上手だな……お前はぁああ……っ♪　好きだぞっ……隊長\n殿っ……隊長殿ぉ……！　私はお前のオナホールになりたいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「あっ♪　もうなっている？　あはっ……あはぁ♪　やった……やったぁ……\n私はデカ乳マゾオナホ……。お前専用のオチンポケース……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
