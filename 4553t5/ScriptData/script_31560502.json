		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ッあああああっ……！　ちょうど私も、一番大きくイクからさぁっ♪　絞り\nあげるから、あるだけ全部もらっていくよ！　んんっ！　ん～っんんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ。うぅっ♪　イクイクイクぅうううう～～～っ♪　ひぃいっ♪　すっごい\nっ♪　ドプゥッ！　ドクドクぅって精液があがってきたぁあ♪　ひぃんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ご褒美っ……！　ご褒美で子宮の中が真っ白に満ちてく……♪　あぁああっ\n、イクのが終わらないよ、ずーっとイキっぱなしになって……あぁあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私、おまえの……！　隊長のオンナにされてしまったぁあ♪　隊長の色に染\nめられて……！　隊長のオスの力に屈服して、隊長の臭いに包まれて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ♪　ちょっとぉっ♪　まだ出てるよ……！　とんでもない量だ\nねっ……♪　んんんっ♪　そうさ、最後の最後まで出しきって……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……ふぅううう……♪　隊長……♪　最高のご褒美、感謝するよ……♪　ハ\nロウィンってイベントのこと一生忘れられなくなったかもしれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ん？　本来は、お菓子をもらって終わりのイベントだって？　そんなことは\n言いっこなしだよ……。ここまで燃えあがらせておいて、突き放すとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　これからも、私と隊長のハロウィンは毎年コレをするっ\nて決めたんだ。いいだろ……？　お互いうんと気持ち良くなれるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「今から来年が楽しみになってきた……。フフフフ♪　何？　まだまだこの星\nには色んなイベントがある？　身体がもつか心配だな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ッあぁっ！？　もぉっ……！　ヤンチャだねぇっ♪　あんまり精液の勢いが\nすごすぎて……オマンコからチンポが抜けちまったじゃないかぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
