		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んふぅうううっ♪　あっ、出てるっ……！　出てるよ、また私の中に……っ\n♪　オマンコに精液注入してくれるんだねっ、ありがとぉおっ……♪」", "NORMAL" ]},
