		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「でも、身体にかけられるのも好きだよっ……！　さあっ、どんどんかけてく\nれっ……♪　あぁ……っ、トロットロの白濁液……ドキドキするよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　はぁっ、ンンッ……！　いいよ、いいよぉ……っ♪　おまえと\n私の仲じゃないかっ……！　今さら遠慮なんかナシだよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「マーキング、しておくれっ……！　私自身の匂いよりも強くっ……♪　おま\nえの精液の臭いにまみれたいんだ、だから……かけまくってほしいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あああああッ……！　いいよ、いいよぉおっ♪　このぬめり、この\n熱さ……っ♪　私の全部っ、おまえのモノだよ……！　あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「精液っ……精液ぃっ……！　大事な、大好きなおまえの精液……っ！　これ\n以上私を興奮させないでおくれぇっ……！　ああっ、かかっているよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ん、はぁっ……♪　これだけ出せたら、どれだけ気持ちいいんだろうねぇ…\n…♪　はぁ、はぁ、私は女だし、女の絶頂を知っているから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504407" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「かわりたいとは思わないけど……。こんなに勢い良くさぁ、精液が何度も身\n体の外に出ていって、エッチした女に降りかかるとか……気分いいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「一度くらい、体験してみたいな～って思ってしまった♪　隊長も、興味ある\nんじゃないか？　女の快感はすごいぞ～？　気を失うかもしれないくらいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……なんて、それは相手が隊長だからかもしれないけどな。いつも気持ち良\nくしてくれてありがとう。フフ、本気でそう思っているって……♪」", "NORMAL" ]},
