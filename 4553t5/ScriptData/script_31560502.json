		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っはぁっ、はぁ、はぁ、はぁ……！　も、もうダメだ、我慢できないよ……\n！　ねえ、ご褒美のお菓子なんていらないからさ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「チンポ……っ。このままチンポを入れておくれよ……っ。一生のお願いだ、\n奉仕をしたらお返しがあるって言ってただろ、だから早く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504102" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あああああっ……んぁああああっ♪　あ、りがと……ぉっ♪　隊\n長、フフフ、おまえもしたくてたまらなかったんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504103" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ものすごく熱くて硬いよ……♪　っあ……♪　なんて力強いチンポ……っ。\nそうだよ、これがずっと欲しくて……私はどうにかなっちまいそうだった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「っあっ……！　あっぁっあっ……♪　恥も外聞もなく、チンポをねだって足\nを開いて……っ。こんな自分、昔の自分が見たら驚くだろうね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　もちろんイヤじゃないよ……♪　こうやって、チンポを隊長に\nハメてもらえてとっても嬉しい……。遠慮なく突いとくれ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「中に入れてわかっただろ？　……んんっ♪　もうずっと、ぐっちょぐちょに\n濡らして待っていたのさ……。奥の奥まで蜜たっぷりだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「それ、に……♪　このガチガチのチンポで、激しく掻き回して、突き上げて\n、貫いてもらわないと……いつまでたってもずっと疼いたままなんだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……んっ……♪　そ、そう……！　来ておくれっ……！　あぁっ、すっご…\n…っ♪　ぐちゅっ、ぶちゅって水音が鳴ってるっ……。んあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「隊長のチンポぉお……！　めちゃくちゃ美味しいよぉお……っ♪　もっと、\nもっと食べさせとくれぇ……！　っあっ！　こんなのたまらないよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「中にっ……、オマンコに入れられただけで満足感が凄まじいよっ……♪　あ\nっ♪　太くてさ、ゴツゴツしていて、重くって……。はぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「欲しかったところに、突き刺さって……肉笠のでっぱりで♪　あっ♪　粘膜\nをぐちょぐちょ押し広げて、えぐって、こすって……。すごすぎるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　あッあっあっ……！　こんな良いご褒美っ、もらえるならハロウ\nィンも悪く、ないねっ……。むしろ最高さぁ……っ♪　あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「着飾ってきたかいがあったよぉっ……♪　あっ♪　おまえも興奮してくれて\nいるのかい……！？　だったら、毎日着てきてもいい……っ♪　はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……♪　ねえっ……♪　二人でこのまま、わけがわからなくな\nるまで絡みあって……トびまくってやろうじゃないかいっ……。っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「もっと、もっと奥を突いておくれ……！　ッうぅうっ♪　そうさ、一番奥ぅ\nううっ♪　子宮口を突き上げて、チンポぜーんぶオマンコにねじこんでっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私を楽しませておくれっ……！　あっぁっ♪　私もぉっ、私も隊長を喜ばせ\nるから……！　っあっ♪　す、ごい……スゴい、いいっ、それイイっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「力任せの乱暴なピストンんんっ♪　それ好きだぁっ、もっと！　もっとして\nぇっ……！　あああっ♪　なんてこった、幸せすぎるよぉお……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「この私がっ……！　襲来者のリーダーだった、敵だった私がっ……♪　隊長\nのチンポと繋がって、普通の恋人同士みたいにイチャついて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっあっ♪　むちゃくちゃに求め合って……っ♪　いっちばん恥ずかしい、\n敏感なところ……二人でお互いにこすりあって、汁にまみれて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁッ♪　あぁっ、幸せ……幸せぇええっ……！　私っ……、こんな見た目\nだから！　あ、姉御とか男勝りな印象……あるみたいなんだけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「本当はっ……あっ♪　こうやって、隊長に主導権握られて……！　オマンコ\n好きにされるのが好きなんだ……！　っあんっ！　普通の女の子、みたいに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「好きな相手に……めちゃくちゃに抱かれてっ！　うっとりしながらするのが\n一番好きぃ……！　あっ♪　隊長……おまえ、エッチ上手すぎるよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私の身体……感じるところ、性感帯……快感のクセ……！　隠してきたもの\n、全部カンタンにあばかれてしまう……っ。剥き出しにさせられるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「天才、だよ……っ！　んぁあっ♪　このチンポを知ってしまったら……もう\n絶対に、他のでなんかイキたくなくなるっ、このチンポしかダメになるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あぁあああ……！　わ、わかるだろ……っ。おまえに突かれな\nがら、オマンコぬちゅぬちゅ掻き回されながら……！　あっあっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私っ……、淫らに自分から腰を振っちまってる……ぅっ♪　尻を揺らしてぇ\nっ、チンポをじっくり味わっちまってる……！　衝動が止められないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んッあぁああっ……！　ああっ、ああっ……！　もっと強く、激しくしてぇ\nっ……！　あっ！　あっ！　全部、全部受け止めるから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ああっ、チンポ、チンポ硬くて気持ちいいよ……ぉっ。それに身体と身体が\n密着して……！　触れているところが疼くんだ、火照っちまうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「す、き……♪　好きだ、好きだよぉおおっ……！　隊長ぉおっ……♪　おま\nえ、いつも私のことを放っておくけどねぇっ、わ、私はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「こうやって、毎晩だって毎日だっておまえとしたいんだよっ……！　オマン\nコしたい！　おまえのチンポを気持ち良くしたいって思ってるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「だから……だから、いつだってこんな風にっ♪　あぁんっ♪　抱いてくれれ\nばいいのにさぁあっ♪　あっ、誘っておくれよ、強引にしてぇっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁううっ！？　な、なんなんだいっ……！　私が甘えたことを言ったら、\n急にチンポが膨らむじゃないかっ……。あっ♪　あっ、出すのかいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「もちろんかまわないけれど、……あっ！　１つだけ……っ！　そ、外に出す\nんじゃなくて……このまま、一番深いところで射精してほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「そうさ、繋がったまま、おまえの精液を感じたいんだ……！　ッあぁんっ♪\n締めるからこのまま、このまま出せぇえ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あああああッ♪　くぅううっ♪　くぅううんんっ♪　くふぅううっ……♪　\nあっぁっあっ、出てる……！　出てるよ、中に……一番奥に出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「おぉおおおっ♪　んッぉっ……♪　ふぉおおおっ……♪　あぁああ、子宮口\nにチンポの先っちょ密着させながら……いつまでも出しておくれぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ドピュッ、ビュルッて入ってくるのがわかるんだよ……！　あぁあああっ…\n…♪　あったかい……！　気持ち良すぎるぅっ……ああイクッっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ご、めんねぇえっ♪　種付けされながらイクよぉっ！　ああああっ♪　イク\n……イクっ！　イクぅううううっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ああああっ……♪　あははは、笑っちまうよ……♪　足がガクガクして、頭\nもぼーっとしてきてる……。身体の火照りはおさまってきてるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「んっ♪　かわりに脳みそがバカになっちまったみたいに真っピンク色だよ…\n…。はぁ、はぁあっ♪　はぁ、はぁ……♪　精液に酔ってるのかも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……ん……。あ、りがとうね……？　隊長……。こんなに私をよがらせてく\nれて、気持ち良くしてくれて……。すっごくすっごく嬉しかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「……なんだい？　何を一仕事終えたようなことを言っているんだ、だって？\n　お、終わっただろ？　今？　二人とも同時に絶頂して……。あぁあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「じょ、冗談だろうっ！？　ま、まさかこのまま、チンポも抜かずに二回戦を\n続けようって言うつもりなのか！？　ま、待ってくれ……無理だよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私、全力でイッたばっかで……！　このままなんて夢にも思っていなかった\n……っ。体力が尽きたよ、休ませておくれ……。って、んぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「チ、チンポで返事しないでおくれぇえええっ♪　あぅっ♪　んふぅっ！？　\nはぅうっ、あっ……、こ、困るよぉ……！　なんでそんなに元気なんだぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ふぅうっ♪　はぁあっ♪　あッ♪　あふぅっ♪　んぁっ、あっ、あぅうっ♪\n　うううう～っ！　い、一方的にされるばっかりなんて情けないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なのに、それなのにぃいい……！　抵抗できな、いぃい……っ！　おまえの\nチンポを拒めない……！　私の身体が、オマンコが欲してしまうぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁうううっ♪　私の身体っ……。持ち主の私なんかより、隊長のチンポの\n方が好きだってさぁっ……！　あっ♪　自分自身に裏切られてるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あぁんんっ♪　い、いやだぁっ……！　すごくオンナっぽい声が出てしまう\n……っ！　あんっ♪　メスの喘ぎ声……あっ、恥ずかしいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あ、くぅっ♪　一度イカせてもらったのに……精液、中に注いでもらったの\nにさぁ……！　少し突かれたら……動かれたら、また火照ってきてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私が私でなくなっていくぅ……！　あんっ♪　チンポの威力に耐えられない\nよ……！　あ～っ♪　あっぁっ、身体のスイッチ入っちまったぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「ずぶっ、ずぷって突かれるたびにぃいっ……！　軽くイッちまうぅうっ♪　\nひぃんっ♪　あっ、イクぅっ♪　イッくぅっ♪　イクぅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「はぁんっ♪　あんっ、あぅんっ♪　んんっ……！　バックから突かれるの、\nすごくイイよ……！　犯されてる、支配されてるみたいでぇっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「あっ♪　私、マゾ……なのか……！？　あんっ♪　もうそれでもいいよっ…\n…！　いっぱいしておくれっ……あっ♪　あっ♪　奥……もっとぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「す、ごいぃいっ♪　チンポの力で私の下半身、ギッシギシ揺れてるよぉおっ\n……！　あぁっ！　オマンコがもう、トロトロのぐちゅぐちゅで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「精液♪　欲しがってうごめいてるぅううっ……♪　あっ♪　わかるだろぉっ\n……？　チンポをシゴくみたいに、絞るみたいにうねってるのが……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「なぁっ……？　精液溜まってきてるか？　私の中に……もう一度出せるかっ\n……？　あぁっ、いいよ、子どもができてもいいからっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「だから一番濃いのをご褒美にっ……くれぇっ！　あぅうっ♪　準備できたか\nらっ♪　中出しの準備ぃっ、オマンコの奥で整ったからぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504219" ]},
		{"command":[ "SETIMAGE", "0", "still_00015605_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「出してほしいっ……！　あっ♪　オマンコヒクついて、おまえの精液待って\nるぅっ……！　イクッ、イくぅううっ！　あ～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0504220" ]},
