{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ……待たせてしまったな。閉店処理を済ませてきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00016002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ん……？　そんな仕事も任されているのか？　そこは、それなりに色々と根\n回しをな……お陰で、こんな状況を作ることも出来るという訳だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふ……私は仕事に手を抜くことはないが、今日の閉店間際は身体を持て余し\nて大変だったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが、目の前に最高のご馳走が待っていると思えば、気合も入る……そんな\n訳で、ようやく楽しい時間の始まりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00016002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふ……やはり制服が気になるみたいだな？　それなら、今日はこのまま…\n…たっぷりチンポにご奉仕させてもらうとするか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ……そうだ……ここだけボタンを外して……隙間からチンポを\n差し込む……ふふ……私の胸の谷間に小さな山が見えているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016002_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「どれ……れろ……んっ、れろ……ん、ふっ……制服越しでも、ちょっとは舌\nの感じが伝わるかな……？　よーく濡らしておかないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「じゅる……えろ……れろ……んっ、唾液が染み込んで……おっと……チンポ\nも浮き上がってきたじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「勃起も、いよいよ膨らんできたところで……本格的に動かしていくか……う\nんっ、ふっ、んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふ……こういうのも着衣セックスなんて言うのかな？　私のおっぱいを…\n…キミのチンポが犯して来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「隙間から……亀頭が顔を出してるな……れろ、ちゅぷっ……んふっ、こいつ\nも……軽く舌先でつついて刺激してやるのがいいみたいだ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふっ……ほんの数時間前までは、この席で客の注文を取っていたのに……\n今は、そのお客様の席に跪いてパイズリをする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「日常の中にある非日常はゾクゾクするな……んっ、もっと大きく動かしてい\nくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、うんっ、んふっ……どうかな……？　少し汗もかいて……いい\n滑り具合になって来た……チンポも、程よく敏感で……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んっ……あぁ……すごいな……ビクビクチンポが震えて……んぅ\nっ！　あぁっ……乳首……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「直に触れると……乳首がピリッとして……んっ……あぁ……興奮が高まって\n来て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ、ダメだ……抑えきれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……乳首ぃ……押さえ込むの……いいっ……んくぅっ……す\nまない、一人で盛り上がってしまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「オナニーする時も……こうして乳首を摘んで、転がすのが私のやり方になっ\nていて……ちゃんと、んっ、キミのチンポを優先するから……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あふっ……んんっ、そういうことだ……乳首オナニーをしながら……キミの\nチンポをパイズリしているという訳だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……閉店後限定の……極秘の裏メニュー……ふふっ、君しか味\nわうことの出来ない……特別なコースだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「胸の肉が……しっとりとチンポに絡みついて……その時々で、このちょっと\nしたアクセント……ほら、こうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「うんっ！　あふっ、んんっ……どうかな……伝わるだろう？　コリコリした\n突起の感触……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「柔らかいだけじゃ物足りないだろうからな……この硬い部分が……不意打ち\nになって……キミのチンポを喜ばせる訳だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はぁっ、あぁっ……おっぱいがひしゃげる……んんっ、自分の\nモノが……こんなにいやらしく形を変えるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……見ているだけでゾクゾクするっ……んぁっ、もっと動かしていくぞ\n……私のおっぱいをチンポ全体で味わってくれ……は、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、はあっ、んっ……おっと……亀頭からカウパーが滲んで来たな\n……ふふっ、思ったよりも早いようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「は、ふっ……こんなに揉みくちゃにされれば、そうなるって？　ふふっ、確\nかに……自分でも動きがどんどん大胆になっていくのが分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ……やせ我慢はしなくていいぞ？　出したくなったら、出したい時に欲\n望に身を任せるといい……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「なんてことを言うと……ふふっ、妙に鼻息が荒くなって……必死に射精を堪\nえようとしているじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そんな顔をされたら……もっと可愛がってあげたくなってしまうぞ……？　\nこうして……ぎゅうっと……チンポをうずめて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……んんっ……亀頭を乳首ズリしながら……竿を……上下させる\nっ……はっ、んんっ、あふっ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「チンポを完全にプレスして……先端だけが見えている状態だ……ここで舌を\n軽く当ててやれば……んっ、れろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ほうら……プルプルしている……んふっ、ちゅぷっ……さあ、そろそろ観念\nしてっ……チンポから射精して見せてくれっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ……始まったな……んんっ、ドクドク……凄い勢いで…\n…精液が溢れ出して来てる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……そうだ……いいぞ……あぁ、染み込んでいく……ウェイトレスの制\n服がキミの精液でドロドロにされていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……大丈夫だ。どうせクリーニングに出るものだからな……その前に\n、自分でもちゃんと処置はしてバレないようにするさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だから、遠慮なくチンポから出していいぞ……んんっ、そうだ……あぁ……\n温かいな……中がヌルヌルになっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっ、はぁ……収まったかな……？　あぁ……おっぱいの中がキミ\nの精液でべっとりだ……だが、この感触……悪くない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……味も男らしさを感じて好みだ……ふふっ、いっぱい出し\nてくれて感謝するよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「さて……後はお掃除でも、と思ったが……キミのチンポはまだまだ元気が有\nり余って仕方ないという感じだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それなら、ここから先は……本当の裏メニューという感じで……ご奉仕接客\nさせてもらおうかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「では……お客様のチンポ……改めてパイズリフェラさせて頂きます……んっ\n、れろ……ぺろ……んっ……ちゅぽ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「敬語に違和感がありますか？　ふふっ、ウェイトレスの時は基本的には敬語\nですよ……そして、任務もその状態でこなす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もっとも、今の任務はこのチンポのご奉仕になるんですけど……んっ、ふっ\n、射精したお陰でかなり滑りやすくなってますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「おっぱいを……寄せて……戻す度に……じゅぶっと……少し品のない水音が\nしています……んふっ、れろ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もっと響かせると……はぁっ、んふっ……私の気持ちも高まって来ますね…\n…んっ、れろ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……また……お客様の前で……はしたない乳首オナニーをしてしまうこ\nと……お許しください……んんっ、どうしても欲しいんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、あぁ……コリコリになってる乳首が浮き上がるの……はした\nない……でも、それを見られていると……じんわり気持ちよくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「チンポと絡ませあうほど……乳首が鋭敏になっていって……あぁ……パイズ\nリしているだけで……私も気持ちよくなって来ますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「お客様……んっ、して欲しいところがあったら、何でも仰って下さいね……\n本日は特別メニューなんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「おっぱいの動かし方も……お客様のお望みのままに……はい、思いっきり押\nし潰す感じ……かしこまりましたわ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「いかがですか……？　制服の中で、お客様のチンポが……縦横無尽に行き来\nしてっ……またビクンって跳ねていますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぷっ……また、先走りも……滲んできて……腰の震えも大きく\nなって……パイズリ……感じて下さっていますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んふっ……おっぱいの中もどんどん熱くなっています……これだけ反応して\nくれれば……パイズリのしがいもありますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「乳首も……いっぱい擦れてっ……ご奉仕なのに……私まで感じてしまってい\nます……あっ、ふっ、んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もし射精する時は……私も一緒にイケそうですから……んっ、仰って下さい\nね……はっ、んふっ、そろそろでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はんっ、んちゅぷっ、お望みでしたら……口の中でも……顔面射精でも……\nお客様の思うがままに……なさって下さいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、れろ……あぁっ、乳首痺れるっ……乳首感じますっ……あぁっ、\n私も……もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はいっ、一緒にっ……イキましょうっ……あぁっ、出してっ……！　思い切\nり射精なさって下さいっ……んっ、あぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ふぶっ……ごくっ……んふっ、うぶっ……んんんんっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「こくっ、んくんっ……口の中……濃いのが……んくっ……たっぷり出されて\n……んぐっ、飲みきれない……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……はぁ……んちゅぷっ、大丈夫……こぼすなんて失礼なことはしま\nせんから……れろ、ちゅぷ……じゅるっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はふぅっ……ふぅ……ご馳走様でした。ほら……あぁん……口の中……全部\n飲んでるでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「後は……亀頭をしっかりと舌でお掃除して……ちゅぷっ、れろ……ちゅぽっ\n……んちゅるるぅっ……尿道口の分を吸い上げて……んはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「こちらでサービスは終了となります。ご利用、ありがとうございました……\nなんてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふふっ、何だかんだで、私も楽しんでしまったな。軽くイッたし…\n…ファミレスの中でというのも良かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ま、ウェイトレスとしてのサービスも、今日だけの特別仕様だからな。そう\nそう出会えるものじゃないと思ってくれればありがたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふ……本当にドロドロだ。キミの精液に浸されて……においが染み込んで\nしまいそうだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが、この逞しさ……悪くない。またその気になったら呼んでくれ。新しい\nサービスも考えておくよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　んふっ……あぁっ……すごい量の……顔面シャワー……出て\nるっ……んぷぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あーんっ……顔に浴びせるだけじゃなくて……舌の上にも出\nして下さい……んちゅぱ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふはぁ……続けて出してるのに……まるで勢いが衰えない……濃さも変わら\nずで……すごいですわ……お客様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……シャワー……やっと止まりましたか。ふふ……たっぷり\nの射精……大変お疲れ様でした」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016002_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「さて……後はお掃除をしてしまいましょう……汚れたチンポの先……そのま\nまにはしておけませんから……れろ、ちゅぷ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はい、これで大丈夫です。お疲れ様でした、こちらでご奉仕は終了となりま\nす……なんてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「普段のウェイトレスの時でも、こんなに丁寧な接客はしないかもしれないな\n。ついつい乗ってしまったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「まぁ、これもキミのチンポのせいだろうな。全く……こいつで、どれだけの\n女を乱れさせてきたのやら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ふふ……だが、たまには気の向くままに乱れてみるのも悪くない。軽くイッ\nたし……私も楽しませてもらったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そうだな、また気が向いたら呼んでくれ。その時は、もっと素晴らしいサー\nビスが提供出来るようにしておくさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}