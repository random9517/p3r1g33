{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0096" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま？　この服はどうでしょうか？　こちらの服も気になります……。\nふふふ、お洋服売り場につれてきてくださるなんて……すてきです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……どちらのデザインがお好きですか？　では、試着をしてみますね……。\nはい？　ためらわずに着替えるな……ですか？　あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんがおおきくなってます。これはわたくしが、かんたんに脱い\nでみせつけてくるから……？　そ、そうだったんですの？　ええと、それなら\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしが、それを楽にしてさしあげてもよろしいですか？　旦那さまがつ\nらそうなのはいやなのです。ですから、よろしければ……こうして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。わたくしのお口と、おっぱいで……おちんちんさんをいや\nしてさしあげます。わたくしの胸、ちいさくていやですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022102_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちっぱいを押し当てられるのがすき？　それならよかったです！　えっと、\nおっぱいは……やっぱりすごく小さいですけど……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「口は、皆様と同じだとおもいますし……。胸の先っちょは、敏感で……ちゃ\nんとピンッて大きくなりますから、それでたくさん頑張ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、んっ……。ち、ちっぱいコキというのですね……この行為の\nこと……。旦那さまは何でも知っていらしてすごいです……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのちっぱいコキ、どうかたのしんでくださいませ……。はぁっ……\n、はぁ、……あっ……。ぷに……ぷに、ぷに、ぷに……んぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい……。以前より、ほんのすこーしだけ大きくなった気がします。旦那さ\nまが、いつも可愛がってくれているから……。んっ、んっ、どうですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふふふ……。わたくしたちの仲です、えんりょなんてしなくてよいんですの\n……。ふにゅ、ふにゅ、ふにゅ……むに、むに、むに……。ん～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぁ……。お口を使うのをわすれていました。これは、フェラチオ……ですよ\nね？　前に習いました。はい、亀頭というところを舌でちろちろします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのおちんちんさんは大きすぎて、お口にぜんぶ入りませんから……\n。舌の先っちょで、ちろ、ちろ、ぺろ、ぺろって愛撫をしちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁ……ぺろっ……。はぁあ……♪　お、おっきい……♪　わたくしのお口\nより大きくて、ふとくて……少し汗のにおいがして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なんとなく、クセになってたくさん嗅ぎたいにおいがするんです……。ぺろ\n……ぺろ、どんどん硬くなるのもとても面白くて……。ぺろ、ぺろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……心配はごむようですよ……。胸で刺激するのもわすれておりません\nの……。お口、ちっぱい……おくち、ちっぱい……ぺろぺろぺろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だいすきな、だいすきな旦那さまのおちんちんさん……いっぱい気持ち良く\nなってください……。なんでもします。ちゅっ♪　ぺろ、ぺろ、ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁ……すごく腫れてます……。すこしでもわたくしのお口で、ぴちゃぴち\nゃ舐めてぬらしてさしあげなくては……。んー……れろ、れろ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おおきくて、一度にぜんぶ舐められまふぇんね……？　ぺろっ……れろっ、\nちゅぅ……。ぷちゅっ、くちゅ、ちゅる……ちゅぷっ、ぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はむ……むぅ……。むっちゅっ、ちゅうっ……ちゅっ、れろっぺろ……ぺろ\nっ、ぴちゃっ……。ちゅむ♪　むちゅ……ちゅぅっ、ちゅ、ちゅーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふふふ……。ピクピクしてます……。だいじょうぶです、わたくしはいたい\nことなんてしませんから……。ちゅぅう……、ぺろ、ぺろぺろぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「え……？　わたくし、ぽーっとした顔をしていますか……？　おちんちんさ\nんを舐めてうっとりしている……？　そ、そうかもしれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すごく、すごく旦那さまのおまたが熱くって……。頭がぼーっとしてきまし\nた。むわって熱気がたちのぼってきて……。はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「今、旦那さまのいちばん大切なところにご奉仕してる、赤ちゃんをつくる部\n分を愛撫しているって思うとすごく興奮するんです……。ぴちゃっ、ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「赤ちゃんにミルクをあげるおっぱいで、赤ちゃんを作るおちんちんさんをぷ\nにぷにして……。それってとてもえっちだなぁって……。ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「愛する人が……。んんっ、未来の旦那さまがわたくしの身体で、ぺろぺろで\nよろこんでくださることが……これ以上ない幸せで……。もうだめです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すぐそこに人がいるのに、ここは試着をする場所なのに……。どんどん夢中\nになって声が出ちゃいます。すき……すき、旦那さま……れろ、れろれろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのご奉仕を、もとめてくださってありがとうございます……♪　お\nちんちんさんも、真っ赤になって腫れてます……♪　れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなに大きく膨らんでいたら、くるしいですよね……つらいですよね……\n。ぺろぺろして、わたくしの唾でテロテロになって……輝いて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「見れば見るほどいやらしい形で……。あぁ、赤ちゃんをつくる部分って一目\nでわかっちゃいます、すごく、すごくえっちな色で……。ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「見るたびに、ぺろぺろするたびに好きになっていくんです……。はぁっ……\nぴちゃ……すき……すき、気持ちいいですか？　ぺろっ、ぺろ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのつたないぺろぺろで、こんなにビキビキになってくれて……大し\nゅき……♪　ちゅぱっ、くちゅ、ちゅぅっ……ちゅ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁっ……♪　おへんじしてるみたいにブルンブルンッてなりました……。\nとっても元気でかっこいいです……もっと、もっとご奉仕します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いっぱい舐めますから、わたくしのお口を好きになって……♪　んっ……。\nあっ？　ビクビクが強くなって……！　で、出ちゃいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ひゃんんっ！？　んぷっ！？　ぷぅっ……んむ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああああっ……。な、なんて男らしいのですか……っ。あっ……ふぁっ♪　\nせいえき……せいえきが飛び散って、はじけて……！　んーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「つ、つよすぎます……！　あふっ……、んぷ……！　待って、まってくださ\nいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっあっ、も、申し訳ありません……！　旦那ひゃま……。あっ……！　勢\nいが、勢いがすさまじくって、わたくし……受け止めきれなくてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふ、ぁ……せっかく、せっかく出していただいたせいえきが……！　……え\n？　気持ち良かったからへいき、ですか……？　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「確かにたくさんぴゅっぴゅって出てました……。白いおしっこみたいに、お\nちんちんさんからびゅるーっびゅるーって……でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きちんと飲み干そうと思っていたのに、大切なせいえきをこぼしてしまうな\nんて……。これではあなたさまの妻失格です……。うう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お、お願いです……。もう一度、挑戦させてはいただけないでしょうか？　\n今度はぜったい、ぜったい全部飲みます……飲めますから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぅ……っ♪　ふぅうう……。心をおちつけて……。ちらばったせいえきさ\nんたちを、少しずつ……ていねいに舐めとって……。ぺろ、ぺろ、ぺろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ここは……人様のたいせつなお店の中……。ですから旦那さまのせいえきは\n、わたくしにだけぶつけていただかないと……。ちゅっ、ぺろっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「さっきより……もっとお口をひろげて……。ねんいりに、ふかく……。れろ\n……♪　れろ、ぴちゃ、くちゅ……っ。チュ、ちゅ……ちゅぅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「興奮しても……。んっ……声はおさえて、水音がたたないように……。っ…\n…あぁ、でも、でも……もっと激しくしたい……。ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んむっ……むちゅっ♪　ちゅぷ……ぷちゅっ……♪　こ、これくらいの速さ\nと強さでいいですか……？　はぁっ、おっぱいもくっつけて……すりすり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくひは……旦那ひゃま専用の、えっちなおもちゃになりたいのれひゅ…\n…♪　誰よりご奉仕が上手なお嫁ひゃんに、なりたいのれひゅ……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぅっ……ふぅっ、ふぅっ……♪　が、我慢しようとおもえばおもうほど…\n…頭がトロッと蕩けてきまひゅ……。ぴちゃ……くちゅ、ちゅぅ、ちゅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んああ……、お口にぜんぶほおばれないことがくやしいれふ……。だいすき\nな、だいすきな旦那さまのかっこいいおちんちんさん……好きですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「たくさん、たくさんかんじてください……。れろっ、れろ、くちゅ……！　\nんちゅるっ、ちゅぷぷ……くちゅっ、ちゅる……ちゅる、ちゅぷぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのおっぱい……おっぱいはここちよいですか……？　わたくしは…\n…あぁ♪　旦那さまのからだで感じています……ちゅる……ちゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああ……旦那ひゃまの体温が、わたくしの胸につたわってきます……。ドキ\nドキしているの、わかりますか……？　んっぁ、あっ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの心臓が脈打って……旦那さまのおちんちんさんもビクビクふるえ\nていて……。とっても不思議な光景れひゅ……。ぺろ、れろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んーーー……ちゅぅ……♪　ちゅぷ……ちゅぷっ、ぷちゅ……にゅぷ……♪\n　ちゅぅ……ちゅる……♪　ぴちゃ、ぴちゃ……くちゅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん……ふぁ……♪　き……気持ちいいですの……。旦那ひゃまのおちんちん\nさんをぺろぺろしていると……胸がムズムズして……ウズウズして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それをぎゅっ、ぎゅってくっつけると……すごくすごく気持ちよくて……。\nはぁ、はぁ、わたくし、もう……もう……。ちゅる、ぺちゃっ、ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203217" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　今すっごく、いちゃいちゃできてうれしいです……。んちゅ\n……♪　わ……また、おちんちんさんが膨らんできましたよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、あの……ここからわたくしはどうすると良いですか……？　できればこ\nのままおちんちんさんをぺろぺろして……せいえきを飲ませてほしいですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「でも、旦那さまにしたいことがあるのでしたらそちらにあわせます。なんで\nもおっしゃってください……！　あっ、ど、どうぞ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ？　い、いいのですか？　もう一度最後まで、この舌で旦那ひゃまのお\nちんちんさんをぺろぺろし続けてよろしいのですね……うれしいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203301" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それでは、愛をこめて、もっと過激に……。んれろっ……レロ、ぴちゃっ、\nれろ……♪　ふふふ……とってもとっても嬉しそうです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしと、おちんちんさんは両想いれひゅね……♪　いっしょにいっぱい\n気持ち良くなりましょう……。れろっ、れりゅ、ぬちゅっ、にちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぺろっ……♪　ぺろっ、ぺろぺろ……♪　あ♪　お口からはみだすくらい大\nきくなってきました……もうすぐぴゅーぴゅーなさるのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの、舌の上……お口の中を狙って出ひてくだひゃい……。どうぞ…\n…♪　れろっ……れろっ、れろ、あぁ、出して、出してくだひゃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぷっ……！　んむぅううっ、む～～～っ……んん……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203306" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああ……っ。わたくしのお口の中にほとばしる、旦那さまの大切なお汁……\nこんどこそ……。こぼすことなんて絶対にいたしません……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ぜんぶ、ぜんぶ舐めとって……お口の中でほおばって、たっぷり味わってか\nら……。ごくっ。んくっ……んく……。ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どう、ですか……？　ちゃんと飲めました……。これならきっと、お外にい\nる方たちにも……わたくしたちがしていたことはバレませんよね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それに……やくそくを果たせました……。せいえきをすべていただくこと…\n…。これなら、妻として恥ずかしくない振る舞いができましたよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ、もうおくちの中におちんちんさんを入れなくていいんですの？　あ、\nあのっ、わたくし何か粗相を……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203401" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「かわいいから、いたずらしたくなった、ですか？　よかったです、てっきり\nわたくしがいたらなかったのかと思いました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　頭撫でてもらうと、からだのおくがふわぁってしますの……♪　わ\nたくしも、おちんちんさんをなでなでしますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なでなでじゃなくて、にぎって強く動かす……？　ええと、痛くないのです\nか？　ふわあ、旦那様はお強いのですね。それではこう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ、んぅううう～～♪　だめ……これじゃあわたくしだけが気持ちよく…\n…って、そんな！　旦那さまのおちんちんさんが大きくっ？　あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どくどくって旦那様の鼓動が手にひびいて……熱くて……どきどきします…\n…♪　あっ、今、びくって……え？　お口を開けるんですの？　舌を出す？？\n　ええと、あーん、こ、ほおれふか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん～～っ♪　だんなひゃまのしぇいえきっ、わらくひのかおにも、髪にも…\n…かかってまひゅ……っ♪　あちゅくて……匂いがすごい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203407" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぅっ、したのうえにょ、しぇいえきっ、ごっくん……しまふ、んくっ、ん\nぷっ、こくん……はい、ぜぇんぶ、わらくひのおなかの中ですの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203408" ]},
		{"command":[ "SETIMAGE", "0", "still_00022102_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……あっ♪　まだびゅるびゅる出て……♪　ふふっ、かけていただくのも、\nあたたかくて……幸せで……。んんっ、おっぱいもどろどろですね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那様の匂いでいっぱいで……きもちいいです。ふふふっ……結局大きな声\nを出してしまってすみませんでした。二人でお店の人に謝りましょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0203410" ]},
