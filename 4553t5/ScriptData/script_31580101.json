{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「緊急の用があるって聞いたから来たけど……ご主人、何かあった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　奉仕任務？　気持ちよくして欲しい？　あー……つまり、あれかな…\n…性的に、ってことでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふーん……そっか、その手の命令だったか……姉さんではなく、私に……ま\nぁ、そーゆーこともあるよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――別に嫌って訳じゃないよ。ただ……うん、少し驚いただけ。それだけだ\nから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――いいよ、する。ご主人がそれを望むなら、してあげる。私はご主人のモ\nノ、なんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに……ふふっ、実はちょっと興味もあったんだ。知識は一通りインプッ\nトされてるからさ。知ってたら……試したくなる、でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「何、その驚いた顔……乗り気なのが意外だって？　ふふっ、知ってるでしょ\n、私達は、そーゆー風に作られてるんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の喜びが、私の喜び。しっかりご奉仕、させてもらうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103108" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……ここまで近くで見るのは初めてだけど、人間の生殖器……おちんち\nんって、思ったよりかわいい形してる、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これを上下にゆっくり擦っていけばいいんだよね……ん、しょ……んっ……\n手コキ、ってやつだよね……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、ご主人もそんな声出すことあるんだ。……力加減はこのぐらいで\n大丈夫？　痛かったら言ってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……それにしてもおちんちんって不思議な感触……んっ……固くはある\nんだけど、押すとその分返ってくるほどの弾力があって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「皮の部分ってこんなに伸びるものなんだ……んっ……それに、指先をゆっく\nり動かすたび、先端が小さくヒクついて……体温の上昇もすごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「たしかここ……裏側の所が敏感なんだよね……んっ……縦の筋に合わせて、\nゆっくりと撫でてあげれば……思ったより素直に反応するんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――そりゃ興味はあるよ。私はインプットされた知識をしってるだけ。それ\nを実際に試せるのが嬉しいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それならもっと色んな事をご主人が教えてくれるって？　ふふっ……ありが\nとうご主人、とっても嬉しいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――わかった、もっと根元からぎゅっと握ればいいんだね。そのまま皮を巻\nき込むように、大きく動かす……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「先端のふくらみの所に指が引っかかるように……んっ、しょっ……これをリ\nズミカルに繰り返す、っと……んっ、ぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　掛け声？　おちんちんに語り掛けるようにしながら？　……ここぞと\nばかりに変態チックなことを教え込んでくるなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも……うん、いいよ。それでご主人が気持ちよくなれるなら、やってあげ\nる……私は、やってあげたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっと……またおちんちんをゆっくり上下に擦りながら……んっ……いち、\nに、いち、に……こんな感じでいいのかな……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「少しずつ、スピードを上げて……んっ……いち、に、いち、に……少しずつ\n、分かってきたかも……いち、に、いち、に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「後は……そうだ、人間の男性は応援されながらシコシコされるのが好きなん\nだって、姉さんが言ってたっけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほーらご主人のおちんちん、がんばれ、がんばれ。いっぱいシコシコしてあ\nげる、がんばれ、がんばれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、おちんちん、こんなに元気に跳ね回っちゃって……ビクンビクンし\nてるの、やっぱりかわいいかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぐちょぐちょ、ぐちょぐちょって、さっきからえっちな音も凄いね。私の指\nに、ご主人のお汁が絡みついてきちゃってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、普通の人間の様に舐めたりはしてあげられないけど、その代わりこう\nして……んふっ……私の顔を使ってスリスリしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「口はないけど……えっちに膨らんだ先っぽを擦りつけて……すりすり、すり\nすり……こうやって、おちんちんにじゃれつくの、好きかも……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私の顔、ご主人のえっちなお汁で汚れちゃった……ふふっ、全然嫌なんかじ\nゃないよ？　むしろ、もっと汚してほしいぐらい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まだまだいくよ……んっ……両手でぎゅっとおちんちんの根元を絞って……\nシコシコ、シコシコ……顔でスリスリって……ん、んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「たくましいおちんちん、シコシコ、シコシコ……いち、に、いち、に……い\nいよご主人、その可愛い声、もっと聴かせて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちん、ドクドクって脈打って、また大きくなった……なんだろ……ご\n主人のおちんちん見てると、全身のパーツが変に熱くなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、不思議だね？　ただ手を使って奉仕するだけなのに、嬉しい気持ち\nが止まらないや……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――分かってるよ、もうそろそろ、なんでしょ？　血管がこんなにも浮かび\n上がって、先っぽがピクピクしてきてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、我慢しないで出していいよ。このまま顔で受け止めてあげる。ご主人\nの子種、たくさん出して……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　すごい勢いっ……人間の精子ってこんなに熱いものなんだ\n……んんっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ビクビク跳ね回って、全然止まらなくて……んんっ……！　必死に射精する\nおちんちんもかわいい、かも……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ん……もう、終わりかな。実際に手コキをするのは初めてだったけど……ど\nうかな、上手にできた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私の顔にべっとりかかった精液の量がその答えだって？　ふふっ、素直に褒\nめない所が、流石のご主人って感じだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　じっと顔を見つめるのは恥ずかしいからやめろ？　もう、ほんとにご\n主人はかわいいなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それにしても……一回出したぐらいじゃ、全然治まらないんだね。おちんち\nん、固いまんまだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「赤く膨れた先端も、まだピクピクしてて……これ、もう一度シコシコしたら\n、まだまだいっぱい出せるんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もう一度お願いしてもいいかって？　もちろんだよ。言ったでしょ、私も興\n味あるって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに、私も試してみたいこと、まだまだ残ってるんだ。ほら、こうやって\n手の平でおちんちんを包み込むようにして、っと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、分かった？　そう、今ご主人のおちんちんを両側から挟み込んでる\nのは、私の肉球の感触だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「その顔見るに、気に入ってもらえたみたいだね。ぷにぷにしてて、気持ちい\nいでしょ？　結構いいパーツ使ってるからね、私的にも自慢の部位なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……さっき出した精液を、肉球に絡ませて……すりすり、シコシコ……\n両側から、擦り上げる様に、っと……すりすり、シコシコ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「折角ならご主人も私の動きに合わせて腰を動かしてよ。ほら……いち、に、\nいち、に、いち、に……そうそう、いい感じ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いち、に、いち、に……シコシコ、シコシコ……ふふっ、必死に腰を前後に\n突き出すご主人、とってもかわいいよ……いち、に、いち、に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああ、またご主人のお汁がいっぱい出てきた……んんっ……さっきの精液と\n混じって、匂いもすごくて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「姉さんが言ってた、ご主人の匂いが好きって気持ち……今ならちょっとだけ\n分かる、かも……んぁ……これが、興奮するってことなんだ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、もっと出して……口でスリスリするからさ、私の顔、ご主人の匂い\nでいっぱいマーキングしてほしいな……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに、ほら、肉球も……ふふ、腰がビクンって浮き上がったね。すごいで\nしょ？　私の肉球、こうやって振動する機能がついてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「何の為にそんな機能がついてるんだって？　そんなの、ご主人に満足しても\nらうために決まってるじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「知ってるよ、ご主人の弱い所。亀頭のこの膨らんだ部分、その付け根を裏側\nからこうやって押さえつけてあげれば……ふふっ、いい反応」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「指先で浮き上がった血管をゆっくりなぞって……んんっ……顔で先っぽをス\nリスリ、肉球で左右からぎゅーって圧迫して……んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「シコシコもどんどん早くしていくからね……いち、に、いち、に……ご主人\n、腰を前後に動かすの、止めちゃ駄目だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「また応援してあげるから、このまま最後まで……！　んんっ……ほら、がん\nばれ、がんばれ……そうだよ、その調子。いち、に、いち、に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああ……やっぱり射精直前のご主人のかわいい顔、大好き……んんっ……い\nっぱいシコシコしてあげるから、もっと私に見せて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「先っぽがまたヒクヒクって……！　出すんだよね、精液！　いいよ、ご主人\nの好きな場所に、思いっきり射精していいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんんんぅぅぅっ～～～！　ま、また顔にっ……んあぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんんぅぅぅっ～～……す、すごい勢い……あつくて、ドロっとし\nてて……ご主人にマーキング、されちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「射精中のおちんちんって、こんなにドクドクしてるんだ……精液が中をのぼ\nっていくのが、よく分かるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ……このまま全部出し切るまで、シコシコ続けるね？　んっ、しょっ\n……全部出し切っちゃっていいからね……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……これで終わり、かな……どんどんおちんちんが柔らかくなって……\nこれはこれで不思議な感触かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、顔中精液でべったりだ……んぁ……この匂い、癖になっちゃったら\nどうしよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　顔を汚してごめんって？　今更そんなこと謝られてもなぁ……ふふっ\n、言ったでしょ、全然嫌なんかじゃないって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それにしても……二回目なのに、ほんとにいっぱい出したね。これが人間の\n子種……ご主人の子供の元、なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……今の私にそんな機能はついてないけどさ、いつの日か、専用のパーツを\n用意して妊娠できる日がくるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「なーんてね、ふふっ……約束通り私に新しい喜びを教えてくれて、ありがと\nうね、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁぁんっ～～～！！　す、すごい勢いっ、ご主人の精液、身体にかかっ\nて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「顔だけじゃなくて、全身にマーキングされちゃう……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「胸の谷間に、精液がこんなに溜まってっ……あっ、んぁんっ……それに、ま\nだまだ止まらなくて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、いいよ、全部身体で受け止めてあげるから。ご主人は気にせず、最\n後の一滴まで私にぶちまけて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んぁんんっ……！　やっぱりご主人の匂い、好きかも……機\n械の身体のはずなのに、ドキドキが止まらない……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ん……これで全部、かな？　どうかなご主人、私の手、気持ちよかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――そんなにまっすぐ褒められると、ちょっと照れくさいかも。でも……喜\nんでくれたのなら、よかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、まだおちんちんピクピクしてるね？　もしかして、まだまだ物足り\nなかったりするのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え？　だからそんなに真っ直ぐ見つめるなって？　……ふふっ、ご主人のそ\nーゆーかわいいところ、やっぱり嫌いじゃないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「我慢できなくなったら、奉仕任務、またいつでも命令してよ。私はご主人の\nモノ、なんだからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}