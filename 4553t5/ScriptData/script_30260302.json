		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「でも……私は大人ですから、これを味わうことは禁止されていませんっ……\n♪　あっ♪　あっ、そ、そうですよね？　これは大人だけのお楽しみ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0304110" ]},
