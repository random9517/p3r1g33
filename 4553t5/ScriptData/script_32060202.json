		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁぁぁぁっ！　またっ、ああぁおっ、中出しぃっ……！　し、\n子宮までっ……ザーメンっ……出て……るぅぅっ！」", "NORMAL" ]},
