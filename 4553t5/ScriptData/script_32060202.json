		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てる……あぁ、こんなの入り切るわけないってばぁ……溢れる…\n…ザーメン漏れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んふぁっ、ま、また潮吹きぃ……やら……止まらない……オマンコ……ずっ\nと気持ちいいのぉ……はぁ、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あっ……中出し……お、終わったぁ……？　んっ、ずっと…\n…すごいの出てたぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あぁ……しちゃった……アタシ……お店の中で、めちゃくちゃセックスしち\nゃった……」", "NORMAL" ]},
