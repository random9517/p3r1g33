		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ……これさ……やっぱりちょっと大胆過ぎない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ここ……店の入り口の真正面だし……か、鍵は掛けたけど……でも、誰か入\nってくるかも知んないし……そしたら、全部見えちゃう訳で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あっ、くふっ……んっ、き、聞いてる……？　めちゃくちゃ\nおっぱい揉んでくるじゃん……？　そんな着々と準備されてさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぅっ……んっ……おっぱいその気にさせてくの……ズルい……んっ、にゅ\n、乳輪膨らんでるとか……い、言うなってのっ……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「くぅっ……もう……何で、そんな上手いんだよ……あぁう……乳首ぃ……硬\nくなっちゃう……はっ、ひっ……あっ、また指ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぅっ、あっ……立ってるって、お前が立たせてるんだろぉっ……遠慮なし\nに、こんな……転がしまくってぇ……あ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁっ、ヤバい……んっ、あぁ……お尻に何か当たって来てる……オチンポ\n……もう待ってる状態じゃん……くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ……ふぁ……な、なぁ、もういいだろ……？　おっぱいばっかりじゃな\nくて……そろそろ、その……こ、こっちも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「だ、だから……んくっ、わ、分かってるクセに……こっち、オ、オマンコも\nぉ……おねだりだろっ？　ちゃんと……おねだりするからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「お願いします……んっ、お、お前……じゃない、貴方の……ビンビンになっ\nたオチンポで……アタシのオマンコ……突いて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ずっとおっぱいコリコリされてぇ……カラダ、ウズウズして……オマンコも\n欲しがってるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「だからっ、いっぱいしてっ、逞しいオチンポでっ、オマンコしてっ！　ずぶ\nって太いのっ……突っ込んでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぅっ！　んくぁぁぁっ、入ってきたっ……！　オチンポッ……\nあひぃっ、ずぶってオマンコっ、中に来たぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ふぁふっ……あひぁ……ヤバ……ちょっとイ、イっちゃったかも……ま、ま\nだ中入っただけなのにぃ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「わ、分かってるし……！　続き、していいから……んっ、そのまま、オチン\nポ……動かしてぇ……はうっ、あっ、あくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「うんっ、あっ、はっ、あぁっ……な、ナニこれ……ゆさゆさ……揺れてっ、\nオチンポ……中でめっちゃ暴れてるっ……んっ、あぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あぁっ、こ、このカッコ……大丈夫っ？　はぅんっ……アタシ\n……重くない？　途中で倒れるの……ナシだかんねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「全然……平気……？　へ、へぇ……案外、力……あるんだ……んっ、ふっ、\nあっ、はぁっ……もっと違う心配……それってどういう……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「うぁっ、はっ、あぁっ！　ちょっ……あっ、ホントに激しいっ……！　あっ\n、オチンポッ……中でっ、あっ、あぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ヤバっ……あっ、グリグリされるぅっ！　はひぁっ、オ、オマンコッ、すご\nっ、ぐちゅぐちゅっ……中っ、回されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「や、やだっ、ちょっ……足……広げすぎっ……そんな見せつけるみたいなの\nっ、は、恥ずかしいしっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「そ、それがいいって……そんなのっ、あっ、あぁっ！　アタシは、そんなの\nじゃっ、ひぁっ、あっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁっ、ちょっ……今、おっぱい……またっ、するのはっ、あぅっ、んんっ\n、くぁうっ！　ま、また乳首ぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「やら……さっきより、もっと敏感になってるの……あぁっ、んんっ、くにく\nにされたら……し、痺れるぅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「もっと濡れて……はぁっ、あふっ、また……揺らすのっ、ダメ……アタシ、\nそんなに一気にされたらっ、アタマおかしくなるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、そこぉっ！　あっ、オマンコッ！　またオマンコぐちゅっ\nてっ、イ、イッちゃうっ！　またイッちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃんっ！　あっ、はぁぁぁぁっ……イ、イクぅっ！　あっ、あぁっ\n……オマンコ……ほぉぉっ、オチンポでイッてるぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁぁ……はぁぁ……あっ、やだ……も、漏れちゃう……あひっ、\nアタシ……あぁ……潮……吹いちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……止まらなっ……み、見るなぁ……あぁ……恥ずかしいからぁ…\n…は、ぅ……ぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……はぁ……はぁ、あふっ……出ちゃった……うぅっ、そのピス\nトン……無理すぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あふっ、しかも……まだ、オチンポ動いてるしぃ……んっ、今度はそっちも\nイクとこまで……？　んっ、はぁっ、あっ、くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「も、もうやめろって言ったって絶対するじゃんっ……いいよっ、続けていい\nからっ、ちゃんと……オチンポ気持ちよくなってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　そうっ、そこぉっ……！　アタシも……んっ、頑張ってオマン\nコッ……ギュッてするしっ……はぅっ、今のもいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、息……荒くなってきてる……んふぅっ、オチンポ……出そう\nっ？　ビュルって射精しちゃうんだろっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「いいよっ、アタシもっ……続けてイクからっ！　このままっ、中に出してっ\n！　熱いのっ、全部……射精してぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「くぅぅぅんっ！　あっ、来たっ……ザーメンっ……めちゃめちゃいっぱい…\n…出されちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……種付け……こんな、働いてる店の中で……いけないことぉ……\nんぁぁ、ヤバい……気持ちよすぎぃぃ……はへぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……ダメ……今、顔見ちゃダメだって……絶対ヤバい顔してるから…\n…だらしないイキ顔見たらだめぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふぁぁ……はぁぁ……あっ……止まった……？　射精……終\nわったぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁぁ……マジ、ヤバかった……オチンポ……気持ちよすぎたぁ……\nんっ、ふっ、はぁ……んっ……ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んっ……あ、あのさ……とりあえず、そろそろ下ろしてくれる？　オチンポ\n……ずっと入ったままだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「お、終わりじゃないって……い、いや、そのままするのっ？　はっ、んんっ\n、あっ、あぁっ、そんな……あっ、ひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「制服でエロいカッコしてるのが悪いって……な、なんでアタシのせいみたい\nになって……んぁぁっ、お、おっぱい……またっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んんぅっ……ずるいってぇ……弱いトコ、されたらぁ……イヤなんて言えな\nいし……うぁぁ……オ、オマンコもまたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はふっ、あっ、んんっ……あっ、中のザーメン……混ぜられてるっ……あっ\n、床……汁垂れちゃうっ……ま、また掃除しなきゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「うぁ……こんなの、明日もシフト入ってるのにっ……めちゃくちゃセックス\nしてるなんてっ……ヤバすぎるからぁ……は、ひぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　またっ、カラダっ……揺すられてるっ！　ひっ、んんっ、\nオチンポっ……グリグリっ……めり込むぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はひっ、あくぅっ、んぁっ、あぅぅんっ……！　さっきよりっ、速くなって\nるっ、あひっ、オチンポっ、激しいっ、オチンポ来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あぁっ、い、いいよぉっ……！　そこ好きぃっ、オチンポの先で……こつん\nってされるのっ、今の……もっとっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んふぁぁっ！　はぁぁっ、それぇっ、されたらっ……ダメになるっ……アタ\nシっ……ま、またイッちゃうっ、オマンコおかしくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はひっ、あっ、んぁっ、あぁぁぁぁっ！　イクッ……オマンコまたイクぅぅ\nぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ひゃひぃ……またイッたぁ……はぁぁ、オチンポ串刺しぃ……すごすぎぃ…\n…はへぇ……ふ、ぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204212" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あぅっ！　んぁっ、あぁっ、ま、まだ止まらないっ！　オチンポ強いっ……\n！　はぁぅっ、ずっとピストン……続いてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、どんどんお汁……掻き出されてるぅっ……ひぁぅっ、ちょっ……\nうなじ……舐めるのダメだって！　あぁっ、またそこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「ひゃふっ、んくっ！　カラダ……全部っ、感じてるっ！　オマンコッ、おっ\nぱいっ！　お腹もっ、背中もぉっ、どこも気持ちよすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00020602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んふぁぁっ、かき回してぇっ、アタシの恥ずかしいオマンコもっとぉ！　オ\nチンポもっ、またビクビクして来てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……また……出そうっ？　んぁっ、ひぁぁっ！　最後っ……い\nっぱい……かき回してっ……はひっ、ひぃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、オマンコッ……メチャクチャにされてるっ！　また、アタ\nシっ……続けてイッちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「いーよっ、出してっ……！　またビュクビュクっ……射精してっ、はひぃっ\n、も、もぉっ……む、無理ぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「またイグッ！　ひぃんっ、オマンコイクからっ、あぁぁぁっ、またオマンコ\nイッちゃうぅぅぅぅぅぅぅんっ！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_0204220" ]},
		{"command":[ "WAITINPUT" ]},

