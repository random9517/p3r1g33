		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カレン" ]},
		{"command":[ "SETTEXT", "「はひぁぁぁ……イキマンコに……せぇえきぃ……熱いの……どぷって……あ\nぁぁ……溶けるぅぅぅ……んふぁぁ……」", "NORMAL" ]},
