{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あつい、身体がとける……ん？　隊長、何か用……？　見ての通り、忌\n々しい太陽光のせいで動きたくないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「別に夏は嫌いじゃないよ、みんなと海で遊ぶのも楽しいしね。ただ……暑す\nぎてやる気がでないんだよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「私は心に決めた、次の夏までに忌々しい太陽をぶっこわす何かを絶対に発明\nしてやる……何だい、その苦笑いは。私は本気だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「その馬鹿げた野望を捨てるなら、いいものをくれるって？　……隊長が手に\n持ってるのは……日焼け止めローション？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「冷却成分入り……オー、イェッ！　なんてナイスなタイミング！　それでこ\nそ私達の隊長だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「って、隊長が塗ってくれるの？　私の身体に？　素手で？　……あー、オー\nケー、そういうことね。少しでも褒めた私がバカだったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「やっぱりこうなっちゃうんだ。隊長の副隊長、今にも爆発しそうなぐらいパ\nンパンだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「私の身体を触ったんだから当たり前だろって？　……そこまで堂々と開き直\nられたら、もう何も言えないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「まぁ、いいよ。下心はあったかもだけど、私のことを思って日焼け止めを持\nってきてくれたわけだしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そのお礼に、このまま気持ちよくしてあげる。……胸で挟んで刺激されるの\nがいいんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふふっ、実はちょっと興味あったんだよね、胸で扱かれたら隊長の棒はどん\nな反応を見せてくれるのか。しっかり観察させてもらうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ……上半身に体重を掛けて、圧迫感を与えてっと……んっ……上下に\n揺らすように、しこしこ、しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「思ったより滑りがいい……んんっ……日焼け止めローションがいい潤滑油に\nなってくれてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「これなら……んっ……もっと胸の谷間にローションを溜まるようにして、ぐ\nちゅぐちゅ、ぐちゅぐちゅ、っと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……ふむふむ、やっぱりこうしてにゅるにゅるの谷間で全体を揉み込むのが\nいいみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「先端がヒクヒクって口を開いて、膨張率も上がった？　軽く挟み込んで扱い\nただけなのに、この反応……やっぱり興味深い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「初めてだからちょっと不安だったけど、問題はないみたいだね。このまま続\nけさせてもらうね……って、な、なに隊長、どこ見てるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ぼ、勃起した乳首って……そんなはっきり言わないでよ！　し、仕方ないで\nしょ、胸をぐにぐにしてると、変な気持ちになるんだもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「私の身体の変化も合わせて観察、比較することこそ、真の科学者に必要な資\n質だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「また無茶苦茶なことを……わ、分かったよ！　確かに自分の身体の変化も気\nになるし、しっかり観察するってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ……もう一回、上半身を押し付けて……ぐちゅぐちゅって、上下に揺\nらす……んんっ……シコシコ、シコシコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「男性の棒を挟むと、私の胸ってこんなに形が変わるモノなんだ……んんっ…\n…なんか、乳首も固くなって……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なんだろう、これ、んあぁんっ……隊長の下腹部に軽く擦れるだけなのに、\n変に快感が強くて、あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長、このローション、何か変じゃない？　擦れる度にス―ってするという\nか、ジンジン身体が火照ってくると言うか、あっ、んあぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そ、そういう成分入り？　やっぱり最初からそのつもりだったか。この変態\n隊長め……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「分かってる、今更止めたりしないって。言ったでしょ、私も興味あるって。\nこのまま胸で刺激を続けるとどうなるか、しっかり観察させてもらうから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ！　もっと力強く、おっぱいの形が激しく変わるほど、ぐにぐに、ぐ\nにぐにって押し付けて、っと……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……すごくいやらしい音、んふんっ……それに、隊長の副隊長、\n先っぽがピクピクし始めた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「透明な汁がダラダラこぼれて……カウパー腺液って、こういう風に溢れてく\nるんだね。人体の神秘って奴だ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うん、分かってるよ。こうしておっぱいをふよふよ持ち上げて、左右に擦り\n上げるように刺激して欲しいんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、んあぁん……！　やっぱりこのローション、だめ……あっ、\nんあぁん！　激しくおっぱい動かすと、私も気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長……！　これだけペニスをピクピクさせながら、カウパーを出してるっ\nてことは、もうイキそうなんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「いいよ、このまま私のおっぱいに出して！　ラビットパワー全開でぎゅーっ\nてしてあげるから、射精の瞬間を私に見せて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「しこしこ、こすこす……ほら、根元からおっぱいで搾り取ってあげるから、\n精液ビュービューって出しちゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふあぁんんっ！？　な、なにこれ、隊長のがおっぱいの間で爆発した！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「熱くてドロドロの精液が、んんっ！　す、すごいっ、胸で扱くとこんなに出\nるんだ、んっ、んふぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　まだまだ出るの？　わ、わかった、このまま止めずにおっぱい弾ませ\n続ければいいんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「こすこす、ぎゅーぎゅー……んんっ……ほ、ホントだ、先っぽがパクパクっ\nてしてどんどん垂れてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「これが胸を使って奉仕された時の男性の反応……うん、いい観察をさせても\nらっちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それにしても……隊長の副隊長、全然小さくなろうとしないね……え？　ま\nだ出せるって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わわっ、おっぱいの間でビクンッてした！　なるほど、このままおっぱいで\nの射精をもう一度観察させてもらっていいんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃあお言葉に甘えて……んんっ……谷間に溜まった精液とローションをぐ\nちゅぐちゅに混ぜ合わせて……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あっ、んんふっ……この動き、やっぱり私も気持ちいい、かも……肌が擦れ\n合うたび、ビリビリってして、んんあぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わ、私の乳首ってこんなに大きくなるんだ……あっ、んあぁんっ！　ここま\nでビンビンになってるの、初めて見るかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それに……すんすん……この匂い……ふあぁんっ……嗅げば嗅ぐほど、思考\nに靄が掛かったみたいに気持ちよくなって、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほら、隊長も見てみなよ、私の谷間。ローションと精液が混ざり合って、白\nい泡が溢れてきちゃってる。ふふっ、いやらしいよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それをこうやって……んふっ、んんんっ！　わざと音が鳴るぐらい大きく上\n下に動かすのが気持ちいいんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「へへへ、さっきのでもうコツは掴んだからね！　どこをどう刺激すれば隊長\nが気持ちよくなるかも、ばっちり把握してるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほぉら、両側からペニスをぎゅーって押さえつけて、擦り合わせるように、\nぐちょぐちょ、すりすり、しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「隊長の顔、どんどんアヘ顔になってきた……んんっ……そんな気持ちよさそ\nうなの見せられると、私も……あっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「乳首ぐいぐいって押し付けるの気持ちいい、あっ、んあぁんっ！　にゅるに\nゅるって隊長の肌の上をおっぱいを滑らせるの、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んひゃぁっ！？　た、隊長、いきなり体動かさないでよ！　そんな小刻みに\n揺らされると、乳首擦れてっ、ふあぁっ！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ううん、嫌じゃないよ。びっくりするけど、嫌じゃない！　あっ、んあぁん\n！　あっ！　オー、イェッ！　イェッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「でも、私だって負けないんだから！　まだまだ激しく搾り取ってあげるんだ\nから！　くらえ、ラビットパワーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほぉら、隊長！　副隊長の先っぽがパクパクし始めた！　ドクドクって脈打\nって、とっても素直な反応を見せてくれてるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「またカウパー腺液も混じり始めたね。イキそうなんだよね？　いいよ、私の\nおっぱいでまた快感を爆発させて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ふあぁんんっ！　わ、私の事はいいんだって、身体、跳ねさせないでっ、あ\nっ、んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そりゃ気持ちよくなるのは嬉しいけど、今は隊長が私のおっぱいで射精する\n瞬間をしっかり観察したいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「だから、ほら！　おっぱいたぷたぷ、シコシコすりすり！　いっぱいぎゅー\nってしてあげるから、射精して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ほらあと一息だよ隊長！　すりすり、たぷたぷ！　好きな所にかけていいか\nら、私にいっぱい観察させて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んあぁんんっ！　またおっぱいの中で熱いのが爆発してる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ドクドクって精液が流れ込んでくるの、変に気持ちいい、か\nも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「えへへ……隊長。今、自分がどんな表情してるか分かる？　すっかり蕩けき\nったアヘ顔しちゃってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「私のおっぱい、そんなに気に入ってもらえたんだ。いいよ、このままぎゅー\nってしてあげるから、尿道に残ってる精液まで全部出しちゃえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「根元から押さえつけて、ぎゅー！　ほら、隊長、がんばれ、がんばれ！　最\n後の一滴まで搾りとちゃうからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んっ……これでお終い、かな？　改めて見ると、私のおっぱいの谷間、すご\nい事になっちゃってるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「色んな液体でぐちょぐちょのドロドロ……んんっ……ほら、聞いてよこのい\nやらしい音、二回の射精でこんなに精液って吐き出せるものなんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「中々興味深い観察だったよ！　どうかな？　隊長も満足してくれたのなら嬉\nしいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「大満足？　何回でも味わってみたい……？　へへへ。そう言ってもらえると\n、ちょっと頑張った甲斐もあったかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あくまで観察の一環だけどね！　それでもいいなら……またいつでも、\nやってあげてもいいよ？　なーんてね、えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　で、出てる！　おっぱいの間で、暴れながら勢いよく射精して\nるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ホント、すごい激しいね……んんっ……確かに好きな所にかけていいって言\nったけど、こんなに出すなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203302" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「二度目なのに勢いも全然衰えてないし……そんなに私のおっぱいが気持ちよ\nかったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「んんっ……まだビクビク跳ねてる。このまま胸を動かしたら、さっきみたい\nにまだまだ出てくるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わわっ、ホントに出てきた！　これがおっぱいで扱かれた時の隊長の反応…\n…ふふっ、中々興味深いね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それにしても、私の顔を無茶苦茶汚してくれちゃって……ビキニ姿だから、\nいつもより興奮しちゃったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　当たり前だろって……？　そこまで堂々と言い切られちゃうと、その\n、恥ずかしいと言うか、どうしていいかわからないというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00009802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「もう！　見ないでよ隊長！　にやにやするな、微笑ましい目をむけてくるな\nぁ！　観察するのは私の仕事だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……ねぇ、隊長？　この気持ちよくなるローション、まだある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そ、そうなんだ……じゃあまた今度、つき合ってあげてもいいかなーって。\nも、もちろん研究の一環だけどね！　へへへ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}