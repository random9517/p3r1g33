		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ、よく来たな。くるしゅうないから、そこに座るがよいぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803101" ]},
		{"command":[ "SETCHARA", "0", "char_00000708_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、そう畏まることはない。今日呼び出したのは他でもない、お主の日頃\nの疲れを癒やしてやろうと思ってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「何も遠慮することはないぞ？　この精巧なボディは、お主の欲望をしっかり\nと満たせるように出来ておるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「それに、えーと、これはそう、女王がしっかりと性能を確認するためにと言\nっておったぞ。なので、これは女王の命令も同然」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「さあ、分かったならさっさとお主のチンポを見せてみるがいい。そうらっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぉー、出た出た。ふん、まだまだ半立ちじゃが、十分にできそうではない\nか。そら……まずはこうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000708_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ、ぴくりと跳ねたぞ？　色々言う割には、なんとも欲望に正直ではない\nか。ほぉれ、さすってやろう……こす、こす……と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうじゃ、柔らかいじゃろう？　この部分は、特殊な素材で出来ておるのじ\nゃ。敵の攻撃にも耐えうる超硬度にもなれば、逆も然り……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふふ……しっかりとチンポにフィットして、血管にまで絡みついてくるじ\nゃろ？　先っぽをさすられて……おぉ、どんどん勃起してきたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむうむ、身体は実に正直で結構。ビクビクと脈打って、すっかりその気に\nなって来たではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「では、もう少し力を入れて……しっかりとチンポを扱いてやろう。んふっ、\nほれほれ……よく皮がめくれて……ふふ、いい感じじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「やはり、強く締め付けるようにするのがいいようじゃな？　ぎゅっと握るだ\nけでお主の腰が動くのがよく分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「なるほどのう……この身体でするのも中々面白いな。もう少し不自由かと思\nっていたが、十分すぎるほどよく動く」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「あ、いや……余のＡＩはまだ色々と学習中でな……それで、どの程度動ける\nのかはまだ、把握しきれてないと……そういう意味じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、細かいことはよいじゃろう。それより、チンポの方もムズムズし\nて次の段階に行きたくなっておるんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……いいぞ、今度はこの高性能ボディの、特に精密な場所を使ってやろ\nう……見ろ……この口じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁんむ……くぽっ、ちゅぷぅぅぅっ、んふぅぅぅ……ふぉら……ひんぽ…\n…ぱっくりしてひまったろぉ……んじゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ひゃんと……適切な……唾液に近い成分が……分泌されるように\n出来ておるからな……じゅるっ、ほぼ同じ感覚じゃろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「だが、ただ同じという訳れはないぞ……くぽっ、むふ、んじゅぷっ、ちゅぷ\nっ、んじゅるるるっ、じゅるっ、くぽっ、んりゅっ、じゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「お主の……んりゅぷっ、チンポの反応を……見極めて……ろうふれば、より\n気持ちいいかを……最適化して……締め付ける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んじゅぅぅぅっ……くぽっ、んちゅぷぅぅっ……りゅぶっ……ろうじゃ……\n？　腰が砕けそうになるじゃろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅぱ……んんっ、余もしっかりとチンポの味を感じておるぞ……これは擬\n似的な味覚じゃが、ちゃんと成分を分析しておってな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「りゅぽっ、もっと言うとお主の健康状態まで……りゅぱっ、分析することも\n可能なのじゃ……じゅるっ、ちゅぷぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……気になるか？　心配するな……お主のチンポの先走り……極めて健\n康的な状態だと保証してやろう……じゅぷっ、ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「強いて言うならば、んっ、りゅぷっ……この大きさは……余の口には少し余\nる……全く……しっかりとチンポをビキビキにさせおって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ、存外……お主も、余のこの姿に……りゅぷっ、雌の色香を感じてい\nるということかも知れぬなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ、無論……余は一向に構わんぞ……じゅぱっ、丹念にしゃぶってやる\nから……しっかりと余のフェラを楽しむがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「れろ……尿道をほじるように……んんっ、口の中で……れる……えろ……れ\nろぉ……舌の硬さはこれくらいでよいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ、舌の感触をお主の好みに変えることもできるぞ？　ちょっとザラザラ\nした先端にして……ふぉら……んりゅっ、ろうじゃ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、腰がビクンとなったな。少し刺激が強すぎたか。じゃが、そんな反\n応を見せられると余も、止まらぬぞ……じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅっ、んふっ、おふっ、んんっ、先走りの……分泌量が……本格的\nに増して来たぞ……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ、余の口マンコも……お主のザーメンが飲みたくて……疼き始めてお\nる……んじゅぽっ、くぽっ、りゅぷっ、んちゅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「出したいか……？　あぁ……飲ませてくれ……んじゅるっ、お主の……新鮮\nなザーメンミルクじゃ……じゅるっ、ちゅぷっ、んちゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の……口の中に……たっぷりと濃いのをっ……んふっ、らすのじゃっ……\nんちゅぅぅぅっ、じゅるるるるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ふぐっ、おぶっ……んんっ、んっく……んっ、りゅぷっ…\n…んちゅっ……ちゅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁぁ……喉を通り抜けていく感覚がある……んふ……余のタンクに……お\n主の濃いのが流れ込んでくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、ちゅぱっ……んはぁぁ……あふっ、美味じゃ……あふっ、この味\nで……余も絶頂の感覚を覚えたぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、んちゅぅぅ……まだ出てくるか……本当に元気のいいチンポじゃ\n……ちゅぷぅぅぅ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「はふぅ……どうじゃ？　本職には及ばぬかも知れぬが……余の奉仕も中々の\nものじゃったろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……これだけ濃いのが出ていれば、それが何よりの証明じゃから\nな……ふふっ、たっぷり味わわせてもらったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「さて……軽く一休みかと思ったが……ふふ、まだまだ、ビクビクと元気がい\nいではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「これは続きをして欲しいということかのう？　それとも、もうお腹いっぱい\nで十分に楽しんだかのう？　んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ……今のチンポキスで、十分に答えは受け取った。これだけ分かりや\nすくチンポを蠢かせたら決まっているようなものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「よいよい、わかっておる。ふふ……まだして欲しいんじゃろう？　ほれ……\nまだイッたばかりのチンポ……柔らかく扱いてやろうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……んふっ……今は敏感になってるからのう。強すぎず、優しく這わせ\nてやるのがいいじゃろう……？　つぅっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、この柔らかい触り心地が気に入ったか？　またチンポが、しっかり\n上向きになってきたのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅっ……また元気いっぱいになったところで、チンポを吸い上げ\nてやろう……はむぅっ、りゅぷちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅるっ……んんっ、さっきの精液が……まだ多少残っておったな……ちゅ\nう……んっちゅ、味がまだ染み込んでおる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅ……こんなものを味わってしまうと……もう舌も止まらぬものよ……\nんふ……余のＡＩがもっと味を学びたがっておるのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぅぅっ、んちゅっ、ちゅぱっ、ぴちゃっ、れるっ、りゅぷっ、んぷっ、\nくぷっ、んちゅぷんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁむ……りゅぱっ……余の舌が止まらない……唇も……皮を扱いてっ、レ\nロレロ……ふるぅっ……じゅぽっ、んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「まら……んりゅぷっ……新しい汁が滲んで来たろ……れろ、んちゅぷっ、ふ\nぉれ……じゅぽっ、じゅるっ、んぐぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぷっ……！　んんっ、腰が止まらなくなっておるの……いいぞ、多少乱暴\nにしても構わぬっ……余の口マンコを犯すがいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぽっ、んぷっ、りゅぷっ、んちゅぷっ……チンポがっ……んんっ、じゅぶ\nっ、激しくぅっ……なるぅっ、りゅぶぅっ！」", "NORMAL" ]},
