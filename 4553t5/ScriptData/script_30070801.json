		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「この身体はっ、頑丈に出来ておるのじゃっ……遠慮はいらぬっ、じゅぷっ、\nそのままっ、もっろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぶっ……んっ、まら……れそうらのかっ……？　んんっ、いいぞっ、お主\nのっ……好きなようにふるがいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んむっ、もう一発……口の中れもっ……余の顔にぶっかけるのもっ……お主\nの思いのままじゃっ……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅっ、余もっ……もうっ、待ちきれぬっ……！　お主のザーメンでっ…\n…もうすぐイクのじゃっ、んぶっ、んんんっ！」", "NORMAL" ]},
