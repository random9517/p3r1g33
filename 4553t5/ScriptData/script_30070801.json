		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「待っておれ、後始末までしっかりとしてやらなくてはな。ちゅぷっ……ぺろ\n……チンポの先にもまだべっとりと精液が残っておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んちゅっ、ちゅぽっ……ぺろ、ぴちゃ……れろ、うむ……こんな\nものでいいじゃろう。実にキレイなものじゃ」", "NORMAL" ]},
