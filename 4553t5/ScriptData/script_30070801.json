		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぐっ、２発目らというのにっ……なんて量を……んぐっ、じゅぷっ、んっ\n、んくっ、んくんっ、んっふっ、んはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……んっ、ふぁぁ……本当に遠慮なく出してくれたのう\n……いや、よいよい、それでいいのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「言ったであろう、この身体はお主の欲望にしっかりと応えられると。余も、\nそれを望んでおる。中途半端に射精を止める方が論外じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、はぁ……んっ、どうやらこれで打ち止めのようじゃな。うむうむ\n、実によく出したものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「んちゅるっ……後は掃除じゃ……奥に残ってる分も吸い出して……全部キレ\nイにしてやらんとな……ちゅうぅぅぅ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむ、こんなものじゃろう……ふふっ、礼には及ばぬ。今日はお主の慰安な\nのじゃからな、存分に余を使うがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000708_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「今日はデータもたっぷりと取れたからな。上手く活用すれば、次はもっと楽\nしいことができると思うぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……そうじゃ、より進化した余のテクニックがお主をトロトロに溶かし\nてしまうのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0803309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「この悩殺ボディにも慣れて来たからな。お主も、存外行けるクチだと分かっ\nた以上、もっともっと楽しまなくては……な♪」", "NORMAL" ]},
