		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・ルナルバース" ]},
		{"command":[ "SETTEXT", "「さあっ、らせっ……！　ドロドロ……ザーメンっ……じゅぷっ、いっぱいっ\n、らせぇぇぇぇっ……！」", "NORMAL" ]},
