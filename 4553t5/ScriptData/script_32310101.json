{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほれほれ～。ど～よ？　ボクのおっぱい。生乳披露だぞ～。もっとよろこべ\n～、ありがたがれ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こうやって、キミのなっさけないポコチン挟んでやってるんだからさぁ。\nんふふっ、間でビクビクしてんじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お～よちよち。おっぱい怖いね～怖いね～。ビッグぱいぱいにぎゅ～って\nされて、可哀そうに可哀そうに～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「でも、ボクは遠慮なくチンポしごいちゃうけどね～。うひっ、おっぱいで\nチンポをがぶがぶしちゃうぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「左右から、思いっきり、ポコチンぎゅ～ってして……っと。こうしておっぱ\nいでチンポしこしこってね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どう？　どう？　やわらかいおっぱいにしごかれて気持ちいいでしょ～。\nんひひぃ♪　我慢は身体によくないんだぞ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それともボクへの挑戦状かな？　ボクがこのおっぱいでキミのこと射精させ\nられるかっていう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あははっ、いいね面白そう！　ボクも、そういうシチュエーションって燃え\nるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、ちょっと本気出してパイズリしてこっかな～♪　んひっ、さっ\nそくチンポに、よだれを垂らしてね～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふっ、ほらこれでチンポがヌルヌル。ボクのねっとり唾液にまみれて先っ\nぽがやぁらしく光っちゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほら、ほら、おっぱいだぞ～。やわらかおっぱいで、チンポをたっぷりしご\nいちゃうぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぎゅ～っと根元から、先端に向かって、ずりずりずりりんってな感じで。\nぱいぱい動かしちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんっ、チンポ脈打ってる♪　こっちは正直だねぇ。ほれほれ、ここか？　\nここがええのんか？　うりうりうり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっぱいごとチンチンこねこねしまくっちゃう。はぁ、はぁ、どんどんチン\nポが膨らんできてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「必死に我慢しちゃってるね。チンポと一緒に、腰までビクビクって震えてき\nているのに、まだ耐える？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まだまだ余裕ってことか。んふふ、このボクを挑発するだなんて、いい度胸\nしてんじゃん。その意気やよし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んじゃあ、遠慮なくキミのリトルボーイをパイコキさせてもらっちゃおうか\nなっ！　それそれっ、もっとぎゅっとパイ固めだぞ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　キミの腰が浮きあがるくらいにぎゅうっとおっぱい締めちゃっ\nて、ンッ、バキバキチンチン、コキコキしちゃうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほらほらほら、見とけよ見とけよ～。ご立派チンポがボクのおっぱいに\n出たり入ったりしてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「や～ん、チンポさんのエッチ～♪　谷間から顔出しちゃうくらいビンビンに\nおっきしちゃって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「やっぱチンポは正直だね～。なんだかんだパイズリで感じまくっちゃってさ\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それに比べてキミの辛そうな顔！　ああん、ゾクゾクしちゃうわぁ☆　本当\nは射精したくてたまんないんじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「パイコキでザーメン、なっさけなくどびゅどびゅ出しちゃいたいんじゃない\n？　そう顔に書いてるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなことない？　もう、強がりさん☆　そのすました顔……めちゃくちゃ\nにしてやりたくなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だからこうやって、もっともっと、乳圧高めてチンポしごいてやるんだから\n覚悟しなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「スケベ乳をたっぽんたっぽん弾ませながら、チンチンゴシゴシ、射精するま\nでしごきまくってやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うひひっ。どうどう？　我慢できなくなってきたでしょ？　ほらほら、顔を\n背けちゃだめだよ、ボクにキミの顔をちゃんとみせて」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「歯を食いしばって、ボクのパイコキで射精しないように耐えてる必死な顔…\n…あははっ、いいねぇ、素敵だよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そのまま射精しちゃおっか。んひっ、もう限界も近いのはわかってるんだか\nらね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「反り勃つガチ勃起チンポがさ、真っ赤な亀頭をパンパンに膨らませちゃって\nるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あははっ、これって本気の勃起？　セックスしてるときに、女の子孕ませる\nとき用の勃起だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「残念ながらこちらのおっぱいマンコ、どれだけ射精しても女の子は妊娠しな\nいのです。ご存じ……ないのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なんてねっ！　ボクは無駄撃ちさせるつもりだよ！　本物マンコに射精させ\nてあげない。キミはおっぱいで十分でしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらもう我慢の限界でしょ？　出しちゃえ出しちゃえ、無駄撃ちザーメン、\n間抜け顔でどぴゅどぴゅしちゃえー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのおっぱいはもう、キミのガマン汁のせいでヌルベトぐっちょりなんだ\nから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だから止めの高速パイズリ♪　ほらっ、だせっ、だせっ、だせっ、だせっ！\n　イけっ、イけっ、オラッ、射精しろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どぴゅっちゃえぇっ！　んんっ、ああっ、出てきたぁあっ！　パイパイマン\nコにザーメン、くっさいの、ああっ、たくさん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いきなり射精するなんてひどいじゃないか。もっと射精寸前のキミの顔を\n見ていたかったんだけどなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まあ、ボクのおっぱいにパイズリされてたわけだし、キミがどーしても我慢\nできなくなっちゃうのは仕方ないよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あー楽しかった。……なに？　これで終わりかって？　んなわけないじゃん\n。まだまだこれからだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「この勝負は当然２ポイント先取だからね。まずはジェスタ選手、巧みな乳捌\nきで隊長を射精させ、１ポイントリードです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「てわけで、このままパイズリを再開しとうございます。ああ、チンポやチン\nポ。なおも勃起し続けてるとならばしごかねば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「たっぷりザーメンだしたからねぇ。ああもうぐちょぐちょだよ。ほら、動か\nすたびにおっぱいの間でザーメンが音立ててる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それに、ああん、すっごい臭い。チンポ汁の臭いが、おっぱい動かすたびに\n鼻の中にすーっと入ってきちゃうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっともっと、いやらしい音を立てながらおっぱい動かしちゃうよ。ほら\nほら、こうやってね、交互にこねくりまわしちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのおっぱいで、チンポにザーメンぬりたくるみたいに……んひっ、\nこれ、チンポがザーメン臭くなるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミはこれから、女の子にフェラチオさせるたびに『うっわチンコくっさ』\nって言われちゃうんだ。かわいそー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あれれー、チンポがビクンって反応したような？　もしかして女の子になじ\nられるのがすきだったりするのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あははっ、まあキミの趣味なんてどうでもいいか。まずはもっともっとキミ\nのチンポからザーメン絞らないとね」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほら、さっきキミが出したザーメンのおかげでこんなにパイズリがスム\nーズだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、もうチンポが暴れて……あんっ、逃がさないよ。ボクのおっぱいで\nもっと射精してもらうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「１回射精しちゃって、チンポの感度も上がっちゃっているでしょ？　うひひ\nっ、我慢してる顔がもうたまんないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいんだよー。もう射精しちゃったんだから、２回も３回もかわんないって\n。射精しちゃいなよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのおっぱいに負けちゃってるチンポなんだから、もう負け続けちゃって\nいいんだよ？　ほら、ほらほら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふっ、キンタマに隠してるザーメンも、ボクのパイコキでぴゅっぴゅと\n射精しちゃおうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もう我慢できなくなってきたでしょ？　ザー汁まみれのヌレヌレ亀頭がパン\nパンに張りつめちゃってるみたいだし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほら、だからもう１回射精させちゃうからねっ！　思いっきりおっぱい締め\n付けてシコシコズリズリ動かしちゃうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だしちゃえ♪　だしちゃえ♪　さっきみたいに腰を震わせながら、情けなく\nザーメンもらしちゃえっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひひっ、ほらっ、ほらっ、限界チンポの根元からドロドロザーメンこみあ\nげてきてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「精液だしちゃえ！　また、ボクのおっぱいに敗北惨敗クソザコオスミルク、\nぴゅるぴゅるってしちゃえぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　ああっ、ああぁああぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「またっ、またおっぱいに、ンッ、キミの精液がびゅーって注ぎ込まれてる…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああもう、２回目だっていうのになんて勢いっ！　ンッ、さっきの射精は\n手を抜いていたな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「濃厚な真っ白ザーメン……ああ、見てほら、ねっとりおっぱいに張り付い\nちゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ……もうくっさいくっさい。嫌んなっちゃうくらいくっさいよぉ～。\n臭すぎて、でも……好きぃ……☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひひっ、たっぷり射精したわりには、キミのチンポは元気だねぇ。どうし\nたんだいチンポ君。なに？　もっと射精したい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そうかそうか～、チンポ君はこのジェスタちゃんのおっぱいマンコが大好き\nになっちゃったんだね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……へ？　そんな芝居はいいから解放しろって？　なに言ってるの？　まだ\nまだ開放するわけないじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクはキミのちんぽが気に入っちゃった♪　というわけで、もっともっと\nチンポで遊ばせてもらうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……うひひっ、ボクがザーメン臭くなるまで、キミには射精してもらうんだ\nから☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁあああぁぁぁんっ！　ちょっと、ンッ、キミのザーメン、凄い\n勢いだよぉおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁああっ、ああっ、顔にっ、あぁんっ、顔にいっぱい……ザーメン、んひ\nっ、どぴゅっ、どぴゅって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、汚されちゃってる……くっさいザーメンで、ボク、いっぱい、顔中\nザーメンまみれぇ☆　ああっ、ああぁぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んもぉ……。キミってばなんて奴だ。ボクに不意打ちをするなんて……んっ\n、おかげで……ちょっとイッちゃったじゃんかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひっ、２回目なのに、こんなに濃厚なザーメン……。ああっ、このネバネ\nバ……すっごく身体に悪そうで、たまんないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても２回目のほうが濃厚だなんて、もしかしてこのまま\n搾りつづければどんどん濃くなる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのザーメン、もっと浴びたくなってきちゃったし……んひっ、となれば\nヤることはひとつだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっともっと、キミにパイズリして、ボクが真っ白になるくらいに射精して\nもらわなくっちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うひひ、逃がさないよ？　逃げられるなんて思ってないよね？　ボクは気持\nちいいことのためなら全力だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だからキミには、ボクと一緒にぶっかけ地獄に付き合ってもらおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0103410" ]},
