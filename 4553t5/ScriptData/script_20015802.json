{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「うう……っ、なんとか、なんとか全員を煙に巻きました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760001" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "4", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「偽情報で誘導したり、実力行使で排除したり、搦め手で落としたり……硬軟\n合わせた対処、お見事でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760001" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「２度とやりたくありません……ていうか、正気に戻った後のルナテミス様の\n叱責が怖い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760002" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ姫様も病に浮かされていたときの対処を罰するということは無いでしょ\nう。多分。きっと。おそらく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760002" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "1", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そこは断言して欲しいものですが……ともかく、隊長はこの先で間違いない\nんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760003" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "4", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ええ。私の鼻がそう告げておりますぞ。匂う……匂いますぞ。ダメな男とそ\nれを甘やかしている人たちの匂いがっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760003" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「嗅覚ってそういうものでしたっけ……えっと、この先は確か、カフェでした\nね。行きましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760004" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0121" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はい、カツマちゃん、あ～ん。ん、いい子いい子。よしよし、怖かったのね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023760001" ]},
		{"command":[ "SETCHARA", "1", "char_00011105_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "8", "CENTER", "400" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「もう大丈夫よ。ここには隊長さんを脅かすものなんてなにもありませんから\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023760001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0","1" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うう……怖かった、怖かったんだ。あいつら、なにも知らない俺を無理矢理\n……っ！！サイレーン曰く、恋の病とか言ってたけど……そんな生やさしいも\nのじゃなかった！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「大丈夫、大丈夫だから安心して。温かいコーヒーでも飲んで落ち着いて、ね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023760002" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……優しさが身に染みる。皆がこんなだったら世界も平和になるのにな\nあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やだカツマちゃんったら。でも、私たちを頼ってくれて嬉しいわ。ふふ、こ\nのままドライブで逃避行でもしちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023760002" ]},
		{"command":[ "SETCHARA", "1", "char_00011105_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "3" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「……これは。あのお二方……２台も恋の病に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうでしょうか。あの方たちは戦う超ロボット生命体でありますからな。一\n般的な病気とは無縁でしょうし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、甘いチョコもあるわよ。お仕事の疲れをこれで癒やしてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023760003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんが望むなら、いつまでもここにいてもいいからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023760003" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0","1" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺……ここの子になりたい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あの甘やかしはいつものような気もしますし、なんだか過剰な気もします…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760006" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "0", "CENTER", "-400" ]},		
		{"command":[ "SETCHARA", "1", "char_00000902_01", "0", "CENTER", "400" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「人間のウィルスは無効でしょうけれど、コンピューターウィルスとかありま\nすからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760005" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "1", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「サイレーンさんの言うとおり、恋の病が普通の病気であれば問題ないでしょ\nうけど、恋という概念が広まっているのであれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760007" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "-400" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ありえますな。ＥＤＯにはそういった、概念を基として術理を構築するお方\nもおられますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760006" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "0", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「概念を基にした病が……という可能性もあるでしょうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760007" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "1", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「むう……考えていても仕方ありませんね。グズグズしていると罹患者がここ\nを調べに来るでしょうし、隊長の保護を優先しましょう。ジュンジローさん、\n手伝ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760008" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "-400" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「了解ですぞ。全く世話の焼けるご主人です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023760008" ]},
		{"command":[ "SETCHARA", "1", "char_00000902_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "PLAYBGM", "M17" ]},
		{"command":[ "SETTEXT", "「隊長！！　こちらに来てください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760009" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},	
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひいいいいっ！！　ソレイユ、お前もか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ！？　ち、違います！！　私は隊長を保護しようと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760010" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつらと一緒じゃねえか！！　助けて！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0","1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「任せて、カツマちゃん！！　あなたは私が守護るわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023760004" ]},
		{"command":[ "SETCHARA", "1", "char_00011105_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんを虐める人は許さない！！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023760004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「話を聞いてぇぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023760011" ]},		
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},	
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}