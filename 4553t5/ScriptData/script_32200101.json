{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あ……その、それでは……そちらに横になっていただけるでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あまり……ご奉仕ということに、慣れている訳ではありませんので、喜んで\nいただけるのか……分かりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私の……その胸……お、おっぱいをお望みということですので……あの、パ\nイズリを……させて、いただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい、一応は……存じています。ほとんど経験はありませんが……頑張って\n……みますので……あの、失礼致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00022001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……ペニスが……こんなに大きくなさって……えっ、違う……\n？　あの、何が……でしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そんな上品な呼び方ではないと……それでは、その……チ、チンポ……！？\n　あ……ぅっ、は、はい……分かり、ました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「では、改めまして……チンポ……オ、オチンポでよいですか？　私のおっぱ\nいで……ご奉仕させていただきますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ……すごい……こんなに熱くされて……くすっ……とても、逞しいオチ\nンポですわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「谷間の中で……とくんと脈打って……あぁ、小刻みに震えています……んっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「すみません、私ったら思わず気を取られてしまって……おっぱい、動かして\n参りますね……んっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……あぁ、まず……このような感じで……いかがでしょうか…\n…はっ、んふぁっ、あっ、ふっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「上下に……ゆっくりとオ、チンポを扱いて……気持ちよく……なっていただ\nこうかと……んっ、もう少し強い方がよろしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「承知しました……では、もう少し力を込めて……ぎゅっと……オチンポを挟\nんで……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そのまま、はぁっ、んっ……こうしてっ、谷間で擦ります……うんっ、んふ\nっ、んくっ、んくんっ、あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ大きくなっていきます……中からこぼれだしてしまいそうな位\nに……しっかり捕まえてあげないと……んしょっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふふ……ダメですよ、ちゃんと挟んであげますから……オチンポ、逃げない\nでくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……もう少し滑りやすい方がいいみたいですね……待って下さ\nい……んっ、えろ……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私の唾液で汚いかもしれませんが……そんなことないですか？　よかった、\nありがとうございます……これで、滑りやすくなると思いますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ……んんっ、あっ、くちゅくちゅして……ずっと、ヌルって動\nきやすくなりましたね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……おっぱいが潰れて……は、はしたない形を見せてしまって\nいます……あぁ、垂れてみっともない所をお見せしているかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「き、綺麗なんてそんな……んふっ、でも、ありがとうございます……もうお\nばさんのおっぱいですけど……感じて貰えるのは少し、嬉しいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふっ、あはっ、はっ、んんっ……あぁっ、んっく……あふっ、うんっ……\nんふっ……はっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「オチンポ、ぴくぴくしています……この、くびれている場所……とっても敏\n感なんですね……ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「分かりました。もっと集中的にやらせていただきますね……んんっ、あっ、\nこうして……いっぱいに挟み込んで……あぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「この感覚……あぁ……オチンポを近くに感じると……私のおっぱいも、だん\nだん熱くなってしまっています……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……や、やだ……そんな乳首が立ってるなんて……仰らないでく\nださい……恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もっと、おっぱい……押し付けますね……んんっ、あぁ……熱いです……く\nぅん……めり込むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ、こんなに動かして……自分じゃないみたいな……こんな……あっ、は\nぁっ、あぁっ、んくぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「オチンポの皮が……何度も行ったり来たりしているところ……すごくいやら\nしくて……はぁ……あぁ……目が離せません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ……亀頭から、お汁も滲んで来て……はぁぁ……これは……\nあっ、もうすぐ射精したくなっているんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「分かっています……んっ、このまま、射精されるまで……一気にさせていた\nだきますわ……はぁっ、あっ、んふぁっ、うんっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「縦だけじゃなくて……横にもスライドさせて……おっぱいの中で……オチン\nポ、揉みくちゃにしてぇ……はぁっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「どうか、我慢なさらないで……そのまま、出してください……私のおっぱい\nの中に……精液っ……沢山中出しなさってっ、はっ、んぁっ、あぁぁぁっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふぁっ！　あぁっ……出て……ますっ……！　んっ、濃い精液っ……びゅ\nくびゅくっ……してます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……あぁ、すごい量……嘘みたい……あの人は、あんなに……あ……\nい、いえ……何でもありませんわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……収まって来ましたね……よかったです、こんなに出して頂いて……\nちゃんと気持ちよくなって頂けたんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふふ……そうですね、最初はもう見様見真似で何とかという感じでしたけど\n……最後は少しコツが掴めたような気がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あ……そ、そうは言いましても、別に使う機会がある訳じゃ……いやだわ、\n私……は、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　あっ……また、おっぱいの中で……オチンポがムズムズし\nてます……んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えっ……掴んだコツを試してみる……い、今から……続けて、ですか……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そ、そうですね……まだ、オチンポもこんなにコチコチのままですし……私\nも、身体が熱いままのようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「このまま、続けてパイズリさせていただきます……はっ、んんっ、あっ、ふ\nぁっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……出していただいた精液が……おっぱいに擦れて……あっ、さっきよ\nりも……ずっとヌルっとしてしまいます……は……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「やだ……私ったら……こんな、あっ、はしたない声が……あ……ふっ、自然\nに……あ、ひぁっ……んっ、くぅっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「違うんです……んっ、これは……わざとではなくて……肌が滑ると、どうし\nても……ひゃふっ、敏感になって……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、くちゅって……あぁ……オチンポの擦れる音ぉ……響いてしまうの\n……あっ、くっ、んふぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んんっ……中で脈打っているのを感じます……私のおっぱい\nに反応して下さっているんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふぅ……お顔もとても気持ちよさそうで可愛い……あぁ、すみません……\n大人の殿方に、相応しくない言葉でしたかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ですが……このオチンポをもっと気持ちよくして差し上げたいと……そんな\n風に感じているのは確かです……んっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もっともっと……私のおっぱいで楽しんでください……あっ、あんっ、はい\n……しこった乳首も……あっ、もっと押し付けてぇ……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁっ、硬くなってる場所……とても、気持ちいいです……あぁ、はい、私\nも一緒に高まっていって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、はぁっ……手が止まらないですっ……おっぱい……こんなに\n、押しつぶしてしまってっ……いやらしくて……はしたないのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……もっとオチンポ扱きますっ……皮を何度も捲り返してっ\n……ぐりぐりっ、剥けてる所に押し付けてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ……また、オチンポがビクビク跳ねていますっ……んんっ、はい……\n後は、また最後まで……いっぱいお扱きしますっ……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私の心を込めたパイズリで……んっ、オチンポの隅々まで……気持ちよくな\nっていただいてっ……はぁっ、んっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「また先端から……ぴゅぴゅっと……勢いよく射精する瞬間を見せてください\nっ……私のおっぱいでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、はぁぁぁぁんっ……震えていますっ……オチンポっ……あと\n、もう少しっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「私もっ……あぁっ、おっぱい感じてっ……はっ、ひぁっ……もうっ、あっ、\n気持ちよすぎてっ……あっ、はぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「きゃうっ……！　あぁっ……中にっ……おっぱいに……またドロドロの精液\n……出て……ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……濃厚です……こってりとして、粘り気も強くて……あぁ……ま\nだ少しずつ出て来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「は、はい……奥に残っている分を搾り出すんですね……ぎゅっと寄せて……\nこう、でしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁっ……また、溢れて来ました……んんっ、おっぱいの中が……あなたの\n精液で満たされてる感じ……あぁ……すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……射精落ち着いて来ました……オチンポがやっと大人\nしくなってくれて……はぁ……あふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……わ、私も軽くイッて……あ、いえ……ほんの少しです……その、何\nでもありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「それにしても……いつも、こんなに出されるんですね……こんな量……初め\nてかも知れません……あっ、その比べるとかではなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「上手だったから……そんな、私なんて全然……でも……喜んで頂けたのでし\nたら一安心です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えっ、また次も……？　そ、それはその困ります……何度もしてしまうよう\nなことでは……ど、どうしても……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「は、はい。もし、また機会があるようでしたら……ですが、このことはくれ\nぐれも内密にお願いします……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁうっ……！　あっ……そんな……顔にっ、あぷっ……いっぱい……出て\n……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……クラクラします……男の人のにおい……あふっ……すごい……ま\nだ出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「まだ、全部出しきれていないんですか……？　分かりました……おっぱい…\n…寄せます……んあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ……！　顔にまだ……ちゅぱっ、ぴちゃ……んんっ……あぁ……ドロド\nロがこんなに……んふぁ……はぁ……あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ、終わりましたか……オチンポ、やっと落ち着いてくれた感じ\nです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅぷ……んっ、あぁ……髪の毛にも……においが染み込んでしまい\nそうです……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「本当に沢山出されて……はい、びっくりしました……これほどまでとは思わ\nなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「心がこもっていたから……も、もう……お上手なんですから……でも、一生\n懸命しましたので、喜んで頂けたなら何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「えっ、また次も……？　そ、それはその困ります……何度もしてしまうよう\nなことでは……ど、どうしても……？」", "NORMAL" ]},
