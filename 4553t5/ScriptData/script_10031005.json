		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なに…？　なんなの？　長官のこのノリ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116010003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……このノリ、わたくし記憶にございますぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……俺もだ。いつぞやのＢＢ隊の件で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はいそこ、うるさい！　ちゃんと説明を聞きなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「説明とは……つまり、なぜか我々の目の前にあるバラエティ番組のセットに\nついて、わかるように説明してくれるということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116010001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0214" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「バラエティの収録ちゃうわ！　これはＥＤＯ大道具部の高度な技術で精密に\n再現された、『ファウンデーション』内部のセットであ～る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ファウンデーション内部だと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116010003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そう！　基地への侵入地点から、目標となる『工房』までを正確に再現して\nある。今からこのセットを使って訓練を行う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『工房』に侵入して爆弾を仕掛け、侵入した場所から再度脱出する！　この\n時間をどこまで短縮できるかが勝負だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なお、爆弾をセットしてから爆発するまでの時間は３０分！　時間内に逃げ\n切れないと、おまえら基地ごとドカンだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「まさか、訓練で爆発したりは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116010003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はっはっは、さすがにこの訓練ではそこまでやらない。そこまでやらないが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やらない『が』……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「失敗するごとにボーナスの査定がどんどん減って行くからな！　覚悟してお\nくように！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「ええええ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116010004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はい、文句言わない！　ボーナスを引かれたくなければ真剣にやる！　とい\nうわけで、訓練開始っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「仕方ねえ……やるか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「行くしかないですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116010004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あ、セットの中には訓練用戦闘ロボットも配置してあるからな～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116010011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
