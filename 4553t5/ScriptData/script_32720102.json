{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0068" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「おっつかっれさ～ん♪　疲れたやろ～？　もうそろそろ、手伝いあがってえ\nえよ。助かったわ。……あ。ちょっと待って。まだこの部屋におって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うん。慣れない温泉宿の仕事で大変やったやろ？　せやからねぎらいとして\n～、うちにも～っとも～っと甘えてもいい権利をあげたいな～、って思て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんさえ良かったら、今からその権利……使ってみぃへん？　うんうん\n、ええんよ～。ほんまのお姉ちゃんやと思って甘えてみて～？　ほれほれ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んふふふふっ♪　今日、いっちばん頑張ったエラい子には特別なご褒美をあ\nげんとねぇ～？　遠慮なんてせんでええんよ。はぁ、はぁ、さてどないしよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そうや♪　サクヤお姉ちゃんの～。いっちばん気持ちいいトコでよしよしし\nたげるわ。いい子～、いい子～ってされたら疲れも吹き飛ぶで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……ん？　何をどうするつもりや、て？　んん～、野暮なコト言わんといて\n。サクヤお姉ちゃんにぜぇ～んぶ任しとき。……ほな、イクで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んふぅううっ♪　ンッ……、ぁっ、ど、どないやぁ……？　トロトロオメコ\nで生マッサージ……、はぁんんっ♪　疲れた身体にキくんちゃう～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あは……♪　仕事の報酬にするにはよすぎる？　そないなこと気にせんでえ\nえの♪　だってこれ、うちも……めっちゃ気持ちええんやもん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんのガチガチ勃起疲れマラ……、はぁ、はぁ、実はさっきからず～っ\nと狙っててん……♪　今やったら抵抗するのもダルいやろ～って、フフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちはねぇ、欲しいモンは手に入れる悪女、ワル～いおキツネお姉ちゃんや\nから♪　シたいことしかせぇへんの。だから……ええんよぉ♪　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「な？　二人で一緒に気持ちくなろ～や～♪　んぅっ♪　フフフフ、せっかく\nの生挿入、生騎乗位なんやし……サービスするよぉ？　具体的にはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……んんんっ！　こう、やってぇ♪　サクヤお姉ちゃんがぁ自分で腰を振っ\nたげるんよ♪　あんっ、あんっ♪　これ、めっちゃ楽やろぉ～？　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちも自分のペースで動けるしぃ、悪いこといっこもあらへんよねぇ♪　…\n…っあっ♪　あっ♪　あっ、激しくなりすぎてしもたらゴメンなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ンッ♪　あっ♪　ぁっあッ♪　んふぅうう～♪　クるわぁ～～～～♪　なあ\n～♪　なんでこんなスゴいオチンポ持っとるん～？　たまらんわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「長くてぇ……いっちゃん奥に突き刺さってくんの♪　んでもって……あぁん\nっ♪　ンッ、太くてオメコむちゃくちゃ広がっとるしぃ、硬すぎぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「こんなん、もはやオチンポやなくて……あっ♪　女殺しの凶器やで♪　コワ\nイわぁ、ほんま～♪　っあっぁっあっ♪　見てや、腰が止められへん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ♪　んぁあっ、あんっ♪　最ッ高やぁ……♪　あっ♪　あっ\nぁっ♪　カリがエグいくらいにくびれとってぇ♪　……んああっああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちの弱いところ、ぐりぐりえぐってくるんよぉおお♪　あんっ、もっと♪\n　もっとちょ～だいってなるぅ♪　一生えぐり倒しといてほしいわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ッあぁ♪　あぁんっ、んぁああっ♪　ヤバいわぁあ♪　おキツネの耳も、尻\n尾も嬉しすぎてピクピクしてもうてるぅ♪　あっぁっあっ♪　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちまでオチンポさんが甘やかしてくれるからぁ、す～っごい、すっごい気\n持ちええわぁあ♪　あっ♪　あっぁっあっ♪　……んん？　どしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あは～っ♪　されとるだけやなくて、自分の方でも腰振ってみたくなったん\n？　あんっ♪　ええよ～♪　好きなだけ腰振って！　歓迎するわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……んんっ♪　二人で交互にピストンするの、気持ちええねぇ～っ♪　んぁ\nんんっ♪　腰が浮くわぁ♪　あっ、ぁっ、オメコにむっちゃ響くぅんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんは、ホンマのホンマにええ子やねぇ～♪　エッチも上手、仕事も上\n手……。サクヤお姉ちゃん、本気で惚れてまいそうや♪　っあっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んね～え？　ず～っとここにおってぇ♪　毎日サクヤお姉ちゃんとぉ♪　お\n仕事して、エッチして、楽しく二人で生きていこうやぁ～♪　っんっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「もううち～、隊長さんのオチンポ無しじゃ生きていかれんわ♪　隊長さんや\nって、悪い気ぃはせんやろ？　うちのオメコと相性ええもんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あっ♪　んふふふふっ♪　オチンポがガチガチになって、うちのオメコを突\nき上げながら返事してくれてるわ♪　一生甘やかしてあげるよぉ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「せやから♪　今は隊長さんと♪　隊長さんのオチンポにラブラブなご褒美、\nご奉仕しまくってぇ、うちとうちのオメコの虜にせんとあかんよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……そぉれ♪　それっ、そぉれ♪　んふふふふ♪　具合のええ、よ～く締ま\nるキツキツオメコの味はどうやぁ♪　あっ♪　下品？　ええやない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ここにおるのは二匹のケダモノだけやもの♪　んはぁんんっ♪　それにぃ、\nうちだけやないでしょお？　あっ♪　こんだけオチンポ太くしといて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ブイブイ言わしとるくせにぃ♪　……んんぁッ！？　いややぁ♪　ま～た硬\nくなったぁ♪　んぁッ♪　あぁっ♪　とんでもないバケモノオチンポやね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「サクヤお姉ちゃん、コレが好きで好きでたまらんくなってきた♪　……あん\nっ♪　あんっ♪　もっと突いて♪　隊長さんのオチンポでぇ、うちをぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「だらしのない、エッロいキツネのお姉ちゃんにしてなぁ♪　あぁっ♪　あん\nっ♪　あん、あん、あんっ♪　リズムも合うし、カラダも合うやぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「なぁ……♪　もうそろそろ、最強のオチンポも限界が近いんとちゃう？　…\n…っあっ♪　うちの中に……サクヤお姉ちゃんの中に全部出してや♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「中出し♪　してくれへんとスネるでぇ♪　っ、な？　なぁっ？　中に出して\n♪　サクヤお姉ちゃんのドスケベオメコにザーメンびゅっびゅしてぇなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「精子♪　注いで欲しいねん♪　ちょ～だいっ♪　うちも絞り上げるから♪　\nうちのオメコに、いっちばん濃ゆいザーメンびゅるびゅる出してぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「は、ぁっ♪　はぁあああああぁんんんっ♪　ええよっ、最高やぁああっ♪　\nあぅううっ♪　あふぅうううっ♪　これが隊長さんのザーメンなん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「めっちゃめちゃ凝縮された、濃ゆぅうううい精子やねぇっ♪　うち、これ好\nきや♪　好きすぎるぅっ、もっと出してぇな♪　まだ足りん、出してぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あああっ！　んあっ、あああああっ！　あっぁっあ～っ♪　情けない声♪　\n出てしまうぅ♪　あっあっ、トロけ声聞かせてまうぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ザーメン♪　ザーメン美味しいわぁ♪　大好きやぁ、これぇえっ♪　あっつ\nくて、ドロッドロで……！　良すぎてカラダの震えが止まらんもんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んはぁっ♪　あはっ……んぁああっ♪　ちゃんと絞れてる？　うち、気持ち\n良すぎて、うまいことできとる自信ないわぁ……♪　っあぁあんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……はぁああ……っ♪　ああああぁ……♪　ありがとうねぇ～……♪　いっ\nぱいいっぱい、中に出してくれてぇ……。良かったよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ちゃ～んとうちに……サクヤお姉ちゃんに甘えられた？　仕事の疲れは取れ\nたかな～？　……って、あらっ♪　なんやのぉ？　コレ……。あぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんのオチンポ♪　全然萎えてへんのやけど？　あらあらあら？　もし\nかして、射精して即フル勃起してもうたん？　うちの中で？　ま～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……それやったら、このままオメコから抜いて放置すんのはイケズやね？　\nまだまだ甘えたりへんらしいから、続けてもええ？　ええよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　うちも、もっと隊長さんとシたかってん♪　せやからウィンウィ\nンということで……再開や♪　あぁっ、どんどんハメてくよぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はぁ～っ♪　はぁああっ♪　んっ！　ンンッ、ん～っ♪　んんっ……♪　そ\nうなん？　気持ちええの？　自分のザーメンでドロドロになったオメコ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのオメコで、射精したばっかの敏感オチンポぐちゅぐちゅされるの\n、えっらいキくやろぉ？　もう、ハメハメのことしか考えられんよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ええの♪　ええんよ♪　オチンポだけに集中しぃ♪　そんで……、あっ♪　\nあっ、あっ♪　うちのオメコでこすり倒すことだけを考えとったらええの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「今はうちとのエッチのことだけ……♪　っんんっ♪　んふふふっ♪　スゴい\nねぇ♪　出したばっかやのに、こんっなに♪　激しく突いてきて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁ、うちも負けてられへん♪　攻めまくるで♪　……んんっ！　\nンッ♪　んっ、んんっ……んんっ、どうやぁ♪　なかなか、やろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「隊長さんのオチンポの形に合わせて……んぅっ♪　オメコの中、動かしてる\nんよ……♪　あはははっ、ウニョウニョ動いてすっごくええやろぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「こういう便利なオメコを、名器って言うんやで……♪　っあっ♪　それを言\nったら隊長さんのオチンポの方が超♪　名器かもしれんけどねぇ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「だってぇ♪　うち、もうず～っとイキそうなんよ♪　イカされてしまいそう\nなんっ♪　……あぁっ♪　ねぇ……甘えてええよって言っといてアレやけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちもっ♪　うちもイッてええよねぇ？　あっ♪　イッた方がぁ♪　オメコ\n、ギッチギチに締まるかもしれへんもん♪　イかせてもらうねぇ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あ、ああああああっ……♪　イクイクイクッ♪　超名器オチンポにイカされ\nてはしたなくイクッ♪　んっ、あああああっ、めっちゃええわ、何コレぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「イッてもイッても余韻が抜けへんんっ♪　あぅんんっ♪　サクヤお姉ちゃん\nをどないするつもりぃい♪　あぁっ♪　あぁ、まだイケそうやぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「まったく楽しませてくれるオチンポやわぁ♪　あーっ♪　あぁんんっ♪　あ\nんっ、はぁんんっ♪　あっ、一つ、名案があるんやけどぉ……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「このままっ♪　一緒に……同時に果てるっていうのはどぉや？　うちも後何\n回かイッてまいそうやし♪　イキたい時にそのままイッてくれたらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ぜ～ったい一緒にイケるから……お願いなぁ♪　っあっ……♪　ゆーて、そ\nないに時間かからんみたいやね♪　イキそうなん？　もう出したいぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ええよっ♪　おいで、おいでぇ♪　サクヤお姉ちゃんのドスケベオメコに中\n出しして♪　ヒトの子ぉ孕ませて♪　お願いや、来て♪　きてぇえ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はぁうううううんんっ♪　イキのええのがも一度キタわぁあああっ♪　ええ\nよ、すごくええっ！　うちもイクっ、またイクわ、イッくっ……！　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ビューッ、ビューッて噴水みたいに打ち上がっとるぅううっ♪　こないに元\n気のいいザーメンなんて普通無いやろぉ♪　隊長さんスゴいわぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちっ、うち……気持ちええ♪　またイクぅ……、イクわぁ♪　あっ、ああ\nあああっ……イクイクイクッ♪　無限にイクッ♪　奥でイクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あっ、ぅうううっ♪　オメコ、壊れてもうた♪　もうイクの止められへん♪\n　オチンポ絞るのやめられへんんっ♪　あ～っ♪　あっぁっあぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「子宮に精子上がってきとる♪　あはぁああっ♪　あああっ♪　受精確定やわ\nっ……！　はぁっ、ああああ、オメコ熱い、切ないぃいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「もう全部出たっ？　まだ残ってるやろ！　ほら……っ、ほら、絞るで……！\n　んんんんっ、んんんんんっ、ごちそうさまぁああっ♪　イクぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……ふーっ♪　気っ持ち良かったぁあああ～……♪　あは……♪　隊長さん\nも、えらいスッキリできたみたいやない……♪　良かったぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「途中から、もう、うちばっかりタガが外れてしもて……。一方的にイキまく\nってもうたって、ちーっと反省しとったんよ♪　でもこれならええよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「がっかりさせへんで済んで、うちも嬉しいわぁ。はー♪　まだ、快感が尾を\n引いとるぅ……。甘えてくれてありがとねぇ～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「これからも、いつでもうちが隊長さんを癒して、甘えさせて、依存させたる\nから……。好きな時に呼びつけてぇな♪　頼んだでぇ、ホンマ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ああっ！？　ど、どないしたん！？　オチンポ、オメコから抜けてもうて…\n…んぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あ、あかんよぉお♪　中出しする予定やったザーメンっ♪　うちの精子♪　\n受精用の大事な精子が身体にかかっとるっ……♪　もったいないっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「それなのになんでやろ……、あっ♪　気持ち良さそうに射精しとる隊長さん\nと、ビクビク脈打っとるオチンポ見てたら……なんか許せてしまうわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そうなん♪　うちにぶっかけたいん♪　……せやったら仕方ないわなぁ♪　\nええよ……かけてぇな♪　あっついのかけられながら、イクの見ててな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ッああああああっ♪　んああああああっ……！　イクぅっ♪　イクッ、くっ\nさいザーメンかけられてイクぅっ……！　あ～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あはっ♪　そないに飛距離が出るなんて……うちのオメコでいっぱい感じて\nくれて嬉しいわぁ♪　もっと、もっとぉ♪　もっとかけてぇなぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　なるほどなぁ……。一発目は中に出したから、二発目は外に\n出す……。そしたら、中も外も、どっちも楽しめてお得っちゅうことかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うん、うん♪　うちも生粋の商売人やからね……。お得なコトは好きなんよ\n♪　それに、コレはお仕事のご褒美や。うちに隊長さんが甘えるワケや」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「そしたら……。中でも外でも、隊長さんが好きなよーに、したいよーにする\nのが一番や……。でも、まあ……そやねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちは、二回連続で中出しでも良かってんよ？　儲けを度外視してでも、欲\nしいくらいにな……♪　今度する時は、期待しとるから覚えといてなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_0104410" ]},
		{"command":[ "SETIMAGE", "0", "still_00027201_02_15" ]},
		{"command":[ "WAITINPUT" ]},
