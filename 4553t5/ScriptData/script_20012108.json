		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「もう少し、骨があると思っていたが……他愛もない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……なんなのこの人達。強い、強すぎるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「貫禄がありすぎるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お褒めにあずかり光栄だが、……両手を上げて喜んでいるわけにもいくまい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「話してもらうぞ。貴様らの目的、洗いざらいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ギロリと怪人達を睨みつける冴島長官は、見ている俺まで震えあがらせるほど\n冷徹だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゃきちゃき吐いてもらえへんのでしたら……もう二、三発重い拳を叩きこ\nんでやりましょか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ひぃいいい！　勘弁を！　もう無理です、これ以上は死んじゃいますううう\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……なら、早く話してください。私達はそう、気が長い方ではありませんよ\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「も……目的はわからない……んです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁ！？　ンなわけねぇだろうが！　こんな派手にやっといて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「わ、私達……。いわゆるちゃんとした怪人、戦闘員というわけではなくてで\nすね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「派遣！　そう、派遣で雇われているだけなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「昼間に軽く稼げる、お得なバイトがあるって誘われて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「最近ヒマだし、友達もみんな忙しいって言うし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「育児の合間に、ほんのちょっぴり危険な遊びを……ということで、リビドー\nクロスを解き放ってしまっただけなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なるほど……。主婦にも色々あるんだな……って、えええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「人妻！？　結婚しているだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021730004" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでそっちに驚くんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　そればかりは聞いてはダメですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「夫に隠れてそんなハレンチな服を着て……人々に迷惑をかけているなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「欲求不満なんじゃねーのか？　にしても、他人で発散するのは許せねぇな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ゴキゴキと首を鳴らして威嚇するほむらに、心底恐怖したのだろうか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ふえぇええええん！　こんな話聞いてないですよぉおお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「一人でなんとか出来るわけないじゃない、相手が悪いです～！　悪すぎます\nう～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021730002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "びえええええ、と人目も気にせず号泣する怪人ハチ乙女だったが、それで解放\nされるわけがない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それで……ハチ乙女さん。あなたも人妻なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021730001" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからそれはどうでもいいだろが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "二人" ]},
		{"command":[ "SETTEXT", "「どうでもよくないッッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021730004" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00005003_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぇえっ！　なんでだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "二人" ]},
		{"command":[ "SETTEXT", "「むしろそこが一番大事ッッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00004904_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、女の食いつくポイントがわからねぇえええ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「女心の闇というやつですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前にわかるのは犬心だけだろーがっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だっ、旦那との出会いはなんだったんだ？　職場か？　怪人同士なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021730005" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それとも道端で偶然ぶつかって？　詳しく順序だてて初めから話してくださ\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021730004" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「この人達、すっごく顔が怖いよぉおおお～！　びえええええ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ついにうずくまり、メソメソしだしたハチ乙女になおも追いすがるほむらと氷\n華。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「全部吐くまで帰さねえからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_040021730006" ]},
		{"command":[ "SETCHARA", "0", "char_00003404_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ。多少乱暴な手を使っても……知らなければなりません。その情報だけ\nは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_030021730005" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハチ乙女" ]},
		{"command":[ "SETTEXT", "「ええええええん、何なのこの任務～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_010021730004" ]},
		{"command":[ "SETCHARA", "0", "char_00021901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まあまあまあ。ご両人、ここは僕に任せてくださいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021730002" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「鳳雛？　まさか、お前初めて役に立つのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふっふっ、もちろんです。尋問は探偵の得意分野ですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021730003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……信じてたぞ。やっとそれらしい仕事をしてくれるのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ご主人ご主人。鳳雛さんへの不信がだだ漏れですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020021730003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "感動にうち震える俺、そしてその信頼に今、応えようとキメポーズを取る鳳雛\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「フフフ、出でよ！　探偵七つ道具……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021730004" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？" ]},
		{"command":[ "SETTEXT", "「ふう……。やはり、だめでしたか」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "美鈴" ]},
		{"command":[ "SETTEXT", "「お前は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040021730006" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にか、足音もたてずにそこに現れていたのは……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スパに来るまでの道中、マイクロバスを運転していた運転手だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「まさか、あなたが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_030021730004" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あ、あれ？　いいんですか？　僕の見せ場を見なくって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021730005" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もうその必要はなさそうだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そんなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_030021730006" ]},
