{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「いきなり呼び出して……どうしたの？　わたし、もうおねむなの……。お話\nは明日でいい……？　だめ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00024501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うん。一人で寝るよ？　今日はエスティマおねえちゃんがいないから……。\nなあに？　かわりにあなたが一緒に寝てくれるの？　……ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「それなら……ここで寝る。えっ？　だっこしながらぎゅーして、くっついて\n寝る……？　わぁ……！　いい！　それするっ……してほしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うん。お洋服を脱いだ方がいいの？　裸でぴったりくっついて……。そうす\nると、いっぱいいっぱい気持ち良くなれる？　そうなんだ……。えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ほんとだ。すっごくあったかい……。たくさんうれしくて、幸せ。でも\n……。ど、どうしてだろ。ドキドキが止まらないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あの、ね……。身体がぽかぽかするの。えっち……な気分になってきちゃっ\nた。それでも、もっとくっついていてもいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「えっちな女の子は、嫌いにならない？　……あなたもえっちなの？　えへへ\n……それならよかった。同じ気持ちなら、甘えてもいいよね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んっ……もっと……もっと近くにきて……。そう、身体と身体がこすれあう\nくらい……。っはぁっ……安心する……。いいにおい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「え？　ヘンなにおいなんてしないよ。とっても落ち着くにおい。エスティマ\nおねえちゃんとはちがうけど……おねえちゃんにはこんな風にならないもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「できるだけ、おにくとおにくをくっつけあわせて……こすって、すりすりし\nて……１つになっちゃいたい。こんな気持ちはあなたにだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んっ……。ちゅっ……ちゅっ……。キス、いやじゃない？　わたしがおっぱ\nいくっつけて……甘えてくるの、いやじゃない？　えへへへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だったらもーっとしたい……。んっ……数えきれないくらいチューしながら\n……。ちゅっ……足を絡めて、密着して……いちゃいちゃしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぷに、ぷにっておっぱい押し付けても、ちっちゃいからつまらない？　……\nすべすべしてて気持ちいい？　あったかい？　だったら良かったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もっと押し付けるの？　んっ……押し付けて、左右に……上下に動かして…\n…？　はぁっ……はぁ、どうしよう。身体が熱くてたまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はだかんぼでだっこされて、わたしもぎゅってして……。恥ずかしいのに止\nめられない……。ねえ、もっと……もっときて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちゅ……ちゅ、ちゅ……ちゅ……。あむ……♪　呼吸、できなくなってもい\nいから……舌出して？　キス……キスしたい……。ちゅ……ちゅ、ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「くちゅ……ちゅぷ、ぷちゅ……ちゅ……はぁああ……♪　ん？　キスよりも\nもっと親密になれる方法があるの？　だったら、わたし……それする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「早く教えて……。ちゅっ……。……あっ？　お、お尻……？　わたしのお尻\n、触ってる？　う、ん……？　いいよ。少しくらい強くしてもだいじょうぶ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぐにぐにって揉んで……。はぁっ……はぁ、はぁ、はぁ……。きもちいい…\n…。それで？　それで、次はなにをするの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？　あっ……おっぱい、揉んで……それで？　きゃんっ！　お\n口で吸うの？　舐めて……！？　あっ……あっ、あっ、わっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だ、め……それ、ピリピリするぅ……。お胸のさきっちょがピクピクして、\nむずがゆくて……おまた、おまたがウズウズするよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……ぁっ、う……うぅ……。あ、あのね……？　こんなこと言うのだめ\nかもしれないけど……えっちしたい。だめ？　してくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたし……あなたと、ひとつになりたい。はぁ、はぁっ……手とか口で触れ\n合うのもいいけど、もっと深いところで繋がり合いたい……。おねがい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……あっ♪　あっ、い、いいのっ……？　いいの？　おちんちん、入れてく\nれるの……？　わぁああ……♪　うれしい、うれしい……いれて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「う、ん……♪　あは……♪　おなかにあっついのが入って……。みたされて\nく……。そうなの、わたし……ほんとはえっちがしたかったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんをここにいれて、一番仲良くしてほしくて……っ。いちゃいちゃ\n、したくて……。ムズムズしてた……。だから、ありがとう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……あんっ……！　えへへ……♪　あなたもしたかった？　わたしのお腹の\n中で、おちんちん……喜んでる。うん、わたしにはわかるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「このまま……動かして、一緒ににゅるにゅるしよ……？　悪いことじゃない\nよね、だいすきな二人が協力してえっちするんだもん……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぜったい、いいことだよ……。ね……本気のえっち、して……？　揺らして\n、動かして……？　っふぅうっ♪　そうっ……そう、そうやって……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしをきもちよくして……♪　っあぁあああ……♪　すっごく奥まで突き\n刺さってるよ……♪　あなたの、元気いっぱいでかっこいいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ズンッ、ズンッ、てして……♪　……あ♪　あふ、んっふ……っ♪　しゅ…\n…しゅごい、ホントに強……い♪　ずぶっずぶって当たってる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うん♪　うんっ……いいよっ、いい……イイのっ……♪　ユサユサされると\n……。はうっ……♪　あ、ぅ……ずぶぅって刺さって気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あぅっ……うぅっ……！　止めないで……っ、やめちゃやだ、あっ、ぁっあ\nっ……あうっ♪　うぅっ、うぅんっ、ん～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしとあなたの一番きもちいいところ……。ぐちゅぐちゅ混ぜ合って、１\nつになりたい……！　ひとつ、に……ひとつに……あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇっ……！　おちんちん、中でどんどん硬くおっきくなってきたよ…\n…？　きもちいい？　これっ……きもちいいってこと……？　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うん♪　うん、わたしの胸も硬くなってる、おそろいっ……。あっあっ、ぐ\nちゃぐちゃに混ざりあうの、気持ちいい……！　気持ちいいよぉおお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あ……れ？　びゅるっ、びゅるってお腹の中に何か入ってくる……のぼって\nくるよぉ？　あれっ……あれ？　なあに？　なあにこれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんがビクビクして、そのたびにドクッ、ドクッてあったかいのがひ\nろがってく……。んっ……もしかして、あなた……。んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしの中でおしっこした？　でも、おしっこじゃない……。もっとべった\nりしてて……。ふぁ……♪　水っぽくなくて……んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「お腹の中が……奥がゾクゾクする！　これっ……これ、もしかしておなかに\n入れたらいけないもの？　だったらどうして入れるの……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……せいし？　精子って……ええと。うん、聞いたことがある。タンパク質\nで……おしっこじゃなくて、男の人から出るお汁だよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「女の子とこうしてて、せいしが出るのは普通のこと？　そ……そうなの？　\nじゃあ病気とか、おかしいことじゃないんだ……。だったらよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「２人でえっちして、きもちよくなったら自動で出る……。身体には悪い影響\nはなくて、むしろ出すと健康にいいの？　これ……良いお汁なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、たくさん出していいよ。わたしのお腹の中に出すから驚いちゃった\nけど……毒とかクスリとかじゃない、当たり前のお汁ならだいじょうぶ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん……もっと出せそうだったら、出していいよ？　手伝ってあげる……。う\nん、いっぱいくっついて、腰を振って、気持ち良くすればいいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ぁ……、んっ……！　んっ、ふ……ふぅっ♪　良いお汁……ドクドクお\n汁、出るように……おちんちん、大事に大事に動かすね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ、はぁっ、あっあっあっ……！　な、なんだか、さっきよりヌ\nルヌルして上手に出来てる気がする……ぅ、すごく動きやすいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ふぅうう……♪　は、ぁ……っ、あぁっ……あーっ……♪　ふふ……♪\n　わたしが気持ち良くなると、あなたも気持ちよさそうになるね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んっ、１つになってると……１個の気持ちいいを、２人ではんぶんこできて\nすっごく楽しい……っ。あ♪　んん♪　なあに？　はんぶんこじゃなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「２倍も３倍も気持ちいい？　そ……そうかもぉ、２人でどちゅどちゅしてる\nと、クラクラするくらい気持ちいい……！　何倍もすごい、すごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁあああ……っ。あなたにも伝わってる？　わたし、わたし今とっても感\nじてるよ……！　あっ♪　おまたのヌルヌルが溢れ出してきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あなた、のおちんちんを濡らしてる……っ。びちょびちょになっちゃって、\nきゅーっきゅーっておまたが何度もキツくなって……ふぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「えっち……！　えっちするの好き……！　おねがい、わたしに気持ちいいお\n顔見せて……！　ふぁ……♪　わたしも見せるから……ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「いっしょに……！　いっしょがいい……っ！　一緒にグチュグチュするの、\nズプズプするのぉ！　あなたと一緒に気持ち良くなるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふ、ぅうう♪　ふぅううう～～～～♪　さっきから……ビクンビクンってな\nるのが止められないよぉ！　ずーっと身体がビクビクしてるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「お汁ぅ……！　えっちなお汁、溜まってきた……？　あぁっ♪　わたしの中\nに出したくなってきた……？　はぁ、はぁ、はぁ……いいよ、いつでもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「いつでも出していいよぉ……！　わたしも……わたしも一緒にすっきりした\nい！　一番気持ちよくなって、ぜんぶ、ぜんぶ解き放ちたいの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……！　あっ、だめ……っ！　だめ、だめ、だめ……！　膝が……脚が\nガクガクしちゃって、も……動けない……ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃん……おにいちゃんっ、わたしの中に出すなら……はやくぅ！　\nじゃないと……じゃないとわたし、おかしくなっちゃうよぉお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……あっ、やぁっ、あぁあ……！　い、嫌じゃないよ、やぁなのっ！　\nイッちゃうの……！　イッちゃう！　一緒にイこうっ、一緒がいいよぉお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んん！　んふっ……ふ、ぅ……！　うぅ……！　ぶびゅぶびゅ……！　どっ\nくんどっくん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「せいし……すっごく出てる……出てるよぉ……。うん、うんっ……止めなく\nて、いいよ……。わたしの中、まだ入るから……奥で出して……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「びゅくびゅく、どぷどぷ……。ふぁああ……♪　二回目でも、やっぱり不思\n議……。誰かのお汁が、わたしの中であばれてるなんて……。んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「きもち、いい……？　おにいちゃん……わたしの中、好き……？　たくさん\nせいし出ちゃう？　……いいよ……いいよ、ぜんぶほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ぁっ……♪　んんぁ……あぁ……！　いきどまり、にたくさん溜まって\n……。身体の内側からあたたまってきたよ……。しあわせ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……えへへ。これだけ出したら、もうすっからかん……。からっぽで、何週\n間かはエッチできないね？　……え？　そうでもない、の？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「１日くらいで……。もしかしたら、数時間くらい、数十分くらいで回復しち\nゃうかも？　ふぁああ……すごい……男の人ってかっこいいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だって、わたしは……こんなにえっちしたら、フラフラだよ……。これ以上\nお腹に精子も入れられないし……。見て、お腹がぽっこり膨らんでる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「汗もかいたし、まだ身体中がしびれてるし……。……わたしは戦いは強くっ\nても、えっちではあなたに負けっぱなし。でも、どうしてかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「それがちょっと嬉しいの。あなたが強くて、かっこよくて……どきどきする\n。えっちして良かった。新しいあなたのこと、わかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あれ……？　お腹の中に出さなくていいの……？　んッ……？　せいし……\nわたしの身体にかかってるよぉ……？　っあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「無駄に……むだになっちゃう、今からでもわたしのお腹にいれて……ぇ。っ\nえ……？　いいの？　外に出したいの？　そうなの……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だったら……うぅんっ、い……いいよ……。あっ♪　せいし……精子わたし\nにかけていいよ、あなたがいちばん気持ちいいのでいい……いいの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あうっ……んん……！　きゃ……、んっ、あぁ……！　真っ白な……せいし\n、精子がわたしのお腹に、胸に……ベタベタこびりついてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あふ……！　んふっ……うぅ……。全部、出た……？　うん、わたしはなん\nともないよ……。ただ、ドロドロが身体についててネチョネチョするだけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024501_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「でも、あなたはほんとにこれで良かったの……？　精子にまみれたわたしが\n見たかった？　そうなんだ……。こんな姿を目に焼き付けたかったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「自分のお汁まみれになったわたしを見ると、自分のものにできたって気持ち\nになるの？　……ふぅん……。だったらわたしも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぴゅっぴゅってお汁を出せたら、あなたにかけてみたかったなぁ。そうした\nら２人でべとべとのドロドロのぐちゅぐちゅだよ。ふふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん……。精子の臭い、すっごいね。これ……ぜんぶ手で塗り広げたらスゴそ\nう……。どう……？　そういうの、見てみたい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んしょ……んしょ、こうかな……？　あっ！　手がべたべたになっちゃった\n……。一緒にお風呂に入って、洗ってくれる？　おにいちゃん……」", "NORMAL" ]},
