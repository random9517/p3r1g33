{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "……そして、数日後。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はぁあ～。まったりとしたこの時間……心が落ち着きますなぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "カフェの特等席に案内され、エルフたちの働きぶりを観察していた俺に１つの\n結論が出た。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし。わかったぞ。みんな集まってくれ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はいで～す☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370001" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ちょうど、他のお客様もいない時間帯ですし……問題ありませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370001" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それで……おわかりになったんですか？　私たちの能力というものが……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370001" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。まずはアイナリンド」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「は、はいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370002" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「雰囲気が優しくて、相手のことをよく見ているアイナリンドにはカフェの受\n付が向いていると思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ、それはいーかも！　アイナ先輩の雰囲気ってふんわりしてて癒されま\nすもんね～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370002" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうことだ。最初に客と会うやつが、怖い顔をしているのはよくない。\nんでもって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「次はディーネリンド」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370002" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前はこの中で、一番面倒見が良いし……他の仲間に信頼され、頼られてい\nる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここにいるポンコツエルフたちをまとめあげ、接客を教えられるのはお前だ\nけだと思うんだが、どうだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「確かに、ディーネリンドさんは皆を率いて戦うのが得意ですもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370003" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よって、お前には店長代理として、このカフェをうまいこと導いてもらいた\nい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……私が店長代理ですか。それは悪くない提案ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370003" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ディーネ先輩がトップにいてくれたら、安心です！　私もそれでいいと思い\nま～す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370003" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかそうか。んでもって、最後にラヴリエータだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はいはいっ。どんなお仕事でも頑張りますよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が滞在しているこの数日間、メシを持ってきてくれたのはお前だったよな\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「う、うん。私、一番新入りだしね。……でも、それがどうかした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370005" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺に食事を渡す時にな、ちょこちょこ素材をアレンジして出してくれてただ\nろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「どういうことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370004" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「たとえば、なんてことない乾パンに、少し手を加えて彩りを良くしたりだな\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「塗るジャムを工夫して飽きないようにしたり、ちょこっとオマケに果実をつ\nけたりしてただろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、意外によく見てますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「う、うん。私もびっくりした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370006" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「だけど……そっか。気付いてくれてたんだ。……そっかぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370007" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よってお前には調理関係を担当してほしい。細やかな気配りを期待している\nぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「うんっ！　ご主人様が言うなら従うよ！　頑張る！　オッケー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370008" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……んでもって、集客についてだが。俺には女のカフェ好きの気持ちはまっ\nたくわからないが……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「スケベな男達の気持ちはわかる！　と、いう事でこういう方向性はどうだ？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "この騎士団のエルフたちの中には、自然にあるものから衣服を作り出せる者た\nちもいるらしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そんな話を聞いていた俺は、もちろん、それを利用するつもりになっていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「彼女達に協力してもらって、二着……服を作ってもらいたい」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「服を……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370004" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それを着て接客すれば、噂が噂を呼び……客は爆増する。特に男の客が」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「であれば……試してみましょう。すぐに、裁縫係を呼び寄せます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370005" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「頼んだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "そしてまた数日後……。", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "PLAYBGM", "M02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が二人に着てもらったのは、色々際どいメイド服だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こ、これが新しい接客の衣装ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370005" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ。これを着て、なるべく多くカフェの中を歩き回ってくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうすると俺も嬉しいし、客もドカッと増えると思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「完全に自分の私情と主観が入っておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「フン……！　なんとでも言えばいい！　ここは異世界！　俺は俺のやりたい\nようにやらせてもらうっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「べ、別に止めてはおりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「メイド服……というものが何かは知りませんが、着心地は悪くありませんね\n。気に入りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370006" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だろ！　最高にエロくていいぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「エロッ……！？　あ、ありがとうございます……？　で、いいのかしら……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023370007" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もっと近くで見せてくれ……。おーっ、いい……。今にも胸がこぼれおちそ\nうだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしいですが……喜んでいただけて何よりです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370006" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あ～あ～……。完全に欲望に忠実に溺れていますな……。いつかバチが当た\nりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「当たるわけないだろー！　なんたって転移！　転移して怖いやつらは全員置\nいてきたんだからなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "二人はこの服が好きらしく、メイド服になってからはカフェでの士気も上がっ\nているようだった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00017302_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「他にも、思いついたことがあれば何でも教えてくださいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023370007" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ～っ。そんなことを言われたら、どんどんアイディアが湧いてくるぞ。こ\nれも異世界転移の恩恵なのか～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もう、完全に調子に乗ってしまいましたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今の俺を止められるやつはもういない！　あーっはっはっはっはっはっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして……絶好調な俺のもくろみ通り……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "カフェはメイドエルフにホイホイ釣られた客が集まって、すぐに大繁盛店とな\nった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「え～っ！　服が変わっただけなのに！　お客様全員喜んでますよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023370009" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうもんなんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「メイドエルフというウリができたことで、わかりやすい支持層ができたよう\nですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023370007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……この衣装、とてもたくさん褒めてもらえて……。驚いてるわ」", "NORMAL" ]},
