		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「失礼します……。あ……、やっぱりこの部屋であっていたんですね……。な\nんだか、生臭くて、薄暗い部屋……。少し寒気がします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00001303_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい。私も今はこの組織の一員ですから……。隊長であるあなたの命令には\n従うつもりです、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「願わくば、こんな暗い部屋じゃなくって……。明るいお日様の下であなたに\n会えたら……力を合わせて、笑いあえたらと思っていたものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00001303_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……いえ、そんなこと夢物語ですよね。それで、どんなご用事ですか？　た\nぶん……私にとっては辛いことなのでしょうけど……。はい。はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「え……！　オナッ……オナニーをしてみせろ？　オナニーって、その……じ\n、自慰……ですよね？　なんでですか？　あっ……今は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00001303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私とあなたは一つの身体におさまっているわけですから……。オナ……いえ\n、自慰なんてしたら、同時に二人に快楽が伝わるわけで……。あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303106" ]},
		{"command":[ "SETCHARA", "0", "char_00001303_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「それが目的、なんですね……。私を、十五夜まりあを辱めながら、自らは快\n感を得る……。なんて悪趣味な、で、でも……拒否権はないんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……股間のパーツと……胸のパーツを外して……。ベッドの上で脚を開け？\n　ぁ……、それから、それから……？　ベッドに置いてある小瓶の薬？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『薬を飲んでからさっそく始めろ』？　っ……薬……。こわい、です……。\n『パワーアップのために必要』？　いつも嘘ばかり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「けれど、信じないことには始まりませんもんね。わかりました。シルバスタ\nー・ブルーの能力向上のために薬を飲みます。……っごくっ。……う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「な、何……？　頭がクラクラして、体温が急上昇？　足元がよろめいて……\nあっ！　あ、あ、こ、これは……媚薬？　媚薬、ですよね……うううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「熱い……！　身体が熱い……！　それにすごく、すごく喉が渇く……！　す\nぐに潤さなくっちゃ、このほてりを抑えなくちゃ、……あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『オマンコをいじりながら、胸を愛撫して湿り気を増やせ』？　そん、なこ\nとで乾きが癒えるわけ……。あぁ、でも、でも、その提案に逆らえない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ。あぁ、あっ……あぁああ……だめ……！　誘惑に負けちゃだ\nめ、ブルー……！　頭じゃそうわかっているのに、勝手に手が……ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「指先が、私のものじゃないみたいに、い、いやらしいところをまさぐって…\n…。あっ♪　ま、まさか！　あなたが誘導しているんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……んぁ……！？　あぁっ！？　あ、いやぁ……！　おっぱいっ……！　そ\nんな、さわさわと、卑猥な手つきで……あぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「乳輪をじっくりなぞり……触りながら、人差し指で乳首をいじって……！　\nはぁ、はぁあっ、あぁっ！　こ、今度は親指と一緒につまんで、つねって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「クリクリ……くにくに弄り回すなんて……っ。あぁ……！　い、いやぁ……\n！　『股間がお留守になってるぞ』？　こ、股間？　そこは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そこも同時に攻められたり、したら……今の私じゃ……！　薬の効き目に理\n性を消失しつつある私じゃ、ひとたまりもな……、っんんんんーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「オマンコっ♪　オマンコに指っ……！　指添わせただけで太腿が痙攣しちゃ\nってっ……ああああっ！　中に、中に手をもぐりこませたらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ああああああッ！！　あーーーー♪♪　指ぃ♪　指入れただけで軽くイッち\nゃっ……あああああーっ！　うそっ！？　ウソ、うそ、嘘ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「乳首とオマンコ、二か所をいじるだけでぇ……！　全身が気持ちいいっ！　\nあ、愛液がこみあがってきて……あーっ、イクと漏れちゃうぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あっんっ！　あっんっ、あっ！　あっ、あっ、あっ……！　両手、両手、操\nられてるみたいに動いちゃう……！　だって気持ちいいから、だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「自分の乳首クリクリしながらぁああ♪　オマンコにじゅっぷじゅっぷ指突き\n入れて……！　自慰しちゃってます、オナニー、オナニーしちゃってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたが、あなたが見ているのに……あっ！　私の気持ち良さぁ……！　私\nが感じた分だけぇ、あなたにもばっちり伝わってしまっている、のにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『女はマンコいじくるだけでこんなに気持ちいいのか』ですか……？　あっ\n♪　当然、じゃないですか、いつも……オチンポ受け入れているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あんな太いもの、い、入れられて喜んでいる場所が……快楽に強いわけない\nじゃないですかっ！　すぐに気持ち良くならなかったら、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「つ、つらいでしょう……！？　だから特別敏感に……あんっ！　ちょっとの\n刺激で絶頂するようにで、でき、てるんです、愛液もヌルヌル出て……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そのトロみでますます悦ぶように……肉体がそうなっていて……！　ッんぅ\nうううっ……！　は、恥ずかしい……恥ずかしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「お、お願いです……！　オナニーはしますから、自慰はちゃんと続けますか\nら……！　目を閉じてもらえませんか、私、見られていると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたに見られると感度がどこまでもあがってしまうんですっ、それが今、\nち、致命傷で……！　薬と、羞恥と、快感とでおかしくなりそうで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「指が止まらなくなってきちゃって……んふぅううっ！？　その度に、イッ…\n…イッている、ので……！　『ダメだ』？　ぁっ……あ、あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたはいつもそうですっ、私にいじわる、で……あっ！　私……！　私、\n冷たくされると……！　見つめられると……んんっ、すぐイクんですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ドＭで、マゾだから……！　あっ！　あっ！　普段抑圧してきた感情が……\n、ふぁ！　性欲が、一度に溢れ出して……本当におかしくなる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「っあああああっ！　ああっ！　ああっ、あああっああっ！　イ……ってます\n、あぁっ！　み、見えますか……またイっちゃってます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「一人でオマンコして！　あ、あなたのオチンポのこと思い出して……！　こ\n、ここに、こうやってズブズブ入ってくるんだよなぁって回想して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「自分の指先……チンポにみたてて出し入れしながら……！　自分の愛液で手\nを濡らして、感じて……あんっ！　悦んで、ます、ああ……いや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……ん……！？　ここ？　ここを強くこするんですか？　え、ぁ……あっ、\nこ、ここ……Ｇスポット？　あ、あ、スポットなんてこすったら！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「今までで一番大きくイッちゃいます！　あ、あ、腰がガクガクして……頭が\n真っ白になって……いやぁあああああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「愛液っ、愛液、漏れちゃう……漏れちゃう、お漏らししちゃううううっ！　\nだめっ、Ｇスポットだめ、だめ、なのに……！　あぁああああん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あーーーーーっ♪　ああっ♪　ああああぁあんん！　はぁんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「やだぁああ……！　おしっこみたいに噴き出しちゃいましたぁあ……！　あ\nっ、あっ、シーツが私のでヌルヌル……こんなことって……ぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「す……すみません、すみませんっ……！　早く拭かないと……。拭かないと\nって思う、のに……！　ン……んん……っ、どうし、て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ネトネトになったオマンコをかき混ぜるのがやめられない……っ。ぁ……あ\n、はぁっ……はぁ、はぁ、は、ぁ……はぁあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「オマン、コ……っ、オマンコぐちゅぐちゅしながら乳首を硬くしていくの、\n楽しい……です……。あっ♪　ちくびっ、芯がとおって……あああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私の乳房も、とろけて柔らかくなって……あん、あんっ……！　つきたての\nおもちみたいで……触るのが、揉むのが止まらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あッ……♪　あっ、あっあっ♪　なんてひどい薬……あぁんっ、媚薬、媚薬\nが悪いんです……！　薬っ……薬のせい、……あっ、あぁあーっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「おまんこの中、ニュルニュルしてて……気持ちいいです！　はぁっ♪　んぁ\nあっ……！　複雑な形してる、いつもこれでチンポを包みこんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んぅ♪　私の指は海綿体じゃない、のに♪　それでも……キュウキュウ締め\nつけられるとこんなにいいんですから、チンポならなおさらですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「オマンコ、……オマンコでオチンポ出来るあなたが羨ましいですっ……！　\nガチガチになったチンポで♪　オマンコの中かきまわして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そんなの絶対イッちゃいますよ、ね♪　……んくぅうっ♪　あぁ……知らな\nかった……。わた、し、エッチな身体してたんだ……。あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「男の人を喜ばせるためだけにあるオマンコ、男の人に……、んぅ♪　あなた\nに揉みしだいて、めちゃくちゃにされるためだけのおっぱいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「服の上からでもわかる、変身したって隠しきれない、甘くて柔らかくて弱い\n身体……。これであなたをいつもいつも、挑発して、狂わせて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「オチンポ入れてくださいって、オチンポ挿入してくださいって媚びてたんだ\nぁ……♪　あぁ、はした、ない、淫乱……淫乱、淫乱ん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私淫乱です……！　ああああっ！　オマンコぬぽぬぽするの気持ちいいっ！\n　おっぱいっ、おっぱい形が変わるまで握りつぶすと気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「っくぅううん♪　くぅっ……あぁああん♪　理性なんて、もう吹き飛んじゃ\nいました♪　イくっ……イくぅっ♪　あーっ、イキっぱなしですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「どうか……どうか見ていてくださぁい……！　私がイッているところ……！\n　ああ、恥ずかしいのがいいんです、あなたに見られたいんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポ想像しながらオナる私はどうですか？　あっ……アソコを\n大洪水にしながら、あっ♪　どこまでもどこまでも深くぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「快感に溺れ、て♪　お薬キメっぱなしでイキまくってしまってすみませんん\nっ……！　あ、ひ……ひぃっ、ひぁああっ、はぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「恥ずかしい私を……ああっ！　視線で辱めてっ！　おっぱいっ、オマンコ、\n気持ちいい♪　気持ち良すぎて……もうダメぇええ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁああああんっ♪　んあっ、あぁっ、あぁあああぁん♪　だめっ、息がっ\n、呼吸ができなくなるくらい……いいっ、いい、いいんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ああ♪　ああっ、あぁああん♪　あぁあああんっ……♪　え……？　『その\nまま失神するまでイけ』……あっ、しっしんっ、しっしんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「気を失うまでイキ続けるなんて……夢、みたいですうぅ～～♪　んぁあああ\nっ！　はぁあっ、はぁっ、あぁっ、あぁあああんっ、あぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「膣内痙攣しっぱなしなのにぃ、奥に、奥に指突き立てるの快感ですっ！　あ\nっ、同時に……乳首も痛いくらいつまんで、こねまわして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁああんっ、あぁんっ、あぁっ、あーっ！　肉欲ぅ、どこまで達しても、\nまだ極められる……終わりがないんですぅっ！　んぁああーっあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「だ……めぇ、だめ、だ……めだめぇええええ……♪　人としての尊厳失っち\nゃう、奪われちゃ……う♪　それでも、それでもイキたいのぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁーっあぁああんっ！　はぁんっあんっ！　あんっ、あんんっ！　イけっ\nて……イけって命令、してください……そうしたら、そしたらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私、イキ、ます……。イキますぅ……！　……ん……！　ん、あっ、あっあ\nっあっあぁああああーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303308" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「やっぱりあなたの命令が一番んん……！　あぁっ♪　私の内側から聞こえて\nくるだけで……！　んぁあああああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……………………。ぁ……。わ……私……今気絶しちゃってまし、たか？　\nあぁ……。今は余韻が凄くて……少し、少し休ませてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303310" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁああああんっ！！　……え？　何……なんです、か？　今、いちばん…\n…一番いいところで……。ぁっ、『潮を噴いてほしい』……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んふぅうっ♪　そ、そんなこと言われたら……！　あっ♪　そんなエッチな\nこと、私の中で言われたら、あっ！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「頼まれなくてもお潮……噴いちゃいそうです、ぁっ……！　感じすぎちゃっ\nて……頭が朦朧としてきちゃいます……！　んんんん、あぁん、んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「お潮……お潮ぉ……！　あっ♪　あなたが見たいなら、……あっ♪　私、私\n……！　あっ、……あの……そんなに時間かからない、です、からぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私から目を離さないでください……ね？　んぁっ……んぁああっ♪　で、ち\nゃいます出ちゃいますぅ、出ちゃう……あぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「くぅうううううううんん♪♪　んんんん♪♪　んんーーーーーっんんーーー\nーーーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303406" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「か、は……っ、あぁっ……あぁっ、あぁ……！　み、見えましたか？　私…\n…私のお潮ぷしゃああって……！　あっ、あたりを濡らして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そこらじゅうにまき散らされちゃいました……。あぁ……！　こ、こんなと\nころ……見せるのはあなたにだけですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「それに、く、薬があったからで……。……『言い訳するな』？　は、はい…\n…。そう、です……。出したくて出しました、気持ち、よくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい……。はぁ、はぁ、はぁ……。すごく……すごく良かった\n、です……」", "NORMAL" ]},
