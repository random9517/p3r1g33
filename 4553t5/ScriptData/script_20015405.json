{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0008" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「や、やめろ馬鹿っ……！　貴様が私たちを攻撃してどうするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ＥＤＯの敵になった俺はまさに無敵で、ルナテミスと修羅姫の猛攻をかいくぐ\nり、２丁拳銃で反撃する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「時間帝国　最高　時間帝国　プレゼント　クレル！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええいっ！　なぜこんなに突然強くなったんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「カタコトで喋るな！　イライラする！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クリスマスプレゼント　欲シイ……。ＥＤＯ滅ブベシ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うああああああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「……味方にしておけば弱いのに、敵になった途端強くなる……。ホント、厄\n介な性格じゃなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いつでもこの実力が出せれば、強者と呼ばれ尊敬もされるだろうにね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "呆れた声で、遠くから戦闘中の俺達を観察していたサンタガールとクィン・テ\nイルはくるり、とジェスタたちの方に向き直った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「それじゃあ、私はこっちを片付けておくかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「え！？　えっえっえっええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「賛成じゃ。余も参加させてもらうとするかの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「こんなの私たちに、勝てるわけないじゃないですかぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぴえええええええ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……一瞬、あたりが静かになったかと思ったら、もう時間帝国の面々は地面に\n投げ出され、敗北してしまっていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……ううう……、負けたわ。これ以上ここにいたら大変なことになる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「に、逃げます！　皆さん逃げましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お……お、覚えてろぉおお～っ！　次はおねーさまたちも連れてくるんだか\nらぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023560003" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "捨て台詞を吐いて、ジェスタのワープホールに飛び込むメンバーたち。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ、おいっ！？　待ってくれ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……あぁあ……行っちまった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "信頼していた人々に見捨てられ、筋骨隆々無敵無双だったはずの俺は……空気\nが抜けた風船のようにしぼみ、うなだれる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなのってないだろぉお……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「今じゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560003" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「今こそ、ルミナリアンサーベルを使うのじゃ！　ルナよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わかりました！　ルーナーテーミースー！　ホームラン！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560004" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐあぁああああぁあああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺は、ルナテミスが力を溜めてフルスイングしてきたその衝撃に耐えられず、\n思いっきり遠くまでぶっ飛ばされる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「プレゼントが欲しかっただけなのにーーーー！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「おうおう、星になりよったわ。良くぞ悪を退治してくれたのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560005" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今、母上の声が聞こえたんです。これがルミナリアンサーベルの力……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560005" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅっ……！　天国の母上、私は必ず母上の無念を晴らします！　空の上か\nら見ていてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560006" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「感傷に浸っているところ、申し訳ないが……今倒したのは味方のカツマだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「一度裏切ったのですから、成敗されるのは当然です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023560007" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それはそうだな。でも、このままにしておくわけにもいかないだろう？」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023560003" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「仕方あるまい。吹っ飛んだカツマを探しに行くかの。クィン、修羅姫、手伝\nっておくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560006" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「はぁ……。本当に世話の焼ける男だねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023560003" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0145" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いました！　ここに埋もれていたようです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023560004" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "3", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……雪山に埋もれていた俺を発見したのは、修羅姫だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「し、し、死ぬ、凍えて死ぬ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「と言いつつ、かろうじて生きているあたりにご主人のしぶとさを感じますぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023560001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ぇ～！　お前は吹っ飛ばされなかったからって～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ちょっとは頭が冷えたかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020023560004" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「反省……反省はしてますが、どうして俺にだけ……クリスマスプレゼントが\nないんだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「カツマへのプレゼント……？　おお、忘れとった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560007" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「案ずるな。お主の分もきちんと預かっておったぞ。これが、一番のポンコツ\n幹部だったカツマへのプレゼントじゃ。ほれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560008" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは……陛下のグラビア写真集！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「これで余の美しさを後世に語るのじゃ！　……と、ルナルバースが言ってお\nった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560009" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「４０ページから先はヌードもあるぞぉ……。これは若者には刺激が強すぎる\nかもしれんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560010" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「袋とじは、本来の姿のルナルバースグラビアじゃ！　これはファン大歓喜の\n内容じゃな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560011" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「死ぬ間際になんてモノを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「……まぁ。ほら、お主にはよく分からん輩が……既にプレゼントを用意して\nおるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560012" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　声が小さすぎて聞こえなかった。今、何か言ったか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「いや、なんでもない。聞こえなければそれでいいのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560013" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しっかし、グラビア写真集か……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なんとも言えない感情に襲われる俺に、降り積もっていた雪を修羅姫が手で払\nい落としてくれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんでもいいから、早く帰ろう。寒すぎて凍えてしまいそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023560005" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「熱いお湯に浸かりたいですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023560002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「早く戻らねば、クリスマスが終わってしまう。とっとと起きて付いてくるの\nじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023560014" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
