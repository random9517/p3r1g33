		{"command":[ "SETIMAGE", "0", "sbg_0194" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "ハルノブのマスクにひびが入り、一部が割れる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「な……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115320005" ]},
