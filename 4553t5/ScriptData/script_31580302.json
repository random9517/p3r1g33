{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇご主人、本当にこんなところでするの？　ただの岩陰だよ？　少し\n移動するだけで人がいるんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「別に、絶対に嫌って訳じゃないけど……は、恥ずかしいんだって！　言わな\nくてもわかるでしょ、もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、しょーがないなぁ……いいよ、頑張って選んだ水着のまま、ご主人に\nかわいがってほしいって思ったのは本当だしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そ、それに……露出プレイ？　っていうのかな。解放感でいつもより気持ち\nよくなれるって情報がデータにあって、気になってたり無かったり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――し、しょーがないでしょ、気になるものは気になるんだから！　……ほ\nら、もう準備はできてるから……ご主人、きて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んくぅぅっ……！　ご主人のおちんちん、おまんこの壁ぐりぐり削りながら\n、入ってきたぁ……んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015803_02_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ、水着の下を入れやすいようにずらすのは分かるけど、上をずらし\nておっぱい出す必要あるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――そっちの方が恥ずかしいだろ、って……こ、このご主人は……あっ、ん\nふぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「片足立ちのこの体勢だと、おちんちんの括れがおへその裏辺りにぐいぐい擦\nれてっ、あっ、んふぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そこ、弱いんだってっ、あっ、んあぁんっ……！　ご、ご主人、最初から激\nしすぎるって……！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こうなったら、私だって……んんんっ！　――ふふっ、どうしたの、ご主人\n、そんなに可愛い声上げちゃって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、内部機構が一気に収縮して驚いた？　ご主人が私の弱い所を知って\nるように、私だってご主人の好きな動き知ってるんだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちんのさきっぽ……んっ、んあぁんっ……亀頭の部分に吸い付くよう\nに中を動かして……あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こうやって、腰をぐるぐる回すのも好きだよね、ご主人……んくっ、あっ、\nんあぁんっ……！　おちんちん左右に振って、擦って……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ああ……これっ、あっ、あぁんんっ！　太陽の下でえっちなことするの、思\nったより気持ち、よすぎてっ、んひゃぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいの感じながら外でするのって、こんなに気持ちいいんだ……あっ\n、ああぁんっ……！　こ、これが、露出プレイ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「この解放感……恥ずかしいの癖になっちゃったら、どうしよう……あっ、ん\nひゃぁんっ！　んくっ、ああぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――あ……ごめん、私だけ先に気持ちよくなっちゃって……ふふっ、拗ねて\nるの？　ご主人のそーゆーところ、ちょっと可愛いよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、さっきみたいに、おまんこの中をぎゅ～ってしてあげるから……んん\nっ……ご主人も好きなように気持ちよくなって、ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あっ、んふぅんっ！　一番奥まで勢いよく来たっ、あぁんっ！\n　子宮パーツがズドンっておちんちんに突き上げられて、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人？　折角だから、私の事もっとぎゅっと抱えて欲しいかも……あ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ありがとう、ご主人、んぁんっ……！　すごい……ご主人の肌と直接触れ合\nってるからかな、ボディに体温が伝わってきて、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁっ！？　ご、ご主人、なんでそんなに太もも揉むのっ、んふっ、んく\nぅんっ……！　嫌ではないけど、変な感じ、して、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いい感じにもちもちって、確かに触り心地も考えてパーツを選んでるけどさ\n……あっ、んあぁんっ……！　そ、それ褒められてるのかなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも……そっか、太ももか……確かそーゆープレイもあるってデータをイン\nプットしてたはず……いつか試してみちゃう？　なーんて、ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――えっちでいいよ。だって相手はご主人なんだもん。知らなかった？　私\n、ご主人の事が大好きなんだよ？　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんんっ！　また一気に激しくっ、あっ、んふぅんんっ！　――私が可\n愛すぎるせいだ、って……ふふっ、ありがと、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ、んあぁんんっ！　パンパンに膨れ上がったおちんちんで、\nおまんこ滅茶苦茶にかき回されて、あひっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おへその裏、またガリガリ削られちゃう、あひゃぁんっ！　じゅぼじゅぼお\nちんちん抜き差しされてっ、あっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「っ、これっ、支えがないからおっぱいも跳ね回っちゃう、あっ、あぁんんっ\n！　私の身体、えっち過ぎるっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、ノイズ来た！　いつもの気持ちいいエラーが、頭の中に溢れてきてっ\n、あっ、あぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん、伝わってるよ！　ご主人もだよね？　おちんちんもっと熱くなって、\nおまんこの中でビクンビクンって跳ね回って、んひゃんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「射精しそうなんだ、私のおまんこに精液ビュービュー出したいんだ……！　\nあぁんっ、あっ、んあぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「このまま出して、私もいっぱい締め付けてあげるからっ、んんんっ！　私の\nおまんこの中、ご主人の精液でいっぱいにしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんんっ！　外なのに、誰かに聞こえるかもしれないのに、声我慢\nできない！　恥ずかしいけど、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃぁんっ！　おちんちん膨らんでっ、来るっ、ご主人の\n精液来るっ！　私も一緒に、あひっ、あっ、んひゃぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃあぁぁぁんんっ！　精液の勢い、すご、過ぎてっ！　あひっ、あっ、\nあひゃぁぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まだ一回目なのにっ、んくぅうんっ……！　こんなエラーの量……ノイズ多\nすぎ、てっ、あっ、んはぁんっっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――！？　ご、ご主人、い、いま近くから人の声聞こえなかった？　あ……\nセンサーにも熱源反応感知してる……これっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「って、ご主人、その怪しい笑い声は何？　……ま、まさか、ご主人、このま\nまもう一回やるつもりじゃ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんんっ！　――んんっ！　ち、ちょっと待って、声出ちゃうって、\n近くにいる人にばれちゃうっ、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「み、見られたらそれはそれで盛り上がってよしって……そうだった、私のご\n主人はどーしよーもない変態だったね……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――いいよ、こうなったらとことん付き合ってあげる。確かに恥ずかしいけ\nど……ふふっ、ご主人に可愛がってもらえるなら、悪くはないかなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　固いままのおちんちんが、またおまんこの中ごりごり削って\n、あっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、声だって我慢しないんだから、んあぁんっ……！　私からもまた腰\nを回して、ぎゅーっておちんちん搾り取ってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んひゃぁんっ！　んふぅんっ！　ご、ご主人、さっきみたいにまた太\n腿もむにむにしてほしいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふぅんっ……！　それ、優しくすりすり撫でられて、いやらしく揉まれる\nの、気持ちいい……あっ、んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ほら、ご主人もさっきみたいな可愛い声をだしてみせてよ。一緒に\n露出プレイ、楽しんじゃお？　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「また奥の方ぎゅ～って収縮させて、あっ、んふぅんっ……！　亀頭の部分を\nぎゅっぎゅって締め付けてあげるからっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私からも、いっぱい腰を動かしてっ、あっ、あぁんんっ……！　ぱんぱんっ\nて、えっちにぶつかる音、周りに聞こえるぐらい激しく、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の喘ぎ声、かわいい……あっ、あぁんんっ！　まだまだ足りないよ、\nもっと激しく、おまんごぐちょぐちょに苛めてほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃぁんっ！　さっき出した精液をじゅぶじゅぶかき出し\nてっ、あひぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そこ、またおへその裏っ、ああぁんんっ！　角度をつけて、おちんちんパン\nパン叩きつけて！　お腹ポッコリするぐらい激しく突いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　あっ、んふぅんんっ！　気持ちよすぎて、全身がオーバー\nヒートしちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「っ！　ご主人、また、近くに熱源が近づいてきてる……！　あっ、んひゃぁ\nんっ！　だめ、止めないで、このまま最後まで、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、見つかったらその時はその時、でしょ？　んんっ……！　ご主人だ\nって、もう我慢できないの、分かってるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁんんっ！　先っぽがまた大きく膨らんで、おちんちん何度もビクンって\n跳ねてっ、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私も来たから、気持ちいいエラーで頭がいっぱいだからっ、んひゃぁんっ！\n　ノイズ凄すぎてっ、あっ、あひゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「平衡感覚のシステムにもエラーが出てっ、あぁんっ！　あ、足がガクガクし\nちゃってる、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「出してご主人！　私の事めちゃくちゃにして！　恥ずかしい露出プレイで、\nイきたいの！　ご主人と一緒に、あひっ、あっ、あひゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んぁあぁんんっ～～～～っ！　イク！　中に出されて私もイッてる！　あっ\n、ああ、あひゃあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこのおくぅ……子宮パーツが、ご主人の精液でパンパンに膨れ上がっ\nて、んひゃうぅ！　精液びゅーびゅー、止まんない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「な、なにこれぇ、気持ちよすぎるよぉ……！　あひぃんっ！　こんな解放感\n知らないっ！　外でえっちしてるから、なのかな！　んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んあぁぁ……誰かに見られるかもしれなくて……えっちな声\n、聞かれるかもしれなくて……んふぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしい、はずなのに……これが露出プレイ……新しい知識……ふふっ、\nふふふっ……本当に癖になっちゃうかも……んくぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……ご主人、ほんとにいっぱい出したね？　お腹の中パ\nンパンすぎて、精液逆流してきちゃってる……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、太陽の下で楽しむ私のおまんこ、そんなに気持ちよかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ごめん、流石にもう一回は厳しい、かな？　ちょっと本気で感じすぎち\nゃって、平衡機能のシステムエラーが消えなくなっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人が抱えてる太ももも痙攣しちゃってるでしょ……？　ふふっ、残念、\n私ももう一回ぐらい可愛がってほしかったんだけどな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……続きはまた今度。外でするえっちに関して、ちょっと知識をインプット\nしてきちゃおうかな？　なーんて、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんんっ！　おちんちんが抜けちゃってっ、あっ、んふぅうんっ！　\nボディに精液がかかっちゃうっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「す、すごい勢い、まるで精液のシャワーみたい……！　んひゃぁんっ！　精\n液熱いっ、全身ドロドロにされちゃうっ、あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「精液が付着したところが熱を持って……あひっ、あっ、んくぅぅんっ……！\n　小さなエラーがいっぱい出てっ、イクっ！　あっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んくぅんっ……！　ご主人の精液、おっぱいにまで飛んでる\n……今誰かに見られたら、私、どう思われちゃうんだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしい、けど……ふふっ、やっぱりこの解放感、癖になるかも……んん\nっ……露出プレイ、気持ちいい……んぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……ご主人は、満足してくれた？　まぁ、この精液の量\n見たら、聞くまでもないと思うけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……あれだけ声出したけど、結局誰も見に来たりはしなかったね。……\nそれはそれでちょっと残念かも、なーんて、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――変態でいいよ、私はご主人の所有物なんだもん。ふふっ、ロボは持ち主\nに似るんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さて、身体を綺麗にしたら、もう一度海に遊びに行こうか？　これだけ私の\n事好きにしたんだもん、付き合って、くれるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――もちろん、一緒に浮き輪でぷかぷかするの！　折角の海だもん、いーっ\nぱい付き合ってもらうから！　大好きだよ、ご主人！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}