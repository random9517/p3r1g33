	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……どうにも、戦闘が長引くばかりで決着がつかんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いや、もっとしっかりやってくれよルナテミスっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふぇえ～……ダイヤナちゃん疲れたぁ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いつまでたってもカタがつきそうにないな、こりゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「先生たち！　もっとしっかりやってくださいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いや、一応やってんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でもねぇ……やっぱりルナさまにはガッツリ攻撃しづらいっていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様のほうも、やりづらそうだもんなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「って！　そんなこと言ってる場合ですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わかったわかった！　しょうがねえ、もう一回行くか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょーっと待ったぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109160003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「その声は、カツマ！？　なにをしにきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はーっはっはっは！　ルナよ！　余もおるぞ、余も！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「母上様ぁ！？　そんなところで、なにをなさっているのですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109160003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なにもカニもあるか、お前ら、遊んでないでとっとと戻ってこんかい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくだ！　アホな争いに巻き込まれて、危うく人としての尊厳を失いか\nけた身にもなってみろ！　このボケナスビども！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺だってマジで死ぬかと思ったぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さすがに留置場で一泊すると、頭も冷えるねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そういうわけじゃ！　アホな争いに付き合って、みんなに迷惑かけるんじゃ\nないわい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ちょーっとお待ちよ、ルナルバースさんよ！　もとはと言えば、争いを煽っ\nたのはアンタやないんかい、おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そう言う側面がなきにしもあらずであることは否定できんかもじゃが、そう\nかもしれんし、そうでないかもしれんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160004" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「わけわかんねえこと言ってごまかすな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109160002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、とにかくじゃ！　ルナもセレーナもダイヤナも、アホなことに付き合\nっとらんで帰ってこい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160005" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　もうやめようよ、こんなの。ねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020109160001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109160004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……どうします？　ルナテミス様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160006" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんたち、ルナさまと戦うのいや～。あとが面倒だし～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010109160004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ちょっと！　先生たち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「たしかに、同じグレート・ルナリアムの幹部同士でこれ以上争うのも、限り\nなくバカバカしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109160005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おーい！　ルナテミスっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109160003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　やめるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109160006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109160007" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七＆ほむら" ]},
		{"command":[ "SETTEXT", "「おまえらなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00003402_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「もうええわい！　もう勝手にさらせ！　こうなったら、まずはおどれらを先\nに血祭りにあげたるわい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「人をコケにしやがると、　どうなるか思い知らせてやらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109160005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほほう、面白い。先に我らと戦うというわけか。だが、勝てるかなぁ！？　\n先ほどまでの戦いで疲れ切ったおぬしたちがのう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160006" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109160006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「まさか、このタイミングで出てきたのは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109160007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふふふ、二つの組織が争って弱体化したところを一気につぶす！　わしの\n大好きな、あの映画と同じパターンじゃよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160007" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんてヤツだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109160007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はて……あの映画、タイトルが思い出せんが、なんじゃったかのう？　まあ\nいいや、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160008" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッド、総攻撃じゃーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109160009" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}