{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "３人" ]},
		{"command":[ "SETTEXT", "「きゃあああああぁぁぁぁぁーーーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440001" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "4", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00015705_01", "4", "CENTER", "700" ]},
		{"command":[ "SETCHARA", "2", "char_00015805_01", "3", "CENTER", "-700" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿な……！？　Ｙ.Ａ.Ｍ.Ｉたちがやられただと……！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「これでわかったでしょう。必ず最後に愛は勝つのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440001" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そういうことです♪　ご主人様への愛があれば、性能の差なんて関係ありま\nせん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440001" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「強靭……無敵……最強……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440001" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「こんなの、認めないわ……！　愛だなんて……！　そんな、くだらない感情\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「私たち超人工知能に……感情なんていらないんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「そうだよ……感情があれば強くなれるだなんて……そんなの、理解できない…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おーい、待たせた――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、なんだこりゃ！？　Ｍ.Ｏ.Ｅたちが黒くなってる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というか、Ｍ.Ａ.Ｍ.Ａはどこいったんだ？　それにこの状況は一体……\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、カツマちゃん。えっと、これは……なんて言えばいいのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様。順を追って説明させてもらいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ。よろしく――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「かっ……カツマちゃーーーーーんっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440003" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐえええええぇ！？　くっ、苦しっ！？　そんなに強く挟まれたら、死んじ\nまうぅぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「あっ、ごめんなさい！　カツマちゃんを見たら、私の超人口知能が暴走して\n、つい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440004" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　なに勝手にカツマちゃんに抱き着いてるの！？　離れな\nさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440003" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「イヤよ！　カツマちゃんは私の愛する人なんだから、絶対に離したりしない\nわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440005" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　貴方、なに言ってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440004" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「カツマ……！？　っ……！　な、なんですか……この心の奥底から湧いてく\nる、言葉にしがたい感覚は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440003" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふっ……！　この人を下僕にして虐めたい……！　そんな加虐的な感情\nが回路を駆け巡ってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ね、姉さん……大丈夫……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440003" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「え、ええ。大丈夫ですけど……クララには何か変化はないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440005" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「変化かどうかはわからないけど……この人を見てると、なんだかイライラし\nてくるというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440004" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「オリジナルと戦ってたときとは違って、苛立ち……いや、これは嫌悪感や不\n快感って言った方がいいのかな……そういうのが、どんどん湧き上がってきて\nる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「まさか、これが感情というものなんですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっ……？　愛……？　加虐……？　嫌悪感……？　ど、どういうこと……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あなたたち、さっきまで愛なんて認めない、くだらない……とか言ってませ\nんでした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440003" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「……もしかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440001" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「Ｍ.Ａ.Ｍ.Ａ、何か思い当たることでもあるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440004" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ええ。あくまで仮説だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440002" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「Ｙ.Ａ.Ｍ.Ｉちゃんの超人口知能は、オリジナルであるＭ.Ｏ.Ｅちゃん\nの情報をコピーして作られたのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん……そういってた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440003" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「だとすると、情報をコピーしたときに、Ｍ.Ｏ.Ｅちゃんが持ってるカツマ\nちゃんへの愛も一緒にコピーされてる可能性が高いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440004" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ですが、あの襲来者は感情を消したって言ってましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440005" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「機械にとって感情というのはかなり不確定で未知の要素だから、完全に消去\nできてなかったんでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440005" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「つまり超人工知能の感情は消せなくて……ご主人を見た瞬間、眠っていた愛\nが目覚めて、暴走し始めたってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440004" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そういうことになるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ちなみに、私たちのコピーも感情を持ってるみたいですけど……これはどう\nいうことなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「Ｙ.Ａ.Ｍ.Ｉと違って……愛っていう感情じゃないみたいだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440005" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ロッテちゃんとクララちゃんも、原理はＭ.Ｏ.Ｅちゃんと同じだと思うわ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440007" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ただ、消去されていた感情は復元したけど、バグの影響でカツマちゃんへの\n愛じゃなくて、歪んだ感情になったのかもしれないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「つまりあの子たちは、バグのせいでご主人様に対して加虐心とか不快感を持\nっているということですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440007" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あくまでも憶測でしかないけど、そういうことでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440009" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿な……！？　私が作り出した超人工知能に感情が芽生えるだと……\n！？　そんな欠陥、あるわけが……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「認めん……認めんぞ！　おい、Ｙ.Ａ.Ｍ.Ｉ！　ロッテ！　クララ！　カ\nツマとやらを人質にして、早くオリジナルを倒すんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんを人質にするなんて、そんな酷いことできるわけないでしょ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「それにカツマちゃんを傷つけるくらいなら、私はカツマちゃんと一緒に死ぬ\nわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「死ぬのはダメですよ。そんなことしたら、この人を虐められなくなるじゃな\nいですか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440007" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「それ、私にも手伝わせて……！　コイツの顔見てるだけで、イライラするか\nら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「なっ……！？　き、貴様ら！　創造主であるこの私に歯向かうというのか！\n？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「私にとって創造主である貴方なんかより、カツマちゃんのほうが大事なの！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440008" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「この人……いえ、この下僕は私のオモチャです。壊していいのは、私だけで\nす♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440008" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「姉さん、本当にこんなのを下僕にするの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440007" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「はい♪　だって、虐めがいがありそうじゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440009" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「なっ、何なんだ貴様らっ！　いいから、さっさとＭ.Ｏ.Ｅたちを始末しろ\n！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「もう！　うるさいわね！　私とカツマちゃんの時間を邪魔しないでっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440009" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「湾曲っ！　唐竹割りーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「覚えてろよーーーーー！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ……襲来者飛んでっちゃったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440005" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「なにはともあれ、無事に襲来者を倒せましたね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440008" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それはいいんだけど……この子たちはどうするの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「うーん……このまま放っておくわけにもいかないし、一緒に基地に連れて帰\nりましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440010" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「連れて帰る……？　それって、この子たちを仲間にするってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440006" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そこまでは言ってないけど、そうなってくれると嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440011" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「襲来者からの襲撃に備えるために、戦力は１人でも多いほうがいいでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「それはそうだけど、何もこの子たちじゃなくたって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440007" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「貴方たちの仲間になれば、カツマちゃんと四六時中一緒にいられるのね！？\n　なら、喜んで仲間になるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440011" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「この下僕をオモチャにしていいっていうなら、私も付き合ってあげますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440010" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「私は別に興味ないけど……姉さんが行くなら、私も行く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440008" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……本当に連れて帰っても、大丈夫なんでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022440009" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でもこのまま放っておいた方が、もっと酷いことになりそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022440007" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ふふっ。ロッテちゃんやクララちゃん。それにＭ.Ｏ.Ｅちゃんがもう１人\n増えたみたいで嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022440013" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　本当に基地に連れて帰るだなんて……！　そんなの、私\nは認めないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440008" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「別に貴方に認められる必要なんてないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440012" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「仲間になるということは、チームになるということよ！　貴方みたいな人に\n背中を預けられないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440009" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ねぇ！　カツマちゃんも、こんな乱暴な子がそばにいたらイヤでしょっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……戦力が増える分にはありがたいが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「な、何よそれ！　カツマちゃんは私より、その子たちの方がいいっていうの\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうことじゃなくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「嬉しいわっ！　カツマちゃんの方からも、私を求めてくれるだなんてっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440013" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうか、Ｍ.Ｏ.Ｅ……早く助けてくれ……！　それと誰か……状況を\n説明して……がくっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「大変っ！　カツマちゃんがぐったりしてるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440014" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「貴方がずっと抱き着いてるからでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440012" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「ちょっとＹ.Ａ.Ｍ.Ｉちゃん！　私のオモチャを壊さないでくださいっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_050022440011" ]},
		{"command":[ "SETCHARA", "0", "char_00015705_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「姉さん……こんなの、壊れてもいいと思うけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_050022440009" ]},
		{"command":[ "SETCHARA", "0", "char_00015805_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ。すぐに生命維持装置を起動してあげるわ。でもその前に、カツマ\nちゃんの服を脱がせて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_010022440015" ]},
		{"command":[ "SETCHARA", "0", "char_00022502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あーーー、もう！　いいから、早く離れなさーーーーーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022440013" ]},
		{"command":[ "SETCHARA", "0", "char_00011104_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}