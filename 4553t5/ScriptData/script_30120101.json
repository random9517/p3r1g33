{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "012_0103101" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やっほー、けいびいんさん！　呼ばれた通り、お部屋まで来たよ～！　私に\nご用事ってな～に？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103102" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、もしかして……このお部屋に呼んだってことは……またイヤらしいこと\n考えてる？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103103" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えー、誤魔化したってダメだよ。だって今、すごくＨな顔してるよ？　もー\n、しょうがないなぁ……ちゃんとお仕事もしなきゃダメなんだからね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103104" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もちろん、わたしだって年頃の女の子だもん。Ｈなことも興味あるし、それ\nで強くなれるなら……あと、けいびいんさんとなら……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103105" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……ううん、なんでもない！　それで、今日はナニをするの？　わたしはど\nうすれば良いのかな？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103106" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ろーしょん？　まっと？　ぬるぬる？　うーん、よくわかんないけど……な\nんだか楽しそう！　とりあえず、やってみよ～！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103107" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うわー、すごい、ホントにヌルヌルだぁ……これがローションなんだね～！\n　ヌチャヌチャしてて、すっごくイヤらしい感じ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103108" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……あ。にっしし～、けいびいんさんのオチンチン、もう大っきくなってる\nよ？　わたしのおなかに固いのがゴリゴリ当たってるぅ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103109" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしの身体でけーびいんさんのオチンチンをヌルヌルこすって、気持ちよ\nくすればいいんだよね？　おっけー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103110" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、いくよー？　身体全体を滑らせながら、ローションで……にゅ\nるーり、にゅるーり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103111" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あははっ！　これ楽しい～！　肌がにゅるにゅるこすれる感じがおもしろく\nて……んふ、でもすっごくイヤらしくて、すごくドキドキするね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103112" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カチカチのオチンチンがわたしのお腹の下で、にゅるんにゅるんて擦れて…\n…んっ、そのたんびに、どくんどくんて跳ねてるよ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103113" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしのお腹でヌルヌルされるの気持ちいいの？　んっふふ～、ちょっと嬉\nしいかも……いいよ、もっとしてあげる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103114" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オチンチンだけじゃなくて、わたしのおっぱいで、けいびいんさんの胸も、\nにゅるにゅる～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103115" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、けいびんさんの身体、固くてゴツゴツしてる……男の人の身体って感\nじ。女の子とは全然違うんだねぇ、えへへ、ちょっとカッコいいかも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103116" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「肌と肌が擦れあうと、あったかくって、にゅるにゅるして……んふぅ、すご\nくＨな気分になってきちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103117" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やんっ、おっぱいがけいびいんさんの胸板でぬるぬる擦れて……あふぅっ、\n乳首、固くなってきちゃった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103118" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、わたしの乳首がけいびいんさんの乳首と擦れあって、くりくり\n……んあぁっ、気持ちいい……すごいＨだよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103119" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　オチンチンも、わたしのアソコに当たってるぅ……あんっ\n、あんっ、ぬりゅぬりゅ、擦れちゃってるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103120" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「アソコとオチンチンがずりゅずりゅ擦れると……やぁんっ、わたしのお豆さ\nんにオチンチンの出っ張りが引っかかって、こりゅこりゅってするぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103121" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、オチンチンでわたしのクリトリスをずりずり擦らないでぇ、あん\nっ、あんっ、Ｈな声でちゃうからぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103122" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もう、動かないで……あんっ、あっ、あっ、勃起オチンチンをアソコに押し\n付けちゃダメぇ、凸凹がいっぱい擦れちゃうよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103123" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やぁんっ、オチンチンの裏筋が、ずりゅずりゅって、んふぅ、わたしのアソ\nコをいっぱい擦ってるぅ、気持ちよくなっちゃうよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103124" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、そこ、ダメっ……！　わたしのアソコの、あぁんっ、オマンコ\nの入り口だからぁ、そこはダメぇっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103125" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やぁんっ、ダメだよぉっ、腰を動かさないでぇっ……！　オチンチンの先っ\nぽを、オマンコの穴に当てちゃダメだよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103126" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「入っちゃうからぁっ……！　んあぁっ、そこにグリグリ押し付けたら、あぁ\nんっ、にゅるんってナカに入っちゃう、セックスになっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103127" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やんっ、あんっ、あぁんっ、敏感なとこばっかり擦られて、あんっ、頭がぼ\nーっとして、身体が変になってきちゃった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103128" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「アソコも、おっぱいも、にゅるにゅる擦れて、んあぁっ、あっ、あっ、キち\nゃう、おっきいのがキちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103129" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、オチンチンがもっと大っきくなってる、あぁんっ、さっきより\nもガチガチに固くなって、先っぽの亀頭がパンパンにふくれてるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103130" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「イっちゃうの？　いいよ、わたしもキちゃうから、あっ、あっ、あっ、一緒\nにイっちゃうからぁ、あっ、あっ、イく、イくっ……イくううううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103131" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！？　あっ、あっ、お腹に熱いの出てるっ、オチンチンから、\nいっぱい……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103132" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どろどろした精液が、びゅく、びゅくって、あっ、あっ、すごい勢い……胸\nの方まで飛んできちゃってるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103133" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お腹のところで精液がいっぱいたまって……やぁんっ、ベタベタになっちゃ\nってるよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103134" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ぬちゃぬちゃして、それに、すごい匂いで……んあぁっ、濃くって、青臭\nくって、男の人の匂いがする……あぁ、頭がふわふわしてきちゃう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103135" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「精液、あったかくて、気持ちいい……肌からじんわり染み込んでくるみたい\n……匂いが取れなくなっちゃうかも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103136" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふぁ……すごぉい、精液いっぱい出たんだねぇ～……私のご奉仕が気持ちよ\nかったのかな？　えっへへ～、嬉しいなぁ～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001201_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103137" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あのね……けいびいんさんのイく時の顔、すっごく可愛かったよ？　切なそ\nうな、気持ちよさそうな顔で、胸がきゅ～んってしちゃった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103138" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ローションのヌルヌルももちろんいいんだけど、肌と肌が触れ合うだけでも\n、すっごく気持ちがいいんだね～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103139" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えへへ、またシたくなったら、いつでも言ってね？　またシてあげる！　私\nだって女の子だもん、Ｈなこと好きなんだよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "012_0103140" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、でも、お姉ちゃんにはナイショにしといたほうがいいかな……わたしと\nけいびいんさん、二人だけの秘密だよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}