{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「ここが……居酒屋というものなのですね。はぁ……なんだか気分が落ち込ん\nでまいりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あぁ！？　文句あるなら座るんじゃねーよ！　ウチは確かに小汚ねーかもし\nんねーが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022960001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「毎日掃除は欠かしてねぇし、出すもんの味は天下一品！　騙されたと思って\n黙って座ってろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022960002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「え、ええ……わかりましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022960002" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ほむらの勢いに負けたのか、ルナテミス・ダークは木製の椅子に白いシルクの\nハンカチを置いた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、その上にしずしずと腰かけて行儀良さそうにお通しを待っている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「まるで野獣のテーマパークですわ……。キツい日本酒の香り、オジサンっぽ\nい煮物の匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022960003" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「何を言っている。それがいいんじゃないか。ん～、落ち着くぞ。この雰囲気\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おおっ、そっちのねーちゃんはわかってるねぇ。大根の煮物オマケだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022960003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……ありがたくいただこう。あとは酒！　酒もってこーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960002" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「任せときな！　うちの酒はどれもウマいから、驚くんじゃねーぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022960004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「任せた任せた！　支払いはこいつがするからあるだけ持ってきてくれ！　わ\nはは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960003" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「勝手なことを言ってんじゃねーぞ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "飲む前から酔っ払いモードのアナザー・ニャンコ先生とは真逆に、ダークエル\nフのクロートーは場の雰囲気にすっかり萎縮していた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「いざかや……というのは、この世界の酒場のようなものなのだな。人々の憩\nいの場……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ん。あれはなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "クロートーが視線を注いでいたのは、古い演歌歌手のポスターだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あれは演歌歌手という職業の女性ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「えんかかしゅ……とは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どう説明したもんかわからんが、情念たっぷりに歌を歌う大人のオンナ……\nって感じか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっとクロートーに雰囲気が似てるよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の一言に、ビール瓶をあけていたほむらがうんうんとうなずいた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ、アンタどことなく艶っぽい雰囲気あるからな。その上、美人で熟女で\n色っぽい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_010022960005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
 		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「このへんにたむろしてるジジイたちに人気爆発しそうな外見してるもんな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっ！　に、人気爆発……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960004" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……だ、誰であれワタクシを好いてくれるのであれば……嬉しいが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「であれば、あなたは演歌歌手とやらになれば人気が出るのではありませんか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022960004" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……そ、そうか。それはいいな。では……どうやったらなれるのか教えてほ\nしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960006" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ～。演歌歌手ったら着物で、髪を上げて～……歌を歌うんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960004" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「う、歌か。わかった。練習を積んでみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960007" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「一流の美女にしか出来ないシゴトだ……。正直憧れる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いっそ、全員で演歌の方向に進んでみるのはどうだ？　意外性があっていい\nかもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960005" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「えええっ！？　着物……ま、まあ高貴といえば高貴……ですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022960005" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……貴方はどう思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960008" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ？　お、俺の意見か？　そうだな～。悪くはないとは思うが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「オジサマ方向の人気しか取れないとなると、それはそれでリスキーでありま\nすな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022960002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだな。支持層を一点集中させると、他の層からの支持を捨てることにな\nる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960006" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そうか……。少しやってみたかったが……仕方あるまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960009" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でもなあ。他にこう、ドカッと人気が出そうな衣装っていうのもパッとは思\nいつかないよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960007" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「じゃあもう脱ぐしかないよな。ギリギリまで過激な衣装で攻めるってのはど\nうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これ以上過激な衣装となると……ワタクシは、ワタクシはどうなってしまう\nのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960010" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「全裸にラクガキだとか、全裸に淫紋だとか、もういっそ全裸とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022960009" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ありえません！　そんな下品な格好になるなどと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022960006" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「全裸に紐だけでも、フダ一枚でもニンジャは寒くないが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022960002" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……もうそれは服ではないとワタクシは思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022960011" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まったく同感と言わざるを得ませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022960003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう少しマシな案はないのか？　……カグヤ・ダーク！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺が指名すると、カグヤ・ダークはそのまま長い間考えにふけりだした……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「……私が案を出すのなら……ええと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022960003" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}