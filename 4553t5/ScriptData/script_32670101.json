{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……来たよ。メジェド到着……。でも、どうしてこんな夜中に……こんな密 \n室に呼ばれたのか。それがわからない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「この部屋、一見キレイだけど……なんだか禍々しい気がうずまいている…… \n。私はここで何をすれば、いいの？　……何もしなくていい？　どうして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……むしろ隊長さんが……私にマッサージをして、くれる……？　おお…… \n。手厚いもてなし……これがこの国の歓迎……？　すごくうれしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んっ……。こ、こう……？　ごめん……。私、誰かにマッサージなんてして \nもらったこと、ない……。だから作法がよくわからない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……隊長さんに全てまかせる。ゆだねる。……してほしいこと、あったら遠 \n慮なく言って。……それで……ええと、コレは……何？　説明がほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「女の子のお股のコリをほぐすマッサージ器具……。そうなんだ。エジプトに \nはないものだから……少し戸惑う。でも、隊長さんが言うならきっとそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103106" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私は別に、お股はこってない。でも……よもぎ蒸しという健康法もこの世に \nはある。ここをほぐすとたぶん、全身のコリがほぐれる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_01" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んんっ……？　マッサージ器具をあんまり動かさないでほしい。そこ、は結 \n構……敏感なところだから……。んんっ、あまり押し当てるの、だめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103108" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「粘膜に添って上下に動かされる、と、なんだか……ヘンなカンジになる。っ \nん……。あ、安定する位置を探して、る？　えっと、割れ目のところなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103109" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「そこにぴったりはめてくれたら、たぶんズレ……ない。うごかない。ん、そ \n、そこ……。ぁっ、その上はだめ、一番敏感なところ、だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103110" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「えっ？　ぁっ……き、器具……中に入れる、の……。んぁっ？　んんッ？　 \nううっ……？　あ……！　そ、そんなに奥に……入らない……んぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_03" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「は、ぁっ♪　ええ？　んんんっ……？　あぇ……？　そ、そんなに大きな器 \n具じゃないから大丈夫って……そ、そんなわけない。むり……むりだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103112" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私、自分の指だってそんなところに入れたこと、な……。いぃっ！？　あぅ \nうっ？　ほ、本当に……そこに何か入れたこと、ない……。あっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103113" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……う……。入っちゃったの……？　う、うん。思ったよりは浅い場所でや \nめてくれたから助かった、けど……抜いてはくれなかった……。うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「これをこんなところに入れて、マッサージだなんて本当かな……。私、もし \nかして騙されてる……？　……え？　う、うん。痛くはないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103115" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「入る時も、つぷっ、て簡単に入ったけど……。……それは私がちょっと漏ら \nしてたか、濡らしてたから？　そうなんだ。この穴、濡れたりするんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「直接胎内から……、身体の内側の、一番柔らかい粘膜から振動をおくりこむ \nことによる波動マッサージ……。あ、だ、だから中に入れたんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103117" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「わかったけど……わりと驚いたから。できればやさしくして。怖いことはや \nめて。これ、メジェド神との約束。……いい？　いいなら、始めていいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「一体何をどうするのかわからないけど……。って、んんっ！？　えっ？　え \nっ、あぅあぁっ、あっあっあっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103119" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「なに……これ、ブルブル震えて、る……！　ああああっ……、んぅ、こ、こ \nれが隊長さんの言ってたマッサージ……？　っぁっ……あっ、うぅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「知らない感覚がお股の中で……！　んっふ……！？　あっ……うぁあっ…… \n！　こ、こわい……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103121" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……こわい、けど……。ぐっと我慢？　う、うん……わかった……。隊長さ \nんが言うなら信じる……！　信じてる、けど……んっ、んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「お股がすごくむずむずして……膝が笑ってしまう……。私も長く生きてきた \n、と、思うけど……。は、はじめて、の、感覚……知らない、知らないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103123" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ふぁ……♪　太ももに、生あったかい液体が垂れて、きた……。これ、さっ \nき隊長さんが言ってた、濡れてる……ってこと？　濡れて、溢れてきた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103124" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ほ、本当にこのままでいいの……？　う、ううう……♪　どうしよう、なん \nだか……気持ちいい。ブルブルしてるのが、どんどん広がってって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「身体の全部に、は、波動、隊長さんの言ってた波動が届いているみたい…… \n。でも、これ普通のマッサージと、な、なにか、違う、ちがうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103126" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あっ♪　気持ち良さの種類が……、揉まれてるのと全然異なる……。んんっ \n！？　う、うぅっ♪　ゾワゾワする……とてももどかしくて……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103127" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ふぁっ♪　ぁっ……あっぁっ……。何も考えられなくなって、きた……。ブ \nルブル気持ちいい、ブルブルずっとしててほしい……。んっんっぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「隊長さんに見られていると……悪いことをしているみたいでソワソワする… \n…。ただのマッサージなのに、恥ずかしい……。っうぅ♪　ん～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103129" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んあ！？　や、やめて……隊長さん、手でお股、いじっちゃだめ……！　あ \nああっ、止まらなくなる……気持ちいいの止まらなくなる、から……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103130" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あ、くぅうっ！　そ、そこ、は……っ！　そこは一番敏感なお豆さん、だか \nら……クリクリしちゃだめ、だめ……本当におかしくなりそう、なの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あ、あああ……こわいぃ……っ。私は女神、なのに、知らないことがあるな \nんてぇ……！　んひぅっ、んんっ、気持ちいい、気持ちいいけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103132" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ご、ごめん……っ。何か、何かくる、何かでちゃいそう、だからおねがい… \n…やめてぇ♪　あっぁっ、と、止まって、気持ちいいの止まってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ッんんんんっ♪　ど、どうひてやめてくれにゃいのぉおお……♪　あぉっ♪ \n　おぉっ♪　んっ、んふっ♪　やだ、やだ、気持ちいいのだめぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103134" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「だ、め、なのにもうやめたくなくなってきたぁあ……♪　げ、限界……っ♪ \n　ひぁ、あぁ♪　だめ、だめぇ♪　気持ちいいのもう止められないぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103135" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ひぅうううううう……っ♪　ふひぃいいいっ♪　ひぃいいいっ、ううううう \n～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「うぁああ♪　ご、ごめんねぇ……！　マッサージの器具、大切な器具……ぬ \n、抜けちゃった……！　でも、お股に力が入らなくてぇえ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103137" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「あううっ♪　んううぅうっ♪　んふーっ♪　ふぅうううっ……♪　うううっ \n、気持ちいいのが止まらなくて、そしたらびゅーってお水が飛び出して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103138" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「こ、これっておしっこ……？　私、女神なのにおしっこ漏らしちゃった…… \n？　あ、あぁ、は、恥ずかしい……いっぱい出ちゃってるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「粗相をするなんてエジプトに申し訳ない、のに……！　ずーっと気持ちいい \nのがおさまらなくて……！　ずっとぴゅっ！　ぴゅっ！　って出てるぅう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103140" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はああぁあ♪　あったかい……♪　私のお漏らし、隊長さんに見られてしま \nった……。こ、こうなったら……証拠隠滅にビームで焼却するしか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103201" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「って、これはおしっこじゃない……？　な、なぜ？　血でもないし、透明で \n、あたたかくて、たくさん溢れ出した……。なのにおしっことは違うの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_07" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「しお……？　そ、そうだった。おしっこは透明じゃないし、こんなにサラサ \nラしていない……。これはマッサージが成功すると出る潮というもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103203" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「身体の中に溜まった悪いもの……。毒素を排出してくれる良いお水……？　 \nた、確かに……ここに来た時よりも身体が軽い、体温も上がっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103204" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……た、隊長、さん……。１つだけお願いがある。わ、私はさっきは何も知 \nらなくて……デトックスの潮が出るのが怖くて、わけがわからなくなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_08" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「だから最後の方は、ちゃんとコリがとれてない……ような気がする。も、も \nう一度だけ……同じマッサージをしてもらってもいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103206" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「うん。今度はこわくないから。潮でヌルヌルにしてしまったけど、マッサー \nジ器具も……そのぬめりで今度はもっと奥まで入るとおもうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103207" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……んっ♪　だ、だいじょうぶ……。一度経験したことだから、もう平気… \n…。それで、ブルブル……ブルブルして？　マッサージ早く、はやくぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……ひっ♪　あぁあああ♪　ブルブルきた……っ♪　ああっ♪　あああぁあ \nあ……♪　マッサージまたしてもらえるぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ふぁ♪　あぁあ……♪　あぁッ♪　あっぁっあっはぁあっ……♪　隊長さん \n……っ♪　見てる？　私がマッサージ、されてるところ……♪　あ、ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103210" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「私ばっかり気持ち良くしてもらって、ごめんねぇ……っ♪　あっ♪　でもこ \nの気持ち良さ……一度味わったら、ずーっと頭から離れてくれなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103211" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「またしたい、もっとしたい、いっぱいしてほしい……って思って、……うぅ \nうっ♪　他に何も考えられないの……っ。あう♪　はう♪　うう……っ♪」", "NORMAL" ]},
