		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「お豆さん、指の先っちょで転がして……あっぁっあっ、いい……！　いいよ \nぉ、くぅううっ♪　お股が麻痺してくる、声がおさえられない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103218" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
