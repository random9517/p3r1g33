		{"command":[ "SETIMAGE", "0", "still_00026701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「んんっ、んんん……！　んん……んんんっ！　お尻、自然に揺れちゃう…… \n腰を振って、マッサージ器具、お股に押しつけちゃう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103216" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「はぁっ、隊長さん……！　また、私のお股いじって……！　そうしたらすぐ \nに効果出そう、だから……！　……あっ♪　そう、そこ……割れ目の上っ」", "NORMAL" ]},
