		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ふぁあっ……１回目と同じ……♪　いけないことをしている気持ちになって \n……♪　それが、逆に気持ち良くて……あぅっ♪　ふぅっ、ううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_0103214" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「気持ち良くなってごめんなさいって、そういう気分で……っ。この遊び、人 \nに見せちゃいけない気がして……っ。なのにやめてほしくなくて……！」", "NORMAL" ]},
