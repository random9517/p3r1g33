{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_05" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "128_0104101" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「……それにしても、なんやねん、この状況は？　よぉ、ウチとこんなことし\nよう思たなぁ……ホンマ、ごっつぅ悪趣味やわ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104102" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「自分……隊長やからって、好き勝手し過ぎちゃう？　ウチと……ウチなんか\nと、こんなこと……マジでどっかおかしいんちゃう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104103" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「フン、わっかっとる……どーせ、チンコ挿れられたら、どんな穴でもエエん\nやろ？　ホンマお安ぅ見られたもんやで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104104" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「え？　そんなことない？　ウチのこと、魅力的……やって？　何言うてんの\n……アホちゃう？　何、調子エエこと抜かしとんねん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104105" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「そんなんこという悪い乳首はコレか？　ん？　この乳首がいらんこと言いよ\nるんか？　ほれ、ほれほれほれ～～～……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104106" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「あはは、なんやのん……自分、チンコも乳首もビンビンやん……。部下の身\n体を好き勝手に使って……エエご身分やなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104107" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ちょっとお灸を据えたらなアカンな……ふっふっふ……ちょ、何ちょっと嬉\nしそうなリアクションしてくれんのん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104108" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「そないに虐められるの好きなんか……へ？　この前の足コキで、ウチに虐め\nられて興奮するようになってしもた……やって？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104109" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ……ただでさえ変態の隊長を、ウチがマジモンの変態に育てあげてしも\nうたんやな……こりゃエラいことしてもうたわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104110" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ホンマ、ここらでしっかりお灸を据えたらなアカンかもしらんねぇ……ふっ\nふっふ……ほな、そろそろガチの本番、イクで……よいしょっと──」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104111" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ンッ、んんん～～～……くぅ、はぁ……ど、どう？　気持ち\nエエんやろ……そんなんわかってるわ……ホンマ素直な表情やでぇ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104112" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ウチはどうかって？　痛いに決まっとるがな、そんなもん……けど、はぁ…\n…ふぅ、あんまり痛ぅないで……むしろ、ちょっと……ん、んん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104113" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ふ、ふふ、今から、動くでぇ……チンコへし折れるかもしらんから、覚悟し\nーやぁ……はぁ、はぁ……んっ、くぅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104114" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「んあぁぁ！！？　あっ、はぁ……はぁ……あはははは……どない？　チンコ\n、ドエライこと、なってんちゃう？　ウチのマンコ、今ヤバいもん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104115" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ、チンコが、マンコの中……ぐちゃぐちゃにしよる……ホン\nマ、凶悪なチンコしとるでぇ……はぁ、あふゅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104116" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ん？　痛いなら無理しない方がいい？　何当たり前のこと言うとんねん……\nそこまで痛かったら、チンコもぎ取って終わりにしとるっちゅうねん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104117" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「そないに悪ぅないから、こうして……ん、んん……チンコでマンコ、グチュ\nグチュにかき混ぜてんねんでぇ……んん、あはぁぁぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104118" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……アカンわぁ、変な声、めっちゃ出るわぁ……もっと、こう…\n…偉そうに上から攻めてやるつもりやったのに……あふぅ、んんぅん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104119" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ほら、もっと腰を動かさんかい！　このフニャチン野郎……とか言うてやり\nたかったけど、今、ウチの方が、ヤバいからな……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104120" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「え？　いっぱい攻めて欲しい……やって？　ははは、アンタ、ホンマにヤバ\nいレベルの変態さんやん……まあええ、変態は正直嫌いちゃうしな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104121" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「よっしゃぁ……たっぷり、責めるでぇ……。はぁ、はぁ……覚悟、しいやぁ\n……はぁ、はぁ、あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104122" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ぐぅ、うあぁっ、グイグイ入ってきよる……。めっちゃ奥まで……うぐっ、\nうあぁっ、はぁ、ひぐぅ……きゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104123" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ふふふ、こ、腰を、こうやって、動かすんやろ？　ちょっとだけ勉強してん\n……ん、んん……ほら、どう？　結構上手いやろ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104124" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ウチ、身体動かすんは得意や……アンタはそこで寝っ転がっとったらええで\n……くぅ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104125" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「んん、ふぅ……チンコ、ビクビク震えとるで……はぁ、ふぅ……あはぁ、だ\nらしないチンコやな……部下にエエようにしてやられて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104126" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「何？　イキそうなん？　処女マンコにどっぷりと搾り取られるのって、どん\nな気持ち？　はぁ、ふぅ……なあ、教えてぇやぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104127" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「あははは、その顔、たまらんなぁ……今、エエ顔しとるでぇ……なんか、人\n生がそのまま顔に表れてるっちゅう感じやな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104128" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「あ、あっ、ヤバっ……めっちゃエエやん……チンコのビクビク、マンコの奥\nに入ってきよる……はぁ、んん、」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104129" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「なあ、なあって……チンコ、どんな感じ？　ああ、しゃべらんでエエ……そ\nのアホ面で大体わかるわ……イクんやろ？　なあ、イキ倒すんやろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104130" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「エエでぇ……お姫様の可愛いマンコの中、自分のきっしょいドロドロミルク\n、たっぷりぶち撒けさせたる……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104131" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁぁあん、アカン……アカンアカン……アカンンン……んッ、ウチ\nもっ、あ、あああ……ひぃ！　んん～～～……ッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104132" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「なんかごっつい気持ちエエのん、来よる……あぐぅ、きゃうぅぅ……ウチも\n、イ、ク……あ、あああ……くぅ……あうぅぅぅ……ッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104133" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……自分もイクん？　何、タイミング合わせて来よんねん……\nアンタが先にイキぃ……ふぐぅ、あぐぅぅぅ……ひうぅぅぅぅ！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104134" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はー……はー…………あへぇぇぇ……何なん、これ～～～……めっちゃ、\nエエやぁん……？　マンコの中で、チンコ、ありえんぐらい暴れとる……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104135" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「あ、あああ……ヤバ、ウチ、また、腰動いてまう……はぁ、はぁ……あああ\nあ、チンコ、たまらん……はぁ、はぁ……はぁぁぁぁん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104136" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「まだ出とる……せーえき、マンコの奥に集まっとるで……あはぁ、自分、何\nなん？　ウチを孕ませたいん？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104137" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「はー……はー……あぁぁ……チンコ……柔らかなってる……ちょ、もう～～\n……しゃあないなぁ……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104138" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「うわぁぁ……マンコの中からチンコが無くなっていく……溶けて、蒸発する\nみたい……チンコ……めっちゃ不思議やん……不思議のカタマリやん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104139" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「精液が……お腹の奥から、溢れてる……ドロドロが滴ってる……はぁ、んん\n……この感じ、めっちゃエエやん……はぁ、んふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "128_0104140" ]},
		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「……今回はこれで仕舞いにしとこか……けど、次する時は、もっとエグい責\nめ方するで？　覚悟……しときや……んふふふふ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012801_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}