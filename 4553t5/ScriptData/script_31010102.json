		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "101_0104401" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃ！？　はひぃぃぃ……！？　あ、あはぁ \nあぁ……精液が、いっぱい降ってくるぅぅ……ん、あぁ、んくぅぅぅ……」", "NORMAL" ]},
