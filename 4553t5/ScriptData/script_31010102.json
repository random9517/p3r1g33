		{"command":[ "SETIMAGE", "0", "still_00010101_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104402" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ、まあまだ出てる……こんなにいっぱいドロドロされちゃったのに… \n…まだ、出てる……精液、いっぱい、出てるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104403" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ……あはは……すごぉい……隊長さんの体温が、肌の上に広がって \n……ゆっくり染み込んでくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104404" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「やだぁ……感じちゃう……ああ、気持ちいいのが、身体に染み込んで、くる \n……ん、んぁ、はぁ……ま、またイッちゃ……あひぃぃ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104405" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あへぇぇ……オマンコがスースーするですぅ……ふぇぇ？　入り口が、パク \nパク閉じたり開いたりしてる？　あうぅ……見ないで下さいぃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104406" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……あふぅ……あああ、気持ちいい……身体が喜んでいます……精液を \n浴びて、全身がビクンビクンしてるですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104407" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、ああ……オマンコの奥から、精液が流れ出してくる……ん、はぁ……じ \nわーっと暖かくて、気持ち、いい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104408" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……はふぅ……隊長さん……このまま続き、するですか……？　え？　 \nああ、もうお仕舞いですか……ふぅ、少し残念、ですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104409" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……もっとしてみたいです……おかげ様で、いっぱいエッチな \nことしてみたくなっちゃったです……」", "NORMAL" ]},
