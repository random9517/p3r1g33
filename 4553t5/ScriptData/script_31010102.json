{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "101_0104101" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「とうとうこの時が来てしまいました！　はぁ……はぁ……え？　緊張してる \nか、です？　ええ、してます！　しまくってるですっ！」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00010101_01", "2", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104102" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「だ、だって、痛いんでしょ？　痛いのは、嫌いなんですぅ……まあ、サムラ \nイですからね、少々のことは気合と根性で我慢するですけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104103" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……でも、怖いなぁ……と、とにかく……気合と根性で乗り越えなきゃ \nなりませんね……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104104" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「サムライはビビったりしませんっ、常に前進あるのみです！　はぁ……はぁ \n……さあ、行くですよ～～～……そりゃぁぁぁ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104105" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ぐぅ、うあぁぁ……はぁ、はぁ……な、なんですか、これぇぇ…… \nちょ、い、痛い……です……痛いけど、なんだか……ん、んん、はぁ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104106" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、あそこが、こじ開けられてる、です……ああう、閉じてたところが、オ \nチンチンの形になっちゃってます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104107" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うっ、くぅ……苦しい、です～～……はぁ、はぁ……お、お腹が、持ち上げ \nられて……ぐぅ、ふぅ……胃がぎゅ～～って圧迫されてる気がします……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104108" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、は、入りました？　根本まで？　あうぅ……は、入るもんですねぇ… \n…ビックリです……じゃあ、次は引き抜くんですね？　わかった、ですっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104109" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ぐ、うう～～……あ……ああ……ひゃうぅぅ……ひ、引っ張られる……っ！ \n　お腹の内側が、オチンチンでよじれてる……ひやぁぁぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104110" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぐぅぅ……オチンチンにお腹の中身が持っていかれちゃいそう、ですぅ… \n…はぁ、はぁ……あふぅ～～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104111" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……ええ、痛い、です。痛いんですけど……でも、気持ちいい \nのも、あるんです……なんか、変な感じ、ですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104112" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「初めてのエッチ、みんな、こんな感じなんでしょうか……はぁ、ふぅ……で \nも、あなたに奪って貰えたのは、ちょこっと嬉しいです……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104113" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「さてっと！　隊長さんにも気持ちよくなってもらわなきゃです……ま、任せ \nてっ、下さい！　サムライテール・序が悪即斬しちゃいますっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104114" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「へ？　意味がわからない？　まあ、細かいことは気にするな、ですっ……私 \n、ちょっと混乱しているみたいですから……んふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104115" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ええっと、動かないと気持ちよくなれないんですよね？　だったら……はぁ \n、はぁ……動くしかないですっ……う、動きますよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104116" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「上手くできるかどうか自信ないですっ。でも、こーいう時は、結局気合と根 \n性です！　行くですよ……せぇの、ど根性～～～～！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104117" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ぐぅ、うぅ、うあぁぁ……入って、くるぅ……お腹の奥に、おちんちん、ぶ \nつかってる～～……はぁ、はぐぅ、んひぃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104118" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あ、ああ、腰を引くと、お腹が引っ張られちゃうぅ……おちんちんに、くっ \nついて、持っていかれそう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104119" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……あふぅ……い、痛いような～～……痛くないような……で、でも、 \nこの感じ、結構、好きかも、ですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104120" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あうぅ、それもこれも、隊長さんに色々されちゃったからですね……すっか \nり開発されました……ああ、こんなこと、司令に知られたら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104121" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「とにかく、もっと気合入れて、がんがん動かなきゃ……その方が気持ちいい \nです？　古人いわく、為せば成る、成さねばならぬエロ事もっ！　です！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104122" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ぐぅ、うっ、うあぁ……すごぉい……何、これぇぇ……あ、ああ、だ、駄目 \nえぇ……こ、んな姿……はぁ、はぁ……妹たちに見せられない……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104123" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んっ、んぁ、はぁ……アソコがちくちく痛いぃ……痛いのにっ、んっ、んく \nぅ……すごく、いい～～……はぁ、あっ、あっ、あああ……っ」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104124" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「動けば動くほど、アソコがピリピリ、しちゃいますぅぅ……はぁ、んはぁ～ \n～……気持ち、いい、ですぅ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104125" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃうぅ、あふぅ……熱いぃ……身体が、燃え上がっちゃいそう……はぁ、 \nはぁ……じっとり、汗かいちゃいましたぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104126" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はへぇ……やだ、隊長……そんなにエッチな目で、見ないでください \n、です……ん、ん……え？　おっぱいがすごくエッチに揺れてる……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104127" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひゃうぅぅ……そんなこと言われたら、は、は、恥ずかしくて……あぐぅ、 \nはひぃ……変に意識しちゃうじゃないですかぁ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104128" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「うくぅ……あっ、あっ、あぐぅ……た、隊長！？　急に、動かないでぇ…… \nはぁ、はぁ……んひいぃぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104129" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「え？　隊長も気持ちよくなってきたん、です？　はぁ、ふぅ……わかりまし \nた、じゃあ、私ももっと気合を入れて、本気で動きます！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104130" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ぐぅ、うおぉぉぉ！！　はぁ、はぁ……あああ、お、お腹が \nオチンチンに持ち上げられてる～～……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104131" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ、すごいぃ……痛くて、苦しいけど、気持ちいい……ああう、駄目ぇ \n……力が抜けちゃう……ぐ、うぅ、ど根性～～っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104132" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はひぃぃ……あ、頭が、ぼーっとして、きちゃった、ですぅ……はー……ん \nひぃぃ……あああ、駄目ぇ、やっぱり、力が入りません……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104133" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、あふぅ……や、やだ……オチンチンが、急にビクビクしてる……え \n？　イク？　わ、わかりました……イッて、下さい、です……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104134" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ！？　あはぁ！！」　駄目、オチンチンが弾んでるぅ……中で暴れて… \n…ひっ！？　やっ、きゃうぅ！　あはぁぁぁぁぁ……っ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104135" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あぁぁぁーーー……はぁ、はぁ……んひぃぃ……中で、熱いのが… \n…ビュクンビュクン……溢れてるぅ……ひうぅ……あふぅ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104136" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……すごぉい……お腹の奥が、ビクンビクン、してる、です……これ、 \nオチンチンが暴れてるんでしょうか？　それとも私のお腹……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104137" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ひぐぅ、んひぃぃぃ……気持ち、いいですぅ……これが、セックスなんです \nねー……あはぁ……勉強になりました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104138" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「勉強は大嫌いなんですけど、これは……もっとお勉強したいです……ふふふ \n、あはぁ……すごい……まだ精液、溢れてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104139" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んふぅ……気持ちよかった～～……あはぁ……これ、ハマっちゃいそう…… \nはぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104140" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「今日はこれで、お仕舞い……です？　え？　もう一回したい……？　え、え \nえもちろんオッケーですとも！　どーんと来い、です！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104201" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぐぅ！？　んはぁあ……はぁ……はぁ……あああ、た、隊長さんっ、容赦 \nないですね……はぁ、はぁ……そーいうところ、尊敬しますっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104202" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「わ、私なら平気ですっ、ふぅ、はぁ……全然、へーき、ですっ、からっ！　 \nふぐぅ、あふぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104203" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あああ、中でオチンチンが、動いてる……んっ、んん、中が精液でニュルニ \nュルしてる……んふぅ、あはぁぁん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104204" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「オチンチンに精液が絡みついて、ん、んん、オマンコの中に塗り伸ばされて \n……あっ、ああ、はぁ……精液いっぱいに広がっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104205" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、あはぁ……妊娠しちゃうですぅ……でも、ん、んん、これ、気持ち、 \nいいかも、ですぅ……はぁ、はへぇぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104206" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ……んん、もう全然痛くない、ですぅ……これって、精液がヌルンヌル \nンしてるおかげです？　はぁ……ん、はぁ、はぁぁん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104207" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……精液が、好きになっちゃうかもぉ……ん、はぁ……あああ、や \nだぁ、気持ち、いいですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104208" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……んふぅ……このまま、続けていいか……ですって？。もちろんです \nっ、どんどんガンガン動いて下さいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104209" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふふふ……激しくしてくれても、構いませんっ！　やせ我慢はサムラ \nイの得意技っ！　古人いわく、武士は痛くても大笑い、ですっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104210" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……さあ、どーぞぉ！　がつーんと動いて下さいっ！　はぁ… \n…はぁ……で、でもちょっとだけ手加減して下さいです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104211" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃぃ……っ！？　あっ、あっ、あはぁっ、ひぎぃぃぃぃ……はぁ \n……はぁ……あぁぁぁん……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104212" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「中が、グチュグチュ言ってる……オマンコの奥から、エッチな音が響いてく \nるぅ……ん、んん、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104213" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「すごぉい……隊長さんっ……すごすぎて、あ、ああ、変な声、出ちゃうです \nぅぅ……んっ、くぅ……はぁ、きゃうぅぅん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104214" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「んくぅ、あふう……オマンコ、いっぱい掻き混ぜられてる……精液が泡立っ \nてる……くぅ、あうぅ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104215" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁん、オマンコが変になっちゃうですぅ……ん、んん、隊長さん……も、 \nもっと、もっと……んん、あぁぁあん……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104216" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ！？　ひやぁ！　あはぁぁぁ……激しくし過ぎぃぃ……で、でも、すご \nくいいですぅ……はぁ、んくぅ、はふぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104217" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「き、気持ちいいのが、いっぱい入ってくるぅ……隊長さんも、気持ちいいで \nすぅ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104218" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、あはぁぁ……ダメぇ……変になるぅ！　私、壊れ、ちゃ……あっ、あ \nあ……はぐぅ、隊長さん……だ、ダメ……あ、あ、あああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104219" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そろそろイキそうなんです？　あ、ああ……嬉しい……私も、ん、んん、イ \nキ、そうですぅぅ……はぁ、はぁ……んん、あはぁぁぁ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104220" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「だ、出して、下さい……え？　中がいい？　外がいい？　ど、どっちでもい \nいですぅ……はぁ、はぁ……ダメッ、い、イイッ、いくぅぅぅ……っ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "101_0104301" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁぁ！！？　ひぐう、あはぁぁっ！　 \nひやぁぁぁぁ……っ！　子宮が、あ、あああ、子宮に……精液が、入って、ぐ \nっ、んひぃぃ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104302" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はー……はぇぇ……イッ、イッてる最中なのに、はぁ……ふぅ……精液を子 \n宮に浴びたら……頭が変になりそうなぐらい、気持ちよかった、です……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104303" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ……ひぃぃ……精液、ま、まだ出てるぅ……子宮の中に精液が入って、 \nくるぅ……ん、んん、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104304" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「中が、熱いぃ……はー……んふぅ……隊長さんの体温が、お腹の底にしみこ \nでくるみたいですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104305" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……んん、はぁ……隊長さん、おちんちん……まだビクビクしてるです… \n…はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104306" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「まだ気持ちいいですか？　ふふふ……私も、気持ちいいですぅ……はぁ、ふ \nぅ……初めてなのに、いっぱい感じさせてくれて、ありがとうですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104307" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ん……んんぅん……ああん、まだイッてる、です……私のオマンコ、まだジ \nンジンしてるですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104308" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ああ、セックスって楽しいです……苦しくて、痛かったのに……もうそんな \nこと、遠い昔の出来事って感じですね……えへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104309" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「今日はもう、これでお仕舞いです？　ううん……わかりました……私、長女 \nなので、物分りが抜群にいいんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "101_0104310" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「でも、ちょっとだけ名残惜しいです……えへへ、またエッチして下さいね… \n…絶対ですよ？」", "NORMAL" ]},
