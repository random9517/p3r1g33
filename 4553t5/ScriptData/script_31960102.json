		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ごめんなさい……ごめんなさい、アーちゃんがわるかったですぅう……！　\nごめんなひゃいぃい……！　お尻に、おしりにしゃせーしてくだひゃいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104219" ]},
