		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「すっ……ごく男らしいぃい……♪　あぁううう♪　す、好きに、しゅきにな\nっちゃうぅ……。おにーさんのモノにされひゃうぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　っひゅぅうう、ひゅー♪　ひゅー……♪　見てぇ……。ア\nーちゃんってば、おにーさんの色に染められちゃったよぉ……」", "NORMAL" ]},
