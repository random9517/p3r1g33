{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっはっ♪　今日も冴えない顔してるね～？　ぷぷぷっ、おにーさん？　暇\nならアーちゃんの相手をしてよ。他のコは相手してくれないんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「さびしーって顔してるよ？　どうするどうするぅ？　アーちゃんにかまって\nほしい？　遊んでほしい？　甘えたい～？　なんちゃって～？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「どーしてもってお願いするなら～？　アーちゃんが良いものあげてもいいよ\n～？　って……な、何！？　なにっ……いきなり押し倒して……あっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これっ……。これ、どーゆーことよぉ！　ちょっとぉ！　は、恥ずかしいじ\nゃないっ……ひっくり返すとか不敬、不敬～っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "PLAYVOICE", "v2_196_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お、おにーさん！　何やってんのよぉっ！　あたしにこんなことするなんて\n……い、いつもの仕返しのつもりなら怒るからねっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えっ？　お、おにーさん……なにマジな顔になっちゃってるのぉ？　いつも\nのイタズラのお仕置きをする？　や……やだなぁ、本気になっちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ！？　やっ……やぁっ……ああ！？　そ、そこはちがうでしょ！？　お\n尻の穴は……っ、ぁっ……何か入れるところじゃないのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ゆ……指なんか入んないからっ！　あっ……、わっ、ちょ……ちょっと！　\nさっさと諦めてよぉ！　ヘンタイ！　ヘンターイ！　やだやだやだぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んひぅうう！？　えっ……あっ……！？　うう……！？　んんんっ！？\n　ゆ……び、おにーさんの指が中に……。んん、んぁああ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「も……もぐりこんでくるぅ……。こんなの知らないぃ……。何？　なに、な\nんであたし……！　お尻を好きにされちゃってるのぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っぁ……ッ。あ……あ、あ、あ……！　ね、ぇ……ねえ！　おにーさん……\n。どうしてあたしのお尻をほぐしてる、の……？　やだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「中ぁ……。んぅう……！　ひ、拡げないでぇ……！　ねえ、お尻が広がっち\nゃったら、は、恥ずかしいから……。無理ぃ……！　っふ……ふぅうっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んっ？　お、おちんちんを入れるつもり？　ま、まさかね……？　いく\nらアーちゃんがナマイキだったからって……そこまではしないよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「や、やだやだやだ！　本気！？　本気で言ってるのっ……？　お尻の穴に入\nれるなんてやだっ……！　やめてよぉ、こわい、こわいよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ！？　……う……！　ふっ……！　ううぅううっ……！　本当に……ぃ\n、ほんとうにお尻にチンチン入れてくるぅうう……ッ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぃっ……！　あっ……い、痛い……いたぁい……！　は、入るわけないで\nしょっ、そんな大きさのおちんぽぉ……っ。じょ、常識で考えて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぐっ……！　うう……っ、ほ、ほらぁ……ほら、太さが合ってないから、\nお尻にそんな硬いの入らな……。ッんんんんっ！？　ふぅうううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あうっ……や、だ……！　ずぬんって入っちゃっ……たぁ……！　あたしの\nお尻に、おちんぽずぷんって入っちゃったぁ……信じらんないぃい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「な……なんでなんでなんで、おまんこじゃなくてお尻、なのよぉ……！　お\nにーさん、妙なシュミがあるんじゃないのぉ……！　んっんっンッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね、ぇ……っ。なんか動こうとしてない……！？　出来ないよぉっ、あ、ア\nーちゃんのお尻の中、そんなに広くないし……。あっ、狭いしぃ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「何か入れたのなんてはじ、めて、なんだからっ……！　あっ……あっ、やだ\n、やだやだ……っ。動かないで、うご、かれると、すごくわかるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お尻の粘膜がめくれちゃうぅ……っ！　あぅ、くうううんっ……。ふぅうっ\n……うう……！　あっ♪　あっ、ふ、普通のエッチみたいにしないでぇ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っあっ……！　奥っ……奥まで入れて……。んふっ！？　ずるぅって抜かな\nいで……！　今、今ちょっとだけ気持ちよく……。……はっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ウソっ……うそだもん！　アーちゃんが……。あっ……ううっ、うぅう～っ\n……！　お尻ほじられて気持ち良くなっちゃうなんて……うそぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「いや……い、や……やぁああ……っ。お、おにーさんが、おにーさんがヘン\nシツシャだから……っ、変態だからアーちゃんまで変にされちゃった……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんな、の……。あうっ、こんなのおかしいぃ……っ！　お尻、おしりで感\nじるとか、……あっ、恥ずかしい……ヘンタイになっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「い、いいのぉっ！？　おにーさん、可愛い可愛いアーちゃんが、お尻狂いの\nヘンタイになっちゃってもいいの……っ！　ねえ、ねえやめてよぉお」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「普通のえっち、させてあげるからぁ……！　ね、おまんこですればいいじゃ\nんっ……！　あっ！　んううっ！　だから、だからお尻だめだってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んんんん……ッ！　あっ……ぁっ、う、うぁ……♪　あぁ……、あっ……あ\nっ、あぁあ……っ、んくぅうう……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ、ンッ、んっんん……！　おかしいよぉ……お尻でなんてぇえ……！　\nあっ……！　ズポズポ硬いのが、出たり入ったりして……怖いのぉお」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ぁ……っ。こ、こわい……こわいのにぃ……ヘンな感じ……！　あっ、\nムズムズして……落ち着かない、お、おちんぽでえぐるのやめてよぉ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んうう……！　うう～っ……、う～！　うう……！　はうぅう……っ！\n　あ……あ、おなかが熱いぃ……、おちんぽおっきすぎて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「引き抜かれるのがはっきりわかるぅう……！　っんぅう！　な、に……？　\nどんどんおちんぽ膨らんで……。え？　せ、せーし出そうなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だ……め、だめぇ！　お尻の穴にしゃせーするなんて絶対だめなんだから！\n　ね、ねぇっ……やめてよぉ、だめだからっ……だめ、だめ、だめぇ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だっておちんちん、オチンポ生で入ってるしっ……！　あっ……！　アソコ\n、だったら出してもいいけど……お尻に出すのは変質者だからだめっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「抜いて……っ、抜いてったらぁ……！　抜い、て……！　ふぐぅうっ！　違\nうっ、精液出してってお願いじゃないっ、そっちの抜いてじゃないぃ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お尻に出すのは絶対だめぇええ……！　あっ！？　あっ、お、押し込まない\nで、おちんぽの先っちょ一番奥にねじこんじゃ……！　あああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぐぅうううう……！！　うそっ、ウソ、うそぉおお……！　ちょっとぉお\nおっ！　せいしっ、精子出てるってばぁっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「やだぁ……ヘンタイ、へんたいへんた～いぃ……！　　やぁっ、やらぁっ、\nやらぁあ、精子出すの禁止ぃい～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「焼けるの、お尻の中が焼けちゃうぅ……！　あっ！　あっ、熱い……熱いぃ\n、精液が染みこむぅう……！　もう出さないでぇ、あ～～～っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁ、はぁあ……。も、もぉいいでしょぉ……？　いっぱい\n出したでしょ……？　ねぇ……、チンポ抜いてぇ……お願いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっ……！？　ま、待ってってばっ！　なんでまたしようとしてるのっ……\n！　動くのやめてぇ……！　お尻、まだ熱いからだめぇえっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ……ううっ！　うぅうっ、う～～！　ねえ～っ！　せいえき……っ、せ\nいえきお尻に入ったままだから……ネチョネチョして気持ち悪いぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……けつまんこ？　ケツマンコにたっぷり中出しされた気分はどうだ、って\n……。へ？　ケツマンコって何？　そんな言葉初めて聞いた……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……わ、悪いメスガキのお尻の穴は、おちんぽをシゴくためのケツマンコ…\n…？　あ……、ち、違うもん！　アーちゃんのお尻はおまんこじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あんなに感じてたのに？　っうぐ……！　オマンコじゃなかったら気持ちよ\nくなるのはおかしい？　そ、そうかも……しれないけど……。んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「待ってよぉ、一回おちんぽ抜いてってばぁ！　入ったまんまじゃ、頭がぼー\nっとしてよく考えられないの！　あっ、あっ、ね、ねぇもうしないでぇ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんのおけつオマンコ……っ、ケツマンコ、ドクドクって入れられた\n精液でいっぱいだから……！　あっ！　あっ、突かれるとあふれちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ふぅうう……っ♪　ん、ふぅうう……ッ、ふんんっ……！　ふぅうう…\n…！　あうぅう……っ、ドロドロがお尻につたわって……。あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「い、やなのに……ケツマンコ嫌なのに、ヌルヌルでスムーズにおちんぽを受\nけ入れちゃってるぅ……！　おちんぽにケツマンコが絡みついてるぅう」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_02_11" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんなのって……こんなのってぇ……！　っはぅッ……！？　うふぅうっ！\n？　ふーっ、ふーっ、ふー……！　ズンズンやめてぇ、突かないでぇ」", "NORMAL" ]},
