		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ぅ、あ……！　ホントに、ホントにまずいのっ……！　アーちゃんのお\n尻、お尻の穴、ケツマンコ……おまんこになっちゃう、なっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104214" ]},
		{"command":[ "WAITINPUT" ]},

