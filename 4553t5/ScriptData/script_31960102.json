		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これっ……これ、気持ちいーのぉ！　いちばんいーのぉっ……！　あっ♪　\nあっ♪　言うこと聞くぅ、アーちゃんなんでもしますぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぶびゅっ、ぶびゅってお尻で恥ずかしい音がひてるぅう……♪　あぁああ…\n…ど、どうひよう……。ケツマンコでイクの覚えちゃったよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もう、もう一生忘れられないぃ……。お尻はイクところなんだって、おにー\nさんに教わっちゃった……。あたしのお尻、えっちな場所になっちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「認めるぅ……。あたしのお尻は、おにーさんのおちんぽを入れてヌプヌプす\nるえっち穴……♪　あたしはおにーさんには勝てない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ……アーちゃんが……アーちゃんがぜんぶわるかった、です……。ナマイ\nキなことを言ってすみませんでした……ぁ……。はぁ、はぁ、はぁ」", "NORMAL" ]},
