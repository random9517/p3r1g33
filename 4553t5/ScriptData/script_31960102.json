		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　ああっ……ああ、そっち……！？　アーちゃんのおっぱいと\n、身体に……ビュッビュするのぉ……！　っあっ！　ああっ……♪」", "NORMAL" ]},
