		{"command":[ "PLAYVOICE", "v2_196_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「これ……これ、ザーメンシャワーって言うんでしょ……？　んっんっ……♪\n　アーちゃんにザーメンシャワーキメられるのなんかおにーさんくらいだよ」", "NORMAL" ]},
