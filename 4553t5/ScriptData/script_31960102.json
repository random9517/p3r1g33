		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んッぁっ……ああっ♪　あったかぁい……♪　おにーさんのニオイで頭がク\nラクラするぅ……。んぁああ……！　すっごい量……っ」", "NORMAL" ]},
