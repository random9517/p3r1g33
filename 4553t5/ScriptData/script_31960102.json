		{"command":[ "PLAYVOICE", "v2_196_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんは……アーちゃんはぁ、本当は自分がヘンタイのヘンシツシャで\n、お尻でイくのが好きなメスガキなのにぃ……偉そうなことを言いましたぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だから、おにーさんに……。んっ……せいえきでお仕置きしてもらい、まひ\nた……♪　はぁ、はぁ、あ、ありがとう……ごじゃいまひゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「も、もうナマイキなことは言いませんから……。だから、アーちゃんを見捨\nてないでくださいぃ……。なんでもします、なんでもしますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「うっ、うう、ううう……。大人のオトコのひとに逆らって申し訳、ありませ\nんでした……。反省しまひゅぅ……。はぁ、はぁ、はぁ……♪」", "NORMAL" ]},
