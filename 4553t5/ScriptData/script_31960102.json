		{"command":[ "PLAYVOICE", "v2_196_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お尻……おしり好きぃ……！　おひりっ……うううっ♪　ケツマンコ大好き\nれす、アーちゃん、ケツマンコほじくられるの大しゅきなのぉおお♪」", "NORMAL" ]},
