{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ……！　隊の長！　隊の長！　一体どうしたっていうの？　ファンタズ\nマちゃんを……我をこんなところに呼び出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「二人っきりになりたかったぁ？　そうよねそうよね♪　他の場所じゃ、いつ\nも邪魔が入っちゃうし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「それで？　我と何をしたいの？　っていうかー……我に何をしてほしーのか\nなぁ♪　ドスケベエッチ、へんたいのおにーさん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んふ♪　わかるよ♪　エッチしたいんでしょ？　でもー。どうしよっかなー\n？　どうしてもっていうなら、遊んであげてもいーけどー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……なんちゃって。いいよ♪　我もあんたの……粗末なモノに興味あるし♪\n　あんたの弱みを握ってぇ♪　ちくちく責めるのもおもしろそーだし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はい♪　ちんぽ出して♪　ま、どーせ大したモノじゃないんでしょうけどぉ\n～♪　って、うわっ！　何っ、コレデカっ！　グロぉおおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019701_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……へ……？　へ？　何？　き、きーてないんですけど！　何この超ドデカ\nゴツゴツちんぽ……！　ま、ま、ま、待って、待って待って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「これは……無理。えっ……？　ヤバ……っ！　なんかくさいし、硬いし黒い\nし……生々しすぎ！　あ、あ、あ、ありえないんですけどぉお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　ビクビク動いたぁ！　……はぁ！？　な、何様よっ……この我\nの眼前で……そんな珍妙なものをふりかざしてさぁ……許せない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「え？　メスガキわからせ棒？　『俺は大人なのでメスガキには負けない』ぃ\n？　あは……いい度胸じゃない。その挑発、のったげる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「いつまで我の前でちょーしこいていられるか、試してあげるっ……！　この\nばかちんぽっ、ざこちんぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「大天才ファンタズマ様のお仕置きに、いつまで耐えられるかなぁ♪　……ほ\nらぁ♪　いっぱいぺろぺろしてあげる……。よく見てなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はむ……くちゅ、ちゅぷ、ぷっちゅっ……ぷちゅ、ぷちゅ、ぷちゅ、ぷちゅ\n……んん♪　まずはナマイキな亀頭にキース♪　あはっ……震えてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちびっこのおちんぽフレンチキッスで感じてるのぉ？　まーだ本気出してな\nいのにぃ♪　よわすぎぃ♪　ほら……もっと味わいなさい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちゅ♪　ちゅ、チュ……んん♪　ちゅ……ちゅ……。我の唇が柔らかい？　\nあったりまえじゃない……でも、舌はもっとすごいんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あーん……♪　れろ……れろっ、ぴちゃ……ぴちゃ、ぴちゃ……♪　あぁっ\n♪　ここ♪　先っちょ弱いんだ～。ウケるぅ♪　ぴちゃ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はぁ？　ダメだって言ったって絶対にやめなーい♪　ぺろ……ぺろっ、れろ\n、れろ……ちゅ♪　チュ、ちゅ、ぴちゃっ、ぴちゃ……れろっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我の口よりデカいちんぽことか、隊の長ってホント遠慮を知らないよね～♪\n　デカちんぽ振り回してぇ、こーんな可愛い我におしゃぶりさせてさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ガチのロリコン……♪　んん♪　ロリコンは粛正しないといけないよねぇ♪\n　おちんちん、しなしなになるまで舐めまくったげる～……ぺろっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ちゅ、ちゅ、ちゅ、ぴちゃ……♪　ぺちょ、ぴちゃっ、ぴちゃ、\nちゅく……♪　ちゅむ、ちゅむ、ちゅむ、ぷっちゅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あは……♪　しょっぱいちんぽの先っちょから、透明なお汁が出てきたよぉ\n？　これなーに？　もしかして感じちゃってるわけぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「へーんたい♪　へーんたい♪　もっと情けないところ見せなさいよぉ……ち\nゅぱっ♪　ぴちゃ……ぺちゃ……くちゅ、チュ、ちゅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「変な味させちゃってさ……あむ……♪　我の口の中に入りたい、入りたいっ\nておねだりしてるんですけどぉ……♪　きっもーい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぷ……入んないってばぁ♪　サイズ全然違うじゃん……♪　デカすぎて、\n舐め回すだけでちょー疲れるんですけどぉ……れろっ、れろ、れろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ソフトクリームを舐めるみたいにぃ？　……我に指示するとか、ちんぽも態\n度もデカすぎぃ……てか、こんな太いアイスがあるわけない、れしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん……ン、ん……♪　ぴちゃ、ぴちゃ、ぴちゃ……♪　くちゅ♪　ちゅぷ…\n…ちゅぷ、ぷちゅ、ちゅ、ちゅ、れろっ、れろ……れる、れるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぷ、やっぱダメ……♪　顎外れひゃう……♪　ちゅぷ、ちゅぷ……んぅ♪\n　冒涜的な凶悪ちんぽ♪　ヤりたいだけのスケベちんぽ♪　ちゅ、ちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我が成敗してあげないとだよねぇ……♪　ほら、ほら……きもちーんでしょ\n♪　ミニミニなベロでぺろぺろされてさぁ……それがいーんでしょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……あは♪　ばっか♪　ばっか♪　嘘ついたってわかるから……♪　口の中\nにちゅたわってくる、んですけどぉ♪　ちゅぷ、ちゅぷ、ぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んーーー……♪　くさくさおちんぽ、クセになりゅぅ……♪　はぁっ♪　見\nて、我の手じゃ握りきれなぁい♪　弾力ありすぎ♪　盛りすぎ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我のちゅばは……唾はあったかくて、ニュルニュルで気持ちいいよねぇ？　\nマセガキに、好き勝手に性感弄ばれて嬉しいの？　さいてー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んむ……ちゅ♪　ちゅ、ちゅぅ……♪　やぁ～～♪　口の中、なんかネバネ\nバしてきたぁ～♪　先走りの時点で濃すぎ、興奮しすぎ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「れろ……れろ、れろ、れろ……♪　んふふふ♪　ぴちゃ……♪　ぴちゃ、ぴ\nちゃ、くちゅ……♪　あっれ～？　めっちゃ痙攣してきてるけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「もしかしてイキたいの～？　我のお口に精子ぴゅっぴゅするつもり～？　や\nっだ、信じらんなーい……♪　んはっ……やれるもんならやってみたらぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなんじゃ、ファンタズマちゃんは負けないけどね～～♪　ぴちゃっ……\n♪　ほーら♪　やってみなよ～♪　ぺちゃっ……くちゅ、くっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ドロドロのあっつい精子で汚してみたら～♪　情けない声あげてさぁ♪　出\nちゃいます、出ちゃう～って泣きながら射精してよ、見てるからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あは……♪　れるっ……れるんっ、れる、れる……ぢゅうう♪　出ひひゃえ\n～♪　出ひひゃえ……んん♪　ぺろっ、れろっ、れろっれろぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あ～れ～？　ナマイキにも耐えるつもりぃ……？　いいよぉ～、それじゃあ\n勝負ひよ……♪　れろ……れろ、れろれろれろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ぷっ……♪　あれぇ……？　言うほどれもないりゃない……♪　おちんちん\nパンパ～ン♪　出ひたいクセにぃ……きゃははは♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「イーッちゃえ♪　イッひゃえ……♪　ぺろっ、ぺろ……ぺろっ♪　もう限界\nでしょ～……♪　あっ♪　来た来たきたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……！？　んぐぅっ……！？　んぶっ……んんん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちょっ……！？　ちょっ、ちょっと……ちょっとぉ！！　あぷっ！　んぷっ\n……んぷっ、はぁああ！？　な、何この勢いぃ……溺れ、溺れるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちょっとっ！　どんどん、どんどん飛び出してきて……んぷっ！　んーっ！\n　んーっ！　んんんんー……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あ、ありえないぃ……ぷぁっ、せ、精液……精液で溺れる……ぅ！　確かに\n、確かにイッちゃえって命令したけど、だけどぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こんな異常な量出せとか言ってないんですけど……んぐっ！　く、口で抑え\nてないとまだ先っちょから出てくる……ぅ、信じらんないぃい！　んぶ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ぅ……。う、ぅうう……！　お、おひゃまった……？　うぷぅうう……\n！　あ、あんたねぇ！　一人でスッキリしてるみたいだけどっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我、我のちっちゃなお口いっぱいに……んむっ、精子……垂れ流しにして…\n…！　ぜ、ぜったい許さないんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「けほっ、けほ……！　世界一強くて可愛くて尊い我に粗相をした償いをして\nもらうわっ……。お仕置きよ……いーい？　……はぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「今度は舐め舐めなんかじゃ許さないんだから……！　食らいついて、咥えて\n、しゃぶり尽くしてイジメてあげる……！　ん、ちゅぷっちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んー……！　くちゅっ！　くちゅっ、くちゅ……！　ぐちゅっ！　……んん\n？　ニ、ニヤケた顔しないでよっ……ばか、ばか、ばーか……！　えふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「まだ口の中ぁ……、あんたのくっさい精液がネチョネチョしてるんらから…\n…。それをこっちからも味合わせてあげりゅ……ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我の唾、と……あんたの精液……２つで口の中がヌロヌロれひょ……？　こ\nの状態でぇ……ぐっぽぐっぽしたらどうなると思うぅ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「その答えはぁ～……自分で確かめるのよっ……。ん、ちゅっぱっ！　くちゅ\nっ……くちゅっ……ぐっちゅっぐちゅ……♪　んぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んーーーーんむ♪　ぢゅるっ、じゅるるっ、ぢゅる……ぢゅるぅ♪　ぐっぽ\nっぐっぽっれろれろれろ……ちゅぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちっちゃな舌が絡みついれ、気持ひいいれひょ……♪　んれろっ、れろっ、\nれるぉ……♪　れろ、れろ、れろ……ぢゅるっ、ぐっちゅっぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んふふ♪　たまんないって顔ひてる……おもひろーい……♪　あんたのその\n顔見てると我も興奮ひひゃうわ……。っぢゅっぷっぢゅぷっぢゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぅうう……れろっ♪　んん～～？　もひかひてぇ、まーた出ひたくな\nっひゃってるのぉ？　あは……根性なさすぎて笑えるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「出ひたいんなら出せばいいけど～♪　我にやられ放題で恥ずかしくないのぉ\n～？　ま、やりたい放題出来るのは嬉ひいけどね～？　あはははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ほらほらイッちゃえ♪　出ひちゃえ～♪　出ひて我に屈服するのよ♪　……\nぐちゅっ！　ぐちゅぷっ！　ぐっぷっ、ぐぷっ、ぐっぷっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ばぁか～♪　ばかちんぽ……♪　れろっ……ずっちゅっ♪　ちゅる……ぢゅ\nる、ぐっちゅっ！　ぐちゅっ！　ぐちゅっ、はしたなく出せぇ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「っんんんん～～～♪　んぐぅ♪　んん、んーっ、んっ、ん～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あは……、上手に出せたりゃない……♪　けほっ、量が多すぎるのは減点だ\nけどぉ……♪　ねっとりネバネバでほんっと最高～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「もう、あんたは我のペロペロ無しじゃ生きていけない身体になっちゃったね\n～♪　どうするのぉ？　これからの人生、我に従わなきゃね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……って、むぅっ！　ま、まだ出てる……ッ！　んむーっ、も、もういいわ\nよぉ！　結構もらったしぃ……！　ん！　んむ！　んむぅう～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「っうぐぅうう……！　んえぇ……、喋り……にくいぃ……！　口の中でドロ\nドロが邪魔するぅ……。けぷ……飲むしかない、みたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やーだやだ、精液なんか飲みたくないけど……。……無理やり出させたのは\n我だってことで……今日は特別ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……んむ……。口の中で、唾と合わせてくちゅくちゅして……。くちゅ、く\nちゅ、くちゅ……一気に飲み干すぅ……♪　……ごきゅっ！　ごきゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んんぅ……！　えっぐい味ぃい……！　それにまずいっ！　くさいし最悪ぅ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「でも……。こ、こんなの我以外で出したら害悪すぎだし、あんたは我のもの\nだしね……。我がきっちり管理して、飲んであげるべきなのかもじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ファンタズマちゃんにぺろぺろちゅーちゅーごっくんしてもらえる喜びを、\n謹んで享受するのねっ！　ほーら、ありがとうございますって言って～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んきゅっ、……あっ！　ちょ、ちょっとぉ！　何腰引いてるのよぉっ……！\n　え、本気！？　ちょっ……ま、待ってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んきゃあああっ！？　きゅぅっ、うきゅぅううっ！？　……あっ！？　あっ\n、ファンタズマちゃんの、我の神聖なる顔に……直出しぃい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ううう、バカぁ何考えてるのよぉおおおっ……！　や、やぁあっ！　鼻に入\nるぅ！　目にかかるっ、く、口に入るぅ……！　んぷっ、んぶぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……くぅううう……！　よ、予想外のことしてくれちゃってぇ……！　せっ\nかく我が飲んであげようって思ったのに、顔に出すとかありえないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00019701_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……我の意表を突きたかったのぉ？　それとも、我の尊厳を破壊してぇ……\n顔に思いっきりマーキングでもしたつもりぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなのどっちでもいいけど、あんたは我のものなんだから……命令以外の\nことをする時には先に言わなきゃだめでしょぉ！？　びっくりするじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……言えば逆らってもいいのかぁ？　……う……う、それ、は……。それは\n時と場合によるもんっ！　よく見なさいよっ、この惨状を！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「美しい我の顔にべったり貼りついた精液っ……精液、せいえきーーっ！　よ\nくもまぁ、こんなくっさい汁を我にひっかけてくれたわねぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……うう……。ぬっちゃぬっちゃしてて取れないぃ……。あんたをからかっ\nて、遊んで、かまってあげようと思っただけなのにー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ひどいしっぺ返しを食らっちゃったぁ……。ねえっ、これ洗うのは手伝って\nもらうからっ……だから……このままにはしておかないでよね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}