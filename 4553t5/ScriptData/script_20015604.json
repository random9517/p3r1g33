		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ！　すごく強そうだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA",  "1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これが、私たちのレジェンド状態……。これなら、悪神にだって立ち向かえ\nる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670003" ]},
		{"command":[ "SETCHARA", "1", "char_00000216_01", "8", "CENTER", "500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いくらでも力が湧き出てくる……！　これならば。アナザー・稲穂姫にも勝\nてるはずだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "6", "CENTER", "-550" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「２人の力を合わせて……堕ちた稲穂姫にぶつけるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670004" ]},
		{"command":[ "SETCHARA", "1", "char_00000216_01", "7", "CENTER", "500" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はあああああああああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670006" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「悪行を悔い改めて！　アナザー・稲穂姫！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「ぐぁあああああああっ！　なんじゃ、なんじゃ！？　この神々しい光はぁあ\nあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「す、すげぇ！　この２人ならアナザー・稲穂姫を倒せるかも！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っくぅっ……！　あ、あと１歩……。なのに、最後の一押しが足りない……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670006" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えーっ！　あとちょっとなのにぃ！　誰かなんとかできないのーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「圧倒的な力を持つレジェンドだが、レジェンド時空でなければ、決定的な一\n撃に干渉できないのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670007" ]},
		{"command":[ "SETCHARA", "0", "char_00000131_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……それなら、とにかく今は足止め……！カツマたちならきっと、倒す方法\nを見つけてくれるはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670007" ]},
		{"command":[ "SETCHARA", "0", "char_00000216_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルたちじゃ……おてつだいできないのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……確かに、俺たちで２人の援護ができれば勝つことができそうだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今の私たちが割り込んだところで、風の前の塵と同じだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなんですよね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "神社なんだし、何か特別なパワーでもないかときょろきょろしていると、ちょ\nんちょん、と小さな手に袖を引かれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　お前はさっきの良い人か。どうした？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「……特別なパワーが欲しいのじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？　俺の頭の中で考えた言葉を、なんでお前が知ってるんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「まあまあまあ。理由は言えぬが、わしには１つ良い案がある。それに乗って\nみてはどうかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670003" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あやしすぎる申し出だが、他に手段がない今は助かる！　それで、案っ\nてどういうことなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そこにおるお嬢と共に、探し物をしてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670004" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お嬢……お嬢とは私のことか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ああ、そうじゃよ。おぬしらが探すのは、わしが昔に自分から切り離した龍\n神の力の断片」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670005" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「龍神？　お前……龍神だったのか！　まったくわからなかった……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何！？　わからなかった？　これだけの龍の力を振りまいておられるこの御\n方の存在感に気付かなかったのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「正直、まったく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はーっ！　これだから貴様はヌルくてダメなのだ！　私なんて、偉大なる龍\nの神……この目で見つめるだけで震えが止まらないというのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「お嬢。わしの話はそれくらいにしておくがいい。今はあの、闇の稲穂姫を止\nめる方が大切であろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670006" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そうかそうか。婆の名はクラミツハ。かつてこの神社に隠した、婆の力の断\n片を探すのじゃ。さすれば望むものが、自然に手に入るやもしれん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670007" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はい！　先生！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はい！　せんせー！」", "NORMAL" ]},
