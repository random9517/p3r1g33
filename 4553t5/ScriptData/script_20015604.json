		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの～、すみません。この神社の神様……稲穂姫ってどこにいるかわかりま\nすか？」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ああ、稲穂姫様でしたら……ええと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_010023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00022003_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "STOPBGM" ]},
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETTEXT", "俺がバニーママに稲穂姫の居場所を聞いていた最中、再び境内から大きな爆発\n音が聞こえた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわああああっ！？　こ、こんな人の多いところでっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これは……先ほどの気配と同じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「いや……もっと大きな力が溢れ出しておるようじゃが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_010023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アナザー・稲穂姫" ]},
		{"command":[ "SETTEXT", "「ククククッ、その通り。妾の負のエネルギーは、高まりに高まっておるとこ\nろじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_030023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「わあああっ！？　どんどん爆発が増えてくよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「すごく危険なオーラ……。このままじゃ、神社がボロボロになっちゃう、か\nも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "爆炎から出現したアナザー・稲穂姫の威圧感は凄まじかった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00024103_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……俺たちじゃ手に負えそうにないぞ！　どうすれば……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……カツマ。心配すること、ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うえぇえ！？　カ、カグヤ！　さっきの巫女さんってお前だったのか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから本人だと言っただろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「せっかくの穏やかな正月を、乱す悪党は許せない。新春初退治させてもらう\nとしよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とはいえ……一体どうやって？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今こそ、あの力を我が身に宿す時！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あの力？　あの力ってなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私たちはたくさんの人に応援してもらった……。その恩を今、返す時」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉおおお！　なんだかよくわからんが、人気投票で得た力が２人に集まっ\nてきている気がする！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "STOPBGM" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「変身……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670003" ]},
		{"command":[ "PLAYSE", "SE_gachaAori_SSR1" ] },
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "FADEINIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEOUTCHARA", "0", "VERYFAST" ] },
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「すっげえ！　２人とも、ビカビカ光ってめちゃくちゃ正月だぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ま、まばゆい光で周囲がまったく見えませんぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023670001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_026" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……どうだ？　見事に変身できただろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023670004" ]},
		{"command":[ "FADEOUTIMAGE", "1", "VERYFAST" ] },
		{"command":[ "FADEINCHARA", "0", "VERYFAST" ] },
		{"command":[ "SETCHARA", "0", "char_00000131_01", "6", "CENTER", "-550" ]},
		{"command":[ "SETCHARA", "1", "char_00000216_01", "6", "CENTER", "500" ]},
