	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「はいはい……。あ、な、た……のスイレン・アファナシエフです。冗談です\n……。どうしたんですか、緊急招集だなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私もそんなにヒマではないのですがー……。と、すげなくお断りしたいとこ\nろですが……副艦長の私がそんなことをして、みなに迷惑がかかったり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ましてやあの、ポヤポヤ艦長がまた余計なことをしでかすと困るのでー……\n。はい。私がお聞きします。なんでしょう。何用でしょう楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……はあ。特殊トレーニング……ですか。それは夜の？　と、気軽に下ネタ\nを挟んでみましたがー……どうやら図星のようですね。隊長……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103104" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「夜のトレーニング……。うん……。どういう反応をすべきか迷います。悲鳴\nをあげるべきか……恥じらうべきか訴訟を起こすチャンスか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「なんて、これも冗談ですよ。ジョークジョーク。私も、隊長とはそれなりに\n親交を深めておりますので、貴方が無意味な言動はしないのはわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103106" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「で、そのトレーニングをすると何が得られるのか教えていただけますか？　\nその内容によっては脳内審議します。はい。するべき行為はパイズリ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あれ？　これは……隊長のただの好みのプレイでは？　私、調査済みですよ\n。隊長の性癖とか。ただ単に、巨乳にパイズリされたいだけでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103108" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……はあ。違いますか。誤解……ですか。実際、みんなこれで強化されてい\nる、と。不思議なこともあるものですねー。ぶっちゃけ嘆かわしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103109" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「でも……。はい。パイズリくらいならいーですよ。いきなり処女膜ぶち破ら\nれるのはちょっとですが。それくらいの恩は感じておりますので……ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103110" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「で。あーのー……こんな感じで、よろしいでしょうか……。んっ……すみま\nせん。何分、初体験なもので……多少のぎこちなさはご容赦を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103111" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「男根……。こんなにも、私の胸にずっぽりと、うまくハマるものなのですね\n……。柔らかい、ですか？　はあ……ありがとう、ございます……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ええと……。ここからどうするんでしたっけ？　胸を股間に押しつけながら\n……。はい。上下左右に揺らしつつ……。はぁ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「なる、ほど……。乳房全体の重みと圧力でペニスに快楽を送り込むんですね\n……。何食べて暮らしてたらこんな異常なこと思い付くんでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……いえ。文句ではなく……。不思議、で……。今まで、自分の胸をそんな\n風に見られているとは気づきませんでしたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ンッ……！　んっ……んっ……ん……！　ふわ……っ、これっ……かなりの\n重労働では……？　あっ……乳房、上に……あっ、下に……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「左右にズラして……あ……、あ……！　直線的な動きから……、っはぁっ、\n円を描く、ように……んん、はぁっ……はぁ、くぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「や、だ……。汗が滲み出してきます……。それがいい……？　ああ、なるほ\nど……。隊長は変態さんなんですね……いい、ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「変態相手にだったら、こちらもマイペースに出来て……助かります。どうせ\nなら、色んな動きをやってみたかったので……。っいぇーい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁ、はぁっ、はぁ……。どう、ですか……。波のように揺れて\nみたり……。不規則、に……乳房でプレスしたり……んんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あー……。隊長の言葉より早く、男根の方がお返事してますよ？　ダイレク\nトな賞賛、まことにありがとうございます……。こういうのがいーんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「限界ギリギリまでおっぱいで押し潰して……ずりずりずり……。ふっ……上\nから下に……。んっ……下から上に……ぃっ、ぬふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ペニスは喋れないはずですが、台詞がなくても悦んでいるのが伝わってきます\n、ね……。ビク、ビクして……自分から頭をおしつけて、きて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「謎の宇宙生命体ってカンジで、グー……ですよ。ちょっと臭い、ですけど…\n…あっ、反応があればこっちもやりがいがあります、し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ン……ふぅっ、ふぅ、ふぅ……ふっ……。ふぅう……っ。ン、ぁ……。はい\n……？　両手でもっと胸を寄せて？　ああ、やってみます……。ふんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ……♪　こ、れ……ペニスがぐいぐいめりこんでき、て……。ふぅうっ\n……！　存在感がハンパないです……くぅっ……うう、ふぅう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「む、ねをこじ開けられているような……っ。ぁっ……力強さ……。はぁっ…\n…、強引、で……野蛮な……ケダモノのような押しの強さ……はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私の胸の中を泳いでいるよう、で……。あっ、捕まえるのに苦労します……\n。で、も……その追いかけっこが……。ふぅうっ♪　あっ、あっくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……んんっ、ん、ぁ……！　……え？　スイレンの下品なスイレンっぱいが\n気持ちいい？　デカすぎて視界が幸せ？　そ……そう、ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私、は……男根でぐねぐね形が変わる自分の胸が少し怖い……ですけど……\n。ン……、でも、まあ、嫌な気分ではない……です……ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私の胸で、隊長が気持ち良くなってくれるなら……いいか、なって……。あ\nっ……なので、せっかくなんで……よくなっちゃってくださ、い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「スイレンの……私の、大きくてパンパンに膨らんだロシアン娘っぱい……♪　\n純日本人のものより、白くてパン生地みたいに張りのあるロシアっぱい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「どうぞご堪能くださ……い……。ん……！　はふ……、ふぅっ、ふぅ……ふ\nぅう♪　あっ……あ、あ……！　妙な気分、です……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「使っているのは上半身、なの、に……。あっ♪　腰が……いいえっ、それよ\nりもう少し、下が……ゾワゾワして、落ち着かなくて……はぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「モジモジ、してしまうような……。はぁっ……♪　脚がしびれ、て……あっ\n、そのソワソワが、ジワジワが胸に伝わってくるような……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「は、ぁああ……っ、あっ……あっ、あぁ……ああ……！　なに……？　なに\n？　あっ……気持ち、いい……あっ……どうして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「男根を喜ばせている私の方が……、私の胸の方が感じるなんて……。く、ふ\n……、おかしい……です、やぁ……。あっ……あっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「す……みません、おかしな声を出してしまって……。でもこれ、自然にもれ\nちゃ……あっ♪　ぁっ……あ……！　隊長……はぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私だけ感じるなんてイヤです……。隊長も、隊長も情けない声出して、感じ\nてください……早く……はや、く……でないと不公平です……はやくぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「い……一緒、に……。んっ、く……くふぅっ……ふぅ……！　ま、まだ、で\nすか……！　こっちが先にどうにかなりそうです……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ッふぅううっ……やっ、た……やり、ました……。ふふー……♪　私の勝ち\n、ですねぇ……。ビュービュー白濁液噴射しちゃってますー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「勝負していたつもりはない？　まさかまさか……。いいんですよー、しょう\nがないですよねー。私のおっぱいが強すぎたんでしょうー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「さ、遠慮なくたくさん出しちゃってください……。なにせ、お乳が大きいで\nすので、出すべき部分がいくらでもありますからー……なんちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んっ……ふふ……。ドクドク、ドクドク……こんなにも……。見てください\n、胸がホワイトコーティングされちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「生クリームよりずっと重い……。それに……むわぁーってオスの臭いが広が\nって……。あは……おっぱいに種付け～ってカンジですねー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「真っ白で、ネトネトして……気味が悪いくらいヌルヌルしていて、あったか\nくて……。へーえ……精液ってこういう感じなんですねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「たぶん汚いものだと思うんですけど……。なんか、嫌いになれないというか\n……。胸だけじゃなくて全身、まーたウズウズしてきたというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「はっ、まさか男性の子種には、女を狂わせる媚薬成分が入っているのでは？\n　それか……エッチな雰囲気にするフェロモン……ですよね、隊長？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ん……これだけ出してもらってなんですが……。すみません。私、今のでイ\nけませんでしたので……続行します。いわゆる二回戦というやつです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……むふふ、そうです。私は自分勝手な女……。……は、ぁ、あ……♪　す\nごい……。白濁液、胸の輪郭をすべりおりて……エッチです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「で、も……地面に落とすのはもったいないのでぇ……。ん、う、んぅ、うー\n……♪　すくいあげて、お互いの、敏感なところにぬーりぬり……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ああー……なんだかイイ感じですよ～？　は、ぁ……いけないことしてるー\nって感じが……あっ……わかりますよね？　んふ……♪　ふぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私と隊長、どっちも精子でベトベトになりながら……あっ、お乳とペニスで\n激しく交わるん、です……すさまじい背徳感じゃないですか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「それに、ヌメって動かしやすくなって……あっ♪　ヤバーいです……今度は\n♪　こっちもそんなに長くもたない、かも♪　んっ、ンッ、んっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「気合い入れて１００％の熱意でモニュモニュしちゃいますから……。私がイ\nくまではイっちゃだめですよー……。そぉれ……それ、それ……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あ、は……あぁ♪　あんっ、ぁ、あ……♪　やだー♪　隊長もすーっかりソ\nノ気じゃないですかー……。むふ、いーですよ。腰打ち付けてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「二人でぐっちゅんぐっちゅんしましょー……♪　ん！　んーっんっ！　おっ\nぱい乱舞ー……♪　前後左右どころか、大回転～んふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あッ♪　あっ、は……！　やぁだ、コレすごい！　す、ご…\n…あっ！　二人の動きで、摩擦で精液が、触れてるところが熱くて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ……す、すみませんー……！　今度は私っ……私、イキそ、うです……\n嘘ぉ……胸だけで隊長にイかされるなんてー……ま、負けちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んっひっ、ひっあぁ……！　胸っ、胸熱いっ……あつぅい……♪　ごめんな\nさ、い……イきます、パイズリしながらおっぱいでイキまぁすううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ……♪　ひィっ……ひぃっ……んいいいいいい♪　イクぅ、イ\n……く、すみませぇえん……っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、あッ♪　こん、な予定じゃなかったんですけどー……っ、私\nが隊長を一方的にもてあそぶつもりで……あっ、だ、だからでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「天罰ぅ……？　んぅっ、んうううううー……！　悔しいです、射精……胸に\n出されるのクセになって、それでスイッチ、入るっていうかー……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長のがビチャッて♪　ビューッて胸にかかると、ぶちまけ……られると♪\n　電撃に撃たれたみたいにカラダ……身体、おっぱいがビクーッてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　も、もうこんだけぶっかかっちゃってるんですから、これ\n以上はノーカンですよ……好きなだけかけてください、どう、ぞ、あ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んんんんー……♪　んんっ……！　あ、あぁ～……♪　結構バストサイズ、\n自信あったんですけどぉ……。隊長の精液に覆われちゃう程度でした……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ていうか、隊長が出し過ぎですよねー……。んっ……私の胸、そんなに良か\nったですかー？　パイズリ相性がバツグンってことですかー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……あっ、あっ……♪　私の胸……隊長のでミルクコーティングされちゃい\nましたねぇ……。ちょっぴり情けなくて、屈辱的で……でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「その何倍も気持ち良くて……。……男の人ってズルいですよね、男根で無理\nやり女……、制圧してきて。エロくてズルくてワル、ですよねー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　たっぷたぷのおっぱいにたっぷたぷの精液ぃ……。サービス\n過剰なくらいに射精してくださってー、ありがとうございました……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あッ♪　イ……く……！　んー……！　んふ……んぅ……んんー……！　っ\nて、あっ！？　た、隊長！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「か、お！？　顔に射精とか、越権行為では！？　軍法会議モノですよ……っ\nて、わぁあ！　止まらないですよね、あっ……ンン！　ん～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「もぉお……っ。あっ……！　はい……。待ちぼうけでおあずけのロシアっぱ\nいは……。お顔に出された精液の受け皿にさせていただきまーす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ンッ……んっ、んっ……。むっちゃ、信じられないくらい出ますねー……？\n　もしかして、私の胸よりも顔が好みだったとかー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「どっちも？　ぷっ……素直に褒めていただいたのでー……。顔にかけたこと\nは不問にさせていただきますー……。と、言いたいところですがー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あ、ふ……♪　顔の表面をダラダラ流れる精子……。この唯一無二の感覚、\n当分忘れられそうにありませんよー……。あっ、こびりついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私の肌が……頬が、顎が……唇が隊長さんの味になってしまったら、どう責\n任を取ってくれるんですかー……？　くさぁい……生あったかい～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……隊長……。やりたい放題やっておいて、私の惨状を見て笑うとは……。\nさすがにいかがなものでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「怒ってはいませんけど、……決めました。次は私が攻めますからー……！　\nうん、そうします。今度はこっちがイニシアティブとりまくって～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長をアヘアヘのガクガクにしてさしあげますから、お覚悟を……。顔に出\nしたのは、その前払いだと思っておきますねー……♪」", "NORMAL" ]},
