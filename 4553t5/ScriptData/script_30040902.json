		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……あぁ……からだ……熱い……ムズムズするぅ……\nんぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なぁ……きょ、今日……するんだろっ？　ほらっ……ちゃんとポーズ取って\nるからぁっ……お尻もオマンコも……全部見せてる降参ポーズぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「どんなことでもしていいからぁ……んっ、あぁっ……バレンタインらしいこ\nと……？　んっ、何でもいいっ……それでいいからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！？　あっ……何を塗ってっ……こ、これっ、あっ……チョコ……ク\nリーム……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私のからだっ……チョコと……一緒に味わうのかっ？　んっ、あっ、ひぁぁ\nぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……お尻に……チョコがっ……んんっ、あぁっ……オマンコにも……\n塗られてるぅ……はふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「これを……あっ、んぁぁぁんっ、あっ、あひっ……！　あっ、舌がっ……オ\n、オマンコっ……くすぐって来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、甘いって……そ、それはっ、チョコの味だろっ？　あっ、\nあぁっ、酸味もあるって……ひ、ぁっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「い、一緒に……汁も舐められてるのかっ？　あぁっ……オマンコのお汁っ…\n…どんどん、溢れてる感じ……するっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁっ、そこっ、そこぉっ……あぁっ、んくぅっ……ゾクゾクっ\nてする……舌が当たるの……気持ちいいよぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぅんっ！？　あっ、そ、そこはっ……お尻の穴っ……なっ、チョコっ……\nそんなとこにまでっ？　あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んはひっ！　あっ、あぁっ！　ダメっ……そんなとこっ、あっ、あぁっ……\n一緒に……舐めるなんてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「び、敏感ってっ！　こんなトコっ……普通に出来るワケっ……ないしっ、あ\nっ、あぉぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……オマンコとっ……お尻の穴っ……交互に舐められてっ、はへぁぁ\nっ、わらひっ、こんなのっ、もっ、もぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「らめっ、も、もうイっひゃうっ！　お尻の穴っ……ペロペロされてっ、はひ\nぃんっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　はっ、んぁっ……あっ……ふぁ……イ、イッちゃったぁ…\n…あぁ……舌……すごいのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……でも、まだムズムズ残ってる……奥の方が……待てなくなってる\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なぁっ……こ、これで終わりじゃないだろ……？　ちゃんと……続き……し\nてくれるだろっ？　するっ、おねだりちゃんとするからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んぁふっ、お願いしまひゅっ……今度は……チンチン……私のっ\n……ウズウズしてるオマンコに入れてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お尻の穴とっ……オマンコ舐められてぇっ……発情したメス犬マンコぉっ…\n…どうにかして欲しいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンッ……チンチン入れてぇっ……お願いっ……オマンコにチンチンッ\n……ずぶってしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はひぃぃぃぃんっ！　あぁっ、んぁぁぁぁぁっ……は、入って……来たぁっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ、んくぅんっ！　あぁっ、太いのっ……広がって入って来るっ…\n…！　はぁんっ、こ、これぇっ、これが欲しかったんだぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、あぁっ……中……ずぶって埋まってるっ……あぁっ、お願い\n……チンチン……激しく動かしてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「発情してるっ、欲しがりマンコっ……あぁっ、もっといっぱいズボズボされ\nたいっ、あっ、んぁっ、ああっ、そ、それぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あひっ、はひっ、はんっ、あぁんっ、気持ちいいっ……！　ずっと待ってた\nからっ、あぁっ、オマンコッ……勝手にヒクヒクするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、それっ、奥のトコっ……もっとコンコンしてっ！　チンチンでっ、オ\nマンコの一番深いトコっ！　ぐりってくっつけるのっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ……んぁっ、指……なに……？　あっ、チョコ……舐めるの\nぉ……？　んっ、ぺろ……れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んふっ……甘い……チョコの味だ……これを……私のオマンコと一緒に味わ\nったんだな……はっ、んふっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そんなこと考えたら……あっ、あぁっ、またっ……ウズウズしちゃうっ、気\n持ちいいのっ、止まらなくなるっ、くんっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「もっとっ、あぁおっ、かき混ぜてっ！　あぁっ、チンチンっ……ぐりぐりか\nき回すのっ、それっ、あひぁっ、今のが好きぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あんっ、んぁぁんっ、はっ、あぁっ……もっと躾けてぇっ、私のヌルヌルオ\nマンコぉっ、全部チンチンで埋め尽くしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はひぁっ、あぁっ、いいっ……止まらないっ、気持ちいいの上がってきてる\nっ、私っ……あっ、も、もぉっ、待てないっ……イ、イク、イッちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ！　また激しくなってっ！　んぁっ、あぁぁぁっ、そんなに\nっ、あっ、されたらぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「イクのっ！？　うんっ、私もイクからっ……出してっ！　中にっ……オマン\nコっ……いっぱいっ、中出ししてぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁっ！　あぁっ……出たっ……精液っ……はひぃっ、あっ、中に\nっ……来てっ……あぁっ、いっぱいにされてるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、流し込んでぇ……ホワイトチョコ……オマンコの中……いっぱいに\nしてぇ……はぁぁ……んふぅぅ……あ……ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……出たぁ……オマンコ……いっぱいにさせられちゃ\nったぁ……はふぁ……ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ、中で白いの……びゅくってしてる……ふぁぁ……この感じが\n好きなんだ……気持ちいいの……ずっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あふ……しばらくこうしてたいな……んふぅ……このままが……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ……なぁ……まだ、これでもう終わりって感じじゃ……ないだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私は……まだ続き出来るし……お前のチンチンも、ほら、その元気いっぱい\nって感じだし……だから、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「つまりっ……もう一回するってことっ！　ほらっ、私からも動くからっ、ん\nぁっ、はっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、あっ、あひぁっ！　やっぱりっ……あっ、すごいっ……！　\n中……さっきよりっ、熱くなってるっ……んくぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、あぁっ、お尻っ……振るっ！　こうしてっ、フリフリするの\nっ……好きなんだろっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ちょっと、恥ずかしいけどっ……私も気持ちいいしっ……それで、そっちも\n気持ちいいならっ……もっといいしっ……あっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んくぁぁ……深いところまで突き刺さるぅっ……お腹の奥っ……オマンコ…\n…ジンジンして……か、感じるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……チンチンそこっ、グリグリしてぇっ……んぁっ、あぁっ、やっぱり\n上手いのっ、はぁんっ……変にっ、なるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ね……も、もう少し強くてもいいからぁっ……もっと激しくズボズボってし\nてぇっ……ぶっすりチンチン突き刺してぇっ、はひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、それっ、それぇっ！　あぁんっ、じゅぶじゅぶって音するっ！　精\n液っ……オマンコの中で混ざる音ぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、私の汁もっ……また溢れて来ちゃうっ……あっ……な、何\nして……んんっ！　また、お尻にっ……あっ、チョコぉっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ、あぁっ……そんなっ……今、そこっ、舐められたらぁ\nっ、はひぃっ！　ゾクゾクするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁっ、チンチンも動いてるっ、くぁぁっ、一緒にされたらっ……おかしく\nっ、あひぃっ、おかしくなっちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んくぁっ……でもっ、これがいいっ！　何度もチンチンで突かれるのっ……\nあっ、あぁんっ、気持ちいいからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ぐりってっ……はぁんっ、今のっ……あひっ、もっとしてっ、オマンコ溶か\nしてぇっ、んぁっ、ふぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうだっ、んぁぁっ、これが好きなんだっ……後ろからっ、メス犬みたいに\nっ……チンチンされるのっ、あぁっ、好きぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そっちもっ……また……イキたくなってるっ？　んんっ、ダメだぞっ……我\n慢したらっ……ちゃんと出すんだからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私もっ……最後っ、頑張ってお尻振るからっ、はっ、チンチンっ……いっぱ\nい気持ちよくさせるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んはぁぁぁんっ！　いいのっ、好きなだけ出していいからっ、来てっ\n！　どこでもっ、精液っ……白いのっ……びゅるびゅるってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私もイクっ、もぉっ、イクのっ！　あはぁぁぁぁんっ、も、もぉダメぇぇぇ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ！　中にっ……いっぱいっ、あぁっ、出てきてるっ……また\n熱いの……びゅーびゅーっ……届いてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ……あぁっ、２回目なのにすごい……ってか、２回目の方がすご\nいかも……あぁぁ……溢れて出てきちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、あぁっ……まだチンチン動いてる……精液出されながら……\nまだオマンコズボズボって……はぁぅっ、んっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「大丈夫……続けていいからぁ……その代わり、ちゃんと最後まで全部出して\n……精液、私の中に出し尽くしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……ゆっくりになって来た……でも、出てる……んんっ、はぁ\n……やっぱりすごいな……お前は……はぁ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……終わった……？　出し切ったんだな……？　んっ、\nあぁ……まだ軽くイッてる感じ残ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……よかった……気持ちよすぎて……頭……おかしくなっちゃうかと思\nったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チョコと一緒に舐められてる時なんて……本当にそのまま食べられちゃうん\nだって思って……なのに、ムズムズが強くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「自分でもびっくりした……私、こういうの……気持ちいいんだって……初め\nての感じだったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、バレンタインの特別だから……今度はもうちょっと普通にするか\nら……た、多分な！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁんっ！　あぁっ、また熱いのっ……今度は……あっ、お尻にっ…\n…掛かってるっ、んっ、ふぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、２回目なのに……そんなびゅーびゅーって……止まらないで出\nてるっ……お尻……ドロドロになってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、あぁっ……まだ出てる……チンチン扱いて……新しい精液、\n出し切っちゃおうとしてるのか……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いいよ……出して……私のお尻に……残りの精液……全部塗りつけてぇ……\nはぁぅ……んんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、そう……チンチン直接お尻に当ててぇ……あっ、ヌルヌル\nの先っぽ……擦れるの気持ちいい……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ……止まった……？　全部出したんだ……んっ、分かった……ちゃんと全\n部してくれたんだな……その、ありがと、な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000409_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……お尻、すごいことになっちゃってる……んっ、このままほっといた\nらカピカピになっちゃうんだよな、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「さっきのチョコみたいに、私のお尻についた精液……舐め取ってくれちゃっ\nたりしないか？　なーんて……あははっ、冗談、冗談……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「い、いや、ホントに冗談だからな！？　今、顔近づけようとしてなかったか\n？　だ、大丈夫だからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「全く……今日は、そのバレンタインなんだから……特別なんだからな……そ\nの辺も、ちゃんと、分かっとけよっ……なっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0904410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}