{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「あはぁ……すごい格好だね……。君のおチンポが、よーく見えるよ……。あ\nあ、すごい……勃起しちゃってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303104" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「これからオシオキされるっていうのに……のんきにおチンポを硬くしちゃっ\nてるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「そんな君には……とっても恥ずかしい思いをしてもらおうかな……。こうや\nって、おチンポを握って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああ……すっごい熱いね……。興奮しちゃってるんだ……おチンポ、ヒヒ…\n…ガッチガチ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「こうやって、君に亀頭を向けながら、手を動かすよ……シコシコって、ヒヒ\n、いま射精しちゃったら大変だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「自分の顔に、精液をびゅって、ぶっかけちゃう……不運だね……。ヒヒ、そ\nうならないように、しっかり我慢しようね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「にしても……さっきから私の目の前で、キンタマが揺れているんだよね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「もしかして、こうされたいのかな……んちゅっ、キンタマ……舐めてもらい\nたかったり……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ンッ、手の中でおチンポが反応して……ちゅっ、ちゅぱっ、そっか……これ\n、感じちゃうんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぶっ、んふっ、ちゅぱっ。それなら……もっと、キンタマ舐\nめちゃおっかな……んちゅぱっ、れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「オシオキの最中に弱点を見せちゃったら、そりゃあそこを責められるに決ま\nってるよ……。ヒヒ、不運だったねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポしごきながら……んっ、ちゅっ、キンタマもたっぷり舐めてあげる\n……んちゅるっ、ちゅばっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んふっ、んっ、ちゅっ、ちゅぅっ。んちゅぅ……ああ、苦いような、しょっ\nぱいような……んちゅ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「オシオキとはいえこんなのを舐めないといけないなんて、なんて不運……ん\nちゅっ、ちゅぱっ、んれろぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んちゅぶっ、れろれろぉっ、君の苦しそうな声……んちゅぅ、射精を……我\n慢しているんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「キンタマ、ちゅばっ、よだれまみれになるくらいに、舐めまわされて……ん\nちゅるっ。精液、ここに溜まってきているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒ……ぷりっぷりのキンタマ……んちゅぶっ、ちゅ、んふぅ……。ちゅる\nる、ンッ、ちゅぱっ、べろぉ、べろぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「腰を震わせて、逃げようとしたってムダだよぉ……んちゅっ、ちゅぱっ。お\nチンポ、んっ、ビクンビクンしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「手の中で、膨らんで……おチンポがもう、射精寸前になっちゃってるみたい\nだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「このまま、シコシコってしたら……んちゅっ、精液……でちゃうかもね……\nヒヒ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ほらぁ……先走りの、ヌルヌルした汁が先っぽから垂れてきちゃってる……\n見えるよね……？　もう、限界だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「君に向けられている亀頭から……君の顔面に向かって、精液……ドロドロの\n汁が、びゅーってでちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「手の動き、激しくしちゃうねぇ……竿の根元から、先端に向かって、おチン\nポから精液搾りとるような……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「キンタマも、いっぱい舐めるねぇ……んちゅぶっ、たくさん、キスしてあげ\nるぅ……ちゅっ、んちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ほらぁ……んちゅっ、れろれろっ、たくさん精液、作るんだよぉ……ちゅっ\n、ちゅぶっ、んふぅ、ちゅっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ちゅるるっ、んっ、ちゅばっ！　キンタマ……よだれでふやけてきたねぇ…\n…んちゅっ、ちゅぶぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「でもやめないよぉ……ヒヒ、これはオシオキだからぁ……んっ、ちゅぶっ、\nんふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「苦しそうだね？　射精しちゃう？　これ以上、我慢できなくなっているみた\nいだけど、射精はさせてあげないよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポをぎゅうって締め付けて……これじゃあ射精できないでしょ？　不\n運だね……んちゅっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「キンタマ刺激されて、精液がこみあげてきているのに、射精できなくて……\nんちゅぅ、辛そう……ヒヒ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポが破裂しそうなくらいにパンパンになってる……。じゃあ、射精さ\nせてあげる……いっぱい、出させてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ここまで我慢させた分、射精して……。びゅるびゅるいやらしい汁を、ぶち\nまけちゃって……！　んぁっ、あむぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んふぅうううぅぅぅっ！　んっ、んんぅっ！　んぐぅうっ！　\nんじゅるるっ、んじゅぶっ、んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「いっぱい……おチンポから、精液でてるねぇ……。んくっ、んくっ、濃厚な\n……ドロドロ汁……んじゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああ……こんな、苦くてくっさい汁……口の中にだされるなんて、なんて不\n運なんだ……んじゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「でも……君の精液は、私のものだから……。んじゅるるっ、セルフぶっかけ\nなんてもったいないこと、させないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒ……だからぁ……もっともっと、君には精液……だしてもらわないとね\nぇ……んじゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んじゅぶっ、すごいね……ンッ、君のおチンポで、私の口の中、いっぱいに\nなってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「勃起して……こんなに大きくなってたんだね……んじゅるっ、じゅぶっ、じ\nゅるるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「そうだよぉ……今度は口も使って、君のおチンポにオシオキしてあげるんだ\nからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んふぅ、んっ、んっ、んじゅるるっ。んちゅぶっ、んふぅ、じゅるる、ンッ\n、じゅぶ、じゅぶ、じゅりゅりゅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「さっきの射精の残り汁ぅ……おチンポに残っているもの、全部啜り出しちゃ\nう……じゅるるるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ、どんどんよだれが溢れてきちゃう……じゅるっ、君のおチンポが美\n味しくて……んじゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「とっても……不運な味がするぅ……。ヒヒ、くさくて、苦くて、しょっぱく\nて……最高な味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、ダメだよ……。すぐに射精するなんて、もったいない\nから、ダメ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ほら……じゅぶっ、おチンポしゃぶりながら、根元、押さえておいてあげる\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「指でぎゅってして、勝手に射精しないようにしてあげる……んっ、じゅぶっ\n、じゅぶっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゅるるっ、おチンポが……亀頭が、口の中でおっきくなった……\nね……んじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「さっきよりも、おっきくなってるかも……じゅぶっ、じゅるるっ、君はまだ\n……射精したりないんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「口の中で、んじゅるっ、おチンポ……暴れて……。んじゅぶっ、じゅるるっ\n、精液をたくさん出したいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「いいよ……搾りとってあげるよ……。パンパンに膨れたおチンポから、でき\nたてほやほやの精液をださせてあげるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んじゅぶっ、じゅるっ、じゅるるっ、んっ、んぶっ、んぶっ、じゅるるぅっ\n！　んんっ、じゅるるっ、じゅぶっ、じゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「先っぽからまた、先走りが……じゅずずっ、いやらしい味で、口の中がいっ\nぱいになる……んっ、んじゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「我慢しなくていいよ……射精、しちゃっていいよ……じゅぶっ、じゅぶっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「私に……君の精液、ちょうだい……んじゅるるっ、じゅぶっ、じゅぶっ、ン\nッ、じゅるるっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、でちゃう？　イッちゃう？　いいよ、いいよ……だして、射精\nして、イッて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「じゅぼっ、じゅぼっ、じゅるるっ、じゅじゅじゅじゅぅっ！　んっ、んっ、\nんんぅ……っ！　じゅずずっ、じゅるるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んんぅうううぅぅぅ～～～～っ！！　んむっ、んっ、んぐぅ……ふぅうぅ～\n～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「でてっ、でてる……また、私の口に……ドロドロの精液が、んぐっ、いっぱ\nい……んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「びゅくびゅくって、勢いよく出て……んんぅっ、喉……塞がっちゃう……濃\n厚な精液……んぐっ、んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「不運にも、飲まされちゃう……っ！　いやらしい味の精液、強制的に、胃袋\nに流し込まれるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んぐっ、んぐぅううう……っ！　んっ、んくっ、ごくっ、ごくっ！　んっ、\nんはぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「の……飲んじゃった……。君が射精した分……みんな飲み干したよ……。ヒ\nヒ……ごちそうさまぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「とっても……不運な味で……おいしかった……。病みつきになるくらいだっ\nたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「もっと、欲しいな……んちゅっ、またこうやって、キンタマを舐めていたら\n……精液、できないかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅぱっ。ね……？　また、精液をつくって……私に飲ませて欲\nしいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒ……。不運にも、君の精液は、魔女に気に入られちゃった……。めでた\nし、めでたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「んはあっ！　あっ、おチンポが……っ！　んっ、ああっ、あはぁあっ！　射\n精っ、しちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　勢いよく精液噴きだしてっ！　んっ、私にっ、かかって\n……あっ、熱いの……いっぱいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ドロドロ、ネバネバで……はぁっ、はぁっ、それに……くっさい汁ぅ……！\n　不運にも、ぶっかけられて……んひぃい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ああっ、すっごいよ……こんなに汚されて……とっても不運なのに……嬉し\nいなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「君の精液……んぅ……ねっとり重たくて……肌にくっついているみたいだよ\n……んぁ……ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001803_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「たっぷりかけられて……私もイッちゃったみたい……。だって……こんなの\n……不運すぎるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「予定にない、ぶっかけ……本当は君の精液、またたくさん飲みたかったのに\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「だけど、これはこれで……。君の最高な不運精液にまみれるのも、いいね…\n…病みつきになりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「もっと、かけてくれる……？　私に、んっ、んちゅっ、キンタマを、また精\n液をいっぱい作るように、舐め舐めしてあげるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「もっと私のこと……君の不運で、いっぱい汚して……」", "NORMAL" ]},
