{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんな時間に、わざわざガレージまで来てもらってごめんなさいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「なんの用って……もう、わかってるクセに。ほら、前に言ったでしょ。カツ\nマちゃんにいっぱいご奉仕したいって……いいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふっ……うふふっ……！　今、確かにいいって言ったわね……！　なら、\n遠慮なんてしないからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　これがカツマちゃんの……！　すごく大きくて、いいニオイ\nがするわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「くんくんっ……んっ、あふっ……！　すごく蒸れたニオイがして……！　身\n体が疼いちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あらっ……どうしてそんなに抵抗するの？　ご奉仕していいって言ったじゃ\nない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「押し倒されるなんて想定してない……？　ご奉仕っていうのは、車に乗せて\nもらえるとか、マッサージしてもらえるとかって思ってたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　座席ならいつも乗せてあげてるじゃない。それに、これは\nご奉仕という名のマッサージよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんはリラックスして、私にすべて委ねてていいのよ……すごく気\n持ちよくしてあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「もう私以外とじゃシたくなくなるくらい……いーっぱい、感じさせてあげる\nわ……んっ、ちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ！　じゅ、ぢゅるっ！　ぐちゅ、ちゅ、んちゅっ！　れろっ、ぴち\nゃ、ぷちゅ！　くちゅ、ずっ、じゅるうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅぽぉっ……！　カツマちゃんのすっごく美味しいわっ……！　ハイオク\nなんかより、断然こっちの方が好みよっ……ちゅぷうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んちゅ、れろっ、ぶちゅ……！　皮の隙間にあるカスも最高だわっ……！　\n全部舐めとって、綺麗にしてあげるわねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅちゅ、ぐちゅるっ……！　ぐちゅ、にちゃ、じゅぞぞっ！　れろっ、ん\nじゅるっ……！　ぴちゃ、ちゅ、じゅぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あぶっ、んぶっ……！　このカリのところもしっかり舐めないと……！　ぴ\nちゅ、くちゅっ……！　えろっ、ぺろぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……この段になってるところが気持ちいいのねっ……！　こうやっ\nて……んじゅ、ちゅちゅ……舐めるたびに、ピクピクしてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「私のおクチが気に入ってくれたみたいで嬉しいわ……！　もっと激しくちゅ\nぱちゅぱしてあげるわねっ……！　んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ぢゅぐっ、じゅるっ！　ぷちゃ、ぴちゃっ！　ちゅちゅ、れりゅ、ちゅぽっ\n、じゅぱっ！　んじゅるっ、にちゅ、ぐちゅううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んふうぅ……！　我慢汁もこんなに溢れてきてっ……！　大丈夫よ……これ\nも全部、舐めとってあげるからっ……！　ちゅちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「じゅぞっ、じゅるるるっ！　ぐぽっ、じゅ、じゅぽっ！　んぶっ、ちゅぱっ\n、ちゅるっ！　れろっ、んじゅ、ぴちゃあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅぱぁ……！　ふぅ……ふぅ……！　私のおクチで、すっかりベトベトね\n……それにさっきよりもカタくなってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　そんなに切なそうな顔しないで……ちゃんとイクまで、咥\nえてあげるから……んっ、あむっ、じゅちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅ、ぐちゅるっ！　そんなに腰を引いてもムダよ……！　カツマ\nちゃんの感じるところは、センサーでわかっちゃうもの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ぐぽっ、じゅちゅ、ちゅぴぃ！　この裏側のスジのところとか……んっ、ち\nゅぱっ……根元のところとか、好きなんでしょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ちゅぱっ、れろぉ……！　舌をねっとり動かしながらおクチでシコ\nシコすると……んっ、んちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　カツマちゃんのがおクチの中で暴れて、ビクビク跳ねてる\nわっ……！　相当気持ちいいみたいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ぢゅぴっ！　んじゅ、ぴちゃ、ぷちゅ！　ぐちゃ、れろっ、んじゅ\nるううぅ……！　じゅぽっ、じゅぽっ！　じゅぱああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「先端のところを舌でチロチロされるのも好きでしょ……！　れりゅ、れろっ\n……！　んちゅ、れろおおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ぢゅぷっ、ちゅちゅ……！　ぴちゃ、ぷちゅるっ……！　くちゅ、じゅるる\nっ！　うふふっ……もう我慢できないみたいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅぱっ……！　いいわよ……遠慮せずに全部私のクチに出してっ…\n…！　カツマちゃんの精液なら、全然イヤじゃないわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んちゅうううぅ……！　ぴちゃ、ちゅ、じゅるるっ！　んふっ、れろっ、じ\nゅぱっ、じゅじゅっ！　ぢゅ、ぴちゃああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ほらっ……！　こんなにビクビクさせて……！　もう限界なんでしょ……！\n　んちゅ、じゅぱっ、ぴちゃあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　どんなに抵抗しても、カツマちゃんが私のチカラに勝てる\nワケないんだからっ……！　ちゅ、ちゅちゅ、んじゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ほらっ……出してっ……！　カツマちゃんの子種汁……私のおクチに出して\n、全部飲ませてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅるるっ！　ちゅぱっ、ぴちゃっ！　んっ、んむっ！　ちゅぱっ、\nじゅるうううううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　いっぱいでてるっ……！　カツマちゃんの濃厚ミルクが、\nこんなにっ……じゅぞっ、じゅるるうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「これがカツマちゃんの遺伝子の味なのねっ……！　しっかりメモリーに刻み\n込んでおかないとぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ！　ちゅぱっ、ちゅ、ずちゅううぅ……！　んっ、あぶっ……！\n　味だけじゃなくて、喉越しも覚えておかないと……んっ、ごくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「じゅぞっ、じゅるるっ！　ごくっ、こくんっ……！　んちゅ、ちゅぱっ、ち\nゅるっ……ずりゅるるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んぐっ、んぐっ……！　ごっくんっ……！　あはあぁ……カツマちゃんの味\n、とっても素敵だわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ふぅ……んっ、ちゅるっ……！　うふふっ……カツマちゃんのミルク、とっ\nても美味しかったわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「忘れないようにメモリーに記憶して、何個もバックアップ取ったから……も\nう絶対に忘れないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……うふふっ……あんなに出したのに、まだこんなにカタい\nのね……私のおクチの感覚が忘れられないのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「いいわよ……カツマちゃんのもまだ全然やる気みたいだし、もっと搾り取っ\nてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「私のおクチじゃないと満足できないくらい、骨抜きしてあげるからっ……！\n　ちゅぱっ、ちゅ……んっ、ぐぷううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ぢゅぐっ、ちゅぱっ！　じゅぷっ、れろっ、ぴちゃあぁ！　ちゅぱっ、ちゅ\nちゅ、んじゅ、ぐちゅるっ！　ぴちゅ、じゅぷぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ！　精子が奥の方に残ってるわっ……！　全部吸い出してあげるわね\n……ちゅちゅ、じゅるるっ！　んじゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅぱっ、くちゅ……！　あぷっ……！　吸えば吸うほど、カツマ\nちゃんのお汁が溢れ出してくるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「濃厚なミルクと一緒に……んっ、ちゅぢゅ……！　我慢汁もたくさん溢れて\nきて……ちゅぱっ、じゅ、じゅちゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ごくんっ……！　はあぁ……！　残り汁の喉越しも最高よっ……！\n　ずっと味わっていたいくらいだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　カリの隙間にもエッチなミルクが残ってるわっ……ちゅ、れ\nりゅ、ちゅぱっ、んちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　気持ちいいなら、素直に声を出してもいいのよ……その方\nが、私も嬉しいし……ちゅぱっ、ぢゅぐっ、じゅぴぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あぶっ、ちゅりゅ、れちゅ、ぴちゃっ！　あんっ……！　カツマちゃんのが\n、さらに大きくなってるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「はち切れそうなくらい勃起してる……！　でも、私ならどんなサイズでも咥\nえ込めるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんなふうに奥まで咥え込むことだってできるんだからっ……！　んちゅ！\n　じゅぱっ、ぐじゅるっ！　ちゅぷっ、ちゅぱっ、じゅぢゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んふっ、んむうぅ！　こうやって根元まで咥え込んで……いっぱい喉奥でシ\nゴいてあげるっ……！　ちゅちゅ、れじゅ、ちゅぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ！　れじゅ、くちゅ、ちゅぷぷっ！　んっ、じゅるっ、ぢゅぐっ\n、ずじゅうぅ！　ぴちゃ、くちゅ、れろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んんんっ！？　カツマちゃんのがまた激しくビクビクしてるっ……！　また\n出そうなのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「いいわよ……おクチでも顔でも、好きなところに出してっ……！　カツマち\nゃんが望むところに、精子出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ちゅぐっ、ちゅぱっ！　じゅぽっ、ぐぽぉ！　くちゅ、ずりゅ、んぶっ、ぢ\nゅぷっ！　んっ、んんっ！　んじゅるうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んふうううぅぅぅ！　またおクチの中にたくさん精子出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「２回目なのにこんなに濃厚で……！　じゅるるっ！　ああっ、舌や喉に絡み\nついてくるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あんんっ！　びゅるびゅる出るたびに、カツマちゃんのが大きく震えて……\n！　私のおクチの中で跳ねまわってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ずずずっ！　もっと出してっ！　最後の一滴まで、私にカツマち\nゃんのミルク注ぎ込んでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ぢゅじゅっ！　んぐっ、じゅるるっ！　ごくっ、こくんっ！　ちゅぱっ、ち\nゅ、じゅるるっ！　ぢゅぷうううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……ご馳走様……カツマちゃんのミルク、たくさん堪能させ\nてもらったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「残ってるミルクもしっかり搾り取ってあげないと……ちゅ、じゅちゅ……ん\nっ、ちゅぱっ、じゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……私のおクチが気持ちよすぎて、腰が抜けてるみたいね……でも、カ\nツマちゃんのはまだこんなに元気だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「もっと出したいって言ってるみたいだし、もう１回私のおクチで気持ちよく\nしてあげるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……！　全部搾り取ったりしないから、安心して身を委ねて頂戴…\n…んっ、ちゅぱっ、じゅるっ、ぐちゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　カツマちゃんのがおクチから抜けて……！　んっ、あっ、あ\nはああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「顔にドロドロしたミルクがいっぱいかかってるぅ！　カツマちゃんの熱い精\n子の感触がするわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　装甲の隙間に垂れてきて……！　ああぁ！　おクチや顔だけ\nじゃなくて、ボディもカツマちゃんの色で染められていくわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「こんなに汚されたら、もう一生カツマちゃんのモノにならないとダメねっ！\n　ちゃんと責任とってもらわないとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　もっと出して！　私の全身を白く染めるくらい、カツマちゃん\nでいっぱいにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022502_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……すごい香りね……私のニオイセンサーが反応し続けてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「とってもクサイのに、もっと嗅いでいたくなる感じよ……すううぅ……んっ\n、あはあぁ……！　メモリーにしっかり刻み込んでおかないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「うふふっ……これでもう、メモリーもボディも全部カツマちゃん一色になっ\nたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「これで正真正銘、私はカツマちゃんのモノよ……絶対に離したりしないんだ\nからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ．Ａ．Ｍ．Ｉ" ]},
		{"command":[ "SETTEXT", "「これからもずっと側に居るから、逃げたりしちゃダメよ？　もし逃げたり浮\n気したりしたら……うふふっ。その先は言わなくてもわかるわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_225_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}