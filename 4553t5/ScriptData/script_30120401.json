		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……顔面シャワー浴びちゃってるぅ……んふぅっ……すごい量…\n…いいよ、いっぱい掛けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はふっ……ちゅぱっ、あぁ……粘ってるぅ……れろ、強烈なニオイ……んふ\n、でもクセになる感じ……好きぃ……」", "NORMAL" ]},
