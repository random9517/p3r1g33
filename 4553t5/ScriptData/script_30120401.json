		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ね、中途半端に残したりしないでね。ちゃんと全部出し切って……わたしも\n、ちゃんと……イクからぁ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403404" ]},
