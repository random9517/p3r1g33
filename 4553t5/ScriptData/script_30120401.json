		{"command":[ "PLAYVOICE", "v2_012_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、全部飲めたよ……えへへ……褒めてくれる？　んふふっ、やった\nー、なでなでしてくれた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、ちゃんと後のお掃除もしなくちゃだよね……ちゅぱっ、ぴちゃ……んち\nゅぱっ、りゅぷっ、んちゅぅ……うん、おっけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「これで、綺麗になったから大丈夫。はぁー、いっぱい口使って、ちょっと顎\nが疲れちゃったかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
