{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えと……もうちょっとだけ隅っこの方行って……多分、大丈夫だと思うけど\n……念のため、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そしたら、ほら……オ、オチンチン出して……んっ、早く……わたし、待ち\nきれなくなっちゃってるの……ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わわっ……あなたのも、すっごくおっきくなってる。えへへ……ナニ、これ\n。もしかして……期待させちゃってた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403103" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だとしたらぁ……私も、ちゃーんと責任取ってあげないと、だよね。んっ、\n待ってね……オチンチンさん、いただきまぁす……は、んむ……ちゅぷぅ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふっ、くぽっ、ちゅぽっ、んっ、んふっ、あんむっ、りゅぷっ、んっ、ん\nりゅっ、じゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403105" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んぁぷっ……えっ？　いきなり……そんなにって……激しくしすぎちゃった\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あはは……多分、すごく……喉が乾いちゃってるからかな……口の中、ジュ\nルジュルにしたくて……んふぅ……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でも、元はと言えば、あなたがそうさせたようなものなんだよ？　少しでも\n隙があれば、わたしのこと……色々して、その気にさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だからぁ……これは、その責任を取ってもらう為のオチンチンご奉仕なので\nす。んふっ、ちゅぷっ……わたしも、我慢できないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……あぁ、はぁ……んっ、お股のとこ……ウズウズしてる……\n指が、勝手に動いちゃうの……んんっ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「し、してるよぉ……オナニー……だって、このカッコじゃ、自分でするしか\nないじゃない？　ちゅぱっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、だからって余計な気は使わなくていいからね？　とにかく、オチンチ\nンだけ舐めさせてくれれば、それでいいんだから……ちゅぱ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、りゅぷっ……後は、自分で何とかしちゃうの……はぁっ、んん\nっ、あぁ、内側……ジワッと来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんっ、普段、こんなピッチリした衣装なんて着ないから……慣れない感じ\n……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「生地はしっかりしてると思うけど、意外に薄くて……肌の刺激が……直に伝\nわってくる感じがするんだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だから、んっ、こうやって……指で弄ってると……あぁ……どんどん、オマ\nンコに響いて……はぁっ、湿って来ちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、股間が熱いの……んっ、あぁ……あなたのオチンチンも、す\nごくなってる……もっと、奥まで咥えちゃうね……はむぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「くぽっ、りゅぷっ、んむっ、じゅぷっ、じゅっぷっ、りゅぷっ、じゅぷんっ\n、じゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あぷっ……あぁ、汗の匂い……する……んっ、男の人のムワッと\nする感じ……ハマりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んんっ……どう？　わたしの……フェラ……んりゅぷっ、ちゃん\nと出来てる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、一応……練習はしてるの……お約束のバナナとかだけど、れろ……ん\nりゅっ、お姉ちゃんに不思議な顔されちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でも、んっ、やっぱり本物は全然違うね……ん、りゅぷっ、こんな……舐め\nてるだけで……口の中、よだれが溜まって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んふっ、くぽっ、じゅっぷっ……はぁっ、ぢゅぽっ、擦れる音…\n…やらしくなるぅ……んりゅぷっ、くぽっ、んぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ……あぁ……おっぱいも、何だかムズムズしてきちゃった…\n…んふっ、わたしのカラダ……どうなってるのかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いろんな所が……気持ちよくって……んっ、りゅぷっ、ホント……どうにか\n、なっひゃいそう……んくぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んむっ、くぷっ、とにかく……オチンチンに集中……集中……んりゅぷっ、\nちゅぷぅっ……じゅぷっ、んじゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんっ、前より……ちょっと大きくなっへる？　んりゅぷっ、気のせいかな\n……んくぷっ、口の中……余裕ない感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「むふぅっ、むぐっ、んむぅ……じゅぽっ、ちゅぱっ……んりゅ、でも……ん\nっ、感じてるのは……分かる、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「りゅぱっ……口の中、新しい味がして来てる……これ……んっ、先走りの…\n…汁の味らよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅぷっ……んんっ、ろう……射精したい……？　んふっ、いい\nよ……このまま……口の中に、ビュクってして……欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わたしも、はぁっ……んっ、オ、オマンコぉ……じわじわしてる……ん、は\nぁっ、オナニーしちゃってるぅ……はぁっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「気持ち……んっ、いいのっ、じゅぷっ……はぁぁんっ、胸の先も……硬くな\nってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、オチンチンも……限界らのれっ？　ならっ、らひてっ、このままっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うんっ、わらひにっ、いっぱいっ……せーえきっ、のまへてぇっ……んっ、\nじゅるっ、んじゅるるるるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんーーーっ！　ふぐっ……んむぅぅっ、こくっ……んんっ……んぐっ、ん\nっ、んくんっ……んんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふごい……いっぱい量……れてるっ……んく、喉にっ……絡んでる……んじ\nゅぅ、くぷっ……んりゅ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、はぁ……はぁ、んちゅぷっ、口の端……垂れて来ちゃった……勿\n体ないよ……じゅるっ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はふぁ……んっ、れろ……これで、よし……ちゅぷっ……ふはぁっ……えへ\nへ、全部飲んだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「その、どうだったかな……？　割と頑張ったかなーなんて思っていいのかな\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ……よく出来てたっ？　えへへっ、うんっ、良かった。ご奉仕任務、第一\n段階突破だねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「えっ、第一段階ってどういうことかって？　えへへぇ、それはこのオチンチ\nンが一番よく知ってるじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ほら、いーっぱい射精したけど、まだギチギチのまんま……もっと搾り出し\nて欲しいって、ウズウズしてるんでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうする？　わたしは、まぁどっちでもいいんだけどなー。このままやめち\nゃう？　それとも……続き……する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ふふっ、だよねー。まぁ、絶対して欲しいって言うと思ってたし。て言うか\n……私も、続きしたくて仕方なかったし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だから、もう一回……いただきまぁす……はぁんむっ、くぽっ、んふぅぅっ\n、りゅぽっ、んちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んむぅ……一番奥まで……くぽって……しひゃった……んむふぅ……オチン\nチン、おいひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あんむっ、はぁっ、口から……よだれ……ろんろん、あふれてきひゃう……\nんりゅぷっっ……止まらにゃいの……んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ……やら……下の方も……んんっ、あふれて……きちゃった\n……んんっ、オマンコ……ウズウズしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、はぁっ……ちゅぷっ……んむっ、んりゅぷっ……顔……もっと\n動かすね……んくぷっ、じゅぷっ、んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「オマンコ……埋められないけど……代わりに、お口で……んふっ、じゅぽっ\n、オチンチンと……セックスするぅ……じゅぱっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あむっ、んふっ……ふふっ、腰がビクビク跳ねてる……私のフェラで感じて\nくれてるの……すっごく嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、りゅぱっ、だから……んっ、ねっ……ちゅぽっ、くぷっ……この\nまま、きもひよくなって……んっ、また……出そ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、ちょっと……足……んっ、変なとこ……悪戯したらダメぇ\n……あんっ、も、もぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そういう悪いコトする人には……こうらっ、じゅぷっ……んじゅぅぅぅっ、\nちゅぶっ、んちゅっ、じゅるるるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んふふぅっ……もぉ限界れひょっ……んじゅぷっ、わらひも……イクんらか\nらっ……あなたも……イッていいんらからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、オチンチンっ……ちゅぷっ、また飲む……？　それとも……んり\nゅぷっ、顔に掛けひゃうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んっ、ふっ……どっちでもいいよ……んっ、決めといてね……じ\nゅぱっ、ちゅばっ……こっちでスパートするからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001204_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「んくぽっ、りゅぷっ、んじゅぷぅぅっ……んじゅぷっ、ちゅぶっ、んじゅる\nるるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、カラダ……疼くぅっ……はぁんっ、私も……イクっ……イク\nのっ……んんっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
