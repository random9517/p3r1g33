{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「に、兄さん！？　私の身体に何したの！　メンテナンスで何か仕込んだでし\nょ！　身体が勝手に恥ずかしいポーズ取るんだけど！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「え……？　お仕置き？　た、確かに最近ちょっと兄さんに対して態度が悪か\nったかなぁ、って気はしてたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「その為だけにこんな恰好させたの！？　こ、この変態！　バカ、死ね！　気\n持ち悪い！　ポンコツのダメ大人！　バーカ！　兄さんのバーカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――反省が足りないみたいだな、って……こ、こんな恥ずかしい格好させら\nれて、反省なんてするわけないでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「って、兄さん、どうして腕を振りかぶるの……あ……こ、この恰好って、ま\nさか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「きゃぁっ！？　う、嘘でしょ！？　お尻ぺんぺんなんてっ！　んひゃぁんっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぼ、ボディは確かに小さいけど、これでも人間の学生ぐらいの年齢設定なの\nに！　んひゃぁんっ！　こんな、恥ずかしすぎっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――や、やだ！　暴力を振るう大人相手に謝ったりなんてしない！　絶対し\nないから！　きゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　あぁんっ！　んくぅんっ！？　リズミカルに叩くなぁ……\n！　きゃぁんっ！　嫌い、兄さん嫌い！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――な、何、兄さん、その気持ち悪い笑い声！　ひゃっ……！　えっ、おち\nんちんの先っぽが、おまんこに当たって……嘘、まさかこのまま！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁんっ！？　に、兄さんのおちんちんが、一番奥まで一気にきたっ！　\nあひっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、ああ、んふうぅんっ……！　このボディの小ささ、だと、奥の圧迫が\nすごすぎて……！　あひっ、中ゴリゴリ削られるっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ま、まってよ、激しすぎるんだって、ふあんんっ！　あっ、んひゃぅっ！　\nそれにこれ、何がおかしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「に、兄さん、私の感度も弄ったでしょ！？　おまんこの中、乱暴にされてる\nのに最初から感じるなんて、絶対おかしいもん！　んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んふぅんっ！　突かれるのに合わせて、内部機構が勝手にう\nねうねしちゃって、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「嫌、なのにぃ！　兄さんうざいのに！　あぁんっ！　気持ちよくなちゃうし\n、兄さんのこと気持ちよくしちゃうの！　んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――い、今素直に謝れば、身体の感度を直してやる？　生意気な口調を直せ\nば、おちんちんもゆっくりに……優しくしてくれるって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ……うぅ……！　だ、誰が謝ったりするもんか！　兄さんキモイ、うざ\nい！　暴力振るえば思い通りになると思うな！　バーカ！　バーカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「きゃあぁんっ！？　ま、またお尻ぺんぺん！？　あひゃぁんっ！？　ま、ま\nって、まさかこのままおちんちんも動かすつもりじゃ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　あっ、きゃうんっ！　同時はダメなの、お尻叩かれると、ジ\nンジンするのがおまんこの奥まで響いてっ！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「痛い、のにぃ！　あぁんっ！　角度をつけておまんこズポズポされるの、気\n持ちいいっ！　きゃぁんっ！　お尻痛いっ、き、気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「なにこれ、分かんないってばっ！　あぁんっ、んきゃうぅっ！　こんなの知\nらない、データにないよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――な、泣き言なんて言ってない、言ってないもん！　だ、誰が兄さんみた\nいな変態に屈するもんか！　喋りかけてくるな、キモイ！　うざい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　あっああ、あひゃぁんっ！　またおちんちん、奥まで来た\nぁ……！　子宮パーツ、突き上げられてっ！　あぁあんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ボディが小さいから、簡単に身体ごと揺さぶられちゃう……！　あっ、あぁ\nんんっ！　中も狭いはずなのに、ゴリゴリ削られる、んくぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お尻ぺんぺんも、やだぁ！　きゃんっ！　あくぅんっ！　叩かれたところ熱\nくて、ジンジンするのに、あぁんっ！　逃げられないよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「なのに、なんでぇ……私の身体、おまんこ、ぐちゅぐちゅって、えっちな音\nが出始めちゃってる……！　やだ、じっくりかき回さないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ああぁっ……！　おちんちんの膨らんだところで、ゆっくり\n内部機構を引っ張り出されて……ひゃんんっ！　突くのは一気にくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やだぁ、もうほんとにやだよぉ……このボディ、そこまで処理能力が高く高\nくないからっ、んひゃぁんっ！　分かんなくなるの！　あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「気持ちいいと痛いのが一緒になって、センサーおかしくなっちゃう……私、\n壊れちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うぅ……兄さん、謝る……謝るからぁ……ご、ごめんさい、もう生意気言わ\nないから……お尻ぺんぺんしないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「う、嘘じゃないもん！　クララいい子にする！　強い言葉も使わないように\nするから！　もう痛いのやなのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ゆ、許して、くれるの？　素直に謝れたご褒美……？　んぁんっ！　に\n、兄さんのおちんちんが、お腹の中で膨らんできたっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんんっ！　ふあぁんっ！　優しくおまんこパンパンってされて、\nふあぁんっ！　痛くない！　気持ちいいだけっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これがご褒美、気持ちいいご褒美……！　あぁんっ、んうぅんっ！　に、兄\nさん、このままクララの中に出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁあんっ！　んひゃんっ！　う、受け止めるよ、兄さんのせーえき、全部\nおまんこで受け止めるから、いっぱい出してねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふああぁぁんんっ～～！！　熱いのせーえき、来たぁ！　小さいおまんこの\n中に、ドクドクっていっぱいっ！　んくぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、私もえっちなエラーが凄い量になっちゃってる……！　ノイズがすごす\nぎるのに、それが気持ちよくて、あっ、ああぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ぼ、ボディが小さいから、すぐにおまんこパンパンになってる……んくぅん\nっ……せーえきが簡単に逆流してきて……んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこの中、熱すぎて……んっ……タプタプに溜まってるの、全部兄さん\nのせーえきなんだ……お腹、ちょっと膨らんじゃってるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ね、ねぇ、兄さん……？　私、いい子にするよ？　これからはもっと素直に\nなって、兄さんにキモイとかうざいとか言わないようにするよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だから……お願い、このままもう一回、気持ちよくしてほしい、かも……感\n度が上がりまくってるせいで、我慢、できなくて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……ふふっ、今更ボディの小ささを心配するなんて、兄さん、ちょっと遅い\nよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「大丈夫だよ、その……一応、こーゆーことを想定してパーツを選んでるから\n……だから、ね？　兄さん、クララの事、思う存分可愛がって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁんっ！　おまんこの中でおちんちん動き出した！　精液かき出すみた\nいに、ゆっくり引き抜かれて、あっ、あっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひぃんっ！　さっきの精液で、にゅるにゅるしてる！　狭いおまんこのは\nずなのに、簡単に奥まで届いてる！　ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「や、やっぱり、おまんこの中が勝手に動いて、おちんちんをにぎにぎしちゃ\nう！　抜けるときは行かないっでぎゅ～って締め付けるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「兄さんのおちんちんの形が、おまんこの中ではっきりわかるよぉ……！　あ\nっ、んくぅんっ！　浮き出た血管の形まで、全部、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さっきのえっちなエラー、まだ全部消えてないのに、ふぁんっ！　どんどん\n積み重なってくる、んひゃんっ！　やっぱり処理が全然追いつかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんんっ……！　気持ちいいよぉ、兄さんのおちんちん\nズドンって響くの、ダメになるのぉ！　ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「じゅぼじゅぼってえっちな音も聞こえちゃう！　あぁんっ！　おまんこが泡\n立ってるの、見なくても分かっちゃう！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ちびっこボディのはずなのに、私、こんなに感じて……あっ、ふあぁんっ！\n　えっちな子になっちゃう、えっちなロボットにっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「に、兄さんは、気持ちいい？　クララのおまんこで、兄さんもいっぱい感じ\nてくれてる？　――そっか、よかった、ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　お、おまんこの中で、またおちんちんが跳ねた！　先っぽ\nが大きくなって、ビクンって跳ねた！　ふあんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もうちょっとなんだ、兄さんもまた出したいんだ……！　だ、だったら……\nさっきみたいに、私のお尻、また叩いてほしいかも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「い、痛いのはイヤだけど、気持ちいと一緒になって、処理ができなくなる感\n覚が忘れられなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――んひゃぁうんっ！？　あひっ、んきゃうぅっ！　それぇ、お尻に響いて\nっ、あぁんっ！　ぺんぺんされるの気持ちいいの！　んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404217" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「頭の中で気持ちいいと痛いの処理が混ぜこぜになって、えっちなエラーが止\nまらない！　んはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひゃぁんぅ！　きゃうっ！　んひゃぁうっ！　私もイクの、兄さんと一緒\nに、お尻ぺんぺんされてイっちゃうのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いっぱい出してぇ！　兄さんのせーえき、クララにちょーだい！　一緒にイ\nクから、気持ちよくなるからぁ！　あひっ、んひゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあああぁぁんんっ～～～！！　ま、また中、おまんこの奥ぅ！　あひっ、\nあっ、んひゃあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こ、こんな、みっともない声、恥ずかしいのにぃ！　あ、ひっ、んひゃぁん\n！　兄さんのせーえき、子宮にあたるのが気持ちよすぎて、ふあぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほ、ほんとに処理能力の限界がきちゃうっ！　気持ちよすぎて、視界センサ\nーにまでノイズが……！　あっ、ああぁ、あああぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お尻、ジンジンして痛いはず、なのに……！　ふあぁんっ！　叩かれたとこ\nろ熱くなって、それも全部、気持ちいいに変わっちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちん、まだドクドクしてるっ……んんっ、んくぅんっ……！　また、\n子宮パーツの中から逆流してきて……あっ、ふくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お、終わった、の……？　んんっ……と、とりあえず、ダメ\nなエラーだけ早く消さないと、足がガクガクしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お腹の中、すごい……せーえきで熱暴走起こしそうなほど熱いのもそうだけ\nど……タプタプになってるせいか、ちょっとお腹が重いや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……兄さんの変態、こんな小さなボディの私相手に興奮しすぎ。こんなにお\n射精しちゃって……えっち、ロリコン、変態、バーカ、バーカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「なーんて……ふふっ、確かに最近ちょっと態度悪かったかなって……うん、\nごめんなさい、兄さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……これからはもうちょっと素直になるから。私の事、たまにでいいから可\n愛がってくれたら、嬉しいな？　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　おちんちんが抜けてっ、ふあぁぁあんっ！　せーえき、ボ\nディに降り注いでくるっ！　あひっ、んひゃぁうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015804_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこの中に出されるのもすごかったけどっ、あひっ！　こ、これぇ、全\n身が熱くって！　ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「特におしりのところっ、ぺんぺんされて痺れてたところにせーえきがついて\n、あっ、ひっ、ふあぁんんっ……！　痛いので、イっちゃってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「匂いもすごい……んんっ……嗅覚センサーを動かすだけで、全ての回路にノ\nイズが走るの……！　ふぁっ、あっ、んくぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、私が兄さんのモノだっていうマーキング、んふぅっ！　に、兄さんの\n所有物だって証……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私……いい子になる、いい子になるから……んぁんっ……！　いつまでも、\n兄さんの所有物でいたい、よ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……兄さん、ほんとにいっぱい出したね？　身動きの取\nれない私のお尻をぺんぺんするの、そんなに興奮したの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うわぁ、いい笑顔過ぎて……うざい、あ、いや、うざくないけど……きもい\n、あ、これもダメなんだ、きもくもない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「むぅ、笑わないでよ！　パーツを切り替えてないんだから、そんな簡単に性\n格が変わるわけないじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やっぱりそのにやにや顔うざい！　きもい！　兄さんなんて、大っ嫌い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
