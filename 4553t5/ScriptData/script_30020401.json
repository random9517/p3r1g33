{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "002_0403101" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「……何か、用事……？　私のこと、探してたみたいだけど……でも、まだ仕\n事中だから……早くお嬢様のところに戻らないと……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403102" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「……もしかして、またエッチなこと考えてる……？ 最近のあなたはそれ\nばっかり……昔はもっと…………ん……やっぱり、昔からスケベだったかも\n……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403103" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「というより……あなたにも、そんな暇があるの……？ やるべきことはたく\nさんあるはず……こんなところで油を売っていたら、ダメ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403104" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「そうやって、サボってばかりいるから……みんなにも、軽んじられるんだよ\n……？ 今のあなたは、責任ある立場に、いるんだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403105" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ダメダメなあなたにも、出来ることはあるから……もちろん、私も手伝うか\nら……ね？ それじゃ、仕事に戻ろう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403106" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「…………はぁ。あなたはいつまで経っても、子どもみたいにワガママで……\nわかった、手早く済ませる。それで……私にどうしてほしいの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403107" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「きゃっ……！？ もう……すっかりココを、こんなに大きくして……本当に\n、こういうことにばっかりは、元気なんだから……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403108" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「それに……すん、すん……んぁ、すごいニオイ……ちゃんと、お風呂に入っ\nてる……？ こもったような、生臭いニオイが……すん、すん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403109" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……んっ、なんでもない……それより、これを、その……口で、す\nればいいんだよね……？ 大丈夫、やり方は、知ってるから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403110" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「え……？ ひどい……手慣れてなんかないよ……私はあなたのしか、見たこ\nとも、触ったこともないのに……その言い方は、少し傷つく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403111" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ん……信じてくれたなら、いいよ……それじゃあ……えっと……する、ね…\n…？ んっ……あ、む……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403112" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「確か……舌に、唾液を絡ませて……ちゅ、ちゅぷっ……オチンチンを、舐め\nるん、だよね？ れろっ、れりゅっ、ねりゅっ……こう、かな……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403113" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「れちゅ、ちゅぷっ……それで、オチンチンを濡らしながら……れりゅちゅっ\n、じゅぷっ……奥まで、咥えていく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403114" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「じゅぷぷっ、じゅぷっ……んふぅぅ……おくちのなか、おくまで、ぜんぶ…\n…はぷっ、ちゅぷぷっ、あなたのオチンチンで、いっぱい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403115" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「あとは……咥えながら、舌をうごかして……れちゅっ、れろぉぉっ、ぜんご\nに、だしたり、いれたり……れちゅっ、じゅぷっ、じゅぷっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403116" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「じゅるるっ……んふぁ……ちょっと、しょっぱくて、にがくて、……れろれ\nろぉっ、ぢゅちゅっ、これが、あなたの、ちゅるっ、オチンチンの、味……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403117" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「れりゅりゅっ、れるぅっ……んふぅ、おくちのなか、ぜんぶ……じゅぷっ、\nじゅぷっ、じゅぷっ……あなたの味と、ニオイになってる……じゅるるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403118" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「もっと、激しく……？ わかった……じゅるるっ、れりゅぅっ、じゅぷっ\nじゅぽっ、たくさん、あなたのオチンチンを舐めて、しゃぶってあげる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403119" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぽっ、じゅぽっ……んふぅぅぅ、ニオイが、濃くなって……\nじゅるるっ、オチンチンの先っぽから、ヌルヌルしたのが、出てきた……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403120" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ぢゅっ、ぢゅるるっ……んぁぁ……すごく、エッチな味……ちゅ、ちゅっ、\nあなたの、オチンポ……おいしい……ぢゅちゅぅぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403121" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んっ、オチンポ、びくびくしてる……私のお口、気持ちいいの……？ ここ\n……？ 裏側の筋のところを、舌で舐められるのが、好きなの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403122" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「れろぉっ、れるぅぅっ……んれっ、ここの……カリ首のところも、好きなん\nだ……？ 唇で締め付けながら、前後に、こう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403123" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「じゅぽぽっじゅぽっじゅぽっ……さきっぽのつるつるしたところも、れちゅ\nりゅっ、くちぜんたいで、すいこみながら、アメみたいにペロペロ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403124" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ぢゅちゅうぅぅっ、れりゅりゅっ、れちょれろろっ……！ んふふっ、こ\nれ、ぜんぶ好きなんだ？ いいよ、もっと激しく、シてあげる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403125" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ぢゅううううっ、オチンポ、吸い込みながら、じゅぽっじゅぽっじゅぽっ、\nれりゅりゅっ、おくちぜんたいでシゴいて、たくさんナメてあげる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403126" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「じゅぽっじゅぽっ、じゅるっ、れちゅりゅりゅっ、れるぅぅっ……！ ん\n……また、味が濃くなって……オチンポ、太くなってきた、ぢゅちゅうっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403127" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「もしかして、もう出そうなの……？ じゅるっ、れちゅるっ、れりゅっ、い\nいよ、出して……じゅぽっじゅぽっじゅぽっ、オチンポ、イって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403128" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ココにたまった、ザーメンを……れろっれろろっ、私のお口に、射精して\n……ぢゅちゅううっ、ぢゅっ、ぢゅぢゅっ、私にいっぱい、ちょうだい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403129" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「私のお口で、オチンポをシゴかれて、じゅっぽじゅっぽじゅっぽ、濃くてド\nロドロした、あなたの精液……いっぱい、吐き出して……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403130" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「じゅぼぼっじゅぼっじゅぼっじゅぼっ、れぢゅるるっ、イって、オチンポ、\nイって、せいえきだして、しゃせいして……ぢゅぢゅううううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403131" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んぶあっ！！？ んぶっ！ ぶぷぅっ！ すごい、いきおい……んぶあっ！\nのどのおくまで、あたって……んぶぅぅっ！！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403132" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「あつくて、ドロドロしたの、んぶっ、ぷぁっ、こんなに、いっぱい、\nぶぷぁっ、もう、おくち、はいりゃないっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403133" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ……ごくっごくっ……ぶぁっ、せいえき、すごく、濃くて……の\nどに、からみつく……んっ、ぐくっ……うまく、のみこめない……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403134" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んぶぁっ！？ んぶっ、ぷぁっ、まだこんなにっ……んぶぅぅっ、ぷぅあっ\n、らめ、くちから、あふれちゃうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403135" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んぐっ、ごくっ、ごくっ、ごくっ、……んっ、く……ぷぁっ、はぁっ、\nはぁっ……こんなにいっぱい、出すなんて……もう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403136" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「……え？ 私のお口が、気持ちよかったから……？ そう、なんだ……\nふふっ、よかった……あ、まだちょっと出てるね……ちゅっ、ちゅるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403137" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んっ、こくっ……ふぁぁ……口の中がすっかり、あなたの精液のニオイに\nなって……舌の上とか、喉の奥とか、精子で、ベタベタする……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403138" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「あっ……あなたの、オチンポ……まだ、大っきくて、固いまま……もしかし\nて……まだ、シたりないの……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000204_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403139" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「……もう。しょうがないんだから……じゃあ、もう一回だけ、だからね\n……？ 本当は、早く戻らなきゃいけないんだけど……でも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0403140" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「あなたの、お願いなら……あなたが、望むなら……私は、いつだって……\nなんでも、シてあげたいから……んっ、ちゅっ……じゅるるるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}