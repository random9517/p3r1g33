		{"command":[ "PLAYVOICE", "150_0103101" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「あの、わたし体力なんてつけたくないんですけど……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103102" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「そ、そもそもおっぱいで……そのっ。うぅ、言います。言って欲しいんです\nよね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103103" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「はあぁ……オチンポをおっぱいでしごいて、お……お口でしゃぶるなんて…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103104" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「体力をつけることと何の関係もない気がします……え？　その通りだ、って\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103105" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「わたしとエッチなことしたかったから、口実にしただけ？　そんなに胸を張\nって言われても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103106" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「……はぁ。でも、あなたがわたしのこと性的な目で見てくれてたの、少し嬉\nしいかも……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103107" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「……！！　わっ、忘れて下さい。とにかくおっぱいを動かして気持ち良くす\nればいいんですよね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103108" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「えっと、えーっと、こうかな……こう、ですか？　はい……もちろん、初め\nてです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103109" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「恋なんてしたことなかったし、だから……男の人におっぱい見られるのも…\n…もちろん初めてで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103110" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「まさか、ぱ……パイズリフェラなんてすることになるだなんて、思いません\nでした」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103111" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ……んっ！　こうですか？　お口も使うんですね……ふあぁ、オチンチ\nンがバキバキに勃起してる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103112" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「硬くて、熱くて……んんぅ、すごい匂いをさせてます……！　く、咥えます\nね？　いきますよ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103113" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「はっ、ちゅるる……ちゅむ、ちゅるっ。え？　きゃうっ！？　び、ビックリ\nしました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103114" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「だってオチンチンがいきなりビクッて跳ねるんだもん……気持ちいいから反\n応したんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103115" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「あなたが感じてくれてるなら……わたし、嬉しいかも。これで、いいんです\nね？　ちゅる……ちゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103116" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「あむっ、ちゅるる……んんぅ、ちゅぷぷ！　んふぅ、わたしいま……すごい\nことしちゃってる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103117" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「ちゅぶぶ、ちゅむ！　ちゅうぅん、んっ、んんっ！　んふあぁ……あなたの\nオチンポ大きくて……んんぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103118" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「全部なんて咥えられない、ですっ……え？　根元まで？　そうしてくれたら\nもっと気持ちイイから？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103119" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「それなら……が、頑張ってみます。あむっ、ちゅぶぶ……ぢゅる！　じゅっ\nぷ！　じゅぷぷ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103120" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んみゅっ！？　んぅぅ！　ぢゅぷりゅ！　じゅぽ！　じゅぽ……っ！　けふ\nぉ！　えほっ、えほ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103121" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫です。オチンポの先が喉に引っかかって……え？　でも、それが\n気持ちイイ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103122" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「うぅ……ムチャな注文するんですから、もぅ。はむっ……ちゅぶぶ、じゅっ\nぷ、じゅぷ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103123" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ、ん～～～！？　ぢゅむ！　じゅぽ！　んふぅ！　ふあぁっ、これ……\nんんっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103124" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「息するのが大変で、苦しくて、頭がボーッとしてきちゃいます……んんぅ、\nじゅぷ！　じゅっぷ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103125" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んふゅううぅっ！　ふぇ？　オチンポがビクビクしてるぅ……えぇ？　イク\n？　イクんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103126" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「わたしの喉奥に射精したい？　うぅ……分かりました。来て下さい、はぁぁ\n、じゅぷ！　じゅむむ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103127" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「ちゅっぽ！　ちゅぷぷ！　ぢゅぷ！　じゅぷぷ！　んっ、んんぅ……何か、\n来るぅっ……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103128" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んみゅっ、じゅぷぷ！　じゅぷっじゅぷぷ、じゅぷりゅる、んふぅ、んあぁ\n、あぁぁ……！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103129" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んんぅ！！　んっ、ん～～～！！　熱ぅぅい……喉に、お口の中に、舌にぃ\n……ビュッビュッて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103130" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んあぁん、苦くてしょっぱくて、すごい匂いぃ……ふあぁっ、はぁ、はぁっ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103131" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「飲んで欲しいんですか？　もぅ……じゅぷ、んちゅ、ネバネバで飲めない…\n…ちゅる、ちゅるちゅっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103132" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「んふあぁ、まだ出るぅ……ごきゅっ、あふぅ、せーえき、もしかしたら美味\nしいかも……んふぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103133" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「わたし、喉オマンコ孕まされちゃったかも……しれません。あなたのオチン\nポ好きだって……言ってます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103134" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「じゅむ、ちゅぱ、ちゅるる……ごくっ、んっ、んあぁ、はあぁ、ぜ、全部…\n…飲め、ましたぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103135" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「えっ、え……？　わたしの顔を見てたら、もっとしたくなってきた？　そ、\nそれって……んんぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103136" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「……分かり、ました。喉オマンコだけじゃなくて、わたしのゼンブ……あな\nたにあげます」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103137" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「貰って下さい。オマンコも、お尻も、おっぱいも、ぜんぶ……ぜぇ～んぶ、\nあなたに初めてになって欲しいから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103138" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「でっ、でも……初めてだから、こんなおっきいオチンポいきなり入らないか\nも……やあぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103139" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「やっぱり手加減しないんですね……？　んふぅ、来て下さい。あぁ……わた\nしの全て……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "150_0103140" ]},
		{"command":[ "SETNAME", "戦闘員Ｃ" ]},
		{"command":[ "SETTEXT", "「あなたに支配されるの楽しみです、ん、んんっ、あああぁぁ～～～っ！！　\n好きぃ、大好きぃ……！！」", "NORMAL" ]},
