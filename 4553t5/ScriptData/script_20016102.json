{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「でぇ？　どうでした？　回想は。何か得られることがありましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010001" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「メタいことを言うな。つーか、肝心のところは何も思い出せなかったんだが\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結局なんで、俺らがお前達に捕まってるんだ？　犬と部外者を捕らえたとこ\nろで利益なんかないだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえ達だけじゃないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010001" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいらが本当に捕まえたかったのはこっちだ。そ～れっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010001" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「うぐぐぐ……。アタシとしたことが、しくじっちまったねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024010001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「フィル！？　お前も一緒に捕まってたのかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「当然でしょう。わたくし達の実力をもってすれば、さほど難しいミッション\nではありませんでしたけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010002" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいら滅棲俄鬼は、こいつら……次元海賊・アルデバランとは別で、この\n一帯を荒らすやつらを追ってたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010002" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「そしたら、めちゃくちゃあやしい船がやってきて……そいつを襲ったら、お\nまえと犬とこいつが乗ってたってワケ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010003" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「なんです。何か気にかかることでも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010003" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て待て。ここいらを荒らしまわってたのは、お前らメス〇キじゃないって\nことなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んまぁ！？　わたくし達を犯人だと思っていたのですか！？　ありえません\nわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010004" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「つーか犯人はおまえ達だろっ。特にこの、フィルってやつは界隈でも有名な\n荒くれものなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010002" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「今までだって、暴れまくって色んな海域を破壊してきてる！　怪しいにもほ\nどがあるだろ、頭よわよわか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010003" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……フィル。お前、いつもそんなことを……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ま、まあ……。うん。余罪がない……わけでもないが……。もごもごもご」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024010002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「そいつに比べたら、あたい達は海賊の中でも正義の海賊～ってこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010004" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「さあ。抵抗しないでくださいませ。もしくはとっとと罪をお認めになってく\nださいませ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010005" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「や、やめろ！　俺は何もしてないんだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あなたがやらかしていなくても、お仲間がやらかしているなら同罪です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010006" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺は無罪だああああ！　離せ離せえええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んっ！？　ひゃあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010004" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あっ！　こいつ！　グラちゃんのおっぱい触ったぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010005" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ち、違う！　そっちが無理やりこっちに触ってきたんだろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……あわ、あわわ……わ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010005" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「サイテー！　さいてー！！　このおにーさん、ヘンシツシャすぎる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010006" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくし達のような、いたいけな少女に痴漢をはたらくとは……変態ですわ\n！　へんたい！　へんたーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010007" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「女の子のおっぱいが好きなんだ！　ううん、ちっちゃい女の子のじゃなきゃ\nだめなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010007" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「犯罪者……。これは銀河まで轟く防犯ブザーを鳴らしてみるべき事案ですわ\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010008" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「冤罪でウルトラ犯罪者にされそうになってるんだが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……ん。い、いいよ……。そ、そこまでしなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010006" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「なんでグラちゃんがおにーさんをかばうワケ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010008" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……謝罪してるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010007" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あらあらあら。グラちゃん、お顔が真っ赤ですわよ？　これは責任を取って\nいただきませんと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010009" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「も、もうこの話はやめよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010008" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「な～んか納得いかないけど……グラちゃんがそう言うなら、しょーがないか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010009" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「そーだ。……おまえを犯罪者にするよりもっといい事思いついた。あたい達\nの船でタダ働き決定」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010010" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あら。それはいいですね。滅棲俄鬼に強制労働させられる気分はいかが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010010" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ばーかばーか！　おまえ、一生こきつかってやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010011" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "9", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "2", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「人権なしなしおにーさん♪　うふふふっ、かわいそぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010011" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ノルマいっぱい♪　身体へとへと♪　くたくたになってざーこざこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010012" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「お給料はぜろぜろ♪　年上なのに、タダ働きさせられて恥ずかしくないんで\nすかぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024010012" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "1", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「財布ぺらぺら♪　大人なのにざこすぎる～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010013" ]},
		{"command":[ "SETCHARA", "1", "char_00020801_01", "8", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたい達に絶対ふくじゅーするって誓ってくださ～い！　た～っぷりわから\nせてやるから覚悟しろ～！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ものすんっごく屈辱的なことを言われている気がする……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ってことで、おにーさんはあたいらの船で、無限タダ働き、永遠奴隷にして\nあげる！　光栄すぎ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024010015" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「もしかして、これってへっどはんてぃんぐ……ってやつ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010009" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ふっ、ヘッドハンティングってのは……海賊が言うと別の意味に聞こえるな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024010003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「逆らったら頭もぎとってやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024010010" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やめてー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「……はぁ……。カツマは捕まり、アタシも逃げられない……と。やってくれ\nるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024010004" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は自業自得だろうが！　反省しろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「そのことは忘れておくれよぉ～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024010005" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}