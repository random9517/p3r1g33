		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ、また……口にっ……ふぶっ、んっ、あぁ……らせっ……精液……ん\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103301" ]},
