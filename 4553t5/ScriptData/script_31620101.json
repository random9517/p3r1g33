{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ま、待たせたようだな……少し心を落ち着かせる必要があったからな……時\n間を貰った」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「私を何だと思っている……？　自分にとっての大事ともなれば、相応の葛藤\nが発生する位のことは理解できるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「とにかくっ……これが肌を触れ合わせる、最初の機会だ。お前も、滅多に出\n来ぬことだと思って感謝するがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「もうお前の準備はいいようだな……ふむ、それにしても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「こ、これがお前の……生殖器……なのか……何というか……全く、様子が違\nうものだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「な、何？　ちゃんと言い方があるのか……チン、ポ……そういう風に呼ぶの\nか、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「チンポ……ふむ、何だか奇妙な響きだが……お前がそう呼べと言うのなら、\nそうしよう……それで、確か……ふぇらちお……だったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「私の口を使って、チンポを刺激し……生殖の為の汁を出させる……そうする\nことが、お前の望みだと……ふぇらちお……か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「……奇妙だな……私には何も響く言葉ではない筈なのだが……何となく、い\nかがわしい雰囲気はあるような気がするぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ええいっ、そこでニヤニヤするなっ。とにかくっ……ふぇらちおだっ。そら\n、チンポを前に出せっ……うあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「な、何だか……さっきより大きくなっていないか？　これが勃起、というも\nのか……必要な時だけ変化すると……そういうことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「全く原始的な……ああ、分かっている。いちいち、野暮は言うまい。とにか\nく、舐めればいいんだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「い、いくぞ……あ……んむっ、ちゅぷっ、ちゅぱっ……んむぅ……何だ……\nこれは……何とも言えない味だぞ……これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「は……んむっ、くぷっ、んふっ……んっ、んぱっ……美味いものでは……な\nいな……じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「何……？　美味いと私は食べてしまうだと……？　何をバカな……そんなこ\nとは……うむ、そんなことは……な、ないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「別に目を逸らしてなどないっ。さあ、柔らかく刺激を与えればいいんだろう\n。やり直しだっ……は……んむぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるっ、くぽっ、ふぉにふぁふ……これで……きもひよくっ……な\nるんらろっ……んくぱっ、じゅぱっ、んぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「何……もっと、深く咥えて……舌を丁寧に当てる……うぬぅ、いちいち注文\nの多い奴め……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「分かった分かった、はんむっ……くぽっ、りゅぷっ、んむっ、これれ……ろ\nうら……んじゅぽっ、くぷっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んむっ……んっ、あぷっ……んぁっ、あむ……ちゅぷ、んっ、りゅぷっ……\nろう、ら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、くぽっ、んふっ……どうやら……いいようだな……ちゅぷっ、\nお前の表情が……目に見えて変わったではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「なるほど……敏感な器官だから、微細な刺激でも反応も大きく……ちゅぱっ\n、感情を高ぶらせることが出来るという訳か……んくぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そういうことなら……りゅぷっ、お前の……チンポを……徹底的に……心地\nよくさせてやる……くぽっ、はむぅ、ん、くぽっ、んぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「くぽっ、この……先端が一番……感じる所なのは間違いないな……？　これ\nを、私の口で挟み込んで……はむぅ、くぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「どうら……？　りゅぷっ、んっ、ちゅぷっ……チンポが震えているぞ？　発\n汗もして……表情も変化して来た……これは快感の反応だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ……んりゅぷっ、何だ、大したことないではないか……この程度なら…\n…んんっ！？　ま、まひゃっ……口のらかで大きく……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んむぐぅっ！　ま、まへっ……ちゅぱっ、ちょっとっ、お、大きす\nぎるっ……もごっ、むっ、んぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んくぷっ、ぷぁっ……はぁ、んっ……まさか……まだ、チンポが膨張すると\nはな……確かにお前のことを見くびっていたようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だ、だが……私とて……そうやすやすと屈するつもりはないぞ。んちゅぷっ\n、そうと分かれば……やりようは……あるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「くぽっ、ふぉら……んちゅ、くぷっ、ちゃんと……チンポは……よくしてや\nる、んりゅぷっ、くぽっ、あ……んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んはぁ……あぷっ、何だか……んっ、ちゅぷっ……汁が出てきたぞ……これ\nは……もう、出たのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……何……これが準備段階のもので……この後……本番の汁\nが……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「つまり……後少しで、精液というのが……出るんだな……？　なら、りゅぷ\nっ、早く出してしまえっ……じゅぷっ、ちゅぷんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぉら……早く……私に、地球の男のっ……生殖汁をっ……味わわせるのら\nっ……じゅぱっ、りゅぱっ、んぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……れるなっ……？　飲むろっ……んっ、じゅぷっ、じゅるるるる\nるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　んぶっ、れたっ……んぐっ！　んふっ、んっく……んぷっ、\nんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「こくっ、んくんっ、けふっ、うっ、むっ……何だ、この味は……全然甘くな\nい……むぅぅ……不味いぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「む……本来飲むものではない……それは、そうか……慣れれば、味が好きに\nなる……？　そんなことがあるものなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んっ……何とも怪しいものだが……まあいい……んっ……しかし\n、随分粘り気があるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「これが精液か……生命力があることは理解した。ふぇらちおのやり方も分か\nったからな……もう迷うことは何もないな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「む……それにしても、射精が終わった後は……チンポは元に戻るのではない\nか……？　どうして、まだ変わらんのだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「一回で終わるようなものじゃない……ふ、ふん！　し、知っていたわ、それ\n位！　あれだろうっ、私もまだ途中だったからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「またニヤニヤしおって！　ええいっ、続けるぞっ……はっ、んむっ……ちゅ\nぷっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んむぅっ……さっきより……なまぐひゃい……むぐぅ……まだ先端が……ヌ\nルヌルしてるではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「これを……丁寧に舐め取ってから……んむぅ……地球の女達はこんなことを\n当たり前にしているのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うぬぅ……ちゅぷっ、りゅぷっ……奴らに出来て……私に出来ぬ道理はない\n……ちゅぱっ、じゅるっ、んちゅ……ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぉら……んっ、りゅぷっ……綺麗に……らったぞ……ちゅぷっ……\nこの臭みも……慣れれば……どうということは、ないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……後は、もう一回……んりゅぷっ、チンポを……れるっ、しゃぶ\nり直す……んちゅぷっ、ふむっ、りゅぷっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「今度は、じゅぽっ、もっと……激しくしてやるぞっ……んりゅっ、くぽっ、\nじゅぱっ、じゅぷっ、んじゅうううぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ……ろうだ？　情けない声を出しおって……私の舌が……りゅぱっ、か\nなりいいと見える……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んぱっ……んふっ、いいぞ……先端だけかと思ったが……この皮\nと繋がっている部分も……かなり敏感なようだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「それに……んっ、体液で……濡れるようになると……ちゅぱっ……唇が滑っ\nて……ちゅぷっ……いい反応を見せおるわ……んりゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ちゅぷっ……奇妙な気分だ……れろっ、私の口に……そのよ\nうな感覚はない筈だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「身体の感覚が……妙だ……んっ……感情が……乱れて……はぁ……高ぶって\nいく……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぇらちおとは……そんな気持ちにさせる……ものらのか……？　ちゅぷっ\n、チンポが……んりゅっ、愛しいと……感じてしまう……りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゅぷっ、どうした……またそんな顔をして……りゅぷっ……い、\n今の言葉で……また出そうになった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……よく、分からんが……また出したいなら……りゅぽっ、くぱ\nっ……射精……して、いいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、はぁ……んむっ、また精液が出る瞬間を……私も……感じたい…\n…ちゅぷっ、こんな感覚になるとは……はぷっ、んぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「一気に……ふるぞ？　りゅぽっ、ぐぱっ、ちゅぶっ、んちゅぅぅっ……りゅ\nぷっ、くぷっ、じゅるっ、んじゅるるるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「我慢……ふるなよ？　お前の……情動を……全部……晒せっ、じゅっぽ、く\nぱっ、全て……見せて……みろっ、んちゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103220" ]},
		{"command":[ "WAITINPUT" ]},

