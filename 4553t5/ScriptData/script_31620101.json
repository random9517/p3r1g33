		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ、このまま出すのか……？　んっちゅぷ……んっ……はっ……あっ…\n…！」", "NORMAL" ]},
