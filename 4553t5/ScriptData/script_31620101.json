		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「何……ぶ、ぶっ掛けっ……？　そういう……趣味が存在する……のか……ん\nっ……あぷっ、」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うぅっ……臭いぞっ……直接鼻先に掛かると……生臭さが際立つ……んふっ\n……あ……んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「もうすぐ終わりか……？　あぁ……もういいから、全部出してしまえ……ん\nちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……終わったな？　んぅ……まだ顔にへばりついている……粘っ\nこいのが……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……んっ、だが……少しずつ味わうと……そう、悪くないような気も\nするな……この味は……不思議な感じだ……ちゅぷ……」", "NORMAL" ]},
