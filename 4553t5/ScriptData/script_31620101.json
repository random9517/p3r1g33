		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「チンポ……出しきったか？　はぁ……んっ、何とかこなせたようだな……ち\nゅぷ……れろっ……後始末とやらをするんだろう」", "NORMAL" ]},
