		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　なっ……顔にっ……出てるっ、あぷっ……お前っ……どういう\nつもりだっ……はっ、んふっ！」", "NORMAL" ]},
