		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぐぅっ！　んんっ、むふっ……んんんんんんーーーーーーっ！　んぐっ、\nんっ、んくっ……んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んはぁっ……はぁ、はふっ、さっきより……多い気が……ふるぞ……ん、こ\nく……んっ、飲み……切れん……ん、むぐっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だが……んっ、この味は……ちゅぷっ……確かに……んんっ、思った以上に\n深みが……んく……あるかも知れん……こく……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「まだ……出るのか？　ちゅぷっ……この際だ……しっかり出し切れ……んち\nゅ、ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んはっ、はふっ……どうだ？　全部……出したか？　ちゅぱ……んっ……う\nむ……確かに甘くはないが……何というか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「不思議な気分にさせる……悪い感覚ではない……身体の中心が少し疼くよう\nな……そんな感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うむ……どうやら、チンポも落ち着いたということは、これで良かったよう\nだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「中々得難い経験だった。お前も感謝するがいい、私自らふぇらちおをしてや\nったのだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「さて、これで次は……もう一段階先に進めるな……ふふ、分からんとは言わ\nせんぞ？」", "NORMAL" ]},
