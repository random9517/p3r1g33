{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0192" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "襲来者も片付けて、俺たちは機械化帝国スペースネットへとやってきたのだっ\nた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても……道行く人がロボットってくらいで、建物とかの見た目はこ\nっちと大差ないな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、次元が変わってもビルは四角いわよ。そっちの方が機能的だし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250001" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど……って、ミヤビ！？　おまえもついてきたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、ふたりになにかあったら困るからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「それより、アーリーボディはデリケートっていったでしょ。普段通りに戦わ\nせないでよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250003" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「壊れちゃうんじゃないかってひやひやしたんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、でもそれはロッテたちがやる気だったから、つい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「しゅうちゅうりょくがおちているのを忘れてました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115250001" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そんなしんぱいされなくても、平気だし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115250001" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「さて、この先が事件現場ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0193" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ここって、スペースネットの整備工場じゃない。アタシの職場だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250005" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか。で、こんなところにどうして俺が？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「防犯カメラの映像をみてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ああっ、ここにうつっているのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115250002" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「兄さん……だね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115250002" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "確かに防犯カメラに写っていたのは俺だ。俺とうり二つの顔の……人間？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「しかも、抱えているのってアンタたちの元のボディよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250006" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「本当だ！　ロッテのボディです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115250003" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「私のボディまで奪われちゃってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115250003" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「整備中のボディを奪うなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250007" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやまて、だから犯人は俺じゃねぇよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だいたい、この防犯カメラの映像の時間、俺はここにいなかったわけだし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん。兄さんは寝ていたよ。ぐっすりだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115250004" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだぞ！　……って、なんでクララがそんなことを知っているんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「えっ、それは、別に……一人で眠れなかったから忍びこんだとかじゃないん\nだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115250005" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……そうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「それは確かな情報ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「間違いないと思うわ。どうしても疑うなら、クララの行動記録を解析すれば\nいいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250008" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「それに、電源の入っていない私たちのボディを二つも抱えるなんて、人間が\nできるとは思えないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そうなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アタシたちはロボットよ。人間サイズの金属の塊をふたつ、普通の人間がや\nすやすと持ち運べるわけないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_010115250010" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「たしかにそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250005" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら、そんなに重いのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えっ、それは、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010115250004" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「女の子に体重の話をするなんて、兄さん最低！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010115250006" ]},
		{"command":[ "SETCHARA", "0", "char_00015804_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「では、このカメラに写っているカツマさんはいったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250006" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、それなんだか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「心当たりがあるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250007" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「前に、別次元のルナテミスが次々やってきたことがあったんだ。だからここ\nに写ってる俺も、別次元の俺って可能性はないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「なるほど……。可能性はありますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250008" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさかこんな形で自分のアナザー？を見ることになるとは。にしても、自分そ\nっくりの顔で悪事を働かれるのはいい気分じゃないな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかも、防犯カメラに顔を撮られるなんて、俺がやりそうなヘマまでしている\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「カツマさん、協力ありがとうございました。次元管理統制局では、このボデ\nィを奪ったカツマさんを追います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250010" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう、そっちは任せた。それで……俺は無実ってことでいいんだよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「はい、お騒がせしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115250011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "よし、疑いも晴れたところで帰るか、元の次元に！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}