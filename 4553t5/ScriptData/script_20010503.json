{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0125" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「はァはァはァはァ……！　な、何なノ……！　この人タチ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060001" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「めちゃ強いシ、本気で命取りにクル……！　金華、殺されるかと思たヨぉ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "泣きべそをかいてしゃがみこむ金華を、蚩尤とセレインが取り囲んだ。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "-400" ]},
	{"command":[ "SETCHARA", "1", "char_00000403_01", "7", "CENTER", "400" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わたしから肉まんを奪うってことの恐ろしさがわかったかー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021060001" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ヒィッ！　怖いヨ野蛮人！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060003" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「オマエのよーな半人前、この街では生きていけないネ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021060001" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ヒィエエ！　その通りでス！　その通り、認めまスからお許しくださイ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060004" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "両手を合わせ、土下座のポーズで拝む金華に、セレイン蚩尤はニヤリと笑う。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "-400" ]},
	{"command":[ "SETCHARA", "1", "char_00000403_01", "8", "CENTER", "400" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「よし、じゃあその肉まんをこっちに渡すんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021060002" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「やぱり、最終決戦はオマエとネ……筋肉オンナ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021060002" ]},
	{"command":[ "SETCHARA", "1", "char_00000403_01", "7", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ふぇえええ、オネーチャンと……家族団欒したかただけなのニ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060005" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "4", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「弱き者、家族でニコニコするコトも許されナイ……。この街は地獄よォ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「家族？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺が事情を聞こうとしたその刹那、顔面に鋭い蹴りが炸裂した。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふごぁあああっ！？　な、なんで俺がぁああっ！？」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「……あなたたち！　金華に一体何をしているんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060001" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「お、オネーチャン！　助けに来てくれたノぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060007" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ええ。もう大丈夫ですよ、金華。辛い想いをしましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060002" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ウェエエエン！　オネーチャン！　オネーチャン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060008" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "突如現れたチャイナ美女に、泣きながらしがみつくお団子娘。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おねーちゃん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021060003" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「そ、そうです！　紅華は金華の、あ、姉です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060003" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「妹を苛めていたのはあなたたちですね！　大切な妹を傷つける人は許しませ\nん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060004" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「イジめてなんかないヨ。ただ、この街は力無き者に厳しーダケ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021060003" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「力……力があればいいんですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060005" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おっ、やるか！？　今ちょうど、中華街バトル決定戦をしてたとこだからな\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021060004" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、そういう戦いじゃねーだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "腫れあがった頬をおさえつつ、ヨロヨロと起き上がる俺。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ごめんなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060006" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐぇええっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その俺の首根っこを、紅華が鷲掴みにしてきた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おっと、人質か……？　ふーん、思ったよりもショボいことするねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021060005" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「いいえ。人質ではありません。この人には、金華が活躍するところをちゃん\nと見ていてもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060007" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「活躍ぅ？　さっき私らに負けた妹がカ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021060004" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ハワワワ、オネーチャン！　この人達バカ強いヨ！　金華じゃ勝てなイ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060009" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「いいえ！　金華！　あなたなら勝てます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060008" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「む、無理ダヨぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060010" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「紅華は、金華のこと、誰よりも信じていますから……！　……やれますね、\n金華！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_010021060009" ]},
	{"command":[ "SETCHARA", "0", "char_00014301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「……。わかたヨ。そこまでオネーチャンが金華に期待してくれるのなラ……\n金華、ヤるヨ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060011" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「コスチュームチェーンジ！！　真・金華お色直しバージョン！　行くアルぅ\nううー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060012" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「せいやァ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「な、何！？　あのコの闘気……急に高まっテ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021060005" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「誰よりもこの街で肉まんにふさわしいのはこの金華ヨ！　中華娘キャラは譲\nらなイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021060014" ]},
	{"command":[ "SETCHARA", "0", "char_00014202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「中華娘キャラ？　ふん、ドーデモいいガ……強き者は好きヨ！　倒すと気持\nちイイからナ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021060006" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからそういう戦いじゃねーだろ！　肉まんはどうした！　アホ脳筋中華娘\nどもがあああああ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}