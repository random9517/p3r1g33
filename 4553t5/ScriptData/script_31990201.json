{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おいおい、なんだぁ？　こんな浜辺に呼び出して。もう帰るところだったぞ \n。ハハッ、もしかして……一人で寝るのが怖くなったのか？　あははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そういうことなら、この奈羅苦ねえさんが一肌脱いでデートしてやってもい \nいぜ。……と、情を出してやろうかと思ったが……あのなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「この衣装が気になってるみたいだな。水着みたいで露出度が高いからか？　 \nさっきから、ジロジロいやらしい目でみやがって……。はぁ、仕方ねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こいつぁ悪の女幹部として、隊長にお仕置きしてやんなきゃいけないみたい \nだねえ。って、それを期待してたみたいだし……そこに横になりな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あ～ああ……。まったく、いつからチンポをこんなに腫らしていたんだい… \n…。昼から？　アハッ、アタシを見て？　困った子だねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そんなにこの衣装、気に入ったのかい。確かにエロさはなかなかのモンだと \n思うけど……隊長に、そこまで刺さってたなんて知らなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「フフフ、元からデカいチンポをビンッビンに硬くして、ワクワクして待って \nたんだねぇ。可哀想に。いますぐ、奈羅苦ねえさんが楽にしてあげないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……どうせ、こうやってこの胸にシゴかれるのを夢見てたんだろ？　それを \n想像して、一人むなしくフル勃起してたんだろ？　何もかもお見通しさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「いつでもどこでも、無節操にギンギンになる悪いチンポは、骨抜きの刑だ。 \nそ～ら、怖いかい？　無理やり襲われて大事なチンポを挟まれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……ん？　な、なんで抵抗しないんだい。こんなにノリノリで脅して怖がら \nせてやっているのにさ。……はァ？　そんなのご褒美です、だって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「す、涼しい顔してなすがままになっていると思ったら……た、大したタマだ \nよ。そ、そうかい。望むところだったってことかい。してやられたねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「フツーはアタシに迫られたりしたら、怯えてガクガク命乞いするもんさ。な \nのに……ああもう、そんなに嬉しそうな顔をするんじゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そ、そうだよ！　アタシも……た、隊長にパイズリしてあげたかっただけだ \nよ！　で、でも……一応悪の女幹部なんだしさ、ノリってもんがあるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「他のやつらみたいに、可愛い誘い方なんて知らないし……。だから、こんな \n風にさぁ……。何？　それなら仕方ないから芝居にのってやる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ハ、ハハハ……い～い度胸してるじゃないか。でも……正直ありがたいよ。 \nそれじゃあ、悪の女幹部に襲われるピュアな隊長って設定でお願いしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……ほ、ほら！　はじめるよ！　ア～ッハッハッハッ！　テメエの弱点…… \n剥き出しの股間を胸に挟まれて、恐怖に震えているんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「このまま、このムチムチで肉厚な極悪巨乳に好きなようにもてあそばれて… \n…恐れおののき、泣きながら射精しな！　そら、いくよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ……♪　んっ、んっ、んっ……！　アハハッ、憎い敵の胸に刺激されて \nも、チンポは喜んで反応しちまうんだねぇ♪　情けないヒーロー様だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そうさ……、アタシの胸にこうしてズリズリシゴかれて、精子出さない男な \nんているはずないからねぇ。徹底的にこの肉棒をイジメ倒してやるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ♪　ふぅっ、ふーっ♪　んっ……ンッ、んっ……♪　ゴリッ、 \nゴリッて胸にこすれるこの……チンポの中の芯……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「どんどん硬さが増していくじゃないか……。感じているのかい？　はぁっ、 \nはぁっ♪　太くて重くて、長いドスケベチンポ……。っはぁっ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「筋肉質なアタシの胸ですら、押し戻してくるくらい元気で……。っんっ、力 \n強くて……なかなかスゴいチンポじゃないかい……。っんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こりゃあシゴき倒すのにも、なかなか苦労させられるよ……。んっ、でも、 \n男ってのはこれっくらい強くないとね……。ほら、ほら、ほら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「奈羅苦ねえさんの全力のパイズリ……受け止めきれるかいっ？　っふっ…… \n♪　やだねぇ♪　ピクピク震えて嬉しがってるじゃないか……。っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「とんでもなく豪快なチンポだよ……。んっ……んっ、んんっ？　な、なんだ \nい？　集中している時に話しかけてくるんじゃないよ……。っんんっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「乳首、を股間に当てながら……っ、あっ♪　こすりつけながらオッパイを動 \nかしてほしい……？　まったく……注文が多いったらありゃしない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「もちろんそりゃあかまわないけどね……。っぁっ♪　乳首、をなすりつけな \nがら、動く、と……♪　それなりにこっちにも快感、がくるんだよっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んんんんっ……♪　隊長の蒸れた股間……っ♪　はぁっ♪　陰毛に乳首がこ \nすれて……あっ、ぁっ、妙なカンジさ……。っあぁっ、あっ、ぁっんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「な……なんだって？　アタシの乳首が、デカくて下品で……あっ♪　感じや \nすくて……いやらしい？　フフッ、敏感なチンポしといてよく言うよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、感じやすさ、なんてお互いさまだろうっ……！　んぁあっ \n♪　それに憎からず想っている相手、のチンポシゴかされてさぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　チンポの臭い……んんっ、形、色……っ。間近にこの目に見せつけ \nられてっ……感度上がらないほど、奈羅苦ねえさんは薄情じゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んんぁっ、隊長のチンポ……先走りが少しずつ垂れてきて、めちゃくちゃイ \nヤラシいんだよ……！　っあっ♪　アタシだって、性欲くらいあるんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「好きなっ、男のチンポ胸でいじりまくってっ♪　何も感じないわけっ、ない \n、だろ……！　あっ♪　あっ、美味そうでよだれがわいてくるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ！　あっ、欲しい……♪　このチンポ、すっごく欲しい……！　で、も \n、隊長がパイズリでイキたいっていうなら胸に出してくれていいんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ♪　ねえっ、出しな！　断るなんて許さないよ！　あっ♪　あ \nっ、奈羅苦ねえさんのデカパイにびゅーびゅー射精してみせな！　そらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っんふぁああああああ……っ♪　やるねぇっ、すごい量じゃないかぁっ…… \n♪　は、ぁ♪　すっごく濃い臭いだ……あぁ、欲情しちまうよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁっ、んんんっ♪　熱い……いいよ、腰を浮かせて……奈羅苦ねえさんの \n胸の中に甘えて出しな、いくら出してもタダなんだ、好きなだけっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「出し、とくれ……んぁっ♪　あっ♪　あっ、うううっ♪　なんだい？　根元 \nから絞り上げてほしいんだね……わかったよ、どれっ……ん～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おぉっ♪　ぴゅるぴゅるっと残り汁が……♪　いいねぇ……♪　もう全部出 \nたかい？　まだだね？　じゃあもう一度……絞り、あげて……！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「びゅーっ、びゅーってアタシの谷間に……♪　どんどん溜まってくよ、隊長 \nの精液……もっと浴びせとくれ、精液溜まりが出来るくらいにね……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……はぁあああ……♪　ゴ、ゴメン……。今アタシ、悪の女幹部って設定も \n忘れて、夢中でチンポを絞りまくっちまったよ……。んんん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「だぁって、隊長ってば真っ白で、臭すぎる最高の精液を出すもんだからさぁ \n……。うんうん、わかってる。次からはちゃんとやるよ……。ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アハハハ、まさか１回きりの射精で終わりってことはないだろう？　ほら、 \nこんなにまだチンポも硬いのに。２回戦……するよねぇ？　っていうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……コレはお仕置きなんだから、アタシが勝手に決めさせてもらうよ。フフ \nフッ……。隊長？　精液まみれの情けない勃起チンポはもうアタシのモンだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「だから許可もなく……。んっ、お仕置きパイズリ続行決定だ。そらっ……！ \n　ぬめりでますますチンポにキくだろうっ、……あっ♪　んっ、んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……んんっ？　ヌルヌルして、アタシの方も感じてるんじゃないかって？　 \n……う、うるさいよ！　隊長は一方的にシゴかれてりゃいいんだ！　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「奈羅苦ねえさんのっ、オッパイに白い精液は映えるだろうっ……？　っぁっ \n♪　そこはね、すごく気に入っているんだ、精液がわかり、やすくてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長がどんだけ出したか目で見やすいっ……！　んっ♪　それに……はぁっ \n、はぁ、ん、ふ……♪　ふぅっ、ふううっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「精液がかかると、アタシの硬い胸が……ほんの少し、柔らかくなって隊長の \nチンポに絡む、気がするんだよねぇ♪　これは気のせいかも、しれないがっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　隊長の精液を浴びるたびにっ♪　アタシのオッパイが女ら \nしく、メスとしての魅力を増してく気がして嬉しいんだ……っ、んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　チンポにだんだん馴染んでいって……んぁっ♪　とろけてく自分の \n胸は嫌いじゃ、ない……♪　元々奉仕するのは好き、だしね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「隊長はチンポが気持ちいい、アタシはオッパイが気持ちいい……。はぁっ、 \nまさにウィンウィンの関係ってことさ。だから……んぁっ♪　思う存分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシの胸で感じるんだねっ！　……んっ！　そぉら、スピードあげてくよ \n……！　っぁっ！　チンポがもげないように踏んばりなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　奈羅苦ねえさんのオッパイは、他の女達より強くて豪快だ \nからねっ……！　必死についておいで！　ほらっ、ほら、シゴいてるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こ、こかいっ？　ここがいいのかいっ……あっ♪　あぁ、アタシもイイよ、 \n隊長のチンポでオッパイ気持ちいいよっ……！　あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ、もっと胸を寄せて……あっ♪　チンポに密着させてほしいんだねっ♪ \n　んっ、んっ、いいんだ、たくさんワガママを言えばいいっ……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「奈羅苦ねえさんのオッパイはっ……！　あ、んっ♪　隊長、だけの専用オッ \nパイだ……！　好きに使ってくれてかまわないんだよっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……アハハッ♪　ま～たチンポがパンパンに膨らんできた……♪　先走りと \n精液とで、アタシの胸ももうトロットロさ……。んっ、出したいかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「クククッ……♪　どうしようかねぇ、気持ちいいだけのお仕置きなんて、悪 \nの女幹部の名がすたるかねぇ？　……なんて、嘘だよ、ウソっ。んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「出したい時に出すのが一番さ！　っぁっ♪　イキなっ！　出すとこ全部見て \nてあげるよ！　奈羅苦ねえさんのオッパイに全部出しちまいなっ！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んッ！？　おおおおっ♪　あっ♪　あっぁっあっ……♪　スゴいねぇ、１回 \n目の射精よりずっと飛距離が伸びてるよ……それにっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ♪　勢いもあがってる……！　うんっ、うん、イイねっ……！　絞り出 \nしてあげようじゃないか！　ほらっ、ほら、全部残さず出しなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「奈羅苦ねえさんのオッパイの色っ……真っ白になるまで出すんだよっ、この \nドスケベチンポっ……♪　んぁっ、あっあぁっ、まだまだだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そんなにチンポを脈打たせて……あっ♪　ドクドク射精しといてもう終わり \nってハナシはないだろう！　まだっ、まだ出しな！　ありったけ出しなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っくふぅうううううっ♪　ふぅううっ……♪　そうさ！　アタシの胸にっ… \n…隊長のモノって印、つけときな……！　っあっあっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「やればできるじゃないかぁっ……んあああっ♪　上手に出せたね！　あっ♪ \n　これでパイズリしたかいもあったってことだ……！　っああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……クククク……♪　んふふふ、フフフフッ、あはははは……！　どうだっ \nた？　悪の女幹部ごっこをしてみせた奈羅苦ねえさんは……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そうかい、そうかい。気に入ってくれたかい♪　……それなら良かった。… \n…ん？　ところどころ、人のよさが滲み出してしまってたって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……そ、それはさ……。本来の性格ってのは、なかなか変えられるもんじゃ \nないからねぇ……。でも、やってて楽しかったよ。だから……そうだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「またこんな風に、色んな服を着てパイズリ……だけじゃないか、色んなプレ \nイが出来たら嬉しいよ。その時は、心底頑張っちゃうから楽しみにね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ひぅっ！？　ちょ、ちょっと隊長！　いくらなんでもそれは飛ばしすぎだよ \nっ……！　あっ！？　こ、コラッ、顔にかかってるってば……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっあっ！　あっ！？　あっ……。も、もう……仕方ないねぇっ！　いいよ \nっ、そのまま……かけなっ、顔にでも胸にでも……好きな、ところにっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んううっ……♪　なんて熱さ……、それにエグいくらいの精液の臭い……っ \n♪　隊長ってば、こんなにもオスくさい射精をする男だったかいっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「んっ♪　まるで……アタシの顔に、マーキングしてるみたいに……っ。んぁ \nっ♪　こらっ、さすがにこれ以上かけられたら……ぷぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ろ、ロクに息もできやしないじゃないかぁっ……！　んんっ！　どんだけ出 \nすんだいっ……♪　んはぁっ、もう……もう充分だろう……んぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「もう胸も、顔も……隊長の汁まみれさ！　あっ♪　あっ、そうだよ、アタシ \nは全部隊長のモノだ、だから……ああああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っふーっ……♪　出しに出してくれたじゃないかぁ……♪　はぁ、はぁ、い \nっくらなんでも限度ってもんが……あるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019902_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……なんだって？　頭っから精液をぶっかけられたのに、アタシが嬉しそう \nで……口元がずっとゆるみっぱなし？　そ……それはほっといとくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「悪の女幹部なんて演じても……思わず素になっちまうことだって、あるだろ\nう？　何ぃ？　元々悪の四天王なのに、女幹部は演じられないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「う、ううん……？　ま、まあ次はもっとうまくやるからさ。もっと悪く…… \n。うん、その時のアタシに期待しといとくれ！　隊長……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}		
	]
