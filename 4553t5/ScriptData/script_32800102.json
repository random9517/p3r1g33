		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんんんんんーっ！　あっ……くぅぅんっ……！　あぁっ、あぁぁぁっ！　 \nどんどん、激しくなっていくっ、オ、オチ〇ポが暴れてっ！」", "NORMAL" ]},
