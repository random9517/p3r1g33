		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんんーーーっ！　あっ、出てっ……るっ……はへぁっ……また、子宮っ… \n…中出しっ……されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104301" ]},
