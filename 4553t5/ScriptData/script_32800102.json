		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……危ないかも知れないのに……妊娠しちゃったらぁ……んぁぁ…… \nでも、これ……気持ち良すぎるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「もっと……流し込んでぇ……奥までいっぱいにしてぇ……私のオマ〇コ…… \n精液漬けにしてしまってぇ……は、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「ダメェ……ずっとイッたままになってるぅ……気持ちいいのが止まらない… \n…身体……ずっとジンジンするぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んぁ……あふっ……オチ〇ポ……止まった……んんっ、射精……出し終わっ \nた……のか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……あ……ふっ……精液が……んんっ、溢れ出して……来てる……こん \nなに、沢山出すなんてぇ……はぁぁ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「すっかりオチ〇ポに夢中……そ、それは……うぅ……でも、もう私は、否定 \nするだけの説得力を持っていない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「実際に貴方のオチ〇ポに狂わされて……何度となくはしたない声を上げて乱 \nれた姿を晒して……それを受け入れてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「後はもう認めてしまうしかない……私は……オチ〇ポに屈服してしまったと \n……あぁ……い、言ってしまったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「もう逆らえない……これから、私は……ずっと……貴方のオチ〇ポに服従す \nるしかないんだ……」", "NORMAL" ]},
