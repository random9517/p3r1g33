		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「また……可愛がってもらう……あぁ……その言葉を嬉しいと思ってしまう自 \n分がいる……また、して欲しい……それが今の私の気持ちなんだ……」", "NORMAL" ]},
