		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……中出しだけじゃ飽き足らずに……こんな、濃いのを浴びせるなんて \nぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んあぁ……このぬめり……臭いが……染み付いて……はぁぅ……ダメだ…… \nまた、イク……あぁぁ……イ……ってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ、ねとねとだ……顔にもおっぱいにも……お腹にも……貴方 \nの精液まみれにさせられてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……射精……終わったのか……でも、まだ……オチ〇ポが私の身体に精 \n液をなすりつけている……あぁ……くすぐったい感覚が気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……あぁ……さ、さっきオマ〇コに出された分が……少し漏れて \nしまってる……あぁ……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00028001_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そ、そんなにじっと見つめないでくれ……自分がどんな状態なのか分かって \nいるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「こんなに中出しされて……身体も汚されて……私は……オチ〇ポに堕とされ \nてしまった……んぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「何より……私は、それを受け入れてしまった……もう貴方に屈服してしまっ \nた……それを認めてしまったのだ……」", "NORMAL" ]},
