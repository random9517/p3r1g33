{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おうおう。キミのチンポってばすっかりガチガチになってるじゃーん。なに\n？　もしかしてこの状況でエッチできるって思ってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなことするわけないじゃーん。キミには素股で十分でしょ？　うりうり\n、こうやって腰を動かしてさ、チンポにマンコ擦りつけ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うひっ、チンポめちゃくちゃ熱い。やだわ～、ケダモノチンポ。ボクのマン\nコが火傷しちゃうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっとずりずりってマンコ擦りつけちゃおっかなー。んふふっ、どうかなー\n？　ボクのオマンコ、あんっ、だんだん濡れてきちゃってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だってほらー、キミがこんなにチンポ勃起させて、せつなそーにボクのこと\n見つめてくるんだもん。興奮しちゃうよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクに素股されて、キミも興奮してるみたいだし？　ほら、乳首も勃起して\nんじゃーん、うりうり、乳首こねくりまわしてやるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あははっ、キツそうな声出すね。男の人も乳首気持ちいいんでしょ？　ボク\nも乳首めちゃくちゃ感じちゃうんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「オナニーのときなんか、こんなふうに乳首をクリクリって転がしちゃうんだ\nー。あんっ、気持ちいいからって暴れちゃダメだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「本当、キミは最高のオカズだよ～。キミの顔を見ながら、ボクの腰も止まら\nなくなっちゃう……んっ、マン汁も止まらないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらもうヌルヌルで……ああ、もうマンコ切なくなってきた。いつものオナ\nニーなら指を入れちゃうところだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「今日はキミがいるからね……。あー、気が変わった。んひっ、どうかな？　\nキミはこのマンコに、チンポハメちゃいたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほらほら、こんなにぐっしょり濡れた、ホカホカのメス穴☆　勃起チンポを\nズボーっとぶち込んじゃっていいんだぞー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お？　その気になった？　言う通りにしてやるから腰を浮かせろって？　\nはいはい、こうかなー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……んひぃっ！？　ちょっ、まっ、本当に一気に……！？　チンポがっ、\nぼ、ボクの中に……きてるぅううぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、ハメたらわかるっ！　こ、これ……こんなに太かったんだ…\n…！？　や、やばいかも……こんなのハメられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「う、動いちゃうんでしょ？　このまま、ボクのマンコの中をずこずこ突きま\nくっちゃうんでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　動いたっ、ああっ、動いてるっ！　んおおっ、おおっ、チンポ\nが……あっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのこと、突き上げてっ、んぉっ、おっ、おおぉおおおっ！　チンポ、\nチンポぉおおっ！　うひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「き、キツキツだって、そんなの当たり前じゃないか。んぉおっ、チンポなん\nて、キミのが初めてなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「これが本物のチンポが、マンコのなかに入っちゃってる感覚……！　ああっ\n、ねえもっと、もっと強く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んはぁあっ！　そうそう！　そうやって思いっきり突き上げてっ！　んおお\nっ、おおっ、オマンコの深くにチンポ突き刺して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あと、あとおっぱいも！　もう大サービス！　ボクのおっぱいも好きにしち\nゃって！　好きにいじめちゃっていいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そうだよぉっ！　んぉおっ、おおっ、おっぱいに指っ、んはぁっ！　鷲掴み\nっ、ぎゅってして……んひっ、ひぃっ、ひぃいぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいよっ、いいよぉおおっ！　おっ、おっ、めちゃくちゃキくぅうううっ！\n　おっぱいとオマンコ、同時責めぇえええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「実際にされるの、こんな感じなんだ……！　ああっ、これヤバ、刺激強すぎ\nてあっというまにイッちゃいそう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぶっといチンポが、ああっ、オマンコずんずんって突き上げてっ！　おっぱ\nいも、乱暴に揉まれてぇえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、だめ、これヤバい……！　めちゃくちゃにされながら、\nああっ、頭が……おかしくなっちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、キちゃうっ！　キちゃうのぉおおっ！　おおっ、おおっ\n、おほぉおおおぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「イッちゃった！　イッちゃったぁあああぁぁぁっ！！　マンコ、イッ、イッ\nてる！　イかされちゃってるぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104129" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「潮噴いちゃってる！　んはっ、はぁあっ、潮吹きアクメッ！　キめちゃって\nるのぉおおおぉぉぉっ！　うひぃいいぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああっ、鬼畜ぅっ！　イッてるボクのオマンコ、おおっ、チンポが突き上げ\n続けてるっ！　んぉおっ、おっほぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポがビクビクしてる……！　今度はキミの番。キミがボクの中でイク番\nなのぉっ！　んはぁっ、ああっ、きてぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのチンポ、いっぱい締め付けて……ザーメン、搾りだしちゃうから……\n！　ああっ、そうだよ、中出しされたいのぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのマンコに思いっきり中出しっ！　キミの生ザーメン、びゅくびゅく\n注いでぇええぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んはぁあああぁぁぁっ！　ああっ、あはぁあああぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「きたきたきたきたきたきたきたきた……！　ザーメン！　中出しザーメン！\n　ああっ、熱いのっ、熱いぃいいぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「火傷しちゃうぅっ！　子宮っ、燃え尽きるぅうううぅぅぅっ！　うひぃいい\nいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのザーメンに、ボクのオマンコがいっぱいにされちゃってる……！　\nああっ、ああ……っ！　溢れるくらい、いっぱいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「孕まされちゃう……赤ちゃんできちゃうのにぃ……！　んひぃい……だめ…\n…孕むの想像したら、ヤバい……イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「中出しされながらイクの、止まらないよ……！　んぉっ、おおっ、またイク\nッ！　んふーっ、んふぅー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「も……もっとしよ……。まだまだ、キミのチンポは元気なままだし、イける\nでしょ……ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほら……こんなに弱ってるボク……チャンスだと思わない……？　今までの\n仕返しができちゃうんだよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ね～、ほらほら～、据え膳マンコだよ～？　思いっきり犯すチャンスなのに\n逃しちゃうのかな～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぬぅっひぃいいんっ！！　きたっ、またきたっ！　おおっ、チンポ突き上げ\nぇっ！　そ、それそれぇ……チンポ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひっ、んひぃいっ！　あっ、あっ、ああぁっ！　むっはぁあっ！　ずんず\nんきてっ！　チンポ、チンポチンポッ！　んっほぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぶっといチンポが一番奥！　ボクの子宮にっ！　んぉおっ、おおっ、突き\n刺さるくらいっ、入ってきてるぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひいっ、イッ、イッてる！　イかされてる！　んはぁあっ！　ぶっとい\nチンポで子宮ゴツゴツされるのぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そうだよぉっ、ザコマンコだよぉっ！　初めてチンポにあっという間に堕と\nされちゃったよぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んほぉっ、おっ、おおっ、ボクも腰振っちゃうぅっ！　キミと一緒に腰振っ\nちゃうよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どんどんマン汁溢れさせてっ、チンポ、チンポ欲しがるっ！　んぁあっ、\n気持ちいいっ、これいいっ、すごいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっぱいも、オマンコもぉおっ！　ああぁっ、いっぱいめちゃくちゃにされ\nちゃう！　んひっ、ひぃいっ、おっ、おっ、おっ、おおぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「マンコ、もっと、もっと、めちゃくちゃにっ！　ああっ、ああっ、突いて\n突いて！　んひっ、んひっ、突き上げぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ずっこんずっこんきて！　んおぉっ！　おおっ！　キミのチンポいいっ！　\n指もいいっ！　おっぱい揉まれるのもいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「全部めちゃくちゃにされてる！　気持ちいいのでいっぱいにされちゃってる\nぅっ！　んぉおっ、おっほぉおっ！　ふひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いっぱい締めちゃう！　マンコ締めちゃうよ！　キミのチンポから精液だせ\nるように……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いっぱい！　いっぱい！　びゅくびゅくびゅくびゅく濃厚チンポミルク射精\nっ、射精ぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぉっ、おおっ、キそう！　イキそう！　もうイクッ、イクッ、さっきから\nイッてるのに、また、イクッ、イクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっ、おっ、おおぉっ、んぉおおっ！　ボクにちょうだい！　キミのザーメ\nンちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ドロぐちょマンコに！　キミのザーメンでアクメ刻んで！　もっとイかせて\n！　気持ちいいのちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ザーメン！　ザーメン！　んぉっ、おおっ、きてきてぇっ！　ボクをイかせ\nて……！　おっ、おっ、おおぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んほぉおおぉぉ～～～っ！　おっ、おっ、おっ、おっ、イクイク！　イクイ\nクイク……ッ！　んぃいっ！　イッくぅうううぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「またきたザーメン、中出しザーメン……！　んひっ、んひひひぃっ！　どぶ\nどぶって流れ込んできてるのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おおっ、おおっ、腰震えるぅっ！　びっくんびっくんイキまくってる……！\n　んはぁあっ、アクメきてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひっ、んひっ、潮噴いてイッちゃう！　オマンコがイキまくってる！　\n中出しアクメとまらないぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぎゅうぎゅうチンポしめて、キミの精液を最後まで搾り取っちゃうぅっ！　\nんはぁっ、んはぁあっ、ああぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひやぁああ～……。ドロドロザーメン中出しぃ。こんなに中出しされたら\n絶対に赤ちゃんできちゃうよ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。キミのことは前から気になっていたけど、こんなに凶悪\nなチンポの持ち主だったなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいねぇ……おもしろくなってきたね……。んひひぃ……チンポ……もっと\n射精させてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「逃がさないよ。今度は攻守交替なんだから。ボクがキミのことヒィヒィ言わ\nせてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「逃げたかったら……。そうだね、さっきみたいにボクのオマンコをいっぱい\nいじめてほしいな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んほぉおおっ！　おおっ、おおっ、かけてかけて！　いっぱいボクにぶっか\nけてぇええぇぇ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「中だけじゃなくて、全身をキミのザーメンでドロドロにぃっ！　んひっ、\nんひぃいっ！　おっほぉおおぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「すごいっ、すごいぃっ！　んぉっ、おおっ、くっさいザーメン、だくさん\nボクのこと汚して、んひっ、んっひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっついザーメン肌にかかるたびにイクッ！　イグッ！　イグイグ！　んぃ\nっ、イッ、イッぐぅううぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふぅ～～～、んふぅ～～～、キミとのセックス……想像以上だよぉ……。\nんはぁ～～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのザーメンで真っ白に染められるの……最高に気持ちいい……。はぁ…\n…はぁ……ヤバ……クセになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00023101_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ねぇ……もっと……もっとだよぉ……。ボクと気持ちいいこと、もっといっ\nぱいしよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「２回目でもまだまだこんなにこってりザーメンなんだから、もっとできるで\nしょ？　ね？　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んひひっ、ボクはキミとのセックスの虜になっちゃったんだから。満足する\nまでキミを帰さないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そして今度はボクの番。キミのこと、ボクから離れられなくしちゃうんだか\nら。にひひひっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0104410" ]},
