{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こういうことになるのではないかと思いました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "私たちが抵抗しているところに、", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あのレディ・ホープとかいう女がやってきたんだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかも、さらに大勢の統制局員をつれてな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「く……さすがに相手の人数が多すぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「抵抗は……無意味か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「理解していただき助かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「で、でも納得いかないわ。ホープちゃん。カツマちゃんをまた拘束するなん\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「カツマ隊長はあくまでも『仮釈放中』です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「再び身柄を確保する必要が出てきましたので、こちらで預からせていただき\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ？　また、時間帝国がらみなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「その通りです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「なので、また皆さんの協力次第で、カツマ隊長は早めに解放できるかもしれ\nません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「またか！　今度はどんな虫を捕まえればいいんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「虫？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そういうことがあったのですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「今回、皆さんに探してきて欲しいものは、宝箱を持つタヌキ像です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110007" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだそりゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「これはとある次元の博物館から盗まれたらしい美術品なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「盗まれた『らしい』って、なんだかふわふわした言い方だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「断定できないのです。なにせ、ある日忽然と消えていたのですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「なにかの拍子に次元を超えてしまった可能性があり、我々が調査したところ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「現在はどうやら地球の九重市内にあるらしいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんでそんなものがＥＤＯのご近所に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115110001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「で、そのタヌキ像ってどんなのなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115110002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0190" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「こちらです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ、これは……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「宝箱を持っている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「タヌキちゃん……だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「顔がお前にそっくりだな、ルナテミス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ、なにを言っている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私に似ているということは、つまりお前に似ているということじゃないか！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私はこんなに知性の感じられない顔をしていないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　わ、私だって、こんな間抜けみたいな顔していないが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ほう……どうして私の顔を見て言うんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115110004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前こそ、さっき私の顔を見て言っただろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぬぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115110005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぬぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい姫様もアナザーも、その辺にしておけって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやはや、このような光景も久しぶりですなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「というわけですから、この『宝箱を持つタヌキ像』を探してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110013" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「見つかるまでは、カツマさんを解放できませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、こら！　カツマを連れて行くな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっと……俺はこれから、こいつらから押しつけられた仕事をしないといけ\nないんですけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そんなことよりも、我々の指示に従ってもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115110015" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……そう、か……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、なにかろくでもないことを考えておりませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010115110003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そ、そんなことはないぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「すみません姫様！　そういうわけなんで、よろしくおねがいします！　始末\n書も頑張って書いてください！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　カツマぁあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「少しは抵抗する素振りを見せろぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115110010" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}