{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「急にどこかへ行こうとするので……不安に思っていたら……。ここに来たか\nったんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00001303_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、いえ……。トレーニングにでもでかけるのかと思っていました。だ、だ\nって……その……。この部屋ですることって、エッチなこと、ですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そういうことなら、わ、私の部屋でもできるじゃないですか。だから……わ\nざわざでかけるなんて、と……。え？　ここは防音だから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ぁっ……。そ、そうなんですか……。確かに私の部屋じゃ、何かすればまわ\nりに聞こえかねませんもんね。『それに』？　それになんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『やってみたいことがある』……。はぁ。なんだか嫌な予感がしますが……\n。あなたがそこまで言うのなら、断れません。何をしたいんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『一時的に身体のコントロールを俺にくれ』？　かまいませんよ。それで、\n何を……って、きゃ、きゃあっ！　一体どういうことですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304106" ]},
		{"command":[ "SETCHARA", "0", "char_00001303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「変な機械の上に座って……！　あっ、自分で自分の股間を露わにしたかと思\nったら！　っ……て、手首を拘束して……。っあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「こ、これっ……身動きができません！　それに……んうっ！　おかしな振動\nが！　身体に……ア、アソコに伝わってきて……。はぁっぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ムズムズ、します……！　あっ……！　あっ、いやぁっ……！　あっ……！\n　あっ、や、やめ、て……やめ……！　んん！　あっ、ぁ、い、いや、ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「なんでこんな刺激が……っ……！　『肉体の主導権を返すぞ』？　ええっ！\n？　今戻されても、私全然動けないですよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……あのっ！　あのぉっ、カ、カツマさん！？　………あれ……？　返答が\nないなんて……。だ、黙っていないで話してください！　…………うそ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ど、どこかにいってしまったんですか！？　……そ、そんなことありえない\nですよね！　私達、今合体していて……。……声が聞こえない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ま……まさか私を捕まえて、動けなくして……。快感だけを与えながら放置\nするつもりですか！？　た、確かにこの姿なら刺激への耐性はあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「でもっ、それは痛みや苦しみに対する耐性で……！　快楽に関しては、……\nんっ、ぁっ！　ひ、人並みのまま……普通のままですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……っぁっ！？　あはっ！？　……あ……！　あん……！？　と、透明な手\nに撫でられているみたい……。これも特殊な科学技術……？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「無数の指が、私の胸に、腰に……ふとももにッ……ふぁっ！？　あ、アソコ\n、に……触れて……ゾクゾクする感じ……。っこ、怖い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「カツマさん！　カツマさん！？　おふざけだったら怒りますよ！　お願いで\nす、何か言ってください！　……ん、くぅっ！？　ふぅうっ、くぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「だめ……声は届かないし……。それに、手が……！　み、見えない手がどん\nどん際どいところに触れてきて……。ふ、ぁ……で、でも耐えないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私はシルバスター・ブルーなんだ、から……！　これくらいの苦難は乗り越\nえてみせない、と……！　ン……！　頑張らないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「…………。はぁっ……はぁ、はぁ……！　何分経ちましたか？　１分……２\n分、５分……？　なのに状況が、ぁ……全然変わらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「むしろ悪くなってます……っ！　極限まで感度をあげられて、……あっ、ア\nソコの浅い部分だけをくちゅくちゅと刺激、されて……。んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「丸出しの胸を、柔らかく包まれたり、触れるギリギリのところをさわさわと\nなぞられたり……。なのにはっきりした接触はしてくれなく、て……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「フラストレーションが溜まっていくだけ……。じりじりと、快感の芽を植え\n付けられて……。私が限界になるまで放っておくつもりですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「っふぅううう……！　ふぅっ……！　ふぅうう……！　……ん……！　カツ\nマ、さん……カツマさん、どうせ見ているんでしょう？　あ、あの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「戻ってきて、ちゃんと触って……ください……！　これじゃあ拷問です、感\nじる半歩手前で、スレスレでずっとおあずけさせられていて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「アソコがヒクヒクして、つ、つらい……です！　胸も……胸もジンジン疼き\nっぱなしで！　も……もう切なくて……我慢できない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「合体、解除します……！　んっ……カツマさん！　私のこと抱いてください\n！　はやく……はやく、この昂りをなんとかしてくださぁい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んんっぐぅうううっ♪　んぐぅうううう♪　いきなり生でハメるなんてぇえ\nえっ♪　あああぁ♪　抱いて欲しいとは言いました、けど……ぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「容赦なくガッチガチのオチンポっ♪　オチンポ……♪　前戯無しで生挿入す\nるなんて、あ、あなたは悪魔ですかぁっ♪　んぉっ♪　あぁっ、すごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「いきなり挿入された、のに……！　私の身体、しっかりカツマさんを受け入\nれてる……！　離したくないってアソコがねぶりついてるぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁああっ……！　そう、ですよね、柔らかくなっちゃってましたよね……\nっ。私のオマンコ、濡れて、潤んで、ヒクヒクってヒクついてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あとはオチンポ入れるだけの簡単な穴になっちゃってるのわかってました♪\n　あぁ……たまらないです、ふと、いぃ♪　太いんですあなたのチンポぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そのせいで満たされちゃうんですっ！　オマンコが……！　あっ！　胸も、\n胸も揉んでください……それで、全力で犯してぇ、マンコ突いて突いてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んふぅうううーっ♪　んぐっ、んぐっ、んぐぅ♪　ひぃいっ……！　あっ！\n　あっ！　肉棒が……オマンコの中で暴れてる、どちゅどちゅ入ってくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「気、持ちいいぃい……♪　気持ちいいのぉ♪　もっとです！　もっとピスト\nンしてください！　腰が壊れるくらいチンポ打ち付けて！　そう、そうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んはぁああああ♪　いいっ……！　あっついゴリゴリチンポっ！　叩きつけ\nられて、ねじこまれて……オマンコ穴を拡張されて、感じちゃいますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あなた、も……あなたもいつもより大きいですね……♪　『入れただけで吸\nいついてきて、ヌルヌルしすぎててすごい』？　あは……嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『チンポ全体に絡みついてくる』？　『引きずり込まれそうなくらいイイ』\n？　わ、たしも自分でわかりますよ、すごく締めつけてること……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「だ、から、悪いのは私ですからぁ……好きにしてください！　入れてすぐに\n出しちゃったっていいんですっ、私も……私も欲しいから……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふうううっ♪　精子ぃい……！　カラッカラに乾ききっていた私の心に……\nしみますぅう♪　潤っちゃう♪　またびしょびしょになっちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あーっ、ああっ♪　あぁあん♪　そうです……これが欲しかったんですぅ！\n　カチカチのオチンチンから発射されるアツアツの精液ぃいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「オマンコの一番奥にビュッ、ビュルッて当たると……脳みそが痺れるくらい\nに気持ちいいんですっ♪　あっ、あっ、もっと、もっとくださぁいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「びゅーっ♪　びゅーっ♪　びゅーっびゅーっ……♪　くふぅうう……♪　お\nいし、い……♪　子宮口が悦んでますぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「弾力のあるプリップリのザーメン……♪　あはぁあ……♪　絶対純白で、う\nじゃうじゃ子種がいるはずです……！　はぁっ、はぁ、はぁあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ねえ、……このまま！　オチンチン入れたままで抜かないでエッチを続行し\nてもらっていいですか……っ！　ゼリー状のプルプル精液ぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「オチンポでオマンコに塗りたくってほしいんですっ！　それ、で♪　それで\nぇえ……♪　泡立つくらい攪拌して、かき混ぜてくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　あぁああう♪　そうですっ、そのまま……そのまま来てくだ\nさい♪　抜かずの二発目で、私の欲求解消してくださいっ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「……あっ♪　あぁっ……力強いピストン……♪　わた、しも腰を揺らし……\nますね、はぁぁっ……♪　もじもじしちゃってすみませんん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ちょっとでも快感が欲しくて……欲しくてぇ♪　くぅう♪　……腕を拘束さ\nれていることで……なんだか肌が敏感になっている気が、しま、すぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「最大限、オチンポの強さを感じられる状態で……！　はぁんんっ、あなたの\n、あなたの好きにされるなんて……！　やっ♪　あっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「こんなのぉ……昂っちゃって、興奮しちゃってクラクラします……！　あぁ\n……。わ、私……私、捕まるシチュエーション……好きなのか、も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「一方的に、逞しいオチンポでオマンコじゅぷじゅぷ犯されちゃって……っ。\n抵抗できなくて！　動け、なくて……好きにされちゃってぇ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「屈しちゃだめ、なのに♪　自分も腰を振ってしまって、あぁ♪　強火の快楽\nであぶられるような……中から♪　オマンコから支配されるような♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「くぅうううううんん♪　カツマさぁん！　もっと支配してくださいっ！　正\n義の味方……っ、あぁっ、シルバスターを凌辱して、調教してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「いくら努力したって♪　女の子はオチンチンにかなわないって♪　オチンチ\nンを入れられちゃったら喘ぐことしかできないって思い知らせて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ああーっ！　あっ♪　あっ、あっ♪　やっ、あぁ♪　あぁあっ、あぁ……！\n　ピストン一番奥にきてるぅ♪　女の子の弱点えぐってるぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「いいっ♪　いいっ、いいの……！　とろけちゃう！　オマンコとろけてチン\nポに甘えちゃいますうう……！　あ！　あ！　あ！　ふぅぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁ……ザーメンまみれのオマンコで、一所懸命搾りますから……シゴきま\nすからぁ♪　また、ください……一番奥に、新鮮な精液ぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あはっ……♪　この身体、なら……大抵の衝撃には耐えられますか\nら……お願いしますっ……ザーメンくださぁいい……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああああ……っ♪　あああああああん、はぁん、んんんんぁ\nああん……ッ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁ、すごい勢いで精液が……精液があがってくるぅ♪　オマンコを駆け巡\nってるぅ……！　あるだけ全部出してください……いただきますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「無駄にしないで飲み干しますから……っ！　オマンコにビュブビュブ注いで\nください……っ、敏感になりすぎた私の粘膜に注射して……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ッんぅうっ♪　んーーーーっ、出てる、出てる、出てます……！　ああああ\nっ……！　あった……かい……。お腹の中に広がって、く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「うふふ……っ。休憩なしで二回目の射精なのに、こんなに出ちゃうものなん\nですか……？　お腹が破裂するかと思いましたよ……。って、あぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「まだ出てる！？　ん、くぅっ……！　ぜ、絶倫にもほどがあります……っ！\n　はぁっ……あぁ、もう入りません、入りませんよぉ……！　んあああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「溢れ、ちゃう……！　んーっ……！　いやです、ずうっと私の中に……オマ\nンコの中にいてほしいのに……っ……！　んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「っふぅうう……♪　あ、あなたは……私が思っていたよりも、ずっとすごい\n人なのかも、しれませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「戦いも、セックスも……。すればするほど、恐ろしい威力を身につけて、他\nではありえない上達を見せる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そんなあなただから、私、は……。惹かれてしまうのかも……。エッチがう\nまいから？　ふふ、そ、それもありますけど……♪　もちろん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁんんっ！？　いやっ……オチンポ抜けて……！　あっ……だめっ、だめ\n……今肌の上に出され、たら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁああっ♪　ああああっ♪　あああっ……♪　敏感になった身体に……皮\n膚に精液、熱いザーメンを垂れ流す、なんて……っ。ひどいです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　……今……今ザーメンを浴びせられたら……私、肌から妊\n娠しちゃいそう……っ……あぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「やっぱり今日の精液……すごくすごく濃いですっ……。ずっしり身体を覆っ\nて……！　あ……あ、洗ってもとれそうにないくらい粘ってて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「鼻がもげそうな強烈な臭い……。こんなの、子種の数を想像したら……それ\nだけでゾクッとするザーメンじゃないですかぁあ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、あ……っ。まわりの空気も精子の臭い、してる……。二度目の射精なの\nに、バケモノじみた発射力で、お、驚き……ました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「『変身ヒロインの拘束姿を見ていたらたくさん出てしまった』？　……そん\nなことにシルバスターを使わないでくださいよぉ……！　でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「私も、それで気持ちよかったから……おあいこですね。悪いのは全部……誘\n惑した私……はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001303_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「また、つきみに言えない秘密……できちゃいました。ヌルヌルで、ベトベト\nで……情けない姿……♪　んんん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃになった自分の姿を想像して、感じてしまうんですから……。\n私もどうかしちゃってますよね……ふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
