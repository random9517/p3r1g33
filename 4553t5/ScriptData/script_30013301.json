		{"command":[ "SETIMAGE", "0", "still_00000133_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっふ、はふんっ……くぽっ、んちゅぷっ……あぁ、太すぎて……口の中も \n犯されているみたいな……じゅぷっ、んくぷぅっ……！」", "NORMAL" ]},
