		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁんっ！　んぁぷっ……あっ、んぷっ……あぁ……また熱いの……顔にっ \n、あふっ……出てっ……んんんんっ！」", "NORMAL" ]},
