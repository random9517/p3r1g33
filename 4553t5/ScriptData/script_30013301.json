		{"command":[ "SETTEXT", "「はふ……うむ、これでいいだろう。けふっ……はぁ……直接飲んでもよかっ \nたが……今日はマーキングされたかったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_12" ]},
