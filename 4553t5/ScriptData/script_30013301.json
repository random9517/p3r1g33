		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「む……来たか。用事……ま、まぁ、そうだな。他でもない貴様に用があるの \nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、このヴァルキリー状態にも、大分慣れてきた。普段以上に力がみなぎ \nってくるが……実はちょっとそれだけではなくてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303102" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「その、他のモノもこみ上げてくるというか……だから、つまり……どういう \nことかというと……ええいっ、まどろっこしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000133_01", "10", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「つ、つまりっ……こういうことだ……ほらっ、前……出せっ、そうだっ…… \nチ、チンポだっ……早く出せっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あぁ……むわっとするこのにおいだ……はぁ、はぁ……んっ \n、すぅぅ……これを吸い込むと堪らなくなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何だ……あっという間に勃起させて……ということは、貴様も少し期待して \nいたんじゃないのか？　んっ、くぅ……はぁ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、たまには私のわがままにも付き合ってもらわないとな……いいか \n、大人しくしていろ。私が……その、し、してやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何をって……み、見れば分かるだろうっ。この状態で事情の分からぬ貴様で \nはあるまい。く、口にして言えだと……？　貴様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、待て分かった、腰を引くなっ。だから……その、フェ、フェラチオだっ \n。フェラチオをしてやるから、大人しくしていろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだ……チ、チンポを舐めたいんだ……だから、フェラチオをさせて \nくれ……い、いいなっ？　はぁっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、あむっ、りゅぷっ、じゅるっ、んちゅぷっ、はぁっ、れろ、ぺ \nろっ、れろっ、んちゅうぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「が、がっついてなど……これは、ちゅぷっ、んんっ……はんむ、いつものペ \nースだ……普通な、だけだ……りゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、それに……んんっ、んちゅぱっ……このチンポは……それがいいと言 \nっているではないか……ちゅぷっ、んちゅるっ、れりゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「この震え方……れる……よく分かるぞ、はぁんむ……あぁ……んっ、興奮し \nているんだろう……じゅるっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ダメだ……私も……あぁ……疼いてしまう……んっ、ふっ… \n…はぁ……んっ、あっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、あ、あまりジロジロ見るんじゃない……んっっ、ふっ……指 \nぃ……オマンコに伸びてしまう……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、濡れている……はぁぁ……こんなに、中が……糸を引いて… \n…あぁ……いやらしいことになってしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「違う、これはいつもの私ではない……だが、ぴちゃ、ちゅぷっ、チンポを舐 \nめる舌が……止まらない……れる……れろ、えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……指も、もっと深く……奥に……はっ、んんっ、挿し込んでしまう… \n…あぁ……気持ちいいのが広がっていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見ているだけ……んっ、くぅぅ……そうか……んっ、ちゅぱっ……今日は… \n…そういうつもりなんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「別に、構わない……とにかく、今の私は……チンポをしゃぶりたい……それ \nだけだからな……ちゅぷっ、りゅぷ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、今日は……ずっとこのチンポのことばかり考えていた…… \n自分でも不思議なくらい……頭がいっぱいになっていたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうして、ちゅぷっ、味わうと……改めて……感じる……んりゅぷっ……こ \nのチンポに……私は狂わされたんだと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぽっ、鼻を突く……このにおい……舐めれば舐めるほどに……強くなっ \nて……濃くなっていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……ちゃんと洗っているか……？　この辺……少し汚れているな……り \nゅぷっ、れろ、きれいにしてやるからな……ちゅる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ……ピクピクさせて……分かりやすい奴め……あぁ……んっ、お互い \n様……？　私も……腰をもじもじさせている……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうなのか……んっ、自分では……その自覚はなかったが……あっ、ふ \nっ……んんっ、いつの間に……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、し、しているかも知れない……指が奥に……あっ、届くと… \n…ビクッとなるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んっふ……仕方ないだろう……んっ、りゅぷっ、自分でどうにか \nできない位に……いやらしい気持ちになっているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ヴァルキリーたちは……こんな……平気なのか？　りゅぱっ、んちゅぷっ、 \n私には……このムラムラは……抑えきれないぞ……んちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁ……割れ目の入り口がピリピリする……くふぅ……あぁ…… \nんっ、かき混ぜるほど……痺れが強くなって……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お、音……あぁ……響いてしまう……オマンコから……はしたない音がして \nしまうのがバレてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、こうなったら……同じ立場にさせてやるしかない……んん \nっ、もっと深く咥えこんでぇ……しゃぶるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、じゅるっ……もっと、れろ……ぴちゃ……んちゅぷっ……んふ \nぁぷっ、あぁ……チンポの味ぃ……先端も震えて……近いな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま、出して……私の顔に掛けてくれ……はぷっ、ちゅぶっ、んちゅる \nっ……じゅるるっ、んんっ、んっちゅぅぅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁっ……あぷっ、あぁ……んっ、顔に……あぷっ、熱いの…… \n掛かって来てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁふっ、そうだ……これを浴びたかったんだ……このドロドロの濃厚精液 \nぃ……もっと出してくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ、ちゅぷん……れろ……ちゅるっ……んっ、んちゅぅ……んくっ、あ \nぁ……すごい勢いで……もっと汚してくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷっ、んはふっ、はぁ……あっ、んっ、りゅぷ……んふぁぁぁ \nっ、はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……これが、ずっと欲しかったものだ……感謝するぞ……ぴちゃ、んち \nゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……んむっ……まだ、チンポ……大きいままでいるよな？　だっ \nたら……もう少し続けさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「身体が……まだ火照ったままなんだ……んっ、オマンコも……イッてない… \n…はぁ、んっ、指……止まらないからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぷっ、ちゅぷっ、んりゅぷっ……んじゅるるっ、んふぅ……あぁ……ザー \nメンを吸い出しながら……りゅぷっ、また……しゃぶり直すぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「えろ……れろぉっ……この生臭さ……クセになるぅ……ぺろ……んっ、こん \nなモノを美味いと思うなんておかしいのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……だが、もう……知ってしまえば……このチンポの味しかない…… \nんちゅぷっ、しゃぶるほどに味が出る……このイカ臭い味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、えろ……んっ、れる……れりゅぅぅ……んふ……震えているぞ……？ \n　イッたばかりのチンポの先はかなり敏感なんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「舌でつついて……んんっ、ぴちゃっ……唇で吸って……くぽっ、深く……咥 \nえるぅ……んむっ、くぽっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんむ……あぁ……またオマンコもムズムズしている……んんっ、あっ… \n…指がめり込んで……はふっ、気持ちよくなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……この太いのが……私の奥に入ってきたら……んっ、すごいなんて… \n…ものじゃないんだろうな……りゅぷっ……じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の指なんかじゃ……比べ物にならない、この太さが……いっぱいに押し広 \nげて……あっ、ふっ、んじゅぷっ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んむっ、あぁ……奥から……私のいやらしい汁が……またいっぱい \n溢れ出してくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……貴様のチンポが……オマンコの中で暴れたら……考えれば考えるほ \nど……汁が止まらなくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんむ……ちゅぷっ、これら……このチンポがぁ……んっ、りゅぷっ…… \n私が舐めて……テラテラ光ってるこれぇ……じゅぷぅ……」", "NORMAL" ]},
