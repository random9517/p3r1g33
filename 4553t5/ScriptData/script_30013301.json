		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……イッ……んっ、オマンコもイってる……くぅぅ……んっ……射 \n精しているところを見ながら……一緒にイってるぅ……」", "NORMAL" ]},
