		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぷっ、りゅぷんっ、はんむ……あぁ……んぅむ……貴様のチンポはろうら \n……？　後……もう少し……なんらな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んちゅぷっ……なら……はぁん、また掛けて欲しい……私を…… \nもっと精液まみれにさせてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「分からない……でも、今日はそんな気分なんら……じゅるっ、くぽっ、んち \nゅっ……だからっ……早く……んりゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、ビクビクしてるっ……んちゅぅぅっ……後は、このチンポの先を…… \n強く吸い上げてぇ……ちゅぷっ、んちゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふぉら……らせっ……じゅぷっ、私も……イクからっ、はぷぅっ……ザーメ \nンっ、いっぱいっ、らせぇっ……！」", "NORMAL" ]},
