		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ、んちゅぱっ……はぁ……んぁっ、あぁ……りゅぷっ……ダメだ、気 \n持ちいい……オマンコ……今度こそイキそうになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3303215" ]},
