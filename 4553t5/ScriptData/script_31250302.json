		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あら、あなた。急に来てどうしましたの？　もしかして、我慢の限界が来ま\nしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、まだまだ我慢してもらうつもりでしたけど……そんな血走った顔で見\nられては、しょうがないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「また躾けてさしあげますわ。さ、そこにお座りになって……どうしたのかし\nら？　わたくしの言うことが聞けないんですの……きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あ、あなたっ、なにを……んんんっ！！　やあっ、服、脱がさないで……あ\nっ、こんな、強引に……！！　こら、待て、待てですわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんんっ、待てって言っていますのに、ああっ、んっ、後ろからペニスを擦\nりつけないで……ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304105" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、もう我慢ができないって……だからって、こんな、ふあっ、\nあああっ、あんっ、先っぽ、胸の先っぽダメっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そこ、埋まってるところ……敏感ですから……ひあああっ、ダメ、ダメって\n言ってますのに……んんっ、待って、待って、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「もっとよくしてあげるって、ああっ、あっ、んんんんっ、ペニスが、中に…\n…ふあああああっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふううっ、胸と中、両方責められたら、あんっ、ああっ、あっ、あくうっ！\n！　んんんっ、同時にって、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んううううっ、奥、と、先端っ、ひうっ、んっ、ダメ、ダメですっ、両方ダ\nメっ、あくううっ、んっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくし、わたくしが躾ける側なのにっ、んうっ、こんな風にされたら、立\n場が……ひああっ、だから、胸の先端、敏感って言ってますのに……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ああっ、指でくりくりするのダメっ！！　んっ、んんっ、あっ、ふうううっ\n！！　んんっ、中が締まるからって、そんな、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ダメっ、ダメですっ！！　んんっ、待て、待てですって、ひあああっ、待て\nってさっきも言ったのに、ひううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「こんな、後ろからっ、んんんっ、まるでわたくしが躾けられているみたいで\n……ふうっ、んんっ、あっ、奥トントンするのもダメっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あうううっ、両方、両方もダメっ！！　んっんっんっ、こんな風にされたら\n、あんっ、気持ちよくて、んんっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、ペニスが中をぐりぐりって、ごりごりって、それだけを考え\nちゃいます……あんっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あうっ、んんっ、じゃあ先端がいいって……ふあっ、んっ、ああっ、あんっ\n、先っぽ、胸の先がじんじんして……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、胸が切なくて……ふあああっ、あなたの指が、んっ、動くた\nびにきゅんってなっちゃいます……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、今度はそんな優しく責められたら……あんっ、ふうっ、んん\nっ、あなたのペニスの形が中で分かって……ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「大きさとか、形とか……わたくしの中でどう動いているのかも、感じ取れま\nすわ……んっ、ぴくぴくして……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっ、そんな、優しく奥を潰されたら……んんんっ、お腹も切なくなってし\nまいます……胸も、中も……ふうっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あううっ、ゆっくり、ゆっくり気持ちよくなって……んっ、あっ、あんっ…\n…あなたの腰と指で……んっ、わたくしが蕩けてきてます……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、んっ、わたくしじゃなくて、あなたがわたくしを躾けてきて\nいるの、分かってしまう……んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「逆だから、逆だからダメなのに……わたくしがあなたを躾けなきゃダメなの\nに……んんっ、ああっ、それ、そのぐりぐりするの、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ……え？　そういうのはいいから、一緒に気持ちよくなろうっ\nて……んうっ、あっ、そんな、そんなこと言われたら……んうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あなたが……あなたが推しメンになっちゃう！！　わたくし、推しメンに後\nろから抱かれてるっ！！　ふあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ね、ね、もっと、もっとしてください……推しメンの指とペニスで、わたく\nしをもっと責めて……あんっ、ああっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、凄いっ！！　わたくし、推しメンと繋がってる……身も心も\n繋がってるっ！！　んんっ、あくうっ！！　あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「推しメンのペニスで中ぐりぐりってされて、頭蕩けてっ、ふああああっ、あ\nっ、イく、イく、イっちゃいます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んううううっ、あなたのペニスも膨らんで、イくんですね、わたくしの中で\n、イくんですね、いいですわっ、いっぱい、いっぱい出してくださいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「このぐじゅぐじゅに蕩けた中に、あなたの精液いっぱい出してっ！！　んっ\n、ふうっ、あっ、奥、奥うっ！！　ぐりぐりって、されたらあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああああっ、あっ、イっく、イっく、イっくうううううううううう\nうううううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あくううううっ！！　中に、わたくしの中に推しメンの精液が、んんんっ！\n！　入ってきたあっ！！　んんっ、ふうっ、ううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ、凄い……熱い……あなたの気持ちよさが熱になって……んんっ、わ\nたくしの中にどくどくって……いっぱい注がれているのがわかりますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、この多幸感……推しと繋がるっていうのはこういうことですの\nね……あんっ、あっ、まだ出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304135" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの中で、あなたの快感が溶けているのが分かりますわ……ふふっ、\nよかったんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくし？　もちろん、気持ちよかったですわ。推しメンのあなたに抱かれ\nて、よくなかったわけがありませんもの……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、腰がこんなにガクガクして……でも、あなたに抱かれてるだけで幸せ\nですわ……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ！！　今の言葉でまた精液が……もう、そんなに出したら私のお腹が\nぱんっぱんになってしまいますわ……嬉しいですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「満たされる、というのはこういうことを言うんですのね……今の私は、あな\nたに抱かれて満たされておりますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、だからこそ、もう１回。もう１回わたくしを満たしてください。もっ\nと、もっとあなたを感じたいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あなたの指で……あなたのペニスで……わたくしをもっともっと気持ちよく\nして……わたくしも、あなたを気持ちよくしますから、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ！！　あっ、もうペニスが硬くなって、んっ、あうっ、ふあっ！！　\nんんっ！！　凄い……あんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしも、こうやって力を入れれば……あくっ、んっ、ほら、ペニスが締\nめつけられるのが分かるでしょう？　やんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ああんっ！！　指先でそんなにいじられると……んっ、お腹にも力が入って\n……んんっ、ペニスの形が分かるぐらいに……ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「この状態で動かれたら、はっ、あっ、んっ、さっきよりも中がどろどろにな\nって……ふうっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「硬くなった先端が奥を叩いているの、分かっちゃいます……んっ、あっ、わ\nたくしの中を、ごりごりって擦って……あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、もうダメ、ダメっ！！　わたくし、推しメンのペニスで躾けら\nれて……もうダメぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304208" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「気持ちいい、気持ちいいのっ！！　好きっ！！　好きです、あなた……んっ\n、あなたは推しメンで、大好きな人……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「だからもっともっと、わたくしの中で気持ちよくなって！！　気持ちよくし\nてっ！！　あくううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、締めつけながら、動かれるの好きっ！！　胸を弄られながら、\n突かれるのも好きっ！！　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あっ！！　あなたも、わたくしの中が好きって……ふあああ\nっ！！　推しメンにそんなこと言われたら、言われたら……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「もっともっと締めつけちゃいます……んんっ、はっ、あっ、ぬるぬるのペニ\nスが出入りしてるのが分かります、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふうううっ、あっ、んんっ、また、またきたっ！！　気持ちいいの、またき\nたあっ！！　お腹の奥から、ぎゅんぎゅんって……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの身体の中に、気持ちいいのが走ってきたあっ！！　あなたのペニ\nスで、指で、わたくしの身体が、んんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ、わたくしだけでなく、あなたも、あなたもまた一緒に、イきましょ\nう、んんっ、推しメンと、あなたと一緒にイきたいんですっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、そんな、激しくっ！！　ふあああっ！！　嬉しいっ、同じこ\nとを思っていたんですね！！　んんっ、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「好き、好き、あなたのペニスも、指も、あなたの全部、好きっ！！　だから\nあなたもわたくしを好きにしてっ！！　ひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んうううっ、うっ、あっ、わたくし、もう、ダメ、イく、イっちゃう、推し\nメンのペニスでイイっちゃう！！　んんんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「イく、イくう、あなたと繋がって、またイっくううううううううううううう\nうう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！！　またきたっ！！　推しの精子追加サービスきたっ！！　\nあふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの中、一番奥に推しの精子が注がれてるっ！！　最高のファンサー\nビス！！　ふあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「溶けるっ！！　身体も頭も溶けちゃうっ！！　サービスのオーバーフローで\nすわあああっ！！　あんっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふうっ、んんんっ、あんっ、んっ、まだ、出てる……最後の一滴まで、わた\nくしの中にサービスしてくれてる……尊い……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、くうっ……推しの精液、全部注がれて……幸せ。わたくしの中も、嬉\nしそうにきゅっきゅって動いてますわ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、こんなに注がれたなら、わたくし、きっとあなたとの子ができてしま\nいますわね……推しとの子……素敵な響き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしとあなたの子なら、きっと素敵な子になるでしょうね……今からた\nのしみですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「でも、もしこれでできてなくても、またしてくれますわよね？　ふふ、もう\nわたくしはあなたのものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「いつだって、どこだって抱いてくれていいんですよ？　オラオラ系の推しも\nまた素敵……もちろん、どんなあなただって素敵ですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「子供が生まれるまでたくさんたくさん愛しあいましょうね……あなたとの子\n供、楽しみですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304310" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、なんで抜いて……ふあああっ、精液、わたくしの身体に……\nんっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「推しからの精液シャワー……最高のファンサービスですわ。んっ、ふうっ、\n熱い……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304402" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「この熱さも、匂いも全部わたくしのためのものと思うと……んっ、出されて\nないのに、中がさっきの精液を飲みこんで……んふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふうううっ、こんなにいっぱいかけられたら、もうこの身体洗えない……推\nしからのプレゼントを洗い流すなんてできない……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304404" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「え？　そんなに喜ぶならまたしてあげるから、身体はちゃんと洗えって？　\nそ、そうですわね。でも、推しの匂いをまとって歩くのも……きゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ぶっかけられたわたくしの姿を知っているのはあなただけでいいって……推\nしにそんなこと言われたら……ちゃんと洗いますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふっ、でも、そう言うからには、またしてくださいませね？　あなたから\nの精液シャワー、凄く気持ちよかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「中に出されるのもいいけれど、推しメンからのマーキングも素晴らしいです\nわね……中も外もあなたの色に染め上げられて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304408" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「全部があなたのものになった気分ですわ。ふふ、気分じゃなくて実際にそう\nなんですけれどね。形として見えるのも、素敵ですわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0304409" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「だから、またいっぱいいっぱいかけてくださいね。こんどは頭のてっぺんか\nらつま先まで全部、あなたの精液で染め上げてください……ふふふっ」", "NORMAL" ]},
