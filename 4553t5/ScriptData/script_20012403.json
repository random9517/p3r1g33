{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「さてと……この辺なら、多少のドンパチがあったとしても何とかなりそうだ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここは……どういう場所なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「今は使ってない採石場跡だよ。近くに人が寄り付くことはまずないし、適度\nな斜面があったり、爆破しやすかったりとメリットだらけなのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人が寄り付かないのは分かったが、斜面とか爆破のメリットがイマイチよく\n分からんのだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「全く、男のクセにロマンを解さない奴だねぇ。他のみんなは結構ウキウキし\nてるってのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おぉ……これは、中々見事な場所であるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「何だか……とっても落ち着く感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021840001" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「何か分かるっす！　ちょっとタマシイ揺さぶられるような、そんなテンショ\nンになりそうっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021840001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えぇ……マジなのか。よく分かんねぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「どうやらキミは大きいお友達とは、ちょっと違う人種のようだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「まぁ、それはそれとして。どうやら、アヌビスの予想は当たってたみたいだ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ってことは、進路が変わってるってことか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そう、思いっきり方向を変えて、ハルカの方に向かって来ているよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふむ……やはり我が目的であったか。一体、どういう用向きなのやら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840002" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかし、ただこいつに会いに来るってだけなら、別に学園で待ってても良か\nったんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そうもいかないね。火器反応のようなものを感じたみたいだし、だからこそ\n長官もボク達に指示を出したのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840007" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぇぇ……ロボット同士の戦いに巻き込まれるなんてまっぴらなんだが……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ……もしかして、アレですかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021840002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「本当……ピラミッドが空を飛んでる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021840002" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「改めて見るとすげぇ絵面だな……あ、着陸してくるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……モード、地上活動形態ニ移行。王ノ反応ヲ検知……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840001" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「やっぱり、ハルカプトラを探していたみたいだね。凄いな、細かい移動もお\n手のものなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840008" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……オ待タセ致シマシタ、王……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840002" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うむ、苦しゅうないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840003" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、普通に話に乗っていいのかよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「む、つい普段のクセが出たのである。えーと、どうすればいいのである？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840004" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「とりあえず、目的を聞いておきたいところだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840009" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そうであった。それで、そなた達は一体何者で、何が目的だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840005" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私ノ事ヲオ忘レニナリマシタカ？　ソレデハ改メテ……ゴ説明致シマショウ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840003" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「私ハ、ピラミドン……マシン・ファラオノ側ニアリ、機械生命体ニヨル王国\nノ繁栄ヲ助ケル者……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840004" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「長ラク起動サレテオリマセンデシタガ、先日再起動ヲ開始……速ヤカ二、侵\n入シテイタ異分子ヲ排除……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「異分子……どうも、そいつが胡散臭いね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840010" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「王ノ反応ヲ検知スルノニ、想定時刻ヲ超過シマシタガ、無事ニ捕捉、御前ニ\n馳セ参ジ参ル事ガ出来マシタ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840006" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なるほど。それは遠路はるばるご苦労だったのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840006" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「アリガトウゴザイマス。改メテ、私ハ王ノオ側ニテ、我ラガ王国ノ繁栄ノ為\nニ働キマス。ドウゾ、ゴ命令ヲ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840007" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あ、あー、命令。うむ……と言われても、特にはないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840007" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ナイ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840008" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「承服シカネマス。我々ハ活動ガ可能デアリ、王ニモ王トシテノ使命ガアル筈\nデス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「む……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840011" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ソモソモ、王国ガ滅ンダトイウノナラバ、何故王ハココニイルノデスカ。国\nヲ失イナガラ、生キ永ラエテイルト？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840012" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「王ノ責務ヲ果タサズ、ソノ身ヲ遊バセテオクナド、到底民ガ許スモノデハア\nリマセン。王ニハ責任ガ問ワレマス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840013" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、待て待て待て。そんなに話を急かすな。一回、こっちの事情ってのも\n聞いておけよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……？　王トノ話ニ割リコムコノ不敬ナ者ハ何デスカ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840014" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あ、あー、それは我の同僚であり、その仲間というか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021840012" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいよ、口下手なお前は下がってろ。とにかく、今はお前らがいた時からず\nっと未来の時代だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「未来……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840015" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「王国は随分と昔に滅んだ。その責任があったとしても、それは過去の奴らの\nもので、今ここにいるハルカプトラのせいじゃねぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まずは、しっかり情報をアップデートしやがれ。今、ここがどういう時代で\n、どういう情勢でいるかをな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「アップデート……デスカ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ。世界は目まぐるしく動いている。お前は目覚めたばかりで、その情\n報を把握しきれていないだろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……ソレハ……確カニ、ソノ通リデス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだろう。大体、今どきピラミッド型のロボなんて中々流行るもんじゃな\nし、まずは自分自身を見直すところから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ピラミッドガダメ！？　何故ダメナノデスカ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840019" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ？　い、いや、別に駄目ってことは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「コノ形状ハ、アラユル事態ヲ想定シタ末ニ辿リ着イタ、完成系デス！　ソレ\nヲ否定スルコトハ、強イ疑念ヲ抱キマス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840020" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、今のはちょっとした言葉のアヤで……う、うわわわぁぁっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「アームが伸びた！？　収納してたのかっ、素晴らしい機構だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021840011" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「感心してる場合っすか！　隊長、捕まっちゃいましたよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021840003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「説明ヲ要求シマス、私ノ形状ニオケル、不都合ナ点ヲ徹底的ニ追求シマス！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021840021" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だ、だからそれはっ……って空飛ぶなっ！　うぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ……飛んでいっちゃう……助けなきゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021840003" ]},
