{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん。他愛もない連中だったな。まあ覚醒した私の敵ではなかったというこ\nとだ。はっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……それにしても、妙に身体が熱いな。興奮が収まらないというか……。う\nぅ……。そ、そうだ！　貴様、今すぐ脱げ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいだろう？　この私が、貴様を労ってやろうというのだ。今回は貴様もよ\nく働いたしな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「べ、別に私がいやらしい気分になっているからではないぞ！　そんなことよ\nりどうなんだ？　労われたいか？　労われたいだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふんっ。最初から素直に労われたいと言えばよかったのだ。さあ、オチン\nポを出せ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503105" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……凄い臭いだな。オチンポの臭いがここまで漂ってくる……。はぁ、はぁ\n……こいつを、胸で挟んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000105_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ど、どうだ？　貴様のオチンポなら、もう何度も挟んでいるからな……。ん\nっ、手慣れたものだろう？　んっ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうやって、しっかりとオチンポを押さえつけながら、胸を動かしてやるの\nが……ンッ、いいんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁ、はぁ、だんだんとオチンポが大きくなってきたぞ……。んっ、んふ\nぅ、もっと激しく、か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな。ンッ、こんなところ、他の誰かに見られるわけにもいかないか…\n…んっ、だが……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せっかくこうやって、貴様のオチンポにパイズリしているんだから。もう少\nしじっくりと味わってもいいんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こうやっているうちに……ンッ、貴様も随分と興奮しているじゃないか。オ\nチンポがビクビクと、あんっ、谷間で暴れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポ……んふっ、もっと気持ちよくしてやるからな……。んっ、ちゅ、\nちゅぱ……先っぽ……舐めてやるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ちゅるっ、ン……ッ、ちゅ、んちゅぶぅっ。ここ、弱かったよ\nな？　んちゅぷっ、たっぷり刺激してやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁ。蒸れた臭い……汗のしょっぱい味……んっ、ちゅぅ、なんていやら\nしいオチンポなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「パイズリされて、こうやって舐められて……ンッ、どんどん硬く……んちゅ\nっ、熱くなってる……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いつも貴様は……私にもっと激しく胸を動かさせるよな？　こんなふうに…\n…んっ、もっと胸を、動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポを、しっかりと挟んで……ンッ、ゴシゴシって、擦りまくって……\nんっ、ああっ！　ンッ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、すごいな……。こんなにパンパンに張りつめたオチンポ……ん\nっ、貴様の興奮が、伝わってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のよだれと、ンッ、これは先走り汁だな？　ヌルヌルになって、肌にオチ\nンポが密着してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅぶっ、ちゅるるっ。私のパイズリだぞ？　遠慮なく気持ちよく\nなっていいんだからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポをしごきながら、火照って柔らかくなった胸に包まれて、ンッ、い\nっぱい気持ちよくなってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んっ、れろれろ、んれろぉっ！　亀頭がますます膨れて……んち\nゅるっ、鈴口も、パクパクしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私の舌で……んっ、ちゅぱっ、たくさん気持ちよくなっているんだな……ん\nっ、んちゅるるっ、んふぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そういう反応をされると、ちゅぱっ、もっと、舐めてやりたくなるな……ん\nれろっ、ちゅっ、れろれろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、どうした？　腰をビクつかせるほど気持ちよかったのか？　んちゅっ\n、ちゅぱっ、そんなに暴れるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅるるっ、んふっ、れろぉんっ。これまで、何度も貴様への奉仕をさせら\nれてきたからな……んっ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様のオチンポの感じるところくらい、ちゅるっ、把握できているんだから\n……ちゅっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと、んちゅっ、気持ちよくして……んちゅぱっ、貴様のことを、射精さ\nせてやる……から……んちゅるっ、ちゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「裏筋や、先端を……んれろっ、れろれろっ、いっぱい舐めて……んふっ、ち\nゅぱっ、ほらもう……限界だろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいぞ、このまま。んちゅっ、私の命令だぞ。我慢なんかしてないで、この\nまま精液……だして、しまえ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ！　んはっ、んっ、んちゅるるっ、んっ、んんぅううっ！　ちゅぱっ\n、あっ、ああぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こんなにいっぱい、んちゅっ、精液を……。ははっ、オチンポが脈打って、\nびゅくびゅく、私の口に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、んくっ、んじゅるるっ！　すごい濃さだ……はぁ、は\nぁ、しかも……たまらない粘り気で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく、喉が詰まるほどの精液をこんなにたくさんだすなんて……。まあ\n、遠慮するなと言ったのは、私だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、もちろん全部飲むぞ……んっ、んちゅるるっ！　貴様が、私の為に射\n精してくれた精液だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、んっ、んふぅ……じゅぶっ、んっ、ずずずぅっ。オチンポの\n中に、残っているのも、啜るからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。この味と臭い……。ううぅ……なんだか身体がますます\n火照ってきたではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いったいどうなっているのだ……。んふぅ……はぁ、はぁ……。もっと貴様\nのオチンポを……気持ちよくしたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様もまだ、こんなにオチンポを勃起させたままだし……。いいよな？　も\nう一回くらい、このまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うっ。たしかに、帰りが遅くなっては皆に心配をかけるかもしれないし、心\n配した誰かが迎えに来るやもしれないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「し、しかしこのまま、身体を火照らせたまま帰るわけにもいかん！　貴様だ\nって、こんな勃起させたままで帰れないだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほらこうやって、ぬるぬるになった胸をつかって、また、貴様のオチンポを\nしごいて、ンッ、滑ってやりにくいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じっとしていろよ？　んっ、ああっ、こうして、胸を……んぁっ、動かして\nしごいて……っと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぅ、んふぅ……はぁ、どうだ？　んっ、貴様の精液のおかげで、胸がオチ\nンポにより密着してるだろ？　んふぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポが胸を擦るたびに、んはっ、ぬちゅぬちゅって、いやらしい音が…\n…してる……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さっきのように、舌でも、刺激してやるからな？　んちゅっ、射精した後だ\nと、ンッ、先っぽも、より敏感になってるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅるっ、ちゅるっ、ちゅぷっ。んふ……ちゅ、ちゅ、ちゅるっ、んはっ\n、精液の味……んちゅるるっ、ちゅぶっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当にお前のオチンポは、いやらしい味をしているな……んちゅるるっ、ん\nっ、ますます興奮してくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「火照りをどうにかするために、んちゅっ、こうして奉仕しているのに……ち\nゅぱっ、これでは、逆効果ではないのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁ、でも、途中でやめるなんてしたくない……。せっかくこうして、貴様\nが私の胸と口で、気持ちよくなっているのだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅちゅっ、ンッ、だから、もっともっと……貴様の気持ちよくなってい\nる顔を見ていたいのだ……ちゅるっ、ンッ、れろれろぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス"  ]},
		{"command":[ "SETTEXT", "「あんっ！　お、おい。急にオチンポをビクつかせるな。びっくりするだろう\nが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ！？　わ、私の奉仕がエロすぎてもう我慢できなくなっただって？　ん\nっ、ああっ、そ、そうなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぅっ、そんなこと言われると、恥ずかしいのに……。し、しかし……どこ\nか嬉しくもあるような……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、わかったから！　そんなにエロくなったとか、恥ずかしいことを何度も\n言わなくてもいい！　一度言われれば十分だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「頭に来たぞ。もう、そんなこと言えないくらいに精液を搾り取ってやる！　\nさっきよりも激しく、胸を動かして、オチンポしごいて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、れろれろっ、舌で先っぽも刺激して、んちゅるるっ！　んふっ、さっ\nそく余裕がなくなって、貴様の口から喘ぎ声がでているぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このまま、んちゅぱっ、射精させるからな！　んっ、貴様から、いっぱい…\n…また、精液……出してもらうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「さあ、んっ、んちゅるっ、射精……ちゅぱっ、射精させてやる……。ちゅば\nっ、精液……だせ、だしてしまえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんんぅううっ！　んむっ、んっ、んぁあっ、んっ、んふぅうううぅぅう～\n～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあっ、また、またいっぱい、精液が……んっ、ちゅるっ、私の口にいっ\nぱい、んぅっ、注がれて……ンッ、んぁっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「も……もったいないからな……んちゅるるっ、ちゅぱっ、ちゃんと、射精さ\nれたものは……みんな、飲むから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅるっ、んっ、んっ、んくっ、んくっ、んふぅ……。二度目なのに、濃\nいの……んはぁ、いっぱい……んじゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅずっ、じゅずずずぅぅっ！　んぐっ、んぐっ、ネバネバを……残さず、\n飲み干して……しまうから……んぅっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、はぁ……んふぅ……。やっと射精も終わったか……。\nふふっ、しっかりと全部飲み干したぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……おい、なに驚いているんだ。そもそも、貴様がこうして精液を飲むよう\nに教えたんじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく、私がこんなにも破廉恥になってしまったのは、貴様にも責任があ\nるんだぞ？　わかっているのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふんっ。こうして、私が身体を許すのは貴様だけなんだ。その意味を、もう\n少し考えてもらいたいものだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……な、なんだ、なにを笑っている！　もういい！　身体の火照りも収まっ\nたようだし、帰るぞ！　……帰ってから、続きだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　んっ、んふぅううっ！　はぁっ、ああぁぁああぁぁ～～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今度は、ンッ、顔に向かって精液……んぁあっ、ああっ、たくさんかけられ\nて……んっ、んんぅっ！　はぁああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「濃いのが、ンッ、いっぱい……！　はぁ、はぁ、オチンポが暴れながら、精\n液噴きあげて、ンッ、ネバネバが顔に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、ドロドロになるっ！　顔面、いっぱい、貴様の臭いのする精液にマ\nーキングされる……！　んぁっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ぶっかけられながらイッてしまった……。ううぅ……こ\nんな姿を晒してしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だ、だが……見ていたのは貴様だけだよな？　貴様以外に、こんな姿を見せ\nられないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ……それにしてもなんて臭い……。さっきはこれを口の中に射精され\nていたんだよな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぅ……なんだか、やはり火照りが収まらない感じだ……。さすがにこのま\nま続けるわけにはいかないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いい加減に帰らないと、皆が心配してしまうからな。だから……続きは帰っ\nてからにしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、帰ったら最後まで付き合ってもらうからな。今夜は寝かせないから\n覚悟しろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}