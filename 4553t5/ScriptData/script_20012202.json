{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんっ、お出かけだねっ、お出かけっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、もうちょっとイルルの日用品も買い足しておかないとまずいからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、にちよーひんって何？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「普段使う服だったり、道具だったりだ。うちの基地じゃ、あんまり子供用の\nものは揃わないしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「そっかー、楽しみ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ははっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ちょうどいいタイミングですので、新製品のドッグフードもぜひ試してみた\nいところですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021770001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何のタイミングだよ。言っとくが、お前の分の予算は０計上だからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「何と！　ご主人とイルル殿を警護する任を帯びた私に、あまりに無体なお言\n葉！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021770002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「警護になりゃ考えなくもねぇけど……ヒマだから付いてきたってだけだろ、\n実際」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とんでもない。あわよくばおこぼれをなどと、露ほども思ってはいませんぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021770003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本音ダダ漏れじゃねぇか……もう少し隠せよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ワンちゃんも、お買い物するの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、こいつはついてきてるだけだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いっしょにお買い物しないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あぁ、お供で来てるだけだからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、欲しいものがあるって言ってたよ？　買わないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、それはだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルだけ？　かわいそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ、分かった分かった。とりあえず１つだけな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770008" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おぉ……ちゃんと私めのことも気にして頂いて……その気配り……ご主人と\nは大違いですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021770004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく、結構甘え上手なんだよな……世のお父さん共は、どうやってあの攻\n撃を凌いでるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「またまた、そんなことを言って、懐かれるのは悪い気はしないんでしょう？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021770005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「見透かすようなこと言ってんな。まぁ、基本いい子だからな……少し位は甘\nやかすのも悪くないさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770009" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルルはいい子だって話だよ。ほら、行くぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770010" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「……ナンなのアレ？　こっちがようやく見つけてアゲてんのに、ヘンなの見\nせつけられて、ちょー気分悪いんですケド？？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ふん……まぁ、いいや。なら、分からせにいってアゲましょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて……こんなものかな。ちょっと小腹も空いてきたし、イルル、何か食い\nたいものとかあるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「たべもの？　えっと、えっとね……それじゃあ、イルルね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770011" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「その前に、こいつを喰らいなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉわっ！？　あ、危ねぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「チッ……外したか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だお前っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ハン、随分と楽しそーにしてるじゃない？　ヤムを差し置いて、勝手に盛り\n上がってるナンて、いー度胸じゃないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………あ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770012" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「イルル！　アンタの母親はどうしたの？　アンタが起きたってことは、近く\nにいるってことじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770006" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もしかして……イルルの知り合いなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………イルル……分かんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770013" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はんっ、そっちは知らなくても、こっちは知ってんのよ！　特にそいつの母\n親の邪龍には色々インネンだらけね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「邪龍……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ナニよ、アンタなんにも知らないでそいつに構ってるの？　チョー間抜けね\n！　まぁ、顔からして分かってたけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「か、顔は関係ねーだろっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いーわ、間抜けなバカにも分かるように教えたげる！　こいつの母親は、世\n界に厄災をもたらす邪神の魔竜よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770009" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「トーゼン、その娘もナニをしでかすか分かんないから封印されてたってワケ\n！　何でか知らないけど、封印は解けちゃったみたいだけどね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムとしては、別にイルルのことはそれほどでもないけど？　のこのこ起き\nたなら、いちおーのオトシマエってのはつけてもらわないとなのよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770011" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オトシマエって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムも起きてすぐだから、ちょっとカラダもナマッてるし？　軽く相手して\nやるから、かかってこいっつってんの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770012" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「…………おとーさん……こわい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770014" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……っ、ナニそんなデクノボーみたいなのに隠れてんの！？　てか、アンタ\n邪魔よっ、どきなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770013" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770015" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「だから、いつまでそいつに構ってんのよ！　ちゃんとこっち見なさいよっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770014" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……ぅっ……あぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770016" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふん……てんでフヌケってワケ！　なら、少しは本気出せるようにしたげる\nわっ！　コイツを預かってくからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770015" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおわぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010021770017" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「悔しかったら取り返しに来なさいよね、ノーテンキ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770016" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、離しやがれって……おわぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「男のクセにキーキーうっさいわね。ま、これであのノーテンキも少しはやる\n気になるっしょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770017" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は……何だって、そんなにイルルに絡むんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「は？　さっきも言ったでしょ？　あいつの母親にはカリがあんのよ。そいつ\nを返すのに、あのガキも相手してやるって言ってんの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770018" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イルルは……別だろ。母親が邪竜だからって、今は害を及ぼしてる訳じゃな\nいんだし……手を出すのは違うんじゃねーのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ？　ナニめんどくさいこと言ってんの？　たかがダシのクセに、ヤムに\n意見なんて千年ハヤいのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010021770019" ]},
