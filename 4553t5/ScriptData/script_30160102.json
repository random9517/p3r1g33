{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様との取引に応じれば、夜叉には手を出さないでくれるんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……いいだろう。取引に応じてやる。それで、私はなにをすればいいんだ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なっ……！？　は、初体験の話をしろだと！？　そ、そんなこと言えるワケ\nが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　わかった……夜叉のためだ。包み隠さず話してやる……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ、あれは私が……初めて破瓜というモノを、味わったときのことだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああっ……オマンコにチンポが当たっているっ……！　熱くてカタい感触が\n、伝わってきて……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これが本当に、私のオマンコに入るんだな……ふふっ。大きすぎて、本当に\n入るか不安になってくるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「言われなくてもわかっている……ちゃんと入るように、オマンコを濡らして\nおく必要があるんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だからこうして、挿れる前にチンポを擦って……あっ、あっ……！　ふあっ\n、くうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「軽く触れるだけでも、感じてしまうな……動きすぎたら、イッてしまいそう\nだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ば、バカ者っ……！　挿れる前にイクなんて、そんなはしたないこと出来る\nワケないだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それに……い、イクときは、一緒にイキたいというか……なんというか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「と、とにかく！　全て私に任せて、チンポを勃起させておくことに、意識を\n集中させておけっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ、くうぅ……あっ、はあぁ……オマンコから、いっぱい蜜が……！　ん\nっ、うぐっ……そろそろ挿れるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　ぶっといチンポが、オマンコ入ってきて……！　あっ、\nんんっ、くはあああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ……あぐっ……！　全部、入ったみたいだな……！　なに、少しだけ痛\nむが、この程度どうってことない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それより、今はこうして一つになれたことの方が嬉しい……いっぱい動くか\nら、私のオマンコをたっぷり味わってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ズポズポしまくって、思いっきり膣内出しして……子宮の奥まで、精液で染\nめ上げてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ……！？　な、なんだ……！？　まだ動いてないのに、チンポがさらに\n膨らんで……ああっ！　オマンコが、押し広げられるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「早く動いて欲しいんだな……！　いいだろう。私のオマンコで、チンポをシ\nコシコしてやるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ！　あああぁ、はああぁん！　チンポが奥まで届いてるぅ！\n　あっ、あっ！　これ、すごいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私の指よりも長いチンポが、赤ちゃんの部屋をトントンして……はああっ！\n　こんなの、初めてだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くっ、ああっ！　ひぐっ、んぐううぅ……！　カリがオマンコに引っかかっ\nて……動くたびに、ズリズリって擦れているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ！　こんな快感、味わったことないっ！　オナニーでも、感じ\nたことないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あふっ、んふうううぅぅぅ！？　子宮口を小突かれるの、すごくいいっ！　\nもっと激しくしてもいいかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あああっ！　我慢汁がどぴゅどぴゅ出てるっ！　精液よりも先に、赤ちゃん\nの部屋に入ってきているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁ、あああっ！　んっ、ふあああぁ！　こんなに出されたら、我慢汁で妊\n娠してしまいそうだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「えっ……あっ！？　やっ、なんで……！　急に動くなっ……はあああぁあん\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「が、我慢汁じゃなくて、ちゃんと精液で妊娠させるだと……！？　ふふっ。\n自分のチンポから出た汁に嫉妬するなんて、みっともないぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だが……私も我慢汁じゃなくて、精液がいい……孕むなら、濃厚でドロドロ\nなザーメンで孕みたいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「だから、もっと激しく動くぞっ！　あっ、ああぁんっ！　あっ、んひっ、く\nううぅぅぅ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「好きなときに、好きなだけ出してくれっ！　私のぐちょぐちょオマンコに、\nいっぱい精液出して……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いっぱい締め付けて、気持ちよくするから……！　私を孕ませるぐらい、た\nくさん出してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あひっ、んひっ、んふうううぅ！？　チンポがオマンコで跳ねて、膨らんで\nるっ！　そろそろ、出るんだなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「いいぞっ！　ザーメンを注ぎ込んでくれっ！　私の子宮、精液でパンパンに\nしてえええぇ～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はああああぁぁぁっ！？　きたっ、精子きたぁっ！　びゅるびゅる出てるっ\n！　膣内出しされてるぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「子宮に流れ込んできてるの感じるっ！　温かいの伝わってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あああっ！　こんなのイクッ！　子宮を満たされながら、イ\nクううううぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「くうううぅ～～～っ！？　な、膣内出しされながらイクの、気持ちいいっ！\n　オマンコにマーキングされるの、大好きぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　またイクッ！　イッてしまうぅ！　あっ、あっ！　ああああ\nぁあぁ～～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はああぁ……すごくよかったぞ……私のオマンコも悦んでいる……ほら、チ\nンポに吸い付いているのを、感じるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……！　オマンコを締めれば締めるほど、チンポに残っている精\n液が出て来るな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ひょっとして、まだ出したいのか……？　もう私の子宮は、精液でパンパン\nだというのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ふふっ。いいだろう……もっとシたいなら、付き合ってやる。だが、後悔す\nるなよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「鬼の性欲……イヤというほど味わわせてやるからなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んはっ、あっ、はあああぁ……！　ど、どうだ、さっきとは違う動きだぞ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こうして、オマンコの奥にチンポの先端を当てながら……グリグリすると…\n…んんっ！　亀頭が刺激されて、気持ちいいだろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「次はこの動きで、精液を搾り取ってやる……！　私のオマンコじゃないと、\nイケない身体にしてやるからなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「えっ……な、なんでそんな動きを知ってるのかって……？　そ、それは、私\nなりに勉強をしたからで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うううぅ……！　は、初めてのセックスなんだぞ！？　気持ちよくなって欲\nしいから、予習ぐらいするだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「えっ、あああっ！？　ちょ、ちょっと待て……！　そんなに腰を動かされた\nら……はひいいぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「せっかく勉強したんだから、私が動かないと意味が……！　ああっ、ダメっ\n！　奥をグリグリされるの、感じすぎるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなの、私がこのチンポじゃないとダメになってしまうっ！　このぶっと\nいチンポじゃないと、イケなくなってしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あああ～～～～～っ！？　激しいっ！　激しいからぁ！　そんなに勢いよく\n、腰を振らないでくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ズポズポされると、頭が変になってくるっ！　気持ちいいことしか、考えら\nなくなるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぎっ、ぐっ、あああっ！　オマンコが悦んで、子宮が疼いてるっ！　こん\nな状態で膣内出しされたら、絶対に孕んでしまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んはああぁんっ！？　チンポがまた膨らんで、オマンコの奥で\nビクビク暴れているっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ま、また出すんだなっ！？　さっきみたいな濃厚なザーメン、いっぱい出す\n気なんだなっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あああっ！　出してっ！　好きなところに出してくれっ！　さっきよりも濃\nい精液、びゅるびゅる出してくれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぎっ、あっあっあっ！　イクッ！　私もイクからぁっ！　あああっ、んあ\nっ、ふああああぁぁぁぁぁ～～～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ぐうううぅっ！？　あっ、ひあっ、くあああぁ！？　まだ膣内出しされてる\nっ！　熱いザーメン、びゅーびゅー出されてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの部屋、もう精液でいっぱいなのにっ！　また次から次に、精液が\n流し込まれて……んんんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「おっ、お腹苦しいっ！　でも気持ちいい方が強くて、感じすぎてしまうっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「全部出してくれっ！　一滴残らず、オマンコにザーメン出し切ってくれぇ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！　んぐっ、あっ、くふうううぅ～～～！？　またイクッ！\n　オマンコの奥から来るっ！　すごいの来るぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああああぁ～～～っ！？　イクッ！　イクイクッ！　イグうううぅ～～～～\n～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ……ああぁ……本当に、こんなに出すなんて……腹が破裂するかと思っ\nたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「まったく……実に鬼泣かせなチンポだ……こんな凶悪なチンポは、私がしっ\nかりと管理してやらないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「オマンコだけじゃなく、口や手でしっかりと搾り取ってやるからな……覚悟\nしておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「えっ……口や手でする方法も、ちゃんと勉強したのかって……？　そ、それ\nはこれから勉強するんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あひいいぃんっ！？　ち、チンポがオマンコから抜けて……あああっ！　熱\nいの、身体にかかっているぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「全身にザーメンが降りかかって……あっ、ふあああぁ……！　す、すごいニ\nオイだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなに熱くてクサイ精液を浴びせられたら、ニオイが取れなくなるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それに、膣内だけじゃなくて、身体までザーメン塗れにされるなんて……こ\nんなの、幸せすぎてイッてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぐっ、ああああっ！　ふっ、あああぁ……！　ダメだっ、イクの我慢でき\nないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ！　ひっ、んはっ、あはあああぁぁぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はあああぁぁぁ……あっ、んんんっ……は、はしたない姿を晒してしまった\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00001601_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「たくさんセックスの勉強をしたというのに……やはり、百聞は一見に如かず\nだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「えっ……？　次はもっと過激なことをして欲しい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「さ、さすがにそれはまだハードルが高いというか……！　もう暫く、セック\nスの復習をさせてもらえると嬉しいのだが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}