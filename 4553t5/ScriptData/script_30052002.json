		{"command":[ "PLAYVOICE", "v2_005_2004306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「今日は一方的にしてきたんですから……それ位の甘えは許してくれる筈です\n。ダメですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2004307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んふ……ありがとうございます。もうちょっと余韻を味わいたかったので…\n…貴方の体温を直接感じられますから……」", "NORMAL" ]},
