		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「溢れてる……あぁ、ごめんなさい……全部、中に欲しいのに……漏れちゃう\nんです……はふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2004303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……射精しながら、まだオチンポがズリズリ擦れてぇ……んんっ！　続\nけてイきます……んくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2004304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あっ、ふっ……終わりました……？　いっぱい種付けされて\nしまいました……腰がガクガクしてます……」", "NORMAL" ]},
