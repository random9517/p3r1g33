		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「あぅっ、んぁっ、はぁぁぁんっ！　あぁっ、オチンポのラストスパートっ…\n…ズボズボされてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_2004218" ]},
