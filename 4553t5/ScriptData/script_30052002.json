		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、イク時に……ちゃんと言うっ……？　は、はい……言いますっ、言\nいますからっ、オチンポ止めないで……続けて下さいっ！」", "NORMAL" ]},
