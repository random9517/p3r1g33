		{"command":[ "PLAYVOICE", "v2_005_2004309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「でも、貴方だけのメイドになるのもいいかも知れませんね……もう、半分位\nはそうなってますし……ふふん、これからもよろしくお願いします」", "NORMAL" ]},
