{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「……確かにお前は色々と任務を果たして、疲れているというのは分かる。そ \nして、それを癒やしてくれという願われれば応えたいとも思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「だが、帰って早々に服を脱いで早々にズボンを下ろし、これ見よがしに私に \n突きつけて……幾らなんでも図々しいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「分かった、分かった……こんなことができるのは、伴侶である私くらいなも \nのだしな……パ、パイズリしてやる。それでいいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「くぅ……こんな時ばかり調子よく頷きおって……チンポも一緒に頷かなくて \nもいいだろうに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「とにかく、んっ、動かすぞ……大人しくしていろよ。んっ、ふっ、はぁっ、 \nんっく……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「今日も連続任務で疲れただろう……優しくチンポを撫でてやるからな……あ \nふっ、んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はふっ、んんっ……相変わらず、ふざけた大きさのチンポだ……隆々に反り \n返って……自己主張が激しすぎるだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「谷間の中で、ビクビクと動いている……んっ、くっ……ふっ、んむっ……は \nぁっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「どうだ、こうして包み込んでやると……んっ、気持ちいいんじゃないか…… \n？　力加減は……こんなペースで……どうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そうか、あまり力まずに……どっしり構えておけ。私の方でうまくやってや \nる。んっ、んむ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「かなり、汗をかいたみたいだな……中で最初から蒸れたようになっている… \n…私のおっぱいの中も熱いのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んふっ、蕩けそうな位熱いか……そいつをもっと感じてくれ……は、ふっ、 \nんっ、んんっ……気持ちいいか……よしよし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「当然だ……私が心を込めて扱いているんだからな……感謝してもらわなけれ \nば困る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「バ、バカ者……そんなに大げさに言わなくてもいい。大体の感じでいいんだ \n。普通に感謝しておけばそれでいい。ふ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁ……こ、こら……あんまり飛び出そうとするな……全く、油断も隙もな \nい……すぐはみ出そうとするんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「もっとしっかり捕まえておけ……？　うるさい、ちゃんとしているだろうっ \n……こうして、ぎゅっと……押し潰すっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そうだ、お前のチンポがじっとしていないのが悪い。大人しくして、私のお \nっぱいに扱かれていろ。わ、分かったな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……何とか押し込めているという感じだな……それでも亀頭は顔 \nを出して……全く、落ち着きのないことだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「なに……もう一刺激欲しい？　どうして欲しいんだ……？　なっ……何をっ \n、ほ、宝石のような唇って……な、何を言っているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「よ、要するに……口でもして欲しいということか……うむ……そ、それは、 \nまぁ……お前がそこまで求めるのなら……やるしかないだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぷ……ま、まずは、軽く先端を濡らしてからだ……いきなりし \nたらチンポもびっくりするだろうからな……ちゅ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁ、もうそんな待ちきれないというような顔をするなっ！　咥えるぞ…… \nいいなっ、はっ、んむっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「りゅぽっ、じゅっぷ……くちゅっ、ちゅぷっ、んぱっ、りゅぷぅ……んぷっ \n、じゅるっ、んちゅぷっ、んふぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「どうだ……こういう感じで、して欲しかったのか？　ちゅぷっ、チンポの先 \nが……ビクついているぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……れろ、んりゅ……最高か。ふふ、どこまでも調子のいい奴め \n……れろ、ほら、裏筋もお留守になっているぞ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、舌先をもっと見せて欲しい……？　ふん、時々見せてやる……せい \nぜい、目を凝らして観察しておくがいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んちゅぱ……それに、意識を置くのは舌先だけではないぞ……？　竿の根元 \nも……んんっ、ぎゅっと……締め付けていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁ……んっ、乳首も……あぁ……んっ、この……筋の継ぎ目に… \n…当てて……んんっ！　あぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ち、違うぞ……今のは少しびっくりしただけだ。別に、乳首が……気持ちよ \nかったとか、そういうことでは……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ええい、ニヤニヤするなっ！　とにかく、まだ続きだっ……せいぜい腰に力 \nを込めて我慢するんだなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「くぷっ、ちゅぽ、んちゅぷ、ちゅぱっ、あぁ……んむ……見ろ……もう射精 \n前の汁が……滲んで来たぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「れろ、くぷぅぅ……んちゅっ、はむっ……私の舌技に……腰砕けになってい \nるんだろう……んちゅぷっ、我慢しなくていいからな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そうだ……んっ、ふっ、全部……飲んでやる……最初から、そうさせるつも \nりだったんだろう……？　承知の上だ……じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「の、飲みたかったという程ではないが……まぁ、貰えるものならば……飲ん \nでやっても……んっ、お、おねだりだと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「う……ま、まぁ……仕方ないな……お前がどうしてもと言うなら……お、お \n願いだ……全部飲み干すから……射精……してくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そ、そうだ……私の飲みたがりの、口……マンコに……お前の濃厚なザーメ \nンを……たっぷり出してくれぇ……んちゅ、ちゅぷぅ……！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んんんんんっ……！　ふぶっ……んんっ！　あっ、ぷっ……い、いきなり… \n…んっ、出すやつが……んぐっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、濃い……今日も、なんて粘りだ……ちゅぷぅ……喉に絡みつ \nいて……なかなか落ちない……んぐっ、んふぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んふぁ……ぷぁっ……あ……ふっ、はぁ、はぁ……遠慮なく出してくれたな \n……ちゅぷ、もう少し宣言する位のことはしろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「まぁ、もう慣れて来たがな……ちゅるっ……んちゅぅ……ぴちゃ……たっぷ \nり出せたのならそれでいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷっ、さて……随分出してくれたが、まだまだ勃起は収まりが \nつかないようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁ、皆まで言わなくていい。続けて欲しいんだろう？　これも、私の役目 \nだからな……はぁんむ、ちゅぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んふっ……今度は、最初から……遠慮なしだ……りゅぷっ、じゅ \nぷんっ……出したての敏感チンポ……もっと刺激していくぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ……あぁ……濃い後味が、まだ口の中に残っているからな……ち \nゅるっ……お前の欲望をひしひしと感じる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「まぁ、それだけ……私の奉仕で興奮したのだと思うと悪い気はしないがな… \n…ちゅぽ、ぴちゃっ、んっちゅ……ちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んふぅ……舌触りもそうだが……舐めれば舐めるほど味が出てくる……じゅ \nるっ、クセになる味わいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「バ、バカ者……別に大好物というわけではないぞ……まあ、嫌いな味ではな \nい……それだけだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んっ、おっと……しゃぶるのに気を取られすぎてもよくないな… \n…パイズリの方も忘れずにしないと……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「少し精液が垂れて……それが、滑りを手伝ってくれているからな……より動 \nかしやすくなっている……はぁ、んんっ……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁん……中でチンポがビクビクと暴れているな……んっ、抑え込むのも一 \n苦労だが……このビクビクという脈動……悪くない感触だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁ、それくらいは認めてやろう……んっ、チンポを挟んでやるだけで…… \n私も気持ちよくなっている……はぁ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷっ、れろ、ぴちゃ、んちゅぷぅ……はぁ……んむ、あぁ…… \nもう、次の先走りが滲み始めているぞ……気が早いな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、まだまだここから我慢する？　ふん……さて、私の責めにどこま \nで耐えられるかな……んっ、はぁ、んふ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「もっと激しく、擦り上げて……どうだ……おっぱいが、もっともっとめり込 \nんでいくぞ……んっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「くぽっ……唇も……じゅぱっ……れろ、えろっ……亀頭を扱きまくって…… \nんふっ、くぷっ……余裕がないだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぷっ、下手な我慢などやめて、欲望に身を任せてしまえ……んっ、じゅぱ \nっ、あぁ……んふ、か、顔がエロい……ど、どういう意味だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「大胆におっぱいを揺らして……頬を窪めて、美味しそうにチンポをしゃぶる \n……あぐっ……お、お前がさせていることだろうがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「実際……そ、そういう気持ちになっているんだから、仕方ないだろうっ。下 \nらないことを言ってないで、ちゅぷっ……さっさと出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「大体……お前の顔も、よっぽど蕩け顔になっているからなっ、お互い様だっ \n……ちゅぱっ、ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「分かったらっ、早く……出せっ！　私の……く、口マンコにっ……思いっき \nり……射精しろっ、じゅるっ、ちゅぷっ、んちゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んぐぅっ……！　ふぐっ、んんっ……あぷっ……こくっ、んくっ、はぷっ… \n…あぁ……また……すごい量が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ん……ちゅる……れろ、ぴちゃ……んはぁ……大丈夫だ……時間を掛けてゆ \nっくり飲み切る……んく、こく……んくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「は……ふっ、んんっ……ま、まだ出るのか……どれだけ性欲が溜まっていた \nんだ……お前は……ちゅぷ、んちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「最高に気持ちいいから……また、このタイミングでおべっかを……んんっ、 \n私がすぐほだされると思って……仕方ないやつだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、じゅぷ……ちゅる……んちゅ……どうやら、んっ、 \n収まったようだな……れろ、りゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……これで満足したな？　もうこれ以上しろと言われても、しないか \nらな？　それで文句はないな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「後始末だけ……む……ま、まぁ、それはな……一応は私の責任の範疇か。な \nらば、それだけは任せておけ、れろ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んちゅ……あぁ、まだここに残ってる……こっちにも……れろ、ぴちゃ…… \n後は、ここか……ちゅぷ、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ふぅ……よし……これでいいだろう。満足したな？　全く……お前の相手を \nするのは大変だ。なにせ注文が多すぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「いいか、私は決して都合のいい女というわけではないからな。そこのところ \nは、よく弁えておけよ？　まぁ、満足したのなら……それで、いい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103310" ]},
		{"command":[ "WAITINPUT" ]},
