		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！　何で……急にチンポを抜いて……んくっ、あぷっ……んんんっ、 \nか、顔に……掛けるだとっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「だったら、最初からそう言えっ……な、何がサプライズだっ！　んぷっ、あ \nぁ……こんなにも濃いのが……出されて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、生温かいのがベトベトになる……んくっ……どれだけ出す \nつもりなんだ、お前は……んっ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「気持ちが良すぎるから……もう、何でもいい……いいから、さっさと全部出 \nしてしまえ……受け止めてやるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……チンポを直接押し付けられて……はぁ……んっ、顔中ザー \nメンまみれになってしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「これで終わり……本当だな？　まだ後から出ると言っても知らんぞ？　しっ \nかり満足したんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ならばいい。まぁ、一応……チンポの後始末だけは、面倒をみてやる……一 \n応、それは私の役目だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ、あぁ……頬についたのもすぐ舐め取らないと、固まって \nしまうじゃないか……んちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷ……ほら……これでいいだろう……大満足か……うむ、まぁ… \n…それならいい」", "NORMAL" ]},
