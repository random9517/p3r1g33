{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ん、ふふふふ……♪　どうです……？　私のオマンコ……もう入れてほしく\nてほしくて、ヌルヌルに潤っておりますよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……あら……。何を驚いてるんですか？　今日は私と……逢瀬をしてくださ\nると約束していたじゃあ、ありませんか。まあ、隊長さまときたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304102" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「若い女の子達にモテモテで……。ヤキモチを焼いた私に、こうして野外で押\nし倒されているわけですが……。どうせ、わかってらっしゃるんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私がずぅっと……一人で身体を疼かせて……。一刻も早く、隊長さまと一つ\nになりたい、身体を重ねたいと切羽詰まっていたことくらい……ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ねぇ……隊長さま？　待たせた分、うーんと楽しませてほしいんです。まず\nは私の胸の先……乳首を、その可愛いお口で転がしてもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304105" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁあんっ♪　そう……そうやって♪　舌先でレロレロレロレロ\n……あはっ♪　乳首、尖った乳首をねぶって舐めて、味わって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そう、そうですぅ……♪　むしゃぶりついていてくださいぃ……♪　あぁっ\n……視界を、私の胸で覆い尽くして……あっ♪　さしあげますからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っン……♪　んんっ、んん～……っ。くすぐったい、甘酸っぱい……っ。隊\n長さまはお口も達者なんですねぇ、胸がすごぉく気持ちいいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ッ……フフフ♪　ここまで煽られたら……もうオチンポはギンギンでしょう\n？　私のオマンコにハメたくてハメたくて仕方ないはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「って、あぁっ！？　ど、どうしてです……！？　乳首っ……乳首はねちっこ\nく愛撫してくださるのに……どうしてオマンコに手ェ出さへんのです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「わ、私のオマンコ……。アソコがトロットロに蜜溢れさせて……ジンジン疼\nいているのはわかっとるくせに……。あぁん、意地悪しとるんですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ね、ぇ……ねぇん……♪　隊長さまぁ……♪　私の匂い……わかるでしょう\n？　発情した、大人のオンナの匂い……。昂ったメスの香り……お願いです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「逞しくてゴツゴツした、えげつないカタチのオチンポ……。どうにか挿入て\nいただけないでしょうか♪　私に恩を売ると思って……どうか、どうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っぅうんん……♪　おっぱいばっかり弄り回されると、辛抱できんのです…\n…っ！　絶対に気持ち良くします、穴という穴でシゴきます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ですから……堪忍してください……っ。入れてほしくて、入れてほしくて…\n…オマンコ、もう大洪水で……。焦らされすぎておかしくなりそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……うふふふ♪　入れてくださるんですか……♪　良かった、隊長さまは本\n当に情の深いお方です。男根も太くて、硬くて、男の中の男です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「さあ……、さあ、さあ、さあ……♪　どうぞ中に、膣内に突き立ててくださ\nいませ♪　早くぅ……もう一秒も待てません……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あぁっ、あああああっ、あぁあああ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「すっ……ごいぃい……ッ♪　あぁっ……ヌルぅって……！　ヌルッて、ズッ\nポリおちんぽがオマンコの奥の奥まで入ってしまいましたよ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっああああああっ♪　全身が、体中が悦んでます……あはぁっ……♪　乳\n首も、ビンビンになっているの……わかるでしょう！？　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「き、気持ちいい……っ、気持ちいい……っ！　あぁ……っ、コレです、コレ\nが奥の奥まで一度にハマると……私、私、簡単に絶頂して……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あッ♪　んぁあああっ……！　す、すみません……今、一回イキました……\n。ぎゅっ、ぎゅぅって締まったでしょう？　あっ、肉穴がうねってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「中のヒダヒダが勝手にオチンポ様にご奉仕してしまうんです……！　あぁあ\nあ……っ、こんな年甲斐もなく、ビ、ビーチでイキ狂って……恥ずかしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「でもっ……、それがまたいいんですっ……！　はぁっ、はぁあっ……！　皆\nさんが……無邪気にお砂で、水で遊んでらっしゃる砂浜でっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「チンポ、ガチハメして悦んでいる……！　この贅沢さに敵うものなんかあり\nゃしません……！　はぁ、はぁ、もう、もう限界です、我慢できません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「思う存分腰……振らせていただきます！　ッあっ♪　あっあっあっ♪　私の\nデカい尻……っ、ぶんぶん上下に振って、下品にオチンポに尽くすっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「羞恥心なぞかなぐり捨てて……あぁうううっ♪　ふんばりながらチンポを、\n肉穴で……。熟れた蜜壺でじゅっぽじゅっぽシゴき倒してイキまくる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぁああああっ！　あぁあああおおぉおおっ♪　おおっ♪　おっおっおっ…\n…♪　あふぁあああ♪　あひっ♪　ひぃっ、ひぃっ、ひぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「どう、です……！　本気でズコバコ、ズッポズッポ女のマンコにハメ倒され\nるんは……！　なかなか、倒錯感があって気持ちええでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んは、ぁあああ……ああああっ♪　大きな声出したら聞こえてしまうのにっ\n、喘ぎ声が止められへん……っ！　だって、大きすぎるんやものっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのオチンポ、ご立派すぎて……オマンコが快感でブルブル痙攣しと\nるんですっ！　あっ！　あっ！　気持ちいいっ、解放されていくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「溜まりに溜まった性欲と、仕事のストレスが一気に解消されていきますっ…\n…！　あーっ♪　もっと早くむしゃぶりつけばよかった……ぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ねえっ……！　ねぇっ、隊長さまぁ……♪　このまま豪気に、生で中出しキ\nメちゃあくれませんか……？　愛液でビチャビチャになったこの肉穴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「一番奥の奥の奥……っ、さっきからキュンキュン言ってる子宮の入り口に、\nビュービューザーメンぶちまけて欲しいんですっ！　ああっ、ああぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「嫌だと言われても……膣圧で無理やりひり出させますっ！　ふんっ……ふん\nっ……！　んんぁっ♪　キンタマから亀頭まで、精子引きずり出してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「子宮口でゴクゴク飲ませていただきますっ……あ～～～っ♪　んぁああっ、\n出してェ……！　欲しいんです、ザー汁が……あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はぁんんんんっ♪　やったぁっ……♪　ありがとうございます、あ～～～～\n気持ちいいっ♪　オチンポミルクがビュクビュク奥にかかってます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はいっ♪　はい、そりゃあわかりますっ……！　こんだけオチンポビックビ\nク震わせて……あっ♪　あぁっ、熱い生出しの精液かけられて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「感じ取れなかったら子宮の意味ありゃしません……♪　ああああぁあっ、ビ\nュブッビュブッて……奥の奥をこじあけるみたいに大量に……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「さ、さすがの私でも失神してしまいそうな量……♪　うふふふっ、隊長さま\nもお外での交尾、気にいってくれたようでなによりですぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あら……♪　あれだけ中に出したのに、……もうオチンポさんがムクムク大\nきくなってきてますねぇ……。それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　まだまだ硬いじゃあありませんか……。隊長さまも、浜辺で\nのセックス……お気に召していただけたようで何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「もちろん、私は嬉しいですよォ？　まだまだ、いくらだって貴方と交わりた\nい……。この夏を、身体に刻み付けてほしい……。もう一回できますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「でしたら……っ、ンッ、あっ……♪　私もイッたばかりで敏感なんで……。\n二人でゆ～っくり、腰を動かして……あっ♪　スローにＨしましょうか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……ん……♪　んん……、は、ぁ……♪　はぁっ……あぁ～……♪　あぁ…\n…♪　そうです、そこっ……そこ、えぐって……突いてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　たぁっぷり膣内に射精していただいたから……。ピストンす\nる度、溢れて、こぼれて……じゅぷじゅぷ淫らな水音がしてますねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ンッ♪　私……この音好きなんですぅ♪　オマンコの粘膜から……あぁんっ\n、子宮にまで響くやらしい音……♪　はぁああ……ヒダヒダ蠢いてしまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ……あっ♪　オチンポにもジワジワ伝わるんじゃないですか……？　あ\nぁ……♪　快感が、粘膜と粘膜を行き来して……あぁああん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「やっ♪　も、もぉ～♪　隊長さまぁ♪　そん、なに突然激しく……あはぁっ\n♪　あんっ、あんっ、嬉しい……！　気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私からもお返し……♪　それっ、それっそれぇ……♪　うっ♪　あぁあっ♪\n　やっぱり極太……ッ♪　一回だけじゃ収まらなかったんですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「器もデカけりゃこっちもデカ……くてありがたいことこの上ない……っ♪　\nあぁっ♪　いいですよ、ソッチがその気なら……付き合いますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私、も♪　どうにかなってしまうくらいオマンコ締めつけますっ♪　……ッ\nあぁああっ♪　締めつけなくても、ミチミチ拡がるくらい大きい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「なんちゅう規格外のオチンポしてますのんや……！　あっひッ♪　あひィッ\n♪　中から拡げられて♪　ズコズコ突き上げられ、貫かれて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「女の悦びで、頭と身体がゾクゾクしっぱなし……っ♪　あっおぉ♪　んぉお\nおっ♪　しゅ、しゅごい♪　このオチンポしゅごい、硬すぎっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「気持ちええとこ……ゴリュゴリュえぐってくるぅ♪　っあああああ～♪　あ\nぁっ、あああぁ～っ♪　オマンコが肉棒でいっぱいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「こんな太いの、ねじこまれたら……あっ♪　あぁっあぁっ！　私も夢中で腰\n揺らして、チンポ、チンポの虜になってしまうぅう♪　あああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「チンポっ……オチンポ気持ちいいっ♪　もっと、もっと、もっとください…\n…♪　あぁっ、コレは私のチンポや、誰にも渡さないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのゴツゴツオチンポしかいらないぃ♪　あぁっはぁっ♪　はぁっ、\nはぁああっ……ねえ♪　ねえ、我儘きいてくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「出して……射精してくださいっ……！　一滴も無駄にしません、どれだけ出\nしてもこぼしませんから……あぁっ、あぁ、ビーチで種付けしてェ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「波の音聞きながら……！　っぁッ♪　一番大好きな……愛しい隊長さまの赤\nちゃん、孕みたいんですっ……このまま受精させてェ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぉぁああああああ♪　あはぁあああ♪　キたぁああ♪　出てるっ……注が\nれてるぅううう～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「おぉっ♪　んぉおおおっ♪　絶対妊娠しますっ、絶対孕みますぅ……っ♪　\nΩ組の跡取りっ、産ませてもらいますぅうう～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あひっ、ドックドク脈打って、私ん中……最高の精液で満たそうとしてるん\nがわかりますっ！　あぁっ……こんなん、こんなん受精するっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っうぁううぅう♪　腹ん中がパンッパンになるまで逃がさんって心意気……\n感じるんですっ。熱いザーメンが……次々に送りこまれて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああああっ……もうダメっ、ダメっ、果てますっ……！　隊長さまっ！　オ\nマンコ締めて最後に一絞り、いたしますからっ……あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「出せるだけ全部出してェ……！　私の気が狂うくらいっ……！　ザーメン膣\n内に放ちまくって妊娠っ……受精させてくださいませェ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っんんんんんー……！　っはぁっ……！　ハァッ、はぁっ、はぁっ、はぁあ\nあっ……あぁ……。すっかり夢見心地にされてしまいましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「下腹がぽっこり……。奥が精液でズッシリ……♪　はぁあああ……♪　中が\nあったかくて……。これ以上幸せなことなんてありゃしません♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……本当に、隊長さまは男の中の男、キメる時はキメる豪傑……。惚れた私\nも鼻が高いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「うふふ……。今、子宮の中で……隊長さまの分身が泳ぎ回っているかと思う\nと……。あっ♪　想像だけで感じてしまうくらい、嬉しいですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああっ！？　なんでですっ……！　いやぁっ、嫌です……！　私のザーメン\nが……！　あっ、あああああっ……くぅうううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あッ……♪　胸……に身体に子種がかかって……！　あっ♪　\n真っ白な雨みたいに肌を叩いてくる……！　いやっ、ぁっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「もう……っ！　なんちゅうイケズしはるんですか……ッ。そりゃあ精液……\nザーメンかけてもらうんも好きです、あっ♪　マーキングのようで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「でも……膣内に、子宮にぶち込んでいただきたかったのに……♪　……んっ\n！？　ンンンッ、やっ、す、すっご……まだ出てる、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ぷぅんと立ち上るこの臭い……。鼻腔をくすぐるイカ臭さ……♪　べったり\nと、肌という肌にこびりついてくる粘着力……。うぅうん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「特別素晴らしい精液なのに、外に出てしもうて……切ないやら嬉しいやらで\n、身悶えしてしまいます……。あっ♪　また出たっ、あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っふぅうう……♪　ふぅううう～……♪　ふぅううっ、んん～……♪　この\nネットリザーメン……せめて、手で全身に塗りつけましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「けれど……そんなことしたら、後でいっくら洗っても、皆さんにバレてしま\nいますよねぇ……♪　私にこれだけぶっかけたこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「おニューの水着にも染み込んで……もう、これ外では着れません。その……\n、家で……もしくはあなたの前でだけ身につけるようにしないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……高かったんですよ？　この水着。キチンと元がとれるまで……エッチの\nコスチュームとして使い倒しますから。協力してください、約束です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0304410" ]},
