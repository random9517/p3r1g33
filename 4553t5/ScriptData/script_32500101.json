		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「やぁやぁ、来たね。待ってたよー、ほらほらこっちに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「どうしたって、やだなぁ……そんなの決まってるじゃない。今日はあたしが\n淫魔として真の覚醒をする日なんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「アスモデウスの名が、ついに名実ともに色欲を統べる存在になってしまうん\nだよね……あ、えーと要するにご奉仕するってこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ほら、隊長さんって、そういうコトしまくってるんでしょ？　だったらあた\nしも、そろそろしとかないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「細かいことはいいから、ほら……オチンチン出して。あ……違うね、オチン\nポがいいんだよね、こういう時って。知ってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ほら……出てきた。大丈夫、代わりにあたしのおっぱいも見せてあ\nげるから。これで興奮しちゃうんでしょ、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あはっ、すご……一気にびくんって大きくなった。すっごく分かりやすいん\nだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「こうしてぎゅって握るだけでイッちゃったり……は、しないか、さすがに。\nえっと……確か……こんな風に動かすんだっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「えっ、あ……痛い？　もうちょっと優しく？　あ、ごめん……なんか、ちょ\nっと加減が難しいみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「えっと……これならどう？　大丈夫……？　えっ、大丈夫だけど何も感じな\nい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「うー、えっと……じゃあもう少し強くて……これで、ぎゅっとして……こん\nな感じ、かな……んっ、どう、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あっ……へへー、ちょっとそれっぽくなって来たじゃんか。そっかー、ちょ\nっとこれ位で指をしてあげるのがちょうどいいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ね……ね、どう？　気持ちいい？　オチンポ我慢できなくて、ぴゅっぴゅっ\nて出ちゃう？　ね、ね……どう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「えぇー、まだこれだけじゃ物足りない？　もう……隊長さんってば、結構な\n欲しがりさんだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「いいよ、もっとしてあげるから。ほら……こうして……こすこすって……皮\nめくってあげる……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あっ……跳ねてる跳ねてる……こすこす……しこしこ……どんどん我慢がで\nきなくなってるんだね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あはっ、こんなに震えちゃって可愛いんだから……でもまだだよ……今度は\nもっとすごい世界に連れてってあげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はあぁぁぁんむっ……くぷっ、んっ、ふっ……！　ふぁ……お、思ってたよ\nり……おっきぃ……んっ、ふぐっ、んむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「むぐぅ……ん、ちゅぷっ、んっ……これで……えっと、んっ、ぴちゃ……先\nっぽを舐める……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっ、分かってるよ、今、そうしようと思ってたとこ……待って、むふぅっ\n、んっ、ぺろ……ぺろ……んちゅぱっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふぁ……れろ、ぴちゃ……変な味ぃ……なんか少ししょっぱくて……臭み\nがあって……んっ、える……れる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「でも、慣れれば全然……んふっ、百戦錬磨のあたしにかかれば、なんてこと\nない……え……初めてだろって、細かいことはいいじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「いいから、あたしに任せてれば……んちゅぷっ、大丈夫らから……もごっ、\nんふぐっ、くぽっ、んりゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふっ……おくひの中で喋ると……ムズムズして、きもひいいの……？　ん\nふー、りゅぷっ、こんら感じ……かな、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「れろ……んぺろっ、んっ、ふっ、ふぉら……なるほろね……んっ、分かって\nきたかもぉ……ちゅぱっ、ちゅぷっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「むぐっ、口の中で……りゅぱっ……オチンポの先のとこ……んりゅっ、れろ\nれろ……舐めまわひて……ちゅぱっ……じゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「そーするとっ、んんっ、じわって……お汁……湧いて来るんだ……んふぅっ\n、ぴちゃ……れる……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふふっ……間違ってないみたいらね……あたしのおっぱいも……じぃーっ\nと見てきてるしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「いいよ……隊長さんが、それでムラムラ来るんでしょ？　その代わり、もっ\nとオチンポおっきくさせて……気持ちよくなっちゃお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んちゅぱっ、ぴちゃ……んんっ、はぷっ、ふぁ……口の中……よだれ、れて\nきひゃうね……んふぅ……じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「これがフェラチオ……りゅぷぅっ、んちゅぷっ、やらしいよね……んじゅる\nっ、んちゅぱっ、くぽっ、んりゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「また……んっちゅ……口の中れ……オチンポが、震えて……あ……んちゅぷ\nっ、何か……れて……来てる……んふっ、んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「これって……せーえき……出たくなってるってことらよね……？　んっ、じ\nゅるっ……いーよ……いっぱい出して……いいからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あらひに……飲ませてっ……隊長さんのとろとろせーえきっ……じゅぽっ、\nんじゅっ、むぐぅっ、んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ！　れたっ……！　あぷっ……んぐっ、むふっ……んっ、んん\nんんんっー！　むぐっ……んぐぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅん……だい……じょぶっ……色欲の……悪魔は……精液はご馳走\nなん……だから……んくっ、ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「これ位……全部……飲んで……んっ、こくんっ……当たり前……んんっ、ぷ\nぁっ、はっ、はふっ、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……えへへ……ほーら、ね？　ちゃんと全部飲んだじゃん。ほら\nほら、あーん♪　ねっ、飲みきったでしょでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「これであたしも、完全覚醒して身も心も色欲魔神になっちゃったかな～。あ\nぁ、７つの封印の１つが解けて、後は６つ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「全てを解放しちゃったらもう、完全に取り返しがつかなくなっちゃう……隊\n長さん……責任取ってもらわないと……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「って……わ……まだ、オチンポ……ピーンって上向きになってる。そっかそ\nっか……これって、アレだ。連続射精するやつだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふ……いいよ。完全に覚醒したあたしのテクニックで、もっと隊長さんの\nオチンポトロトロにしちゃうんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ね……この辺とか……今、とっても敏感なんだよね？　ほら、つんつんって\n……ふふっ、ちょっと痛かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ごめんごめん、デリケートな場所だから優しくしてあげないとね……んちゅ\nっ……ふふっ、やさしーく……舌で……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「じゃあ、もう一回……はむ……んりゅっ、れろ……えろ……くぽっ、むちゅ\n……んちゅっ、ちゅぱっ、ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふっ、オチンポの弱いところ……すっかり覚えちゃったから、もうすぐに\n出ちゃうんじゃない……？　れろ、んりゅっ、れる……れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「え……まだまだ？　ふーん、いいのかな、そんなこと言っちゃって……はむ\nぅっ、んりゅっ、くぽっ、じゅぷっ、んぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふふっ……むき出しの亀頭のトコ……ぺろぺろ舐め回しちゃうんだから…\n…ちゅぽっ、んくぷっ……りゅぽっ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「オチンポの味も……もう、すっかり分かっちゃった……んふ……後は、これ\nを……シコシコする……んらよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるっ、んちゅぷっ！　んっ、れろ……わらひの超絶テクれ……ん\nっ、けほっ！　今のはちょっとむせただけだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「は……んんっ、じゅぽっ、本気出すのは……ここかららから……んりゅっ、\nじゅるっ、んっ、むぐぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、口の中の……おしる……溜まってくぅ……んじゅるっ、ちゅぽ\nっ……くぱっ、んりゅぷっ……ふぶっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んぁふっ、じゅぱっ……ふぶっ、もっと激しくぅ……じゅぽじゅぽっ、んふ\nぅっ、ふぉら……ここも好きなとこぉ……りゅぽっ、んくぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「後は……こっひもっ……れろ……じゅぱっ、よく分かんないけど……何とな\nくコツ掴んじゃった……えろ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ろぉ……ひゃんとれきてる？　んふっ、じゅぱっ、よかった……もうすぐら\nからね……んちゅぅっ、りゅぷんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0103215" ]},
