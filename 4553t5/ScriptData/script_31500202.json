		{"command":[ "SETIMAGE", "0", "still_00015002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「出し入れするたびに、ん、んん、ドロドロが掻き出されて……あ、はぁ……\n潮でも噴いてるみたい、です……ああん、恥ずかしいでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はえぇ？　隊長氏も、気持ちいい……でござるですか？　嬉\nしい……ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ひゃう！　あひぃぃ……そ、そんなに激しくされたらっ、あっ、ぐぅ、ひう\nぅ……膝に力が、入りませんでござる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「中で、ゴツンゴツンぶつかってる……っ、あ、ああ、身体が、持ち上がっち\nゃいますでござるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあん……おちんちんに、身体が支えられてる……あ、ぐぅ、子宮\nごと、持ち上げられちゃうぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「駄目ぇ……拙者、イ、イイ、イキ、そうでござるぅ……はぁ、はぁ……あぁ\n、はぁぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「え？　あ、はいぃ……だ、出して、下さい……このまま、中に……ん、んん\n、はぁ……ああぁっ、ひやぁぁぁぁぁん……っ！」", "NORMAL" ]},
