		{"command":[ "SETIMAGE", "0", "still_00015002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ふぐぅぅ……！　ひやぁぁっ、あっ、あっ、はぁ……はへぇぇぇ……イッ、\nイッちゃい、ましたぁ～～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んひぃ……はぁ、はぁ……イクのが、と、止まりません……ああ、入\nってくる……精液がっ、子宮に染み込んでくるでござる……」", "NORMAL" ]},
