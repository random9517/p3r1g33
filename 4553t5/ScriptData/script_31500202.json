		{"command":[ "SETIMAGE", "0", "still_00015002_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はー……はー……イッちゃい、ましたぁ……はぁ、はぁ……え？　震えてる\n……？　だ、だって、気持ちいいん、でござるですもの……」", "NORMAL" ]},
