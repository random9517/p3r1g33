		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あああ、アソコが、おちんちん、握りしめてる……ううん、意地汚いアソコ\nで……なんだか、恥ずかしい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……あふぅ……締め付けたまま、おちんちんが動いてる……\nおちんちん、いっぱい感じちゃうぅ……っ」", "NORMAL" ]},
