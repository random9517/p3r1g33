		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「もっと落ち着いた体位がいいのに、雑に扱われてる……悲しいけど、ちょっ\nと感じちゃうでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……うう、拙者、やっぱりＭみたい……でござるです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あ、でも、丁寧に扱われたいっていう、普通の女の子の気持ちもあるんでご\nざるですよ？　だって、拙者普通の女の子ですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……それなのに、こんなに濡れて……あああ、拙者、変態だと\n思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「え？　挿れたい……？　わかり、ました……どうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、はへぇぇえ……入ってくる……入り口がこじ開けられて……ぐぅ\n、ふぅ……んはぁぁ……」、", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「太くなった部分が、アソコの中をいっぱいにこじ開けて……んん、あはぁ…\n…はぁ……ああ、すごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「アソコが全部、おちんちんに絡まっていくみたい……あ、あああ、そのまま\n奥に……んぐぅっ、ひうぅ……！　あはぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はっ、はぁ……あはぁぁ……す、すみません……軽く、イッちゃい、ました\nでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はー……はー……お腹の隙間に、おちんちんがミッチリ詰まってるでござる\nです……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あ、熱い、です……アソコの奥で、隊長氏の体温を感じます……ん、ふぅ…\n…どうしてこんなに熱いんでござるですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「これって、男女の違い……なんですかねぇ？　って、どうでもいい話でござ\nるですね……はぁ、ふぅ……すみません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、おちんちんが、動いてる……はぁ……はぁあん……熱いぃ……先\nっちょが、太くて……ん、んんぁ、中でひっかかっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「う、くぅ……アソコの壁が、おちんちんにピッチリ貼りついてるでござる…\n…形がはっきりとわかります……はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「そのまま、う、動かれると……あ、はぁ……アソコ、全部持っていかれてし\nまいそうでござるぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あああ……はぁ、ふぐぅぅ……一番、深いところに、ごつごつ\nぶつかって……くる……あ、これ、す、ごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あ、あひぃ！？　お、奥に入ったまま……グリグリされてる！！　きゃうぅ\n！　あはぁぁ……子宮が、持ち上がっちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あああ……これ、すごぉい……一番大事なところ、犯されてる……身体が、\n隊長氏のものになっていく感じが、しますでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……おちんちん、すごぉい……はぁあん、こんなに気持ちいいだなんて\n……あ、ああ……はぁ……はへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅっ！　んっ、んんっ！　あはぁあ……ま、また、軽くイッちゃった\nぁ～～……あ、ああ、駄目、う、動かないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「そ、そんなことされたらっ、ん、んん、またすぐイッちゃうでござるですぅ\n……はぁ、はぁ……あはぁ……すごぉい……気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あっ！　はぁ……はぁああん……奥に、コツコツ、ぶつかってくる……はぁ\n、はぁ……あああ、お腹に、響いてくる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んんぁ、はぁ……はぁ……隊長氏も、気持ちいい……でござるですか？\n　はぁ……ふぅ……そ、そうですか……嬉しい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ぐぅ、んはぁ……はぁぁん……おちんちんが、出たり入ったりして……アソ\nコが広がったり縮んだりするのが、わかります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ああ……アソコが、おちんちんの形になっていく……はぁ、はぁ…拙者の身\n体が、隊長氏に、支配されていくでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んんん、あぁ、はぁぁあん……ま、またイキ、そう……ああ、わたし、\nやっぱりＭみたい、ですね……こんなことで、感じちゃうだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ひゃううぅ……やだぁ、中が、ドロドロしてる……拙者、いっぱい濡れてい\nるで、ござる……」", "NORMAL" ]},
