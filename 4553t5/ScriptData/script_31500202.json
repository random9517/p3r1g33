		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「中が、擦られて……あ、ああ、アソコ全部、気持ちいい……駄目ぇ、い、イ\nクっ……はぁ、はぁ……イッ、ぐぅ！！　はぁ、はぁ……あぁああん……」", "NORMAL" ]},
