		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁ。はぁ……はへぇぇ……中で、グチュグチュが、聞こえてくる…\n…はぁ、ふぅ……んんぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ああん、すごぉい……こんなの、駄目ぇぇ……はぁ、はぁ、ひぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「精液、欲しい……ああ、アソコが、精液のおかわり、欲しがってるでござる\nぅ……ん、ん、はぁ……欲しい……欲しいですぅ……」", "NORMAL" ]},
