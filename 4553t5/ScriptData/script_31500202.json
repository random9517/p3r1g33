		{"command":[ "SETIMAGE", "0", "still_00015002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「アソコの中が、おちんちんに持っていかれてしまいそう……あ、ああ、子宮\nが引っ張られる……ん、んん、押し込まれ、ちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あぁ、はぁ……膝がガクガクします……身体に力が入りませんでござる……\nはぁ、はぁ……はぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あああ、中に出された精液が、気持ちいいですぅ……ヌルヌルが塗り伸ばさ\nれて、アソコ全部に染み込んでいくぅ……」", "NORMAL" ]},
