		{"command":[ "SETIMAGE", "0", "still_00015002_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……子宮が、精液をゴクゴク飲んでいます……ああ、入ってくる…\n…はぁ、はぁ……隊長氏の体温……あ、温かい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はー……はへぇぇぇ……気持ち、よかった～～……はぁ、はぁ……ふぅ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「隊長氏も、ん、ふぅ……満足してくれたみたい、でござるね～……はー、ふ\nぅ……よかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ふえぇ……？　まだ満足していない……？　うう、確かに……まだこんなに\nビンビンしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「でも、嬉しいです……このまま続けてくれるってこと……でござるですよね\n……？　はぁ……ふぅ……拙者も、もっとしたかった、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁ、はぁ……あぁぁぁん……動いてる……おちんちんが、中でず\nるずる動いて……ぐっ、ふぅ……はぁ、はぁぁああん……」", "NORMAL" ]},
