{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……こんな場所に呼び出すだなんて。非戦闘に徹しているからってウチを暇\n人だと思ってるです？　まだ書類仕事が残ってるんですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「は？　パワーアップのためだから我慢しろ……？　まったく、ウチにそんな\n口を聞くとは……ほんっっっっとうに偉くなったものですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いいえ、文句なんてありません。え？　どうして棒読みなのか、ですか？　\nそのお利口な頭で勝手に考えればいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それで？　何をどうすればいいんです？　は？　エッチなことをして、恥ず\nかしい思いをすればパワーアップする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503104" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……頭が変になったですか？　いえ、もともと変でしたね……パワハラとセ\nクハラされたこと、あとで陛下に報告するですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503105" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……ウチがどうしてこんなことを……。これでパワーアップできなかっ\nたら、法的な問題にしてやりますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「うう……大きくて、グロテスク……。それに、なんです、この匂い……くん\nくん……胸が、悪くなるです……くんくん……すんすん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……自分の吐息で眼鏡が曇ってしまいます……ちょっと待って下さ\nい。今から眼鏡を外すです。えーっとケースは…………」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「は？　眼鏡は外さなくていい？　その方が興奮する……です？　まったく、\nとんだ変態さんですね……おぞましくて、寒気がします……くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……頭がクラクラします……本当に風邪でも引いてしまったかも…\n…あなた、ウチに一服もったでしょう……怪しげな薬か毒を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「じゃないと、説明がつきません。ああ、駄目ぇ……くんくん……いいです？\n　これは熱に浮かされたせいです。ウチの意思ではありませんからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んん～～……れろ、れるれる……ぴちゃ、ねるん……ああ、想像通り、変な\n味ですぅ……ねるれろ、くちゅ、ぬるぬる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……んん、舌が、痺れてしまいそう……ねるん、ぴちゃ、んちゅ、ねろ\nん……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ああ、眼鏡が曇る……ぴちゃ、れろれろ、んちゅ、れろん……ああ、酷い匂\nい……ちゃんとお風呂に入ってるですか？　ねる、にちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え？　なのに、こんなに臭うだなんて……きっと、あなたの人格が匂いに表\nれてるんでしょうね……れる、れろれろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おや、怒ったです？　心が狭いんだから……れろ、れろれろ……え？　もっ\nとしっかり咥えろ？　はぁ……わかりました……仕方ないですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んはぁぁむ……れろ、むぐ、もごもご、んふぅ……咥えると、匂いが一段と\n強くなるです……んぁむ、むちゅ、ねる、んちゅちゅる、ぴちゃぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ああ、変な味ですぅ……ちゅぼじゅる、ぴちゃ、ちゅちゅじゅる、ねろぉ…\n…はぁ、はぁ……でも、少し慣れて来たです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「これ、もっと激しくすればいいです？　あんまり、期待しないで下さい……\nウチ、初めてなんですから……んん～～……んちゅ、ちゅぼ、じゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「むぐ、もごもご、ぐぶっ、じゅぶじゅるるぅ……はぁ……はへぇ……おちん\nちん、お口の中、いっぱいになってるですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……んへぇ……息苦しくて、失神、してしまいそうですぅ……ぴちゃ、\nちゅるじゅるる、れろ、ぬちゅぅ……はぁ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くん、くんくん……はぁ、少し匂いが薄くなってきたです……え？　殘念そ\nう？　な、何言ってるですか……本当にお馬鹿ですね……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はむ、れる、んちゅちゅる、ちゅぼ、ぐぶ、ちゅぶじゅるるぅ……んん、は\nぁ……ああ、おちんちんの味、だんだん濃くなってるような……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ねるれる、んちゅ、ぴちゃぁ……え？　第一ちんぽ汁……？　カウパー氏腺\n液でしょう？　テキトーですね、相変わらず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん、んん、気持ちよくなってる証拠……なのですよね？　それぐらい、知っ\nてるですよ……はぁ、はぁ……んれろ、ぬるぬる、じゅる、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ……んん、ああ、アソコがモゾモゾする……んはぁ、あぁあん……ぬる\nれろ、ぴちゃ、くちゅじゅる、れろれろ、ちゅぼぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……はぁ……れろ、れる、ぬるる、くちゅ、ちゅちゅぴちゃ、\nじゅるぅ……あふぅ……ああ、ウチ、おかしく、なりそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んん、んふぅ……こ、このまま続けると、射精するですよね？　ああ、そん\nな……酷い……むぐ、んちゅるる、びちゃぁぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ちゅぶ、ちゅる、ぐじゅるる、ちゅぼぉ……ドロドロで、イヤな匂いがして\n……気持ちの悪い液体……なのでしょう？　んぶ、ぐじゅれろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ？　ウチが精液を楽しみにしてる……？　そんなわけないです……んち\nゅ、ちゅぼ、じゅぶじゅぶ、ぐぶじゅるる……れろぢゅぢゅる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん、ふう……知らないことを知る楽しみはあるです……それだけ、です……\nはむ、れろ、じゅぶじゅる、ん、んん、んちゅじゅぢゅるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はー……あぁあん…我慢汁が、おちんぽ汁が、いっぱい溢れて……んぐっ、\nちゅる、ぐぶぷっ、ぐぶちゅぼ、くちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウチに出す、ですか？　はぁ、んふぅ……うう、スーツ、汚さないで下さい\nね……んぁむ、むぐむぐ、ちゅぼぉ……明日も仕事があるですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あ、ああ……ビクンビクンしてる……あ、あの、ちゃんとお願い聞いて下さ\nいね……むぐ、じゅぼ、ちゅるちゅる、ずるじゅるるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んはぁ、はぁ……あああ、出る……れろれろ、ちゅる、じゅるじゅぼぉ……\n出されちゃうぅ……ん、ん、ちゅるじゅぢゅずちゅうぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぶぅ！？　んぐっ、んぶぅぅぅ……んはぁ、あぁぁ……こ、これが、精液\nぃ……？　うぶっ、おぇえぇ……酷い、味ぃぃ……あへえぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……想像してたより、勢いがすごい……ビックリして吐きそうで\nした……はぁ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「くんくん……うぐぅ……変な匂いですぅ……うう、気分が、悪くなりそうで\nすぅ……はぁ、はひぃ……はへぇ？　嬉しそう……ですって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「馬鹿なことを……ひふぅ……あへぇぇ……どうして、ウチが……こんなもの\nで、嬉しくなるわけ、ないです……ホント、バカですね……くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ふぅ、それじゃあ、もう戻るです。こんなもので強くなれるわけないです…\n…まったく、時間の無駄だったですね……はぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000505_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}