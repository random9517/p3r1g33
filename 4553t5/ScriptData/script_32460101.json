{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こんばんは、隊長さん。こんな夜分に訪ねてきてしまってごめんなさいね？\n　貴方の活躍、毎日私の目に映っているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00024601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「そうよ。褒めにきたの。おかしいかしら。……ただ……、貴方が凄くなれば\n凄くなるほど、１つ大きな懸念が生まれてきたのも事実よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「このままじゃあエスティマちゃんやルナちゃんが、すっかり貴方にお熱にな\nっちゃって……Ｘヴァルキリーの任務に支障が出ると困るの。だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「２人がおかしなことをする前に……私が貴方にご褒美をあげようかなぁ～っ\nて。フフフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「え？　何？　ご褒美いらない？　まっ……待ってよ。その返答は想定外だわ\n！　あっ、貴方に選択の余地なんてないの！　ご褒美を受け取るの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00024601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「じゃないと……じゃないと、可愛い可愛いあの子達が、いつ貴方の毒牙にか\nけられることか……！　嫌だといっても受け取ってもらいますからねッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00024601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ふふふ～ん……♪　どうぉ？　こうすれば……さすがの貴方も、肉欲と圧迫\nとで逃げ場を失った……ということでしょう？　ウフフフ♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こんなにゴージャスで優雅なご褒美を受け取れる人間なんて、他にはいない\nんだから……ありがたく、感謝して私に支配されてちょうだいねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……なによ？　おっぱい丸出しで、オチンコ挟んでご満悦だっていうの？　\nそっ……それは……。些細なことでしょ！　名誉なことでしょ、黙りなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私からのご褒美は……精巣がすっからかんになるまでの濃厚～なパイズリよ\n？　好きでしょ、貴方……パイズリ。そういう顔をいつもしてるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「毎日、仕事ばかりで疲れているんでしょうから。今だけは、何もかもわすれ\nて快楽に溺れてみればいいんじゃない？　逆らわなければ優しくしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「そうよ……ジーっとしてなさい……。んッ……。このメアフォルマ様の特別\nなおっぱい奉仕……受けられる男なんて他にいないんですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……もちろん、女の子たちにも出来ないし……。つまり、貴方独占ってこと\nなんだから。ごちゃごちゃ言わずに感じまくりなさい？　いくわよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んふ……っ、ふぅっ、ふ～……♪　ふぅ～っ、ふっ、ふっ、ふぅ……♪　ど\nう？　この縦揺れ……前後上下に自在に動く乳房……ふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「今夜のために、念入りにケアしたおっぱいは……プルンプルンのふわトロで\nしょう？　これはね、マッサージをして血流を良くしたのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「それで、ダマスクローズの高価なローションをねりこんで……っ。ん……♪\n　いい匂いがして、肌ざわり最高な胸になるよう努力、を重ねたの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「だって……、んっ……！　せっかく褒美を与えるんなら、最高だって思われ\nたいじゃない？　……はぁっ、メアフォルマ様が一番だって……。ねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「エスティマちゃんやルナちゃんでは満たせない、巨乳の魅力をぶつけにぶつ\nけて……。っはぁっ、ぁっ……満足させないといけない、から……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……えぇ？　貴方のチンポについてどう感じたか、ですって？　やぁだ、も\nぉ……ソレ、言わせるの？　シゴいてあげてるだけでも凄いことなのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「オチンコの感想まで聞かせてもらおうだなんて……。ん、ふっ……やっぱり\n危険人物ね。他と比べてなんて知らないわよ……さっきも言ったでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方くらいにしか、こんなことしたことないから。ん、誰よりも大きいとか\n太いとかは比較対象がないけど……。そ、そうね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「実際に見て触れた限りでは……。きょ、巨根……なんじゃないの？　ほらっ\n、私の胸からもハミ出すくらいだし……じゅ、充分でしょうっ……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「っていうかこれ以上大きくなられたら、胸でなんて挟めないでしょう？　だ\nから……これでいいと思うわ。太さだってとてつもないし……熱いし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「本来女性の膣内に入れる……ものなのでしょうから、あまりにも硬すぎるの\nも……。って、なんです！　言った先から急に硬くしてっ……！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「も、もうっ……！　暴れさせないで……！　はぁっ……捕まえているのが大\n変じゃないの……！　こらっ……おとなしくしていなさい！　それっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私が……。んっ、気持ち良くしてあげると言っているんだからっ……！　ふ\n、ぅ……はぁっ、んん……！　極上のマッサージを受けている気分で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「じっとして……。っぅっ！　痙攣させないで……。はぁっ、はぁっ……。私\nの胸の中に収まってなさい……イタズラしないで、外にいかないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「他の子にその危険な矛先を向けない、ようにっ……私、私の胸に全ての欲求\nを吐き出すの！　んっ……はぁっ、はぁっ……んっ、んん～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「妙に節くれだっていて、こすりにくいったらぁ……！　んッ……ふふふふ、\n喜んでいるわ。ここが感じるのね……重点的に責めてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ここ？　ここかしら……？　っはぁっ……♪　はぁ、はぁっ……。なにこれ\n。意外と愉快になってきちゃった。パイズリって面白い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んんっ！　無抵抗のオチンコちゃんをおっぱいで好き勝手に蹂躙して……感\nじさせて、操って……うふふふ……。悪くない、悪くないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ぷりんぷりんのおっぱいが、オチンコの上で跳ねたり弾んだり……大事なと\nころをムニュムニュすると股間が幸せいーっぱいになるでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私も……。っんっ、私もすっごく楽しいわ……。はぁっ、はぁ……はぁっ…\n…！　そぉれ……ぐにゅぐにゅぐにゅぐにゅぅうう～～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「谷間で精子を絞り出してあげる……♪　むにゅむにゅむにゅぅうう……♪　\nぐにゅぐにゅぐにゅぅうう～～♪　ぱふっぱふっ、ぐにゅぐにゅぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「そぉれ出しなさい♪　目で見ていてもわかるわよ……？　ぱんっぱんに腫れ\nたオチンコが、もう限界だって叫んでる……。胸の中で震えてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「さっさと観念して、精子をドプドプ排出するのよ……。ええ、私が出せとい\nったのだから、当然私が受け止めます。いらっしゃい……！　ここよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「はっぁっ♪　ああああっ……！？　うぁっ……！　すごいっ……！　あらっ\n……！？　思っていたより勢いがすさまじくて……。ふぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「って、普通出すのなら胸に！　でしょうっ……！　顔に……あっ、顔に出す\nなんて完全に想定外だわっ……！　もうっ、もう！　ベトベトするぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こらぁっ……！　にょ、尿道口をこっちに向けないでっ！　顔はだめよ……\nだめ、……ダメなのに……なにこれぇえ……♪　酔っちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私が！　私が貴方にこれほどの量の射精をさせたということなの？　ありえ\nない量が出ているのだけれど？　へぇえ？　そんなに興奮したのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「こんなのっ……人が体内から放出していい量じゃないでしょう！？　ひぁっ\n……！　飛距離もとてつもないし！　臭いもくさすぎるし……ちょっとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方、本っ気で私のパイズリでエンジョイしちゃったのね……！？　ふふ…\n…うふふふ、そーぉ。そうなんだぁ……だったら成功ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「このまま、更に絞り続けてあげましょうね？　貴方に拒否権なんてあると思\nう？　私がしたいから、するの。うーん、探求心がそそられるわ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……ねえ？　射精した後すぐに刺激されると、くすぐったいのかしら？　そ\nれとも、敏感になって……より、乳房の感触がわかって興奮する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私は……すごく興味津々よ。貴方のモノに付着した精子……この白濁液の触\nり心地……とても不思議。トロっとしていたりネットリしていたり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「研究しがいがあるわ。ねえ？　この液を膣内に注がれたら……女の子って赤\nちゃんが出来ちゃうんでしょ？　魔法みたいだと思わない……？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「もっともっと見たいなぁ？　貴方の魔法の体液……。だからたくさん出して\nもらうわね。大丈夫よ、大体射精のさせ方はわかったから♪　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「貴方の反応って、単純でわかりやすすぎるの♪　……ここをね……。こう♪\n　こうして……胸を激しく揺らしながら、弾力たっぷりにまとわりつかせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ふにゅふにゅふにゅ、むにゅむにゅむにゅって揉みしだくみたいにするの…\n…。あん、逃がさないってば♪　こんな面白いことやめられない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「どこまで耐えられるか、勝負しましょ……。ほら♪　ほら、ほら……♪　た\nぷ、たぷ、たぷ、たぷ……うふふふ♪　オチンコ胸に沈んでいくわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あったかいでしょ？　柔らかいでしょ？　ずぷずぷ亀頭も竿もしずんでいっ\nて……まるでおっぱいでエッチしてるみたいだと思わない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、心配しないで？　私もすっごく喜んでるわ……。あっ……♪\n　腕や足と違って……あん♪　ココってすごーくデコボコしてるか、ら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「胸のあらゆるところにひっかかって……感じるのよ♪　本当に……、あはっ\n♪　胸の穴でセックスしてるみたい、で……わくわくしてくるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ねえ？　ねえ？　胸の穴にだったら、どれだけ精子を出してもいいのよ？　\nここに出したって妊娠なんかしないんだから、出し放題でしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ここにね？　ビュッビュッてすると気持ちいいわよぉ……？　華奢な女の子\nたちじゃ経験できない、お肉の圧力……それにぷにゅぷにゅ潰されてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「オチンポガッチガチにしながら射精するの……♪　次はどこに出したいかし\nら？　また顔？　それとも……この豊満なバスト？　どうするのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んふふ……♪　意地悪言っても、どんどんここは元気になってきて……とん\nでもない逸材ね。少しマゾなの？　だったら私と相性がいいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「っん……♪　ぐにぐにぃって左右からおっぱいにいじめられて、いっぱいい\nっぱい精子出しちゃいなさいよ。じーっと見ててあげるから……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「射精するところ♪　女の子に見られていたら絶対気持ちいいわよ？　ね……\n射精♪　射精見たい♪　はーやーくぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「タイミング、計ってあげるわね？　いくわよぉ……？　５……、４、３……\n２，１……。はい、ビュッビュして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あぁもぉ～～♪　まぁた顔に出すのぉ？　いいけど……♪　ンッ……、思っ\nたより独占欲強いのかしら？　私にマーキングしようとしてるう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「あッ……んもぉ♪　そんなにまんべんなく……♪　顔のいたるところにぶっ\nかけてくるなんて……すごい執着心ね、感心しちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「びゅぶっ、びゅぶって……きゃっ。何度も何度も降り注いでくる精液……。\nまだまだこんなに隠してたなんて、底知れぬ男なんだから……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「っはぁっ……♪　ふぁああ……♪　すごい量……。息をするたびに、ムワム\nワ～って精液の臭いがまとわりついてくる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「うふっ、ふふふっ♪　噴水みたいにどんどん精液が湧き出してくる……。白\nく濁ったこの液体……すすりとったら、とても苦いんでしょうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……びゅっびゅっびゅっ、びゅっびゅっびゅっ……。一体どこまで出すつも\nりなの？　私の顔、そんなに……精液かけたくなる顔かしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「まったく、やんちゃなオチンポなんだから……。……全部出せた？　そう。\nそれなら良かったわ……。見てよ、パックしたみたいにドロッドロ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「これだけ出してくれたってことは……私の胸、気に入ってくれた？　これか\nらも使いたいって思ってくれる？　……ああ、違うのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「私も貴方のコレ……気に入ったから、もしそうなら嬉しいと思って。ね？　\nちっちゃい子達……エスティマちゃんやルナちゃんのおっぱいじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「ここまでの乳圧は出せないんだから。２人に手は出さないで、私とこれから\nもいいことしましょうね？　約束よ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「んふふふっ……♪　今回は胸に出すことにしたのね？　嬉しいわ……♪　だ\nって、出てくるところがよーく見えるんだもの……ありがとう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「うふふっ、どっくんどっくんオチンポから精液が発射されて……もう胸の曲\n線がヌッルヌル……。精液ってタンパク質なのよね……っ？　フフフッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「身体に良さそうだから……おっぱいに塗って当分放置しておいてあげる……\n♪　っきゃっ♪　まだ出るの？　困ったオチンポねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「はいはぁい、私のおっぱいは逃げませんから……ゆっくり出せばいいじゃな\nいの。はい、びゅっびゅるびゅっ、びゅっびゅるびゅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「フフフッ、こぼれおちて垂れそうなくらいの量……♪　滝のように出るのね\n、この量を受け止められる女なんてそうそういないでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「……はい、上手に出せました♪　あ、まだしばらくはこの胸の中にいていい\nわよ？　余韻ってあるものね。少しここで休んでから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024601_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「また、一緒に任務をがんばりましょ？　あぁ……それにしても、精液って面\n白いわ。こんなのが、毎日のようにオチンポに溜まって出るなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「男って大変なのね……。え？　だって熱くて、ネバネバしていて取扱注意じ\nゃない。……外に出るまではそうでもないの？　そうなの……へぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「それなのに、女の子にかけたらこーんなにも粘着力がアップしちゃうんだ。\nそれって、たぶん……女の子を妊娠させたい欲求のあらわれなのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メアフォルマ" ]},
		{"command":[ "SETTEXT", "「やっぱり危険すぎるから……。定期的に抜きにこないといけないみたい。ち\nっちゃい子達に手を出す前に、このおっぱいを思い出すのよ。いいわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_246_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}