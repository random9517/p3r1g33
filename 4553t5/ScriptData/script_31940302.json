{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「フフッ♪　待たせてしまったようだな……。だが、本日ばかりは許してもら\nおう。ワタクシの、アイドルとしての第一歩……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00019403_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「初ライブが無事に成功した！　それもこれも全て、貴方のサポートがあった\nからだ。ありがとう、本当にありがとう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304102" ]},
		{"command":[ "SETCHARA", "0", "char_00019403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……それで、なのだが。前に約束したのを覚えているか？　覚えていない？\n　であれば今一度伝えるとしよう。このライブに成功したら、その時は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00019403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方はワタクシに、褒美を与える……ということになっている。ああ、いい\nのだ。記憶になくとも。貴方はワタクシに、ご褒美をくれるだろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ああああ……♪　嬉しい……！　嬉しくてどうにかなってしまいそうだ……\n！　本当に、褒美をもらえる時がくるなんて……信じられない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019403_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシの甘えに、応えてくれてありがとう。なあ、ちゃんと見てくれたか\n？　ワタクシがステージで舞う姿、歌う姿、貴方にだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぁんさ、というものをしていたことを……！　ああ、ああ。ウインクもし\nた。投げキッスもした。両手でハートマークも作った。それも何もかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシから、貴方一人に贈ったふぁんさ……。たっぷりと愛情をこめた特\n別な暗号だ！　……ふふふふ。そして、それらの礼がこの現状……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ライブ直後の甘トロいちゃいちゃ交尾に他ならない……♪　もっと、強く手\nを握りしめてくれ。まだ、身体中が高揚していて気分も高まったままなのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「この状態で、アイドルの衣装のままで抱いてほしいと願っていた……。っン\n……♪　わかるだろう？　身体のあちこちが、挿入を期待している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ツンと尖った乳首が、揺れる乳房が、濡れそぼった陰部が、火照った肌が、\n全身が……貴方に愛してほしい、推してほしいと叫んでいる……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぅっ♪　ふぅ、ふう……♪　息が荒いままで申し訳ないが……前戯は必要\nない。ずっと、貴方のオチンポが入るようにオマンコを湿らせておいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「だから……っ、早く、一番深いところまでズブリと挿入してほしいっ……♪\n　……あっ♪　いつまでも素股状態なんて辛すぎる♪　んっ、はやくぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ください……♪　オチンポください♪　淫乱熟女アイドルのこのワタクシに\n、ご褒美のアツアツチンポ、ファンオチンポを恵んでくれ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッくぅうううう……♪　あああああっ、チンポ……♪　ぶっといオチンポが\nワタクシの中に、オマンコに……！　ありがたき幸せぇえ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んっ♪　んんんっ♪　なんだか、オチンポもいつもより太く逞しい気がする\nぅ……♪　はぁ、はぁ、貴方も待ちきれなかったというわけか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こんなにも素晴らしい名器を挿入していただいたのだ、ワタクシからも……\nあんっ♪　もう１つだけ、プレゼントが、ある……♪　んッんっんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……貴方の好きな母乳の薬。ボニューデマクールをガブ飲みしてきた。……\nそうだ。喉が渇いたので、水の代わりに。ゴクゴク飲んできたのだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「それから、どんどん乳首が敏感になってきている。カチコチに硬くなって、\n……あっ♪　も、もう、今にも破裂しそうなくらいに張りつめている♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あと一押しで母乳がぴゅーっと乳首からしたたり落ちるはずだ……。っんっ\n♪　さあ。貴方がワタクシの、母乳のスイッチを押してくれ。んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「スイッチ、はぁ♪　オマンコの一番奥ぅう……♪　子宮口だ♪　ココを……\n、あぅんんっ♪　そう！　そうだ、ココをぐりぐり突き上げて……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ほらっ♪　ほらぁあ……っ♪　もう母乳が滴りはじめているっ♪　あっ！　\nあっ♪　貴方はダークエルフを悦ばせる天才、だなっ♪　……んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシがチンポに感じさせられれば感じさせられるほど、に♪　母乳がぴ\nゅっぴゅっと溢れ出す、のだ♪　……あっ♪　どうだ、わかるだろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「気持ち……イイ♪　貴方にピストンされて♪　生でオマンコをオチンポで突\nき上げられて、気持ちイイ……っ♪　あひっ♪　ぴゅっぴゅっと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ぴゅるるっ、ぷぴゅるるっと母乳が出てくるっ……♪　んぁああ♪　こ、こ\nれだけでもすぐにイッて……達してしまいそうだが、更にっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こうっ♪　こうやって♪　ワタクシからも……甘えて腰を動かすと♪　ます\nます感度が向上していくっ♪　くぁああっ♪　頭が、胸が痺れるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はッ♪　はッ♪　突くのをやめず、に♪　ワタクシの腰使いを味わいながら\nっ♪　み、見ていて……くれっ、ああっ♪　あああ……イクぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ひぃいいいんっ♪　母乳がブシャアアッと♪　大量に撒きちらされたのが見\nえた、か♪　ああああっ！　まだだ、もっと出るっ、出るぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ああああああああッ♪　オチンポが子宮っ、子宮口を突くたびに♪　ワタク\nシの胸の先端から、ばびゅっ！　びゅぶぅっと甘いミルクが漏れるのだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぁああああっ♪　ああああッ、あああああ……っ♪　ずっと……こうした\nかったからっ、身体がバカになってしまっている、歓喜しすぎているっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「母乳も止まらない、腰も止めたくないぃ……♪　んんんぅっ♪　貴方も容赦\nなくワタクシの中を掻き回してくれっ♪　攻めて、モノにして……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁあああっ♪　それっ……♪　その動き、好きだ……♪　感じるぅ……！\n　欲しい、今のもっと欲しいっ！　好き……♪　好きだから、くださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方のチン、ポ♪　最強のオチンポで突いてっ♪　まだシャワーも浴びてい\nない、汗まみれのワタクシの身体♪　母乳まみれの胸もっ♪　はぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃに、して……♪　……ンンっ！？　あははっ♪　従順なワタク\nシの懇願に、オチンポが反応してくれたようだな♪　大きくなった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そう、か♪　貴方も一度、白濁液をぶちまけたくなったか……♪　それなら\n♪　このまま中に出してくれ、外ではダメだ、中に……中に欲しいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「中に出してぇ……っ♪　オマンコはとっくに受け入れモードに突入している\nっ♪　貴方の精子……ワタクシのオマンコにびゅるびゅる注いでほしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッはぁああああああぁっ♪　ああああっ！　あっあっあっ♪　イクッ……イ\nクっ♪　膣内射精で、オマンコの一番奥に種付けされてイクぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あっああああ♪　最高の褒美だ！　コレをもらうために……っ、ワタクシは\n厳しいレッスンにも耐え、若い娘たちと同じ踊りをし、歌を歌い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方に媚びて頑張ったのだ……♪　っはうっ♪　熱い……♪　すさまじく重\nい精液が♪　ドピュドピュとワタクシの赤子の部屋に注入されて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ん～～～～ッ♪　まだ抜かないで♪　逃がすものか……あぁあンンッ♪\n　精子出して、ずっと出して、出し続けて……あっあっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「く、ふ……♪　あああっ♪　す、すご……い……♪　オマンコにミッチリ詰\nまったオチンポから……いくらでも精液が放たれて、……んぷぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシの腹が膨らんでしまいそうなほど、大量の精液で満ち満ちている…\n…♪　クク、くふふふ♪　少しでも動けば逆流してしまいそうだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁああ……っ♪　本当ならば、ここで満足して休むのが普通なのだろうが\n……。足りない♪　こんなものではまだワタクシの飢えは満たされない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「このまま……♪　精液をたっぷりオマンコに溜め込んだままで、性交を……\nセックスを続けさせてもらおう。……貴方もイヤではないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「その証拠に……。あっ♪　ワタクシの中で、オチンポも賛成だと言ってくれ\nている……♪　あと少し、貪らせてもらおう。……いくぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ♪　あぁあっ……！　ンンンッ、はぁああ……♪　自分から腰を振り、\nチンポを粘膜で堪能しているワタクシを軽蔑しないで、くれぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あッ♪　んあああっ……ああっ♪　深く刺さるぅ……♪　んはぁあっ♪　出\nしたばかりの精液のヌルヌルが、オマンコの中に広がっていく……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「すべりが良くなると♪　二人が同時に気持ち良くなれて……ああっ♪　す、\n素晴らしいな……！　貴方も、一緒に腰を使ってくれ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんんっ♪　は、ぁっ♪　はぁっ、あああ……♪　ワタクシが心の底からっ\n……、身体の奥から喜びに満たされているのが、つ、伝わるか……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「アイドルとして見事に成果をおさめっ……♪　その姿を貴方に♪　一番見て\nほしい貴方に見てもらえた……そして褒美として抱いてもらえている♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「こんなに嬉しいことはないぞ……！　んんっ♪　せっかくだ、この幸福の絶\n頂で……あっ♪　貴方の子が欲しい、ワタクシに子種を注いでくれっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁああっ♪　オチンポもこんなに硬くなっているのだぁ、お堅い\nことを言わずともいいではないかぁ♪　欲しい、赤子が欲しいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「お前のママ、はっ♪　アイドルをやって、そのご褒美にお前を授かったのだ\nと……我が子に告げたいのだ♪　……フフ、嫌だと言ってももう遅い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「このまま……精液を絞り取らせてもらおう♪　んんっ♪　ど、どうだ♪　ダ\nンスレッスンで鍛えた腰使い……チンポに響くだろう……っ、ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「他の誰かではダメ、なのだ……♪　ワタクシは貴方に一番輝く姿を♪　っぁ\nっ♪　淫らな姿を見てほしい……♪　っぁっ♪　もっと、もっとだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「たくさんのニンゲンのために、ではなく……貴方だけのアイドルにしてくれ\nっ♪　ワタクシの全てを知り、オマンコまで独占していいのは貴方だけだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っんくぅううっ♪　突いて、突き上げてくれっ……♪　ワタクシもオマンコ\nを締めて、精一杯尽くすからっ……！　ああっ、こうか？　これでいいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「二人で気持ち良くなろう……♪　っぁっあっ♪　フフフ、敏感なオチンポが\nビクビクと痙攣している……♪　また種付けをしたくなったのか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「望むところだ……、子宮はすでに貴方の精子を待ちわびている……っ♪　あ\nっ♪　出して、出してくれ……！　ご褒美精子、何度でも欲しいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシが絶頂するタイミングに合わせて……貴方も子種を放ってくれ！　\nすぐだ、すぐにイクから……！　っああああっ♪　イクイクイクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「くふぅううううっ♪　んんんんッ♪　出ているぅっ、熱い子種がワタクシの\nオマンコを♪　アイドルオマンコを駆けあがってくるぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「あはははっ、貴方もよっぽど切羽詰まっていたのだなっ……♪　すっ、すご\nい勢いだ♪　熱くてドロドロの白濁液が、怒涛の勢いで流れこんでくるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんんんぁ♪　ワタクシはすっかり、この射精に……貴方のオチンポに、女\nの……メスの喜びを教えこまれてしまったぞぉ……っ♪　あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「責任をとって、どんっどん出すのだっ！　あっ♪　ああっ♪　モイライシス\nターズのクロートーに♪　種付けしていい男は一人だけ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「貴方の子種だけが、ワタクシのオマンコに、子宮に侵入することを許されて\nいるのだからっ……♪　権利を行使して、すかさず種付けするがいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッひゃんっ♪　まだ……まだ出ている♪　そんなにもか♪　そんなにワタク\nシのイキたてオマンコが心地いいか♪　可愛いやつだ……♪　っあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ふぅううう……♪　もう、これ以上は子宮にも入りきらないな……♪　優し\nい貴方、二度もワタクシのために精液を出してくれてありがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「い、いつもは照れくさくて声に出して言ったことはなかったかもしれないが\n……。ワタクシは、貴方にはいつも感謝しているのだ。本当だぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ワタクシがいつどんな姿になっても、応援し、支えてくれる……。熟れた肉\n体をもてあましていただけだったワタクシを、抱いて、愛してくれる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そんな貴方にふさわしいワタクシになれるよう、これからも頑張りたい。だ\nから一番近くで……見つめていてほしい。これからも、ずっと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　こ、こらぁ……っ！　貴方というヒトはぁっ……！　ワタク\nシが中に、オマンコに射精を欲していると知りながらぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「いじ、わるぅ……っ♪　イジワルだっ……！　それなのに、……んくっ♪　\n身体にこうしてかけられるのも……精を浴びるのも気持ちいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「ッあぁ……♪　はぁあああっ……♪　いつもと違う姿の……アイドル姿のワ\nタクシに、精液をぶちまけてみたかったのか……？　悪趣味な……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「そんなことをしなくとも、ワタクシはすでに貴方の色に染まっているという\nのに……！　あっ♪　そんなにかけるなぁ♪　熱い、臭いぃいっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　あっ……衣装に貴方の臭いが染みつく……♪　どうせなら、\n二度と着られなくなるくらいにかけてくれ、貴方専用の衣装にして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「っあうっ……♪　うぅ……♪　精液というものは、本当にどこまで飛ぶかわ\nからなくて刺激的だ……。これだけ出せば満足かぁ……？　あんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00019403_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……ふー……♪　スッキリとした顔をして……。その顔をされると、ワタク\nシはもう何も言えなくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「確かに衣装はもう使えなくなってしまっただろうが、気にすることはない。\nアイドルになったのは全て、貴方だけのためだ。その目的を達した今」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「これから全世界に飛び立とう、だなんて大それたことは考えていない。……\nうむ。見て欲しい人に見てもらえた。褒めてもらえた。それで充分だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……が、たまには……その。プライベートで。貴方の前でだけ、これを着る\nこともあるかもしれんな。その時は……な♪　また、褒めてほしい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}