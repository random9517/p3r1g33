	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いやだぁ～！　研究資金は絶対に渡さないぞぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113240001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あ！　また逃げたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113240001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったく！　いいかげんにあきらめろっての！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、俺たちがまたＤｒ.サイレーンを追いかけようとしたときだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「たぁ～～～まぁ～～～おおおおおおおお～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「放すである、放すであるぅ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113240001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "激怒した修羅姫が、ハルカプトラを引きずったままこちらに走ってくる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「珠魚のバカはどこだぁあああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「修羅姫殿、あそこのようですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113240001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とジュンジローが、逃げていくサイレーンを鼻先で示す。さてはこいつが修羅\n姫に密告したな……？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「うおおおおおおおおおおおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "修羅姫はすごい勢いで、逃げるサイレーンを追っていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「げっ！　修羅姫！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113240002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「珠魚！　いや、Ｄｒ.サイレーン！　貴様いったい、学園内でなにをやって\nいるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240004" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「い、いや！　あれはだね！　学生たちに喜んでもらって、それと同時にボク\nも研究資金を稼ごうという、いわばウィンウィンの――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113240003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「学園内で、妙な商売をはじめるんじゃなぁあああああーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240005" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいいいいいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113240004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "修羅姫の特大のカミナリが、Ｄｒ.サイレーンの頭上に落ちた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うわぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113240002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「すっげえ迫力…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113240001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、呆然とその様子を見ていた俺たちにも――", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様たちも、学園にゲームなど持ち込んでるんじゃなぁあああああーいっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240006" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001302_01", "4", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00000401_01", "4", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「今日からカードゲームは、持ち込み禁止ーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113240007" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちの頭上にも、修羅姫のカミナリは平等に落ちるのだった……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、さんざん明日楽に説教をくらい、寮へと戻る途中。俺はたいへんなこ\nとに気づいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんですかな、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113240002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういえば今回俺たち、襲来者（インベーダー）と戦ってなくね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんか学園内で、カードゲームをめぐってワチャワチャやってただけだぞ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほっほっほ、なにをいまさらですぞ。襲来者（インベーダー）と戦っていな\nい回など、すでに何度もあるではありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113240003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうだっけ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さよう、気にするようなことでもありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113240004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか、そんならまあ……って、それでいいのか！？　本当に！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんか、だんだん学園コメディになじんできてしまう自分が怖い……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

