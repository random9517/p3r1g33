{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……なあ。なあ、暇なんだけど。何もすることないなら帰ってもいいか？　\nつ、つまんないし……。なんだよ、せっかく来てやったのに、さ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぁ？　わ、わたしはおまえと違って忙しいし……。ってか、わざわざ？　\nよわよわのおまえのためにここにいるのに、面白いこと全然ないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……はぁ。もう帰る。……ナマイキ？　ふんっ、し、知らない……。かまっ\nてくんないおまえが悪いし。１００％間違いないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なんだよ！　今更何言ったってもー遅いから！　帰る帰る帰る！　遊ばない\n！　……なんだよ。急にわたしを睨んできて……。うぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「び、びっくりした……。……フーン……そーゆーことか。エッチなことがし\nたかったって、こと？　はー……そーなんだ、なるほどでーす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020901_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「し、したいならすればいいじゃん……。わたしは協力しないけど、勝手に盛\nり上がって、勝手にオチンポして射精してハイ終わり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「それでいいでしょ？　だ、大丈夫だし……。わたしの身体は丈夫だし、おま\nえなんかに何されたって少しも感じるわけないし。無意味だし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「どーせすぐに、ぴゅっぴゅってして終わり……でしょ。つまんない。……っ\nて、うぁっ？　な、なん……だよ、そのチンポ……で、デカ……い！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぐっ！？　あぐぅううっ！？　うあああああっ！？　い、いきなりっ……\nいきなりオマンコに突き刺すバカがいるかぁっ！　うあっ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ぬ、抜けぇ……抜け、ぇ……っ！　ふ、太い……っ、えぐれるぅ！　そ、そ\nれにほぐしたり濡らしたりもしてないのに……突然挿入すると、か、ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ひ、卑怯すぎる、し……っ！　あっ……！　や、ヤバイ……っ。お腹の中ギ\nッチギチに入っちゃって、る……。あううっ、し、信じられないぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「種付けプレス……？　こ、この体勢、そう呼ぶのか？　ナマイキで反抗的な\nメスガキにわからせ種付けプレス？　な、何言ってるかわかんないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ば、ばっかじゃん！　こんな無理やりで……、はぐぅうっ！　あふっ、チ、\nチンポずぶーって突っ込んだだけで、……あうっ！　感じるわけないじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あうっ！　感じ……ない……。あっ！？　か、かんじ、てない……っ！　は\nぁ、はぁ……なんでこんな奥までねじりこんで……。あ、ぅ、うぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「っていうかエッチ自体はしてもいいって許可出したのに……なんっで優しく\nじゃなくて、わからせ種付けプレスとかいうアブナいプレイなんだ、よぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぁっ……ふぁああっ！　こ、心の準備とかぜんっぜん出来てなかったから\n……超びっくりした、し……！　わたしじゃなかったら壊れてるしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ♪　だ、だからわたしにはしても平気、だけど……！　んぁああっ！　\nえ？　え？　だんだん腰を速く動かしてる……？　や、やめろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「こういうのはいいって言ってない！　うぎゅっ！　重いぃ……！　体重かけ\nるなぁあ！　体重っ、チンポに乗せてぐちゅっ、どちゅって突かれる、と！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえの身体の重さ分チンポが奥までめりこむんだよぉおおっ！　あぁっ！\n　やだ、やだやだ！　愛のないわからせプレスやだ、強すぎるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「っはひっ！　ひぁああっ、ううっ、あふっ、ううっ、うぁあああ……！　男\nの全力で、全体重でチンポ突っ込んできやがってぇえええ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「くる、しい……！　オマンコミシミシいってるってぇっ！　あっ！　あっ、\n速いから！　腰っ、揺らしすぎ……リズムのりすぎぃっ！　あうっううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わ、わたしのマンコで遊ぶなぁ！　一人でハァハァするなぁっ、んぁあああ\n……！！　ズル、いぞ一人だけよくなってぇ！　あっ、チ、チンポぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「チンポで奥ぅ……奥を刺激するなぁ！　そん、なとこ……っ！　自分の手で\nも触ったことないとこなのに！　あっ、深いとこドチュドチュやめろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あひっ、んひっ、ひぃいっ！　ぐちゅぐちゅぐちゅぐちゅっ！　速いぃ……\n！　あっ！　あっあっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「え？　え、なに？　なんだ？　この感覚っ……お、おしっこ漏らしそうな…\n…ヘンな感覚！　膀胱……じゃない、おまんこ全体が疼いて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ！？　ウズウズする、モジモジするっ！　ま、待てよぉ！　これっ、漏\nらす……なんか来てる、じゅわって来てる、無理、むりぃ、むり～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ！？　し、刺激するな……イジワルするなぁ！　ひぃっ！　ズンッズン\n突かれたら……！　ああっ、出る、出ちゃう、イ……くぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　ああああああッ……ふぁああああ……！　ぷっしゃあああって\n、ぶしゃああって出ちゃってる、お水っ、お股から出ちゃってるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ち、違うからな！　おしっこじゃない、から……！　イッて身体が、マンコ\nがヘンになってそれで……！　ふぁっ♪　ま、まだ溢れてくるぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ……！　み、見ないで……！　見るなぁああっ……！　んぁああ\nあっ、は、恥ずかしいよぉ……！　あーっ、あああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「イキ、ながら透明なお潮噴いちゃって……はぁ、はぁ、それが恥ずかしくて\nまたイッ……♪　イッちゃって……！　やだやだぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「っん……っ。や、やっと終わったぁ……。ゆ、許さないからな、こんな恥ず\nかしい目に合わせて……って、んん！　エッチ続けるのやめろぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「イッたから！　もう何回も何回もイッたからやめてくれよぉ……！　あっ！\n？　うぁああっ、やだやだ、これ以上ズコズコされたら、あ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ホントにおかしくなるからぁ……！　んぁああっ！　わ、わたしがイッたの\nなんかおまえにもわかっただろ！？　つ、つながってるんだからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「チンポの方に伝わってるは、ず、じゃないか！　なのになんでズブズブやめ\nてくんないんだああ！　あっ！　あっ、やめっ、だめ、だめだぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あうううう！？　な……？　今ドクッ、ドクッて……おまんこでなんか出て\nる……。あっ！？　精子か！？　これっ……あっあっ、なんで、なんでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ゴムとかなんもしてないで入れてんのに、精子……！　精液出したらニンシ\nンしちゃうだろ！？　やっ……止めろぉ、それ以上出すなぁあああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あ～～～～～～っ！　出てる、出てる、出てるぅううう！　んひぃいっ！　\nグリグリぃってマンコの奥こじあけられて、そん中に出されてるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ……あふ、あっついぃ……！　赤ちゃん、赤ちゃんできちゃうぅ……！\n　んぐぅっ！　びゅるっ、びゅるるってずっと出て……！　あっふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「頭が……ボーッとするぅ……。うぐ……。これが、種付けプレス……？　乱\n暴すぎる、上から押さえつけられてオチンコ抜けない、し……うう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁああ……っ。わ、わかった……もうわかったぁ……。\nおまえのチンポがすごいのは、よーく、わかった……これでいいだろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「潮をお漏らしまでさせられて……わたしのプライドは傷ついた！　めちゃく\nちゃだぁ！　ぐすっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……ん？　な、なんだよぉ……。たっぷり好きなだけ中出しキメただろぉ！\n　早くチンポ抜けよぉ、精液ついてるからマンコ洗わないと……。ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「は、ぁうううううっ！？　な、なんでなんでなんで！？　なんっ……あうっ\n！？　なんでチンポ、またデッカくなって……！　あっあっあうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ゴリゴリッ……ゴリゴリしてりゅっ……！　うあああ……！　精子まみれの\nマンコ、容赦なくズップズプかきまわされて、りゅ、ウソだああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「さっき出したのに、あんなに出したのに……！　あああっ、わた、わたしが\n気を抜いた瞬間狙ってぇ……またチンポ動かすなんて！　っはぅぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ……！　あぁッ！　も、もぉお股がお潮と精子でぬちゃぬちゃなのに…\n…ぃっ！　拭く暇もなくぐちょぐちょするなんて……うううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「うぁっ♪　その、上からプレスしてくる動き、ヤ、ヤバいぃ……！　うくぅ\nううっ♪　ズンッ、ズンッて一番奥に刺さって、苦しいのに……んぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なんか、すごく気持ちいいよぉお……！　あふっ！　それっ！　そのズンズ\nンッ！　それされると頭、真っ白になって勝手に腰が動いちゃうよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あふっ、ふぅっ……うううっ♪　うう……！　くるしいのに……、息、でき\nないのに……！　上からぐちゅっ、ぐちゅって貫かれる、と……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なんでぇ！？　気持ちいいっ……気持ちいいよぉ！　あああっ！　足だって\n無理やり広げられてる、のに！　チンポ全力でねじこまれてるのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「それが……気持ちいいの！　あぁあああ♪　ヒドくしてぇ♪　わたしが潰れ\nちゃうくらいむちゃくちゃにして！　いっぱいいっぱいチンポ入れてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あ～～っ♪　あっあっ♪　すぐイッちゃうよぉっ♪　あっ♪　おっ♪　おぉ\nっ♪　おぉ～～～っ♪　んぁあっ！　ヒドいこともっとしてほしいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「もっとぉ♪　もっと体重かけて！　チンポ一番奥まで突き入れてっ！　あっ\n♪　そう♪　それされるとマンコがビクビク痙攣しちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「気持ちっ♪　よすぎてっ♪　ああああ、お尻くねらせちゃうよぉお♪　すっ\nごくイイっ……！　オマンコからぶぴゅぶぴゅお汁溢れるぅっ♪　あうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　イキそうっ……！　あっ♪　乱暴にされてイクなんてやだ♪　\nやだけど……っ、あぁっ！　か、身体が勝手に反応して……！　あうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「イ……くぅ！　あ～～～～っ♪　オチンポ、チンポ気持ちいいっ！　ちょう\nだい、奥に……♪　ふぁああっ♪　またイクぅ……！　あぁあッうう～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　イクぅっ！　もうやだぁ！　イクッ……ずっとイッてるよぉ\n！　ねえっ……おまえも、おまえもわたしと一緒にイッてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「た、たねづけぇ……♪　種付けプレスしちゃっていいからぁ♪　赤ちゃんで\nきちゃってもいいから、出して……出してっ、マンコに出してぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「欲しいんだよぉ♪　おまえの精液……っ！　オマンコでゴクゴク飲み干して\nやるからっ……。なっ♪　なっ、ちょーだいぃ♪　お願いぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はうっ！？　はぁううううううう♪　最高っ……さいこぉおおお……♪　出\nてる、出てる……わたしの中に、マンコにびゅっびゅ入ってきてゆぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んーっ♪　んっ、ん～っ♪　お、おいひぃ……♪　気持ちいぃい……♪　あ\nんっ、あんっ♪　もっと……もっとちょうだいぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ♪　……わ、わかるぅ？　オマンコぎゅーって締めて、絞って\nぇ……おまえのチンポから精液ねこそぎ奪い取ってるよぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「一滴だってこぼしたりしないぃ……♪　はぁっ、はぁ、はぁ……！　ねえ、\nこれで終わりかぁ？　んっ♪　あははっ、まだ出た、出た出たぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「びゅーっびゅーっびゅーっ♪　ふぁあああ♪　あ、ありが……と♪　二回目\nなのにこんなに出してくれて……めちゃくちゃ嬉しいよぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　ふぁあああ……大満足ぅ……♪　でも、腰も足もガクガクで\nぇ……当分一人で立てないかもぉ……♪　あっ……あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「えへへへぇ……♪　これが、おまえの種付けわからせプレスってやつかぁ…\n…。最初はびっくりしたけど、すごく気持ち良かったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　わたしはいつだって最強、だったから……誰かにこんな\n風にめちゃくちゃにされたのは初めてだ。おまえは、スゴイな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「絶対無理やり犯されるのなんかやだって思ってたけど、どんどん気持ち良く\nなって……夢中になって、腰を振ってイッてしまった……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わたし、もしかして……Mってやつ、なのかもしれない……。本当はどうな\nのか、また……おまえに強引に教えてもらいたいな……♪　へへ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「やったぁ♪　精子精子～！　って……うぁっ！？　チンポっ……チンポ抜い\nて何する気だよぉ！　やだ～～！　っんうっ！？　ううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「お、お腹ぁ！？　それにわたしの胸……！　ええっ！？　そんなとこにびゅ\nるびゅるしたって意味ないじゃんっ……戻して、マンコで出してよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ！　う、うそだぁ！　ごほーび！　わたしのマンコのための精\n液が、外で出ちゃったぁあ……！　あっ！　あっ、こ、これはこれで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あったかくって、エッチなニオイして、いいけど……だけど！　ううっ……\nオマンコにどぴゅどぴゅしてもらえると思ってたのに……ひどいよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んひゃっ！？　ひゃぁううっ！　も、もうかけないってばぁ……！　あっ、\nあっ、か、身体が真っ白になってく……。くさいよぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ん、んぁあああ……。わたし、おまえの精液の色に染められ、ちゃった……\n。ナマイキにしてたから、中に出してくれなかったんだよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あぁあ……こんなにいっぱい出してくれたのに……。うう……ご、ごめんな\nさ……い。この量をマンコで受け止められてたら、絶対……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「気持ち良すぎて失神しちゃってたかも……。はぁ、はぁ……。ヌルヌルして\nる……。これがおまえの赤ちゃんの種、なんだな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「この汁とわたしの卵が合体したら、ニ、ニンシンするんだって思うと……オ\nマンコがキュンッて疼いて、身体が熱くなってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「こ、今度する時はちゃんと中に出してもらえるように……えっと。な、ナマ\nイキな態度……改められたらいいな。が、がんばるね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
