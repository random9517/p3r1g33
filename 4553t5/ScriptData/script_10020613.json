{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「くくく……実に面白い結果になったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「並行世界の接点、まさかこんな形で確認できるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、なにやってんだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「おや。この度は実験に付き合っていただき感謝しますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「その実験が大がかりすぎるって話だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「よかったでしょう？　思い出の味を堪能できて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680004" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、そりゃね。だけどあんまり派手に動くんじゃないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの存在は、まだバラすわけにはいかないんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「奇策も策のうち。ときに大胆に、最前線へ突撃するのも策なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうかいそうかい。だけどセレーナなんか、鼻が利くから勘づかれてるかも\nしれないよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680005" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「心配無用です。気づきやしませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680006" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの知ってるセレーナは、そんな細かい変化には気づきやしませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それはあんたのいた次元のセレーナだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680006" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「まあ、そうですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680008" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの次元のことは詳しく知らないけど、あまりこっちの次元を舐めてる\nと痛い目見るよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680007" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、そうやって自爆する方が『オボロ』らしいかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680008" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「……忠告、ありがたく受け取っておきますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680009" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ところで、差し入れを持ってきたんだけど食べるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680009" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「そうですね。ちょうどお腹が空いてきたところですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680010" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それじゃ、どうぞおあがりよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680010" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「これはパンケーキ？　いただきます……もぐ、もぐもぐ……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680011" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……どうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680011" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「な……なんですかこれは……っ！　生地がオレンジ色だと思ったら、ニンジ\nンがぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680012" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「グルメコンテスト以来、うちの姫様が料理にご執心でね。ちょっといろいろ\n教えてやったのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680012" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……って、どうしたんだい？　目に涙なんか浮かべちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680013" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もしかしてアナザーのあんたもニンジンが大好物なのかい？　泣くほど好き\nだとは思わなかったけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「そ、そういうことにしておいてください！　くっ、ニンジンパンケーキなん\nかで……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680013" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「このニンジンパンケーキ、ウチの記憶にある味とまったく一緒じゃないです\nか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「やはり、並行世界の同じ存在というだけあります。作る料理が同じ味になる\nなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「泣くほど喜んでくれるなら、これから毎日差し入れてやろうか？　そのパン\nケーキ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113680015" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・オボロ" ]},
		{"command":[ "SETTEXT", "「け、結構です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090113680016" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}