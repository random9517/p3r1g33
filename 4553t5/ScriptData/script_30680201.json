{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あ、あの……隊長、これはいったい……どういうことでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ええ、パワーアップのためというのは聞きました。そのために胸で奉仕しろ\nとも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「それは了承しましたが……いえ、すべて納得したわけではありませんけど…\n…今はいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「なにが不満って……わざわざ説明が必要ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ご奉仕がしやすいからと、水着に着替えるのもいいでしょう……ただ、やる\nならもっと普通にすればいいのではないでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「私もそこまで詳しいわけではありませんが……胸で奉仕って……こう、谷間\nに挟むものでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「なぜ、そんなところに……挿入して……んっ……う、動かさないでください\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「これがいいんですか？　本当ですか……？　隊長のご希望でしたら、いいで\nすけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あの……本当にみなさん、こんな感じで……奉仕をしてるんですか？　私だ\nけ……変じゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「いえ……本当に必要なのでしたら……もちろん協力したいとは、思っていま\nすが……ただ、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「嫌というわけではありませんが……なんだか、変態的というか……もっと常\n識的なやり方があるのではと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「それでは効果がない？　そう、ですか……わかりました。私はどうすればい\nいでしょうか……このままジッとしていればいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はい、では……隊長の好きなようにお使いください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「……んっ、んっ！　ふぅっ……く、訓練の一環と思えば、これくらいの羞恥\n……耐えてみせます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……んっ……擦れてる……胸と、隊長の……ち、ちんぽ……が…\n…あふっ……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「し、下乳……ですか？　なんだか、卑猥な言い方ですね……ううっ、下乳と\nちんぽが……ずりずり擦れてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「どうって、言われても……困ります……その……まずは熱いです……それに\nとっても硬いです……ちんぽ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ゴツゴツしてて、胸と……えっと、下乳と擦れて……変な感じ、です……と\nっても恥ずかしいことをしているような気分にはなります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「隊長は、こんなことで……本当に感じるんですか？　ちゃんとパワーアップ\n……できますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はあ……順調だから、心配はいらない……ですか……それなら、一応安心し\nました……続けてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「んっ……！　あっ、ふっ……ふぅ……んんっ……うぅ、ちんぽが……出たり\n、入ったり……してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「しかも横向きに……なんか、変な眺め……です……あふっ……んぁっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「さっきから、思ってましたけど……ちんぽが、どんどん大きくなってるよう\nな……やっぱりそうですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「感じてる証拠ですか？　隊長がいいなら……いいですけど……あっ、ンっ…\n…大きさだけじゃなくて、硬くなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はい、わかります……肌で感じて……ちんぽが気持ちいいって言ってるみた\nいで……あんっ！　い、今ビクンって……震えました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あっ……あっうっ……そんなに強く腰を振って、大丈夫ですか……ん\nんっ！　強く擦れて……あ、熱い、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「くっふうっ、くぅうっ……んんっ……ますます硬くなって、お、おっぱいが\n……揺れて……あふぅ、あっうぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……なんか、ぬるぬるしてきました……が、我慢汁、ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「やはり……ンっ……そう、ですか……ということは、もうすぐ射精しそう…\n…ということですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「本当に……こ、こんな行為で快感を……いえ、悪いとは言ってません……は\nい、これは必要なことですから……承知してます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……し、射精、しそう……ですか？　いいですよ……もちろん\nです……あっ、あうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「は、はい？　このまま下乳……に？　隊長がしたいなら、べつにかまいませ\nんが……とことんマニアックですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あんっ！　んっあっ！　はっ、激しいっ……！　うっ、うぅんっ……あっ、\nあふっ……ちんぽ、すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「お、おっぱい……じゃなくて、下乳が……犯されてる……んっ、んあっ！　\nはっ、あぁぁっ……んっんんんぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっあっ、あぁぁぁぁっ！　あんっ、あっあふぅっ！　ひぃあっ……ああぁ\nぁぁぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「出てるっ……！　おっぱいの下で、チンポが……ドクドク脈打ってますっ…\n…！　ンンっ、あっ……はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひぅっ……んっはぁ……あ、あぁ……たくさん出てる……精液が、いっぱい\n……はっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「こんなに射精って……続くものなんですか？　私の水着がエロかったから、\n普段より興奮した……そ、そう……ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「嬉しいような……恥ずかしいような……うう、複雑です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「お、お礼だなんて……急にどうしたんですか？　いえ、満足していただけて\n、よかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はひっ！？　えっ、ええっ？　どうして、また腰を動かして……あんっ！　\nお、終わったんじゃ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「全然満足はしてない？　そうなんですか？　あっ、あうっ……もっと私のお\nっぱいを味わいたい……と、言われてもぉ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「いいです、けど……こんなに連続で……するなんて、可能なんですか……あ\nっ、あふっ……射精したら、一度落ち着くのでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「そうですね、隊長のちんぽは硬くて大きいままですが……んっ、ああっ……\nど、どうしてこんな……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「わ、私のおっぱいが魅力的だからに決まってる？　あ、あうっ……そんなっ\n……さっきのはお世辞ではなくて……本気で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ンっ、あぁっ……すみません、隊長を疑っていたわけではなくて……自分が\nエロいって、ピンとこなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「うぅ、そんなにエロい、エロいって言わないでください……あうっ……恥ず\nかしいです……んっ、あぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「そんなに勢いよく擦ったら……は、肌が熱くて……んっ、あぁっ……ひゃう\nう……あ、あつ、いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「こ、声、出て……うっ、んんっ……だって、こんな激しく、おっぱいに擦り\nつけられたら……声、出ちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！　んっ、あっあぁ……いやぁ……ちんぽで、おっぱい……タップ\nしないでぇ……恥ずかしい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長……さっきから、息荒いですよ……興奮しすぎです……あっ、あん\nっ！　こ、腰……すごいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、ううっ……気持ちいい、から仕方ないって……そんなぁ……あっ、あ\nうっ……おっぱいも熱いっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ、イヤらしいです……お、おっぱいの下から、亀頭が……飛び出たり\n、引っ込んだりして……あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「さっき出した精液が、泡立ってきて……んっ、ますますヌルヌルしてます…\n…これが、気持ちいいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「た、確かに匂いも……キツくて……むせ返りそうです……ううっ、はっ……\nあふっ、くふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ま、またちんぽが震えてますけど……ふぅ、んっ……出そう\nだったりしますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「そう、ですか……やはり……んっ、んふぅっ……あぁ、ううっ……は、激し\nいっ……ま、またイクんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はい、いいですよ……いつでも、隊長の好きなように……射精してください\n……私の下乳をお使いくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　んっ……ちんぽ、硬いっ！　んんっ、ンっはっ……あっ、\nあふっ……くっ、ううっ……んはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「だ、出して！　私のおっぱいに……あっ、うっ……しゃ、射精っ……いっぱ\nい出してくださいっ！　んっ、ンンぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はううっ！　んっ、ひぅっ！　あっ、んっあぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「んっ！　ま、また……おっぱいの下で……ちんぽがビクビクいってるっ……\nひぃうっ、あっあっ……あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ！　さっき出したばかりなのに……んんぅっ！　あぁっ……せ\n、精液……いっぱい、いっぱい出てるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ふぅっ、あふうっ……あ、あつ……いぃ……あぅうっ……どうして、こんな\nに熱くて……匂いもすごくてぇ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ふぅっ……はぁ、はぁあっ……あん……ま、まだ出てます……こんな\nに射精って、続く……んですね……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はっ、はぁ……これで終わり、ですか……？　ううっ……下乳が、\n精液でドロドロですよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「でも、これでパワーアップできたんですよね……よかった、それを聞いて安\n心しました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「え？　これからも定期的に……ですか？　い、いえ……嫌というわけでは…\n…隊長の命令なら、もちろん従います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「その時も水着で……？　はあ、わかりました……ずいぶん気に入ったんです\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「うぅ、照れるので……エロいとか、可愛いとか……そんなに言わないでくだ\nさい……ちゃんとご奉仕はしますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「きゃあっ！　い、いきなり……なんですか！　んっ……あっ、あひっ！　ひ\nぃいっぃぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃあっ！　あっ、あふっ！　おっぱいにかかって……！　あんっ……な、\nななっ……なんでっ……！　ひゃぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あ、あぁっ、熱いっ……！　ひっあっ……あふぅっ！　精液が……いっぱい\n飛び散って……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……びちゃびちゃって……んっ、あぁっ……おっぱいに、へばりつ\nいてる……あんっ……くはぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ！　さ、さっきも……いっぱい出してたのに……またこんなに\n……ンっ、んはぁっ……ひぃううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁっ……に、匂い、すごいです……んんっ……オス臭くて\n……ここまで匂ってきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……どうして射精するとき、おっぱいから抜いたんですか……？　その\n方が興奮するから……？　そう、ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「いえ、隊長が満足したなら、それでいいです。えっと……パワーアップもち\nゃんとしてますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「お役に立てたようで、よかったです。えっ？　これからも付き合ってもらう\nって……え、ええっ？　またするんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「しかも水着で……って……うぅ、恥ずかしいですけど……隊長のためなら、\n頑張ります……」", "NORMAL" ]},
