{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0171" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゃじゃーん！　さあ、どうかしら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330001" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……こいつは、また……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょうど３着あったし、サイズもピッタリだったんだよな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「みなさんとお揃いで、私も嬉しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「学園祭の時にも使ったメイド服のアレンジなんだって！　いくつかあったけ\nど、色をチョコに合わせてみたわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330002" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「本当にとても可愛らしい仕立てでございますな。よくお似合いですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます……少しだけ、恥ずかしいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、よく似合ってるぜ。自信を持っていい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あ……は、はいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふーん、マーガレットちゃん達は元の素材がいいから何を着ても似合うで\nしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330003" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分で言うな。せっかく似合ってても褒める気がなくなるだろうが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「もー、素直じゃないのね。そういうのは女の子に嫌われるわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330004" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうだぞ、お前はもう少し女心を勉強した方がいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まかり間違っても、お前たち２人には言われたくないけどな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「私、こういう服を着るのは初めてなので……何だかとても新鮮な気分です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330004" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こーいうのは、なんでもやってみるものよ！　女は度胸ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330005" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330005" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょっと足元がスーッとするのがヘンな感じだな。ま、思ったよりは動きや\nすいからいいけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一応スカートなんだからな、あんまりおおっぴらに足を上げんなよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「分かってるよ、覗こうとすんなよ、スケベ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330004" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「覗かねーよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さっ、衣装はＯＫ。調理場も貸してもらえたし、後はこのチョコと私達の力\nで最強のバレンタインを作るのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330007" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いよっしゃー！　私の『王王棒』を最強にするんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330005" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「チョコと武器の掛け合わせ……未知の体験、全力でやらせていただきます！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330006" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「よっし、気合い入れていくわよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330008" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「気合なら任せとけっ、うりゃーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330006" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「お二人には負けていられませんっ！　精一杯の力でっ……えーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330007" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……およそ、チョコを作るって体の掛け声じゃねぇんだよな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、止めなくていいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こうなったら全力で突っ走らせて、早く終わらせよう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「てぇぇぇーいっ！　えいえいえい、えーーーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330009" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかし、これでは食品を作っていると言うより、工事現場か、道場といった\n雰囲気ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022330004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言わなくていい！　こうなったら、なるようになれだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「せめて、爆発だけはしないで欲しいと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022330005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「流々那、そっちよろしく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330007" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はいっ、マーガレットさん、これお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330008" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オーライ！　任せといてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330010" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なんだかんだで息はあってるのかね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「完成だわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330011" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、出来ましたね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330009" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「出来たのか……果たして、一体どんなものが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「見ろっ、カツマ！　これが私達のがんばりの成果だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330008" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは……棒の先に……チョコ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そうだっ。私の『王王棒』にチョコレートがつけられて、パワーアップ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「その名もずばりっ、『王王衝棒（わんわんつけぼー）』だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待てっ、その名前は色々とヤバくないか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0171" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅーっ、溢れるパワーを抑えきれないっ！　このまま変身だっ……う\nぉぉぉぉぉーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030022330011" ]},
		{"command":[ "SETCHARA", "0", "char_00000409_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こっちでも、姿が変わった！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ……よく分かんないけど、体の内側からパワーが溢れて来てしょうがな\nいぞっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010022330001" ]},
		{"command":[ "SETCHARA", "0", "char_00000409_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「確かに……すごいエネルギーを感じます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330010" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぉぉぉっ、この有り余る力をどうすればいいんだぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010022330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000409_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今こそバレンタインの仕上げよ！　そのチョコを使って気になる男性に思い\nをぶつけるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330012" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！　なんで最後の最後でバレンタインの帳尻が合って来るんだ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「バレンタインってそういうものなんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330013" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、それはそうって……だからって武器は違うっ、待て、早まるな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「カツマぁぁぁっ、うけとれぇぇぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010022330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000409_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉぎゃぁぁぁぁぁぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、カツマさんがすごい勢いで飛んで行きます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130022330011" ]},
		{"command":[ "SETCHARA", "0", "char_00000120_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「パワーアップの効果はばつぐんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020022330014" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「想いのたっぷりこもった手作りチョコを受け止める……しかと見届けまし\nたぞ、ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022330006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}