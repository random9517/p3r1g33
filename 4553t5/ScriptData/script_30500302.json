	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「隊長。急に呼び出して申し訳ありません。本日の任務、全て完了いたしまし\nたのでご報告します。……それで、提案なのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私、少々……身体を持て余しておりまして。よろしければですが、この火照\nりを鎮めに海に浸かろうと思うのです。ご一緒にいかがですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……そうですか、ありがとうございます。では、誘った者の務めとして、さ\nっそくサンオイルを身体に塗らせていただきます。……なにか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00005003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私が献身的でおかしい？　戯言を……。私はいつも上司思いで、献身的です\n。馬鹿なことを言っていないでそこに横になってください。いいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「このオイルは一度塗れば、一日はもつ高品質のものです。身体を硬くしない\nでください。ゆっくり塗っていきますから……。手のひらであたためて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00005003_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こうやって……少しずつ肌に塗布します。ぬり、ぬり、ぬり……首元や耳の\n裏、脇の下まで徹底的に……。ぬり、ぬり、ぬり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いっそのこと、私の身体全体で塗った方が早いかもしれませんね。……ん…\n…どう、ですか？　きちんと塗れていますでしょうか……。は、ぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「積極的で怖い？　そうですね、この気温、この環境です。私も多少浮かれて\nいるのかもしれません。水着で肌を晒している興奮もありますし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そこにちょうどいい獲物が、鴨がネギをしょった状態でやってきたと思えば\n、高揚するのも当然かと。……あら。抵抗するおつもりですか？　でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……隊長のここは、股間はそうは言っていないようですよ。さきほどから、\n健気に存在を主張しています。触れて欲しそうに、苦しそうに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「はちきれそうになりながらも、自分からはしたいと言わない……。強情です\nね。それとも、この後の展開を楽しみに黙っているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「であれば、私が楽にしてあげましょう。同意は求めませんよ、どうせあなた\nはそうして欲しいに決まっています。……入れますね。……ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ほぉら……♪　おとなしく、ズップリ入ってきましたよ。フフ、したかった\nんですよね？　こんなところで。誰に見つかるかもしれないというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「皆が無邪気に遊んでいる浜辺のすぐそばで、優しくオマンコにこのチンポ…\n…。期待してガチガチに勃起したペニスを挿入したかったのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私はただ……。あっ♪　あなたのことを思って、善意でオイルを塗っていた\nだけだったのに……。男性器を大きくして、交尾のことを想像したとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「本当に、発情しっぱなしの猿ですね。いえ、褒めているんですよ。いつでも\nどこでもセックス可能になってしまう、このどうしようもない変態肉棒」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「これを……。ッふ……うう♪　トロトロに濡れそぼった蜜壺でご馳走になる\nのが、私の何より好きなシチュエーションなのです。変態で良かったですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「普通……。っふっ……♪　外でこんなにも、肉棒を太くし、反り返らせる人\nはいませんよ？　あなたは人一倍性欲に溢れ、それを持て余して、いるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いつだって女のねっとりと柔らかなオマンコに、肥大化した男根をブチこむ\nこと、ねじりこむことばかり考えている……。破廉恥な男なのですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そんな危険な男は、……ぁっ……♪　私が支配して、手なずけて、こうして\n身動きがとれないっ、ようにっ、捕まえておかなければなりま……せんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ヒーロー活動で鍛え上げたキツいオマンコで♪　グチュグチュと締めつけて\n……有り余る肉欲をすぐさま発散させてあげないといけませんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「っぁっ……あっあっ♪　あっぁッ、あっ……♪　隊長？　どうかしました、\nか？まだセックスははじまったばかりではありませんか。あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私のオマンコが濡れすぎていて、心地よくてすぐに出したくなってしまった\n？　まあ……お褒めの言葉は嬉しいですが、すぐにはイかせませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「腰をくねらせ、アソコでずっぷりとオチンポを咥えこんだまま、リズミカル\nにお尻を揺らす……♪　あなたの好きな動きは覚えています、から♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「その通りに動いているだけです。……あぁ……♪　おいしい♪　気持ちいい\n……。ん？　どうしてイくことができないのか、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「単純な事ですよ……。んっ♪　あなたがイこう、出そうとするタイミングで\n膣内を締めているんです。射精を導こうとするペニスの根元、を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こうしてぎゅぅうっと……！　はぁっ、あぁ……♪　ギチギチと輸精管ごと\n締めつけて、精液発射できないようにしています、から……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……んふ、苦しいですよね？　辛いですよね？　でもやめてあげません。ど\nんどん性感は高まって、いつでも射精の準備は整っているというのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……っあっ、ンッ……♪　こうして、出そうとするたびに膣肉で、肉ヒダで\nせきとめられて……気が狂いそうでしょう？　っぁっ……あっ、ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私もとても辛いですよ……♪　あなたの泣きそうな顔を見下ろしながら腰を\n振るのは……♪　まるで逆レイプをして、犯しているようなものですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「オマンコを締めるたび、にぃ……っ♪　歪んだ母性本能とサディスティック\nな喜びで……あはっ、イッてしまいそうになります。……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「フフ、射精したくなってきたんですか？　私の中に？　オマンコにみっとも\nなくビュービュー膣内射精したいんですか？　どうしましょうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私はこのまま……、ぁっ♪　永遠に寸止めのまま、ずぅっとし続けてもかま\nいません、よ……？　いくらでもオチンポ扱いてさしあげます、し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたもその方が、長く楽しめていいのでは？　……なんて、意地悪をしす\nぎましたか？　肉竿がパンッパン……。これ以上焦らすのは可哀想ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いいでしょう……さあ、イキなさい……！　あなたは欲望に負けて……あぁ\nんっ♪　私のオマンコに大量に精を漏らしてしまえばいいんです、さあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んあっ♪　はぁあああ♪　いいんですか、隊長ぉお……♪　皆を導くリーダ\nーのあなたが、無責任に種付け♪　避妊無しで生発射だなんて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「抜かせてくれなかったから？　そうですね♪　わかるでしょう？　ビク、ビ\nクとオマンコの中でペニスが脈打ち、次々に精が放たれていく様が♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「中出しが終わるまで絶対に抜いてなんてあげませんよ♪　フフ、うふふふっ\n……！　ああ……こんなに出して♪　子宮が熱くなってきました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「無様でとても愛おしいですよ……。あぁ♪　興奮して、膣壁が収縮します♪\n　自然に蠢いて、受精のためにどんどん精液を子宮におくりこんでくる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「これはもう確実に手遅れですね♪　私？　私はいいんですよ……隊長のこと\nが大好きですから。望まれるのであればいくらでも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「私の愛が……。はぁっ♪　恐ろしいですか？　でも……やっぱり身体の方は\n、ペニスは嬉しがっているみたいですね？　自分の種を注げたこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それどころか、念入りに……もっと交尾したいみたいですよ？　すぐまた復\n活して……。あっ、わかるでしょう？　私の中を小突いてきます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたのそういうタフなところ、評価しますし好きですよ。私が身体を捧げ\nるにふさわしい……。ええ、いつだって私を虜にするこのペニス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「やっと見つけた運命の人のペニスを……はぁっ♪　熟したヴァギナで気持ち\n良くしてあげたくなるのは、女のサガ……。もちろん抜かせません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「抜かずにこのまま……♪　ぁっ、永遠に交わりつづけましょう。安心してく\nださい……。あっ、体力には自信があります、ので♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「いくらでも腰を振ってあげます。……ね？　上下に大きく……！　んっ、は\nぁっ、はぁっ、はぁ……ああっ。も、もうすっかり元通り」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ペニスっ……すごいですよ、太くなって……。あっ……あッ、すごい……。\n感じるところに当たり、ます♪　Ｇスポットもこすりあげて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んぁあああ♪　射精した直後にこれですか、感嘆に値します……っ♪　あは\nっ♪　大きいっ……尖ってるっ、奥に刺さる……気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こんな暴れん坊を乗りこなせるのは……。あっ♪　きっと私だけ、でしょう\nね、あなたのペニスは大きすぎます、形もエロティックで、んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「生娘が相手をすれば見ただけで失神してしまいそうな剛直ですから……。…\n…っふっ♪　挿入するだけでも一苦労、そし、てぇぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「このっ、まっすぐに子宮口を狙って突き上げて来る傲慢さ♪　あっ、種付け\nのために生まれたかのようなテクニック、失神ものです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「こんな規格外の、鬼のようなオチンポで突かれたらっ、あっ♪　私以外は気\n絶っ、しますよ♪　快感と衝撃で……っ、あぁんんっ、太いぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「太い快楽が、オマンコから脳のてっぺんまでを貫いて……あはぁっ♪　イキ\nますっ♪　強引にイカされてっ、受精ＯＫの状態にされてしまうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んっあっあふっ、ひっ……あっ♪　あっぁっあっ……！　本当に卑猥なペニ\nス……っ♪　あら？　中で震えているみたいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あは……♪　またイキたくなってしまったんですか？　隊長は私のオマンコ\nが好きなんですね……？　相性がいいのか、慣れ親しんだせいか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「入れただけでいつもオチンポをビクビク痙攣させて……、少し動くともうモ\nジモジ。立派なオチンポなのに、敏感過ぎて大変ですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ッ出したければっ、出してください……♪　私のここは、あなたの専用便器\nですし……。あぁっはっ♪　あなたのペニスも、私専用の肉バイブ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「互いの快楽のために……ああっ、お互いを貪り尽くして、獣欲のままにっ♪\n　あっ、肉欲が命じるように射精し、受け止め、それを飲み干す♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「嘘をついても無駄ですよ、粘膜同士でこんなにも密接に絡み合っているんで\nす……♪　あなたのペニスが膨張しているのくらい感じ取れます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「出して……、出してくださ、いっ……早くっ！　誰かに見つかる前に……あ\nあっ！　あなたの精液を独り占めさせて、私にプレゼントして……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ッああああっ♪　あッ、ああああっ……！　いいですよ、上手です、きちん\nと中に……！　膣内に体液が、精液が注ぎ込まれてきています……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「んっあぁああ……！　オマンコの奥の奥っ……子宮口から子宮内へと精液が\n……ああっ！　精液が入ってくるのがわかります……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304302" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたのッ……♪　あなたの分身が、私の一番大切な場所を……満たして、\n潤して……♪　ああああっ……その事実だけで達してしまいます、んぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ッはぁっ……イ……くっ、イ、く……っ♪　あはっ♪　あああ……！　両脚\nがガクガクして……あっ、だめ、こぼすのはだめ……一滴だって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「無駄にはしません……っ。あっ♪　貴重なあなたの、隊長の精液です、から\n……！　ん、最後に一絞りします、ね……。ふぅっ！　んんんッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……はぁあああ♪　ごちそうさまでした……。情熱的なまぐわいでしたね。\n木工ボンドみたいに真っ白な精液が、性器同士を繋いでくれている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「も、う今死んでも悔いがないほどに幸福……です。わかるんです、子宮の中\nにミッチリと二回分の精子が詰め込まれているのが……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「逞しいペニスを持つあなたの精液ですから……きっと、私の子宮の中を泳ぎ\nまわっているんでしょうね……。その様子をこの目で見てみたいけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「見られないのが残念です……。……ただの知的好奇心ですよ。ですが、そう\nですね……。もし、このまま受精していたのなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「１０ヶ月の間、新しい楽しみが増えます。妊娠してからのセックス……。私\nは興味がありますが、隊長はしてみたくないですか？　フフフ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「えっ……？　抜くのですか……！？　あっ♪　身体に……身体にかけたいと\n？　……っああっ！　そ、そんな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「な、なんて淫らなことをするのです……！　あっ♪　そんなにっ、そんなに\n精液を身体に……水着にかけたら……。ッぁ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「絶対に、浜辺の皆にバレてしまう……。あ、あなたの精液は濃すぎるんです\nっ……んあああっ！　現に、現に今っ、私に降りかかっているこの量と！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ちょっとやそっとでは洗い流せない粘り気……あんっ！　そして、む、胸や\nお尻……腰のくびれ、い、いやらしい部分ばかり狙い撃つせいで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「気づかれてしまう……。そんなの困る、のに……胸が高鳴ってしょうがない\nんです……。あっ……！　この熱い体液が肌をつたい流れると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もう、何も考えられない……♪　あっ、あっ、まだかけるのですか……！　\nやっ……、も、もう真っ白です……あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……ふぅ……。よ、ようやく落ち着いてくれましたか。想像よりもはるかに\n激しい射精……この身でしっかり受け止めさせてもらいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00005003_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「不機嫌に見える？　……まさか。この顔は生まれつきです。私は……その…\n…大変良い思いをさせていただきました。こんなにも精を浴びて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「肌という肌を精子でデコレーションしていただけて……。この悪臭に、あな\nたの香りに陶酔しきっているんですよ？　ここまでされてしまったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「もうあなたからは離れられそうにありません……。この禁断の甘い蜜、あな\nたとの不埒な関係を一度でも多く、楽しませてくださいね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
