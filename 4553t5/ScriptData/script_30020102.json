		{"command":[ "PLAYVOICE", "002_0104117" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「キツキツのオマンコを、無理やり押し広げてっ……あっ、あっ、オマンコが\n、オチンチンの形になっちゃうぅっ……！」", "NORMAL" ]},
