		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あなたが、私の身体を開発しちゃったからっ……あんっ、あぁっ、あっ、あ\nっ、んあぁっ……だから、気持ちよくなっちゃうのぉっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0104111" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「Ｈな道具をいっぱい使ってぇ……あぁんっ、あんっ……Ｈなことをされて、\nだから……んふぅっ……イヤらしい身体になっちゃったのぉっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "002_0104112" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
