		{"command":[ "PLAYVOICE", "002_0104105" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、そこっ、だめぇっ……あぁんっ、あんっ、あっ、あっ、やぁっ\n……やだぁっ、クリトリスをイジめないでぇっ……」", "NORMAL" ]},
