		{"command":[ "PLAYVOICE", "002_0104109" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……ちがうの、私、淫乱なんかじゃないっ……！　やぁんっ、あ\nぁんっ……！　ぜんぶっ、あなたのせいだからぁっ……」", "NORMAL" ]},
