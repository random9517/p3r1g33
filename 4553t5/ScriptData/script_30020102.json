		{"command":[ "PLAYVOICE", "002_0104115" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ、すごいよぉっ……んあぁっ、オチンチン、固くて、熱くてっ……んあ\nぁっ、すごく、おっきいよぉっ……！」", "NORMAL" ]},
