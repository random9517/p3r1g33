		{"command":[ "PLAYVOICE", "002_0104116" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「凸凹してて……んふぅっ……いっぱい擦れちゃうっ……！　あぁんっ、オチ\nンチン、イヤらしい形してるよぉっ……！」", "NORMAL" ]},
