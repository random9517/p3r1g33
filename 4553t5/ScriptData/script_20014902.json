		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺だって、ダイヤナたちならコンテストの賞を総なめできるって思ってるが\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ダイヤナの機嫌をとろうと声をかけるが……。", "NORMAL" ]},
