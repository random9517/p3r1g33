{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "会場は想像以上ににぎわっていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ここにいるみんなが、スタークリスタルを狙うライバルってわけね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023260001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうわけでもないだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "会場に入り、最初に目に入った広場には、すでに様々なコスプレをした参加者\nが集まっていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アニメやゲームから飛び出してきたかのような高い完成度のお姫様やエルフ、\n女騎士や軍人といったものから、", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "乳牛、ピクトグラム、サカバンバスピスといったネタ寄りのものまで入り混じ\nり、混沌としていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そんな会場を、ＥＤＯの隊員たちはビキニバズーカ隊の衣装で警備にあたって\nいる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして俺たちは、変身も済ませて広場を散策していた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うぅ……なんでこんな格好……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260001" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ただし、グリムロックは魔法少女の姿になっていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっと……どうしたんだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「腕の銃器が規約違反だったみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260001" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだったのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ビキニバズーカ隊のバズーカは許されてるのに……不幸すぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260002" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それでアンは……制服？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。普段の格好にしようと思いましたが、制服で参加されている方も見受\nけられましたので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260002" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アンが見たのは、おそらく学園ものアニメのコスプレをした参加者だろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なので、こちらの格好でいこうと思いましたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そう言って、アンは背負った鞄の肩ひもを掴むと、リズミカルに足踏みをはじ\nめる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「中出した瞬間、孕んだわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まて、まて、まて、まて、そんな歌はない！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "突然妙な歌を口ずさむアンの口を慌てて塞ぐ。そんな俺をみて、周囲がざわつ\nいた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "あれ……もしかして、幼女を誘拐しようとしている不審者のように見えてる…\n…？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「みんなお待たせ～。さ、はやく受付にいきましょ。みんなでコンテストに参\n加して、表彰台を独占するの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023260002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "遅れてダイヤナもやってきて、俺への疑いの目は離れていった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それにしても、今回のダイヤナは、いつもより化粧に気合が入っているような\n気がするな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「で……でもさ……。私、普段の格好で参加できなくなったし、帰っていい\n……よね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260003" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「グリムロックさま、だめですの。それに、とっても似合ってますの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260005" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だ……だって……。こんな目立つ格好……お、落ち着かない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260004" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんもついてるんだから、もっと堂々としていいんだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023260003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "隙あらば帰ろうとするグリムロックの手を、ダイヤナがしっかりと握っている\n。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000601_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そうですの！　はぁ……とっても素敵な衣装をもらえて……うらやましいで\nすの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260006" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "もう片方の手はアンに握られていた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00022102_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "2", "char_00000601_01", "8", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "挟み撃ちにあっているグリムロックは、俺の方を見て、", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「たすけて……カツマくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、目で訴えているようだが、すまん。俺にはどうすることもできないんだ…\n…。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんもなにか言ってあげてよ。隊長なんだから、隊員にやる気を出\nさせるような一言！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023260004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「無茶言うなよ。まあ……たしかにグリムロックのその衣装……かわいいとは\n、思うぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "少々無理している感じもあるが、そういうところがいい味を出している。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そ……そう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260006" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "グリムロックは少しだけ口元を緩ませると、すぐに元の陰鬱とした表情に戻っ\nてしまった。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほらほら、カツマちゃんのお墨付きももらったんだし。参加しましょ、コス\nプレコンテスト♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023260005" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「一緒に参加しますの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023260007" ]},
		{"command":[ "SETCHARA", "0", "char_00022102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え……あ……それとこれとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010023260007" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ダイヤナに引きずられるように、グリムロックはアンと一緒にコンテストの受\n付に連れていかれてしまった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "三人が受付から戻るのを待っていると、ルナテミスとアナザー・ルナテミスを\n見つけた。", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00000109_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ、姫様とアナザーも参加するのか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、参加するぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023260001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私もだ。アナザーとの決着をつけるために」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「最初に誘ったときは、断られたのだがな。しかし急に態度を変えて、参加す\nると言いだしたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023260002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それは、貴様が『美貌では私の方が上だ』などというふざけたことを言った\nからではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このコスプレコンテストで、アナザーに私の美貌の方が勝ってるということ\nを証明して見せる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ……そうですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "息巻いている姫様は、まんまとアナザーの言葉に乗せられたようだ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00000109_01", "6", "CENTER", "-400" ]},		
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "姫様は煽り耐性がゼロどころかマイナスだからなぁ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様も参加するのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺じゃなくてダイヤナたちが……あ、そうだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様たちが優勝したら、賞品の宝石をゆずってくれないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「宝石を？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。実は俺たちは、グランプリの商品を確保する任務で参加しているんだ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか……。だが、それはできないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、それは……だな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「わたしは構わないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023260003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、さすがアナザー！　話が分かる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ただ……もし私が優勝したら、私の願いをひとつ叶えさせてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023260004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……ああ……。そうだな、もちろんいいぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "この言い方……スタークリスタルが本物だってことを知っているのだろうか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まあ、チラシには大きくどんな願いも叶うって書かれていたし。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それにアナザーなら、スタークリスタルの力を悪用したりなんかしないだろう\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、待て！　その……私の願いも叶えさせてくれるなら、宝石はお前に譲っ\nてやらないこともないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023260008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様も協力してくれるんですか？　ありがとうございます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "姫様の願いってなんだろうか……なんだかロクなことではないような気もする\nが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ともあれ、もしものときの保険ができたのは大きい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いざってときは、姫様たちにがんばってもらおう……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃ～ん？」", "NORMAL" ]},
