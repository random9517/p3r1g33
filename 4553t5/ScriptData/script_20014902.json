		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっ、ダイヤナ、いつ戻った！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「さっきよ。もう、ダイヤナちゃんとアンちゃん、そしてグリムちゃんだって\nいるのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010023260007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「グランプリをとれないって思ってるの！？」", "NORMAL" ]},
