{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「どうだ！　長官！　今度こそ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「全然ダメー！　１５分もオーバー！　お前ら中でなにやってんの？　ナニか\nしないと出られない部屋に入れたつもりはないんだけど！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「えええええ～っ！　まだダメなのかぁ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「バカ犬があれだけモタモタしていれば当然です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「というか、アナザーが爆弾の設置に手間取ったせいだろ！　もっとテキパキ\nやれんのか、この赤点娘！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あれだけの広さを一度で吹き飛ばすには、設置場所も考えねばならん。だい\nたい、赤点娘はお前だろう！　この間も数学で――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お前らいいかげんにしろっつーの！　はい、ちょっと休んだらもう一回やる\nよ！　いいな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれだ……こんなんで、うまくできるようになるのかね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふぅむ……ご主人、長官、少々よろしいですかな？　わたくしに策がござい\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「策ぅ？　またろくでもないこと考えやがったな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「待て待て。悪知恵に関しては飼い主よりジュンジローの方がよっぽど信頼で\nきるぞ、どんな策なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい。それでは長官にご主人、少々お耳を……ごにょごにょごにょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふむふむ？　メンバーをルナテミスチームと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザーチームに分けて競わせる？　ふむふむ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ……なるほどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もちろんセレーナとハルノブは別チームに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「見え見えの策ですが……まあ、この人たちには効果的でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……というわけだ！　これから２チームに分かれて、タイムアタック勝負を\n行う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおおー！　勝負か！　勝負だな！？　おーっし！　ハルノブには負けねえ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はいはい、相手してやるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぉおおおおおっ！　私は今、猛烈にスポコンしている！　カツマ！　つい\nてこーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺も！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おっーっし、カツマ！　行ってこーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116030007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人～。せいぜいがんばってくださいませ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるせえ、バカ犬～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ガタガタ言うな！　打倒アナザーだ～っ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いいだろう！　行くぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}