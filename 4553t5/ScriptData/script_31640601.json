		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちがう？　ぜったい？　おとーさん、ぜったいに、えっちぃー目で見てなか\nった？　ほんと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「じゃあ、ほんとかどうかイルルが、たしかめてあげる。だから、おとーさん\n、おちんちん出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603104" ]},
		{"command":[ "SETCHARA", "0", "char_00016406_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いーのっ！　おとーさん、おちんちん出しなさいっ！　イルルがしてあげる\nからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふーん……おとーさんのおちんちん……やっぱり、ちょっと大きくなってる\nね？」", "NORMAL" ]},
