		{"command":[ "PLAYVOICE", "v2_164_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふっ、おちんちん……きもちいいーのね？　じゃあ、もっとこすこすしち\nゃお……はっ、ふっ、えいっ……えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016406_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……おちんちんの先から、お汁……出てきてる……おとーさんのせーえき\nの……ちょっと前のやつ……だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
