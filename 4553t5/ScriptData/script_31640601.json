		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……別にイルル怒ってないよ？　おとーさんが、他の女の子のこと、えっち\nぃー目で見てるのなんていつものことだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603102" ]},
