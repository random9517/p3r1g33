		{"command":[ "SETIMAGE", "0", "still_00016406_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「学校のかわいい子を見て、こーふんしちゃったの？　それって、おかーさ\nんにイケナイことだって、言われなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えっ、ちがうの？　じゃあ、このおちんちんは……なんでこんなにビクビク\nってしてるの？　んふふ……ねぇ……どうして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルが足でしてるから？　えへへぇ……そうかも……イルルが、おちんち\nん……ぎゅうーってしちゃってるからかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「それだけじゃない？　イルルのかっこがエッチだから？　おとーさん、イル\nルのエッチなかっこで、こーふんしてたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふーん、でも……それって、やっぱりいけないことなんだよねぇ？　えっち\nなおとーさん……おしおきしないとダメだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ……おしおき……しちゃうんだから……んっ、えいっ……えいっ、おと\nーさんの……おちんちん……足でこすこすしちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あぁん……おちんちん、すっごくあちあちになってる……ね、ね、おとーさ\nん……これって、おちんちん気持ちいーの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「そーなんだ……んふふぅ……なんだかイルルもムズムズしてきちゃった……\nおまたのとこ……ヘンなかんじぃ……あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016406_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱいもね……何だかコリコリってして……ちょっとじわーってす\nるの……おとーさんにしてもらってる時とおんなじね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016406_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「は、んっ、あふっ……もっと……強いのがいいの？　んっ、どーしよーかな\nー？　おとーさんのおしおきだからなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルがいちばんなの？　ほかの女の子は、ちょっと見てただけ？　んー、\nほんとにほんとなのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふふ……じゃあ、おとーさん……してあげる……。おちんちん、気持ちよ\nくなっていーからね……んっ、んしょっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「こすこす……んっ、ふっ……はぁ……んっ、ここってね……イルルたちがお\nべんきょーしてるお部屋なんだよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いつもね、先生が分かる人ーって聞いてきてね、イルルもね、はーいって手\nを上げてるの……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、今日は……おとーさんのおちんちん……ぎゅってして……イルルも、\nいけないこと……しちゃってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「今は、誰もいないから……だいじょーぶだけど……もし、誰か……見てたら\n……ドキドキしちゃうね……は……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016406_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、くぅ……イルルのおまんこも……ぬるぬるになって来ちゃっ\nた……はふっ、んっ、あぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんも気持ちいいー？　んふっ、何だかおとーさん、すっごい気持ち\nよさそーなお顔になってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルのおしおきで、こーふんしてるんだ……んふふう……しょうがないの\nね……じゃあ、さきっぽ……ぎゅってする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016406_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ……痛かった？　ごめんね、おとーさん。でも、おとーさん……そーいう\nのも好きなんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0603126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
