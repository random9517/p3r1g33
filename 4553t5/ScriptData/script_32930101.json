		{"command":[ "SETTEXT", "「くはぁあああぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103301" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「おっ、オマンコ、イッくぅうううぅぅぅ～～～～っ！　んはぁっ、ああっ、\nまたっ、潮ぉ、噴くぅううぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「腰跳ねるっ、んはぁっ、はぁっ、ガクガクって、んぉっ、おおっ、オマンコ\nからびしゃびしゃって、とまらねーですよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「おおっ、まだ、オマンコがぁ……ジンジン疼きっぱなしでいやがりますぅ…\n…はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「な……なんですか……。いつもそんな、エロい顔でイッてるのかって……う\n、うるせーですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ……これは……オマエを悦ばせるための、サービスだってんですよ……。\nんはぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「別に……オマエのチンポに夢中になって……んふぅ……いつもより激しく、\nオナニーしてたわけじゃ、ねーですから……断じて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……なんですか……？　指が、まだ動いてるって……そ、それ\nは……ま、まだオマエがイッてないからですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「オマエのチンポ見ながら……オナニーでイッた余韻に浸りながらぁ……オマ\nンコ、こすってるわけじゃぁ……ねぇ、ですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……とにかくぅ、これで、あたしがちゃんとオマンコつかえる\nオトナだって、そのケダモノ脳みそでも、理解できましたね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
