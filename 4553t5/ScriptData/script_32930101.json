		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁあぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103401" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁあっ、あはぁあっ、イクッ、イク……ッ！　あっ、ああっ、頭の中ぁっ\n、真っ白にぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「くひぃんっ、こんな絶頂ぉっ、ああっ、おかしい……！　頭の中にぃ、強烈\nなチンポの匂い、刻み込まれるようなぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁあっ、身体にっ、どろどろしたの、ぶっかけられてる……んぁっ、ああ\nっ、チンポが、ビクビクしてっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「白いの……いっぱい、くる……っ！　んはぁ……はぁ……なんでこんなぁ…\n…お……オマエ……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「おさわり……なしだからって……。こんな方法で、あたしのことを……んは\nぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、あたしのオナニーがエロかったから、こんなに射精できたって……。ま\n、そーでしょーね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「オマエが、おねえちゃんに興奮するってことは、とーぜんあたしにだって同\nじように欲情するのはあったりまえですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「にしても……量が多すぎやしねーですか……。いつもこんな量を、おねえち\nゃんのオマンコに……きっと何十発も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_293_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リン＝クァー" ]},
		{"command":[ "SETTEXT", "「あたしも、同じようにされるかと思うと……。はぁ、はぁ……お、オマンコ\nが……またジンジンしてきやがりましたぁ……」", "NORMAL" ]},
