		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ……わかった。無理するなよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「その言葉だけで充分報われるわ……さあ、行くわよ。３、２……１っ！！　\nでやああああああああっ！！」", "NORMAL" ]},
