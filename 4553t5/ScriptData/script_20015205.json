		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前はどうするんだよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「私は自分でなんとかするさ。むしろ２人がいると私が全力を出しきれない。\n２人は逃げてこいつらを撹乱するんだ。いいな？」", "NORMAL" ]},
