		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「部屋から飛び出したはいいが、どこに逃げりゃいいんだ……！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私に１つだけ考えがあります……こっちに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こっちって……受付の方か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええ。上手くすれば……いや、上手くしてみせます。そこに逆転の切り札が\nあるはずです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そうはさせませんわっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450001" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐああああっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「きゃあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ぐ……あっ……ここは俺の部屋……？　こんなところに吹き飛ばされたのか\n……うぐっ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「おほほほほ。相手の動きを監視カメラでチェックできるのは、あなたたちだ\nけの専売特許ではありませんのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450002" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その声……喋り方、お前、貴子か？　なんでこんなことを！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「その名前は世を忍ぶ仮のもの。私の名前はメガデス。武装組織ジョーカーの\nリーダーであるメガデスですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450003" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あのテロ組織の……外部に連絡ができないのもメガデスのせいだったんです\nね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ご名答。正解の賞品はこちらになりますわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450004" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐああああっ！！　くっそ、棚が壊れてるじゃねえか……誰が掃除すると思\nってんだ……ぐっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、心配せずとも、もう二度と掃除も残業もない世界に送ってさしあげま\nすわ。隊長に恨みはありませんけれど、むしろ同情しますけれど、これも仕事\nですわ。悪く思わないでくださいまし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450005" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……マジでこれまでかよ……俺の人生、なんにもいいことなかったな\nあ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450006" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………………………なんだ？　なにを見てるんだお前……？　棚から\n落ちたグッズ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「こ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「これは地下アイドルグループ♭の田中利奈ちゃんの写真集！！　ＣＤまで…\n…しかも初期ロットサインつき！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450008" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？　あ、ああ。それか、それは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「きゃああああああああああ！！　バンドスコアまで！？　これ、限定発売だ\nったんですのよ！！　しかもこれもサインつき！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450009" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「生写真まで！？　利奈ちゃんのお宝だらけじゃないですの！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あ……あなた、もしかして生粋の利奈ちゃん推しですの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450011" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "(知り合った本人から挨拶代わりにもらったものだということは黙っていよう\n……)", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わ……わたくしとしたことが、同じ推しを担う人を殺そうとしたなんて……\n推しの掟第二条『推し活同士で争うべからず』に反していましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450012" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだその掟……いやなんでもない、そうか、お前も同じ推し仲間だったん\nだな！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ええ！！　わたくしの破壊活動の日々に潤いを与えてくれる存在、それが利\n奈ちゃんですわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450013" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「血と硝煙と争いの日々……そんな荒んだ毎日でも、彼女の歌声と笑顔を見て\nいると癒やされて、明日も頑張って破壊工作しようって思えるんですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450014" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「彼女こそアイドルの中のアイドル！！　わたくしの最推し！！　田中利奈ち\nゃん！！　名前も可愛らしいですわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450015" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「よくわかりませんが今のうちに……危ない、カツマさん！！　避けてっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちっ、外したか。まあいい。あの裏切り者は排除した。あとはお前ら２人じ\nゃ。メガデス、足止めご苦労」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023450002" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「三度目の正直だ。今度こそ逃がさねえぜ。ラケシス、出口はきっちり固めて\nおいてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023450003" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふ、お任せあれ。ここらでお遊びも終わりですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023450003" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、優しく呪ってやろう。大丈夫、余の呪いは素晴らしいゆえな。苦しむ\n間もなく意識を失うじゃろうて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023450003" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ……今度こそやばいか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あともうちょっと……もうちょっとの距離なのに……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450009" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「……させませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450016" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023450004" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「させませんわ！！　同じ推し活仲間、それも生粋の利奈ちゃん推しをここで\n失うわけにはまいりませんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450017" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うおっ！？　なにを血迷ってんだお前！！　裏切るつもりか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023450004" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「……裏切ってはおりませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450018" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はあ？　どこからどうみても裏切ってるだろうが！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023450005" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしが請け負ったのはＥＤＯへの潜入とシステムハッキング、セキリュ\nティを無効化して潜入を手引きすること。それは完了しております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450019" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「先ほどまでのカツマさんへの攻撃は、いわばアフターサービスです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450020" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやなサービスだなぁおい！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そしてサービスタイムは終わりました。ならば、わたくしは同じ推し活仲間\nを助けますわ。推しの掟第一条『推し活仲間は相互に助け合うべし』ですわ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450021" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主……まぁよい、ならば３人共々排除するだけじゃ。いくぞ、セレーナ、\nラケシス！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023450005" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「お２人は逃げて救援を！！　先ほど通信妨害は切りましたから、誰かしら来\nてくれるはずですわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450022" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いえ……それでは間に合いません！！　だから、メガデスさん、そちらの壁\nを壊してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450010" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「っ！？　承りましたわっ！！　はああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450023" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、俺の部屋の壁っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「よし、これで……繋がった！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450011" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、やはり逃げる気ではないか！！　セレーナ、ラケシス、先行して逃げ\n道を塞げっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023450006" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「了解っ！！　逃がすか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023450006" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「誰が逃げるもんですか！！　カツマさん、こっちに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450012" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう……ってここ、ロビーか？　壁の向こうはこっちに繋がっていたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ここに、私が受け取るはずだった荷物が保管されているはず！！　実験室行\nきの荷物が！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450013" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それでしたら、受付テーブルの後ろですわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023450024" ]},
		{"command":[ "SETCHARA", "0", "char_00012599_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「了解！！　あった！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450014" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そのでかい段ボールに何が……品名・新型スーツ？　おいまりあ、まさかそ\nれって……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そのまさかです！！　試運転も装着もしてないけれど、もうこれに賭けるし\nか！！　カツマさん、手を！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450015" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おうっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
