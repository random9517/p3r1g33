		{"command":[ "FADEOUTCHARA", "0", "VERYFAST" ] },
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「シルバドライブ・リンケージ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023450016" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
