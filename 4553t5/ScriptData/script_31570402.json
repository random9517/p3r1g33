{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃん、どしたの～？　何かご用事かな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……へ？　最近メイドの仕事にミスが多すぎる？　ドジっ子メイドにはお仕\n置きが必要だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ま、まさかこれは……！　噂に聞く、あれこれ理由をつけてメイドを手籠め\nにする悪徳ご主人様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふっふっふっ～♪　いいよ、ロッテはぱーふぇくとメイド！　お兄ちゃんの\n特殊なせーてき嗜好にも付き合ってあげちゃうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404104" ]},
		{"command":[ "SETCHARA", "0", "char_00015704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あー！　お兄ちゃん何、その呆れたような顔は！　え？　いいから、ベッド\nの上で四つん這いになって服をめくれ？　は～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これでいいの、お兄ちゃん？　……お尻をもっと上げるんだね……ん、しょ\nっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015704_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こーゆー時の台詞、ロッテ知ってるよ！　きゃ～、お兄ちゃんにお仕置され\nちゃう～♪　お許しください、ご主人様～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃん♪　な～んだ、お兄ちゃんも意外とノリノリじゃん♪　カチカチの\nおちんちん、そんなにロッテのおまんこにぺちぺち叩きつけちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……大丈夫だよ、確かにボディは小さいけど、そーゆーことができるように\nは調整してパーツを選んでるからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうすれば……んっ……ほら、潤滑油……おまんこからえっちなお汁も出せ\nちゃうの♪　おちんちんの先っぽにぬ～りぬり、んぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「遠慮なんてしなくていいからね。あなただけのいたずらメイドに、思う存分\nお仕置きしちゃってくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁ、んにゃぁんっ……！　は、入ってきた！　お兄ちゃんのロッ\nテのおまんこにぐりぐりって、あっ、んんぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、んっ、んくぅぅんっ……！　や、やっぱりちょっときつい、か\nな……？　先っぽの部分がグッて入ってっ……あっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごいっ、おまんこの中で、お兄ちゃんのおちんちんの形がぜ～んぶ分かっ\nちゃう……！　あっ、んくっ、んにゃぁうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんの凸凹が、内部機構に擦れて、あっ、んくぅんっ……！　お腹の\n中、抉られるみたい……んぁ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これで全部入った？　ロッテの小さなおまんこでも、お兄ちゃんのおち\nんちん、根元までぱっくんできたかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふふ、苦しくないかって、だめだよーお兄ちゃん、ロッテに優しく\nしちゃったら♪　これはドジっ子メイドへのお仕置きなんでしょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でも……ありがとう、お兄ちゃん。そーゆー優しい所、だ～いすきだよ、に\nゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、ロッテは大丈夫だから……お兄ちゃん、もっとお仕置き、して？　ぐ\nりぐりって、ロッテのロリおまんこ、いっぱい可愛がってよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ♪　あっ、ああぁんっ……！　す、すごい！　おちんちんが引\nき抜かれると、内部機構ごと持っていかれるみたいで！　んにゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんのでっぱりが、浅い所削ってくる、あっ、ひっ、んひゃぁんっ！\n　ロッテのおまんこ、ゆるゆるになっちゃうっ！　ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、んくぅんぅっ……！　今度はゆっくり奥まできたぁ！　にゃ、んや\nぁんっ！　一番を奥をぐりぐりって、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お、お兄ちゃんってば、こんなロリロリボディのロッテに興奮しすぎだよ～\n♪　ほ～んと、変態お兄ちゃんなんだから～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃあぁんっ！？　あっ、あひゃぁんんっ……！　ま、また、一気に激し\nくなって！　おちんちん、ズドンってくるっ！　んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「す、すごい、お腹がポッコリ膨らんでるよ！　あっ、ああぁんっ♪　ご仕事\n引っ張られて、ずぼずぼされてる！　んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……な、生意気なロリメイドにはもっとお仕置きが必要だ、って？　にゃふ\nふ、お兄ちゃんも中々分かってきたじゃ～ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ、やめてください、ご主人様～♪　あっ、あぁんっ♪　これからはもっ\nとしっかりご奉仕しますから、お許しください～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あっ、んひゃぁんっ！　……って、遊んでたけど！　これっ、\nんにゃぁんっ！　さ、さすがにちょっと、余裕ない、かもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……え、えっちなのはしょうがないの！　お兄ちゃんに喜んでもらえる為に\n、そーゆーパーツにしてるんだってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んにゃぁんっ♪　ダメ、おまんこの奥、勝手にぎゅ～って震\nえてっ、ああぁんっ！　えっちなノイズ、増えてっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「パンパンってすごい音、あぁんっ♪　愛液も止まらない、ぐちゅぐちゅって\nロッテのおまんこかき回されて、あっ、んやひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お、お兄ちゃんのおちんちんもいっぱいぴくぴくしてるっ、んにゃぁん♪　\n知ってるよ、このままロッテのロリおまんこに出したいんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……いいよ、このままおまんこにいっぱいびゅーびゅー出して！　えっちな\n精液注ぎ込んで、ロッテのお腹いっぱいにしてほしいの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ！　あっ、あぁんんっ！　この体勢だと、ほんとに奥の奥まで\nおちんちん届いてくるのっ！　あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ロッテもイクね！　お兄ちゃんと一緒にイクからね！　お仕置き射精で、い\nっぱい気持ちよくなっちゃうの♪　んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃあぁぁんんっ～～！　あっ、んあぁんんっ♪　膨らんだおちんちんか\nら、あついのドクドクきたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ♪　すごい、ロッテの中で、おちんちんが何度も跳ねてっ、あ\nぁんっ！　お腹の中、精液でいっぱいになっちゃう、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ♪　頭の中ノイズでいっぱい、だけどっ……んあぁんっ♪　\nお兄ちゃん、気持ちいいね、にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……お兄ちゃん、い～っぱい出したねぇ。精液あつすぎて、熱暴走起\nこしちゃうかも……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　お兄ちゃんは心配しょーだなぁ♪　あなたのロッテは、この程\n度じゃ全然壊れたりしませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「って、あれ？　あれれ？　……お兄ちゃん、なんかこれ……ぁんっ……おま\nんこの中で、またおちんちん固くなってない？　なってるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「うわぁ、悪い笑い声してるなーお兄ちゃん。……お仕置きなんだから一回で\n終わるわけないだろ？　ここからが本番だから覚悟しろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふ♪　もちろん、受けてたってあげましょー！　ロッテはぱ\nーふぇくとメイドさんだからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でも……んにゃぁん♪　にゃふふ、今度はやられっぱなしじゃないんだから\n！　ロッテもおまんこを使って、い～っぱいご奉仕、してあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こうやって、お腹にぎゅ～って力をいれてぇ……あっ、んぁんんっ♪　おま\nんこの中、ぶるぶるってするの、すごいでしょ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ボディは小さくたって、お兄ちゃん……主人様を喜ばせる機能に不備なんて\nないんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「入口のところをぎゅうぎゅうって締め付けて……あっ、あぁんっ！　おちん\nちんの根元をぎゅ～、ぎゅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あっ、んにゃぁん♪　おちんちんの先っぽにも、子宮のパーツで\n吸い付いて、ぐりぐりって腰を回すのっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お、お兄ちゃんも動いて、ロッテのおまんこ、もっとお仕置きして！　あひ\nゃぁんっ！　あっ、んひゃぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それぇ、またお腹ポッコリ膨らんでっ、んにゃぁんっ♪　きもちいところ、\nがりがり削られちゃう♪　あぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さ、さっき中に出してもらったお兄ちゃんのせーえきが、全部かき出されち\nゃうの～、あぁんんっ！　えっちな音、すごい、んにゃぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んひゃぁあんっ……！　んふぅんっ！　このボディ、処理能力がそこ\nまで高くないから、えっちなエラー、どんどん増えてきちゃうの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！　お、お兄ちゃんに一突きされるたびに、思考回路がノイズ\nまみれになってっ！　あっ、んにゃぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お兄ちゃんのお仕置きおちんちんでイクのが止まらないよぉ……！　お兄ち\nゃん好き、大好きぃ♪　んにゃぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「またおちんちんがパンパンに膨らんできた！　ふあぁぁんっ♪　お兄ちゃん\nもイキそうなんだ、せーえきびゅーびゅーってしたいんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいよ、いつでも出して！　あっ、んにゃぁんっ♪　お兄ちゃんのせーえき\nでロッテの事をドロドロにしてほしいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404216" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、んあぁんんっ……！　締め付けるから、ロッテのロリロリおまん\nこ、ぎゅ～ってするから、い～っぱい出してお兄ちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んにゃぁんんっ♪　ああぁんっ、んふぅんんっ……！　ま、また、一\n番奥までズドンって！　ロッテのおまんこ壊れちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふあぁんんっ……！　ロッテも一緒にイクからね！　また、一緒にっ、んに\nゃぁん♪　お兄ちゃんのせーえきでイクの！　あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃあぁんっ♪　来てぇ、おしおき射精いっぱい来てぇ♪\n　ロッテのぜ～んぶを、お兄ちゃんでドロドロにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んああぁぁぁぁんんっ～～！！　あひっ、あっ、んにゃぁんんっ！　また中\nに出てるっ！　おまんこにドクドク注がれてるっ！　あぁあんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃぁんんっ♪　こ、これ、ロッテのおまんこ、熱すぎて\nっ！　ほ、ほんとに壊れちゃうかも♪　んにゃぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えっちなエラーも、多すぎてっ、あぁんんっ♪　気持ちいいよ、お兄ちゃん\n♪　えっちなお仕置き、大好きなの、あっ、んあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　ロッテのお腹、お兄ちゃんのせーえきでぽっこり膨らんでるの\nが分かるよ。子宮パーツの中まで、たぷたぷになっちゃってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんんっ……！　射精中も、おちんちんビクビク跳ねてる！　まだ\nまだせーえき出てる、ロッテもイクの止まらないよぉ！　んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おまんこ、またぎゅ～ってするから！　んふっ、んあぁんっ！　お兄ちゃん\nの全部を、おまんこで搾り取るのっ、あっ、んにゃぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……ろ、ロッテのおまんこの中、ぐちゃぐちゃになっち\nゃった……頭の中ノイズだらけなのに……これ、幸せ……にゃふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もう出ない、かな？　んんっ……おまんこから精液がどんどん逆流してきち\nゃってる……にゃふふ、すごいえっちな音♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても、ほんとーに激しかったねぇ♪　小さなボディを押さえつけて\n乱暴にえっちするの、そんなに楽しかったのかな？　お兄ちゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「まったくまったく、ロッテのお兄ちゃんは鬼畜の変態さんなんだからー♪　\n……まぁでも、そーゆーところも、好きなんだけどね？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃあぁんんっ！　おちんちん抜けてっ、んあぁんんっ♪　ボディにせー\nえきがいっぱい降ってくるっ！　あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「精液がついた所がどんどん熱くなってきてっ、あっ、んにゃぁんっ♪　えっ\nちなエラー、すごいっ！　ふあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だめ、ほんとに熱暴走が起きちゃいそうだよお兄ちゃん！　ノイズ凄すぎて\n、あぁんっ、視界センサーもぼやけて、あっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お仕置きおちんちん、すご過ぎるよぉ！　お兄ちゃんに乱暴にエッチされる\nの好き、大好きっ！　あっ、んふぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「に、匂いもすごい……ロッテの全身から、お兄ちゃんのえっちなせーえきの\n匂いがして……んくぅんっ♪　匂いだけでもまたイっちゃうよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……さ、流石にもう終わり、かな？　お兄ちゃん、最後の一滴ま\nで、ロッテのボディに射精してくれた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015704_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、よかった♪　お兄ちゃんが満足してくれて……うん、もちろんロ\nッテも気持ちよかったよ！　とっても気持ちよかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「でも……これって、お仕置きなんだよね？　ちょーっとだけドジをしちゃっ\nたロッテへの、お仕置きのえっち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……じゃあ、ロッテがもっとしっかりご奉仕できるようになれば、今度はお\n仕置きじゃなくて、ご褒美にえっちなこと、してもらえるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……にゃふ、にゃふふ♪　まっかせておいてよお兄ちゃん！　なんたってロ\nッテはぱーふぇくとメイドなんだからね！」", "NORMAL" ]},
