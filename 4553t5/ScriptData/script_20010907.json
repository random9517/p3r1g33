{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "襲来者（インベーダー）に偽装したソルダー兵が現れた市街地。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カツマは物陰にて鈴の様子を眺めていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。たいしたことねーな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021220001" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ふふ、やはり一人で来ていたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220001" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「その声は、クラッド！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021220002" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「この世界に我ら以外の侵略者が来ていることは知っていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220002" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「それを利用すれば、たった一人でも飛び出してくると思っていたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「へっ、また偶然だろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021220003" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ち、違う！　ちゃんと調べたし！　課金もしたし！　好感度上げや開発もし\nたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220004" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「トタンの前でプレイするのは、少々恥ずかしかったな、ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220005" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「なに言ってんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021220004" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつ、一人だとキャラがかわるのか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こちらが素なのでしょうか？　メッキが剥がれやすい方なのでしょうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021220001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「それもこの世界を学ぶためだ。お前たちアマルガメイトを分断するためにな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220006" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「まあ、過程はどうあれ、結果としてまんまとおびき出されたってわけか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021220005" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「ああ、そういうことだ。お前の仲間は呼ばせないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220007" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「へっ、お前だっていつも連れているやつがいないじゃないか。タイマンって\nことだろ？　上等だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021220006" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "周囲の空気が淀みはじめる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ、また体が重たく……。これってこの間の変な空間か？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「一応、『アンコクーカン』という名前があるそうですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021220002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「名前なんかどうでもいいわ！　というか、このままじゃまた部隊や本部と連\n絡がとれなくなるだろう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ええ。ですがこのようなこともあろうかと、石凝姥命さまよりこれを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021220003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　この道の駅の売店で売ってそうなＬＥＤライト……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ブリキラミラクルライトでございます。これを振ると、我々の居場所を教え\nることができるとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021220004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど。じゃあ、使ってみるか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カツマはブリキラミラクルライトを点ける。そして大きく振る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "小さいライトからまばゆい桃色の光が放たれる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラッド" ]},
		{"command":[ "SETTEXT", "「そこに居るのは誰だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_120_010021220008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00012001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　俺たちの場所を敵にまで教えてどうする！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そりゃあ、こんなに光れば目立ちます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021220005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あんのシコ女神ぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}