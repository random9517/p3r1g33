{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「週に何回ぐらいオナニーをするのかって……そ、そんなの、あんたに教える\nわけないでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「自分のオナニー回数を教えるから、あたしのも教えて欲しいとか、ワケわか\nんない！　そもそも、あんたのオナニーに興味なんてないから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「じゃあ、男のオナニーを手伝ったことはあるのかって……な、なんでそうい\nう話になるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そ、それに、こういうことは……仮にしたことあったとしても、人に言うよ\nうなことじゃないし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしの反応からして、経験がありそう……？　そ、そそそ……そんなこと\n……！　くっ……ダメ……！　あの日のこと、思い出しちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オチンチン……すごく大きくなってる……こんな熱くてカタいモノを握らせ\nるなんて、あんたって本当に変態だね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002802_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それで？　このオチンチン、どうして欲しいの？　こうやって、軽く握って\nるだけでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふーん……もっと強く握って、上下にシコシコして……いっぱい、精液出さ\nせて欲しいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふふふっ。オチンチン、もっと大きくなってきたね……あたしにエッチなこ\nと言わせて、興奮したんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ねえ……ちゃんと射精させられたら、今よりも強くなれるって言ってたけど\n……あれ、絶対ウソだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしにオチンチンをシコシコして欲しいから、適当なこと言ったんでしょ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんな気持ちよさそうな顔しながら、ウソじゃないって言われても、説得力\nないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203112" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「まあいいけど。あたし、あんたのこと……信じてるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それじゃ、オチンチンいっぱいシコシコしてあげるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、でも……こ、こんなことするのはじめてだから……痛かったりしたら\n、遠慮なく言ってね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、あっ……あふっ、んんっ……！　擦るともっとオチンチン熱\nくなってくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いっぱい血管が浮き出て……あっ、んふっ……！　すごい速さで脈打って…\n…んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「先端からエッチな汁もいっぱい出てきたね……このままシコシコするだけじ\nゃなくて、先端も手でグリグリしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こうやって……片方の手でシコシコしながら、もう片方の手のひらで皮が剥\nけてるところを撫でて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　軽く触っただけなのに、すっごくビクビクしてる……！　もし\nかして、痛かった……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「痛いんじゃなくて、気持ちいいから、自然にオチンチンが反応したの……？\n　そ、そう……なら、続けても問題なさそうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「軽く撫でただけでさっきみたいになるとか……この先端のところ、弱点だっ\nたりするの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんな必死に首を振らなくても……でも、弱点だっていうなら、もっと優し\nく撫でてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こうやって……手のひらで軽く抑えつけながら、グリグリ撫でまわして……\nあっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はあぁ……オチンチンの先っぽから、ネバネバした汁が出てきてる……！　\nな、なによこれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「これが我慢汁……？　ふーん……エッチな気持ちになったり、興奮したりす\nると、オチンチンから出て来るんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「この状態でシコシコし続けたら、精液が出るのね……わかったわ。なら、も\nっと速くシコシコしてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　くっ、ああっ……！　擦れば擦るほど、オチンチンから\nエッチな音がするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ネバネバも多くなってきたし……それになんだか、オチンチンのニオイ以外\nもしてきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「濃くて、ドロドロしてて、すごくクサイのに……なんか、ずっと嗅いでたく\nなる不思議なニオイ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、あああんっ……！　うっ、うぐっ……！　ダメ……！　オチンチンの\n感触とニオイが、頭から離れないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　んっ、うぐっ……！　やっ、あっ……！　オチンチン\nが、手の動きに合わせてビクビクしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「このビクビクしてるのは、射精の合図……？　じゃあ、もうすぐ精液が出る\nってこと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、うん……言われた通り、いっぱいシコシコするわ……！　だから、早\nく射精して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んふっ……はっ、くふっ……！　やっ、あっ……！　オチンチンの奥から、\nなにか出てきてる……！　あっ、ああっ、くあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「きゃあああっ！？　あっ、熱っ……！？　こ、この白いのが、精液なの……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いっぱい手にかかって……！　んっ、んんんっ……！　我慢汁よりネバネバ\nしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それに、ニオイもキツくて……なによ、このイカみたいな香り……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「すううぅ……はぁ、あああっ……！　精液……変なニオイなのに、もっと嗅\nぎたくなってきちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ……あっ！　ひぐっ、んふっ……！　あっ、あっ……！　もっと精液の\nニオイ、感じさせて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んっ……はあぁ……いっぱい出たわね。手の中、あんたの精子でドロドロよ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それにしても、これだけ射精させてあげたのに、まったく強くなってる気が\nしないんだけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふーん……もう一回射精させたら、効果が出るかも知れないのね……まあ、\nあんたがそう言うなら、もう一回シてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それに……あたしも精液のニオイを嗅いでたら、変な気分になってきたし…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、違っ……！　変な気分っていうのは、エッチな意味じゃなくて……！\n　ああ、もう！　いいから、さっさと二回目するわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んっ、くふっ……！　精液の熱さが、手の中に広がっていくわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オチンチンを擦れば擦るほど、このドロドロした感触が広がっていって……\n滑りがよくなっていってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それに、ニオイも……んっ、あふっ……！　さっき出した時の比じゃないく\nらい、濃くなって……はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなの嗅いでたら、オマンコが疼いてきちゃう……！　もっとエッチなこ\nと、したくなっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、くううぅ……！　だ、ダメ……！　今日は手でするだけ……！　エッ\nチなことは……もっとお互いのことを知ってからじゃないと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　んっ、あっ……！　はううぅん……！　こうやってオ\nチンチン握ってると、あんたの弱いところ、全部分かっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「先端もだけど……このデコボコしたところとか、オチンチンの裏側とかが気\n持ちいいんでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「どうしてわかるのかって……そんなの、触ってればイヤでもわかるわよ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「オチンチンの弱いところを、こうやって指で刺激すると……ほら。ビクンっ\nてオチンチンが跳ねるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それで……このまま、指とか手のひらでグリグリしたり、速くシゴいたりす\nると……もっとオチンチンが暴れ出すの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……！　こうやって、弱いところを激しくされるシコシコされる\nのが、気持ちいいんでしょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ふふふっ……オチンチン、さっきみたいにビクビクしてきたわね。もしかし\nて、またイッちゃいそうなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんなにイキたいなら……イカせてあげる……！　あたしの手で、気持ちよ\nくさせてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ……！　んっ、くふうぅ……！　あっ、あっ……！　今にも射\n精しそうなの、わかるっ……！　手のひらで感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「うん……イッて……！　オチンチンの奥に溜め込んでる精子……全部、出し\n切って……！　あっ、あっ……！　あうっ、くううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！？　またすごい勢いで精子出てるっ……！　あたしの手の\n中、いっぱい汚されてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はああぁ、あふっ……んんっ！　射精中も、シコシコすればいいの……？　\nわ、わかったわ……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　な、なによこれ……！　シゴけばシゴくほど、精子が出て来る\nじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなに出るなんて、聞いてないわ……！　やっ、ああっ……！　エッチな\nニオイが、いっぱい……んふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ダメっ……オマンコ疼いちゃうっ……！　あたし、精子のニオイで感じて…\n…イッ、イクッ……あああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はあっ……はあっ……き、気持ちよかった……？　そ、そう……ならよかっ\nたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あたしも軽くイッてたって……？　そ、そんなことあるワケないじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「指で弄ったりしてないのに……せ、精子のニオイだけでイクなんて……そん\nな、はしたないこと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そ、それより、これだけ射精させたのに、全然強くなってる気がしないんだ\nけど、どういうこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと……！　誤魔化さないで、ちゃんと答えなさい！　この変態\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　いっぱい精液が飛び散ってる……んっ、あぐっ！　熱いの\n、拡がってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やっ、あんんっ……！　とっても濃くてクサイの……あっ、あっ！　か、感\nじるっ……！　精子のニオイ、感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなの嗅いでたら、頭がおかしくなっちゃう……！　ダメ……あっ、くっ\n……！　うぐっ、はううぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はあっ、あはあぁ……！　ダメってわかってるのに……ずっと嗅いでいたく\nなっちゃう……！　な、なによこれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「んんっ、くっ、ああぁ……！　あひっ、くはあぁ……！　オマンコ……気持\nちいいっ……！　精子で感じちゃうぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はああ……あたしの手、いっぱい汚されちゃった……見て……あんたの精子\nで、真っ白になってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「こんなに汚して……ふふふっ。相当気持ちよかったみたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「このままだと、ニオイが染み付いちゃいそうだわ……もしそんなことになっ\nたら、どう責任取るつもり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「その時は、手だけじゃなくて身体やオマンコも、精子のニオイでいっぱいに\nするって……な、なに言ってるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00002802_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そんなことされたら、出歩けなくなるじゃない！　バカなこと言ってないで\n、もっとまともな責任の取り方を考えてよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
