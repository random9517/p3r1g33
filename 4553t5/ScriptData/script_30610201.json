{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「お疲れ様です！　隊長、お呼びでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「言われた通り水着を着てきましたけど……こんな感じでよかったスか？　問\n題ないっスか？　よかった、安心したっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「それで今日はなにを……パワーアップ？　ああ、いつもやつスね。了解っス\n、じゃあすぐ準備するっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　なにしてるって、いつものヤるんスよね？　だから裸になろうと……\nえ？　水着のまましないと意味ない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……そういうもんなんスね。じゃあ、このままで……はい？　胸でご奉\n仕っスか？　もちろんいいっスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ははーん、なるほど。だから水着なんスね……確かに脱がないでも、谷間に\n挟めますもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「というわけで、失礼します。下脱がせますから……よいしょっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　い、いや……もうこんなに大きくなってるとは思わなくて……\nすごく元気いっぱいっスね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「自分の水着姿がエロい……んスか？　エヘヘ……なんか照れるっスね……で\nも嬉しいっス……めちゃくちゃやる気になってきたっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ、隊長のオチンチン……おっぱいで挟むっスよ……んんっ、はんぅっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁっ……！　あふっ……すごいっス……なんかいつもより大き\nくなってないスか？　んっ……それにめっちゃ熱いっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おっぱいで挟むと……肌に直接伝わってくる……んっ、はぁあっ……硬い、\nス……鉄の棒みたいになってるスよ、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「もちろん知ってましたけど、こんなになるんスね……男の人って、すごい…\n…あんっ……うぅ、いつ見ても……卑猥な形してるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひぅんっ！　な、なんスか、急にビクンって……今、なんか震えたっスよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「えっ、あ、あぁ……気持ちいいんスね……よかった……水着だから余計に興\n奮する？　そうなんスね……正直なオチンチンっスね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「わかってるっス。すぐもっと気持ちよくします……から……んっ、んしょっ\n……はぁ、はっあぁ……待ってて、くださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「こうやって、おっぱい揺らして……オチンチンを擦りあげる……こんな感じ\nっスよね？　ふっ、んぅっ……気持ちいいスか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あはっ、よかった……感じてるんスね……じゃあ、このまま続けるっスよ…\n…んっ、んんっ……はふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……んっあっ……どんどん熱くなってるっスね……自分のおっぱいで、\n感じてもらえて嬉しいっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「もっと強く挟んでいいんスか？　わかりました……んんっ……はぁ、はあっ\n……これくらいっスか？　もっと強く？　了解っス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はうっ……んはっ、あんっ！　あんっ……！　ンっ、なんか、先っぽ\nがヌルヌルしてきたっスよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「我慢汁っスよね、これ……なんか早くないっスか？　いや、問題はないっス\nよ……むしろ嬉しいっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　自分の乳首も勃ってる……？　そんなことは……うわっ、ホントじゃ\nないっスか……ううっ、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「だ、だって……隊長のせいっスよ、これ……こんなに強くおっぱい擦りつけ\nてたら、こうなっちゃうに決まってるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「い、言い訳じゃないんスけどぉ……うぅ、わかりました……続けるっス……\nはっ、ふぅんっ……ンっ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んっんんっ……！　我慢汁……どんどん溢れてきます……自分のおっぱいま\nでヌルヌルになってきてぇ……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はあっ、はあっ……うぅっ……胸が熱いっス……隊長のオチンチンのせいで\n……はふっ……こっちまでエッチな気分になってくるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひぃうっ……んあっ！　あっ、ふうっ……！　パンパンに膨らんだカリが擦\nれて……くぅぅっ……んっんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あぅ、なんかエッチな音が……あンっ……あぁ、ヤらしいっス……はぁ、は\nぁぁ……あうっ、力が上手く入らない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はうっ、ううっ……おっぱいがベトベトしてきて、滑るせいで……んっ……\n変な擦れ方しちゃうっス……ひぃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「それに匂いも……どんどん強くなってるっス……あの、もしかして……もう\n出そうになってるとか……？　あぁ、やっぱそうっスか……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「大丈夫っス……スパートかけるんで……隊長の好きな時に、出してください\n……はっ、んっ……あぅ、んはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっあふっ、んあっ……！　オチンチンが、おっぱいの中で震えてて……は\nぁ、あぁっ……あうっ！　んっ……んんぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「イ、イキそう……スか？　あっ、あふっ……たいちょ、うっ……くっ、ひっ\nうっ……あっ、ああっ……あんぁぁっぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひぃぐぅぅぅぅぅっ！　あぁっ、あううっ……で、出てるっ……！　オチン\nチン暴れてっ……んひっ、ひぃあぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ふぅうぅっ……す、すごいっス……熱いのが、ドクドク出てきてるっ\nス……んっ、はぁあっ……くっはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁー、はぁっ……はぁっ……うぅ、やっぱ匂いもすごいっスね……はふぅ\n……ここまで匂ってくるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……隊長のザーメンが、おっぱいにべったりはりついて……ンっ……う\nぅぅ……ドロドロじゃないスか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あ、あの……隊長、もう射精終わったんスよね……？　えっと……でも、オ\nチンチン大きくなったままっスけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「もう一回スか？　本当にタフっスね……自分はもちろん大丈夫スけど。じゃ\nあ、このまま続けるっスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぅあっ……あっ、あんっ……本当にオチンチン硬いままっスね……んっ、\nゴツゴツしてて……たくましいっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「自分のおっぱいが気持ちいいからっスか？　お世辞でも嬉しいっス……隊長\nに喜んでもらえるなら、頑張りますから……んっ、ンンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……お世辞じゃなくて本当にっスか？　うぅ、嬉しすぎて、身体中\nが熱くなってくるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「もっと隊長を気持ちよくしてあげたいっス……どうしたら、感じるか教えて\nください……んっ、ンっ、ふぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「強くしたり、弱くしたりするんスか？　えっと……こんなふうに……んんっ\n……ふぅ、んっ……どう……あっあんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「いい感じっスか？　了解っス……じゃあ、続けるっス……隊長もまた射精し\nそうになったら、いっぱい出してくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぅっ、んっ、あうっ……ずっと乳首が勃起しっぱなし？　もうっ……恥ず\nかしいから、言わないでくださいってばぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「エロくていいって言われても……気になって、ご奉仕が……あっ、あふっ…\n…集中力の問題スか？　ううっ……わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「頑張って、ご奉仕しますけど……そんな露骨にジロジロ見られたら、照れる\nっスよ……あっ、あうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はっあぁっ……き、気にしなくていいって言われても……無理っスよぉ……\nだって、隊長に見られてたら……意識しちゃうっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ううっ、自分の気持ち知ってるくせに……からかわないで欲しいっス……も\n、もうっ……急に可愛いとか言わないでくださいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あー、ダメダメ！　余計なこと考えてたら集中できないっス……隊長も変な\nこと言ってないで……早く出しちゃってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「自分も、頑張るんで……はっ……あふっ……んっ、おっぱいで……こうやっ\nて、隊長のオチンチンを……ぐいぐいって、扱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぅうっ……！　ほら、今ビクビクって震えたっスよ……感じてるんスよね\n、これ……んっ、はぁぁっ……はぁ、はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「い、息荒いのは……隊長も同じじゃないっスか……射精しそうになってるん\nでしょ？　くっ、ふうっ……正直になってくださいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……オチンチンも、どんどん熱くなってるっスよ？　匂いもキ\nツくなってますし……んっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そろそろっスか？　自分はいつでも大丈夫っスよ……ちゃんとおっぱいで受\nけ止めますから……いっぱい出して欲しいっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あああっ！　た、隊長まで……腰動かしたら……あんっ！　自分が上\n手くできないっス……んっんっ……あっあふうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「こ、このままおっぱいで挟んでるだけでいいんスか？　わ、わかりました…\n…あっ、ああっ！　オチンチンが擦れて……熱いぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長ぉ……自分まで胸が……ひぐっ！　んっ、ンあっ！　あっ、あっ…\n…あうっ、はっはうぅっ！　んんうぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひぐっ！　んっあああぁぁぁぁぁっ！　あっ、あううっ……すご、いっ……\nまたおっぱいの中で……オチンチンがっ……ンンぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「びっくん、びっくん跳ねて……ザーメン吐き出してるっ……うっうぅっ、あ\nぁっ……さっきより勢いが……あ、あっ……ひぃうぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あうっ、あっあんっ！　どんだけ続くんスか、これ……ヤバいっスよぉ……\n量が多すぎて、おっぱいから垂れてきてるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……はーっ、はぅぅっ……あふぅ、うぅんっ……お、おわり、スか\n……？　すっごくたくさん出たっスね……ふぅぅ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「気持ちよかったスか？　確かに、これを見たら……答えは聞かなくてもわか\nるっスね……でも、隊長の口から言って欲しいっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ご奉仕頑張ったんで、これくらい甘えてもいいじゃないっスか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「エヘヘ……隊長のために頑張ったっス。満足してもらえて、自分も嬉しいっ\nス。はあ～、なんか幸せな気分スね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「水着がよかった？　じゃあ、また水着でご奉仕しますから、楽しみにしてて\n欲しいっス。自分も自信がついたんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　今度はもっと派手な水着で……？　えっと、今回のも結構派手だと思\nうんスけど……さらにってことスか？　仕方ないっスね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「もちろん恥ずかしいっスけど、隊長の頼みだから。それだけ頼りにされてる\nってことスからね～、自分もやりがいがあるっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいぃぃぃぃぃぃっ！　ちょ、ちょっ……ひうっ！　なんで急に……ひ\nっ、ひぐっ！　ひぃああぁぁぁ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「なんで、オチンチン抜いちゃうんスかぁ……おっぱいにかかって……あっ、\nあうっ……うぅんっ……あ、熱いぃっ……くふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひゃう！　んっあっ！　胸がベトベトになって……うぅっ……水着にぶっか\nける？　わ、わかりました……受け止めるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はっあぅ……すごい勢いスね……おっぱい飛び越えたり、してるっ\nスよ……あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204404" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そ、そんなに興奮するんスか……自分を、こういうふうに……精液まみれに\n……するって……いや、隊長がしたいならいいんスけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぅうっ……これで全部っスか……？　本当にすごい量っすね……さっきの\nも残ってて、おっぱいがドロドロのぐちょぐちょっスよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00006102_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　自分も興奮っスか？　まあ……正直言えばちょっとしたっス……こん\nなに隊長が気持ちよさそうに射精してたんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あう……う、嬉しいっス……ありがとうございます。隊長に褒めてもらえて\n、幸せっス！　頑張ったかいがありました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「またお願いしたい？　もちろん、いいっスよ！　隊長のお願いなら、いつで\nもご奉仕するっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「み、水着っスか……？　今度はもっとヤらしいやつ……？　はぅ……恥ずか\nしいっスけど……用意しとくっス……だからまた呼んでくださいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_0204410" ]},
		{"command":[ "WAITINPUT" ]},
