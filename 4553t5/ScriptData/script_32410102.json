		{"command":[ "SETIMAGE", "0", "still_00024101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうじゃ、お主の逸物が……よすぎるのじゃ……は、あぁ……挿入れられた\nだけで、果ててしまいそうなほどじゃ……ひぃあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それなのに……こんな、激しく……腹の中、かき回されて……奥、突いて、\n突いて……突きまくって、きてぇ……こんな……堪らぬぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……おぬしの逸物……どうして、こんなに……感じてしまうの\nじゃ……あっあっ、んぅんっ！　はぁぁ……はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「で、出そうか……？　んんっ……よい、ぞ……存分に妾の中に出すがよい…\n…くっ、ひぃいっ！　あっ、あっ……あっああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「一緒に……果てて……果て、てっ……んっ、んんっ！　もう、耐えられぬ…\n…はっんっ、んぅっ……はぁぁぁっぁあ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひっいいいっ！　んっ、んんんぅぅぅ……！　あっ、あふぅっ……！　出て\nる……んんっ……奥で、子種汁が……出て、るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、あぁあ……逸物が、中で跳ねて……ひうっ！　ひっ……ひい\nっ……あはぁんっ……す、すご、いぃ……んぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まだ、出ておる……ではないか……くっ、うぅんっ……中が、子種汁で溢れ\nておる……赤子を、孕んでしまう……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁ……なんというおそろしい逸物じゃ……あっという間に果てて\nしもうたわ……んんっ……まだ、ふわふわしておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おお、すまぬな……膝に力が入らぬのじゃ……おぬしが支えてくれ……ふぅ\nう……はぁはぁ……ああ、よかったぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしも、満足してくれたか……？　どうやら……逸物はまだ足りぬという\nておるようじゃが……もっとしたいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうじゃな……妾も、もっとおぬしと繋がっていたい……なんじゃ、\n妾をあなどるでない。これくらい大丈夫じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしとなら……何度でもできるわ……ひぃうっ！　逸物が、また……大き\nく、なっておる……はぁあ、う、動いてよいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「さすがじゃな、若いだけある……んっ、はあっ……果てたばかりなのに……\nいきなり、激しく……はっ、はぁあ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、あふぅ……妾だって、全然足らぬわ……一度や二度まぐわっただけ\nでは、満足せぬぞ……はぁあぁぁ……あ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしの、逸物から……一滴残らず搾り取ってやるから、覚悟せよ……んっ\n、あっ……ほれ……めこを、締めてやるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「どうじゃ？　気持ちよかろう？　果ててしまいそうなら……我慢せず、出し\nてしまってよいぞ……んんっ、はっ、ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、はぁあっ！　もう、慣れてきたからのう……多少、乱暴にしても大丈\n夫じゃ……んっ、ああっ、妾の方がお姉さん、じゃからのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……はぁあっ！　ち、乳……？　あぁ、そうじゃな……おぬしが\n強く腰をぶつけるから……乳が揺れて……んっあぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、これがよいのか？　んうっ……まったく、おぬしも好き者じゃな……\nあっ、あふっ……まあ、よい……好きに楽しむがよい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっあっ！　あふっ！　ひゃあっ……！　声は、仕方なかろう……んぅあ\nっ……！　おぬしが、激しくするから……勝手に出てしまうのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「誰か、来ると……困るが……んっ、んぅうっ……できるだけ、声は抑えて\nみるが……強く、中をかき回されると……我慢できぬぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫とは……なにが……あっあふっ、全然大丈夫ではないぞ……こん\nなっ……ひぃうっ！　はっ、あぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「すぐに妾を果てさせるじゃと？　な、生意気な……くひぃっ！　あっ、あぁ\nぁぁっ……そこ、だめじゃ……そこ弱いのじゃっ……！」", "NORMAL" ]},
