		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くふふ……どうしたのじゃ？　そんなに鼻息荒くしながら、抱きついてきて\n……まるで、けもののようじゃぞ、おぬし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「これは異なことを……妾のせいか？　ほう……妾の服がえっち、とな？　\nそうかそうか、おぬしには妾の身体は目に毒じゃったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「だからと言うて、いきなり抱きつくのは感心せぬのう……妾だからよかった\nものを……他のおなご相手にやってはいかんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なに？　理性を失ったのは初めて？　ふふっ……口が上手いのう。まあ、\nよい……妾もおぬしに抱かれたい気分じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「違うのか？　抱きつくだけでよいのか？　どうしてと言われても……さっき\nから尻に当たっておるぞ、おぬしの硬くなった逸物が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それにのう……こうして男と女が、ふたりきりで会うておるのじゃ……こう\nいうこと、期待するに決まっておろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうじゃ。おぬしなら、よいぞ……んっ……これ、慌てるな。ゆっくりで\nよい……妾は逃げぬ……それより辺りに誰もおらぬな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ、ならよい……このまま、ここでまぐわおうぞ……ほれ、おぬしの逸物\nを……ここへ……妾の中へ……くるがよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、んんぅっ……は、あぁ……！　挿入って、くる……なんじゃ、大丈夫\nに決まっておる……おぬしの逸物くらい、しっかり咥えてやるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「年下のくせに余計な気をつかわなくてよい……ただ、まあ……経験の少ない\nおなごを相手にするなら、その気遣いは大切じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾は、お姉さん……じゃからな……ふふ、おぬしの抑えきれぬけもののよう\nな性欲を……ちゃんと受け止めてやるから安心せい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、動いてよいぞ……おぬしの好きなようにしてみよ……んっ、あっ、\nあふっ……なんじゃ、やけにゆっくりじゃのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ああぁ……やらしい、腰使いじゃ……ねっとり、と……妾の中を逸物がかき\n回しておる……うっ、んぅっ……はあっ……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「う、うむ……んあっ……き、気持ちよいぞ……やはり、おぬしの逸物は……\n堪らぬ……んぅ、はぅっ……ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そういうおぬしはどうじゃ……？　妾の中は……気持ちいいか？　んんっ…\n…これ、逸物で返事をするな……くあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……あんっ……ちゃんとおぬしの口で、言って欲しいのじゃ……\nんっ……あうっ……そ、そうじゃ……うむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「いいのじゃな……妾の中、気持ちいいのじゃな……んんっ……嬉しい、ぞ…\n…妾もじゃ……妾も気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ……！　こ、これ……ワザとらしく、音をたてなくてよい……さっき\nから、聞こえておる……ああっ！　んっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そ、そうじゃ……おぬしの逸物が、よすぎて……めこがよだれを垂らして\nおるのじゃ……あ、ふぅ……あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「奥まで……んっんんっ！　はっ……あぁっ……逸物が奥まで届いておる……\nんっ、やや子の部屋を……突っついておるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっあっ、あぁっ……逸物がまた大きくなっておる……な、中で……膨ら\nんで……くひっ……擦れて、おる……んんっ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……どうじゃ……もう果てそうなのではないか？　まだ挿入れた\nばかり……？　それはそう、じゃが……ひぃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬし、逸物……ひくひく震えておるぞ……んっ、腰振りながら……息、\n弾んで……あっ、あふっ！　はぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾のことはよい……おぬしがやりたいように、やればよいのじゃ……あんっ\n……はぁっ、あぁあ……そ、そこぉ……おくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ！　んふぅ！　奥を……突くの……感じるのじゃ……腰を打ちつけら\nれるたび……果てそうになってぇ……ひぃあっ！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、このままでは……妾だけ、果ててしまうのじゃ……おぬしも、おぬしも\n……一緒に果ててくれ……一緒がいいのじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……！　くっ、ふうっ……な、情けないのう……妾が、おぬしを\n導いてやるつもりじゃったのに……んっ、ああっ！」", "NORMAL" ]},
