		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ちゃんと……おぬしも、感じておるのか？　んんっ！　そうじゃな……逸物\nは今までにないくらい、大きくなっておる、のう……」", "NORMAL" ]},
