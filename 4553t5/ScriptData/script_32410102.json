		{"command":[ "SETTEXT", "「あっ、あん、あぁんっ！　くひぃっ！　も、もう……だめじゃ……わ、妾…\n…立っておれぬ……ひぐっ、ひっ、ひぃいぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃうっ……ひっ、ひぃいっ！　ああっ、あぁあっ……な、なか……よす\nぎて、痙攣しておる……めこが、とろけてしまうぅ……んあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あぁあっ！　おぬしも、早くっ……んぅんっ！　い、一緒に果てておくれっ\n……妾を孕ませるくらい……中に、子種汁を、おっおおっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くひぃっ！　んひっ、ひんっ……！　はっ、はっはっ……す、すごいっ！　\nあぁっ！　あ、くっ……果てる、果ててしまうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ、あんっ！　あんあんっ！　あっ、あっ……あひっ、ひっ\nあっ……あっああぁ……あっ、あぁぁぁぁ～～～～っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひぃうううっ！　あっはぁぁ……！　また、出てるっ！　んんっ、あっ……\nくぅうっ！　お、おくっ……んあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……あついっ……子種汁、熱くって……ひぃうっ……はああっ、\nあんっ……逸物、がっ……んひぃいっ！　あっあんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おくを、突きながら……熱いの、吐き出してるっ……！　くひっ、ひいいっ\n……はぁああっ、あふっ……だ、だめじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「果ててしまう……あ、頭が、真っ白になってぇ……あっ、あぁあ……なにも\nかも、とろけてしまいそうじゃ……んっ、ひぃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「さっき、あれほど出したのに……まったく勢いが、おとろえておらぬ……ん\nんうっ……わ、若いとはいえ……すさまじい、量じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くうっ……まったく、本気で妾を孕ませる気か、おぬしは……んっ、んんっ\n……あぁ……はぁ、はぁぁ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「くっ、はぁ……そうじゃな……言わなくても、わかるわ……気持ちよさそう\nに、ぶちまけておったからのう……おぬしは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ～……はぁ……う、うむ……妾も、気をやるほど気持ちよかったが…\n…やや子ができたら、どうしてくれるのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾を娶ってくれるのか？　まあ、それもよいかもしれぬ……昔から『年上の\n女房は金(かね)のわらじを履いてでも探せ』とも言うしのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「わざわざ探す手間がはぶけてよかったのう。妾はよい女房になると思うぞ…\n…どうじゃ、その気になってこぬか？　ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっあああっ！　な、なにをっ……ああぁっ！　逸物が、抜けて……！　\n抜けるっ……ひっ、ひぃいいいっ！　あっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……あ、熱いぃ……！　ひんっ……きゃっ……ひゃうっ！　\nかかってっ……！　子種汁がっ……んんっ！　んひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ひゃああっ……！　あっ、あひっ……！　おぬし、なにを……これっ……\n聞いておるのか……んんっ！　あっ……あはぁ……あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿者ぉ……んっ、はぁ……身体中にかかっておる、ではないか……\nんっ……はぁ、はっ、あぁぁ……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしの匂いを、妾の身体に……うつすつもりか……犬みたいなことを考え\nつくやつじゃのう……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても、なんじゃこの量は……さっき出したばかりというの\nに……それだけ妾の中が気持ちよかったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ、そう言ってくれるのは嬉しいが……こ、これはやりすぎじゃ……早く\n風呂に入らぬと……本当にしばらく匂いが取れなくなってしまうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「嫌なのか……と言われても……おぬし、その聞き方はずるいぞ……妾を自分\nのものだと言いたいなら、それなりに男を見せてもらわねば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「な、なぬ……？　これから、毎日？　仕方ないやつじゃ……いくら若いと\n言っても毎日まぐわいたいとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしのような発情猿を受け止めきれるのは、妾くらいしかおらんじゃろう\nな。感謝するのじゃぞ？　まったく……」", "NORMAL" ]},
