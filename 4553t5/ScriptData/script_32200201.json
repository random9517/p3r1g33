		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「いつもと違うこのドレスだと……なんだかもっと大胆になってしまった感じ\nがします……」", "NORMAL" ]},
