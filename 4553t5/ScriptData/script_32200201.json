{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「き、来ちゃいましたね……その、ちょっと緊張しちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00022002_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「こんな二人きりでなんて内緒ですよ……？　でも、日頃お世話にもなってま\nすから……今日はリラックスしてもらって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい、そちらに。あの……一応、リクエストとかありますか？　出来る範囲\nでしたら、させてもらって……パ、パイズリ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「やっぱりお好きなんですね……分かりました。では、えっと……もう少し足\nを開いてもらって……正面から失礼しますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……もう、こんなに立派になって……んっしょ……ふぅ……何\nとか入ってくれました……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022002_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「すごい……とくんとくんって……元気に脈打ってますね……んっ、ふふ……\nあんまりおいたしちゃダメですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「大人しくしていれば、たっぷり気持ちよくして差し上げますから……んっ、\nあふっ、んんっ……ふっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「柔らかいですか……？　ふふっ、ありがとうございます……このチャイナ衣\n装……少し恥ずかしいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも……着たままでも、ご奉仕できるのは……ちょっとだけ便利かも知れま\nせんね……んっ、うん……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もし、ご注文があればなんなりと仰ってくださいね。なるべくご期待に添え\nるように頑張りますから……はっ、ふっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「力加減とか、擦れる場所とか……私も慣れてるわけではないので、かなり手\n探りというか……おっぱい探りになってしまいますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「でも……ふふっ、お顔がとろっと気持ちよさそうにされてるみたいですから\n……この調子で続けてよさそうですね……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「亀頭さんが、ちょうど顔を出したり……引っ込んだり……大きさはとても立\n派ですけど……ちょっと可愛いですね……あふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「気持ちいいですか……？　よかった……私も……んっ、こんな風にして差し\n上げるのは……好き、かも知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「何かと邪魔になることも多いおっぱいですけど……こんな立派なオチンポに\n喜んでもらえるなら……もっと頑張らないとって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……あんっ……やだ……乳首……そんなにじっと見られると恥\nずかしいです……いやらしく動いちゃってるのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「照れ顔が見たいって……もう、意地悪ですね……んっ、そんな悪いオチンポ\nには、こうですっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ほら……ぎゅってしちゃいましたよ？　んふっ、揉みくちゃにされて……ま\nた顔が緩んじゃってますね……ふっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……はぁ……おっぱいも……汗で滑って……気持ちよく擦れて\nます……あふっ、あぁっ、んっ、そろそろ、でしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もう亀頭さんも、待ち遠しくなってるみたいですし……お口でも……しちゃ\nいますね……あぁんむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぷっ、ちゅぷっ、んちゅぽっ、くぷぅっ、りゅぷっ、んむっ、んちゅぷっ\n、じゅぽっ、んちゅるっ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……おおきぃ……んりゅっ、ちょっと汗の味が……んりゅっ、れろ\n……ちゅぽっ、もごっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「このままれ……おっぱい……動かひまふね……んりゅっ、はぷっ、んちゅぷ\nっ、れりゅぅぅ……れる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふっ、舌と……おっぱい……同時に動かすの……難しいれふ……ちゅぷっ\n、んちゅるっ……はぁ、んりゅっ、れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「今は……んっ、ちゅぽっ、とにかく……おっぱいを押し付けて……先端を…\n…ちゅぅぅぅっ、吸い上げて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、感じてくださってますね……オチンポの震え方……もう、何と\nなく分かってしまいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……私ったら……あの人のオチンポよりも、彼のオチンポのことの方が\n分かるようになってしまってるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「い、いえ、何でもありませんわ……んっ、もっとオチンポ……おっぱいの中\nに挟み込んでしまいますね……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あんっ、はぁっ、んっ、んふっ……ちゅるっ、んちゅぷっ……ちょっと滲ん\nできましたね……カウパーさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ちゅるっ……出したい時は、遠慮なく仰ってくださいね……ち\nゅぷっ、その、どういう風にしてもいいですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はふっ、んっ、あぁ……ヌルヌルします……んっ、くちゅくちゅ……音がし\nて……あぁ、私……どんどん大胆になって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んちゅるっ、ちゅぽっ、んふっ、くぽっ、ふむぅっ……オチンポが震えて…\n…おっぱいの中でムズムズしていますわ……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、りゅぷっ……あぁ、でも……本当に逞しい……熱くて硬いのが、\nずっとおっぱいの中にいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……こうやって、何度も押し付けているだけで……あぁ……私まで感じ\nちゃいます……あふぁ……はっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もっと……んっ、ちゅぷっ……あぁ……いっぱい動かして……はふっ、んん\nっ、あんっ、オチンポっ……もうすぐですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あがって……はいっ、んふっ、ちゅぷっ……飲ませて……下さい……新鮮な\n精液っ……いっぱい飲ませてっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぷっ……！　んんっ、ふぐっ、んっ、んくっ……出まひた……んんっ、ん\nっく……ちゅぷっ、あふっ、こんなにぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んじゅるっ、やだ……わたひったら……品のない啜り方を……ん\nじゅるっ、でも、ちゃんと飲まないと……んく、ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅぅ……んはっ、はぁ……あふっ……はぁ……んっちゅ……ちゅぱ\n……ふぅ……何とか全部飲めました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、喉にまだ絡んでる……すごくつぶつぶが粘っこい感じで……\n本当に濃かったですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふ……でも、まだまだオチンポは全然小さくならないのね……やっぱり若\nいっていいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「い、いやだわ……私ったら、変なことを……何でもないんです。あの……そ\nれで、よかったら……もう少し続きをしましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「その、まだオチンポ……出せちゃいますよね……？　射精のお手伝い……続\nけさせてもらっても……よろしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はい……それでは、このまま……おっぱい、また動かしていきますから……\nんっ、あふっ、んくっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……すごい……あんなに射精した筈なのに……さっきより硬くなってる\nような……ツヤツヤして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「滑りもよくて……んっ、あぁ……ちょっと乳首……擦れちゃいます……あふ\nっ、んんっ……だ、ダメです、ずっとはしませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「その代わり……ちゃんと、おっぱいで……喜んでもらえるようにしますわ…\n…んふっ、はぁっ、んっ、また……咥えちゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「くぽっ、りゅぷっ、んちゅぷっ、くぷぅぅっ……はぁんむ……ぴちゃ、んち\nゅぷ……ちゅぱ……れろ……えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、さっきの精液がまだ残ってる……んちゅっ……この味、もう\nすっかり覚えちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あの人のよりもずっと濃くて……あぁ、ダメよ……私……比べるなんてそん\nなこと……ちゅぷっ、あぁ、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「このオチンポの味を知ってしまうと……ちゅぷっ、いろいろ目覚めちゃいそ\nうなの……はぁ、んりゅっ、れろ、ぺろ……えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「舌の動きがいやらしい……あぁ……仰らないで下さい……その、自然にして\nしまうんです……ぴちゃ、れろ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「このオチンポを味わってしまうと……はぁんむっ、どんどん舌が伸びて……\nんちゅぷっ、唾液が口いっぱいに広がってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、あぁ……ダメ……美味しいなんて思っちゃ……あぁ……んちゅぷ\nっ、でも、貴方の気持ちよさそうなお顔を見ているともう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふっ、おっぱいも……止まらない……んっ、あふっ……ち、乳首まで……\nこすり付けて……はぁっ、私も……感じ過ぎてっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「うんっ、あぁっ……じゅるっ、新しいお汁も……じわじわ……浮き上がって\nます……んちゅぷっ……また出したくなってますね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もちろん分かります……いいですよ……遠慮しないで、またいっぱい出しち\nゃいましょうね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んふっ、また……飲ませていただけますか？　りゅぷっ、それと\nも……私の顔に……お掛けになりますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、はい……もちろん、お好きなように……んふっ、これは貴方に喜\nんでいただくためのご奉仕ですから……んじゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「このまま、オチンポ……思いっきり感じてっ……んじゅるるっ、出して……\n下さいませぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ！　んんっ！　むぐっ、あぁっ……ふごい……また、こんなに\nぃっ……んんっ、んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっく……あぁ……どんどん溢れて……飲みきれない位……んんっ、こくっ\n、んくんっ……こくっ、んっく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……じゅるるっ……んぐっ、こくんっ……ダメ……こぼれちゃう……ん\nちゅるっ、んっふ……じゅぽっ、んちゅぽぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ、あふ……やだ……私ったら……品のない吸い方をしてしまって……は\nぁ、はぁ……でも、何とか零さずに飲めましたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「オチンポ……出し切れましたか……？　良かった……お疲れ様でした。あっ\n……まだです……ちゃんと綺麗にしないと……ちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ、ちゅぱっ……んっちゅ……ぴちゃ……んちゅぷぅ……はい\n、これでいいですわ……ふふ、どういたしまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……まだ口の中に精液の味が残ってます……ぺろ……んっ、本当に濃厚\nで……素敵でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ……でも、私ったら……いつも以上に大胆にしてしまったような……は\n、恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「こんな、誰とでもこんな風になるなんて思わないで下さいね？　日頃お世話\nになっていますし……特別なんですから……」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「その……内緒ですよ？　どうか、二人だけの秘密で……そうしたら、また機\n会がありましたら……その時はよろしくお願いしますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぷぁぁっ！　あっ……顔にっ……はい……んっ、いっぱい掛けて下さい…\n…おっぱいで押し出しますから……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ふぁ……ねっとりしたのがへばりついて来ます……あぁ……すごく濃いの…\n…染み込んじゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、マーキングされてる……あぁ……こんな、匂いでバレちゃう……あ\nぁ……んふぅ……ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「やだ……私……つい欲しがってしまって……れろ、んちゅっ、あぁ……お味\nも濃いまま……素敵です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁ、あふっ……射精……出し切りましたか？　んふっ、本当に沢山出され\nましたね。はい、お疲れ様です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022002_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あ……今、お掃除もさせてもらいますから……そのまま楽になさって下さい\n……れろ……ちゅぱ……んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁ……こうして、精液を味わっていると……もう、それだけで……ちょっ\nとイッてしまいそうで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あふっ……は、はい、これで終わりです。んちゅぷっ……お疲れ様でした…\n…んっ、喜んでいただけたなら何よりですわ」", "NORMAL" ]},
