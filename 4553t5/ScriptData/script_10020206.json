{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここは……！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ハルカプトラたちに連れ込まれたのは、地下に広がる洞窟のような空間だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんなんだよ、ここは……この学園に、こんなところがあったのか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カツマ先生！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つきみ！？　おまえ、こんなところでなにやってんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いったいどうなってんだ？　と思ってまわりを見渡してみると、洞窟の中には\nつきみやルルーナたち、さっき教室にいたメンバー、そして――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それ以外にも大勢の生徒たちが集められているようだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんなんだ？　ここは……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あなたも、連れてこられてしまったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「連れてこられた……？　っておまえら、誰に連れてこられたんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ハルカプトラの部下たちだよ。あいつらのデッキ、すっげぇ強いんだもん\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからって、教師が学生に連れてこられてんじゃねえ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なんでもいいわ！　なんだか面白そうじゃない、ここ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえはいいなあ、能天気で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "などと言っていると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆さま。ハルカプトラ七世陛下のお出ましですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、ジュンジローてめえなにやってんだ、そこで！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さては、さっそくハルカプトラにゴマすって取り入りやがったな……！？　ホ\nント節操のねえ駄犬だよ、まったく！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「よく来た、皆のもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "洞窟の奥に作られた台の上から、ハルカプトラが言う。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ここは我が領土。王たる我が主催する『カードゲーム地下闘技場』である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113180002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カードゲーム地下闘技場～！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "また妙なことを言い出したぞ、このポンコツファラオ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「貴様たちは毎日放課後、ここでカードゲームによる死闘を演じ、我を楽しま\nせるのである。それが貴様たちの役目である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113180003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにわけのわかんねえこと言ってんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あのー、私、宿題やらなきゃいけないんで帰っていいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113180002" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私だって帰りたいわ！　お腹が空いたし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「一回職員室に顔出してこなきゃいけないんだけどなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113180002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうね！　わたしも帰ってテレビ観たいなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113180002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちが文句を言うと、周りの生徒たちもつられて騒ぎだす。ハルカプトラは\n黙ってその騒ぎを見つめていたが――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しばらくして、珠魚が台に上がってきて、言った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0115" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ブチ泣かすぞ……ゴミめら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "学生たち" ]},
		{"command":[ "SETTEXT", "「ざわっ……ざわざわ……ざわざわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113180003" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「キミたちを下校させるのはたやすい。だが、ここで帰ってどうなる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ちゃんと帰らせろよ。もうすぐ下校時刻なんだから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「キミらは対戦で負けに負け、いまここにいる。誰からも愛されることなく、\n学園内対戦ランキングの底辺を這って這って、這いまわっているのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "学生たち" ]},
		{"command":[ "SETTEXT", "「ざわっ……ざわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113180004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだよランキングって。いつの間に作ったんだよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「キミらがいまなすべきことは勝つこと！　勝ってここから抜け出ること！　\n心に刻め！　勝つこと！　勝つことだけが全てだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「勝たなきゃゴミ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113180005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113180005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「フフフフフ……勝たなければ、勝たなければ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「って言われてもなあ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113180005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あ、あれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180008" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「勝たなきゃゴミって、おかしいんじゃない？　ゲームなんだから、勝つこと\nも負けることもあるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010113180006" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうよ。勝ったり負けたりしないと、面白くないもの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113180005" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あ、あれ？　あれ？　えーと……あのね？　そういうことじゃなく、あの…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180009" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「話は終わりかー？　それじゃみんな、そろそろ帰るぞー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113180006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あ！　ちょっと待って！　あのね！？　あのね……！？　勝ったら！　もし\n勝ったら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180010" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「本日優勝された方には、ブースターを３パック！　無料でプレゼントいたし\nますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180011" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "学生たち" ]},
		{"command":[ "SETTEXT", "「ざわっ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00000106_01", "3", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00000403_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00002402_01", "3", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そういうわけなんで……ちょっと遊んでかない？　ねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180012" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113180007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113180007" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180013" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なんだよー！　それを早く言ってくれなきゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030113180008" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あ、あはははは……皆さん、現金なことで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180014" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ということで、学生たち（一部教師も含む）は、賞品が出ると聞いたとたん、\n大はしゃぎで対戦相手を探し始める。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ま、いいか。少しぐらい珠魚や学生たちに付き合ってやっても。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「カツマ！　対戦しましょ！　教室では、私と対戦してないもんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113180008" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、そうだな。それじゃお願いしようか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、いうわけで俺もマーガレットと対戦を始める。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「フフフフフフ……まんまと引っかかってくれたね。ゲームに夢中になってく\nれれば、こっちのもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113180015" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

