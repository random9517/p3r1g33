		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あ、当たり前じゃない……いくら、周囲に人がいなくても……こんなお日様\nの下で、よ、四つん這いなんてポーズ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「しかも……大切な所は……ぜ、全部貴方に見せてしまっていて……どうなっ\nているかも、全部分かっているのよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そ、そうよ……私のオマ〇コ……もう、すっかり濡れて……疼いているわ…\n…貴方のオチ〇ポを入れて欲しくて……こうなっているのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こんなこと、わざわざ言わせるなんて……やっぱり貴方は意地悪だわ……ん\nぁっ、あっ、ダメ……そこ触っちゃ……あ、あひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……指……あっ、あぁんっ、いや……ク、クリトリス……弱いのにっ…\n…んんっ、転がさないで……あ、ひぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、イヤよ……また焦らすのは……あぁ、どんどん愛液が溢れて\nくるの……見ているんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「お願いします……先端が当たっている……貴方の、オチ〇ポを……早く、中\nに……オマ〇コに入れて……下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……もう、身体が待ちきれなくなってるの……分かるでしょう？　はぁ\n……んっ、ほら……ここ……あ……お願いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、はっ、ああぁぁぁぁぁぁぁーーーっ！　来たわっ……んくぅ\nっ、太い……オチ〇ポッ……入って、来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅ……あぁ……いっぱいに……埋まってるぅ……中、広がっちゃ\nう……くひぃ……あっ……大きい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……くぅぅ……奥に届いた？　んんっ……えぇ……感じるわ……オチ\n〇ポがみっちり埋まってる感じするの……はぁ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ただ入れられただけでも、こんななんて……ここから、本気で動いちゃうの\nよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「い、いえ……大丈夫よ。覚悟は出来ているわ……遠慮はしないで……私のオ\nマ〇コ……深く突きこんで……んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、くぅんっ！　そ、それぇっ、あぁっ……中っ……か、かき回\nされるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、ひぁぁぁっ……やだ……あっ、私……あひっ、は、はしたない声がっ\n……んんっ、だ、めっ……止められないっ……ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫かもしれないけどっ……は、恥ずかしいっ……こ、こんな……淫\nらな姿を貴方に……見せちゃってるのっ……んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、はあっ……あぁっ……それは……日焼け止めのローション…\n…ど、どうするの……んっ、お、お尻にっ……もっと足すの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……もうたっぷり塗ってるわ……そんな、お尻撫でて……塗り拡げなく\nても……あひぁっ、指が……いやらしいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ……お尻、広げないで……繋がってる所……見えちゃうのに……あ、\nいやんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……見られてる……ぱっくり……オチ〇ポ咥えこんでるオマ〇コ……こ\nんなに間近に見られちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ダメ……意識すればするほど……身体がムズムズして……あふっ、濡\nれて来ちゃうの……あっ、んぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、深くっ……届くぅっ！　今、そんなにっ、あっ……何度も擦\nられたらっ……はぁんっ、あっ、あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「待ってっ……！　も、もうイッちゃうのっ、ひぁんっ！　あっ、強いのっ…\n…ひっ、いひぃんっ、イクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ……はぁぁっ……こ、こんなにすぐにイカされちゃうなんて……ひぁっ\n、ま、まだ……んっ、続けて……うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ……あんっ、はうっ、んっ、ふっ……あぁっ、犯されてるっ……こん\nな動物みたいな格好で……後ろからのしかかられてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こんなこと……いつもの私なら絶対許さないのにっ……あっ、ひぁんっ！　\nお尻っ……ぶたないでっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさいっ……そうよ……今の私は、貴方の為に尽くす女なの……\nオチ〇ポをよくする為に、一生懸命するからっ……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、も、もう少しだけゆっくりぃ……じゃないと、続けてイッてっ…\n…腰が抜けちゃうからっ、は、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、はっ、あぁっ……すごいっ、あぁっ、でもっ、いいっ、気持\nちいいっ！　今のっ、オチ〇ポ回されるのっ、いっ、いひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あはぁんっ、こんなっ、またイクっ……気持ちいいの上がってきてるっ、オ\nマ〇コジンジン痺れてっ、んひぁっ、ま、またイッくぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「は、あぁぁ……イッた……続けてイカされちゃった……あぁ……オマ〇コ…\n…ヒクヒクして、止まらない……くぅん……あ、ふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「でも、まだ……かき回されて……はひっ、あぁっ、も、もうすぐ……出るの\nっ？　射精……するのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ひぁぅっ……あぁ……は、はいっ、中で……だ、大丈夫だからっ……欲しい\nのっ、貴方の精液……中に欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「このままっ、イッてるオマ〇コにっ……熱いのっ、いっぱい出してっ！　は\nひぁっ、ぐっと根元まで挿し込んでっ……奥で出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃんっ！　あっ、だ、出してるのねっ！？　んぅぅっ、中っ……\n来てるっ……射精……されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「くぅぅん……あぁ、待ってね……オマ〇コで搾ってあげるから……んくっ、\n全部奥に出しちゃって……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あぁ……こんなの、初めて……あぁ……日焼け止め……汗\nで流れちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はふっ……すぐ、起き上がれそうにないわ……これ……ちょっとだけ休憩さ\nせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……私、こんなに感じやすくなってたのかしら……自分でも信じ\nられないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、あぁ……オチ〇ポ……抜けない……んっ、もしかし\nなくても……続き、するの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……えぇ、いいわ……今は、何でも貴方の言う通りにしなきゃ……いけない\nもの………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「で、でも……どうか、お手柔らかにね……あひっ！　あっ、はっ、あっ、あ\nぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁっ……イッてから……ずっと敏感になってるの……んっくぅ……オチ〇\nポの出し入れが……さっきより、はっきり分かっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んんっ、どんな風になってるか……それは……あっ、今は……んっ、わざと\n浅い所で……出たり入ったり……しているわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「亀頭が……んっ、同じ所を……何回も繰り返し……あっ、擦って……あぁっ\n……変よ……ここは、別に……特別感じる場所じゃないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「続けて……あふっ、何回もされてたら……あぁ……じわじわして……んふぁ\n……あっ、また……お尻……マッサージもされてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁ……からだ……溶けちゃいそう……力……入らない……私……本当にオ\nチ〇ポで骨抜きにされちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はんっ、あん、あっ、あぁっ、イク……ギリギリのとこっ……ずっと、され\nてる感じ……あぁっ、熱い……んくぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000306_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ……ダメよ、そんな身体中撫で回して……背中も、おっぱいも\n……あっ、あぁっ……どこも、ふわふわしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　あっ、また……オチ〇ポッ、深く……入って来るっ！　こ、こ\nこからっ……またスイッチ入るのっ！？　あひっ！　あひぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「は、激しいっ！　あぉっ、イ、イクっ……イッちゃうっ！　はひぃっ、また\nオマ〇コっ……あっ、イっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……何、この……感じ……さっきより、イッた時の気持ちいいのが\n……続いてる……私、いつの間に……こんな開発……されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぉっ！　おぉぉっ！　またオチ〇ポッ！　激しくっ……あぁっ、そんなぐ\nちゅってかき回されたらっ、またすぐイクっ、んひぃっ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「は、ひぁぁぁ……お、治まらないっ……気持ちいいままっ、まだイッてるの\nにっ、オチ〇ポッ！　と、止まらないのっ、いひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ま、またイクっ！　くぅぅぅんっ、オマ〇コイッてるっ！　ずっとオマ〇コ\nイッたままになってぇっ！　あへぁっ、はぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あぉっ、あぁっ、ずりゅずりゅっ、中っ……お汁っ、掻き出されてっ、はひ\nぃっ、オチ〇ポッ！　あっ、また……ずぶってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_0604217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「で、出るのっ！　あぁっ、貴方もっ……イクのっ！？　わ、わらひもっ……\nずっとイ、イッてるからぁっ、早くっ……来てぇっ！」", "NORMAL" ]},
