		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003104" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「私の身体で奉仕することが大事……本当なんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003105" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「えっ、こんな大胆なことをみんなしているというのですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000810_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003106" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「必要だと分かっていても……恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000810_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003107" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「別に拒否するつもりは無いのですけど……恥ずかしくてつい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003108" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「口と胸ですね……分かりました、やってみます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003109" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「隊長の……もうこんなに逞しくなって……はぁはぁっなんか身体が熱くなっ\nてきました」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_02" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003110" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はむぅっ、んちゅるりぃっ……私、上手くできているでしょうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003111" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「胸も使って……分かりました。頑張ってみますね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003112" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「こんな感じで胸に挟んで……あああっ……硬くて逞しいのがビクンビクンし\nています」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003113" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「胸でこすりながら、先端を……あむぅっ……んじゅるりぃっじゅるりぃっ…\n…」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003114" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「んぐぅっ、じゅるぅっじゅるぅっ……ふぅぁっ……先っぽから汁が出てきた\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003115" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「経験不足なので……すべてが手探りですけど……こんな感じで良いのですか\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003116" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「くっ……あまり見ないでください……は、恥ずかしいからに決まっているで\nしょ……んっ、はぁ……れろっ……んっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003117" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「目を見ながら、しないと意味ないって……そんなこと知りませんよ……はぁ\n、はぁっ……この体勢、キツいんですから……ね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003118" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はぁっ……はっはっ……んっ、早く……出して、ください……そのために、\nこんな屈辱的な行為を……わざわざしてるんですよっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003119" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「なんでこんなことを、私が……ンふっ……ふうっ……ホントに最悪……はっ\n、はぁっ……ちゅ、ちゅぶっ……ン、はぁっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003120" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「もっと強くですか？　やってますって……ほら、こうやって……胸で挟んで\n……先っぽを……舐めて……ちゅ、ちゅくっ、ちゅるるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003121" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「これより、もっと激しく……ですか……？　くうっ……わかりました……ん\nっ、んぶっ……はっはっ、んっはぁっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003122" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ンぢゅっ……ぢゅ、ぢゅるっ……こ、この……我慢汁をもっと吸えばいいん\nですね……ちゅ、ちゅくっ……ちゅぱっ、ンっぢゅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003123" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……はぁ、あぁっ、どんどん溢れてくるっ……なんですか、これ\nぇ……んうっ、んちゅうっ、ちゅううっ！　ぢゅうぅぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003124" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ンンっ！？　なんか、すごく硬くなって……胸の中でビクビクいってますけ\nど？　こ、これは……もうすぐって……ことですよね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003125" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「わかりました……このまま続けますから、早くイッてください……んっ、ン\nふぅっ……しゃせぇ、してくださいっ……あ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003126" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……急に腰を動かさないで……あっ、んっ！　んぐっ！　ん\nぐっ、ンンっ、んぶっ……ぢゅ、ぢゅううぅぅうっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003127" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「んぐぅうぅっ！　あっあぁっ……んっ、ぐっぶぅぅっ、ンぐっ……ンっ、ん\nぐんぐっ……ふっ、うぅンっ……ンンンンっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003128" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「な、なんですか……これっ……口の中に……げほっ……大量にっ、んぶっ…\n…んっ、はっあぁぁっ……んんっ、ぐぅぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003129" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「んんんっ、く、苦しいっ……んくっ、んぐっ……こ、こんな……ちゅ、ちゅ\nばっ……ああっ、んああっ……いやぁぁ……ンっあぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003130" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はっ、はうっ……ん、んくっ……ごくっ……くふっ、ふぁ……あああっ、は\nっ……あぁっ、あぁんっ……あんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003131" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ、はっはぁ……ぐっ、ぷっ……な、なんですか……これ…\n…ねばねばで……喉に絡んで……気持ち悪いぃ……んぐっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003132" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「しかも熱くて、クサくて……こんなものを飲ませるなんてぇ……うっ、ぐっ\n、ぐふっ……はっ、はあっ……あ、ふぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003133" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はあ？　出せとは言いましたけど……なにも喉の奥に出す必要はないでしょ\nっ……射精する時、無理やり口にねじ込んできて……最低っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003134" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「なんですか？　これでパワーアップ間違いなし？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003135" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「そ、それは……まあ、嬉しい……というか！　そうじゃなきゃ、やってる意\n味ないでしょう！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003136" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「それだけパイズリフェラがよかった……？　そんなこと言われても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003137" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「こんなこと褒められても、喜べるはずないでしょっ……くっ、ううっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003138" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「なんですか？　ちんぽを舐めて綺麗にするまでがご奉仕……？　これで終わ\nりじゃない……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000810_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003139" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「はぁ……わかりました……やればいいんでしょ、やれば！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_1003140" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「くっ、あんなものを飲ませておいて……まだやらせるなんて……ちゅ、ちゅ\nぶっ……ンっ、喜んでません！　黙っててください……ちゅうっ……！」", "NORMAL" ]},
