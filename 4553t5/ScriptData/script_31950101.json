{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっふっふっふ～♪　こーんなところに隠れてたんだぁ……。今夜はまだ、\nあなたに夜伽をしてるコがいないみたいだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「どぉ？　良かったら、わたしがその役目……担ってあげよっか。身体のどこ\nを使ってもいーよ……？　って、ふふふっ。君はやっぱり胸が気になるかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱい♪　いつもチラチラ見てるでしょ？　んふふふ、気づくよ\nぉ……。わたしね、男の視線にはビ・ン・カ・ンなの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んん？　別に怒ってないよ。むしろ、それらなよろこんでくれるかなーって\nモノを手に入れちゃった。じゃ～ん、ボニューデマクール！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これを飲むとね？　わたしのおっぱいの先っちょから……ぴゅっぴゅってい\n～っぱいおっぱいが……母乳が滲みだしてくるんだって。興味あるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あるっていいなさいよぉ～。あるって言ってくれたら～。飲んだげる♪\n　どうする～？　やめとく～？　やっめないよねぇ。おっぱい星人さん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「素直になりなさい？　ラケシスおねーたまのぉ～えちえちおっぱいに興味が\nあるのよね～？　うんうん、それなら飲んじゃう～♪　はい、ごくごくごく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ぷはっ♪　後はぁ……あなたのおちんちんを取り出して……。えい♪　こう\nしてわたしのおっぱいで挟んじゃいまぁ～す。ふふ、気持ちい～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……やぁだ♪　あなたの目、マジすぎて怖いくらい……♪　うんうん、そー\nんなにわたしのおっぱいがいいのね♪　嬉しいわ……頑張るねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「え？　ボニューデマクールの入手先？　そんなこと、もうどうでもいいじゃ\nなぁい……。つまらないこと言ってないで、私のおっぱいだけ見てなさぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「すこーし張ってきた気がするわぁ……。ね？　触ってみて……。胸の膨らみ\nがパンパンになってきたら……母乳が出てくるのかしらね？　楽しみ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたも色々触ってみて？　どこに触ったって平気だから……。立派な母乳\nがいーっぱい出るように……揉んで、吸って、つねってひっぱって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ……んん……♪　そうそうそう……♪　あぁ……どうしよぉ♪　母乳を\n出すなんて初めての経験よぉ……どんな風になるの、かしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「それに……あなたのおちんちんったら、他の人よりも太くて逞しすぎ……♪\n　こんなの見せつけられて、肌で感じたらすっごく興奮してきちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……んふっ！？　あらっ……！　今母乳が少し出た？　うん、うん……強く\n搾っていいわよ……っ♪　わたし、ヤワなおっぱいしてないし……。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「メス牛の、おっぱいを搾るみたいにぎゅうううって強くしてぇ♪　んん……\n上手、上手よぉ……。遠慮なく、力いっぱいに……。あぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「すっごぉ……♪　ちょっとずつ、ぴゅ、ぴゅって溢れ出してきたぁ……。へ\nーえ……♪　母乳って……出す時乳首が気持ちいいんだねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あっついお汁が乳首を通り抜けていくっていうか……。少しだけ、男の人の\n射精みたいじゃない？　あっ♪　気持ちいい……これ、ハマっちゃいそ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁ……っ♪　はぁ、はぁ、はぁ、はぁあん……♪　あぁあん……！　母乳\n、ぴゅっぴゅっ……♪　ぴゅっぴゅっぴゅっ……イイぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「って、わたしだけ気持ちよくなっちゃうのはルール違反よね……。ごめんな\nさい、だって本当にイイんですものぉ……。ええ、そのまま搾っててね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたしも……あなたの超極太、極悪おちんちんを気持ちよくしてあげる……\n。ふふ、いいのよ♪　わたし、そういうのがとっても好きなのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　わたしのおっぱい……とろけるみたいに柔らかくってあたたかい\nでしょ？　すっごく評判いいんだから……たっぷり堪能しちゃってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あなたのおちんちんもとーってもシゴきがいのあるサイズで嬉しい……\n♪　いやらしい形をしてて……太さもわたし好みで完璧よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。おっぱいミルクがローションみたいに、あなたのおちんち\nんにまとわりついて……。すっごく甘い匂いが広がってく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これが、ボニューデマクールを使ったパイズリなのね。面白ぉい……。おっ\nぱいの優しい圧力と、母性が香りたつトロットロの母乳……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ご奉仕しているわたしまで、頭がトローンとしてきちゃうわ……。んっ……\n。おちんちんとおっぱいと、母乳の混じりあった濃厚なニオイぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「すてき……すてき♪　んんッ……♪　あ……。もしかして、ぷにゅ、ぷにゅ\n、って優しくパイズリしてるだけじゃ少し物足りない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「いいわよ……？　力強く、私の胸に……。胸の隙間におちんちんを叩きこん\nでも。うん♪　腰を振って……セックスみたいにピストンしちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「っあっ……♪　そう、そう、そんな感じぃ……♪　やだぁ……♪　胸にズン\nズン響いて……気持ちいい♪　おっぱいイラマチオって最高♪　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ぺろっ……♪　んん……！　あはっ……♪　あなたが腰を動かしてくれてる\nんだから、わたしもお口で協力しちゃう。ぺろ、ぺろ……れろっ、くちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あぁん、おいひい……♪　男臭くて頭が痺れちゃう♪　母乳の甘い匂いを凌\n駕する、亀頭とカウパーの欲望の臭い……。これ、すっごく好きなの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もっと……もっともっとわたしのおっぱいを、男の臭いで塗りつぶして♪　\nめちゃくちゃにして……れろっ……あぁ、おちんちん、おちんちん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「わたひのお口ひちょうどいいサイズだわぁ♪　これっ……、んむ♪　ちゅぱ\nっ、くちゅっ……わたしのためのおちんぽね、絶対そうよぉ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「唇で吸いつくとぉ、ちょうどいい形なんですものぉ……♪　ちゅぷ、ぷちゅ\n、くちゅっ、ちゅぷ……。ほら、竿だってしっかり胸の谷間に収まってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんはぁ……。れろっ、わたしのカラダにジャストフィット\nしてる、のよ♪　まさに運命的な出会いでしょ……。ちゅぷ、くちゅ、ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んふ……♪　おいひぃ……。おいひい♪　ぴちゃっ、ぴちゃ、ぴちゃ……ぢ\nゅる♪　わたひ……あなたのおひんひん大好きぃ……ちゅっぷっ、ぷちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「舌の上でパンパンに張りつめたおちんぽ転がすの、好きよ……♪　れろ……\nれろ、きっと精液もスゴいんでしょうねぇ……飲んでみたいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「少しだけ……。少しだけでいいから、ビュッビュッて出してみてくれないか\nしら？　飲みたぁい……あなたの精子が飲みたくてたまらないのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「……あっんっ♪　あはっ♪　うふふふっ、ふふふふっ……♪　ふふふふ……\n♪　んぷっ♪　んく……ごくっ、ごく……♪　あぁ、精子、精子ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「やっぱり抜群に美味しいわぁ……。んふふふ♪　搾りたてのあつあつ精液が\n、わたしの舌の上で踊ってる……♪　んー……とっても好きな味ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「でもぉ……。まだまだ出せるでしょう？　知ってるんだから。今の射精はお\n試しで、わたしがおねだりしたから出してくれた一回目……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「二回目の本気の射精のためにぃ……。こっちも本気を出さなくちゃ失礼よね\n……。はぁ……♪　それにしても素晴らしい味の精子だったわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ……んん、んっ……んん……♪　あふ……♪　すこぉし精子が胸に垂れ\nちゃったけど……。そのせいかしら？　更にえっちなニオイになったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んぁ……♪　わたしのぉ、母乳とあなたの精液……。わたしの唾液とあなた\nのカウパー……。混じり混じって、もう大変なことになってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「これよ、これ……。この性臭がわたしを狂わせてしまうのぉ……♪　あっ、\nむしゃぶりつかせてね？　パイズリフェラ、もっとしたいの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「んっ…ぢゅるっ……ぢゅるっ、じゅる……♪　はふ……♪　精液の味、苦く\nて濃くて舌が痺れひゃう……。んっ、あっ、胸にも硬いのがぶつかってきて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019501_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「もう脳内がまっピンクよぉ……♪　おちんぽ、おちんぽぉ……♪　色んなお\n汁でネトネトになったおちんぽをおしゃぶりできるこの幸せぇ……ぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あんっ……んん……♪　くちゅっ♪　ちゅぷっ、ぷっちゅっ、ぷちゅ……。\nあぁ、だめ……だめ、わたしもイッちゃいそ……。れろっ、ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「今まで食べたおちんちんの中でも、飛びぬけてわたしの好きなおちんちんだ\nわ。んむっ、吸いついてもう離れたくないくらいぃ……すき、すき好き♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ……ぐちゅっ！　くっぷっ、くぷ……ちゅるっ、ちゅ、ちゅぅうう\n……♪　はぁああ……♪　イッちゃう、イ、く……イクぅ……！　んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラケシス" ]},
