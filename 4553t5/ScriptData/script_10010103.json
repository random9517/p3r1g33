{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0022" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_002" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「す、すげえ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "シルバスターと共闘するような形になったとはいえ、あんなに大勢いたピース \nムーンたちをあっという間に叩きのめしちまうとは……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "カグヤのヤツ、いつの間にこんなに強くなったんだ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん！　たかがピースムーンに勝ったぐらいで調子に乗るなよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「このまま逃げ切れるなどとは、ゆめゆめ思わないことですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……カツマには、指一本触れさせない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「無駄なことを！　皆のもの！　カグヤとムーンナイト、そしてシルバスター \nを捕らえよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "幹部たち" ]},
		{"command":[ "SETTEXT", "「おおーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "000_010101030002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「できるもんなら捕まえてみろー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "と、シルバスターはやる気満点だが、今度の相手は幹部たち。しかもカグヤ以 \n外の５人が総がかりだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！　カグヤ！　今度こそヤバくないか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "と、慌てる俺にかまわずカグヤは――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「月影流忍術、微塵隠れの術……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "あっという間に、あたりは真っ白な煙に包まれる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわっ！　なんだなんだ！？　なんも見えないぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カグヤ得意の忍術とやらですか！　こざかしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "幹部たちは、俺たちの姿を見失って慌てているらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！　こっち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そのすきにカグヤは俺の手をとり、その場から逃れる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「や～ん！　みんなー！　カグヤちゃんたちが逃げちゃうわよ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだと！？　どっちだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「えーと、あっち？　じゃなかった、こっち！？　えーん！　ダイヤナちゃん \nわかんな～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええい、どこでもいい！　とにかく追え！　奴らを捕らえよーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "などと、背後で幹部たちが大騒ぎしているのが聞こえる。冗談じゃねえ、捕ま \nってたまるかーっ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ごほっ！　ごほっ！　ふぇ～！　やっと煙が晴れたよー！　あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ええっ……？　皆どっかに行っちゃった。まりあ姉ちゃん、どうしよう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このまま彼らを逃してはいけないわ！　何故だか知らないけど……イヤな予 \n感がするのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「わかった！　今すぐ追いかけよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0027" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫じゃねえって……あれから何十分も走りづめだったからな。完全に息 \nが……上がっちまって……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふぅ……とりあえずは追手を撒けたようですな。これからいったいどうなさ \nるおつもりですか、ご主人？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……今頃現れやがって犬コロ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ジュンジローでございます。どうぞお見知りおきを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030010" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「十分知ってる。しかしお前は、肝心な時にいつもいないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それは心外というものですな。このジュンジロー、ご主人のことをいつも案 \nじておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「先程だって、地割れに飲み込まれない程度の安全な距離からご主人の無事を \n一心不乱に祈っておりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "……この、見た目は犬そのまんまだが、やたら口が回るこいつの名は、ジュン \nジロー。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "一応、俺の唯一の部下……ということになっているが、まぁ、犬畜生だ。それ \n以上でもそれ以下でもない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "たまたま、人の言葉を理解出来て、話すことも出来る犬……ってだけだな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんですかそのいい加減な説明は。もう少し、私とご主人の出会いとか、武 \n勇伝とかを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あぁはいはい、後でな。今はそんなことやってる場合じゃねぇんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……しかしご主人、裏切り行為は重罪でございますが、良いのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「先に裏切ったのはあいつらじゃねーか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人のとばっちりで私までお仕置きされるのはいやですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえなあ……いいか、ジュンジロー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あーっ！　いた！　見つけたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げっ！　十五夜つきみ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "カグヤがとっさに刀を構え、戦闘態勢に入る。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "さっきは成り行きで一緒に戦ったが、シルバスターに変身するこいつとは本来 \n敵同士だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「落ち着いて！　あなたたちと戦う気はないよ！　話があるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「話……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうです。あなたたち、どうやらＧ・ルナリアムに裏切られて逃げ出す羽目 \nになったようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「逃げ出したのはいいけれど、このままではいずれあいつらにつかまり、処罰 \nされるのは確実」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それで間違いないですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030005" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う、うるせえ！　大きなお世話だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さすが十五夜まりあ殿。敵ながら現状把握が完璧ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから犬コロはだまってろっつーの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「落ち着いて！　わたしたちが、あなたたちを保護してあげるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　保護？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「敵の情けは受けない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「情けをかけるつもりはありません。共通の敵に対して、協力して当たろうと \n言っているだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そうそう！　さっきもそうだったでしょ？　わたしたち、一緒に戦ったよね \n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「う…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "緊急事態だったとはいえ、それを持ち出されると俺たちも弱いな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で？　いったいどうしろっていうんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「つまり、こういうこと！　ステラルクスで、あなたたち二人を保護してあげ \nる。でも、その代わりに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030008" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「代わりに？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「その代わり、あなたたちにはＧ・ルナリアム内部の情報を提供してほしいん \nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「二人とも、いまさらあっちには戻れないでしょ？　だったら、わたしたちと \n一緒に戦おうよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030009" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030010" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺とカグヤは顔を見合わせる。そりゃＧ・ルナリアムに戻れないのは確かだが \n、かと言ってあっさり敵側に鞍替えと言うのも――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いた！　見つけたぞーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やべえ！　あいつらも追ってきた！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「来たなぁっ！？　銀装！　ガン・シスター！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101030010" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "幹部たちの姿を見たつきみは、シルバスターの前段階、ガン・シスターへと変 \n身する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "一方、つきみと俺たちを見た幹部たちは――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なによアイツら～！　やっぱり十五夜姉妹と一緒じゃな～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか、そういうことか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もはや生け捕りなどと生ぬるいことは言わん！　シルバスターもろとも、内 \n通者どもを粛清せよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だーっ！　内通する前から内通者にされちまった！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もう、こうなったら覚悟を決めて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030008" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "まりあは俺たちに向かってそう言うと、手にした銃からガイド・ビーコンをガ \nン・シスターに照射する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「モード『ＳＩＬＶＥＲ・ＳＴＡＲ』スタンバイ！　シルバドライブ・リンケ \nージ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101030009" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "まりあの体がガン・シスターの中に取り込まれ、融合合体する。毎度見慣れた \nこの変身プロセス。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「月夜に蠢く悪を断つ！　銀星装甲シルバスター、オーバードライブ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……仕方ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101030011" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "カグヤも半ばあきらめ顔で刀を構え、ルナテミスたちに向きなおる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。こうなったらもう、シルバスター殿とカグヤ殿に付き合うしかあり \nませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……らしいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「では、わたくしは安全なところで、皆様に心からの声援とはげましのお便り \nを送るといたしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前も来るんだよ犬コロ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}