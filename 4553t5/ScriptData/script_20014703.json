{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETTEXT", "……そうしてアーマーンに案内された次の女神のいるところ。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「次はここ、猫陣営のバステト様の居住区……なんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「なんかもう、３つ目の派閥の女神様も一緒にまとまっているみたいっスね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ。もう仲直りして２人でお茶でもしてるってのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「違うっス。はちゃめちゃに互いを攻撃しあってて……いわゆるサシでのタイ \nマン中っス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶ、ぶ、部下を使うんじゃなく、自分で戦う剛腕スタイルなのかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とんでもなく元気な女神様たちですなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほら。アレを見てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アーマーンが手で示した先で、激しい戦いを繰り広げていたのは……タイプの \n異なる二人の女神だった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "1", "char_00026601_01", "7", "CENTER", "300" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「今日という今日こそ決着をつけてやるにゃ……。陰険フード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170001" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "シャーッ、と威嚇音を出しながらピンと猫耳を逆立て、激昂するスタイル抜群 \nの褐色の女神。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「いい度胸……こてんぱんに叩きのめしてやる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170001" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "対するもう一人は、深くフードをかぶった少女で猫耳の女性よりはだいぶ小さ \nい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「すごいビーム……出しちゃおかな。このあたり一面焼け野原になるかもしれ \nないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おぅおぅおぅ！　やれるもんならやってみろにゃ！　そんなショボい脅しに \nノるアホはいないにゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170002" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーっと……つまり、こいつらが３つの派閥の残り２つってことでいいか？ \n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そういうことっスね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アヌビスが犬で、あそこに見えるのが猫？　ネコだなたぶん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「猫陣営の女神のバステト様っス。見た目のまんまニャンニャンっス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で……あと１人……。アレは何の動物なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170003" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あの方はメジェド陣営のメジェド様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010023170007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「メジェドって犬や猫と同じレベルで括れるものじゃないだろ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "予想外の生物を目の当たりにして、一瞬動きを止めた俺。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しかし、すぐに当初の目的を思い出し、２人の女神の間に割って入ることにす \nる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て待て待て！　一旦争うのはやめてくれ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んん？　何にゃ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170003" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「乱入者……。お前も私の裁きを受けたいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170004" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ギスギスしている空気の中に、割って入るのは緊張するが仕方がない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アーマーンから話は聞いた！　エジプトの女神たちが争い、再びナイル川の \n惨劇を起こすというエジプト神話大戦！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はそれを止めるために、アヌビス派閥より派遣された使者だ！　話を聞い \nてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……大戦を止める者……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170005" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ふぅーむ、そのためにこの……偉大なる女神を２人も敵に回すっていうわけ \nにゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170004" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ははぁ～ん？　……いいねぇ。きみ。不敬にして不遜！　気に入った！　今 \nならこのバステトおねーさんの率いる陣営……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170005" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「猫派閥に特別待遇で加入させてあげてもいいにゃ。それ、それ！　我が軍に \n下るのにゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「にゃんにゃんうるさい……。それに、ワガママすぎる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170006" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「この人は私のメジェド陣営がもらいうける……。これは、神が決めた神の宣 \n託」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170007" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「野良猫ごときが口を出すレベルのお話ではない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170008" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「はあああ！？　猫なのは否定しにゃいけど、女神ですけどバステトちゃんは \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170007" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00026601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が説得をする前に、再び緊迫した雰囲気になってしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "1", "char_00026601_01", "7", "CENTER", "300" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "7", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（この状況を変えるには……。ああ、そうだ！）", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アヌビスから二人に、渡してほしいと頼まれたものがあったんだった。…… \n二人とも！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これを受け取ってくれ！　これが……アヌビスからの気持ちだ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00026601_01", "3", "CENTER", "300" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "3", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んんんんんん？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00026601_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「一体なんです……これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170009" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「エジプト銘菓、ハッピーコナーファだそうだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「にゃ、にゃにぃ！　ハッピーコナーファ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170009" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「ほ、本当ですか。アヌビスが私たちにこれを……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170010" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「お、意外に食いつきがいいですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「たぶんエジプト神の中ではたまらないお菓子なんだろう。エジプト神の中で \nは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なんとなく名前的には幸せになれる粉っぽくて怖いが、箱からは甘くて美味し \nそうな匂いがしてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「死ぬほど甘い系のお菓子……だと思う。たぶん」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「やったにゃあああああああ！　バステトおねーさんコナーファ、死ぬほど好 \nきにゃああああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170010" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「く……ください。モノによっては考えを改めます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170011" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ささっとフードの中から両手を出してきたメジェドに箱を渡し、続いて興味津 \n々なバステトにも同じ箱を渡す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうぞ、お納めください」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「わくわくわく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170011" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「そわそわそわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170012" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「開封の儀～！　開けるにゃ！　パッカーン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170012" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「この芳醇な香り……たまりません。いただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170013" ]},
		{"command":[ "SETCHARA", "0", "char_00026701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして、二人は同時にエジプト銘菓の箱を開けた、の、だが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「か、空だにゃん」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_266_010023170013" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メジェド" ]},
		{"command":[ "SETTEXT", "「……エジプト銘菓……。中身が入ってない。これはアヌビスからの宣戦布告 \n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_267_010023170014" ]},
