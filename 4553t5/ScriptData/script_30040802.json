{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おい、お前。ちょっといいか？　なんだか身体がおかしいんだ。妙に火照っ\nてるっていうか……ううぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804101" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「すごく、イライラする！　お前のそばにいると、余計イライラしてきた！　\nだから、お前がどうにかしろ！　責任取れ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804102" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「えっ、どうにかしてやるから後ろを向け？　こ、こうか……？　いったいど\nうするつもり……きゃうぅん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000408_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、おおっ、お前っ！　オレのことを後ろから襲うなんて、んぁっ、しかも\n……ま、股にっ、なにを擦りつけてるんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ち、チンチン！？　チンチンを擦りつけてるのか！？　お前ふざけるなよ、\nいったいどういうつもりなんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「発情しているようだから、交尾でもすれば治るだろうって……お、オレはそ\nの辺の犬じゃないんだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁあ……っ。でも、なんだか……。イライラが……うぅ、チンチンが当た\nっているところが、疼いてきて……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチン、擦りつけられると……はぁ、はぁ……全身にぃ……力が、入らな\nくなる……んぅっ、んふぅうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「抵抗しないと……チンチンに、犯されるのにぃ……。はぁ……はぁ……。身\n体が……お前に犯されたがってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、オレは……狼なのにぃ……。メス犬みたいに、チンチンに媚びてしまっ\nてる……。でも……我慢できないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「身体が疼いて……チンチンが欲しくてたまらなくなってる……！　な、なあ\n……お前のチンチンで、オレのこと、思い切り犯して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぉっ、おぉおおぉぉんっ！　ち、チンチン！　チンチンが、おっ、オレの\nナカにっ、入った……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　あっ、ああぁっ！　アソコがっ、チンチンに、いっぱいにひろ\nげられてるっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ま、待てっ、待ってっ！　んひぃいっ！　おいっ、動くのは\nっ、あっ、あはぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「たしかに、思い切り犯されたいって言ったけど！　んぉっ、おおぉっ！　い\nきなり動くのっ、おっ、おおっ、おおぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンがっ、チンチンがナカ、いっぱい擦るぅ……！　んひっ、きゃひぃ\nいんっ！　激しいっ、んっ、チンチン激しすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぉおっ、おおっ！　チンチンが、ズコズコって、アソコを突きまくってる\nぅっ！　んひっ、ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それっ、それダメだっ！　おっ、おっ、おおっ、おおぉんっ！　ダメっ、頭\nがっ、おかしくなりそう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンにっ、んぁっ、アソコのナカ、好き勝手に動かれてっ、んぁっ、あ\nあぁっ！　こんなにぃっ、感じる、なんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「も、もっと感じたい……チンチン、もっと……！　んはぁっ、ああっ、お前\nのチンチン、もっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　な、なんだ今の感覚ぅっ！　おっ、おっ、チンチンがぁっ、ナ\nカの一番奥にっ、突き刺さった……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、身体の内側がっ、チンチンで揺さぶられる感覚ぅ……！　んぉおっ\n！　おっ、おおっ！　おおぉおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「奥っ、奥っ！　ああっ、アソコの奥ぅっ！　んぉっ、おおっ、硬いチンチン\nの先っぽがっ、奥ばっかり、何度もぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「さ、さっきより、ずっと気持ちいい……！　奥、チンチンにズコズコされる\nの感じすぎるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁあんっ！　いいっ、いいっ、感じるぅ……っ！　チンチン感じるっ、ア\nソコで、お前のチンチン全部感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、オマンコ？　オマンコって言えばいいのか？　んぁっ、オ\nマンコ……発情オマンコ……きゃひぃんっ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オマンコ、チンチンで突かれて、かき混ぜられてぇっ！　おっ、おおっ、な\nにか……キそう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なにか……もう、なにも……頭が、真っ白になりそうな……っ！　んぉおっ\n、おおっ、おっ、おお……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前っ、オレ、おっ、オレ、このままじゃ……！　ああっ、本当に……ヤバ\nいの、なにか……あっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おいっ、だ、出すって精液をか！？　イけってどこに！？　んぁっ、ああっ\n、ああ……オレ、オレもう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あうぅううぅぅうぅんっ！　お、オマンコにぃっ、熱いのがっ、入ってくる\nぅううぅうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、中に精液出されて……身体に、力が入らなく……んぁっ、\nああ……だめだ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「で、でる……でる……っ！　漏れるぅううぅぅっ！　んぁっ、ああっ、オシ\nッコでるっ、止まらないぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はうぅううっ！　人前で、オシッコ漏らすなんて……恥ずかしすぎるのに…\n…！　か、身体が、ますます熱くなるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。い、イキション……？　イクって……？　さっきの、感\n覚のことか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「気持ちよかったんだろって？　ま、まあ……そうだな……。お前のチンチン\n、気持ちよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だ、だから……もっとしてほしいぞ……。お前のチンチンで、もっとイかせ\nて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あれくらいじゃ、全然足りないみたいなんだ……。むしろ、さっきよりも疼\nきがひどくなった気がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だ、だから頼む……。もう一回、お前のチンチンでオレのマンコをイかせて\nくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「発情オマンコ……もっともっと、チンチンでめちゃくちゃに犯してくれぇ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「きゃいぃいいんっ！　またきたっ、チンチンきたぁっ！　んぉおっ、あおお\nっ、あおおぉおおんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「さっきよりも、チンチン感じる……んぁっ、チンチンの形っ、熱っ、んぁっ\n、ビクビクって暴れるのもわかる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「イッたから？　イクと、敏感になるのか？　んぁっ、感度が上がったから、\nチンチンをより感じるのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、そうなのか……んぅっ、そんなの、初めて知ったぞ……\nんっ、んぁっ、あっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「でも、おかげでもっと、チンチン感じられ……んぁっ、お前っ、なんで動か\nなくなるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「疲れたから自分で動けって！？　ううっ、こ、こうか……？　んぁっ、自分\nで動くと、ンッ、当たるとこ、全然違う……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「自分から腰振って、んぁっ、感じるところに、お前のチンチンを当てて……\nんっ、おっ、おお……あおぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こ、ここっ、ここがいい……っ！　んぉっ、おおっ、腰が勝手に……あおぉ\nんっ！　気持ちいいのっ、おおっ、も、もっと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、んんぅうっ！　お、オレ……チンチンに夢中の、エロ犬にな\nってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンに媚びる……発情したメス犬にぃ……。でも……んぁあっ、身体が\n疼きまくって、おかしくなりそうなんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、お前もいつまでも休憩してないで、発情メス犬オマンコ、犯してよぉっ\n！　んぉっ、おおおぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「またいきなりぃっ！　チンチンきたぁっ！　あおおっ、おおっ、おおっ！　\n奥っ、奥……んぅううっ！　突き刺さるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレも、腰が動いちゃってっ！　あおぉっ、あおぉんっ！　これ、さっきよ\nりも深くにチンチン届いちゃって……すごく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いっ、いいっ、オレ……さっきと同じ感覚……イク……イきそうになってる\n……！　お前に、チンチンでイかされる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、イかせて……いっぱいズボズボしてオレのことイかせて…\n…っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そして、お前のチンチンから、さっきみたいな熱いの、いっぱい……たくさ\nん出して……注いで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「きゃひぃいいいんっ！　は、激しいっ！　チンチン激しいぃっ！　んぉっ、\nおっ、おおっ、おおぉっ、オマンコめちゃくちゃになるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んひっ、ひぃっ、イクッ、イクッ、イク……ッ！　ああっ、ああっ、頭の中\n……ぐわんぐわんしてきた……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オマンコいっぱいっ、チンチンで満たされてっ！　身体の奥まで何度も突か\nれてイク……イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、もう限界ぃいいいいっ！　んぉおっ、おっ、おおおおっ、\nイッくぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぉおおおぉぉぉんっ！　んぉおっ、おおっ、おおぉおおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「また注がれるっ！　熱いドロドロ……いっぱいオマンコに入ってくるぅうう\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あひぃいいっ！　イクッ、イク……ッ！　んぁっ、ああっ、また……漏れる\nぅううぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「またイかされて……おもらしまで……んあっ、ああ……こんなの恥ずかしす\nぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、中出しされてうれしいから漏らしたんじゃないかだって！？　そ、そん\nなわけない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、お前の精液を、中にたっぷり出されたことが、嬉しいだなんて……ある\nわけないだろ！　オレは誇り高き月狼族だぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「すっかりエロいメス犬になってただって……うぅ、それは発情していたせい\nだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「普段のオレだったら、こんなふうにはならないんだからな！　チンチンを向\nけられたって、平気なんだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……な、なんだよ、疑ってるのか？　さっきまでのサカりっぷりを見せられ\nたら説得力がないって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「い、言わせておけば……。いいか、オレがこんな姿を晒すのはこれが最初で\n最後なんだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひゃふぅうううぅぅぅんぅ！？　んぁっ、ああっ、チンチン抜けてっ、精液\nがぁあ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、すごいっ、またこんなにたくさん……お、おお……オレの\n身体に、かかって……んっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はあっ、はぁっ、すっごい濃い臭いのする精液が……んぁっ、オレのこと、\nドロドロにして……んっ、んぁっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「い……イク……ッ！　精液まみれにされて……イッ、イク……イク……ッ！\n　あおぉおおおぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。精液かけられて、イかされて……。また……おもらしま\nでしてしまってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うぅ……。発情したくらいで、お前にこんなに情けない姿を見せてしまうな\nんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレは……誇り高き月狼族なのに……。すっかりメス犬に成り下がって……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ……オレのこと、慰めてくれるのか？　オレに精液だけじゃな\nく、情けまでかけるつもりか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「い、言っておくが……こんなこと、もうこれっきりなんだからな……はぁ、\nはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0804409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前に、いろいろかけられるのも、今回限りなんだからな……！」", "NORMAL" ]},
