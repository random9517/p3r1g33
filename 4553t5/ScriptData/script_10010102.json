{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0022" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_002" ]},
        {"command":[ "WAITMOVE" ]},		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちっきしょお～～～！　よくも裏切りやがったな覚えてやがれえええ～～～ \n！！」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "くそっ！　俺はこのまま葬り去られるのか……！？", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……カツマっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "とつぜんカグヤが、オボロの作る『陣』の中から飛び出した。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "その途端、俺たちを飲み込みかけていた砂の渦がピタリと回転を止める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ、おい！　カグヤ！　どこ行くんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱり、出来ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101020002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "駆け寄ってきたカグヤが、しっかりと俺を抱きかかえて地面から引きずり出す \n。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、あれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "もちろん、俺がなすすべもなくしがみついて――じゃなく、しっかと捕まえて \nいたシルバスターも一緒にだ。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101020003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……カグヤ！　お前、俺を助けて……くれたのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "俺は、信じられない思いでカグヤに尋ねる。すると彼女はなぜか顔を赤らめ、 \nうなずいた。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様の命令とはいえ……やっぱり私にはカツマを見殺しにすること \nなんて出来ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101020004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "5", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "考えてみれば、俺とカグヤは幼なじみだもんな。そんな俺を見殺しにするには \nしのびないと……", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "他の冷血幹部どもとは違って、こいつにはまだまだ情ってものがあったんだな \n……泣かせるじゃねえか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そんなことを考えている俺に向かって、カグヤはきっぱりとうなずく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「例え相手が誰であろうと、どこであろうと……私は必ず駆けつける。それが \n私の存在理由だから……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101020005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え！？　そこまで！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "カグヤのヤツ、こんなに友情に厚い熱血女だったのか！？　付き合いの長い俺 \nだが、さすがにそこまでとは思ってなかった。驚いた。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "だが、驚いたのは俺だけじゃない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まさか、あんたがこんなことしでかすとはねえ……どういうつもりだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「シルバスターをやっつけちゃえば～あとは遊んで暮らせると思ったのに～！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「バカ一匹のためにウチの陣を崩し、シルバスターまで助けるとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おまえらぁ！　仲間を捨ててどうするつもりだあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101020002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「にっくきシルバスターを、あと一歩で仕留められたというのに……おのれお \nのれこの裏切り者っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ちょっと待て！　裏切りって、そっちがそれ言うか！？", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ピースムーン！　総員かかれっ！　裏切り者のカグヤとムーンナイトを、シル\nバスターもろとも捕らえるのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101020002" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "008_090101020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「全く、どっちが先に裏切ったと思ってるんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ったく、これ以上付き合ってられるか！　とにかくこの場は逃げるしかなさそ \nうだ！", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、カグヤ！　今すぐ逃げ――」", "NORMAL" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマは私が守る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101020006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "俺を守る？　つまり戦うってことか……？　あいつらと？　", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「なんだかよくわかんないけど、来るなら来いっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "013_020101020002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "俺のそんな疑問をよそに、カグヤとシルバスターはピースムーンたちの前に立 \nちはだかる。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "えと……俺はどうしたら？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "どっちみち、あの二人が負けたら俺も後がないんだよな。", "NORMAL" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "ってことは……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でええええーい！　こうなりゃヤケだあーっ！」", "NORMAL" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}