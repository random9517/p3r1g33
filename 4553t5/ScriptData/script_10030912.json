{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "バッケンローダー・ツインソードにルナテミスたちが迫る。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やはりルナテミスたちの狙いはメスゴリラか！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「メスゴリラさん！　特訓の成果を見せつけちゃってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115920001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふたりとも、あとで覚えてなさいよ！　とにかくいまは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920001" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バッケンハンターの銃弾をかわし、ルナテミスの剣技とガン・シスターの拳を\n受け流し、バッケンローダーは３人をまとめて攻撃できる一瞬を待つ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、３人が脳筋ゴリラ（ルビ：バッケンローダー）の間合いに入った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「双桃連斬ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920002" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00002804_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "力任せの攻撃に、３人が吹き飛ばされる。それだけじゃない。周りの生徒たち\nまで吹き飛んだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスたち" ]},
		{"command":[ "SETTEXT", "「きゃぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115920001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00002401_01", "9", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00001301_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「どうだ！　これが、バッケンローダー・ツインソードの力だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920003" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すごい！　まさに通常攻撃が全体攻撃で２回攻撃の脳筋ゴリラですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115920002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「さっきの、通常攻撃じゃなくて必殺技だったんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920004" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、さっきから言おうと思ってたんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「今度はカツマさん？　なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920005" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「片方は金棒なんだし、ツイン『ソード』じゃなく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺のセリフへの返事は金棒だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ごふぅ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「細かいことは気にしないの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「う……ああ……あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ここ……学園？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115920002" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガン・シスター" ]},
		{"command":[ "SETTEXT", "「みんな、なんでここにいるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115920002" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ！　みなさん、目を覚ましたようです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115920003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスたちだけではない、洗脳されていたほかの生徒たちも目を覚ました\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "洗脳されていた間の記憶はないため、みんな混乱している様子だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「大丈夫？　ケガはない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920007" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや……ケガだらけだが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガン・シスター" ]},
		{"command":[ "SETTEXT", "「なんで目が覚めたらこんなにボロボロになっちゃってるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115920003" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "３人同時に気絶させるつもりで大技をくりだしたから、そりゃ身体もボロボロ\nにもなっている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「というか、バッケンローダー？　その姿は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115920003" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「これは、桃花さんがみなさんを助けようと無理やり会得した、メスゴリ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115920004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「バッケンローダー・ツインソードよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115920008" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "夜叉のセリフを遮り、バッケンローダーが自身の姿の説明をした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「バッケンローダー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115920004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ツインソード！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115920004" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガン・シスター" ]},
		{"command":[ "SETTEXT", "「かっこいーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115920004" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ぐぬぬ……。洗脳がとけてしまったじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115920001" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こうなったら、我らが戦うほかないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115920001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……しかたないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115920001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
