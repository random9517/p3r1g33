		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あふっ、また……出そう……？　オチンポ……イキそうになってるの？　あ\nたしも……んんっ、ヤバい……かもぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、うんっ……一緒にイキたいなっ……隊長さんと同じタイミン\nグで……気持ちいーのっ、弾けたいのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっ、中っ……掛けるのも……どっちもいーかもっ、決めて……隊長さんの\n好きにしていいからぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、イキそっ！　あとっ……もう少しっ……隊長さんもっ、ね\nっ、来てっ……あぁっ、あと少しぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はふっ、あっ、イクっ……もぉダメっ……！　オマンコイッちゃうっ、また\nっ、オマンコイッちゃうよぉぉぉぉっ！」", "NORMAL" ]},
