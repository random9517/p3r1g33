		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「どうする気って？　ふふ……今日はアスモデウスの覚醒の儀式をするんだよ\n。隊長さんはその依代ってこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「まぁ、細かいことはどうでもいいから。ほら、脱いで……えへへ、あたしも\n邪魔なのは……ポイ、しちゃうから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「じゃあ、上からお邪魔しちゃいまーす♪　んふふ……もう逃げられないよー\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025001_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「えっと、ここから……えっと、とにかく……責めちゃうんだから……覚悟し\nてね……んっしょ、あ、あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ねぇ……えっと、この辺にオチンチン……オチンポだっけ……あったよね。\nそれで、ここを……こうして……ぬるって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「おかしいな……確か、入り口がこっちだから……んっ！　ちょっと……あっ\n、待って……まだ動かしちゃ……はっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「やだ……オチンポ……ちょっと逃げないでってば……んんっ、あふっ、あん\nっ、擦れるぅ……あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「素股で感じるって……あふっ……んっ、違うの……ホントは入れてから……\n気持ちよくなる予定なんだってばぁ……あ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ちゃ、ちゃんと入れるの……んっ、位置……ずらせばいいの……？　ふぇ…\n…お、おねだりも……？　うぅー、もう……分かったからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「お願い……隊長さんの太くて……硬いオチンポで……あたしの……ミウのオ\nマンコ……目覚めさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「もういっぱい開発されたカラダ……我慢出来なくなってるの……ね、ここ…\n…ほら、オマンコヌルってなってるからぁ……ここぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……あっ、あくぅぅぅぅんっ！　あっ、んんんんんっ……入っ\nて……るぅぅっ！　んくうぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっふ……はぁぁ……これが、隊長さんのオチンポ……あふぅ……やばぁ…\n…中……全然思ったのと違ってるし……くぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ふはぁ……中……広がってくぅ……あぁ……こんな感じなんだね……んっ、\n思ってたよりおっきいし……いっぱいな感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「え……？　初めてだよ……それが何か……？　だから、覚醒の儀式なんだよ\n。んっふ……はぁ……んっ、あっ、く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「痛み……？　そう言えば全然ないかも……えへへ、あたし……エッチなこと\nは大体、便利な感じに順応しちゃうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっ、だから……遠慮しないで動かしていいよ……あたしのオマンコ……隊\n長さんのオチンポでグリグリしてみて……あっ、はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んぁっ、そうっ……はふっ、んふぅっ……いい、感じぃっ……くぅっ、んく\nっ、はっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「これ……あひっ、やばっ……中で……ぐりぐり暴れてっ……！　ねとねとが\n……気持ちよくてっ、こんなのっ、くっ、んぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ヤバ……あっ、気持ちいいのっ……どんどん来てるっ、オチンポっ……奥に\nぐりゅってされるのっ、良すぎてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、はぁぁ……あふ……ちょっとイっちゃったかも……これ、\nすごすぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んんっ、はふっ、あっ、うんっ、んぁんっ……！　腰が……んっ、自然に動\nいちゃうっ、あひっ、はっ、んくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……ぬるぬるしてる……？　うん、隊長さんのオチンポハマって\nから……いっぱい溢れて来てるかもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、んっく……あひぁっ、ちゃんと……あたしも動くからねぇっ……んん\nっ、えいっ、はふっ、んんっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、おっぱい……ぷるんぷるん揺れちゃうね……これって、やっぱりエ\nロエロな眺めなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「だって、隊長さんの目が泳いじゃうんだもん。いーよ、見て……あたしのエ\nロパイに、釘付けになっちゃえっ……あふんっ、はふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ほら……あたしのおっぱいでオチンポギンギンにさせてよね……んくぅぅ…\n…そう、あぁ……オチンポの奥でキスされてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふ……ちゃんと硬くさせた責任は取るからね……んっ、はぁっ、こうして\n……ぐちゅって……オマンコ……かき回すのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あぁんっ、これ……いいっ、セックス……やば……そりゃ、み\nんな……ハマるよねぇ……こんなのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ、ね……隊長さんはどう……？　あたしのオマンコ……\nちゃんと気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あふっ、そっかぁ……よかった。まあ、こんなにオチンポ震わせて、違うっ\nて言っても全然説得力ないもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふっ、ずっとビクビク震えてるし……これ、そんなに長くないのかな……\n？　はふっ、んっ、えいっ、えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あはっ、可愛い声出てるっ……あんっ、はひっ、お互い様……？　そーかも\n。なんか、気持ちいーとこ擦れると、声出ちゃうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んっ、じゃあ、もっと声出してこ……あひっ、はっ、あたしも……ジンジン\nして……また気持ちよくなってるから……は、ひっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、えっ、出そう……？　んっ、中っ……このまま中に出しちゃ\nうのっ？　それって……赤ちゃんできちゃうかもっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ど、どーしよ……あっ、でも……気持ちいいっ……あんっ、止まん\nないっ、んっ、いーよっ、出してっ、中……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふぁぁぁぁぁぁっ！　あぁっ……中っ、びゅるってっ……あっ、来たぁっ\n……はっ、ふぁぁぁ……はひぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコの奥ぅ……熱いの当たってるぅ……すご……んっ、はぁぁ\nっ、イ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ふはぁ……はぁぁ……熱いのトロトロに出たぁ……はぁぁ……イクと……自\n然に声出ちゃうんだぁ……すごかったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、ふっ、んふっ……んっ……何してるって……？　んと\n……続き……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「え、だって……まだオチンポすごくおっきいままだし……気持ちよかったじ\nゃん？　まだしたいって思うの……当たり前だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「大丈夫だよ、隊長さんは無理に動かなくても……あたしが、いっぱい腰振っ\nてとろとろオマンコで幸せにしたげるから……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あんっ、あふっ……わ……中……ヌルってすると、擦れ方も全\n然違うかも……んふぁ……あふっ、くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、それに……オチンポがまた膨らんで……んんっ、中っ……オ\nマンコぉ……まだ広がっていくかもぉ……ふぁっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はふっ、抜かないで……二回目するの……んっ、ずりゅって来て……あんっ\n、いい、感じぃ……んはっ、んひっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「オマンコも……嬉しくなってぇ……むちゅって……オチンポにキスしちゃっ\nてるぅ……はっ、ふっ、んっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「こうして……くっつけたまま、んんっ、ゆっくり前後させたげてぇ……ぁぅ\nっ……いっぱいこすこすしてあげるの……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、あぁっ……どう……？　気持ちいい？　あたしの色欲の力…\n…迸っちゃってる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「まだまだぁ……もっと、してあげるからぁ……オチンポ……包み込んでぇ、\nシコシコするのぉっ、はぁっ、くふぅっ、ぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、精液の混じってる音……あんっ、にちゃっていってる……あたしの\n奥からも、またオマンコの汁……溢れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……止まらないよぉ……もっとしろって……あたしの中の悪魔が叫\nんでるからぁ……はぅっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00025001_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「熱いオチンポ……むちゅってして……ぬめぬめ粘膜、すりつけてぇ……んふ\nぁっ……はぁんっ、ま、またおっぱいもしてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「んふっ、あんっ……あぁんっ……きもちいー……オマンコ、いっぱいきもち\nいー……きゅんきゅんって締め付けちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_250_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アスモデウス・ミウ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、オチンポも……下からずんずん来てぇっ、はふっ、あひっ、ん\nくぁっ……奥が……じゅぷって蕩けるぅ……」", "NORMAL" ]},
