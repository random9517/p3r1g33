		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「どういうこと……？　この状況を打破できる秘策でもあるっていうの……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420004" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「……一つだけ、とっておきの秘策があるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
