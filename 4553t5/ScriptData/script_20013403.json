		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "３人" ]},
		{"command":[ "SETTEXT", "「が、合体っ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "2", "char_00015701_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00015801_01", "3", "CENTER", "600" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420005" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ええ……こうした強大な敵と対峙したときのために、Ｍ.Ｏ.Ｅちゃんには\n私と変形合体する機能が備わってるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420007" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「そんな機能初めて知ったわ……でも、合体してパワーアップするなら、早く\n合体しましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420006" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「……そうしたいのは山々だけど、この合体機能には大きな欠点があるの……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420008" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「欠点？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420007" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「この合体プログラムには、未だに多くのバグが残ってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420009" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「現状のままで合体すれば、プログラムに不確定要素が生じて、私かＭ.Ｏ.\nＥちゃん……どちらかの超人口知能メモリーが完全に破壊してしまう可能性が\n極めて高いわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えっ！？　合体したら、超人口知能メモリーが壊れちゃうんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022420005" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「Ｍ.Ａ.Ｍ.Ａ……お互いの超人口知能メモリーが無事に残る確率は……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022420006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「その確率は、０．００２％……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420011" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はっきり、０といった方がいいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「０．００２％……５万分の１ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420008" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「なんですかそれ！　絶対に成功しないじゃないですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022420006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも……可能性は０じゃないよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022420007" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「……そうよ！　０％の確率じゃないなら、成功することだってあるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420009" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「確かにその通りだけど、これは何回もチャレンジできることじゃないわ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420013" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「たった１回で、０．００２％の確率を引き当てる必要があるのよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420014" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「それでも、このまま全員スクラップにされるよりはマシよ！」", "NORMAL" ]},
