		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　どうしたんですかぁ？　もう終わりですか？」", "NORMAL" ]},
