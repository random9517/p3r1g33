		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「……Ｍ.Ａ.Ｍ.Ａ。もしも私の心が消えたなら、カツマちゃんを守ってあ\nげて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420013" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「でもその逆だったら……その時はカツマちゃんを頼むわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420017" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「この命に代えても……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420014" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
