		{"command":[ "SETCHARA", "0", "char_00015801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「……方法がないわけじゃないわ」", "NORMAL" ]},
