		{"command":[ "SETCHARA", "0", "char_00015805_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「本当はもっと強がりたいですけど……そうも言ってられませんねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022420003" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「このままだと、みんなやられちゃうよ……！　なんとかならないの……！？\n」", "NORMAL" ]},
