		{"command":[ "SETCHARA", "0", "char_00011102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｙ.Ａ.Ｍ.Ｉ" ]},
