		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「で、でも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010022420015" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「迷うことなんてないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420011" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「成功率なんてのは単なる目安よ！　あとはカツマちゃんへの愛で補えばいい\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010022420012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
