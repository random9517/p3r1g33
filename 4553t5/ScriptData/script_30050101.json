		{"command":[ "PLAYVOICE", "005_0103101" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんな部屋まで呼びつけて、いったい何の用です？　あなたのお遊びに付き\n合っていられるほど、ウチもヒマではないのですが」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103102" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それに、あなたも一応、責任ある立場を任されたのですから、無能なりに雑\n用でもして働いてみてはどうです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103103" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はあ？　……もしかして、またＨなことをしたいのですか？　理性の利かな\nい下半身だけの猿は本当に見苦しいですね……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103104" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まぁ一応、何をしたいのかくらいは聞いておいてあげます。それで……今度\nはウチに、何をさせようって言うのですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103105" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……は、はぁ！？　ペニスを舐めろだなんて、不潔です！　そんなことを臆\n面もなく言うなんて、頭がどうかしてます、恥を知れです！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103106" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、何でもう勃起させてるのですか！　最低、汚らわしいです！　あなたの\n存在はもう男性器そのものです！　単細胞生物並みです！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103107" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くっ……これだけ言われても、懲りずにまだシたいのですか？　見下げ果て\nた変態ですね。あなたの脳みそは男性器にでも入ってるのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103108" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……しかたがないので、付き合ってあげます。ウチも全く興味がないわ\nけではないので……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103109" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……はあ？　ウチはあくまで、知的好奇心から色々と実験をしてみたいだけ\nです。下半身で生きているあなたと一緒にされると極めて不快です」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103110" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「わかったなら、ウチの優しさに感謝をしながら、さっさと準備を始めるです\n。あなたのおバカな会話に付き合っているのは時間のムダですので」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103111" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……これが男性器、つまりはペニスと呼ばれる部位ですか……こうして間近\nで見ると、とても興味深いですね……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103112" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まさに生殖器というような生々しさです。端的に言って、ちょっと気持ち悪\nいですね……生理的嫌悪感を催させる、醜悪なフォルムです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103113" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「挿入のためとはいえ、ここまで固くそそり立つのですか……ここに段差があ\nるのは……性的刺激を増大させるため、なのでしょうね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103114" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「陰茎が女性器の中に挿入されると、この部分がナカを引っ掻いたり、擦った\nりして……ん……性的な快楽を与えるのですね……ごくっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103115" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、何を言ってるのですか！　ウチは興奮などしていません！　あくまで学\n術的な興味だけで、性的な目でなど見ていません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103116" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「だ、だいたい！　あなたこそ、どうして勃起してるのですか？　ウチのよう\nな貧相な身体で興奮するなどと、とんだ変態ですね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103117" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……な、ななな、か、カワイイなどと…！　そ、そんなことを言っても、ウ\nチはだまされないですよ！　ほだされたりなんて、しないですから！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103118" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふんっ……ま、まぁ、よく見れば男性器というのも多少は愛嬌のある形をし\nているような……少しは気持ちよくしてやってもいいです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103119" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んれぇっ……ちゅ、ちゅぱ、れるっ、れるぅっ……うぇぇっ、変な味がしま\nす。それにオス臭くて、れるぉっ、うぅっ、鼻が曲がりそうです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103120" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろっ、れろぉっ、これもフェロモンの一種なのでしょうか、ちゅ、ちゅう\nっ、臭くて、不味くて、ウチには効きそうもないですね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103121" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「すんすん……はぁぁ、本当にひどい臭いです。味も、ぴちゃ、ぴちゅるっ、\n不味くて、最低です、はぁ、はぁ……ちゅ、ちゅ、ちゅうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103122" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……はぁ？　ウチが夢中になってるなどと、れちゅっ、あなたの目は節穴で\nすね、れりゅりゅっ、れろぉっ、これだから、単細胞生物は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103123" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……先っぽから透明な汁が出てきましたね、これがカウパー\n氏腺液……尿道を中和して、精液を出す準備をシてるのですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103124" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、ちゅぱっ、新鮮で活きのいい精子を、女性の子宮へと届けるための\n機能……ぴちゃ、れろれろぉっ、とても興味深いです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103125" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅうぅっ、はぁ、味が濃くなってきたです、れちゅ、れろぉっ、\n先走りの汁には微量の精子が含まれてるそうですが、ちゅぱちゅぱっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103126" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もしかして、ちゅ、ちゅっ、もうすぐ出そうなのですか？　それなら早く出\nすのです、れりゅりゅっ、精液をココから、ちゅっ、ちゅうぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103127" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぷはっ、はぁ、はぁ……キモチワルイ勘違いをしないでください、れりゅり\nゅ、れろれろぉっ、ウチが精液を欲しがってるなどと、ちゅぱちゅぱっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103128" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「男性器の情報は、もう十分なので、ぴちゃ、れりゅっれろぉっ、あとは時間\nのムダですから、さっさと射精させて、ちゅっ、おしまいにしたいだけです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103129" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いいから、さっさと出すのです、ちゅぱちゅぱっ、あなたの弱いところは、\nすでに把握済みですから、れりゅりゅっ、れろぉっ、激しくナメてやります」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103130" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの手管にかかって、ぴちゃれりょっ、無様にお漏らしするです、れりゅ\nりゅりゅっ、ほら、出すです、ちゅうぅっ、イきなさい、イけ、イけっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103131" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！？　ひゃああああああっ！？　な、なんですかぁっ！？　きゃうぅ\nっ！？　熱いのが、びゅくびゅく……っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103132" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「精子が、こんなに、勢いよく……ひゃうぅっ！　びゅくびゅくっ、うぅっ、\nこんなに、出るなんてぇっ……！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103133" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぁっ、ひゃああっ、ぷぁあっ！　顔に、かかって…んぶぷぅっ！　ふぇぇ\nっ……早く、止めなさい、ぶぷぁっ、止めてぇ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103134" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぇっ！？　ふひゃあっ！？　まだ、出るのですか……！？　ぷぁうっ、出\nしすぎです……きゃあっ！？　うぅぅ、早く、終わってぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103135" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ぷふぅぅ……ようやく、終わりましたか……うぇぇ、顔中、\nベタベタになって……なんてだらしないオチンチンなんですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103136" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんなに好き勝手に出しまくって……うぅぅ、ちゃんと出す時は出すって言\nうのです！　まったく……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103137" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くん、くん、うはぁぁっ……！　これが、精液の臭い……？　くぅぅ～～っ\n、はぁ、はぁっ……なんて、ひどい臭い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103138" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「熱くて、ドロドロしてて、はぁぅぅ、顔中にこびりついてしまってます……\nくぅぅ、臭いが取れなくなったら、どうしてくれるのですか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103139" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんな臭いニオイに四六時中、包まれるだなんて……はぁ、はぁ……考えた\nだけで、ゾッとします……ふぅぅ、不快極まりないです、っあぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103140" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はあ……？　何度も言っていますが、ウチは興奮などしてないです……んあ\nぁ、はぁ、はぁ……寝言は、寝てから言ってほしいです……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103201" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ……オチンチンがまだ固くて、大っきいままですね……もしかし\nて、まだ出し足りないのですか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103202" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まったく、節操のないオチンチンなのです、はぁ、はぁ、性欲ばかり強くて\n、ふぅぅ、変なところで、ムダに男らしくて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103203" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「し、しかたがないので、んくっ、もう一回だけ、特別にシてやります、ふぅ\n、ふぅぅ、ありがたく感謝するのです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103204" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んれぇっ、れろぉっ、勘違いをしないように……ぴちゃ、ぴちゅちゅっ、こ\nれはあくまで学術的な試みで、ちゅるるっ、ただの実験なのですから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103205" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「一回目と、二回目で、じゅるっ、精液の量や濃さがどのように変わるのか、\nちゅるっ、れるぅっ、それを確かめているだけです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103206" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んくっ、はぁぁ……ウチが、欲しがっているなど、れりょおっ、\n調子にのって、このペニスを、バナナみたいにもぎ取られたいのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103207" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたはおとなしく、れろっ、れりゅうっ、ウチにペニスを搾り取られて、\nちゅ、ちゅうっ、不味くて臭い精子を、吐き出せばいいのです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103208" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅるるっ、んっ、くっ……ふはぁ、ペニスにこびりついた精液が、舌にか\nらみついて……んくっ、こくっ、くっ……ぷはぁ、本当に、気持ち悪い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103209" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「最低の味で、ぴちゃ、ぴちゅるっ、臭いもひどくって、くん、くん……むは\nぁぁっ……あとで、成分分析もしてみましょう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103210" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろぉっ、ちゅるっ、みっともなく、ペニスをびくびくと震わせて、れろれ\nろぉっ、だらしない顔をして、ちゅちゅちゅっ、恥ずかしくないのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103211" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろぉっ、れりょぉおっ、んっ……はぁぁ、まだ、二回目は出ないのですか\n？　こんな時までノロマだなんて、じゅるるっ、本当に使えないですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103212" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「しかたないので、んちゅうっ、れりゅっ、ペニスをナメながら、根本の方も\n手でシゴいてやります、ちゅぱっ、れるっ、れろぉっ……」", "NORMAL" ]},
