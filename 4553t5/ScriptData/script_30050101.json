		{"command":[ "PLAYVOICE", "005_0103213" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「敏感な先端のあたりを舐められながら、れるれるれるぅっ、手で陰茎の根本\nをシゴかれるのは、ちゅるるぅっ、どうです？　気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103214" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ペニスを犬の尻尾みたいに振って、れちゅっ、れりゅうぅっ、大の大人がみ\nっともないですね、ちゅぱっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103215" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こうして、鈴口を舌でほじくると、れろっ、れろれろぉっ、ふふっ、脚が震\nえてますよ？　れちゅっ、もっとマヌケ面をさらして悶えるがいいです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103216" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ……、またカウパー汁が出てきました、ちゅっ、ちゅううっ、んはぁぁ\nっ……相変わらず臭くて、不味くて、最悪の味です、ちゅっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103217" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くん、くん……また、臭いが濃くなってきて……れちゅっ、れりょぉっ、睾\n丸が上に持ち上がって、ちゅるるっ、もうすぐ出そうなのですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103218" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いいですよ、ほら、ちゃぴ、れりゅ、れりゅりゅっ、ムダな抵抗をしないで\n、さっさとイくです、れろれろれろぉっ、早く、精液を出しなさい……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103219" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、ウチにペニスをナメられて、シゴかれて、ちゅるるっ、れりゅ\nうっ、白くて、熱くて、ドロドロしたイヤらしいミルクを、出すのです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103220" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱちゅぱっ、れろれろぉっ、精液を、射精しなさい、早く、私に、れり\nゅりゅうっ、出して、出しなさい、イけ、イけっ……ぢゅううう～～っ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "005_0103301" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぶううぅぅ～～っ！！？　んぶぁっ、ぷぁっ、ま、待って、ペニスの先端\nが、口に……んぶふぅぅぅ～～っ！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103302" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ぶぁうっ、ぷぁぁっ！　んぶぁっ！？　二回目なのに、まだ、こんなに……\n？　んぶうっ、んぐっ、んん～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103303" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぶぷっ、んぶっ、出しすぎ、もう、お口に入らない……口の中、いっぱい\n……んぶっ、ぶぷぅぅ……っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103304" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くっ、んぐぅぅっ、うぐぐぅっ……んくっ、んぐっ、ごくっ、ごくっ、ぶぷ\nぁっ、まだ、精液が……！？　んぶぅっ！？　んっ、ごくっ、ごくっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103305" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぶぁっ、口の中に、精液の味と、臭いが広がって、んごぐっ、ぐくっ、身\n体が熱いぃ、あぁぁ、なにか来る、キちゃうっ、んあぁあああっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103306" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くはっ、はぁっ、はぁっ……ち、違います、イってなど、いないです、精液\nを飲んで、イくなど、ふぅぅっ、バカなことを言わないでほしいです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103307" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅぅ……あんなに出したのに、まだこんなに固いままなんて……本\n当に節操のないオチンチンですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103308" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、しかたないので、もう少しだけ、ウチがシてあげます、ねちゅ\n、れりゅりゅっ、精液を出し尽くして、勃起しなくさせてやります……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103309" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れりょおっ、ちゅるっ、んっ、これは、あくまで実験ですから、じゅるるっ\n、れりゅうっ、どれくらい精液が出るのか、確かめているだけですから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103310" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「早く出すのです、ちゅぱちゅぱっ、粘ついた精液を、ここから、ぢゅるるっ\n、濃くて臭いのを、ぴゅっぴゅと出して、ウチにもっと飲ませるのです……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "005_0103401" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふあああぁぁっ！？　また、顔に、うぶっ！？　うぅっ、やめて、やめるの\nです、ふぁうぅっ、また、こんなにっ……！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103402" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あうぅっ、あくっ、ふぁあっ、どれだけ出すのですか、くぅぅっ、はぁ、は\nぁ、二回目だというのに、また、いっぱい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103403" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「節操なく、こんなに出して……ぷあぁっ！？　あっ、あぁっ……！　顔中ベ\nトベトで、汚くて、くぅぅっ……なんて、ニオイ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103404" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んひゃあっ、まだ出るのですかっ！？　んぶあっ！？　鼻の中に、入って…\n…んぇあっ、うえっ、けほっ、けほっ、ずびびっ……くあぁぁっ……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103405" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、はぁぁっ、臭いが、鼻の奥に……ふぁぁっ、頭がくらくらして…\n…あ、あっ、何かクる、変なのが、キちゃいますっ、んあぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103406" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「っ、はぁ、はぁ……う、うるさいです……ウ、ウチが精液をかけられて、ん\nくぅぅっ、臭いで、絶頂するだなんて……そんなこと、あるわけないです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103407" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くぅぅっ、顔中にベトベトと精液がへばりついて……くはぁぁっ、何より、\n鼻の奥に、精液の臭いがこびりついていて……くはぁっ、はぁっ、はぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103408" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅぅっ、ふぅぅっ……これは、ダメです……ダメな臭いですっ、はぁっ、\nはぁっ……はやく、洗って落とさないと……ふくぅぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103409" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今日はもう、終わりです、ふぅ、ふぅ……コレ以上は、ウチの頭が……身体\nが、おかしくなってしまいますっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "005_0103410" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「また今後、シてやるので……ふぅぅっ、ふぅぅっ……それで、勘弁して欲し\nいです……ふぁぁっ……とにかく、今日はもうお終い、です……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}