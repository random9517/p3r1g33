		{"command":[ "SETTEXT", "そのころ、フィルたちは……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「おいみんな！　損害はどうなってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙海賊Ａ" ]},
		{"command":[ "SETTEXT", "「シールド４７％に低下！　予備のパワーをバイパスしてなんとかやってみま\nす！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宇宙海賊Ｂ" ]},
		{"command":[ "SETTEXT", "「第三砲塔、ダメっす！　うんともすんとも動きません！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「ワイはいま忙しいねん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「こっちも忙しいって言ってんだろ！　繰り返しのギャグやってる場合か！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「邪魔になるから、あなたはこっち来ててください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114530001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「しょぼ～～～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114530002" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「しかし、おもったより手ごわいねえ……時間帝国の連中」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くそっ！　あの艦隊のすぐ後ろにワームホールがあるというのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「っていうか、ガガーンと突っ込んで、ババーンとワームホールをくぐっちゃ\nえよ！　できないのかー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「無茶言うな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530004" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「とてもじゃないけど無理だと思うわ。二隻の海賊戦艦と、ダイアンサスから\nの支援攻撃だけでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114530002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もう少し戦力が必要だ。援軍が来てくれれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114530001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ありもしないものを当てにするな！　やっぱりこうなったら、強行突破しか\nないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530005" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「女には、無謀だと思ってもやらなければならないときがある。いまがそのと\nき」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114530001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いえ、さすがに無茶すぎるでしょ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114530003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「大丈夫！　やれる！　もししくじったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530006" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「しくじったら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114530004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「酒でも飲んで、ひっくり返ってふて寝していればいいんだ。ふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114530007" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いくら海賊だからって無責任すぎますーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114530005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいじゃないか！　私は気に入ったぞ！　突撃だ！　突っ込め！」", "NORMAL" ]},
