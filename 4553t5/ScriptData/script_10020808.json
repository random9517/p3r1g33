		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「感動で涙が止まりません……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「最高でした！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大ヒット映画を劇場で観たカップルの感想かよっ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……いやまあ、昔ヒットした恋愛ドラマの感想としては、正しいのか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかし！！　惚けている暇はないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910002" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしたちの崇高な目的を忘れてはならない！　気合いを入れ直す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「全員整列！！　純情塾塾是（じゅくぜ）、唱和！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「はい！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「『婚活は恥だが役に立つ！』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910005" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「『婚活は恥だが役に立つ！』」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「『諦めません、幸せになるまでは！』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910006" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「『諦めません、幸せになるまでは！』」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「『タフでなければ花嫁になれない、優しくなければ婚活する資格がない！』\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910007" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「『タフでなければ花嫁になれない、優しくなければ婚活する資格がない！』\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やっぱもう意味わかんねえなこいつら……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「婚活とは、花嫁修行とは、闘いだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910008" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だが、強ければそれでいいのか？　男を手に入れればいいのか？　否！　否\n！　否！　否！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「否！　否！　否！　否！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どっかのセリフやキャッチコピーを、まんま持ってきているだけに聞こえるん\nだが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その支離滅裂なアジテーションに、しっかり騙されてやがるこいつらって……\nホント、純粋過ぎないか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いったいどこでどんな教育を受けてきた連中なんだ？　この先、生き馬の目を\n抜く現代社会を生きていけるのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「じゅ……塾長！　ひとつ、お願いがあります！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ん、なんだ。言ってごらん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910010" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「あの、聖典には……幻の、劇場版があるとも聞きました！　それは……観ら\nれないのでしょうかっ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「あ、私も観たい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「自分も観てみたくあります！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふむ……劇場版ねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910011" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ……嫌な予感。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーっと……なあ、俺、そろそろ帰……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「待て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とおっ！？　なんだ、この体勢……俺、壁ドンされてる？　されちゃってる！\n？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「滅多に自分から意見しない塾生たちが、たっての頼みと口にした望みだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910013" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしも叶えてやりたい……が、さすがに劇場版までは視聴していない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は……はい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お前なら、簡単に探し出せるのではない？　なあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「た……たぶん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ならすまないが、あたしとあいつらのために、ひと肌脱いでくれないだろう\nか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「頼むよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やだ何このイケメン、キュンとしちゃう☆", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー……ご主人もエファナティカ様に落とされましたなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113910001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
