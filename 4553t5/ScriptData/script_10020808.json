		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「よぉーし！　全員、聖典は堪能したな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113910001" ]},
