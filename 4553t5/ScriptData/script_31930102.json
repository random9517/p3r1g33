{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……あ……。隊長っぴ……。も、もう仕事、終わったですよね……？　ここ\nからはリリアが……独占しちゃっていい時間ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104101" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "5", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「何をもじもじしているんだ、ですか……？　わかって聞いてますですね？　\n隊長っぴが……隊長っぴが、いつまでも仕事仕事って待たせるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「待ちきれなくなって、一人でエッチ動画……見てたです。でも、今夜呼んで\nくれることになったから……。ムラムラは解消できてなくて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「も、もう限界です……。お願いです！　リリアにエッチ動画みたいなことし\nてください！　エッチ動画みたいなこと！！」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「声が大きい……？　だったらキスしてふさいでください。……ん……。ちゅ\nっ……ちゅっ、チュ……♪　早く……ベッド行きましょう、早く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……っ。ああ……やっと隊長っぴにしてもらえます。ずっとしてほし\nかったこと……。ああもう！　服を脱ぐのがもどかしいです！　んんー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019301_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「え？　それくらいでいい？　半脱げですよ……？　あ、それがいい、と……\n。胸はよく見えるように、前を開いて……スカートをめくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「こ……こんなパターンでどうです……？　エッチいですか？　あっ……！　\nた、隊長っぴ……隊長っぴの隊長が……チンポがすごく大きくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「わぁ……っ。ん、う……。リリアのお腹、縦断しちゃうくらいおチンポ長い\nんですね……。ほら、あそこにあてがうと全長がよくわかります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアの、恥ずかしい入り口から……おへその裏まで届きそうなくらい……\n。ふぁあ……。逞しすぎです、最強です、隊長っぴ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んっ……。両脚を掴まれて、ぐっと広げられると……。もう何も抵抗できな\nいですね。するつもりもありませんが。……リリアの……どうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「自分ではそこそこ可愛いあそこだと思うのですが……。こ、ここはＳＮＳに\nは画像はありませんから、他の人と比べてどうかはわかりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ただ……。じゅわじゅわって、エッチい愛液が湧き出してきて……。リリア\nのピンクの入り口が、てらてら光って濡れているのって……よくないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴのこと、待ちきれなくて湿っているのです……。その、太くてゴツ\nいおチンポを……入れて欲しくって泣いているです……。ん、んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あッ！？　入れてくれるですか？　や、やったぁ……はい！　欲しいです、\n欲しいです、くださ……。っひぃいいいっ！？　ああああああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「入っ……ああああああっ！　えっ！　そこ、そこ行き止まりです、それ以上\nはもう入らな……んうううっ！？　あっ！　まだ入るです！？　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……んんんっんんん……！　っはぁっ……！　はぁ、はぁ、はぁ……！　こ\n……これで全部入りましたか？　あとちょっと？　んやっ……んひうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ストップ！　ストップですっ！　そこが一番お……く、奥ですっ！　あっ！\n　奥っ……奥をおチンポがどちゅんって突いて、突いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んひぁあああ！？　はいっ！　入りました……入りましたねっ。はぁっ、は\nぁ、はぁ、はぁ……！　あうあああ、なんっという重量感……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「一瞬失神しかけました！　はぁああっ……！　す、ごいです……。おチンポ\nの異物感……。何も食べてないのに、お腹がパンパンに膨らんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ぶっとい木の幹が、そのままあそこに突き立てられているみたいで……。苦\nしい……。でも、抜くのは無しですよ。リリアは覚悟がキマってます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「こ、のまま……このまま隊長っぴの本気の力を見せつけてもらいま……す。\nリリアも中を、きゅーって、ぎゅーっていっぱい締めますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「キツキツのあそこの中をかきまわしてください……。エッチ動画みたいに…\n…っ、パンパン腰を打ち付けて、種付け……してもらうです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアの、恥ずかしいところが精液で満タンになるまで……抜いちゃいやで\nす。さ、さあ……動いてください……。……ん！！　んーっんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっ、こ、これ、これひゅっご……！　ひゅっご、しゅごい……！　あっ…\n…！　あそこが、あそこが丸ごと刺激されて……ひああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おチンポがぱちゅんっ、ぱちゅんって奥……を！　あそこの奥をスタンプし\nてるみたい、です！　それで、それで……全体的にかきまわされ、て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「奥がずどん、ずどんって突かれる衝撃……と♪　あそこにおチンポが出たり\n入ったり、出たり入ったりする感覚と……ダブルで、ダブルで襲ってきて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……んぁあ！？　んあっ！　ああっ、ああっああっ！　ド、ドン引きするく\nらい気持ち……いいのですっ！　何コレ、何コレです、な、なにこれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっひっ、ひっあっあっ！　あひぃっ！　ひぃっ、ん、ひぃっ……！　ずっ\nぽずっぽ！　ずっぽずっぽおチンポが！　入って、引き抜かれて……ぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「微妙に違う角度で、何度も何度もあそこの中をえぐりまくって……んあああ\nあ！　快感に慣れさせてくれま、せん！　毎回違うところに当たるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ッあっ、ああっ……ああっ！　た、隊長っぴぃ……！　隊長っぴぃ！　ええ\nええっ？　みんな、みんなこんなしゅっごいことしてた、ですか……ぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「エッチ動画の人達はっ！　こんな……！　くひぃいっ、ひぃっ！　こんっな\nエッチい……！　えちえちなことして楽しんでたんだぁああズルいいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んーんんんんー……！　んんんーっ、んんんんー……！　あ……あ……！　\n隊長っぴ……っ、リリア、リリア今発見したん、ですけ、ど……ぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアのあそこと、隊長っぴのおチンポの形……完全一致してないです！？\n　まるで……最初からくっつく予定だったみたいに……ぴったりで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ぴったりだから……あっ！　ちょっと動かすだけで、隙間なくグチュグチュ\nグチュウって……！　卑猥な水音慣らしておチンポがこすれて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、気持ちいい……！　気持ちいいです……気持ちいい……！\n　んっ……隊長っぴも？　隊長っぴも気持ちいい？　うわあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「両想い、です……んあああっ♪　リリアのあそこと♪　隊長っぴのアソコは\nラブラブで……んぁあっ、愛おしい、です♪　もっともっとしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「えっぐいくらいピストン連発で……ああっ！　二人で一緒にのぼりつめたい\nです！　……はぁっ♪　はぁっ♪　あああ、隊長っぴ……んああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おチンポの動き、どんどん早くなって……あっ！　何か、何か切ないのが伝\nわってき、ますです……！　おチンポが切ない、もどかしいって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「なんにも我慢なんかしなくていいんです！　ん、あ、好きに、好きにしてく\nださい、リリアのあそこ……好きにしてぇ！　っああああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「熱、い……熱いぃいいい！　あああっ……！　隊長っぴ！　ねえ！　ねえっ\n……何か出てる、何かあっついの、あそこに出てる、出てる……ぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……あっ♪　えっ、全然止まんない……ぃ♪　なんか出てるです、信じられ\nないくらい、たくさん……蛇口が壊れたみたいにっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「おチンポのホースからどぴゅどぴゅ、びゅくびゅくびゅるっ、びゅーっびゅ\nーって……ああ♪　そうです、これ……これ中出し……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「膣内射精、です……あぁ、知ってます！　エッチ動画で予習しましたか、ら\n……♪　んくっ……！　くぅううっ……とてもあっつい……熱いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっ、あーっ……んう！！　……っはぁっ……！　長い射精で\nした……ぁ。身悶えと身震いが止まらないくらい最高の……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「『おまんこがキツすぎてすぐに出た』？　んふっ……！　ほ、本当ですか？\n　ゆるゆるじゃなくて良かったぁ♪　は、初めてだから当たり前ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……キツキツ……。すぐに出しちゃった……♪　そう言われると気分がいい\nです。天にも昇る気持ちです。だから……だから、もっとしたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「このまま抜かないで、エッチ続けましょう……。あっ♪　隊長っぴのおチン\nポもそれがいいって言ってます。リリアの中でばんざいしてます……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……あっ♪　ふふふっ……！　そうですよね、まだします、よね……♪　あ\nっ♪　あぁ♪　回復力すごいです、もう力を取り戻してる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……はい♪　そうです、リリアをめちゃくちゃに抱いてくださ……い。あう\nっ♪　力いっぱい、犯して……。あんっ♪　とろけさせて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あぁっ……ああ、あぁっ、んんう……！　くふぅう……♪　あふっ……あっ\n！　あっあっあっ！　いいです、その調子……ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリア今、エッチ動画と同じことしてもらってる……ぅっ……！　ずっとず\nっと憧れてたです、隊長とエッチ動画するの、……あっ、エッチっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長のエッチ気持ちいい……！　気持ち良すぎて、勝手に腰がくねくねしち\nゃいます、あっ！　エッチの作法なんてしらないのに、本能が♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「本能がこの人は強いオスだって♪　隊長っぴは世界一エッチがうまくておチ\nンポかっこいいって言ってます♪　ん、ん、リリアも同意……です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴのエッチ気持ちよすぎです……ぅっ！　あああ……っ！　胸がとき\nめいて……あっ！　乳首が勃っちゃって……すみませんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴが見てるって思うだけで、おっぱいも気持ちいいですっ！　おチン\nポが出入りしてるあそこも気持ちいい！　あっ、あっ、天才現るぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「エッチの天才、が♪　リリアのあそこでエッチしてるっ……あぁ、ありがた\nいです、感謝の気持ちでいっぱい、です、……隊長っぴもですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「『また射精したくなってきた』？　……お許しなんていりません！　リリア\nのあそこは隊長っぴのフリー回線です、２４時間ご自由に……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……ん！　んひゃうううっ♪　チンポ、チンポが中で膨張してますよっ……\n。出すんですか？　出すんですね……ああああ、くださいいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴのビチビチ跳ねまわる、元気で天才的な精液発射してください♪　\nそしたらリリアも合わせてイくです……。み、見ててくださ……いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ほらぁあ♪　ほらほらほらぁああ♪　中出しされた瞬、間に絶頂ですっ……\n！　初エッチ初イキです、すっごい相性です……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あふぁあああ……♪　腰がガクガク……もう当分立てないくらい、射精……\n射精♪　隊長っぴの膣内射精……完璧でぇえええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアの中、精液が押し合いへし合いぎゅーぎゅーです……！　それなのに\nまだ入ってきて♪　まだ溜まってって♪　……あーエッチの天才ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「隊長っぴ……！　出しながらもっと奥にきて……！　っうん……！　一番奥\nで……直に熱さを感じたくて……。ッん……んん、染み入る……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアの赤ちゃんルームに、とぷっ、とくってあったかい精液が流れ込んで\nって……。身体中がぽかぽかするのです……、指先まで！　ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んん……！　んん、んんっ……んん……！　……はあああ♪　これで全部、\n受け止めた……ですよね？　あああ……射精、良かったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアの中で一所懸命、ビックンビックン脈打ってました……。孕ますぞー\nって……。エッチ動画でも人気あります……中出しは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「だから、どうしてもしてほしかったのです……。そし、て……っ。せっかく\nもらった精液は無駄にしちゃいけない……ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「なので、念には念を入れて……もらった精液は、このまま吸い上げます。…\n…ん！　はぁあっ♪　はぁっ、どうですか、動いてます……か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアが力をこめると、赤ちゃんのお部屋がちゅーって精液吸い取るんです\n。……ん……。これで、いいです。上手にできました……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んゅうううう……！　イ……っく……！　んぁっ、あっ、ああ……！　……\nあ、あれ？　お、おかしいのです……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアが感極まった途端に、隊長っぴがおチンポずにゅうって抜いちゃって\n……。まさか！　外に出すのですか！？　そ、そんな……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あっあああっ！　ひ、卑劣です……！　リリアを中出し大好き娘にしておい\nて……あえての外出し……ぃ！　あぁーっ、ひ、卑怯ですーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっうっ♪　んんうう♪　飛び散った精液が、砲火みたいで綺麗\n……ですけどもっ……。おあずけされたあそこがヒクヒクです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「い……意地悪、いじわるいぢわるぅうう……！　リリア、真剣にまぐわいし\nたですよねっ！？　エッチ動画顔負けなくらいイっちゃいましたよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「くぬぅううう……。屈辱の膣外射精ぃい……！　あぁもう、どこもかしこも\nネットネトです、精液漬けにしないでくださいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……はぁあああ……。がっくりです……がっかりです……。　『エッチ動画\nでも外出しはする』？　それはそうです、……けど……。ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019301_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「『外出しはリリアを自分の色に染めたって感じで満たされる』？　ぁ……。\nそ、そういう考え方も……ある……ですか。そうですか、ふぅーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアは隊長っぴの色……。リリアは隊長っぴにマーキング済み……。うん\n……それは悪くないですね……。リリアは隊長っぴのもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……う。キュ、キュンとなんてしてないです！　次回は間違えないでくださ\nいねっ……。でないと全力で拗ねまくるです！　約束です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}