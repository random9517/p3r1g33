{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0133" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　大勝利だっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見回りに来た猿をぶっ飛ばすと、俺たちはそのまま外に出て大暴れを続ける", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ははははっ！　寒さに震え、縮こまっているなど私たちらしくない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「だね！　やっぱりこうやって暴れてるのが、一番わたしたちらしいよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020107110001" ]},
	{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "よし！　いいぞいいぞ！　このままいけ！　この調子でいけば……！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "猿は数が多いが、しょせんは獣だ。本気を出したウチの連中にゃ、抵抗なんて\nできるはずもない。面白いくらいに吹き飛ばされていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿１" ]},
		{"command":[ "SETTEXT", "「キキキーキキーーーーー！！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「身体もあたたまってきた！　いくらでも行けるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな！　調子が良すぎて、敵をあらかた打ちのめしてしまったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107110001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へっへーん！　ざっとこんなもんさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107110001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "脳筋女どもは猿たちをぶっ飛ばして上機嫌。ここでもう一発、ヤツらのハート\nをぐっ！　とつかんでおこう。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんな！　聞いてくれ！！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……な、なんだ突然……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あったかいごはんの話～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107110001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ！　まさにその話だ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0068" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「諸君、私は食べることが好きだ。諸君、私はお風呂が好きだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0069" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「たべもの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お風呂……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お腹が空いた時に、すぐ気軽に食べられるファーストフードがあるのを見つ\nけると心が躍る」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……ごくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おうちで！　組織で！　コンビニで！　喫茶店で！　焼き肉屋で！　この地\n上で行われるありとあらゆる食事行動が大好きだ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「諸君、私は飲食を！　一円も払わぬバイキングディナーを望んでいる！　諸\n君、インクレディブル・スクワッドの諸君！　君達は一体何を望んでいる？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「めし！　めし！　めしーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ごはん！　ごはん！　ごはーんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よろしい！　ならば食い放題だ！　地上を支配する猿どもを制圧し！　この\n試される大地に王国を！　バイキング王国を築くのだーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「食べ放題！　食べ放題！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「飲み放題！　飲み放題！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107110001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　すてき……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010107110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「我らに時間無制限バイキングを！　一日三食のバイキングを！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおおおーっ！　食い放題！　食い放題！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107110004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「食べるぞー！　胃もたれするまで食べるぞー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「称えよ！　バイキングの王を！　胃もたれ・カツマ様を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「バイキングの王！　つまりバイキングのキング！　略してＶＫ（ブイケー）\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　ＶＫを称えよ！　ＶＫ！　ＶＫ！　胃もーたれカツマ！　胃もー\nたれカツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107110003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "空腹による、極度の錯乱状態が俺を新しい王にした！　……というか俺を含め\nて全員、出撃前からの変なテンションを引きずってたせいかもしれない。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ＶＫを称えよ！　ＶＫを称えよ！　ＶＫ！　ＶＫ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010107110002" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ＶＫ！　ＶＫ！　ＶＫ！　ＶＫ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107110002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0133" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "その歓声を聞いて集まってきたのだろう。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺達は再び、猿の軍団に包囲されてしまった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿１" ]},
		{"command":[ "SETTEXT", "「ウキキー！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "猿２" ]},
		{"command":[ "SETTEXT", "「キキーキキー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「普段なら恐怖だが、今の俺は無敵だ！　さあ行け！　猿どもを倒し、暖かい\n食事を！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおおおおおー！　めしーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107110005" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぉおおおおお！　私を見ろぉおおお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107110007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
