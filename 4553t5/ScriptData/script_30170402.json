{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「えっ……ま、また私のエッチな話を聞きたいんですか……？　出来ればとて\nも過激な話？　そ……そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あれは、その……。どうしても身体が疼いてしまって、……お願いしてエッ\nチをしてもらった時のことです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……は、はい……。今日、この教室に呼び出したのは……その……私と、\nしてほしいからです……。何をって、い、言わせるんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001704_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あなたに毎日毎日からかわれて、……あぅ……身体をもてあそばれて……。\nが……我慢できなくなってしまったんです。だ、だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんには内緒で……。して欲しくて……。ダメ、ですか？　絶対に\nご迷惑はおかけしません。エッチも普通ので……大丈夫です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ただ……。この疼きを……自分ひとりではどうしてもおさえきれなくて……\nそれで。あなたを頼ってしまいました。やっぱりだめですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……え？　机の上に寝そべって、上手におねだり出来たらしてくれる……？\n　ぁ……。お、おねだりなんて、私……恥ずかしいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「交換条件なんですか？　どうしても私の口から聞きたい？　……う、うぅ…\n…。ど、どうしよう……えっと……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「わ……かりました。上手く言えるかどうかはわかりませんが、頑張ってみま\nす。……ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……えっち……。エッチ、しませんか……？　んっ、こ、これくらいでは興\n奮出来ない？　そんな……もう思いつかないです。あ、あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いつもあなたがするみたいに……私の身体に触って、キスをして、……セッ\nクスして欲しいです。具体的にですか？　ぐたいてきに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「きゃっ！　い、いきなり何をするんですか！　私の胸を鷲掴みにして……！\n　あっ……言います、言いますから揉まないでくださいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404112" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ふぅっ、んんんっ……んん……！　い、いやっ……いけません、そんな風に\n胸を……おっぱいを、ぐにぐに指で揉みしだかれたら……私……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おねだりどころか何も言えなくなっちゃいますから……！　んっ……くぅ…\n…くぅううっ、ふぅう……。ふ、ぅんん……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「乳房がいつもより熱いですか？　あ、あぁ……それってたぶん……。んっ？\n　ち、乳首が勃ってすごく存在を主張している？　……やっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ……！　さ、触っちゃだめです……乳首は、そこはすごく敏感で、弱く\nて……。ふぁっ、あっ……はぁっ、ゾクゾクするから……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「い……いや……っ、ふぅううっ。だ、だめ……だめ、です……ぅっ。あっ…\n…指でクリクリされたら……も、もう……気持ち良くなっちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んふぅううっ……んん、……ぁっ、こ、言葉……言葉が口に出せなくなっち\nゃ……。んん！？　あっ、強い、強いですから、乳首……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「乳首コリコリひっかきながら、おっぱい揉むの……本当に、ほんとに弱くて\n……。私……。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ぁっ……どんどん、全身が熱くなってきちゃいま、す……！　ふううっ、\nくふぅうっ！　はぁっ、はぁあっ、あぁ……こんなのだめ……だめぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、あのっ……おっぱい……おっぱい揉むの中止してください……っ。\nしゃべ、喋れないです、……あっ、ぁっ、あぁっ、……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ん！？　んっんんっ！？　ふぁああっ！？　な、舐めるのもだめですっ……\nやぁっ、す、吸うのも、お口の中で乳首を転がすのも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「声っ……漏れちゃって全然何も考えられな……。んふぅうっ……！　恥ずか\nしい、恥ずかしいです……！　ごめんなさい、ごめんなさい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「上手におねだりできなくて、……ぁっ、前戯、前戯の胸だけで、こんなに\nトロトロになっちゃって……あああ、幻滅しましたよね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……あなたの攻めに負けずにちゃんとおねだりをしないと、い、入れてくれ\nないんですか？　うう……そんな……無理ですよ……。ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「感じすぎて何も言えな……。っくぅううっ！　わ、わかりました……！　\nわかりました、言いますっ、言いますから胸を噛まないでくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチン……あなたのオチンチン、入れて欲しいです、挿入してほしいで\nす……私のオマンコに……ふぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「頑張って、精一杯気持ち良くしますから……っ。オチンチンください……！\n　はい、そのままおっぱい、おっぱいをいじりながら……。あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んあっ！？　あああああっ……あああっ！　太いぃ……！　あっ、あっあっ\n！　オチンチン、太いオチンチンが突然私の中に入ってきて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～～っ……！　お前がおねだりしたんだろって……そ、そうで\nす……そう言われたらそうですけど、あまりにきゅ、急で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いきなりで、大きくて、ふ、太すぎて……驚いてしまいました……。あっ、\nう、嘘みたいです、私でこんなにオチンチンが太く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「う、嬉しい……です、はぁ、はぁ、あぁ……っ。すごく強引に、にゅるうっ\nてオマンコの中にもぐりこんできて……。そ、それでっ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ぬぽっ、ぬぽっ、てエッチな音をたてながら……くぅううっ、ふぅっ、ふぅ\nうう～～～っ、小さく動いてて、あっ、う、動いてます、すごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「や……やぁあ……やぁああ……っ。ど、どうして……？　私の腰も、か、勝\n手に動いちゃってます……。あっ、あなたの動きに合わせ、てっ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404134" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「クチュ、クチュって音をたてながら……自然に揺れて……。んんんっ……。\nは、はしたないよぉ……こんなのお姉ちゃんに絶対言えない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ご……ごめんなさいお姉ちゃんっ、わ、私……私、オチンチン入れてもらっ\nて、腰、腰動かしちゃってる……ごめんなさいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やだぁ、あぁ、止められないよぉ……！　んっ……。えっ？　すっごくキツ\nくオチンチンを締め付けてる……って……。ぁ……そんな、そんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「違うんです……っ、それもオマンコが勝手に蠢いて……！　私の意思じゃ…\n…ああっ！　と、止まってぇ、止まって……恥ずかしいよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「本当にごめんなさいぃ……！　ふぁっ、あぁ、あぁっ、あぁ……！　私の身\n体、オマンコ、精液が欲しいって言ってるんだと思います……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「びゅーびゅー出して欲しいです……！　ごめんなさい……！　あっ、…\n…あっ、こうですか？　こうして締めると出ちゃいますか？　ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅううううう……！　ふぅうううう～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あなたの……、あなたの精液がドクッドクッて脈打って飛び出すたびに……\n私のオマンコが、ぢゅるぢゅる～って飲み干してるのがわかります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やっ……こ、こんなに、こんなに私って貪欲でしたか？　あぁ……なんでこ\nんなに求めちゃうの……！　い、一回精液をもらってるのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「今出してもらっている最中なのに……また腰が動いちゃう……。んっ……ん\nっ、んっ……。１回だけの射精じゃ満足できなくなっちゃってるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すみません……っ、このまま抜かないで、私のオマンコの中にいてくれます\nか……？　ふぁ……っ、一所懸命腰を振りますから、だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「もっと、もっとしたいです……！　うううっ！　オチンチン、硬くて、気持\nち良くて……！　あっ、む、胸も、胸も強く揉みまくってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んんん～～っ……！　そうです……！　上半身をあなたの手で、下半身をあ\nなたのオチンチンでいじめられるの、すごくいいです……感じます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404207" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ、あぁ……っ。私……私、いつのまにかむっつりスケベになっ\nちゃってたのかもしれません……。だって全然やめられなくて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　うぅ……うぅっ♪　あなたの動きに合わせながら……！　ふぅ\nうっ♪　力の限りオマンコズプズプ前後させちゃってます……。んん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「激しいピストンを身体でおねだりして……あっ、胸を揺らしながら、……\nオマンコでオチンチンを味わっちゃってる、堪能しちゃってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やぁああ……愛液が、愛液がオマンコの奥から溢れ出して……！　見ないで\nくださいぃ……！　でもやめないで、ここでやめられるのは辛いです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「最後まで、最後まで突きまくってください、私のいやらしいオマンコをドチ\nュドチュ突き上げてくださ……、んっ、んぁああああはぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「だめぇ……だめぇ、気持ち良すぎるよぉ……！　私のばかぁ……っ、快感で\n頭が真っ白で、……あっ、ぁっ、勝手に、勝手に締めちゃいますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチンつかまえて、オマンコで締め付けちゃってます……！　んぁああ\nっ……何か、何かチカチカしたのが目の前で光って……、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やだぁっ……。イ、イッちゃいました……っ。簡単に、……んっ……身体が\nあなたを完全に受け入れて、あなたの喜ぶように動いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オマンコがビクビク痙攣しちゃいます……っ。あぁ、見ないでください……\nっ。絶頂してる顔、イッているところを見られたら恥ずかしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んくふぅううっ！　あっ、あっ……ま、またイっちゃいました……ぁ。こん\nなことってあるんですね、ずっとイクのが止まらなくって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、あなたの精液で満たされたオマンコをズプズプ突いてもらいながら、…\n…激しくかき混ぜてもらいながら、何度でも絶頂させられてしまいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んぅううう……！　うぅうう……！　あのっ……もし良ければなんですが、\nて、提案させてください……。もう一度射精しませんか……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私、あなたにまた射精してほしいです……！　ギットギトのザーメンミルク\n……ください、ください……お願いです、おねが……い、んんん～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます……ありがとうございますぅう……！　ふぅうう\nっ……ふーっ♪　ふーっ、ふーっ、ふー……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああああ……あったかいザーメンが、私のオマンコの中にドピュドピュ注が\nれていきます……。熱くて、……はぁあっ、濃いザーメンが……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404302" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んん……！　こんなにたくさん出してくれるなんて……あなたも喜んでくれ\nたって思っても、うぬぼれても……いいですか？　あぁああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すごい……中でブルブル震えてますよ……。そしてその度に……新しい精液\nがびゅるーっびゅるーって……受け止めきれないくらいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私……我儘を言ったのに、こんなに幸せにしてもらって……なんだかバチが\n当たっちゃいそうですっ……。ふぅうっ、まだ、まだ出てます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「っんんん……っ。これで……これで全部気持ち良く出せましたか……？　は\nぁ、はぁ……はい。私は満足です。満足しすぎたといいますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「自分がここまで快感を楽しめるタイプだったことに……すごくびっくりして\nいます。今も、まだ興奮がおさまらなくて……ドキドキして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「夢の中にいるみたいで……。あぁ、お腹も頭もずっとぽかぽかしています。\nきっと、だらしない顔をしちゃってるんだと思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ……！　そんなに見ないでください……。こんな顔、お姉ちゃんにも見\nせたことないんですよ……。誰にも言わないでくださいね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「うう……。なんだか、落ち着いてきたらどんどん照れてきちゃいました……\n。今日のこと、どうか秘密にしてくれませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あぁっ、ありがとうございま……って、きゃぁあっ！　ど、どうしてオチン\nチンを引き抜いて……。んぅっ、し、信じられないです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私の顔と身体に射精を……？　ふぁっ……あぁっ、これも嫌じゃないです、\nけどぉ……。っあっ……！　こんな量伝い落ちちゃって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んふっ……ふぅうっ……！　んーっ……んー……っ！　次々精液が飛び出し\nてきます……！　肌にドロドロってザーメンミルクがこぼれて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、あなたっていじわるです……！　あっ……あっ、全身に精液を浴びるの\nも気持ちいいですけど……。あっ……わ、わかってましたよね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それなのにビューっビューって外に……んっ、くぅっ、くふ……んんっ……\n！　ああ……も、もったいないです……どうしよう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ふぁああ……。はぁああ、はぁああ……っ……。私の身体が全部、あなたの\n臭いでいっぱいになってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「こうして私にかけると征服欲が満たされますか……？　こんな姿、お姉ちゃ\nんに見られたら怒られちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「その時は……一緒に言い訳を考えてくれますよね？　んん……。あれ？　結\n構、皮膚にべったり貼り付いているんですね、この精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私の上でぷるぷるしてます……。なんという粘着力……。いつもこれを中に\n出されているって思ったら……少し怖いくらいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「すっかり私は、あなたの虜になっちゃいました……。い、いいのかなぁ、こ\nんなに溺れちゃって……。自分が自分じゃないみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
