		{"command":[ "SETNAME", "時間帝国兵たち" ]},
		{"command":[ "SETTEXT", "「うわああーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_924_010114520001" ]},
		{"command":[ "SETCHARA", "0", "char_00092401_01", "9", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00092501_01", "9", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
