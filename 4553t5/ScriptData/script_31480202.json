	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……隊長氏と、こんなことになってしまうだなんて……ああ、ヤバいで\nござるっすっ、マジでドッキドキでござるっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「それで、ええっと……うわぁ、緊張してるでござるっす……はぁ、ドキドキ\nで胸が爆発してしまいそうでござるっすよぉ～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「って、おっぱいめちゃんこ小さいから、爆発しても被害が小さいっすよね～\n～って、何言わせるんでござるっすか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「……いや、あの……余計なこと言ってしまったでござるっすね。へへ……い\nや、まじ緊張してるんっすよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「だって、恥ずかしいっすよ？　マジで……うう、これまでウチはどれだけド\n貧乳にコンプレックスを持っていたか知らないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ま、まあ……足の速さは、おっぱいの小ささに助けられてるところはあるん\nすけどね～……あははは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あ、申し訳ござらんっす……くのいちだってこと、つい忘れてしまうっすね\n……はぁ……向いてないのかなぁ、くのいち……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「っと、そんなことどうでもいいでござるっすね～……えへへ、えーっと、そ\nれで？　拙者、このまま寝転んでればいいでござるっすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「は、はいっ、いつでもオッケーでござるっすっ……あ、でも、こういうのあ\nんまり経験ないんで……ゆっくり、お願いするでござるっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はー……はー……緊張する～～……うああっ、おちんちんが、触れてる……\nああ、これが中に……ひうぅ……は、入って、ぐっ、ううう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひぐぅぅっ、んはぁ……あはぁああん！　おちんちん、入って、くるぅぅ…\n…っ、うぅ、うああ、はぁ……はぁ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んくぅ……はぁ……隊長氏の、おちんちん、立派でござるっす……はぁ、ふ\nぅ……おまんこが、苦しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ん、あっ、あぁぁああん！　ずるずる、中で擦れて……ぐっ、うあぁ……は\nぁ、あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……あはぁ、苦しいけど、ん、んん、気持ちいいでござるっすよ……は\nぁ……あっ、あぁあああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……奥で、ゴツンってぶつかったでござるっす……ふぅ……あふぅ……\nこの、ミッチリとお腹が詰まる感じ、気持ちいいっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、動いてくれて、大丈夫でござるっすよ……拙者、死人となっ\nて、隊長氏に仕える所存……覚悟完了でござるっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁ……はぁ、はぁ……マンコの中身が、引っ張られちゃうぅ……お\nちんちんに持っていかれちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁ……はぁ……固くて、大きくて……ぐぅ、ひゃうぅ……っ！　あ\n、ああ、はあぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「丸く膨らんだ先っちょが、ぐぅ、ううう……中でグイグイ動いてるっ……あ\nっ、んひぃ、す、ごい、っすぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「熱い……おちんちん、こんなに熱いだなんて……あっ、ああっ、マンコが、\n火傷しちゃうでござるっすぅ……はぁ、あはぁ……んひぃぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んくぅ……あはぁ、はぁっ、マンコが、よじれちゃうぅ！　内側が、引っか\nかって……あっ、あっ、んはぁ！　きゃうぅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「た、隊長氏ぃ……すごく、いい……はぁ、ふぅ……拙者、おっぱいが小さい\nせいで、あんまりモテなかったから、すごく嬉しいでござるっす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ふわぁ！　んぐぅ……はっ、あっ、あああ……また、入って、くる……押し\n込まれて、ぐっ、うああっ！　子宮が持ち上がっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はっ、ああぁっ、はぁぁあん……お腹が、苦しいでござるっす……はぁ、は\nぁ……あへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「切腹した時ぐらい、苦しいでござるっす……はぁ、ふぅ……いや、したこと\nないので、わかんないっすけど……ふぐぅ、あはぁ……はぁぁあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「この、引っ張られる感触……すごくいいでござるっす……はあ、ああっ、お\n、押し込まれる感じも、いい～～～……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「マジ、ヤバいっす……あっ、あっ、はぁ……ぁぁあん……ふえぇ？　乳首が\n立ってる……ぅ？　そりゃ立つでござるっすよぉ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「もう、隊長氏も顔を見るだけで、乳首がビンビンになっちゃうかもしれない\nでござるっすぅ……はー……はー……んへぇえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ああん、気持ちいい……もっと、もっとしてぇ……はぁ、はぁ……んぐぅ、\nひやぁぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひぐぅ、ひやぁぁ！　はー……はー……んくぅ！　ひゃへぇぇぇ……おちん\nちん、震えてる……ああ、ああ、イキそうでござるっすかぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はっ、はっ、はぁ……あひぃぃぃ……っ、激しく、なってるっ！　ま、まっ\nてっ、そんなにされたら……あっ、ぐぅ！　ひうう！　ひやぁぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「バキバキに膨らんだオチンチンが、ぐっ、んひぃぃ……マンコの中で、暴れ\nまわって……ひぐぅ、んひぃ！　はぁ！　ひやぁぁぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あああ、すごぉい……じゅぼじゅぼ音がする……マンコの奥から音が聞こえ\nてくる……んひぃぃ……イクぅ……ウチもイキそう、っすぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あ、あはぁぁ……オッケー、ですっ、出して、くださぁいっすぅ……ウチの\n子宮に、熱いの全部ぶちまけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひやあっ、い、イグっ…………イキます……あっ、あっ、ひやああ……んん\nんっ、んぎひぃぃぃぃぃ……っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204135" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あはぁっ！　はぁぁぁぁあん……！　お、おお、おちんちん\n……暴れてる……マンコの中で飛び跳ねてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ひぃ、んぎぃぃ……あはぁぁあ……っ！　精液が、入ってくるぅ……マンコ\nの中、熱いので、いっぱいにぃぃ……んひぃぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ああ、あああ……イッてるぅ……拙者、ん、んん、ふぅ……イッてるで、ご\nざるっすぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ、あはは……急に、今の自分がくのいちってことを、思い出したでござ\nるよぉ……ふぅ、にんにん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……よかったぁ……本当に、気持ちよかったでござるっす……\nふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「ふぅ……これで終わり…………じゃないみたいでござるっすね……はぁ、は\nぁ……だって、まだこんなにカチカチでござるっすよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「わかってるでござるっす……拙者と、もう一戦交えたいと、そういうことで\nござるっすな？　ふふ、全然オッケーっす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あっ……ああ、そのゆっくりとした動き……超いやらしいでござるっす……\nはぁ……ああ……んぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅ！　あ、ああっ、精液を吸って、子宮が膨らんでる……いっぱ\nい、ぶつかってる……子宮が、めり込んじゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「はっ、はぁ……あああん、駄目ぇ……苦しい……お腹に、おちんちんが食い\n込んで、くる……はぁ、んんんっ、ひぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「マンコが、おちんちんの形になっちゃってる……。はっ、ふぅ……ああん、\n身体が、隊長氏のモノになっちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「んっ、んん、あはぁあ……やだ、ウチ、自分で腰、動かしてる……はぁ、は\nぁ……んひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「なんてはしたない……ウチ、もう……ああぁ、はぁ、はぁ……マンコが勝手\nに、おちんちん、締め付けちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「出し入れされるの、気持ちいい……ああ、おちんちんを握りしめたまま、腰\nが動かされると……いっぱい擦れて……ひっ、ぐぅ、あはぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……マンコが、どんどんエッチになっちゃうぅ……あ、ああ、欲し\nい、もっと気持ちいいの求めてるぅ……ん、くぅ、あはぁぁぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00014802_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あああ、激しく、なっていく……おちんちんが、ガンガンぶつかって、くっ\n、うううぁ、はぁ、はぁ……あへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「おちんちんが……んぐぅ、あはぁ……子宮をゴツゴツノックしてくるぅ……\nあ、ああ、お腹の中で、精液がチャプチャプ揺れてるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「あ、ああ、おまんこが締まっちゃう……ん、はぁ……おちんちんの形が、ク\nッキリわかるでござるっす……ん、あっ、あぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「膨らんだ先っちょ、カリ首……根本の部分まで、あ、あああ……浮かび上が\nった血管まで、マンコで感じちゃうっすよぉ……」", "NORMAL" ]},
