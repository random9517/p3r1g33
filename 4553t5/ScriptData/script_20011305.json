{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「やった！　当たりました！　超フェイザー砲……命中しましたぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560001" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「侵略者（インベーダー）のおよそ９９％が消滅……。残り１％も、勝ち目が\nないと見て撤退を始めたようです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021560001" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "残存エネルギーの全てを注ぎこんだ超フェイザー砲の威力は凄まじく、宇宙（\nそら）を貫き、全ての敵を焼却し尽くした。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「いよぉっし！　みんなーありがとうっ！　最ッ高に冴えた一撃だったよー！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560001" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「やっぱり悪は滅びる宿命（さだめ）！　ダイアンサスに敗北の文字はなーし\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ふぅ……。なんだかんだでなんとかしちゃうのが、艦長のイケてるとこ……\nですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021560002" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「良かったぁ……。私生きてるっ、生きておうちに帰れそうですー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560002" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ふっふっふっふっふ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560001" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ん？　なあに、スイレンちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560003" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「さぁて皆さぁん。大勝利に浮かれているところ、悪いけどぉ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560002" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「今回の勝利の代償も、とんっでもないことになっちゃってるから……覚悟し\nてね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セリカの言う通り、侵略者達を一掃したものの……それでダイアンサス自体の\nダメージが回復するわけもない。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スイレンがとうとうと読み上げる損害は、一同の血の気を引かせるには充分す\nぎる金額にのぼっていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ざっくりまとめると～、『絶対本部に大目玉食らう』感じでーす。生き残っ\nたことを後悔するくらいしぼられるわよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560004" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「むっ。誰なの？　大事なダイアンサスをそんなに酷使した悪いヤツは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560004" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「かかかか、艦長に決まってるじゃないですかっ！　もー、今回ばかりは私達\nにもフォローは出来ませんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560003" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「毎度勝つからいいよーなものの……。少しでもしくじってたら、全員宇宙の\n藻屑コースだったんで……そのへんガチで反省してくださーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021560003" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「で、でもでもでもー！　勝ったんだからいいじゃない！　そんなに怒らなく\nたってー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560005" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "再びスイレンにこっぴどく怒られるセリカと、子供じみた言い訳を繰り返すセ\nリカに呆れるクルー達。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ、本部には艦長だけ行かせるっていうのはどうかしら～。私達は疲れた\nし～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560005" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スイレンの提案に、スミレとリリアが前のめりになったその瞬間だった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「……ご苦労さまだったねぇ、ダイアンサスの諸君」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560001" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間に、ダイアンサスに接近していたのか。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "勝手知ったる他人の艦（ふね）とばかりにブリッジに入りこんだフィルが、セ\nリカに向かって一礼する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「どえらい手間をかけちまったね。でも、おかげさまで窮地を脱することが出\n来たよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560002" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「フィルちゃぁ～ん！！　あなたも無事だったのね、良かった～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560006" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「だいぶしてやられたけどね……。そっちのキツーい一撃に救われたってとこ\nかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560003" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ほらー！　ほらー！　撃って良かったんだってー！　人助けなんだよー！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560007" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560004" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「や、こっちの艦（ふね）にもちょっとカスって、ヒヤヒヤさせられたけどね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560004" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「す、すみません！　うちのポンコツ艦長がご迷惑を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560007" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「いいってことさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560005" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あはははは……。よかったね、みんな、よかったね……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021560001" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "力を使い果たしたのか、弱々しく笑いながら床に膝をつきそうになるシャム。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その腕をぱっと支え、持ち上げたフィルは驚いた口調で呟いた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ん？　あんた、イノセントアサシンじゃないか……！？　トレミー海賊団も\n、あいつらに襲われてたのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560007" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「うん……。いきなりだったから、避けきれなくて……。きみたちも、そうだ\nったんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021560002" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ああ。突然さ。やつらの存在は聞いていたけど……油断しちまって、危ない\nところだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560008" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あの侵略者たち……。インベーダーって言ったっけ？　あれってどういう存\n在なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560009" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私達も……。これからも継続して敵対する可能性があるのなら、可能な限り\n情報を知っておきたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560008" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "興味津々な様子のセリカ、スイレンにシャムとフィルは目を合わせ……それか\nら静かに語り出した。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "-300" ]},
	{"command":[ "SETCHARA", "1", "char_00012901_01", "0", "CENTER", "300" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「それがね、まだよくわかってないの。わたしたちにも……これはほんと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021560003" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ただ、わたしたち……。実は今、地球のある特殊部隊……インクレディブル\n・スクワッドと協力していて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021560004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「多次元宇宙を侵略している『侵略者（インベーダー）』達と戦っているんだ\nぁ。それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021560005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「戦いの中で、相手の残骸や艦への攻撃方法……。戦闘スタイル、なんでもい\nいからデータを集めてるのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560009" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「それで、あいつらが何者なのか。何が目的で、アタシら人類を襲い出したの\nかを調査中なのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「では、まだほとんど未知の物体Ｘってことですよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560005" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「それを突き止めるから面白いんだよっ！　まだ誰も知らない謎の宇宙怪物！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560010" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「よっしゃぁ！　義を見てせざるは勇無きなりってね、私達も加勢しにいこう\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021560011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "少し面白そうな話題があれば、すぐ吹き上がるセリカに、スイレンも、スミレ\nも、リリアもやれやれと呆れ顔になる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ああ、それならこれを見ておくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560011" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フィルが胸元から取り出した一枚の写真に、全員の視線が注がれた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「真ん中に写ってるこの男。彼がその特殊部隊のリーダーなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560012" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ええと……お名前は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560007" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「カツマ。なかなかいい男だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010021560013" ]},
	{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「幸薄そうな感じがするけど、そこがまたそそるなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560010" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「か……か、彼女……いるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021560009" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「いいじゃなぁい。私も協力しちゃう。そろそろ、この艦（ふね）にも男手が\n欲しいと思ってたのよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021560011" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
