{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬし、いつも妾の胸ばかり見ておるのぉ……そんなに気になるのか？　\nん～？　まさか妾が気づいておらぬと思ったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あれだけいつもじろじろ見ていれば、嫌でも気づくわ。それで、どうなの\nじゃ？　妾の胸が気になって仕方ないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほうほう……そうじゃ、大きかろう。それに形も綺麗……？　ふふふ、相\n変わらず口が上手いやつじゃ。人の子より、妾が気になるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、これ……そんなに褒められると、照れてしまうではないか……身体が\n火照ってきたわ。ふぅ～、暑い暑い～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、また……胸をじーっと見つめて……他のおなごに同じことをすると\n嫌われるから、気をつけるのじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「見るなら、妾の胸だけにせい。こうやって……可愛がってやるからのう……\nんっ……どうじゃ……おぬしの大好きな乳じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00024101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なにを驚いておる……こういうことくらい知っておる……紅葉合わせと言う\nのじゃ……これをすると男は悦ぶのじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふっ……やはりそのようじゃな……うむ、気持ちいいか？　それならよか\nった……んっ……これくらい、朝飯前じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それにしても、おぬしの逸物も……ずいぶんと大きくなっておる……先っぽ\nが禍々しい形になって……見ているだけで、身体が熱くなる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ん？　それだけ、妾の乳が気持ちいい、のか？　嬉しいことを言ってくれる\nのう……もっと強く挟んでやろう……ほれほれ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はふぅ……硬くて、熱いのう……たくましい逸物じゃ……男らしくて、惚れ\n惚れするわ……んっ……ふう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「この逸物で、何人のおなごを泣かせてきたのじゃ？　よいではないか、妾に\n話してみよ。ふふっ……秘密？　残念じゃのう～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それなら、妾の乳より大きな乳に挟んでもらったことはあるのか？　それ\nくらい教えてくれてもよいじゃろう？　どうじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんじゃ、つまらぬ。まあよい。たしかに今は、妾の乳に集中したいという\nのも……わかる……では、どうして欲しいのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほう。もっと強く挟んで欲しいのか……んっ、んんっ……これで、どうじゃ\n？　足りぬか……？　では……ほれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ぎゅ、ぎゅう～♪　むにむにむに～♪　とな……どうじゃ？　気持ちいいか\n？　おぬしが言う通り、強く挟んでやっておるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そうじゃな……乳の中で、逸物がひくひくと震えておる……気持ちいいよ～\nと泣いておるようじゃ……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ。妾に任せよ……こうやって、乳を重ね合わせて……んっ……ほれ、\n逸物を……擦って……んっんっ……やるのじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ……腰も動いておるぞ……先っぽから、つゆも出ておる……これは男が\n感じておる証拠じゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「強がらなくてもよい。おぬしは楽にしておればよいのじゃ……このまま妾の\n乳で果てよ……ほれ、ほぉれ……んっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おう……乳の中で、逸物が……また一段と大きくなっておるわ……くっ、\nんうっ……それに、小刻みに跳ねておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「よほど、妾の乳が気に入ったと見える……待っておれ、もっと感じさせて\nやるからのう……ふっ、ううっ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「だめじゃ、待たぬ……子種汁が出そうなのじゃろう？　我慢せず……出して\nしまえばよいのじゃ……それ、もっと乳で搾ってやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、んんっ……可愛いのう、乳を擦りつけると……切なそうに声を\n我慢しおって……強情なやつじゃ……んあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「よかろう、どこまで耐えられるか……見ものじゃな……ほれ……んっ、は\nふぅ……乳で、むにむにっと……包み込んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしの逸物が、吐き出しておるつゆを……乳で、塗り広げてやろう……な\n……んんっ……どうじゃ、滑りがよくなっておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ……あ、ああ……熱い……妾の胸も、どんどん熱くなってお\nる……あぁ……は、はぁ……やらしいのう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしの逸物を、胸で挟んで……こうやって、おると……妾も発情してしま\nうわ……交尾、したくなるという意味じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「しかし、今は我慢じゃ……まずはおぬしを、この乳で……思いっきり果て\nさせてやらんと……ほれっ……ふうっ、ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ、聞こえておるか？　淫らな音が……鳴っておる……くっ、うぅん……\n乳を擦るたび……あ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そろそろ、限界ではないか？　さっきから息が荒い、ぞ……ふふ、妾には\n全てお見通しじゃ……素直に、果てるがよい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……よいぞ……乳の中に……おぬしの子種汁を……くっ、んぅ…\n…思いっきり……出すのじゃ……あふっ……んふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「つ、強く？　やっておる……じゃろう……んううっ……ほれ……んっ……く\nっ、ふううっ……で、出る？　んっ！？　んんっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、これ……急に腰を動かすでなぃ……あっ、んっ……あっ、あっ……ひぃ\nうううぅぅぅぅぅ～～～～！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬし……出せとは、言ったが……いきなりすぎる……んぅうっ！　はあっ\n！　あっ、くっ……はぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「で、出て、おる……逸物が跳ねて……熱い、子種汁が……乳の中にぃ……\nんっ……ふうっ……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あふうっ……よ、よい……おぬしの好きなように……出すのじゃ……すべて\n、受け止めてやるからのぅ……んっあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふぅ～……ずいぶんと出たのぅ……ほれ、見てみよ……妾の乳の中が子種汁\nまみれじゃ……んっ……匂いも、強烈じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「これだけ出したのに……おぬしときたら……まだ満足してないのか？　さす\nが若いのう……よいぞ、とことん相手をしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ほれ……時間がもったいない……このまま続きをしてやるから、乳の中へ\n肉棒を押し込むのじゃ……そ、そう……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ、はぁあ……出したばかりなのに……元気な逸物じゃ……若い男は、\nこうでなくてはな……んっ……ふぅ……ふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾の乳に興奮して、こうなっておるわけじゃな……ふふっ……まったく、\nすけべじゃのう……まあ、嫌な気分ではないがのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふ、妾の乳も罪作りじゃのう……んっ、んんぅっ……これから、毎日おぬ\nしを誘惑してしまうかもしれぬぞ……大丈夫か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「いつでも、どこでも……逸物をおっ勃ててしまうかもしれんのう……じゃが\n、安心せい……妾はそんなすけべなおぬしが好きじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「本当じゃ……そうでなければ、こんなこと……してやらぬわ……んっ……\nお、おお？　なんじゃ、また逸物が大きくなりおった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「素直なやつじゃ……ふふ……逸物で返事をするな……んぅっ……よしよし、\n可愛がってやるからのう……待っておれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「んっ、んうっ……どんどん硬くなっておる……嬉しいのじゃな……もっと\n強く、挟んで……んっ……ほれ、どうじゃ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「うむ……気持ちいいじゃろう？　おぬしも、動きたいのか？　べつに……\n動いてもよいが、あまり激しくするでないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、これ……強くしすぎるなと、言うたであろう……ひうっ……おなごは\n優しく扱わねばいかんぞ……ふう……んあっ、あはぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「焦らなくてもよい……ほれ、乳をぐいぐいと……押しつけてやるから……\n中へ逸物を押し込んでくるがよい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、んぁっ……そうじゃ、そのくらいで……んっ、んぅんっ……んふっ…\n…乳と逸物を、擦り合わせるのじゃ……はあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あふぅっ……ま、また……逸物がひくひくしておるぞ……果てそうになって\nきたのか？　ん？　正直に言うてみよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「よいではないか、それだけ妾の乳を気に入ったということじゃろう？　ふふ\nっ……おぬしの逸物も見る目があるのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「愛い逸物じゃ……ほれ、少しずつ……ゆっくり腰を、強く……そ、そうじゃ\n……焦るでないぞ……あっ、んぅっ……ち、乳が……くうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「おぬしが、出した……子種汁が、絡みついて……ぐちゅぐちゅいっておるの\nう……なんとも淫らな音じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「は、あっ……あふっ……また果てそうなのじゃろう？　また乳の中に……\n出して、よいぞ……好きなだけ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「たっぷり……出して、くれ……おぬしの満足いくまで……わらわの乳を\n楽しむがよいぞ……くっ、んああっ……あふうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、んあっ……！　よ、よい……このまま……妾の乳に……んっ、んんっ\n……なんじゃ？　か、顔……？　妾の顔に……じゃと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なにを言うておるのじゃ……無礼者っ……素直に乳へ……こ、これっ……\n待つのじゃ、あっああぁ……おぬし、聞いておるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はっ、んっあっ！　だ、だめじゃ……乳で、果てよ……んっ、あっ、くは\nぁっ……！　あっ……あっあぁぁぁぁぁ～～～！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はあっ！　あっ、んはぁぁぁっ！　あっ……あぁっ……出てっ……出て\nおるっ……んんっ！　乳の中で……逸物が暴れておるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、これ……あまり派手に動くと、乳からはみ出てしまうわ……くっ、はぁ\nあっ……んっ……んんぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……あ、熱いのう……さっきあれだけ、出したのに……まだこんなに残って\nおったのか……くうっ……はぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「み、見てみよ……妾の乳が、あっという間に……真っ白になってしもうたわ\n……すべて、おぬしの子種汁じゃぞ……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まるで、乳が孕んでしまいそうじゃ……ふぅう……んっ……まったく……\nどれだけ出せば気が済むのじゃ……おぬしは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「わらわの乳が、素晴らしすぎたか……それは、仕方ないのう……はぁ……\nはぁ……それにしても、狂暴な逸物じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「まったく……今までどうしておったのじゃ……これからは、妾が面倒を見て\nやるから、安心せい。……なんじゃ嫌なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「妾はべつによいぞ。おぬしも妾の乳を気に入ったようじゃしのう……ならば\n、わらわが世話をしてやらねば。そうじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_06" ] },
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「ふふっ……逸物は正直じゃのう。嬉しそうにひくひくしておるぞ？　愛い\nやつじゃ。うむ、妾に任せておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「なんじゃ？　もっとして欲しいのか？　世話してやると言うたからのう……\nよし、妾の乳で徹底的に搾り取ってやるから覚悟せい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「こ、これっ！　なにをして……んんっ！　逸物が抜けてしまうぞ……おぬし\n……んっ！　ひっ、ひううぅぅっぅぅ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「あふうっ、んぅっ！　ま、待つのじゃ……か、顔に……んぶっ！　かかって\n……馬鹿者っ……はぁあ……ひゃんっ……！　んあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「……なんじゃ、この量は……顔中が、子種汁まみれになってしまうわ……\nあっうっ……ひうっ……あっ、あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「嬉しそうな、顔をしおって……ひうっ！　飛ばしすぎじゃっ……んっ……！\n　まったく……どれだけ、出せば気が済むのじゃ……んうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「く、ううっ……くさい……蒸せそうじゃ……なにを食うたら、こんな匂いを\n放つものを出せるのじゃぁ……ひぃい……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「はぁ……は、はぁぁ……は、鼻が曲がりそうじゃ……くふぅっ……それは\n気持ちよかったじゃろうなぁ……これだけ出したのじゃからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「いくら、妾の乳が気持ちよかったからと言って……なぜ、顔にかけるのじゃ\n……！　つい……ではない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「興奮しすぎて我を失ったのか？　それほど妾の乳がよかったのか？　ふむ…\n…そんなに、か……まあ、そうじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「それほど妾の乳が特別じゃったということか……それなら、仕方ないかも\nしれぬのう……わかったわかった、怒ってなどおらぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00024101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "稲穂姫" ]},
		{"command":[ "SETTEXT", "「そんなに気に入ったのなら、またいつでも世話をしてやろう。うむ、本当\nじゃ。しかし妾の乳の味が忘れられなくなっても知らぬぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_241_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
