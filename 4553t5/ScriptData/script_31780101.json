{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああんっ……！　私のおっぱいに触手たちが絡みついてきて……んっ、あっ\n……！　ヌルヌルしてて、すごく気持ちいいわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……必死に動いて可愛いわね……いいのよ。遠慮しないで、好きなだ\nけおっぱいを撫でまわして頂戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……！　乳首もいっぱい弄っていいわよ……！　私の身体は、\n貴方たち触手のモノでもあるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あはあぁんっ……！　そうやって、おっぱいぎゅってされるの好きなのぉ…\n…！　触手たちの熱や感触が、直接響いてくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手の１本１本が意思を持って、ウネウネ動いて……ああっ、なんて可愛い\nのかしらっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、くちゅ……！　おっぱいだけじゃなくて、口にもまとわりついてきて\n……！　ふふっ……どうしたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もしかして、おっぱいや乳首じゃなくて……私の口の中に入りたいの……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んちゅ、んぷっ……！　ああぁんっ……！　触手が口の周りで暴れるわっ…\n…！　奥まで咥えて欲しいって、訴えてきてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もう……しょうがないわね……いいわ。私の口でじゅぽじゅぽしてあげる…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「たくさん吸って、しゃぶってあげるから……奥の奥まで突き挿れて頂戴っ…\n…あむっ、んっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、じゅるるっ……！　ちゅぱっ、じゅるううぅ……！　ちゅぽっ、じ\nゅぽっ……じゅぱっ、んぢゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、にちゅるっ……！　んんっ……！　口の中で触手が動いて……！\n　あはあぁ！　そんなに動かれたら、おしゃぶりできないわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「でも、こうやって無理やり口の中を犯されると……触手が私を求めてる感じ\nがして、すごく興奮しちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……もっと強くしゃぶってあげるわね……！　じゅちゅ、ちゅぴっ…\n…！　ぐぽっ、じゅるるっ……！　にちゅうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　頬の内側に触手の先端があたってっ……！　粘液が唾液と\n混ざり合って、ぐちゅぐちゅってエッチな音がしてるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ああっ、もう……！　こんな音を間近で聞かされたら、たまらなくなるじゃ\nないっ……！　ちゅぱっ、ちゅちゅ、ぐじゅ、じゅぷうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「れりゅ、ちゅぱっ、ちゅちゅ……んちゅ、じゅぱっ、じゅぴぃ……！　ちゅ\n、ぢゅるるっ……じゅぞっ、ぐちゅるっ、ずりゅりゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぶうぅ……！　触手たちの先っぽから、いやらしい汁がぴゅるぴゅる噴き\n出てるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「表面の粘液よりもドロドロしてて……んちゅ、じゅるるっ……！　んぐっ…\n…！　はあぁ……喉も絡んでくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっぱいと口だけじゃなくて、喉にも絡みついてくるなんて……！　本当に\nいやらしい子ねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私をエッチな気分にさせる触手には……エッチなオシオキをしてあげないと\n……！　ちゅぱっ、じゅるるるっ……！　じゅぞおおぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ぢゅぽぽっ！　ちゅるっ、れりゅううぅ……！　ぴちゃっ、ぷち\nゅるっ、ぐちゅ、れろおぉ……！　じゅぽ、じゅぱあぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……先端をペロペロされるの、たまらないでしょう……！　もっと感\nじて、ブルブル震えていいのよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぺろっ、ぷちゅるっ……！　んれろっ、じゅろぉ……！　ぺりゅ、んじゅる\nっ……！　くちゅ、じゅぞっ……ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あぅ、んっ、んふっ……！　触手の締め付けが強くなってきてるぅ……！　\nおっぱい搾り上げられちゃってるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「勃起した乳首もいっぱい撫でられて……！　ああぁ……！　乳首感じるぅ…\n…！　粘液擦りつけられながら、シコシコされるのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私を求めて、愛してくれてるのね……！　こんなに気持ちよくされたら、ち\nゃんとお返ししてあげないと……じゅるるっ、ちゅぱあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「れりゅ、ちゅぱっ、じゅぱっ、ちゅるるっ……！　ぴちゃ、ぷちゅるっ、じ\nゅぞっ、れろおおぉ……！　ぐぽっ、じゅぽっ、ちゅ、ぢゅぷるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んちゅ……！　唇でシコシコしながら、ペロペロされるだけじゃなくて……\n舌の先っぽでチロチロ撫でられるのも好きなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ちゅちゅうぅ……！　じゅぱっ、ちゅぶっ……！　あんんっ……！\n　口の中の触手が、ビクビク暴れ出してるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「自分で腰を動かすみたいに、前後にズポズポ動いて……！　もしかして、出\nちゃいそうなのかしら……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　エッチな汁をびゅーびゅー出したいのね……！　いいわよ、\nいっぱい出させてあげるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅちゅ、ぐぽっ！　じゅぱっ、ちゅちゅ！　んじゅるっ、ずずっ、れろっ\n、ずぷっ、じゅぴいぃ！　ぐぱっ、ぢゅぼっ、にじゅるうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　いいわっ、来てっ！　口の中に出してっ！　エッチな触手\n汁、びゅるびゅるしてえぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「全部受け止めて、飲み込んであげるわっ！　ちゅぱっ、じゅぢゅ、ぢゅぱあ\nぁ！　ずりゅ、ちゅ、ちゅぱっ！　じゅぽっ！　ぢゅぷうぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぶうううぅぅぅ！？　じゅぞっ、ちゅ、じゅるるっ！　口の中で触手汁が\nどぴゅどぴゅ出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「すごく勢いがあって、喉に直接流し込まれてるわっ……！　じゅぞっ、んぐ\nっ、じゅるるっ！　ごくっ、ごっくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ヌメってるのにドロドロしてて……ああっ……！　こんなに美味しい触手汁\nなら、ずっと飲んでいられそうだわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……！　最後の一滴まで、ちゃんと飲み込んであげるわねっ\n……！　じゅ、ぢゅるっ……！　じゅぞっ、じゅぞおおぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ、ぐぷっ……！　んぐっ、じゅぽっ、ちゅるうぅ……！　んぐっ、\nんぐっ……ごくっ……ごくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はあぁ……いっぱい出たわね……身体の中が、いやらしい汁で満ちてる感じ\nがするわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「それにすごく濃い臭いもするわね……精子とは違った香りで、頭がクラクラ\nしちゃいそうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　また触手が口の中で暴れて……！　ふふっ……このくらいじ\nゃ満足できないって感じね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もっと私に絡みついて、いっぱい触手汁を出したいの……？　いいわよ……\nまたいっぱい、おしゃぶりしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方たちみたいに可愛い触手の頼みなら、なんでも応えてあげたくなるもの\n……ほら、遠慮せずに奥までいらっしゃい……んっ、ちゅぱぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ぐぽっ！　ちゅ、じゅるるっ！　れりゅ、じゅぱっ、ちゅぴいぃ\n！　んじゅるっ、れりゅ、じゅぞぞっ、ちゅぞぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んちゅ、じゅるっ……！　また触手の奥の方に、汁が残ってるわね……これ\nも吸い出して、飲み込んであげるわ……にちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぢゅぞっ、ぢゅぢゅううぅ……！　れりゅ、ちゅちゅ、じゅぷっ、ぢゅぴぃ\n！　んっ、んぐっ……ごくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　吸い出すたびに、口の中で触手がビクビク震えてるわっ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「おっぱいを搾る触手たちも、嬉しそうにズリズリ這いずり回って……！　ま\nたおっぱい搾り上げられちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅ、じゅぞぞっ！　れりゅ、ぴちゃっ、ぷちゅるっ！　ぐぽっ\n、じゅぽっ、んぢゅ、ぐぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁっ……！　本当に可愛いくて、素敵な触手たちだわっ……\n！　気持ちいいところを刺激されて、感じすぎちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるっ！　れりゅ、ちゅぱっ、ちゅちゅ、ぐぷっ！　ぬりゅ\n、ずるるっ、れろぉ……ぴちゃ、ぐちゅ、じゅずうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あぶっ、んっ……！　また触手たちがビクビク動いてるわっ……！　口の中\nで暴れて、歯に擦れてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「喉奥にもズルズル入り込んで……！　ぢゅぐっ、じゅぱっ、んじゅるっ！　\n触手汁出したくて、たまらないのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いいわっ……！　汁が出るまで全力でシコシコしながら、じゅぽじゅぽして\nあげるっ……！　くちゅるっ、じゅ、ぢゅぱっ！　れりゅ、れろぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ぐぶっ、じゅぱぱっ！　くちゃ、ちゅ、じゅりゅううぅ！　んぢ\nゅ、ぐぱっ、じゅぐっ！　れじゅ、ぢゅぐっ、くちゅ、じゅぱああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぶっ、じゅぷううぅ！　あっ、んんっ！　触手たちの動きがさらに激しく\nなってきてる……！　触手汁を出したくて、ウズウズしてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「れりゅ、じゅぱっ！　んっ、あああぁん！　出してっ！　私にまたいっぱい\n、触手汁味わわせてえぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「貴方たちが望むところで受け止めてあげるからっ！　ちゅぱっ、じゅるるっ\n！　んっ、ちゅ、ちゅぞっ！　いっぱい、びゅるびゅるしてぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、じゅるるるっ！？　あぶっ、んぐっ……！　あはあぁんっ！　触手\n汁がまた口の中に出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「さっきよりも勢いのある触手汁がこんなにっ……！　ちゅぱっ、れじゅ、ぐ\nぽっ！　じゅぱっ、ちゅぞおおぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぶっ、ぢゅるっ！　あぐっ、んふうぅ！　喉奥に直接流し込まれるの、た\nまらないわっ……！　もっと出して頂戴っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んぐっ、じゅぞっ、ちゅるるっ！　貴方たちから出るエッチな汁、全部飲み\n干してあげる……！　身体の中まで、触手と１つになってあげるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んばっ、ぢゅぐっ！　れじゅ、じゅぱっ！　ぢゅぞっ、ちゅるるっ！　んぶ\nっ、ごくっ、じゅるるっ！　ごくっ、ごっくんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ、ちゅ……じゅぞっ、ちゅるっ……！　ああっ、すごいわ…\n…こんなに出してくれたのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……必死にびゅるびゅる汁を出す姿……本当に可愛かったわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「私をこんなにも気持ちよく、いやらしい気持ちにさせてくれるなんて……や\nっぱり貴方たちは最高だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　またそんなに動いて……残ってる汁を吸い出して欲しいの…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「いいわよ……ちゃんとお掃除もしてあげる……んっ、ちゅ……！　ちゅぞっ\n……ちゅ、ちゅちゅううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んはあああぁ！？　触手汁が顔に向かってびゅーびゅー出て……！　あぶっ\n、んぐっ……！　はあああぁ！　熱くて臭いわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「精子なんかとは比べ物にならないくらい、ドロドロでいやらしい汁がこんな\nにっ……！　こんなの、火傷しちゃいそうよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ！　あっ、あふっ！　顔に触手汁を塗りたくられるの、たま\nらなく感じるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「触手にマーキングされてるみたいで……あはあああぁ！　心も身体も、触手\nに包まれてるみたいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「その調子でもっとぶっかけてっ！　私の顔、触手汁でベトベトのグチャドロ\nにしてぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはぁ……！　臭いだけじゃなくて、触手汁が鼻の奥に入り\n込んでるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……身体の中も外も汚すなんて、貴方たちじゃないと絶対に許さない\n行為よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00017801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　出したばっかりなのに、また動くだなんて……！　い\nったいどうしたの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「もしかして、気持ちよくイカせてもらったから、今度は私をイカせてくれる\nっていうの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アユミ" ]},
		{"command":[ "SETTEXT", "「ふふっ……なら、たくさんイカせてもらうわ……おっぱいや乳首だけじゃな\nくて、アソコも気持ちよくして頂戴ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0103410" ]},
