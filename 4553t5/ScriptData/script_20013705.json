{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわぁぁぁぁぁぁぁーーーーーっ！　岩がっ……岩がーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええいっ、下僕っ……何をしているっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「す、すいませんっ！　ジュンジローが、迂闊に踏んだ罠がっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あんな美味しそうな肉が転がっていれば食べようとするのは獣の性ですぞっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あんな何でもない場所に肉が転がってることを胡散臭いと思えよっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だぁっ、とにかく口より足を動かせっ！　岩に押しつぶされたいのかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うひぃぃぃぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ、はぁっ、ふぁぁぁっ……危ないとこだった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やれやれ……ひどい目にあいましたぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいか……今度は間違っても拾い食いすんなよ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「善処いたしますぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022590003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、このような障害があるということは、その先に眠っているものも期待\nが持てるというものだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何か、今回はえらいポジティブですね……姫様」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「何となく予感がするのだ。伝統の鎧だか何だかが、私を待っているのではな\nいかとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そこに至るまでの試練と思えば、ちょっとやそっとのこと、どうということ\nもない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そりゃあ、いいですけど……何か、目の前にヤバそうなのが見えてます\nよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「敵か……いかにも門番という雰囲気の奴が目の前にいるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ゴーレムというやつですかな。しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022590004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結構ヤバいサイズですよ。流石に俺と姫様だけじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、私を忘れては困りますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022590005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前がこの状況で１ミリでも戦力になることがあるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ自分でもないと断言出来るレベルですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022590006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「清々しいまでに開き直りやがって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん……とにかく、目の前の障害は自力で突破する。それまでのことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……けど、流石に無策で突っ込んでいくのは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ええいっ、臆病者めっ。貴様が行かないなら、私一人で行くまでだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んな無茶なっ……少しは考えて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だったらどうするのだっ！　おめおめと尻尾を巻いて逃げろと言うつもりか\nっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022590009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、そこまでは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「お待たせしました、隊長殿！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022590001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ……その声は……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0189" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "一方その頃……ビキニ星、浜辺では……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ボールいきますよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「オーライ、カモーン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「えーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あははっ、どこ打ってるのよ。へったくそー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「ご、ごめーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010022590003" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「大丈夫です。カバーしますっ！　そーれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はーい、こっちでーすっ！　パース！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふふ……いいな。若者が青春を謳歌している姿というのは、それだけで癒さ\nれる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「長官、お飲み物をお持ちしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、ご苦労。皆の分もちゃんと行き渡っているか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「問題ありません。クーラーボックスも確保していますので、例え人数が増え\nても対応できます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「結構。ならば、君たちも好きにやってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590003" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「了解しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010022590003" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あのぉ……こんなことしてて大丈夫なんでしょうか？　皆さんばかり探索さ\nせておいて……こんな休みを満喫させてもらうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「心配するな！　既に先導隊の後に、この任務に最適な者を派遣している。そ\nこに抜かりは一切ない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590004" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「は、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「我々は今出来る最善を尽くすことだけを考えていればいい。それは何かわか\nるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590005" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「えっと……なんでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010022590003" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「滅多に味わえることのないバカンスという任務に集中することだ！　んむっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590006" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「気持ちよく２缶目を開けた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010022590001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「どうしましょう……私達も、任務……行っちゃいましょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そうだな。何と言っても長官命令だしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010022590002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ、全ての責任は私が取るぞ！　かんぱーーーーーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022590007" ]},
		{"command":[ "SETCHARA", "0", "char_00004904_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}