		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……この部屋は……一体……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおっ！　天の助けが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「カツマさん？　そう言えば、姿が見えなかったと思いましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、もう少し心配しろよ！　こんな物騒な場所ではぐれたんだぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「物騒？　一体、何の話です？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何のって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「うるせぇなあ……何の邪魔を……て……てめぇは……！　仮面戦隊マスカレ\nードのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620001" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「その声は……奈羅苦！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「マジかよ……間違いねぇ……しかも、マスク・ザ・ブルー……テメェとはな\nぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620002" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「まさか……次元旅団オーヴァーハングは全員倒した筈では！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「……へへっ、こいつは面白ぇ……目覚めた早々に、因縁の相手と巡り会える\nなんてなぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620003" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……なるほど。長官が調査団を派遣したということは、やはり、そういう意\n味があったということですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「くくっ……十分やる気あるってことじゃねぇか。こうなったら、することは\n一つしかねぇ、お楽しみの時間だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620004" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「っ……！　有無を言わさず攻撃してくるとは……相変わらず躾がなっていな\nいようですねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620008" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はっ！　お行儀なんか気にしてられっかよ！　こんな楽しいことを前になぁ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620005" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「学習しない……やはり、再教育をしてあげなければなりませんかっ！　はぁ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620009" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！　マジかよ……こんな狭いとこでいきなり……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「へへっ！　そうそう、こんな感じだ！　どんどんカンが戻って来てるぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620006" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふんっ、この程度の動きで、知った風な口を効くとは……まだまだですねっ\n、はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620010" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「っとぉ！　いい蹴りだなぁ、ビンビン来るぜぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620007" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「遊ぶつもりはありませんっ、本気で捕らえさせてもらいますっ……うくっ…\n…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620011" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「二人して、随分と楽しくしてはりますなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021620001" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「せっかくの座興を独り占めって言うのは、強欲が過ぎるんじゃあないのかい\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021620001" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「て、てめぇらっ……二人共、本命は別にいるだろうがよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620008" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そうですなぁ、ですが、今は目の前にご馳走がある訳ですしなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021620002" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ただぼんやり眺めているだけっていうのは、どうにも性に合わなくてね、は\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021620002" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620012" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うわ……こいつら、動きがやべぇ……！　マジでウチの女幹部共に匹敵するん\nじゃないか……？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……ここは、状況が悪いようですね……やむを得ません……はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620013" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あっ……てめぇっ、何逃げてやがるっ……くそっ、待ちやがれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620009" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、おいっ！　俺を置いて行くなっ！　ちょっ、おいって！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021620014" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「んくっ……！？　これは……煙幕どすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021620003" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「……ダメだ、気配が遠ざかっていく……まんまと逃げられたようだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021620003" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「チッ……逃げ足の早い……やっぱり一筋縄じゃいかねーな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620010" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あらあら、あらぁー♪　がん首揃えて取り逃がしちゃうなんて、だらしない\nんだからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620001" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はっ、指を咥えて見てるだけのヤツに言われたかねーな！　バカみたいに棒\n立ちしやがって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620011" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなの当然でしょ♪　マスカレードに興味はあるけど、我の本命はブルー\nじゃないし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620002" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「けど、結局取り逃がしてしまったら、元も子もあらしまへんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021620004" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そうとも、しっかり捕らえておけば、後の手がかりにも繋がっただろうに…\n…面倒じゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021620004" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちちち♪　手がかりなら、ちゃーんと残ってるし♪　それも、とびっきり分\nかりやすいのが♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620003" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おっと……どこへ行くんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620012" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いやぁ……もう用事は終わったかなぁと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「いやいや♪　用事はこれからが本番でしょ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620004" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そう言えば、何かブルーと話をしてたな……てことは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620013" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我のとこの戦闘員かなーって言ってたけど、さっきの感じからすると、どう\nも違うみたいだし？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620005" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「貴方……マスカレード知ってるんでしょ？　案内しなさぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620006" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺が……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや……けど、こんな奴らをＥＤＯに案内したらどうなるか……どう\nするんだ……？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「なーんか、迷ってるように見えるけど、貴方に選択肢なんて一切ないから♪\n　ずっと拉致監禁されたままになる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021620007" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぃっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「一生、ファンタズマのオモチャか……それも、長くは持たないだろうけど、\n悲惨な命運であることに変わりはないね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021620005" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「何とも不幸なことどすなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021620005" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「さっさとラクになっちまった方がいいと思うぜ？　こいつは本気の忠告だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021620014" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
