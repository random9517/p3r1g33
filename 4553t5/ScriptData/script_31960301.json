{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0098" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「じゃっじゃぁ～ん♪　到着ぅ～♪　おにーさん、やるね～？　クリスマスに\nぃ、アーちゃんをラブホテルに誘うなんて……エロすぎぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おとなしくついてきてあげたんだからぁ……当然プレゼント、くれるでしょ\n？　んふふふっ、あたしが欲しいのは……おにーさんのぉ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「どーん！　あはははっ♪　びっくりした？　急にベッドに押し倒されて、ド\nキドキしちゃった？　答えはあとで教えてあげる……。だ・か・らぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「まずはパイズリ、させてもらっちゃおっかなぁ～♪　ん～……イヤ？　イヤ\nなわけないよねぇ。おにーさん、あたしのパイズリだぁいちゅきだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でもさぁ？　せっかく聖夜にパイズリするなら～。何か一工夫ほし～と思わ\nない？　今日だけの～、特別なプレイ♪　したいよね～。ってことで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「時間帝国から来た三姉妹の三女らしく♪　時間の魔法を使ってあげちゃう…\n…。……キラーン☆　わかるぅ？　何されちゃったか。実はねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あたしの能力で、あたしがじ～っと見てる間は、なんにもできなくしちゃっ\nたの。そ、まったく動けないってこと。……試してみて？　ね？　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぜんっぜん身じろぎもできないでしょ～。スゴくない～？　今夜はぁ、この\n力で……い～っぱいお漏らし射精させてあげるね♪　んっふっふっふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「好きでしょ～？　一方的に、おっぱいでおちんちんイジめられてぇ、ぴゅっ\nぴゅ～って射精させられるの……屈辱的でたまんないでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えぇ～？　動けなくてもどかしい？　それがまた快感につながるんだよぉ。\n素人にはわかんないかな～♪　なぁ～んて。……じゃ、始めてくね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっ、ふ……♪　なんかぁ……おにーさんのおちんちん、こーして見るとま\nたデッカく成長してる気がする～。なんでなんで～？　……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あたしとえっちしすぎて、太くなってきた？　それとも～。今日のクリスマ\nスえっちに期待して？　……どっちでもいいけど、おっきすぎなんだよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんのおっぱいで挟むのもタイヘンっていうか……。あはっ、でもコ\nレくらいのほーがシゴきがいがあるっていうか……楽しみでもあるよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね……♪　あたしに無理やり魔法でイタズラされてるっていう、極上の言い\n訳させてあげてるんだから～。堪能しちゃって？　感じまくってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っんっ……。ねーえ、おっぱい……。あったかくって最高でしょ？　ぬくも\nりがじわじわじわ～っておちんちんにつたわって、熱くなってきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「根元から先っちょまで、こうやってぐにゅぐにゅぐにゅぅ～って絞り上げる\nとぉ、……ほらぁ♪　我慢汁がにじみ出してきたぁ♪　んふ～、えっちぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えぇ～？　おにーさぁん？　アーちゃんまだ全然本気出してないんですケド\nぉ？　なんで、もうこんなにおちんちん濡らしちゃってるんですかぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「感じやすすぎでしょ♪　女の子みた～い♪　って、あ～♪　その恥ずかしそ\nうな顔……見てるこっちがウズウズしてきちゃう……。ん、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「やっば……♪　アーちゃんのおっぱいからも母乳……。おっぱいミルク、溢\nれてきちゃったじゃぁん♪　先にお漏らししちゃうとか屈辱ぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ん？　コレ？　ボニューデマクールっておクスリ飲んできたから出てる\nの。だってさぁ、せっかくのクリスマスだし、ホワイト要素欲しいでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それ、に……んっ♪　見て……♪　おにーさんのおちんちんの我慢汁とぉ、\nあたしのおっぱいミルクで、おっぱいの谷間がヌルヌルになってきたぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「この状態でパイズリするとすっっ……ごい気持ちいいんだから……。いくよ\nぉ？　っはぁっ……ほらっ、ほらぁ♪　すごいでしょ♪　んんっ、ほらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ねぇ～！？　んっ……♪　出したて新鮮ミルクでおちんちん、ぬちょぬちょ\nされるの気持ち良くない～？　……っぁっ、いい匂いだし～、わかるぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんのおっぱいミルクのあまぁ～い匂いを嗅げる幸せモノはぁ、この\n世でおにーさんただ１人ってこと、自覚してハッピーになっちゃってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……っんんっ♪　ンッ……んっ、んっ……んん……っ♪　あははっ、お返事\nできないおにーさんのかわりにぃ、おちんちんが嬉しいーって言ってるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「へぇ～♪　そうなんだぁ♪　素直でぶっといおちんちんは好きだよぉ♪　ふ\nーん♪　感じちゃうぅ？　わかるよ、ビクビクしてるもんね～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もぉっともっと痙攣させてあげる……。んぅっ……ふふふっ、ほんっと感じ\nやすくて、敏感で……えっちなおちんちん……。見てて楽しいし～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こうっ、やって……おっぱい全部で刺激してぇ、どんな風に震えるのかを観\n察してるだけで……。あっ♪　こっちもちょっと感じるしぃ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「面白くって好きだよ……♪　何回もズリズリパイズリしたくなる、もん……\nっ♪　んぅっ、ちょっと強引なくらいがいいんでしょ？　……ん～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おっぱいの谷間ぁ、キツ～く、せま～くしながらヌルヌルでおちんちんっ、\nシゴいてぇ、母乳で磨いてあげる、ねっ……♪　にゅる、にゅるにゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ、あ～っ♪　良くなってきたぁ？　んっ、はぁっ♪　にゅるにゅるパイズ\nリ好きになってきたぁ～？　んっ、ぁっ、それは～わかるよぉ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おっぱいごしに伝わってくるもん♪　おにーさんのおちんちんがぁ、アーち\nゃんのおっぱい大好きすぎて射精寸前、ヤバヤバのヤバだって♪　あはっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「せっかくクリスマスなんだからぁ、１年でいっちばん派手なお漏らし見せて\nほしいな～♪　はぁっ、はぁ、こ～んなに尽くしてるんだから、お願い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「勢い良くぅ、精液でホワイトクリスマスやってぇ～♪　んんっ、見～た～い\nぃ♪　はぁっ♪　見～せ～て～♪　んふっ、ガチで膨らんできてるしぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「イケるよね？　出したいよねぇ～？　アーちゃんの柔らかぽにょぽにょおっ\nぱいに射精しようね～♪　はいっ、お漏らし確定！　ぴゅっぴゅして～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふぅうっ♪　出た出たぁあ♪　びゅーっ、びゅーっ、びゅるびゅるびゅ～\nっ……♪　うんうんうん♪　い～よぉ、カッコイイ♪　すごい出てる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「で～も～♪　その渾身の大量射精～♪　おっぱいで押し潰してぇ、びゅぶび\nゅぶ押さえこんじゃうんだよね～っ♪　あはははっ♪　たのし～い♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっつい精液どっぴゅんどっぴゅん飛び出してるのにぃ♪　溢れて爆発して\nるのにぃ～♪　あたしの胸がおっきすぎてせきとめられちゃうんだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っあっ♪　でもっ……！　かなりイイよぉ♪　あっ♪　あっ、ネバネバが超\nしつっこいし、ドロドロの感触がヤバぁい♪　練乳みた～い♪　あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのおちんちん、あたしのおっぱいの中でめちゃくちゃハシャいで\nる……♪　うんうん、いーよ♪　出せるだけ出しちゃいなよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ……！　あっ、ぁっ、あっ……！　びゅるびゅる強いぃ……っ♪　おっ\nぱいが押し上げられてくぅ……、どんだけ出したかったのぉ～♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……全部出たみたい。わ～、谷間にたっぷたっぷに溜まってるぅ……。これ\nだけ出したらもう休みたい？　後はまったり寝てたかったりする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「残念でしたぁ～♪　今日はクリスマスだしぃ、こんな程度じゃ終わらせてあ\nげないよ～？　もーっともーっと搾り取っちゃいまぁ～す♪　ぷぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほらっ……んんっ♪　精液まみれのおっぱいで、ぐにぐにモミモミされただ\nけでぇー……♪　おちんちん、すーぐに元気になってきたぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふふふふっ♪　だめでぇーす、やめてあげませーん♪　んんっ……♪　い\nいじゃん？　おにーさんはアーちゃんに気持ち良くしてもらうだけだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おちんちん楽にしてぇ、もらえる快感にうっとりしながらトロットロに感じ\nまくってればいーの♪　……ほら。ほらぁ♪　おっぱい好きでしょぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「精液出して身体は疲れててもー、おちんちんはぶっちゃけ、アーちゃんのお\nっぱいとまだ仲良くしてたーい、挟まれたい、シゴかれたーいって言ってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そしたらその欲求に従っちゃうのもアリだよねぇ～……♪　んんっ……♪　\nんふふふ、ニュルニュル動いておもしろーい……♪　パイズリってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「１回かる～く射精してぇ、汗とか精液とか、おちんちんの先っちょから出る\n透明なお汁とかぁ、もー色んな液体まみれになった２回目が楽しいよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おちんちんの敏感さだってアップしてる、ん、だしっ……♪　……ん～？　\nなに～？　気持ち良すぎてまたすぐ出ちゃいそう～？　ハイ、まだだめ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「我慢して我慢して、我慢しまくってぇ、最後の最後にびゅぶーって一番濃い\nのを発射すると、この世のモノとは思えない快感がほとばしるよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だ・か・ら、ガマンガマン……ぷぷぷぷっ♪　え？　からかってないよ？　\n笑ってない、って……♪　こんなに懸命にパイズリしてるじゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ダークエルフの美少女が、ぷにぷにおっぱいでご奉仕してくれてるのに文句\n言うとかありえないからね～♪　黙って感じなさ～い♪　……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「喘ぎ声は出していい、からねっ♪　女の子みたいにアンアンって言っていー\nよ♪　はぁ、はぁ、ここには他に誰もいないから♪　ラブホだし♪　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃん大好きぃ、アーちゃんのおっぱいが世界一ぃって情けなく叫んで\nもいーよぉ？　んっ、だ～って事実でしょ♪　他の人はどうか知らないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのおちんちんには、アーちゃんのおっぱいがいっちばんキくよね\nぇ～♪　はぁ、はぁっ、ふふふふ、嬉しそうにピクピクしてるしぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んんぅっ……♪　おにーさんのつよつよオチンポをピッカピカに磨けるのは\nぁ、あたしのむにゅむにゅおっぱいだ～け♪　シゴきまくっちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ……♪　な、なんかぁ、あたしもおっぱいがまたウズウズしてきたぁ…\n…♪　感じまくってるおにーさん見て、快感がうつったのかもっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ♪　今度はあたしもっ……アーちゃんも一緒にイキそうっ……！　あん\nっ♪　母乳たくさん出ちゃうかもっ……！　あっ、や、ヤバぁいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ねぇ、出したいよね？　おっぱいに精液出したいよねっ♪　それじゃ、一緒\nに出そっ……♪　母乳と精液一緒にぃっ♪　い、いくよぉっ♪　あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303220" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁ～い、びゅるびゅるびゅる♪　びゅるびゅるびゅるる～っ♪　上手に射\n精できましたぁ～♪　おっぱいの中に中出しぃ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303301" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひぁあああっ♪　あたしもぉっ！　イキながら母乳っ、勢い良く発射しちゃ\nったぁ……っ♪　おっきなおちんちん刺激して、自分も気持ち良くなって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「びゅーっびゅーって、精液みたいにおっぱいミルク♪　発射しちゃった……\n！　っああっ、んぁあああああっ！　出るぅっ、出る出るぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひぅうっ！？　おにーさぁんっ！　ちょっと、２回目の射精なのに出しすぎ\nぃっ……！　おっぱいギューッて締めてるのに溢れ出しちゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんなにくっさい精液溜めこんでたら、びょーきになっちゃうもんねぇ……\n♪　定期的にアーちゃんが絞り出してあげないとぉ～♪　んっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　ぜんぶ出たぁ？　あたしのおっぱいの谷間、たっぽんたっぽ\nんになるくらい出してくれちゃってぇ～。パイズリ大好きすぎ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……と、いうことで～♪　クリスマスプレゼント、いっぱいいっぱいくれて\nありがとぉ、おにーさんっ♪　んぷぷぷっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「クリスマスってぇ、恋人同士が愛を確かめ合う、神聖な一日らしいけど……\nアーちゃんはね、こっちの方がいいな♪　欲望まみれのメ・リ・ク・リっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だーって身体は嘘つけないし♪　おにーさんのおちんちんがどれだけアーち\nゃんを好きか、どーっしても知りたかったんだもん。しょーがないよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「結果？　そんなの、言わなくてもわかるじゃん♪　アーちゃんの勝ちぃ♪　\nボロ勝ち♪　くやしーい？　でも、事実は事実ですからぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぁあああっ♪　ご、ごめぇんっ、射精の勢い強すぎてぇ……おっぱい突破\nされちゃった！　あっ！？　あっ、おちんちん制御不能……ひぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303401" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あッあっ！？　あたしのおっぱいもつられて爆発ぅっ……！？　あひぃっ♪\n　ひぅうっ、母乳が炸裂しちゃってヤバいぃいいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぁあああ～っ♪　イクぅっ、おっぱいイクぅっ……！　おにーさんと一緒\nにイケて嬉しいっ……！　もっと浴びせていいよ、浴びたいぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁあああっ……♪　あったかぁいい……っ♪　おっぱいミルクと精液で、\nあたしの身体……えっちなお汁でだくだくになってくぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「二種類の、真っ白なシロップ……♪　混ざり合って、ぽたぽた垂れてくぅ…\n…。……んんっ♪　ちょっとぉ……♪　顔にかけてきすぎだからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんのこと、俺のモノだ～って主張してるのぉ？　精液マーキングぅ\n？　独占欲強すぎて……あっ♪　こっちも本気イキしちゃうよぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぷ、ぁ……♪　精液で溺れるかも、なんて思わされたのはじめてなんですけ\nどぉ～……♪　すっごい粘り気ぇ、ありえないくらい……んふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そーんなにアーちゃんのパイズリ、良かったんだぁ♪　それならがんばった\nかいがあったってカンジだねぇ……♪　また、気が向いたらしてあげる♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「最高のクリスマスプレゼント、ありがと～……♪　次はお正月？　バレンタ\nイン？　ホワイトデー？　ここって、いっつもイベントがあっていいよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0303409" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんがおにーさんをイかせまくって遊ぶ口実がい～っぱい♪　これか\nらもぉ、ず～っと楽しめそうだね♪　期待してるよぉ～♪」", "NORMAL" ]},
