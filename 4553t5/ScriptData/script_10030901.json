		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わかりますよね？　活用形とか、変化のさせ方とか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115810002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「未然・連用・終止・連体・已然・命令ってやつだよね？」", "NORMAL" ]},
