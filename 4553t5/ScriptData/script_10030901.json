		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「というわけで、私たちに勉強を教えて欲しいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115810006" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]}, 
