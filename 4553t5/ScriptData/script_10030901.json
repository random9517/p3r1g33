		{"command":[ "SETNAME", "ルルーナ＆マーガレット" ]},
		{"command":[ "SETTEXT", "「暴れてストレス解消できなくなる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00002402_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え……。ふたりともそのために活動してたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115810005" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いくら先生でも、やっていいことと悪いことがありますわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうよ！　だいたい、そんなこと勝手に決めていいの！？」", "NORMAL" ]},
