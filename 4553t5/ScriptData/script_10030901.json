		{"command":[ "SETCHARA", "0", "char_00001602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「どういうことですかと言われても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、わからなくても解答欄は埋めているからいいじゃない」", "NORMAL" ]},
