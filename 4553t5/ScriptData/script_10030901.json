		{"command":[ "PLAYVOICE", "v2_016_020115810007" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ＆マーガレット" ]},
		{"command":[ "SETTEXT", "「そんなー！」", "NORMAL" ]},
