		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それで……どうしてカツマがここに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえ達が追試に合格できず、そのままＥＤＯの活動ができないと戦力が低\n下するからって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「長官と学園長におまえ達の勉強を手伝うように言われたんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ったく、俺は教師じゃないんだぞ。こういうことは、もっと適任なやつが\nいるんじゃないか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なーんだ。隊長まで応援につけるなんて、長官や学園長先生も鬼じゃなかっ\nたんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115810007" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「桃花と夜日楽に勉強を教えてもらえるなら、小テストなんか楽チンよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115810009" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうですね。桃花さん、夜日楽さん、どうかよろしくおねがいします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おい、お前たち。俺から教わるって気はハナからないんだな？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はいはい。無駄話はそこまでにして、勉強はじめるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115810002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "かくして、追試のための勉強が始まり……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「わからないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なにこれ……何語……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115810010" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "始めて３分たらずで、暗雲が立ち込めはじめていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だから、この助動詞の活用を考えて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115810003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ジョドウシ……？」", "NORMAL" ]},
