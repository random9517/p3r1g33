		{"command":[ "PLAYVOICE", "v2_016_020115810006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なっ、なんですって！」", "NORMAL" ]},
