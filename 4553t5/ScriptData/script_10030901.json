		{"command":[ "PLAYVOICE", "v2_028_020115810005" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ああぁぁっ！　もう限界ぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115810013" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
