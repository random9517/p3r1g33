		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私は構いませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115810001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「桃花、お願いっ！」", "NORMAL" ]},
