		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「今回に限って勉強していなくて、一夜漬けしたらヤマを外したなんて言えな\nいよね……」", "NORMAL" ]},
