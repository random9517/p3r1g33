        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "100_0104101" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあぁ……隊長どの、助けて、くれぇ。夜分遅くに、押しかけた非礼は詫び\nる。だが、どうしても、助けて欲しくて……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104102" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ま、マタタビだ。秘蔵していたマタタビを、うっかりと間違えて、料理に混\nぜてしまったんだ。おかげで、身体が、熱いぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104103" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに、身体の奥が……下腹部が疼いてしまって、もう、我慢が……駄目だ\n、隊長どのの顔を見ていたら、ますます……えい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104104" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふ、ふふふ。可愛いな、隊長どの。女に組み敷かれて、驚くその顔、そそる\nぞ。ふふふふふ」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00010001_02_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104105" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「わ、分かっている。こんなことをして、迷惑をかけていることは。非礼は、\n後で詫びる。だが、すまん。もう限界なんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104106" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんんんんん！　あ、あぁ……入って、きたぁ。隊長どののペニス、入っ\nて来たぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104107" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら、見えるだろ、隊長どの。奥まで、一気に……マタタビで疼いてたから\n、あそこ、とっくに濡れてて、一気にペニス、奥まで来たぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104108" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「……あぁ、これ、落ち着く。私の中に、ぴったり収まってる。まるで、私の\nためのペニスだ……あぁぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104109" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「す、すまないが、動くぞ、隊長どの。もし面倒なら、そのままじっとしてて\nくれ。すぐに終わらせるから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104110" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん、んあ、んん！　はうう！　んっ、んっ、んっ、んんんんん！　凄い！　\nあ、ふあぁ！　奥まで、んんんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104111" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「大きくて、ガチガチにかたくて、たくましいから、ペニス、簡単に、私の奥\nまで、届いてくるぅ！　んんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104112" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ、いい！　ずん、ずんって、奥までぇ！　子宮に、響くぅ！　気持ち良\nすぎるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104113" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの！　隊長どの！　隊長どの！　あ、あ、あ、あ、あ、あ！　もっと\n、激しく、動く、ぞ！　もっと……んんんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104114" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはぁ！　ずぶずぶって、ペニス、私のアソコ、擦れてるぅ！　こんな、気\n持ちいいの、初めて、だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104115" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんん！？　ち、乳首、摘まんだぁ……ひあ、あ、あ！？　また！？　ひ\nんんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104116" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だ、駄目だ、隊長、どの！　そんな風に、されたら……私、今、ただでさえ\n、感じてる、のに！　乳首ぃぃ！　あ、ふああああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104117" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「駄目駄目駄目駄目駄目ぇぇぇぇ！　このままだと、乳首、でぇ！？　あ、あ\n、あ、ああ！？　ふああああああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104118" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んきゅんんんんんんんんん！　あ、ふあぁ……い、イッたぁ……乳首、強す\nぎてぇ……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104119" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあ！　はぁ、はぁ、はぁ、はぁ、はぁぁぁぁぁぁ。い、一気に、上り詰め\nて、しまった。私とした、ことが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104120" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「乳首、抓られて、我慢、できなかった……目の前が真っ白になるぐらい、急\nに、快感が、弾けたんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104121" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まさか、乳首で、気持ち良くなる、なんてぇ。イク、なんてぇ……初めて、\nだ。こんな、の」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104122" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、おかげで少し落ち着いたよ。す、すまない、隊長どの。迷惑を、かけ\nた。あとは、一人で処理するから……んああ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104123" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「う、動いた……ガチガチになったペニスが、奥に、ぐいぐい、擦り突いてく\nるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104124" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そ、そうだな、すまない。やはりマタタビのせいで頭がどうかしていたらし\nい。隊長のペニスがこんなにギンギンなのに、放っておくなどできないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104125" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「す、好きに動いてくれ、隊長どの。私も、隊長どのが気持ち良くなれるよう\n、思いっきり動くから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104126" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん、あ！？　んああ！？　ん、ん、んん、ん、んんん！　は、激しい！　ん\nんん！　激しいのに……はぁ、はぁ、優しぃ！　んんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104127" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「い、イッたばかりだから、気を遣ってくれてるのか？　大丈夫だぞ、隊長ど\nの。まだ私の身体は、強く疼いてる」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104128" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だから、乱暴にしてくれても、平気……んああああ！？　いきなり、動きが\n！？　んああああああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104129" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふ、ふふふ。隊長どのも、たまってたん、だな？　か、感じる、ぞ。ペニス\nが、私の中、出たり入ったりしながら、ピクピク震えてるの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104130" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひううう！？　でっぱりが、気持ちいい場所を、引っ掻いてる！　そこ、あ\n、ああああ！？　身体、ぞくって、するぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104131" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お、おかげで、また……またぁ！？　ひううう！？　このままだと、また、\nすぐにぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104132" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「い、言うなぁ。アソコ、震えてるとか、じゅぶじゅぶ音がするとか、そうい\nう、ことは、言うなぁ……恥ずかしいじゃ、ないかぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104133" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ。イキそう、だ。また……イキそう、なんだぁ……はうぅぅ！\n　また、乳首ぃ！？　んんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104134" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だ、駄目だ、また、イク！　ふあああ！？　今度は、乳首と、おまんこ、両\n方で……あ、ふああああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104135" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いきゅううぅううぅうぅうう！　んあ！　あん！　熱いのが、中にぃ！　ん\nんんん！　どばどば、中に、来てるぅぅぅ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00010001_02_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104136" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んああ！　はぁ、はぁ、はぁ、はぁ……ふあぁぁぁぁ。い、イッた。こんな\n、短時間の間に、続けて、イったぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104137" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「頭が、ぼうっと、する。お腹の奥が、熱いぃ。そ、それに……乳首が、まだ\n、きゅんきゅん、してる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104138" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あぁ……やっと、マタタビの疼きが止まったよ。迷惑をかけたな、隊長どの\n」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00010001_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104139" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このお詫びは改めてさせてもらう。今は……二回続けてイッたせいか、こ、\n腰が抜けてしまってな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104140" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「すまないが、手を貸してもらえないだろうか。うぅ、こんな情けない姿を見\nられるとは、面目ない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104201" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん？　ああそうだ。腰が抜けたんだ。おかげで今、動けないんだ。ほら、全\n然下半身に、力が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104202" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おい、隊長どの。どういうことだ？　私の中に収まったままのペニスが、ま\nた膨らみ始めたぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104203" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んああ！？　ま、また、乳首を──んん！？　んむ、ん、きすぅ、いきなり\n……んちゅうぅ、ん、ちゅうぅ、んんん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104204" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「むぅ、んちゅ、ちゅうぅ、ちゅ、ちゅぶぅ……ん、ぷあっ！　はぁ、はぁ、\nはぁ……し、知らなかった、ぞ、隊長、どの」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104205" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どのは、キスも、上手なんだな。おかげで、今ので私、また、スイッチ\nが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104206" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに、キスされてる間、ずっと、ペニスが、中でぴくぴく震えて、それが\n、子宮にまで響いて……駄目だ、完全に、スイッチが、入った」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104207" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「腰は相変わらず動かないが、このまま……あ、あ、ふぁぁ。んんん！　隊長\n、どの……あ、あ、ああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104208" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひあああ！？　お腹の裏側、擦れてるぅ……んんん！　そこは、Gスポット\n。んん！　んっ、あんんん！」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00010001_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104209" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひあああ！？　疼く！　子宮が、どんどん、疼くぅ！　そこ、ごりごりされ\nると、身体中が、痺れるぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104210" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「き、気持ち、良すぎる！　頭が、吹き飛びそう、だ！　二回も、イッて、敏\n感になりすぎてるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104211" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このままだと、また……また、すぐにぃ！　私、三回目、なのに、こんなに\nまた、すぐに、気持ち良くなるなんてぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104212" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあぁぁ……む、胸ぇ、優しい……さっきまでと違って、凄く、優しい手つ\nきで……よ、余計に、感じる、それぇ」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00010001_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104213" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「むぅ！？　んむぅ、また、きすぅ……んちゅ、じゅる、ちゅううぅぅ。んぶ\nぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104214" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふあぁ！？　きす、しながら、身体あちこち、撫でられてる……じゅる、ち\nゅぶぅぅぅ。ぷあっ。はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104215" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「か、感じ、すぎるぅ。まるで、全身が性感帯になったみたい、だ。髪の毛を\n撫でられても、ぞくぞく、してしまうぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104216" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひゃんんん！　く、首に、キス……あ、ふあぁ。今ので、もう、気持ちいい\nの、止まらなく、なったぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104217" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「き、来てる。ぞくぞくしたのが、来てる。お腹の奥で、疼いて、身体中に、\n広がってぇぇぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104218" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「た、隊長、どの！　隊長どの！　わた、し……また……あ、あぁぁ。三度目\nの、絶頂、もう、すぐそこにぃ……」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00010001_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104219" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひうううう！？　今までで、一番、激しい！？　ペニス、ガンガンに、突い\nてくるぅぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104220" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あああ！？　駄目！　イクぅ！　イクイクイクイクぅ！　\n私、あ、もう！？　イクぅううぅ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "100_0104301" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあああああああああ！　イッてる！　んんんん！　イッてるところに、ま\nた、熱いの、どばどば、来てるぅぅぅぅ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104302" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁぁ……す、凄い……また、イッた。私、こんなに、何度もイクな\nんて……は、初めて、だ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104303" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに、隊長どのの射精も、全然、衰えて無くて……私のお腹、たぷんたぷ\nんになってる。子宮が、溺れそうになってるじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104304" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「暖かい……こんなに暖かいものなんだな、セックスとは。隊長どのとまぐわ\nって、初めて分かった気がする」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104305" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「災い転じて福となす、だな。マタタビで酔った時はどうしようかと思ったが\n、隊長どのに抱いてもらえて良かった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104306" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあっ……ふふ。ペニスが抜けたな。さすがに、小さくなってしまったか。\nできれば、もう少し感じていたかったが……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104307" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「し、しかし、終わった後のこの光景……卑猥だな。あそこから、塊になった\n精液があふれている」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104308" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「って、隊長どの、その卑猥な光景にまた興奮したのか？　ペニスが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104309" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふふ。いいだろう。とことん付き合おうじゃないか。私の身体を慰めてく\nれた礼だ。隊長どのが嫌になるまで、お相手しよう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104310" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「夜は始まったばかりだ。忍びが最も活動する時間だ。さあ、隊長どの。今一\n度、蠱惑のひとときを」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]}, 
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "100_0104401" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあ！？　どうして、急にペニスを引き抜くんだ！？　せっかく、イケそう\nだったのに！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104402" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「──って、んああああああ！？　精液が、身体中に！　んんん！　熱いぃぃ\nぃ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104403" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「熱いのが、肌を……おまけに匂いが……あ、ふあぁぁ！？　ぞくぞく、する\n！　身体中に精液、ぶちまけられて、ぞくぞく、するぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104404" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「う、うそだ！？　私、このまま……あ、ふああああああ！？　いくうぅうう\nぅぅううぅうううぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104405" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んあ！　はぁ、はぁ、はぁ、はぁ……はぁぁぁ。そん、な。精液を、ぶっか\nけられて、イク、なんてぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104406" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ、ああ。熱いのが叩きつけられて、それが、気持ち良かったんだ。我慢で\nきず、果ててしまった」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104407" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まさか、こんなこと、あるなんて。ぶっかけられて、イクなんて。んあぁ…\n…匂いが、凄い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104408" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにしても……隊長どののペニス、まだ萎えないんだな。私の今の姿に、\n興奮してるのか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010001_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104409" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、良いとも。何度でも、隊長どのの好きなだけ、私を感じてくれ。ふふ\n、こんなに何度も求められるなんて、私は幸せな女だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "100_0104410" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「忍びの道に入ったとき、人並みの幸せは諦めたのだが、まさか、こんな喜び\nを味わえるなんてな。ふふふふふ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
