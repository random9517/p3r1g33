		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「不死なる鳳よ、命の焔で邪悪を滅ぼせ！　鳳凰天舞の陣！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「うっ！　うわあああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「くっ……！　式神とニンジャの戦闘術を組み合わせてくるとは……！　ここ\nは、いったん退くしかありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やった！　ハルノブ――じゃねえや、オボロ！　あいつら、逃げてくぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうかあのスーツ……単なる『養成ギプス』ネタじゃなかったんだな…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「わははははは！　私だって、たまには役に立つものを持ってきたりするのだ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分で『たまには』って言っちゃってるよ、この人」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「どうやら、勝ったようですね。あいつに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「これが、ウチの人生のリベンジです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640003" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんか、またどっかで聞いたようなセリフだな……っていうかさぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こんなのできるんなら、最初からやっとけよな！　こっちだってすっげえ苦\n戦してたんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「うっさいです、バカ犬。そうできるなら、最初からやってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お？　なんかそのムカつく感じ！　ちょっと昔のオボロが戻ってきたかな？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「そう……ですか？　記憶は、まだあまり戻っていないですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんか、前のオボロにだいぶ近くなった感じだけど。でもさ、さっきの技と\nいい性格といい……どうして急に思い出したんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「え？　それは、カツ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「カツ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「……い、いえ！　なんでもないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640008" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「えー？　なんだよ、もったいぶるなよー！　教えろよ―！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640006" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "真・オボロ" ]},
		{"command":[ "SETTEXT", "「な、なんでもないです！　そんなことより、さっさと本部に戻るですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_210116640009" ]},
		{"command":[ "SETCHARA", "0", "char_00000521_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え？　なんだよ？　なに怒ってんだ？　おい、オボロ―！　ちょっと待てっ\nてば！　オボロ―！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116640007" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「今の『カツ』って、まさか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「穴に落ちていたわずかな間にカツマさんとナニかがあった……！　そうよ、\nきっとそうよ……！　わたしにはわかる！　なぜかは知らないけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116640001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ＆まりあ" ]},
		{"command":[ "SETTEXT", "「前回に続いて、またイヤな予感が……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116640002" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}