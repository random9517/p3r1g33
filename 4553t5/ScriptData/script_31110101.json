{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、私にお水をかけていったいなにを……あら、洗車してくれる\nの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「最近は遠出が多くてあまり洗車してなかったから、少しボディが汚れてたわ\nね……助かるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103102" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「……ふふっ。洗車が好きだなんて、カツマちゃんはちょっと変わってるわね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「洗ってくれるのは嬉しいけど、洗車機に入れるだけでもいいのよ？　……え\n？　自分の手でピカピカにする方が面白いの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やっぱりカツマちゃんは変わってるわね。でも、ボディがキレイだと、道路\nを走っていても気分がいいから、私は助かるけど……あんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「な、なんでもないわ……！　ただ、思っていた以上にお水が冷たくて、ボン\nネットにかかるたび、私の超ＡＩが反応しちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「気にしなくても大丈夫よ。全体的に水かけてもらえば、それだけで埃はだい\nぶ落ちるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちゃんと拭き洗いもしてくれるの？　そこまでしてもらうと、さすがに気が\n引けるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「好きだからやらせて欲しいのね……それじゃあ、お願いするわ。さっと拭い\nてもらうだけでも、大丈夫だからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うあっ……あっ、んっ……！　ご、ごめんなさい……！　タオルごしにカツ\nマちゃんの手の温もりが伝わってきて、ビックリしちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　そ、そんなゆっくりと拭かれたら……！　あんっ、んんーっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「優しく撫でられたら、私のジャイロセンサーが誤作動しちゃう……！　はあ\nぁ……やっ、あっ、ああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「気持ちよさそう……？　そうね……人間の感覚はよくわからないけど、気持\nちいいというのは、こういうことなのかも知れないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの手でボンネットを拭いてもらってると……んっ……各圧力セ\nンサーに乱れが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「拭き方が変かなって……そんなことないわ。カツマちゃんの拭き方は、とっ\nても丁寧よ。力加減もちょうどよくて……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そんなにされたら……ドライブシャフトが勝手に動いて……！　ああぁん！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ご、ごめんなさい……エンジンコントロールユニットに、ち\nょっとしたエラーが出ちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こんな風になるなんて初めての経験だわ……もしかして、カツマちゃんの手\nで洗車してもらってるからかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁああんっ……ううっ……何度もごめんなさい。突然エンブレムに触れら\nれたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それにしてもこのカーシャンプー……とってもヌルヌルしてるわね。別に不\n快なわけじゃなくて……むしろ、すごく気持ちいいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひうぅ……！？　だっ、駄目……！　ち、違うの……洗車をやめて欲しいわ\nけじゃなくて……！　このままだと、変な気分になっちゃいそうで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あ、あっ……あはん、ああぁんっ……！　だ、大丈夫よ……私、耐えてみせ\nるから……！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うっ、くっ……！　はぁはぁ……洗車がこんなにも感じるだなんて、思って\nもみなかったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「このままだと私の超ＡＩが暴走を起こしちゃいそう……気持ちよすぎて、情\n報処理が追いつかないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はあっ、か、カツマちゃん……もう少しゆっくり……ああっ、優\nしくって意味じゃなくて……んっ！　そんな触れられ方をされると……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うんんっ……！　ご、ごめんなさい……あまりの快感に、サスペンションが\n乱れちゃったわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ほ、本当にカツマちゃんの洗車はすごいわね……人間でいうところの、マッ\nサージを受けているような感覚とでも言えばいいのかしら……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「くっ、あ、あっ……カツマちゃんの手つきが、ゆったり、じっくりと私のボ\nディを触って……す、隅々まで洗車するの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そう……カツマちゃんなら、触っても……あはぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そこは……んっ！　ヘッドライトをそんな優しい手つきで、丁寧に拭かれる\nと……とっても変な気分に……感じすぎて、勝手にピカピカしちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああっ……駄目だと言っているのに、執拗に私のことを拭いて……！　そん\nなに……私のボディが好きなの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そんな……綺麗で魅力的だなんて……！　私の超ＡＩがおかしくなっち\nゃうわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「発熱が止まらなくて、エンジンがオーバーヒートしちゃいそう……！　あっ\n、あっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「駄目駄目、駄目ぇ～～～……っ！　あっはあああんっ、来る、きちゃう～…\n…っ！　なにかがエンジンルームから湧き上がって……ひゃうぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひああああーっ……漏れちゃううぅ～～～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはああぁぁあぁん！　うっ、あっ、くうぅんっ……！　わ、私の冷却水が\n、びちゃびちゃ漏れちゃってるぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ううっ、はぁはぁ……制御できない……！　どんどん溢れて……くうぅん！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあー、はあー……ご、ごめんなさい……私も突然のことで、動揺しちゃっ\nて……最後の仕上げに、泡を洗い流してもらってもいいかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それにしてもカツマちゃんの洗車……本当に感動したわ。くせになっちゃい\nそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「え……さらにキレイにするって……ま、まだ洗車を続ける気なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「やっ、やああぁ……！　これ以上洗車されたら、私の超ＡＩが本当に壊れち\nゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「さっきのだけでも、だいぶ暴走気味だったのに……！　ああ、言っているそ\nばから、警告灯がたくさんついて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあああんっ、あっ……あっ、そんな遠慮なく、タオルでごしごしされたら\n、私……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「き、気持ちよくて、リザーバータンクからはしたなく冷却水を噴き出しちゃ\nいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、やめてぇ……！　んっ、ああぁん……！　ど、どうして……そ\nんな意地悪するの……？　私のこと、嫌いになっちゃったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「好きだから綺麗にしてあげたいだなんて……！　ああっ、嬉しくて、エンジ\nンルームにもお水が入っちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「別にお水が入っても、エンジンが壊れることはないけど……ああっ！　タオ\nルでごしごしされるの気持ちいい……！　もっと、たくさんこすって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ボディの塗装が落ちるくらい、力強くごしごしって……んあああぁぁ、いい\nわ……んっ、ああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……その細かく小刻みにきゅっ、きゅっとされるの、とっても好\nきなの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はああぁぁん、ああんっ……気持ちよくて、少しだけラジエーターからお漏\nらししちゃったわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あ、あのねっ……できれば、サイドミラーも拭いてもらえるかしら……？　\nあっ、ふぁ、ふぁあああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「お、思わずエンジンがかかっちゃうかと思ったわ……！　もうっ、ふぅん…\n…はうんっ、はぁっ、はあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「全身がビリビリして、バッテリーからも液漏れしちゃいそう……ああぁん！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なんだか、私の声に合わせて手を動かしているような……ひょっとして私の\n反応を楽しんでるの……？　あっ、うんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「う、疑ってるわけじゃないの……ただ、あっ、んんっ！　だ、だめぇ……！\n　もう無理……！　また私……イッちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ほ、ほら……もうボディもピカピカだから、泡を落として終わりにしましょ\nう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ちゃんと最後までするだなんて……！　わ、わかったわ。カツマちゃんがそ\nこまで言うなら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ……！　ああぁん、やっぱり無理っ……！　こんなの耐えられ\nない……カーシャンプーでぬるぬるでボディも、制御装置も限界だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの手で新車みたいにピカピカにされて……あっ、ああ……！　\n壊れたみたいに、ボンネットの中が熱くなって……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあああぁんっ……！　レブリミッターが壊れて、回転数がレッドゾーンに\n達してる……！　いっ、イクっ……！　イっちゃうううぅ～～～っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま","LABEL2","水洗い","LABEL1" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ううっ、んくううう～っ！　火照ったエンジンに、冷たいお水がかけられて\nるぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「エンジンルームにも、フロントガラスにも、たくさんかかって……！　気持\nちよくて、ウォッシャー液がびゅるびゅる出ちゃうぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふあああぁ……！　わ、ワイパーも勝手に動き出してる……ひゃあああんっ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そんな……！　動いてるワイパーを無理やり止めて、立たせるだなんて\n……！　しかも、タオルでごしごしまでされて……ああ、ああぁあ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「全身余すことなくピカピカに……あうぅぅっ、洗車好き……大好きっ！　カ\nツマちゃん、大好きぃ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはあぁ……はぁはぁ……あんっ、中身が空になるくらい、ウォッシャー液\nを放出しちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「きゃっ……！　仕上げの水洗いだけじゃなくて、乾拭きまでしてくれるの…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあぁ……全身の泡が綺麗に流されて、拭きとられていくわ……火照った私\nの超ＡＩも、冷水で冷えていくみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ……ある程度冷静さを取り戻すことができたわ……それにしても、こ\nんなに恥ずかしいところを見られちゃうなんてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「でも……もし嫌じゃなかったら、また洗車してもらえると嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あううっ、漏れ出るっ！　ああ、だめぇ～～～～、ウォッシャー液が漏れ出\nちゃうぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあぁぁぁん、こんなにたくさん……壊れたみたいに出ちゃってるぅ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103402" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、あはあぁ……あは、はあはあ……あれ……？　カツマちゃん、なにを\n……？　も、もしかして……！　や、やめっ……んんんっ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あああっん！？　そ、そんな……私のウォッシャー液を、ワイパーの届かな\nいところまで塗りたくるなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あううっ、またヌルヌルで気持ちよくなって、フロントガラスにウォッシャ\nー液が溢れ出ちゃってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああぁあん……！　こんなふうにされるなんて、思っても見な\nかったわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ……綺麗に洗い流してくれるのね……泡だらけだし、ワイパーでは届か\nないところもあるから、とっても嬉しいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ……カツマちゃんの洗車はとっても気持ちよくて……くせになっちゃい\nそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「気が向いたら、また洗車してくれるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00011101_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ。ありがとう……嬉しくて、ヘッドライトが勝手にピカピカしちゃう\nわ……」", "NORMAL" ]},
