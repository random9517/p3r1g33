{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "俺はまた受付に戻ってきた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "すると、珍しい３人組？　がちょうどやってきたところだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あら、隊長ちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490001" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たちは……えっと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「オクティーヌよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490002" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「リアンお姉ちゃんよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_010023490001" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「ショーコですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490001" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだった。こうして外で会うのは初めて……だよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「そうね。ママたちの出番は半年とか１年に１度くらいだもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490003" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「というわけで、また次の出番が来るまでに、たまには温泉旅行をしようって\n話になりましたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490002" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「みんなで温泉なんて、お姉ちゃん楽しみー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_010023490002" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「また隊長ちゃんたちの全力を受け止められるように、英気を養わないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490004" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか。ごゆっくり」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "謎の多いダンジョンで登場する彼女たちだが、ほんの少しだけプライベートを\n垣間見れた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しかし、この３人って温泉に入れるのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "タコだし、蜘蛛だし、蝸牛なのだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「たたたた、大変です～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023490001" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そこへ、大慌てのミナカがやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうした！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お、おお、温泉に……サメが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023490002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　サメ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「サメって……あの、お魚のー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_010023490003" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「温泉にサメがでるだなんて、ありえませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490003" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだよな。普通は……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なんだろう、猛烈に嫌な予感がする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "相手はサメだ。それが温泉にでないとなぜ言い切れる？", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "0"]},
		{"command":[ "FADEOUTCHARA", "3", "NORMAL" ] },  
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……って、どこぞのサメハンターに思考が毒されてしまってる。温泉にサメが\nでるなんて、普通は、本当は、常識的に考えればありえねぇのに！", "NORMAL" ]},
		{"command":[ "SETCHARA", "3", "char_00012701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ] },
		{"command":[ "FADEINCHARA", "3", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、現場へ行ってみよう。ミナカ、案内してくれ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「は、はいぃっ！」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYVOICE", "v2_273_010023490003" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ザッバーン！　……ココドコ？　ココドコ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010023490001" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "さっそく湯船の中からサメのエントリーだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「本当にサメですわ～！　サメがでやがってますわ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490004" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「あらー、本当ねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_010023490004" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ザッバーン！　……ココドコ？　ココドコ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010023490002" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……やっぱこいつか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「か、カツマ様は……もしかして、あのサメのことをご存じなのですか……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023490004" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、あいつはファイナル・デッドシャーク。次元のはざまを泳ぐサメだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おそらく、また迷子になったんだろうな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "遭遇したのはこれで３回目だ。また現れるなんて。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「迷子だなんて……！　それなら、ママがなんとかしてあげなくちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490005" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「オクティーヌ様、不用意に近づくと、食べられてしまいますわ！　相手はサ\nメですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490005" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「平気よ。それに、この子もそんなに悪い子には見えないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490006" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……顔はかなり凶悪だぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ビーチでは温厚だったが、学園では襲いかかってきたし、こいつは個体による\n性格の差も大きいようだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "いま襲いかかってこないってことは……幸運にも温厚な個体を引いたか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ザッバーン！　……ココドコ？　ココドコ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010023490003" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「デッドシャークちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490007" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ア……アア……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010023490004" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "デッドシャークがオクティーヌの方を見た。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "じっと見つめあうオクティーヌとデッドシャーク。すると、オクティーヌが踊\nりだす。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00022201_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "跳ねるような足踏みをしながら、ハグをするように腕を前へと伸ばしている。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「タコソイ・フグアジ・ドンコティラピア・コボラー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "-200", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "200", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ウ……ア……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_010023490005" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "デッドシャークは踊るオクティーヌをじっと見つめている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なにやってるんだ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「言葉が通じる相手に見えませんから、踊りで意思疎通を図ろうとしているの\nですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490006" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと……でき……ますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023490005" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「オクティーヌならー、できるかもー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_010023490005" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「タコソイ・フグアジ・ドンコティラピア・コボラー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_010023490009" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "7", "CENTER", "0" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "-200", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "200", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というか、この呪文？　いったいなんなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「えっとねー、地下迷宮界隈で大バズりしてる、芸人のネタだよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_010023490006" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ショーコ" ]},
		{"command":[ "SETTEXT", "「いろんな方の『踊ってみた』が毎日のように投稿されていますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_186_010023490007" ]},
		{"command":[ "SETCHARA", "0", "char_00018601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "地下迷宮にＳＮＳなんてあるのか……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そんな感想を抱きつつ、あらためてオクティーヌの方に目をやった。その奇妙\nな踊りとともに、ゆっくりとデッドシャークに近づいていく。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00018701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "やがてデッドシャークがオクティーヌのリズムにあわせて身体を揺らしはじめ\nた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022201_01", "0", "CENTER", "0" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "-100", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "100", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
