{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「突然、お時間をいただきたいだなんて……お願いしてしまって申し訳ありま\nせん。今宵は私の秘密を、あなた様にお教えしたいと思って参りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「もしかしたら、もう薄々お気づきかもしれませんが……。私は男性の顔と名\n前を、忘れてしまう呪いにかかっているのです。はい、ずっと昔から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「今まではこの呪いのことを諦めていました。ですが、あなた様と出会って、\nどうしても、あなた様を忘れたくない。そう思ったのです。ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「何か良い案はありませんでしょうか。……え？　忘れられなくなるような、\n鮮烈な、強烈な経験をすればいいのではないか、と？　それは一体……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……あ。もしかして、それは身体と身体の触れ合い……。いわゆるご奉仕と\nいうものでしょうか。わ、わかりましたわ。少々お待ちくださいまし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ……！　つ、つまりこうして……。私の胸で色々なことを……って、き\nゃっ……！？　あっ……！　あっ、あなた様の、そ、それは……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「おチンポ……？　おチンポというのですね……。え、ええ。その……知識と\nしては、殿方の股間にそういったものがあるとは聞いておりましたが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「じ……実際に目にしたことは初めてですので……。驚いてしまいましたわ。\nそ、そうなのですね。これが……男性のとても大切なところ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……見ているだけで顔が赤くなってしまいます。それに体温も上がってきて\n……。はぁ、はぁ、恥ずかしいのに目が離せなくなってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「確かに……これは衝撃的で、鮮烈な記憶になるのかもしれませんね。あっ…\n…！　ピクピクと震えております、それにこの頭のクラクラする臭い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私に反応しているのですか？　あ、あぁ……なんと健気な……。であれば私\nが、責任をもって対応させていただかなければ……。ま、まいります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「はぁ、ンンッ……！？　あ、熱い……！？　それに、おチンポがこんなにも\n硬く逞しいものだったなんて……！　す、すごい、すごいですわ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「生きて……います、私の胸の間に挟まって、強いぬくもりを発している……\n。せ、生命力の塊といった印象を持ちました。あ、強くて太くて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私のような未熟者に、これほどまでに強靭なおチンポを受け止めることが可\n能でしょうか……？　少し不安ですが、は、始めますね……？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ……。あぁああぁ、本当に硬いですわ……！　これが人の身体の一部だ\nなんて思えません、中に鉄の棒が仕込まれているかのよう……神秘的ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……んん……、大変申し訳ありませんが、ここからのご奉仕の方法を……あ\nの、教えていただいてもよろしいでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「はい、はい……。あぁ、そうなのですね。どれだけダイヤモンドのように硬\nくとも……おチンポは繊細で敏感な気管……。大事に刺激していくのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「優しく……やさしく……。えぇ？　く、くすぐったいですか？　あ、あまり\n触れない方がいいのかと……？　そうではなく、しっかりと愛情をこめて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「は、はい。愛情でしたら誰よりも人一倍……。んんん……？　私の方では、\nどこまで力をこめて良いものか判断がつきかねますので……言ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「どれくらいの力加減がちょうど良いのか、どこからが過ぎた真似なのか……\n。それなら安心して刺激できます。……これくらい、ですか？　もっと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私の胸を押しつけて、おチンポの根元から……。はぁっ、先端まで、中の精\n液を絞り上げていくイメージで……んんっ。上下にしごくのですね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……あっ♪　ご、ごめんなさい……！　この動き、私の方にも快感が生まれ\nてしまって……妙な声を漏らしてしまいました。……あっ、す、すごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「おチンポを胸の膨らみで揉みながら、乳房を揺らしてまとわりつかせている\nだけなのに……、はぁああっ♪　おチンポの熱に浮かされてしまいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「い、いやぁ……♪　乳首が硬くなってきてしまいました、はぁっ、どうして\n……？　ご奉仕をしている私の方が、まるでお酒に酔ったかのように……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あのっ、こんなぎこちないご奉仕であなた様は気持ちがいいのでしょうか？\n　はぁっ、心をこめて！　おチンポをこすらせてくださっています、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あぁんッ……！？　どう考えても私の方がっ、あんっ！　か、感じているよ\nうな……、はぁんんっ♪　気持ちいいですか？　私のお、おっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あ、あああああ……♪　そうおっしゃっていただけるなら幸せです……！　\nもっともっと精進します、たくさんたくさんご奉仕します！　あんっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私……！　あなた様に褒めていただいたこと、絶対に忘れません！　ですか\nらあなた様も……あっ、おチンポ様も忘れられない記憶を刻み付けてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っあっ♪　あっぁっ、あぁんっ♪　あんっ……！　だめです、声、抑えられ\nません……っ！　あぁんっ、おチンポ、おチンポ好きですぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あんっ！　どうか……どうか、私の頭が忘れても、身体が覚えていられるよ\nうに……！　たくさんの快楽をください、……あっ、気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ふふ、うふふふっ……♪　ご奉仕って、二人で一緒に気持ち良くなれて、同\nじ快感を共有できるのですね……っ。こんな素敵な思い出、忘れたくない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……だからっ♪　もっと♪　もっと深くまで……！　私の身体に教えこんで\nくださいっ……。あっ♪　ご奉仕の気持ち良さを……あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「おチンポっ……ビックンビックンしてきましたわ……っ♪　あぁっ、あぁあ\nんっ！　中に……！　胸の中に出してください！　射精の知識はあります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ですから後は……！　消えない記憶をっ、あんんっ♪　私と私の胸にくださ\nい、しっかりと染みこませて、絶対に忘れられないくらいぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　あぁ、あっ♪　あぁんっ、出して……！　出してくださいませ！\n　はぁああっ♪　たっぷりと、あなた様の精をこの胸に、どうか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ひぁあああっ……♪　あッ……♪　これが殿方の射精……！　あなた様が私\nにっ、私の胸にくださったお情け……！　んぁああっ、あたたかい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ヌルヌルとした熱い雫が……あああっ、どんどん溢れて、流れていきますわ\n……っ！　あっ……あっ、胸の中で脈打って……すごく激しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ♪　これが……これがあなた様の射精……♪　男らしく、何度も私の胸\nの間に精を解き放つその姿……！　あっ、ぁっ、目に焼き付けます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ふふっ、うふふふっ……♪　たくさん出ましたね……。あぁ……、嗅いだこ\nとのない臭い……。これが精液の香りなのですね……？　すううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ……！　鼻孔に残る濃厚な臭いです……。これも、忘れないようにしな\nくては……。はぁ、はぁ……。あなた様の子種……。真っ白な種……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「話に聞いたところでは、これを……その、膣内に注入すれば子どもが出来る\nのですよね……？　そんな貴重なものを出していただいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ありがとうございます……♪　……あら？　あらあらあら？　あの……。お\n礼をしようと思って、胸を動かしていたら……その、またおチンポが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「どんどん大きく、太くなってきて……。これはどうすればよろしいのでしょ\nうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「もう一度、新しい記憶を胸に……身体に刻みこむチャンス？　そう言われて\nみれば確かにそうです。あの……もう一度、させていただいても？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……よろしいですか！　あ、あぁ……助かりますわ。では、僭越ながら……\n今一度、おチンポにご奉仕させていただきますね……。っんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ひゃっ……♪　あらっ……！　先ほど出していただいたばかりの精液、が…\n…んんっ、胸に広がって……あぁっ、とても、ヌメります……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あんっ……んんっ、なんだかいやらしい……♪　んんぅ……っ♪　それに、\nおチンポをこする時に滑りが良くなって……はぁっ♪　あぁ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「スムーズに刺激できるようになった気がします……！　あっ……！　あっぁ\nっ……！　え？　シゴき方が上手くなってきた？　そうですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「どんどん慣れて、上達していると……？　あっ……♪　そんな風に褒められ\nるととてもくすぐったいです、それに……、んぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「精液まみれの胸で、おチンポをこすっていると……あっ、卑猥な香りがただ\nよってきて……あっ、心臓がドキドキしてまいりました……。んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「おチンポをいじるのが、やめられませんっ……！　はぁっ、あぁ、あぁっ、\nあぁん……！　どういたしましょう、き、気持ちいいです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んぁんんっ♪　硬くて長いモノがっ……！　あっ♪　おチンポが胸の間をに\nゅるにゅると往復して……そのたびに、あっ♪　感じてしまってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「は、ぁっ♪　あぁっ、あぁっ、あぁ……っ♪　自然と身体が揺れて、しまい\nます……♪　あっ……あぁっ、もっと上手くしたいのに、もどかしいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あなた様は……、んぁっ♪　ちゃんと気持ち良くなれておりますか……っ♪\n　私は……！　あぁッ♪　すごく、すごくいいです、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っんっ……！　あっ？　こ、腰を突き上げて、私の胸とリズムを合わせてく\nださって、いるんですね……♪　協力して、二人で気持ち良くなれて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「幸せ、です……っ♪　あぁっ、胸が熱い……っ♪　んぁあんっ、だめぇ……\n！　だめですっ……あっあっあぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んっ……！？　再びおチンポ様がヒクついてまいりましたが……、あっ、そ\nうですか、二度目の射精をご所望なのですね……♪　ふふ、うふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　もう一度、もう一度おチンポ様の精をお注ぎくださいませっ……\n♪　んぁああっ、私も……！　私の胸も今すぐ達してしまいそうです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ですから一緒に……っ！　共に果てたいのですぅうっ♪　んぁああっ、好き\nっ♪　好きです、あなた様も、あなた様のおチンポもぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あっ♪　イキますっ、ですからイッてくださいっ♪　びゅるびゅる出してっ\n♪　私の胸に、消えない臭いをつけて、あなた様のものにしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103220" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んふぁああああああぁああっ♪　あぁあああんっ♪　あんっ、あぁああんっ\n……♪　イクッ、イクぅっ！　あなた様の精を感じながらイクぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　あっぁっああっ……！　ドクドクと、命の源が……！　また私の\n胸の中に、惜しみなく注がれて……！　んぁっ、あたたかいです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「はいっ、はいぃっ♪　これだけ何度も射精していただいたら……っ！　いく\nら私でも忘れることは難しいと思います、あっ♪　忘れたくないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「あなた様の気持ち良さそうな顔、その吐息、このおチンポの震え……！　私\nの胸にどぷどぷと流れこむ精液の感触、この臭い……！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んぅっ……！　あなた様の香りで私の胸がいっぱいになっていく……っ。は\nい、どうぞごゆっくり……！　慌てずに射精を続けてください……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ん、んんん……っ。ありがとうございます……！　私の拙い動きで、二度も\n射精してくださるなんて……。あなた様はなんてお優しい方……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……あぁ……♪　どこにでもいる少女のように……、記憶をなくすことのな\nい女性のように……ただ、愛する殿方と濃密な時を過ごせた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「明日、そしてこれから私の記憶がどうなってしまうかは……今はわかりませ\nん。ですが、これだけは誓って言えると思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「今宵、あなた様と触れ合うことができて……。こうして快感を共有できて、\n本当に良かったです。もし、呪いが解くことができたら……もう一度」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103309" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「お祝いに……こんな時間をおねだりさせていただいてもよろしいですか？　\nふふふ、その日のことを、今から楽しみに待ちわびております……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ひぁんんっ♪　あっ……！　あぁっ、あなた様……！　お、おチンポの先端\nから……っ、大切な精液が飛び出してしまって……あっあっあっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_24" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「も、申し訳ありませんっ……！　胸の中ではなく、私の顔にかかってしまっ\nております……！　っあっ！　ど、どうすれば……、んぁっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「えっ？　よ、良いのですか？　このままで……んぁああっ♪　あっ、そ、そ\nうでしたか……！　胸以外にも記憶を刻んだ方が良いと……っ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「それでしたらたくさん顔にかけてくださいませ……！　ッんん……！　なん\nと粘り気の強い精液でしょう……っ、二回目の射精だというのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「元気いっぱいに私の顔に降りかかっています……♪　っぁっ……あっ、確か\nに……！　記憶を刻む場所は多い方がいい、そうですね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「んッ、私のためにありがとうございます……！　あっ♪　びゅっびゅっと精\nがほとばしって……♪　飛沫がどんどん顔に当たります……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ふぁ……♪　あぁああああ……。胸でご奉仕させてくださっただけではなく\n、顔にも射精していただけるなんて……。大変驚きました……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「確かに、私の想像を超えた行為の方が……強く記憶に残るかもしれません。\nここまで意表を突かれた経験は他にありませんから、期待できそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……もっとすごいプレイはたくさんある？　まぁっ……！　それなら、色々\nと試してみなければなりませんね。その時もお相手をお願いできますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……！　よろしいのですか！？　ああああっ……♪　こちらこそ、よろしく\nお願いいたします。心をこめてご奉仕させていただきますわね……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00028501_01_23" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}