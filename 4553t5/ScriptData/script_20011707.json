{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「手に汗……ではなく、尻に汗握る女の闘いが今ここに！　ムチムチ！　尻相\n撲対決のお時間です！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「待ってましたあああああぁーーーーーっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここ一番の盛り上がりだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「尻相撲と言うぐらいですし、いろんな意味で見ごたえがあるんでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540020" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こちらは読んで字のごとく、尻で相撲を取る競技です！　海の上に浮かぶ不\n安定な足場の上で、思う存分尻を突き合わせてください！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「足技はＯＫですが、手を使えば反則とみなします！　尻と足腰の力で相手を\nフィールドから突き落とすか、足の裏以外を足場に付かせれば勝利です！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こちらは紅組、白組ともにランダムで４名ずつ選出され、トーナメント方式\nでの戦いとなります！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「１回戦のみ紅組と白組の組み合わせですが、２回戦以降はチームに関係なく\n、勝った人との勝負です！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、出場する選手を選びたいと思います……まずは紅組！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「選ばれたのはこの人たち！　エファ・グラナーダさん、ピースムーンさん、\nゲンナイさん、若苗破さん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「続いて白組！　朧兎子さん、ディアナ・アーマーンさん、若苗序さん、若苗\n急さんです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「若苗姉妹は全員参加か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「誰が勝ち上がるのか、楽しみですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540021" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「１回戦の組み合わせを発表します！　Ａブロックはエファ選手と序選手！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「相手が誰であろうと、手加減はしないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「いきなり私からですか。気合を入れて行くですよ～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540033" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「続けてＢブロック、ゲンナイ選手とディアナ選手！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「修行で鍛えた足腰を見せるチャンスだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いやぁ～ん！　ディアナちゃん、お尻で相撲なんてやったことないのにぃ～\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「Ｃブロックはピースムーン選手と急選手！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「初戦から、幹部の皆様が相手でなくてよかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540004" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクとお姉ちゃんたちが勝ち進めば、破お姉ちゃんとは２回戦……序お姉ち\nゃんとは決勝で戦うことになるのかぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540030" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そして最後のＤブロックは、兎子選手と破選手です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「海の上で相撲だなんて……！　落ちたら水浸しじゃないですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ビーチフラッグでは不甲斐ない姿を晒したので、名誉挽回させてもらいます\nー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540027" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは！　１回戦Ａブロックのエファさん、序さん！　海上のステージへ\nどうぞ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「あっ、言い忘れておりましたが、この競技に参加されない方は、あちらの野\n外ステージで歌を歌っていただきます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なによそれ。そもそも、どうして歌を歌う必要があるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「この手の水着コンテストには、付き物の演出です」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「歌の方は後日編集して、ワイプ映像として流しますので、よろしくお願いし\nます」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだかよくわからんが、歌えばいいのだろう？　なら、私に任せておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「歌の準備の方も問題ないみたいなので、それでは改めまして……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「尻相撲対決、１回戦Ａブロック……尻合って～、のこったあああぁーーーっ\n！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「子供だからって、容赦しないわ！　くらいなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「くっ……！　すごい力です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540034" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「エファ選手の尻が序選手を襲うーーーっ！　小さな子を無理やり襲うデカ尻\n！　これはもう、犯罪的と言ってもいいでしょう！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「誰がデカ尻で犯罪的よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「対戦中にツッコミを入れるとは、甘く見られたものです！　正義の刃……も\nとい、お尻を受けるですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540035" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと……！？　きゃあああぁーーーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「序選手！　エファ選手の隙をついて、場外に沈めたーーーーーっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これは文句なしの突き出し……いえ、尻出しです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「体格差もあるのに、あっさりと勝負を決めたな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「集中が途切れた瞬間を狙った見事な一撃。さすがはサムライといったところ\nでしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540022" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「続いて１回戦Ｂブロック！　ゲンナイ選手対ディアナ選手の試合です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「尻合って～、のこったあああぁーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「一気に行くよ！　ニンジュツ・張り尻！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いやあぁ～～～んっ！　お尻に柔らかいのが当たってるぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おーーーっと！　ゲンナイ選手、尻を左右に振ってディアナ選手の尻を何度\nも叩いております！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「まさに尻の往復ビンタ！　ディアナ選手の尻がぷるんぷるんと震えておりま\nす！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「いいぞおおおぉーーーーー！！　その調子で叩き続けろーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「な、なんでこんなに盛り上がってるの……！？　こっちは真面目にやってる\nのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「もうっ！　ディアナちゃんのお尻はデリケートなんだから、そんなに叩いち\nゃダメよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「わわっ！？　そんなに押されたら……うわああああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「勝負ありぃ！　見事な突き倒し……いえ、尻倒しです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ディアナの尻の弾力が、ゲンナイの攻撃を受け切った形だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにを真面目に解析しているのですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540023" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「どんどん行きましょう！　１回戦Ｃブロック！　ピースムーン選手対急選手\nです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「尻合って、尻合って～……のこったあああぁーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「行くよ～、先手必勝……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540031" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「くっ……！　いい勢いですね。ですが、私も負けてませんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540005" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あぐっ……！　お尻の力は互角といったところだね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540032" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「互いに尻を突き合わせ、押し合いを続けております！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「尻の肉がいやらしく形を崩すほどの力です！　これは両者一歩も譲らないと\nいった様子だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「つらいなら、ギブアップしていいんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「確かにこのまま押し合っていれば、体格的に先に力尽きるのはボクだけど…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540033" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「でも……相撲の勝ち方は、押し合うだけじゃないよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540034" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「なっ！？　いきなり尻を引くだなんて……！？　これじゃ、バランスが……\n！　きゃあああぁーーーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「決まったあああぁ！　急選手、突然ぶつかり合いをやめて、ピースムーン選\n手を手前に引き倒しました！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「自らが力を抜くことで押し合う力を利用し、相手を引き落とす見事な引き落\nとし……いえ、尻落としです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「相手の力を利用した、見事な戦法だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの判断が咄嗟に出来るのは、素直にすごいと思いますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540024" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「１回戦も最後の戦いとなりました！　Ｄブロック、破選手と兎子選手です！\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「尻合って！　のこったあああぁーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「うっ、あううぅ……！　相撲は得意じゃない上に、こんな水の上でなんて…\n…！　ち、力が入りません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふふふ、足が震えてますよー。この勝負、もらいました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540028" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「破選手！　兎子選手をジリジリと土俵際に押していきます！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あっ、やっ……！　もう、無理です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「武士の情けですー。せめて苦しまないように、落としてあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540029" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「兎子選手、なすすべもなく足場から落とされてしまいました！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これは文句のつけようのない寄り切り……いえ、尻切りです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「武士娘だけに、決まり手は尻切りってか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「破殿は狙ってやったわけではないと思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540025" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、勝ち上がった選手たちによる２回戦の開始です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「２回戦の第１試合は、序選手とディアナ選手との対決となります！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは……両者、尻合って、尻合ってぇ～……のこったあああぁーーーー\nー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「こ、これは……！　なんて弾力のお尻ですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540036" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それって、ディアナちゃんのお尻が大きいってことぉ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「別にそういう意味ではないです……！　ですが、これではどれだけ押しても\n勝てる気がしないですよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540037" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「序選手が懸命にディアナ選手の尻を攻めております！　いい突っ張り……い\nや、尻張りだぁ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「だがディアナ選手の弾力の前には、どんな攻撃も意味をなしていない！　こ\nの柔尻をどう攻略するのでしょうか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「正攻法がダメなら、絡め手勝負すればいいだけです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540038" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「おーーーっと！？　ここで序選手、尻張りをやめました！　どういうつもり\nなのでしょうか！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「なにをするつもりか知らないけど、今度はこっちから攻めさせてもらうわよ\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540009" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「今度はディアナ選手が序選手の尻を攻める！　自慢の柔尻による、波状攻撃\nだーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「さすがディアナさん……！　攻めも守りも完璧な、すごい弾力パワーです…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540039" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ですが、これはあくまでも相撲……！　手を使わないのでれば、問題ないの\nですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540040" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「こ、これは……！　序選手、自分の足を外側からディアナ選手の足に引っ掛\nけているーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「お覚悟ーーーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540041" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「イヤあああああぁ～～～～～ん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021540010" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「勝負ありいいいぃ！　片足でバランスを崩したディアナ選手！　そのまま落\nちてしまいましたーーー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これは見事な外掛け……いえ、尻掛けです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは足を使って勝ったんだから、外掛けでいいだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「尻相撲の決まり手にツッコむのは、野暮というモノですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540026" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「見事決勝に勝ち進んだ序選手！　その相手となるのは、いったいどちらなの\nか！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「負けないよ～。お姉ちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540035" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「まさか急と戦うことになるとは……けど、どっちが勝っても恨みっこなしだ\nよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540030" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「２回戦の第２試合、急選手と破選手！　尻合ってぇ……のこったあああぁー\nーーーー！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「とりゃあああぁ～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540036" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うぐっ……！　さすがの攻撃力……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540031" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ここは守りを固めることにしよっかなーっとぉ……不言実行・破！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540032" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「１回戦同様、先制攻撃をしかける急選手！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ですが破選手は攻撃をしっかりと受け止め、がっぷり四つと言った様子です\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「さすがお姉ちゃん。ボクの攻撃をこうも容易く受け止めるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540037" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ふふ～ん、姉というのは、妹を受け止めるだけの包容力があるものなのよー\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540033" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そうなんだ～。じゃあ、少しだけワガママなことするから、しっかり受け止\nめてね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540038" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「急選手が尻を離し、膝を曲げて体勢を低くしていく！　これはいったい、な\nにをしようというのでしょうか！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「いくよ～……不言実行・急！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540039" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「わっ、わわわっ！？　ちょ、ちょっと急！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540034" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「な、なんと！？　急選手が尻の力で破選手を持ち上げ、自分の腰に乗せてい\nます！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「小さな身体なのに、なんというパワーなのでしょうか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「とおおおおおぉ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540040" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「うわあああああぁ～～～～～！？」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540035" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そのまま破選手を投げ飛ばし、決着です！　これはいわゆる腰投げ……いえ\n、尻投げです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「急はああ見えて、一番パワーがあるからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの不安定な足場で相手を持ち上げるとは、大したものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540027" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さあ、尻相撲もいよいよ決勝戦！　注目の対戦カードは、若苗家三姉妹の長\n女である序選手と三女の急選手です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ともに白組なので白組にポイントが入るのは確定ですが、誰が一番強いのか\nを決めてもらいましょう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「さすがは急ですね。ですが、姉として負けるワケにはいきませんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540042" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「それはボクのセリフだよ。お姉ちゃんより強いってとこ、見せてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540041" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「両者、やる気十分といった様子です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「それでは、尻相撲決勝戦……尻合ってぇ～～～！　のこったあああぁ～～～\n～～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「最初から全力でいくよ……不言実行・急！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540042" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「いきなり強化ですか……！　なら、私だって……不言実行・序！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540043" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「果敢に尻を突き出して攻める急選手と、攻撃をかわす序選手！　開幕から激\nしい攻防が繰り広げられています！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「よけるなんてズルいよぉ～！　破お姉ちゃんはちゃんと受け止めてくれたの\nにぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540043" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あれは破の防御力があるからこそ出来る技です。私では一撃で落とされてし\nまうですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540044" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「でも破お姉ちゃんは、『お姉ちゃんっていうのは、妹を受け止めるだけの包\n容力がある』って言ってたよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540044" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「包容力ですか……ふふっ。破はそうかもしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540045" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「む～……！　じゃあ序お姉ちゃんの場合はどうなの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540045" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「私は破みたいな包容力はありませんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540046" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ですが、妹たちを背負うぐらいの力があります！　それを今から見せてあげ\nるですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540047" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ここで序選手、華麗な足さばきで急選手をいなし、懐に入り込んだーーーー\nー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「先ほどの急選手のように、尻投げを決めるということでしょうか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「妹の一人や二人背負えなくて、姉は名乗れないです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540048" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「えっ……！　ちょ……！？　か、身体が持ち上がってる……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540046" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「行きますよ、急！　これが私の……妹への愛ですーーーーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540049" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「わああああぁ～～～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540047" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「決まったあああああぁ！　序選手、見事急選手を背負い、綺麗な一本背負い\n……いえ、尻背負いを決めました！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これは文句のつけようがないぐらい、見事の決まり手……いや、決まり尻だ\nあああああぁ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "観客たち" ]},
		{"command":[ "SETTEXT", "「うおおおおおぉーーーーー！！　すげぇぞ、序ちゃんーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ぷはっ……！　さすがはお姉ちゃんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540048" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……姉として、妹に負けるワケにはいかないですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540050" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「水着コンテストに続いて、尻相撲でも美しい姉妹愛を見せてくれる若苗姉妹\nに、盛大な拍手をお願いします！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いい試合だったが……アナザーのヤツは、いつまで歌ってるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「観客の皆様も試合に集中しておられて、誰一人として見ておりませんでした\nな……嘆かわしいことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540028" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}