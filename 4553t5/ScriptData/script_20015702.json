{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……よし。その人気投票ってやつについては大体わかった」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前らは、そのイベントで各部門の１位をそれぞれ総ナメして、自分たちの\n知名度をあげたいってことだよな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……わかりやすくまとめると、そういうこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710001" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし。じゃ、さっそく１位を達成するための計画をはじめるか。となると…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まずはお前らのことをよく知らなきゃ話にならない。詳しく聞かせてもらっ\nていいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「いいぜ。んじゃあ、まず……最初はアレクト姉からか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710001" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……うん。わかりやすく上から順番にいこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710002" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「わ、わ、私からですか？　こほんっ……。え、ええと……私はですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710001" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「先ほどお話した通り、冥界の３姉妹、【エリニュス】の長女であり……冥府\nに漂う死者の魂を罰する役割を持つ者です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710002" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私は女神界隈ではとても肩身の狭い自分たち３姉妹を、もっともっと皆様に\n評価していただきたくて……そのことばかり考えております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほうほう。で、人気投票はどの部門を狙ってるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「私は、姉妹の中では正統派といいますか……。『ママにしたいキャラ部門』\nと『姉にしたいキャラ部門』を狙っていければと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710004" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど。年上系で攻めまくるっていうつもりなんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「はい……。ですが、すでにママや姉の要素を持つ者は、悪の女幹部にはたく\nさんいらっしゃるそうなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710005" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「まず、母親系って言ったら怪人のバニーママさんだろ？　ミセス・ウィドウ\nに血桜お七」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710002" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「牛神様にプルリー＝ヤンカシュ、人妻怪人たちに古賀道子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「そういう、いかにも慈愛に満ちた母親系もたくさんいるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710003" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「さらに最近は、……ママにしたいキャラの解釈もかなり広がっているようで\nして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710006" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っていうと？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「幼女にバブみを感じてママと呼びたい！　という勢力が強すぎて、需要がま\nったく読めなくなってしまったのですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー……！　ママ部門ってのはそういうのもアリなのか。そんじゃあ、ママ\nだからって熟女や年上キャラとは限らないわけで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これはちょっと、狙いがぼやける……。っつうかどっち方向を目指していい\nか見失って当然か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「……はい。もしママ部門を狙うことが難しいのであれば、姉部門に専念する\nことも考えてみたのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710008" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「姉というものの定義が、自分の中で、ママ部門と重なってしまいまして……\nこれもまた迷いに迷ってしまっていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710009" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姉……姉ったら年上なわけで、年上の包容力……ってなると、これはママ要\n素とかぶってるっちゃかぶってるしな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「リードしてくれる、引っ張ってくれる、甘やかしてくれる……ってのもママ\nと共通になっちまうのか。こりゃ難しいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……あたしの勝手なイメージだとよ？　ママっつうのはふんわ～りおっと～\nりで、姉がキリッと頼れるカンジなんだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710004" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ん～。私はそうは思わない。ママこそ強くて安心感があってどっしり安定し\nてる印象……逆に、姉はポンコツとかダメダメなのが可愛いと思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710004" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んなこと言ってたら、それこそ選択肢無限じゃねーか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710005" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「アレクト姉はバカ姉だけど……雰囲気は清楚だよね。となると……どっちだ\nろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710005" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「えっ？　今バカっておっしゃいました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710010" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んーんー、聞き間違いじゃない？　母にしても姉にしても最高だって言った\nだけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710006" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そ、そうなのですか？　それならとても嬉しいですけれども……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710011" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「姉キャラ……っていうと、ニャンコ先生や修羅姫……エファナティカに奈羅\n苦や十五夜まりあなんかがいる枠だよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710007" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「どう考えても超激戦区！　っつうか……。ハード系からソフト系まで、どん\nな性格でも出揃い終わってるんだよなァ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710006" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「うん。それだけじゃないよ。姉枠には……モイライシスターズのクロートー\nもいる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710008" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「っくぅ……！　ク、クロートーさん……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710012" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そう、ですわね……。彼女には、私とおなじく長女としての属性があります\nわよね。だからこそ、絶対に負けたくはありませんけれど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710013" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……うーん……。アレクトには、他の誰にもない強烈な個性みたいなものっ\nて何かないのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710014" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それがものすごく尖ったものなら、目立つことが出来るかもしれないだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「なるほど。考えたこともありませんでしたわ。強烈な個性……？　個性……\n。そういえば、１つ言い忘れていたのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710015" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「これは短所で長所にはなり得ないかもしれませんが、私は……呪いで殿方の\n名前と顔を、長時間記憶していることができないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710016" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「一時的に、ごく短い間でしたら覚えていられるのですが。一定期間ごとに、\nなぜか男性に関する記憶だけをなくしてしまうのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710017" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおいおい……！　つついてみたらとんでもねー個性が出てきたな！\n？」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つうか、まずはその呪いをなんとかしないことには、人気投票どころじゃな\nいんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「そうですわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710018" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……でも……。ものすごく……ポジティブに考えると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710009" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　何か名案でもあるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「えっちするとき、毎回記憶を失ってるから……無限に処女の雰囲気が楽しめ\nる、っていうのはかなりのウリじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710010" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「え、えっち……！？　そ、そんなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710019" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……や。悪くねえ考え方だぞ。別にエロいことじゃなくてもさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710007" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「何度も何度も新しく巡り合って、出会うたびにお互いに一目惚れする……と\nか超ロマンチックじゃねえか？　飽きがこないっつうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710008" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うーん……。毎回１からやり直しするのが、めんどくさいって気持ちの方が\n強いかもしれん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あぁ～？　そっか……。いい案だと思ったんだけどなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_010023710009" ]},
		{"command":[ "SETCHARA", "0", "char_00028601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「ただ、これも個性であることは確かですので……。少しお時間をくださいま\nすか？　なんとかこれをウリに出来ないか考えてみたくなりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710020" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。こっちも、いい案があったらすぐに言う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「なにとぞお願いいたしますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710021" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「それじゃ、アレクト姉が考えてる間に……カツマには私とポ姉の作戦から考\nえてもらおうかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_010023710011" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アレクト" ]},
		{"command":[ "SETTEXT", "「それが最善かと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_285_010023710022" ]},
		{"command":[ "SETCHARA", "0", "char_00028501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
