		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、なにが起こったのやら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115210001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
