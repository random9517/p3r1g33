	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「月龍剣！　遠点新月斬り！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ドラグソードの剣から放たれたビームが怪獣戦車を直撃！　怪獣戦車が爆発四\n散した！　その直後――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113380001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「あああああああーっ！　せっかく作ったのにーーーーっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なぜか仮想空間が校庭の一角に代わり、爆発音とともに変な声が聞こえてくる\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「なに？　今の声」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "そのころ、シミュレーションマシンの前では……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おー！　ははははははっ！　いいもの見つけたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「なになに？　なにを見つけたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「怪獣戦車のデータ痕跡を追ってたんだ。そしたらあいつが撃破された瞬間、\n戦車を操ってた連中との信号を拾った！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113380002" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「じゃ、いま、画面にちらっと映ったのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そうそう！　データが混信して、あっちの様子が映っちゃったのさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113380003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「つまり襲来者（インベーダー）は、校庭にいるってことですね！？　そこで\n怪獣戦車を操っていたと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そうとわかれば！　みんな、行くわよっ！　襲来者（インベーダー）は、私\nが倒ーすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113380002" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0150" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）はどこですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「あ！　襲来者（インベーダー）みーっけ！　あたしのオモチャにしていいの\nよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そうじゃないでしょ！　あいつらぜーんぶ、私が倒すの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「くそっ！　見つかったか！　撃て撃て！　迎撃せよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「無駄な抵抗は不運のもと……フフフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お！　始まってるな！　私たちも加勢するぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんなの楽しみぶち壊す、襲来者（インベーダー）は許せねえ！　インクレ\nディブル・スクワッド！　突撃だーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうでもいいですがご主人、まるでヒーローみたいなセリフですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}