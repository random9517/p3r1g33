		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ……また、イクっ……は……ひぁっ……オマンコ……痺れて……あひ\nっ……イ、イクっ……！」", "NORMAL" ]},
