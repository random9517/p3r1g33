		{"command":[ "PLAYVOICE", "v2_220_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁ……は、はい……あなたのオチンポが……今、全部……みっ\nちりとオマンコに埋め込まれてしまっています……」", "NORMAL" ]},
