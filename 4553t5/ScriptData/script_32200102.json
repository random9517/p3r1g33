		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁんっ……止まらないっ……ダメっ、おっぱい揺らしてるところぉっ……\nあぁ、恥ずかしいのにぃっ、跳ねちゃい……ますぅっ！」", "NORMAL" ]},
