		{"command":[ "SETIMAGE", "0", "still_00022001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ……中がドロドロのまま……腰を突き出すなんて……んふっ\n、こ、こんな感じ……でしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104204" ]},
		{"command":[ "WAITINPUT" ]},

