		{"command":[ "PLAYVOICE", "v2_220_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、そんなっ……恥ずかしい音っ……鳴らすなんて……あぁっ、\nそうですっ……こ、この音はぁ……私のオマンコから出てる音ぉっ……」", "NORMAL" ]},
