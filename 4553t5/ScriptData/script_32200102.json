		{"command":[ "SETIMAGE", "0", "still_00022001_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んっ……くっ……あぁ……太くて、硬い……内側から押し広げられて……少\nし、キツいです……んくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あ、あの……それで……動かないのでしょうか……？　い、いえ……その…\n…待ちきれないということでは……ゆっくり、お、お願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、はっ、あっ、あぁっ……はっ、んくっ……あふっ、あっ、はっ、ん\nぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ……始まりました……ピストン、運動……私のオマンコの中を……太\nいオチンポが……出たり……入ったりして、います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「こ、こんな説明をしないとダメなのですか……これは、恥ずかしいです……\nあっ、んくぅっ……分かっています、お、お仕置きなんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んんっ、濡れ濡れになった……オ、オマンコ……何度も、擦り上げられてぇ\n……はしたない音が……して、しまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぅぅぅんっ！　あっ、そこは……おっぱい……あっ、許してください……\nはぁんっ、ぎゅってされたらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あはぅっ……あぁっ、荒々しい……こんな風にされることなんて……全然な\nいのにっ……あぁっ、どうして、身体……熱くなってしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「ひぁっ！　あっ、んぁぁぁんっ！　ああっ、また……オチンポっ……そんな\nにグッと押し込まれたらぁっ……あっ、はぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「んぁっ……ち、違います……今の声は……そのちょっと驚いてしまっただけ\nで……気持ちよかった訳では……あ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
