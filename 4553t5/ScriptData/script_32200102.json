		{"command":[ "PLAYVOICE", "v2_220_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「もっと、お腹に力を込めて……こ、こうでしょうか……あっ、あぁっ……オ\nマンコ……締め付けると……オチンポ……中で膨らんで行きます……んくぅぅ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、はぁぁっ……くぅ……んっ、あぁっ、でも、こんな……一度射\n精なさってるのに……オチンポ、益々逞しくなるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ、すごい……お腹の中……いっぱいにされていく感じ……んくぅぅ…\n…たまらない……もっと、していきます……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あはぁっ、ひっ……あひっ、はいっ、あぁ……オチンポのピストンに、合わ\nせて行きますっ……んっ、んくっ、あぉっ、くぅうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「そんな、あぁ……いやらしい顔だなんて……ダメです……覗き込まないで…\n…恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ、こんなおばさんの顔を……魅力的なんて……からかわないで……あ\nっ、あぁっ、おっぱいも揉んじゃだめぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「どうして……あぁ、私、こんなにいやらしかったなんて……あなたのオチン\nポで……はぁうんっ……骨抜きにされていってる……あ、はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はいっ……くぅんっ、感じますっ……！　いっぱいオチンポされてっ……オ\nマンコ気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「あぁっ、もっと腰を振りますからっ……！　突いてっ、太いのっ……もっと\nかき回してくださいっ！　奥っ……オチンポでごりゅって来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_220_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バニーママ" ]},
		{"command":[ "SETTEXT", "「はぁぁっ……あなたごめんなさいっ……私は……いけない女ですっ……夫以\n外のオチンポがっ、こんなに気持ちいいのぉっ、あっ、あはぁんっ！」", "NORMAL" ]},
