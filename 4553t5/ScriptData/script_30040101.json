		{"command":[ "PLAYVOICE", "004_0103401" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぷぅうっ！？　ぷぁっ、また、顔に、うぷっ、熱くてドロドロの汁が……\nんぶぁっ、口に入るっ……！」", "NORMAL" ]},
