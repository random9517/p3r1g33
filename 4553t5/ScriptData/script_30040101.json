		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103302" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「熱くてドロドロのが、あんんっ、んんっ、おっぱいの上に、びちゃびちゃか\nかってるぅ、んふぅぅ～～……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103303" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んあぁ……チンチンの割れ目が、パクパク開いたり閉じたりしてぇ、あうん\nっ、白い液体を、ドプドプ、吐き出してるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103304" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいの間で、チンチンがびくびく震えてる……んふぅ、いいぞ、もっと\n出して……んぁ、あぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103305" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンをおっぱいで挟んで、んふぅ、シゴいてやる……ほら、ほら……私\nが全部、搾り取ってやるからな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103306" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わっ、また出てきた……おっぱいでシゴくたんびに、びゅ、びゅって……あ\nははっ、面白いな。ほら、もっとだ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103307" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「まだまだ、根性を出せ……！　あんっ、そうそう、気合を入れて、もっと白\nいやつを出せよ……んっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103308" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……ふぅ。……うわ、すごい量が出たな。私のおっぱいをこんなにドロドロ\nにして……でも、それだけ気持ちよかったってことだな！　ふっふ～ん♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103309" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んん？　でも、チンチンはまだカチカチに固いままだぞ。どれだけコってる\nんだよお前……！　まったく、しょうがないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103310" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほら、もっと出せ。チンチンが柔らかくなってもう白いのが出なくなるまで\n、私がしてやるぞ。遠慮するな。行くぞっ、そらそら～！」", "NORMAL" ]},
