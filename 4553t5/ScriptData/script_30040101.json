		{"command":[ "PLAYVOICE", "004_0103409" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そ、そのかわり、ほら……私がしてやったんだから……次は、お前の番だろ\n……？」", "NORMAL" ]},
