{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "004_0103101" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おい、来てやったぞ？　まったく、弱っちいくせにこのセレーナ様をこんな\nところに呼び出すなんて……生意気だぞ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103102" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お前とちがって、私は忙しいんだからな。え？　何がって、そりゃあ昼寝と\nか、肉まんの食べ歩きとか、あ、撮りためた特撮番組も観ないと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103103" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「どうだ、やることがいっぱいだろ？　だからほら、さっさと用事を言えよ。\nつまんないことだったら、新技の練習台でサンドバッグにしてやるからな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103104" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……マッサージ？　それって、いつもお前がしてくれるやつか？　なんだ、\n先に言えよ～。アレ、気持ちよくて好きなんだよな～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103105" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ？　ちがうのか？　じゃあなんだよ……はぁ？　私がお前にマッサージを\nするのか？　ヤダよ、めんどくさい。だいたい、なんで私が……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103106" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「う、確かに……いつもは私がマッサージしてもらってるわけだし……最近は\n美味いもんも食わせてもらってるし……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103107" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「恩と仇は倍返しだって、じっちゃんも言ってるもんな……よし、わかった。\nやってやるよ、マッサージ。ありがたく思えよ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103108" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それで、どこをヤればいいんだ？　肩か？　腰か？　いつもじっちゃんばっ\nちゃんにもやってるからな、実は得意なんだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103109" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ？　普通じゃない特別なマッサージ？　……天性の素質が必要だから、\n私くらいじゃないとできないマッサージなのか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103110" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へっへ～ん、しょうがないなぁ～。よし、任せておけ！　この天才の中の天\n才、セレーナ様がお前を極悪焦土？　ってやつに連れてってやるよ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103111" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ん、と……これでいいのか？　チンチンが凝るなんて、変なヤツだなぁ。じ\nっちゃんはそんなこと一度も言ってなかったんだけどなぁ～……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},		
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103112" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいで挟んでマッサージってのもわけがわからないし……だいたいこの\n格好、胸が丸見えでちょっと恥ずかしいぞ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103113" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こんなのでちゃんと気持ちいいのか？　むにゅむにゅするだけで、全然力が\n入らないし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103114" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうだ！　どうせなら、チンチンの両側から拳でグリグリやってやるよ！　\n肘でもいいぞ！　肩とか腰とかにはこれが一番効くらしいからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103115" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……なんだよ、そんなにイヤがることないだろ。失礼なヤツだなぁ……じゃ\nあ、どうすればいいんだよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103116" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おっぱいを押し付けるように挟んで、上下に擦ればいいのか？　ん、ほ、よ\nっ、と……どうだ？　こんな感じか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103117" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おぉ？　チンチンがぴくぴくしてるぞ？　おっぱいで擦るたんびにびくびく\n震えてる。気持ちいいのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103118" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あははっ！　ただでさえだらしないお前の顔が、ますますだらしなくなって\nるぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103119" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「少し、楽しくなってきたぞ。いつもは私がされるばっかりだったからな～。\nよーし、ヤるからには本気でヤってやる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103120" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「今日はお前のチンチンを、私のおっぱいでとことん気持ちよくしてやるから\nな。覚悟しろよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103121" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「とにかく、んっ、こんなふにチンチンを擦ればいいんだろ？　むにゅーって\nおっぱいで挟んだまま、上下にゴシゴシ、ゴシゴシ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103122" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぉ？　ここのでっぱりが気持ちいいのか？　先っぽのふくらんだとこのま\nわりの……へへー、そうなんだろ？　ほら、うりうり～、どうだ～？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103123" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それに、ここの裏側のところも、んぁ、好きなんだな？　おっぱいの先端で\n上下に擦ると、んぁ、んっ、情けない顔になってるぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103124" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、チンチンの先っぽから、なんか出てきたぞ……ふぅ……透明で、ぬる\nぬるの汁があふれてきてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103125" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「これって、アレだろ、んっ、気持ちよくなると、出てくるヤツだろ？　ふふ\nん、知ってるんだからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103126" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私も、お前にマッサージされる時は、んぁ、アソコから、透明な汁が、ぁふ\n、たくさん出てくるからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103127" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「先走り汁、カウパーって言うのか？　んっ、なんていうか不思議だよなぁ、\nんぁ、なんでこんなヌルヌルしたのが、出るんだろうな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103128" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わ、すごいぞ、チンチンの割れ目がパクパクして、汁がたくさん……先っぽ\nの亀頭ってとこも風船みたいにパンパンになってきた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103129" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「出る？　もしかして、私のおっぱいマッサージでイきそうになってるってこ\nとか？　ふっふーん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103130" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いいぞ、イって！　んっ、私がマッサージされた時みたいに、んぁ、絞め技\nキメられたみたいになって、頭真っ白になって、イけ……ほら、イけ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103131" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわあぁああっ！？　な、なにっ！？　わぶっ！　んっ、んぶっ、ぷあっ、\nなんか、いっぱい出て、んぶっ、うぅっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_05" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103132" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「白くてネバネバした汁がたくさん、んぶぁっ、おっぱいや顔にかかって……\nんぶぅえっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103133" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うえっ、ぺっ、ぺっ、うぇぇ、飛んできたのが、口の中にまで入ってきて…\n…うぅ、思わず飲んじゃった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103134" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ねちゃねちゃして、青臭いような変な味がするぅ……あ、でも、意外とマズ\nくはないかも……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103135" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うぁっ、まだ出てる……チンチンがビクビクするたんびに、先っぽからびゅ\nるっ、びゅるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103136" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「まったく、出すなら出すって、ちゃんと言えよな。お前の白い変な液体で、\n私の顔からおっぱいまで、ドロドロになっちゃたぞ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103137" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「……まぁ、いいけどさ。私もお前にされる時は、その、いっぱい出ちゃうし\n……それに、ちょっと気分いいしな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103138" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いっぱい出たってことは、それだけ私のおっぱいマッサージが気持ちよかっ\nたってことだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103139" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いつもお前にされてばっかりだし、たまには私がするってのも悪くない\nな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103140" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「それに、こんだけたくさん出させたってことは、私の勝ちってことだからな\n！　ふふん♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103201" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ、チンチンまだ固いままだぞ？　もしかして、まだコってるの\nか？　しょうがないなぁ～……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103202" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「よし、いいぞ。私がもっとしてやる。お前のチンチンをおっぱいでマッサー\nジして、コリをほぐしてやるよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103203" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「よっ、と……んっ、さっきお前が出した変な汁のお陰で、んっ、ヌチュヌチ\nュになって、だいぶ動かしやすくなってるな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103204" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほら、どうだ……？　こうやってキツイくらいにギュウギュウに挟まれなが\nら、上下にシゴかれるのが好きなんだろ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103205" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルになったおっぱいの中に、んふっ、チンチンの先っぽを包み込んで\n、んぁっ、ぐにゅぐにゅしたり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103206" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「裏側のところに下から上までおっぱいをおしつけて、んぁ、ぬりゅぬりゅ擦\nりつけたりしたら、んふぁ、気持ちいいんだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103207" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンがさっきよりも固くなって、んふっ、先っぽから透明な汁がいっぱ\nい出てきたぞ？　ん、チンチン気持ちいいんだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103208" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふっふーん、んっ、セレーナ様の目には、全部お見通しなんだぜ……ぁんっ\n、どうだ、参ったかぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103209" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「私の天才的なおっぱいで、ぁふっ、ガチガチに凝ったチンチンの気持ちいい\nところを、た～っぷり擦ってやるからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103210" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だから、さっさとイっちゃえよ、んぁ、チンチンの先っぽから白くて臭い汁\nをびゅーびゅ出して、気持ちよくなれよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103211" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……！　くぅ、チンチンの凸凹がおっぱいの変なところを擦って…\n…くふぅっ、私まで気持ちよくなる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103212" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンでおっぱいがマッサージされてるみたいな……くぅぅ、でも、負け\nないからな……！　ぁふっ……勝つのは私だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103213" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おらおら、これでどうだ！　ムリしてないで、さっさとイっちゃえ！　んぅ\nっ、チンチンから白いの出せよっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103214" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、強情なチンチンめぇ、んぅぅっ、てい、やぁっ、んぅぅっ、早く\n諦めろよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103215" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こうなったら、本気をみせてやるからな、んぁっ、チンチンをシゴくペース\nを上げるからな、あぅんっ、ついて来られるか！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000401_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103216" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ほら、どうだ、ぁふっ、私の鍛え抜かれたおっぱいに激しくシゴかれて、く\nふぅっ、気持ちいいだろ？　もうイっちゃいそうだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103217" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「この、このぉっ、んぁぁ、さっさとイっちゃえよ、んふっ、ちんちんシゴか\nれて、白い汁をびゅーびゅー出しちゃえよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103218" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンの先っぽが情けなくパクパクしてるぞ、あははっ、お前の顔と同じ\nだ、真っ赤な風船みたいになって、すぐにも弾けそうだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103219" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「この最強のセレーナ様にかかれば、んぁっ、弱っちいお前のチンチンをイか\nせるなんて、んくっ、朝飯前のオヤツ前なんだからな……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103220" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「イけ、イっちゃえ、私の最強おっぱいにヌルヌル擦られて、んぁっ、お前と\n同じ雑魚チンチンをぴくぴくさせながら、白いの出せぇっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "004_0103301" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ふぁあああ～～～っ！！　あっ、あぁっ、出てる、変な白いのがまた、んあ\nぁっ、私のおっぱいに、出てるぅっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
