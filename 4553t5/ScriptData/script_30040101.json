		{"command":[ "PLAYVOICE", "004_0103402" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あぷっ、まだ、どんどん出てっ……んぶぁっ、だから、顔はやめろって……\nあぶぅっ、また口にぃっ……んぶうぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103403" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ……んぐぐっ、くっ、んくっ……ぷぁっ、うえぇぇっ、飲んじ\nゃった……お前の出した変な汁をいっぱい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103404" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「口の中がベタベタ貼りついて……んくっ、舌にもからみついてるし、んんっ\n……くっ、喉にも引っかかって、うまく飲み込めないぞっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103405" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぅぅぅ、変な味だ……苦いようなしょっぱいような……全然美味しくない\nのに、んぅ、でも、どこかクセになるような……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103406" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「生臭くて青臭いニオイも口の中に染み付いたみたいに取れなくて、げぷっ、\nうぅぅ、身体の中までお前のニオイになっちゃってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103407" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くうぅ……クサくてマズいはずなのに……ふぁぅぅ……頭がクラクラして…\n…身体が熱くなってくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "004_0103408" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「も、もう、いいだろ……！　マッサージはおしまいだ！　おわりおわり！」", "NORMAL" ]},
