{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「フフフッ♪　まさか、多忙なキミが……ボクの誘いにのこのこ付いてくるな\nんて思わなかったなぁ♪　今日は、そういう気分だったとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00023102_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「とりあえず、行きたいところには全部行けたし。ここからは……、あ、そう\nだ。１つ勝負をしようよ。コイントスをして表か裏かで勝敗を決めるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……賭けるモノは何にするかって？　フフ……決まっているだろ？　今日の\nエッチ……セックスの主導権だよ。キミもそろそろシたくなってきたろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00023102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だから……どっちが攻めるかをこのコインに決めてもらうんだ。いくよ？　\n３、２、１……それっ！　さぁて……お楽しみの結果は……？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00023102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まいったなぁ……。まさか、キミの勝ちだなんて……。まぁいいよ、勝負は\n時の運だし。ただ……こんな開けた場所でするとは想定してなかったかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00023102_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミってば、おとなしい顔して相当なヘンタイだな……。野外公園だなんて\n、ここを散歩コースにしている人もいるだろうに……はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いつ、誰に見つかるかもわからないんだよ？　どんな風に思われることか…\n…。でも……露出プレイがお望みならば、言うことを聞くしかないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクは……負けたんだから。そ、そりゃあ……気にはなるよ。誰かに知られ\nたらと思うと……。んッ、若干緊張するし、ポーズもポーズだし……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「淫乱な痴女だと思われてしまうからね……。っふ……♪　道化の上に淫売だ\nなんて、どうしようもない女だと思われたら……。はぁ、はぁ……あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「も、もう御託はいいから早くはじめてくれっ……。時間がかかればかかるほ\nど、人に見つかる確率も上がるんだから！　はやく……触って……そう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あッ♪　そう、そうだよ……っ。おっぱい……ボクのおっぱいを、その手で\nこねまわしながら……。あぁっ、オチンポ、チンポをこすりつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「素股状態で……クチュクチュしながら、んッ……肌という肌をなぞって、ま\nさぐって、とろけさせてくれ……。あ……っ、あ、はぁっ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「風が吹くたびに……とんでもない場所でいやらしいことをしているっていう\n実感が湧いてくる……。いいのかな？　こんな公共の場で、シちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ……。そ、そうだよ。もう止まれない。やめたりなんかできないけど…\n…。あッ♪　お子様たちの教育にも良くないよねって♪　あっ、ぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「何？　なんか、今日の触り方めちゃくちゃヤラしいんだけど……っ！　あっ\n、あっ……ヤバい、おまんこがヌルヌルになってきちゃったよ……ぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……これだけ密着して粘膜を重ね合わせているんだ、もうわかって\nいるだろう？　愛液が止まらなくて……おまんこがウズウズしっぱなしだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それっ……それ、挿入てくれないか？　チンポっ……すごく大きいし、硬く\nて美味しそうだ……。欲しい、そのまま突き上げて、ねじこんでぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミのそのすごい肉棒で、ボクをめちゃくちゃにしてよ……っ！　あっ……\n♪　ねぇ……なんでもするからぁ、絶対気持ち良くするし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キツキツでにゅるにゅるの器用なオマンコでいくらでもオチンポ絞って甘や\nかしてあげるから……早くきて♪　うん、胸を揉みながら……そう、そう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「は、ぁああああああ……♪　太ぉおおお……♪　あッんぐっ♪　この体勢…\n…！　ボクの全体重がかかって、オチンポに突き刺さって……ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いつもより深く刺さってるぅ♪　あっ、はぁっ、ヤバッ、なにこれ……っ♪\n　あひっ……ひぃっ、すっごくイイっ！　イイよっ、最高……気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ええええっ！？　こんなッ……こんなにはっきりオチンポの形が、熱さが感\nじ取れるなんて……あっ♪　スゴいな、野外エッチって……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「外の涼しさのせい？　ボクが興奮して火照ってるせい？　オチンポの存在を\nはっきり粘膜で感じるんだ……あぁっ、マズいよ……絶対マズいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「感じまくってしまっているぅ……！　あっ、あッ♪　外で生オチンポハメら\nれて……主導権握られて、ボク……ボク、おかしくなるくらい感じてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ……あっ♪　あっ、はぁっ、はぁっ……はぁ、はぁ……！　ダメだ、我\nを忘れちゃ……あぁっ！　ダメ、だめ、だめなのに……うぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ！？　おしっこ漏れちゃっ……ああああああっ！　ゴメンッ……ごめん\n！　興奮しすぎて嬉ションしちゃった、あっ……こんな……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ジョボジョボ出ちゃってる……！　は、恥ずかしいよ……！　やっ……止め\nられない、うそみたいにたくさん出てる……ボクの、ボクのおしっこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミに見られて……うぁああ♪　あぁ、ああ、そうだ……そうだよ！　ボク\nは……ボクは、露出プレイに興奮してしまうドマゾだ、ドＭだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だからもっとイジめてほしいっ……！　あっ、あぁ……！　突いて、とろと\nろに蕩けた膣襞を思いっきり突いてかき混ぜて……意地悪されたいよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おね、がい……お願いだから！　この逞しいオチンポでボクをイジメてぇえ\n……♪　あぁっ！？　はぁっ、あふぅっ、ふぅうっ、激しく突いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっんんっ！　奥っ……奥、一番奥……！　一番感じる敏感な場所、ボクの\n弱点にオチンポをぐりぐりねじ入れてよぉ……！　あ、あ、あ、あぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぷしゅっ、ぷしゅっておしっこ……！　残りも全部漏らしちゃって……はぅ\nうっ！　愛液も、ぶしゅぶしゅ噴き出しちゃって……だらしなさすぎるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの下半身、もう大洪水だよぉ……！　色んなお汁でヌラヌラのぐっちゅ\nぐちゅで……あっ、あっ、卑猥すぎる、本能に従いすぎている……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの下半身、もう大洪水だよぉ……！　色んなお汁でヌラヌラのぐっちゅ\nぐちゅで……あっ、あぁ、卑猥すぎる、本能に従いすぎている……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あッ♪　あぁあああ……！　ねえ！　ボク、おっぱいぶるんぶるん揺らしな\nがらおねだりするから……ここに、この穴に精子注ぎ込んでほしいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「これだけ色んな体液で濡れているんだから、もう遠慮することないから……\nっ！　精子、精子中出しして……精子ぃ、ここにちょうだいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はっ♪　う……っ♪　ああああ……！　びゅるっびゅるっ！　びゅるっびゅ\nる……！　あり、がとう……っ、ありがとう、出てる、出てるよ精液ぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのおまんこの中……いっぱいに満たされてく、真っ白な精液がぶびゅぶ\nびゅかかってる……！　あぅっああ……最高に気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うんっ！　一番奥……一番奥、子宮口にあてながら出して……！　ああっ…\n…！　すっご……、子宮に直接ドクドク注がれて……ボク♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こんなの絶頂しないわけない♪　は、ぁああああ……♪　イクっ……イク♪\n　おもらしキメた直後に、中出し射精されて絶頂ぉおお……たまんないよぉ♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あうっ♪　あふ、あっあっあっ……！　……ぅ……♪　嘘だろぉ？　キミの\nオチンポ……これだけ出して、まだ硬いまま……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それ、どころか……。ああああっ♪　むしろ巨大化して、ボクのお腹を内側\nからえぐってくる……！　とんっでもないエロチンポ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……もちろん、まだ続けてするよね？　ここでやめるなんてありえないよね\n？　ね～え……抜かないで、もっとボクを感じさせてよぉ……♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「嫌だって言われたって、やめてあげないし……勝手に絞り取らせてもらうけ\nどね♪　んっ……んん♪　おまんこ、キュウキュウ締めつけてくるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ボク、ヒダヒダも自由に動かせるんだぁ……。それ♪　それ……\n♪　あっ♪　ど～お……？　気持ち良くって抜けないでしょお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そしたらしようよ、二回戦♪　はぁっ♪　ボク、キミがもっと欲しい……。\nあっ♪　全身ガクガクするまで揺らして、突いて突いてぇ……♪　あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはぁ♪　荒々しい……！　男らしいピストンみせてくれるじゃんかぁあ…\n…っ♪　あうっ♪　あふっ♪　いいよ……イイっ、すごくイイ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ、あぁんんっ……♪　このボクを……っああっ♪　メスに\nして、甘い声でよがらせるなんてキミはとてつもないテクニシャンだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　はぁあっ、あぁ……！　オナホみたいに、道具みたいにむちゃく\nちゃに突いてよ……っ！　あっ！　ひどくされると感じるんだ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポ、の事しか考えられなくなるくらい……♪　入れて、出して、入れて\n、出して……んんんん、限界まで引き抜いてぇ……一気に突っ込んで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぁはああああああ♪　面白いくらいにイキまくってるっ……おまんこっ、\nおまんこ痙攣して、イクのがやめらんない……！　これっ、すごいよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっあっ♪　ボク……ボク、キミのオチンポから精液を吸い上げるだけの卑\n猥なオモチャになっちゃってる♪　あぅ……！　あう、あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「気持ち、いい……気持ちいい！　ユサユサ揺らされるたびに、オチンポズプ\nズプ動いて……オマンコがめくれてる、なんて力強い男根なんだ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あぁっ！　あっあっあっ！　やわらかいオマンコ粘膜に叩きつけられる、硬\nくて太い傲慢なオチンポ……！　いい、いい、興奮する……興奮するぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おまんこ、きゅうきゅう収縮して……！　うねってすごぉく喜んでる……！\n　あぁッ……！　脳天がシビレるようなこの快感……あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「永遠に！　浸っていたい……っ！　あぁ♪　いけないことなのに♪　ここは\nみんなの公園なのに……っ、誰かが来るかもしれないのにぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そう想像すればするほど……おまんこが悦んじゃって、感じるんだよぉ……\n！　あぁ……ッ♪　あぁ、あああ……！　キミ、キミ、キミぃぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミだけだっ……♪　ボクをここまで乱すことが出来る存在は！　あぁっ、\nボクの、おまんこにいつでも好きなだけ精液を注ぎ込んでいいよ……ぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ううん、注いでほしい……♪　全人類に見せつけるみたいに！　お外でボク\nに種付けしてよ！　避妊なんかするもんか、生の精子が欲しいんだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぅああああ……♪　精子、精子ぃ……！　強いチンポから無慈悲に放たれ\nる子種……！　ボクをキミのモノにして♪　出して……出してぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぅううっ！？　あぅあああああ……ッ♪　あふっ、んふぅううう♪　あぁ\nあああああ……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「感謝っ……感謝するよっ！　キミぃっ……！　あっぁっあっ！　膣内に出て\nるの、わかる……わかるぅ♪　二度目も種付けしてくれたんだねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはっ……いいよ、受精したげる……♪　ボクの全部、キミに捧げるぅ……\n♪　そのまま、そのまま子宮をキミのザーメンまみれにしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あふっ……♪　あぁ……うぁああ……♪　オチンポビクビク震えて……あう\nっ♪　もうダメ、これ以上気持ち良くなったら死んじゃうよぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんんん……♪　あっつい精液……腹に溜まって……♪　んんんっ、うれ…\n…しい、これ全部、ぜーんぶボクがもらっていいんだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁ、はぁあああ……♪　スゴかったぁあ……。気持ち良か\nったぁ……♪　なんかもう、なにもかも解放させられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おしっこも愛液も精液も、いっしょくたになってどうでもよくなっちゃうカ\nンジ……。これはさすがに、ボクといえども初体験の衝撃だったよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……まだ身体が熱い……。うっとりするような快感の余韻で、頭\nがフラフラする……♪　キミって……もしかしてボクに隠していただけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「世界一のセックスの天才だったとか、そういうオチがあるの？　じゃなきゃ\n……ここまで狂わされるイミがわかんないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ホント……ボクみたいなのまで夢中にさせて。とんでもない男だね。これで\nもう、キミから離れられなくなっちゃったじゃんかぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　えっ、あっ……！？　そっち！？　ボクをキミのモノにするっ\nて……全身にぶっかけて、マーキングするって感じ！？　そっちなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「うぁっ……♪　じょ、冗談だろ……！　どんな量ぶっかけてるんだよぉ……\n！　ああああッ……！　ボクは、ボクは便器じゃないぞぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁっ、うううう……！　ドロドロの精液がこれでもかと身体にかかって…\n…。うんっ、わかってるよ、キミの精液がスゴいのはわかってるってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「わかってるのに……こんなドピュドピュと……！　ふぁああっ！　こらっ…\n…イタズラするなぁ！　あっ！　とれなくなっちゃうだろうっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……そりゃああったかくて、気持ち良くて……満足だけど……。ふぅうっ♪\n　ボクは二度目もおまんこにくれるって期待してたのに……うううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それも含めて、主導権の主張だって言うなら……しょうがないけどさぁ……\n。あーぁ……、この量。膣内に出てたら絶対妊娠出来たのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「でも……。ごくっ。ここまで巻き散らかされている様は……、結構見ごたえ\nあるね。へぇ……こんなに出したんだ。ドロッドロの重たい精液……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの肌にびっちりこびりついて、……はぁっ、存在を主張してる……♪　\nはぁっ、なんだか、可愛く思えてきたかも……。んっ……よしよぉし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなに、ボクのいやらしい身体が好きなのかい？　フフフッ……ボクもキ\nミたちが好きだよ♪　今度はちゃんとおまんこにおいでねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクならいつでも大歓迎だからさぁ……♪　なんちゃって……。はぁ、はぁ\n……。次が楽しみになるくらい、上質な精液をありがとう……♪」", "NORMAL" ]},
