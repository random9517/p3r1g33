		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うっさーい！　おまえらこそ、次から次へと出てくるんじゃなーーーいっ！\n」", "NORMAL" ]},
