		{"command":[ "SETNAME", "襲来者たち" ]},
		{"command":[ "SETTEXT", "「うぎゃーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「まったくもう！　いいかげんにしろよな！？　この列車、いったい何人襲来\n者（インベーダー）が乗ってるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったくだよ！　次から次へと……こいつらいったい、どこから出てくるん\nだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「アルルカン、わかっちゃったんだけど～？　襲来者（インベーダー）たちっ\nて、みーんな前の車両から来てるよね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「つまり、どんどん前の車両に進んで、先頭まで行けば、襲来者（インベーダ\nー）ちゃんを止められる、っていうこと～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「そういうことなんじゃないの～？　キャハハハッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やってみる価値はありそうだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よし！　そうと決まれば、先頭車両の運転席に殴り込みだ！　車内をやつら\nの終着駅にしてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「そういうことなら、バット持ってくればよかったかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なんで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「列車内の戦闘ってさ～？　バットが役に立ちそうなイメージあるっしょ～？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんわかんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そういうことなら私は、両腕にテーピングしとこうかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114390003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それもわかんない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114390004" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「この間、みんなでそういう映画を観たの。私は、網棚を這っていくべきかも\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114390001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああ、みんなで映画に……って、ちょっと！　なんでダイヤナちゃん誘って\nくんなかったわけ～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114390005" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「映画の話はいいから、さっさと行かないかい！　それと！　なんであたしも\n誘わなかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114390002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
