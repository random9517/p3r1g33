{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "061_0104101" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ここに呼ぶってことは……その、そーゆーことっスよね？　んぅ、仕方ない\nっスね。命令、なんでしょ？　……え？　自分の自由意思っスか？」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00006101_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104102" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そんなこと言うなんて……た、隊長はさ、ちょっと……卑怯っスよ。意地悪\nでズルいっスよ。……嫌いっス。……いや、それは嘘。……大好きっス」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104103" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「うん、隊長のこと大好きだから……だからします。言われたこと、するっス\n。……えっとぉ、隊長……自分のこと、お膝に乗せてもらえますか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104104" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ん、エヘヘ。……そんな、おいでとか言われたら……なんか、照れるっスね\n。顔赤くなっちゃった。じゃあ、お言葉に甘えて……失礼しまーす」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104105" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んぁ……な、何なんスかぁ。いきなりおっぱい揉むなんて、ううぅ……。や\n、やだぁ。そんな思いっきり揉まれると、んふぅ……恥ずかしいよぉ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104106" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、隊長の指が……おっぱいに食い込んで……んぅ、そんなことして楽\nしいんスか？　……あ、楽しいんだ？　じゃあ仕方ないっスね……くぅん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104107" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁぁん、ああぁ……そんな、くぅん……乳輪を指でくるくるするの、はぁ\n……駄目ぇ……。ぞ、ゾクゾクするんっス。乳首弄られるとぉ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104108" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひゃぁん！　ち、乳首ぃ！　あはぁ！　乳輪を、丁寧に丁寧になでなでされ\nた後、乳首触られたらぁ……おほぉ！　か、身体に電気走るぅぅうぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104109" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んおおぉぉおぉ！　乳首ぃぃぃいぃぃ！　あ、あはぁ……なでなでだけじゃ\nなくて、コリコリまでぇ……！　んふぅ、乳首、すっごい敏感になってる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104110" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひいいいぃい！　駄目ぇ！　駄目っス！　敏感乳首、つねっちゃ駄目ぇ！　\nい、痛いんじゃなくて……気持ち、良すぎるんっスよぉ。……もぉ許してぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104111" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「だ、だって……乳首弄りされてるだけなのに……もぉ、ううぅ……触られて\nないオマンコがぁ……ジンジン痺れてるんっス。隊長、どうしよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104112" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んぅぅうぅ……やだぁ。乳首弄られて、オマンコ濡れるぅ……。は、恥ずか\nしいし……じれったい。隊長、もぉ……やだなぁ。言わせる気っスかぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104113" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「やっぱ、意地悪っスね、隊長……。だから、その……隊長がおっぱい揉むか\nら、オマンコが……疼いて……挿れて、欲しいんっス。……分かるっしょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104114" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「だ、だから、その……隊長の、オチンチンっスよぉ。オチンチンを、自分の\nオマンコに……ずっぷり挿れてほしいんっス。掻き回してほしいんっスよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104115" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「言ったからぁ……挿れて？　隊長……。たまには、優しくしてほしいっス。\n意地悪だけじゃなくて……あ、おっぱいの揉み方は、うん……優しいけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104116" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長だって、もう……オチンチンが、ガッチガチじゃないっスか。あの\n、挿れたく……ないんスか？　自分の、オマンコ……気持ちぃっスよ、多分」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104117" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「自分のオマンコの中……温かくって柔らかくってふわふわで……でも、きゅ\nうってオチンチン締めるっスよ？　……ほら、挿れたくなって、きた？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104118" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、隊長のオチンチンの先っぽから……先走りが……。フフッ……ほら\nぁ？　涎垂れてるじゃないっスかぁ。早くオマンコにぶち込んでぇ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104119" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んおぉおぉお！　は、挿ってきたぁ……！　隊長のオチンチン……自分の欲\nしがりマンコにぃ……あはぁ……隊長ぉ……悦んでるよぉ、マンコがぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104120" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おおぉおぉ……いきなりそんな、奥までぇえぇ……んふぅうぅうぅ……！　\n自分の好きなとこに、隊長のオチンチンが、キスしてるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104121" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「きっ……気持ちぃよぉおおぉぉ！　隊長のオチンチン、最高に気持ちぃ……\n！　好きになるぅ！　隊長のオチンチン、もっと大好きになるぅううぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104122" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「好きぃ！　好きです隊長ぉ！　いつも大好きなのにぃ……オチンチン挿れら\nれるとぉ……あはぁ！　もっともっと好きになっちゃうぅううぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104123" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁん、ああぁ……！　隊長が、オチンチンでオマンコ、ズコズコしてくれ\nる度に、あはぁ、頭の中が……隊長で、いっぱいになるぅ！　好きぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104124" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おほぉ、下からオマンコ突き上げられるの、本当に……最高ぅ……！　もっ\nと、削って！　オマンコの奥抉ってぇ……！　隊長の極太オチンチンでぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104125" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいぃ！　んぎぃいいぃ！　もっとズコってぇ……！　自分のマンコで\n、隊長に気持ち良くなってほしいっス！　隊長、気持ちぃっスかぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104126" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はへぇ……はへぇぇえぇ……！　そ、そっかぁ……自分のマンコ、気持ちぃ\nっスかぁ……。あはぁ、嬉しいよぉ、隊長のオチンチン悦ばせてるぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104127" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「じ、自分……ずっと隊長のオチンチンに、ズコズコされてたいっス。こんな\nの、恥ずかしい、よぉ……。自分がこんなにエッチなんて、んきゅぅううぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104128" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぇ？　あ、好きって……本当に？　こんなエッチな……自分のこと、好き\nでいてくれるっスかぁ？　隊長……優しいよぉ……。大好き、大好きっス」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104129" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長のオチンチンも、はぁぁ……大好きぃ……。疼きマンコ、奥の奥までズ\nコズコ掻き回してくれるオチンチン、大好きぃいぃ……！　……んごぉお！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104130" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、腰がぁ……んくぅぅ……痺れるよぉ……！　あはぁ、隊長のオチン\nチン、さっきよりさっきより熱くなって……あはぁ、オマンコ蕩けるぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104131" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おほぉ！　んほぉおおぉ！　オマンコ気持ちぃよぉおおぉお！　すっごく敏\n感になっちゃてるぅぅ！　隊長のオチンチン、熱いことだけじゃなくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104132" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「隊長のオチンチンの、血管が……バッキバキに浮き上がっていることも、分\nかるよぉおおぉ！　んううぅう！　好きぃ！　隊長のオチンチン大好きぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104133" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「この、大きくて硬くて太くて熱い……自分のオマンコを奥までたーっぷり突\nき上げてくれる、隊長のオチンチン！　大好きなんっス！　あはぁあぁぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104134" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んぎぃいいぃ！　あはぁ、隊長のオチンチン……び、ビクビクって、震えて\nるぅううぅ！　んおおぉお！　い、イくんっスね？　隊長のオチンチン！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104135" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「い、いいっスよ……隊長……自分のきつきつマンコの中で、射精してほしい\nっス！　んごおおぉっ！　中出しして、子宮に精液流し込んでほしいっス！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104136" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「おひぃっ！　おひっ！　おひいいいぃいいぃ！　じ、自分もイくっス！　隊\n長の極太オチンチンでオマンコの奥ズコされながら、イくぅうううぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104137" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んっぼおおおぉおおぉおぉ！　ああぁ、イってるぅ……。オマンコが、ビク\nビク震えてるよぉおおぉ……あああぁ、隊長のオチンチンも、凄い……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00006101_02_08" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104138" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいいぃ……子宮の壁に……精液当たってるの、分かるよぉ……。おお\nぉぉお、染み込むぅ……。マンコの奥に、隊長の精液が……じっとりぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104139" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ああぁ、隊長の精液……溢れてきたぁ……。ああぁん、隊\n長の精液……全部……子宮に閉じ込めたいのにぃ……勿体ないよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0104140" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……すっごく気持ち良かったっス……。んふぅ……隊長も？　マジっス\nか？　ふへへ……それはやっぱり無茶苦茶嬉しいなぁ。またしましょうね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}