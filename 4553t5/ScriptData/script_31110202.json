{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん。今日は私の下部ユニットに直接挿入していいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「これはなにかって……？　これはカツマちゃんのために用意した、特別なセ\nックスユニットよ。メンテナンスをした時に、換装しておいたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ほら、見て……私のココ……人間と変わらないぐらい、柔らかそうでしょ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「各センサーとも連動してて、カツマちゃんの動きや感覚を全身で感じられる\nの……だから遠慮せずに入れて頂戴……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あんっ、入り口に熱いのが当たってる……！　大きなお豆さんにも、カツマ\nちゃんの息がかかって……んっ、あああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあぁん、入ってきたぁ……！　あぁ……カツマちゃんと一つになれるだな\nんて感動だわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私の超ＡＩが製造されてから、はじめての体験よ……ああ、人間の体ってす\nごいのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、カツマちゃんはどう……？　私のセックスユニット、気持ちいい\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「気持ちよくて、とっても柔らかくて、人肌の温もりを感じる……？　そう言\nってもらえると、作ってもらった甲斐があるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ……！　か、カツマちゃん……もう少しだけゆっくり動いて…\n…刺激が強すぎると、私の思考回路に負荷がかかっちゃうから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……ああ、カツマちゃんの太くて硬いモノが、あっ、あっはん…\n…私の中でぐぽぐぽ動いてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「このエンジンが高回転する感覚……人の言葉だと、なんて言い表せばいいの\nかしら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「興奮する……？　そうね……その言葉が一番しっくりくるかも……んっ！　\nか、カツマちゃん。私、とっても興奮してるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ。カツマちゃんも興奮してるのね……ならもっと私のセックスユニッ\nトを堪能して頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私が駄目になるくらい、激しく……！　あっ、あんんっ、ああぁんっ！　あ\nっ、はうぅ……あはああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うっ、うっ……お、オイルが……カツマちゃんに突かれるたびに、オイルが\n外に吹き出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私、べつに出そうと思ってないのに……なのに、どうして！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁん、んん～……！　はうんっ、カツマちゃんの腰の動きが早く\nなってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああん……はぁはぁ……はああぁんっ！　中身がかき回されて、ぐ\nちゃぐちゃになっちゃうぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ううっ、このセックスユニット……カツマちゃんのサイズに合うように、調\n整したの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だから密着して、カツマちゃんの先っぽから根元まで吸い付くように……刺\n激して、あはあぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……はあああぁんっ……！　か、感じるでしょう……もっとこう\nやって、締めつけることもできるのよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……気持ちいいの？　ふふっ、嬉しいわ……用意した甲斐がある…\n…んはぁああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「また腰の動きが早くなってる……！　まるで小さな子供が、駈けずり回って\nるみたいだわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああ、そんなに激しく……！　もう少し落ち着いて……ああんっ、はんっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああん……でも夢中になってもらえて、とっても嬉しいわ……！　も\nっとずぽずぽしていいからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんの元気だから、あっ、あんっ……私のセックスユニットが壊れ\nちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、ふぅんっ……あああっ……！　私の中身がぐちゃぐちゃに、めち\nゃくちゃに突かれてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んふぅんっ……！　カツマちゃんの腰がプルプル震えてる……！　い、イキ\nそうなの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはんっ……！　ビクビクして、先っぽが固く大きく、熱くなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私もさっきから全身の排熱が間に合わなくて……ハァハァ、駄目っ……！　\n熱暴走しちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、イって……！　私の超ＡＩ回路がオーバーヒートする前に…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああ、ああっ、駄目、駄目ぇ……！　私の知らない感情と感覚で、エラーが\n止まらないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んはぁああああああ……！　あああぁっ、おかしくなっちゃうううぅ～～～\n！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふあああぁぁんっ……カツマちゃんの熱いエナジーが溢れ出てる！　んあっ\n、あああっ、んふぅぅうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私の中にいっぱいドピュドピュ出されてる……これが中出しというものなの\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ、勢いが強くて奥にたくさん……んっ……当たって……！　激\nしい衝撃を受けたわけでもないのに、振動が止まらないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁー、はぁーっ……ああ、もう終わりなのね……はじめての感覚でどう表\n現していいのかわからないけど……とにかく、すごかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204138" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「え……？　これがイクという感覚なの……？　ふふっ。一瞬目の前がブラッ\nクアウトだからバグかと思ったけど……そういうことだったのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「できれば、もう一度あの感覚を味わいたいわ……カツマちゃん、協力しても\nらえる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「嬉しい……カツマちゃんも、同じ気持ちだったなんて……私のセックスユニ\nット、思う存分堪能してね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「いい具合にユニットもほぐれてきてるから……さっきよりも気持ちよくなっ\nてもらえると思うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはんっ……う、動くときは言ってね……急に動かれると、びっくりしちゃ\nうから……うん、いいわよ……ゆっくり……んふぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あん、あんん……！　カツマちゃんのさっきよりも硬くて、ギンギンになっ\nてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あはんっ……！　わ、わかるわ……カツマちゃんのモノが凶悪な形に\nなって、私の中で前後に激しく動いている様子が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そんなに悦んでもらえるなら……とっておきのサービスをしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「私のセックスユニットには隠された機能があってね……言葉で伝えるより、\n実際に体験してもらった方が分かりやすいわね……んっ、ふあああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「どうかしら……ユニットが回転して、いろんな方向からマッサージできるよ\nうになってるの……んっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ただ……私にも、あっ……強い衝撃が来るから……！　使いすぎると、ふぅ\nんっ……熱暴走を起こしちゃうかも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぅん……！　あっ、あはぁん……！　カツマちゃん、気持ちいい\n……？　もし物足りないなら、回転速度をあげることもできるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「もっと回転数をあげて欲しいの……？　なら……んっ、これでどうかしら…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「腰が砕けそうなぐらい気持ちいいのね……ふふっ。なら、この状態でもっと\n動かしてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だ、出したくなったら……我慢せずに出していいからね……！　あん、あっ\nはあああんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そんな……この状況でも動けるなんて……！　私の超ＡＩでも、そんな\n予測はできなかったわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んくうぅ……！　カツマちゃんの動きがダイレクトに伝わってきて……！　\nさっきとは違うエラーが出ちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あはぁあぁんっ、ひぐっ、んひいいいぃ……！　エラーを解除するリソース\nに手がまわらないわ……！　私は人に開発された超ＡＩだというのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「人間のセックスって、すごいのね……！　ああぁ、本当に暴走しちゃう……\n！　またさっきみたいに、イッちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん早くイって……！　私はもう我慢できなくて、オイルがだらだ\nらと垂れてきてるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ああ、ぐちゅぐちゅ音が鳴って、熱いの出し入れされてるのがわかるわ……\n！　ああ、いっ、イク……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁ……イク、イクぅ……！！　はああああん、イクイクッ……イ\nっちゃううううぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ！　カツマちゃん抜かないで……あああぁあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふぅんんっ、あっ、あっ……下腹部の装甲に、びゅっびゅってかかってる…\n…カツマちゃんの大事な遺伝子が、あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「んふぅ、んっ……！　あ、ああっ……そんなに外に出して……もったいない\nわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「せっかくセックスしてたんだから……中に出してくれてもよかったのに……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「負担をかけたくなかった……？　ふふっ、優しいのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それにしても、この白い液体……とっても熱いのね……はぁ、はぁ……私の\n塗装が剥げちゃいそう…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「あんっ……まだ搾りだせるなんて……遠慮しないで、好きなだけ出していい\nのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふふっ……やっと出し終わったのね。お疲れ様……さすがに疲れちゃったか\nしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「生体スキャンで確認したけど、随分と疲労が溜まってるみたい……無理させ\nちゃったのね……ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「またしたい……？　ええ、もちろんいいわよ。カツマちゃんが望むなら、い\nつだって換装してあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「うああぁぁぁんっ……！　カツマちゃんのが中に出てるっ！　熱い液体がど\nぷどぷって、奥に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ひぐうぅっ……！　この状態でさらに奥まで腰で突かれると……ああぁ！　\n暴発して溢れ出しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁあああん……！　こ、こんなにたくさん……出しすぎよ……あっ、くぁ\nぁ……あはぁ～～～んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……カツマちゃんの遺伝子情報が……ＡＩ回路に流れ込んで\nきて、妙なノイズが……これが幸せという感情なのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「だとしたら、カツマちゃんので幸せを感じてるわ……！　私っ……ああっ、\nまるでヒトのようにあそこで愛を感じてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、カツマちゃん……！　もっと、もっとっ……幸福エナジーを\nたくさん注いで頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00011102_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁー、はぁー……す、すごかったわ……エラーとオーバーヒートで、回路\nがショートしちゃうかと思ったぐらいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「とっても刺激的で……いままで感じたことのない電気信号が、何度も全身を\n駆け巡ってたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「おかげでたくさんのことを学べたわ……全部カツマちゃんのおかげよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「この経験を活かして、次はもっと気持ちよくしてあげるわね。楽しみにして\nてくれると、嬉しいわ」", "NORMAL" ]},
