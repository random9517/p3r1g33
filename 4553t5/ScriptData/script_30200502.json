{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「さてと、そなたにはまた我のメンテナンスをしてもらうのである。今回はこ\nの器具を用意したのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「このマッサージ器を使うのである。……はぁ？　肩が凝っているのかって、\n我は人間ではなくメカである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「肩凝りになんかならないのである。……変態のそなたが、これの使い方を知\nらないとは、我の見込み違いであったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「いいから、服を脱ぐのである。察しの悪い愚かなそなたに、我が一から説明\nを施してやるのである。感謝するのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「持ったであるな？　それではスイッチを入れるのである。そして、振動して\nいる先端を、我のクリトリスに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002005_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んんぅっ、んふっ、んっくぅ……っ！　お、押しあてる加減が、絶妙である\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「やはりそなた、本当はこれの扱いをしっていたであるな？　我を欺くとは…\n…んはぁっ、あっ、ん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くぅ……クリトリスに、触れるか触れないかという……んはぁっ、微妙な位\n置で、振動させ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もどかしい刺激で……あふぅ……腰が勝手に、反応してしまうのである……\nんっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「な、なんであるか……？　クリトリスも感じるのか、と……？　んふぅ、当\n然である……ここも、我にとって重要な部位であるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だからこうして、メンテナンスをする必要があるのである……。はぁ、はぁ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁああっ！！　急に、ぐりっとクリトリスに押しあてて……っ！　し、振\n動がっ、強すぎるのである……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、そうである……乳首と一緒で、こっちも強めに……しっか\nりとしたメンテナンスが必要なのである……んっ、くぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「で……デカクリ……振動で揺さぶられているのである……！　はぁあんっ！\n　下半身が、弾けそうである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「腰が勝手に……んっ、ああっ！　マッサージ器から逃れようとして……しか\nし、そなたは逃がさず、我のクリトリスを……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そして我の股間には、んぁっ、先ほどからそなたのチンポが……勃起したチ\nンポがあたり……んっくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「熱いチンポが、ワレメに擦れて……んぅっ、ああっ、振動とともに、我のこ\nとを昂らせるのである……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んはぁっ、ああっ、ああ……っ！　イクッ、イッてしまう……！　この振動\nで……クリトリス……イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ！　ああぁっ！　ああっ、あはぁあああぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああ……絶頂に達してしまったのである……。んふぅ……またそなたに、イ\nかされてしまったのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「な……なんであるか……？　我のオマンコに、チンポを挿入したい……と？\n　それは許可できないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「確かにそなたのチンポはバキバキに勃起しているようだが、そなたは我のメ\nンテナンスに専念するのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「余計なことを考えている暇があるなら、さっさとメンテナンスの続きを……\nんひぃっ！　おっ、おほぉおおおぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ななっ、振動が、さっきよりも強く……っ！　んくっ、ひぃいっ！　振動を\n最強にしたのであるかっ、はぁっ、ああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おおっ、おおっ、おかしくなるっ！　振動が強すぎてクリトリスがすり減る\nのであるぅうっ！　くひっ、ひぃいん！　はぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これを続けられたらっ、壊れてしまうっ！　ああっ、思考がっ、快感が異常\n値……危険値なのである……！　んひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「に、逃げなければならないのにっ。快感で腰が抜けてっ、身体を動かそうに\nも、え、エラーが出てしまうのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぁっ、頼むからこれ以上は……！　なっ、挿入の許可をすれば、弱めるだ\nと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「この期に及んで、我に取引を持ち掛けるとは……あひぃいいっ！　クリトリ\nス潰しながら、ぐりぐりするのをやめるのであるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「わ、わかったのである！　許可するのである！　んひっ！　そ、挿入してい\nいのである！　我のオマンコにハメていいのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃっ！　そ、そんな一気に！　我のオマンコがそなたのチ\nンポでいっぱいにされてしまったのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あ、愛液で濡れまくっていたのであるかっ！？　我のオマンコがそんな反応\nを……んっ、ひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「それよりも約束が違うのである！　挿入させたのだから、振動の強さを弱め\nるのである……んっ、ああっ、あはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なっ。我のオマンコが気持ちいいから、一度射精してからって、そんな……\nんぁっ、ああっ、チンポが我のっ、奥を……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「わ、我にも子宮が備わっているのである！　そこを、何度も突かれては、我\nは……我、わ、わわわわ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イク、イク、イク、イク……ッ！　あっ、ああっ、イッて……イッ、イッ、\nイクッ、イッ、イグッ、んぃいっ、イッぐぅううぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504136" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁあああぁぁぁああぁぁ～～～～っ！！　あっ、ああっ、中にっ、中に精\n液ぃっ！　流れ込んで、きてるのであるぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、オマンコで、チンポがビクビクと暴れまわってっ！　膣壁っ\n、ごりごりとっ、抉ってるのであるっ、んぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「子宮に、精液が注がれているのを感じるのである……！　こんなに、大量に\n中出しされたら、孕む……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「孕んでしまうのである……！　妊娠してしまうのである……！　ああ……赤\nちゃん……できて、しまうので、あるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「……はっ！　そ、そなたなんであるか、この状況は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「さっきはあまりの絶頂に強制再起動がかかったようである……。もしやそな\nた、その間もずっと我に挿入していたのであるか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「い、いますぐそなたの上からどくのである。だからもう……んひぃいっ！　\nまた、振動でクリトリスを……んぉっ、おおぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「腰を動かしてっ、ズボズボと我のオマンコを責めたてるのをやめるのである\nっ！　くひっ、こ、腰が跳ねあがって、器具にぶつかるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ、クリトリス、メンテナンスはもういいのである！　振動を与えるのは\n、もうけっこうなのである……んっ、ああっ、あはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「この方が、オマンコが反応して気持ちいいって、そなたの都合などどうでも\nいいのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こ……これ以上、我の身体を玩具のように扱うというのであれば……あれば\n……んはぁ……ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ダメである……なにも、考えられないのである……！　き、気持ちいい……\nクリトリスとオマンコ、気持ちよすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「快感が膨れ上がって、回路がどうにかなっているのである！　んぁっ、ああ\nっ、オマンコが勝手に動くのであるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポを感じてしまうのであるっ！　熱を、太さを、硬さを……そして、\n我のオマンコを犯す動きをぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んほぉおおっ！！　振動っ、振動も強いっ、我のクリトリスがビンビンに勃\n起してしまっているのであるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんな、腫れたように勃ったクリトリス！　無防備なデカクリをっ、執拗に\n責められ……んぁあっ！　ああっ、ああぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっ、おかしくなる！　本当に、壊れてしまうのである！！　んひぃいっ！\n　クリトリスとオマンコ、同時にぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「快感が大きすぎて、処理が間に合っていないのである！　おおっ、チンポが\nっ、さらに激しくぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「また射精するのであるかっ！？　わ、我に向かって、また……そなたの精液\nがっ、んっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504215" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「よ、悦んでない……っ！　そなたの射精を想像して、さらに興奮したなど、\nありえないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なのにっ、腰が勝手に動くのである！　んぁっ、制御できないっ！　下半身\nがそなたを射精させるために動くのであるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「理解できないっ、解析できないのであるっ！　我の身体がっ、我の手を離れ\nているようなっ、ああっ、ああっ、イッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたを射精させ、我もイクッ、またイクッ、イク……ッ！　あっ、ああっ\n、イかされてしまうぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、我にっ、我に精液ぃっ！　そなたの精液を、ああっ、浴び\nせてぇえええぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃ～～～～っ！！　んはぁっ、ああっ、あはぁああっ！！\n　はぁっ、イッ、はいって、くるぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「チンポが跳ねてるっ！　おっ、オマンコ！　我のオマンコにまたっ、精液っ\n、中出しぃっ！！　注いでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イグッ、イグッ、イッでるのであるぅうううっ！！　おっ、おっ、おおぉっ\n！　オマンコ、オマンコぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「止まらないっ、絶頂の感覚がっ、んはっ、はぁっ、さっきからずっと続いて\nいてぇええっ！　んくっ、ひぃいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そ、そなたのせいで……本当に、おかしくなってしまったのである……！　\nと、止まらないのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オマンコが、そなたのチンポを咥えこんだまま離そうとしないのであるっ、\nこのままでは、立つこともままならないのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「……ただ、理解できたことがあるのである。我の身体は、どうやらそなたの\n精液を心底欲しがっているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もっと、そなたの精液を子宮に感じ……孕みたいと、おそらくはそう思って\nいるのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「であるから、そなたには我が孕むまでこのままいてもらうのである。これは\n命令である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふふ、そなたのこどもなら、我は何人授かったってかまわないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　ああっ、はぁっ、んぁっ、あああぁぁぁああぁぁ～～～～っ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我の身体にっ！　いっぱい、そなたの精液がかかっているのであるぅっ！！\n　んひっ、ひぃっ、イクッ、イク……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ドロドロのザーメンぶっかけられて、ああっ、回路が弾けるっ！　快感がっ\n、オーバーフローしてっ、んひっ、ひぃいいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたっ！　んほぉっ！　おっ、おおぉっ！？　精液でヌルヌルになったそ\nれで、クリトリスをぉおおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「クリトリスに精液がっ、いやらしい音をたてながら塗り込まれているのであ\nるぅううぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イグッ、イグ……ッ！　勃起クリ壊れるのであるぅううぅぅっ！　おっ、お\nっ、おおぉっ！　んほぉおおおぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んぉお……おおぉ……おほぉお……。クリトリス、おかしくなったのである\nぅ……さっきから、イキっぱなし、であるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504407" ]},
		{"command":[ "SETIMAGE", "0", "still_00002005_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「デカクリ、ヒクヒクさせながら……い、イク……イキまくり……んひぃ……\nあぁ……おっ、おほぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そ……そなたぁ……。メンテナンスで、我をこんなにしてぇ……ゆ、許さな\nいので、あるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これから毎日、我のクリトリスをお世話してくれないと、許さない……覚悟\nするので、あるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}