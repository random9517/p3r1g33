{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0175" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「一は十に、十は百に、百は千に！　月兎族オボロが奥義、目にも見よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うひゃあああああああああっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああああっ！　ご主人！？　しっかりしてくださいませ！　ご主人ーーーー\nーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おお、なんということだろう！　オボロの必殺奥義『遊撃の陣・改』をもろに\n食らったカツマは、あっけなく失神してしまった！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カツマはこのまま、二度と再び立ち上がる力を失ってしまうのだろうか？　\nがんばれカツマ！　立ち上がれカツマ！　地球が地球が大ピンチだ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0176" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "一方そのころ。列車内で捜索を続けていた他のメンバーは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あら？　カツマさんは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そういえば、姿が見えない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「列車の屋根でも調べてんじゃなーい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まあ、なにか見つけたら戻ってくるだろう。気にすることはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わたしは、もう一度ホームを見てみます。ちょっと気になったことがある\nので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルルカン" ]},
		{"command":[ "SETTEXT", "「はいはーい、気を付けて～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_010114380002" ]},
		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そう言って列車を降りた翔生子は、ホームの捜索を始める。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「うーん……考えすぎだったかな……ホームには、ゲートの手がかりも痕跡も\nないみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380002" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「これ以上、調べなきゃいけないものもなさそうだし。列車に戻ったほうが―\n―」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、翔生子が列車の方に向きなおったとき！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSe" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　ええええっ！　なんで列車が動いてるの！？　ちょっと待って！　\nわたしまだ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「翔生子！　急げ！　列車が動き出した！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114380001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0163" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「急いでます！　急いでますけど！　あ、あ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「翔生子ちゃーーーーーんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114380001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「翔生子っ！　手を伸ばせっ！　翔生子ーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114380002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「姫さまーーーーーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETTEXT", "いま、万感の思いを込めて汽笛が鳴る。いま、万感の思いを込めて列車が\nゆく。ひとつの旅が終わらぬまま、また別の旅が始まる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「って！　そんなこと言われても困りますっ！　わたし、一人でどうしたら\nいいんですかぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さらば翔生子。さらばインクレディブル・スクワッド。そして、少女はひとつ\n大人になる――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「だから！　そんなこと言ってる場合じゃなくて～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……翔生子さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「あ！　オボロさん！　あなたも乗り遅れたんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380009" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いえ、乗らなかったです。やらなければならないことがありましたので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「え？　なにをですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380010" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……出ませい、式神」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「オボロさん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380011" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「悪いですね。ウチは、やらなければならない事をするまでです。あなたを\n、ここで始末します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「オボロさん、なにを言ってるんですか！？　やめてください！　わ、わたし\n、オボロさんに何も悪いことなんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380012" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「一は十に、十は百に、百は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380006" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ちょーっと待ったーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114380001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「え！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380007" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「その声は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380013" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0164" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ＳＭＮＲ" ]},
		{"command":[ "SETTEXT", "「ラビットパワー！　イェーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114380002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「スクールガール・ミュータント・ニンジャラビッツの皆さん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380014" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「オボロ！　あんたいったいどういうつもり！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114380002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ここまで来て裏切りとは。なにかよくよくの事情があるのか、それとも……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114380001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「バッケンローダーさんに、ニャンコ先生も！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114380015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたたちが、どうしてここにいるです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ワームホールが消える直前に飛び込んだのよ！　あんたたちを助けに行けっ\nて、クィン・テイルと長官に言われてね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114380003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「シーズン２では、あーしらあんまり出番なかったしー。ここで一発、見せ場\nをもらっとこうかな～なんて思って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010114380003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こら、シャラク！　本編中のメタ発言はつつしめと、教えたばかりだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114380002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……あなたたち、コントをやりに来たですか？　ならば即刻お帰りを。\nそうでないのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380009" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ないのなら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114380003" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの『陣』の、餌食となっていただきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114380010" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}