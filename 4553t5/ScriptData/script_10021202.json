		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ちょっとさー……これ、マジな話やばくね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「だよねー……あの人たちにバレたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「そうね。こういうときは……せんせー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うむ。なんであるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「出かける前に、お手洗いに行ってもいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114490005" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

