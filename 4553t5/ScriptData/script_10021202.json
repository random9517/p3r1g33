{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "一方そのころ。地球のＥＤＯ本部では……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「うううっ……すんませんすんません……地球の食べ物おいしいです……めっ\nちゃおいしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほらな？　あたしの言った通りだろ？　どんなヤツでも、カツ丼食えば素直\nになるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「それは、ほむらの経験からですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうそう、あたしもよく取調室で――って、大きなお世話だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あー、大丈夫。さっきも言った通り、この二人のこれはただの百合だから。\n怖がらなくてもいいから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ちょっと長官！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だれがこんなヤツと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「もういいっつーのよ、そーゆーのは！　さっさと結婚しちゃえよお前ら。私\nなんかほっといてさー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「こっちの人のやさぐれ具合のほうが怖くない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「だよねー。なんかストレス爆発してるかんじー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そりゃストレスもたまるっつーのよ！　唯一の愉しみが勤務明けの呑み歩き\nだったのに、あんたらのせいで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あー、長官？　そろそろ仕事に戻ってくんない？　宇宙軍から連絡が入って\nるんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あーそう。なんだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「シャムさんとフィルさんの海賊戦艦が、やはり苦戦しているようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00006701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「やっぱりか……そんな気はしてたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「それに、カツマ隊長たちも同様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00006701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、カツマ隊長だしなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「カツマ隊長ではなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「なんかひどい言われようですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「苦戦してるんなら、こっちからも援軍を送ってやらなきゃならんが、どうし\nたもんかなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そうだねえ。できれば少人数をちまちま送るんじゃなく、ＥＤＯと九姉妹（\nナインシスターズ）全戦力をドバッ！　とねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「となると、巨大なワームホールを開く必要がありますが、こちらにはそこま\nで大きなものを作る技術は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00006701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ないよなあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ないねえ……襲来者（インベーダー）の技術でも鹵獲してこない限りはねえ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）の技術をねえ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「…………！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「たまたま偶然、運よく捕虜にした襲来者（インベーダー）はいるけどねえ…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「え、えと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「その子がたまたま、そんな技術持ってたりしないかなあ～？　ねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「…………あ、あの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんか、似たパターンを前にも見た気がするな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ、私もそう思いました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと？　ダメっすよ？　リーダー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「カツ丼……おいしかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「それはもう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490005" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「リーダー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そかそかぁ……ねーえ？　ほむらたん？　居酒屋・正義（まさよし）のカツ\n丼って、アタマダブルもできたよねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490013" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう！　カツが２倍に海苔が５倍だぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114490005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「カツが２倍！　２ばーい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490006" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「うっわ……目の色変わったよこの人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114490002" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……どうだろう。それをこの先１週間、１日１杯ずつということで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490014" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「はいっ！　ワームホールですね！？　あります！　ありますともっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490007" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者たち" ]},
		{"command":[ "SETTEXT", "「この人ダメだぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114490003" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "-500" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "3", "CENTER", "500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「交渉成立！　それじゃ、案内してもらおうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010114490004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「はい！　こちらです！　はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114490008" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なかなか協力的であるな。いい心がけである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010114490001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おう、みんな。がんばってこいよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114490015" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "というわけで襲来者リーダーは、ＥＤＯやブラックメルヘンのメンバーを連れ\nて外に出ていく。当然、部下たちも同行するのだが……。", "NORMAL" ]},
