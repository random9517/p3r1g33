		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ぁあああ……力を込めてこね上げると、胸の間からまた、おちんちん独特の\n臭気が……ふぁああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「た、隊長サン……！　隊長サンのおちんちんが、先ほど同様、真っ赤に膨れ\n上がってきました！　これは、もしかしてまた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「やはりですか！　やはり、また出るのですね！　ああああ……おちんちんが\nピクピクと痙攣しています……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「は、はい！　大丈夫です！　強くなるために必要な試練ですから、紅華は耐\nえてみせます！　出させてみせますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「さあ、かまいません！　隊長サン、出してください！　出して！　早く出し\nてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「出して！　出し……んぁっ！？　あ、あ、ふぁああああああああ～～～っ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「あ、ああああああっ……出ていますっ！　紅華の胸の間で、隊長サンのおち\nんちんがどくどくと脈打って……きゃっ！　きゃっ！　きゃぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「あ、あああっ！　またこんなに！　またこんなに噴き出してっ！　どこにこ\nんなに残っていたのですか！？　はぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「やっ！　やぁん！　胸も顔もべたべたですっ！　それに……匂いが……匂い\nがっ！　すぅううううっ……はぁあああ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「すうぅ～……はぁ……すぅ～……はぁあああ……なんてひどい……ひどい悪\n臭が部屋にこもってしまって……すぅううう～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ぁああああ……この匂い。隊長サンのこの匂いっ！　ひどすぎて頭がくらく\nらしてしまいそうです！　あああ、なんだか気が遠く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「な、なんですか！？　隊長サン！？　人聞きの悪いことを言わないでいただ\nけませんか！？　紅華は、トリップなどしておりません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「トリップなんて……そんなこと。まるで、紅華が悪いおクスリかなにかやっ\nているような言い方を……すぅううう～……はぁあああ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「と、とにかく、これで今日の特訓はおしまいですね？　これで紅華は、以前\nよりも強くなれるのですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「……なるほど、たしかに、一度で結果は出ないでしょうね、継続は大事です\n。ではまた、この匂い……もとい、特訓を、よろしくお願いいたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103310" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「え？　どうして腰を引いて……きゃっ！？　きゃぁああああああああっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ぁああああっ！？　隊長サンのおちんちんから、精液が噴き出して……んぁ\nああっ！？　やめて！　顔はやめてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、ああああっ！　きゃあっ！？　違いますっ！　顔でなければい\nいというわけでも……いやぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……はぁあああ……紅華、もう体中ベトベトになってしまいま\nした……全身からすさまじい悪臭が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「すうぅ～……はぁ……すぅ～……はぁあああ……それにしても、この匂い…\n…本当にすさまじいです……はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「日頃なにを食べていたら、こんなものすごい匂いを放つ液体を、放出できる\nようになるのでしょうね……すぅう～はぁああ～……すぅうう～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ごほっ！　ごほごほごほっ！　はぁああ……悪臭を胸いっぱいに吸い込みす\nぎて、むせてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「な、なにをおっしゃるんですか！？　いきなり！　別に、この匂いを気に入\nってなどおりません！　人聞きの悪いことをおっしゃらないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「と、とにかく、特訓は終了ですね。紅華、どれだけ強くなっているのでしょ\nう。次の任務が楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103409" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「これだけ強烈な匂いに耐えたのですもの。強くなっていなければ困ります…\n…すぅぅ～……はぁああ～……すぅうう……ふぁああああ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103410" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
