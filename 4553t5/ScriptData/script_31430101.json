		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「こんな密室に男性と二人きりだなんて、き、緊張してしまいます。出来れば\n早くお仕事を済ませたいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00014301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「え？　仕事ではなく……パイズリを？　そうすることで私を強化する……。\nそ、そうなのですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00014301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「パ、パイズリ……。あ、はい。知識はあります。ですが、自分に出来るかど\nうかというと……。その、体験したことがありませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「それに、パイズリと強化との関係もいまいちピンと来ませんし。今回はお断\nりをして……って、きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「や、やぁあっ……。こ、これ……！　隊長サンのこか、股間、股間ではない\nですか……！　だ、駄目です、やっぱり無理です、あ、あ、あ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00014301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「男性器を胸で挟むだなんて……！　金華ちゃんに知られてしまったら軽蔑さ\nれます！　か、帰ってもよろしいでしょうか……？　だ、駄目ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「…………駄目……なら……。さっさと済ませてしまった方がいいみたい、で\nすね……。隊長サン、内緒にしてくれますか？　今夜のこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「は、はい。紅華も他の誰にも告げ口しません。ですから……。私が胸でした\nということは、金華ちゃんには言わないでください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「……っはぁ……はぁ、はぁ……お、おちんちん……。おちんちんを自分の胸\nで挟むだなんて……卑猥すぎます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103110" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「あ、ああ……あんまり紅華の顔は見ないでください。む、胸も……駄目です\nよ。これは強化のためのパイズリのはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「それなら、快楽を目的にするのは間違っています。……っ……そ、それでは\n……はじめさせていただきますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「っはぁっ、はぁ、はぁ……はぁ、ああ……はぁ……。んっ、ん、んぅ……は\nぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「……初めてパイズリをしてみてどうか、ですか……？　はぁっ、そ、それを\nお聞きになるのですか……。そうですね、んん、まず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「生で見る男性器というものが初めてで……。ほ、他の方もこんなに大きいも\nのなのか……隊長サンだからなのか判断しかねます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「んん……、ち、知識で想像していたものと、実物がかけ離れているんです…\n…。小説で読んだ限りでは、そ、その、愛の証明と言いますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「もっと小さくて、キラキラしていて、……あっ！　優しいものだと思ってい\nたのですが……実際に触れてみると、こ、これは……はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「グロテスクで、あ、赤黒くて……生きているという感じがします。恐ろしい\n爬虫類を……太い蛇を挟んでいるみたいで、少々困惑が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「生物特有の生々しさを感じるといいますか……。んッ、ぬ、ぬくもりと……\nあの……血管の這った肉幹とが……あん、んん、その、そのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「……私の胸から顔を出す亀頭が……あッ……その先端がクパクパと開いたり\n閉じたりして……く、口のようなんです。それが怖い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「男性のおちんちんが、全部こんなに恐ろしい形や色をしているのなら……。\nこ、子供を作った女性は凄いのだな、と……か、感心します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「だ、だって……こっちにかみついてきそうなんです……！　尿道口で、がぶ\nッて胸に、首に……んんんっ、顔にかじりついてきそう、で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「隊長サンは……男の人はこれと共に暮らしているだなんて、にわかには信じ\nられません。はぁ、はぁ、これが人体の一部だなんて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「あ、ああ、怖いっ……こわいっ……。んん……！　紅華のおっぱいに、ひ、\nひどいことしないでくださいね……っ、ああ……ん、ん、ん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「大事なところを女性の胸に挟ませて……刺激させるなんて……。理解できま\nせん……。や、柔らかさが欲しいんですか？　ぬくもり……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「圧迫されるのが好きなの、ですか……？　わか、らない……わからない……\n。でも、し、知ってしまうのも怖い……。はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「隊長サンが……男の人が、私の胸を見て、パ、パイズリして欲しいと思って\nいたなんて……。思わせぶりに見えたの、でしょうか……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「それとも、おっぱいがあれば男の人はこうしたいって……パイズリを命じた\nいって思っているのかも……。っ……そんな、そんなこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「それが真実だったら、明日から私……。っ……も、もう感想はいいですよね\n？　本物のおちんちんは、こ、怖い……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「でも、少しだけ……ここまで凝り固まったものをほぐしてあげたい、柔らか\nく戻してあげたいとも、思うから……だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「んぁっ、ぁっあっ、ぁっあっぁっ……！　あっ！　あっ、あぁ……はぁあっ\n……あぁ……！　んふっ……んっ！　んっ！　んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「あふ……ふぁっ、ぁっ……！　あっ……お、怒っているの……？　あん……\n！　か、顔におちんちん近づけないで……あっ、おとなしくしてて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「んんんっ……気持ちよくしてあげるから……！　あっ！　んぁッ……あっぁ\nっ……！　ふぁっ……！　アッぁっあっあぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ああ……出すのですね。って、きゃ……！　だ、出す？　だ、出すのですか\n？　ま、待ってください、こ、このまま出されたら私……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「きゃああああっ！？　あつっ……！　あっ、待ってくださいとお願いしたの\nに……！　あっ！？　あぁっ、あっ、あ……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「パ、パイズリを許可しましたが、だ、出されるのまでは許した覚えはありま\nせん……っ。なのに、なのに……ああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「なんという悪臭……うう……。どこもかしこもべっとり……。こんなの、洗\nっても取れませんよ……。い、いや……いやぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「やっぱり、おちんちんは怖い生き物です……。どこにここまでの量を蓄えて\n……。ふ、噴水みたいでした。ばびゅっばびゅって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「隊長サン……恨みます……。って、自分の意思では止められない……？　そ\n、そうなのですか……だったら……仕方ないのでしょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「いえ、自己で制御出来ないような生き物を股間に飼っているなんて、まずそ\nれが問題ですっ……！　お、男の人ってこれだから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「きゃっ！　な、なんですか！？　またおちんちんが動き出し……って、隊長\nサン！？　なぜ腰を動かしているのです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ま、まだ物足りない！？　もっと出したい！？　こんなに出してまだ物足り\nないというのですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「おちんちんの要求だから仕方ない？　これも自分の意思では制御できない！\n？　なんということでしょう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「なんという迷惑な……！　ほんとうに最悪です、男性器……！　隊長サン、\nこんなものは、いっそ取ってしまうわけには……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「いきませんか、やはりそうですか……わかりました。これも修行のうちです\n。強くなるためです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「パイズリ……させていただきます。んっ……んんっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ううう……やはりベトベトします。胸の間も、臭くてべとべとした汁がいっ\nぱいついていて……その間でグロテスクなものが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「それにしてもこの汁……どうしてこんなに臭いのでしょう……臭い……はぁ\nあああ、臭いです……ぁああああ……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00014301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「海産物系と植物系、二つの生臭さをあわせ持った独特の匂い……無駄に生命\n力の溢れる匂いとでも言いましょうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「それに、隊長さんのおちんちんの匂いが……磯の匂いを思わせる、この荒々\nしい臭みが入り交じって……はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「くんくん……はぁああ……くんくん……ぁあああああああ……ひどい……ひ\nどい匂いです……ぁあああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「こんなひどい臭気にさらされながら、隊長サンのグロテスクな怪物に奉仕し\nなければならないとは……なんと厳しい特訓なのでしょう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_143_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		
		{"command":[ "SETNAME", "紅華" ]},
		{"command":[ "SETTEXT", "「ですが、この試練に打ち勝ってこそ、得られる力と技があるのですね！　紅\n華は負けません……！　ふぁあああ……！」", "NORMAL" ]},
