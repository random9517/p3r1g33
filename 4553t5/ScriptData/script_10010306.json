{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0097" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_004" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……まったくもう。どうしてつきみがついてくるのよ」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_060103060001" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だってルナテミ――ルルーナちゃんがいきなり本部を飛び出しちゃうんだも\nん。びっくりして追いかけてきたんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060001" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ホントに、あなたって人は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060002" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「へへへへ……。それにしても、ルルーナちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060002" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060003" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミスって、本当にルルーナちゃんだったんだね。初めて聞いたときは\nびっくりしたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060003" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　今はその名前は出さないで！　いちおう秘密なんですからね！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060004" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ、ご、ごめん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060004" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「つきみったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060005" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それでね？　ルルーナちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060005" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なによ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060006" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうして急に飛び出しちゃったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060006" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「っ！　そ、それはあなたには関係ないでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060007" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「関係あるよ！　そりゃ、ちょっと前まではいろいろあったけど……今は同じ\nインクレディブル・スクワッドで戦ってるわけだし、それに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060007" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060008" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルルーナちゃんとわたしは友達だもん！　友達が急に部屋を飛び出しちゃっ\nたら、そりゃ気になるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060008" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060009" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルルーナちゃん、よかったら話を聞かせて！　わたしで相談に乗れることが\nあるかもしれないし、そうでなくても――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060009" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「話すだけで楽になる、ってこともあるかもしれないし！　だから、お願い！\n　ルルーナちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060010" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「…………まったくもう。……つきみったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060010" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……別に、たいしたことじゃないわ。あの女が、なんとなく虫が好かないだ\nけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060011" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あの女って、アナザーのこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060011" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ。あいつが来てから、私は気が休まる暇がないのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060012" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「何をやるにも、何を言うにもあいつが先回り。しかも、いつでも上から目線\n！　もう、ホントにうんざりだわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060013" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ル、ルルーナちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060012" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「おまけにちょっとばかり器用で腕が立つのを鼻にかけて、どんなことでも『\n自分のほうがうまくできる』と言わんばかりに見せつけてくる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060014" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もう嫌！　ほんとに付き合いきれない！　部下たちの手前、弱みを見せるわ\nけにはいかないと思って頑張ってきたけど、もう……もう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060015" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「……ルルーナちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060013" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「っ！？　な、なによつきみ！　急に手を握ってきたりして！　人前で、そん\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060016" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あのね、わたし、ルルーナちゃんのその気持ち、わかる気がするんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060014" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060017" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うちのお姉ちゃんってさ、とっても頭がよくて、何でも知ってて、いつもわ\nたしの面倒を見てくれるじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060015" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうね。あなたとまりあ、とっても仲良しでうらやましい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060018" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でもね、わたしも時々……あ、ほんとに時々だよ！？　今、ルルーナちゃん\nが言ったような気持ちになっちゃうことがあるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060016" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「え……！？　あなたが……まりあに対して、ってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060019" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うん。そう。内緒だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060017" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「信じられない、そんなこと……とっても仲良しの姉妹だと思ってたのに……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060020" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「もちろん、わたしとお姉ちゃんはとっても仲良しだよ？　でもさ、仲良しだ\nって、時々はそんな風に感じちゃうこともあるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060018" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だからルルーナちゃんとアナザーも、きっと仲良くなれるんじゃないかな、\nって思うんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060019" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_060103060021" ]},
        {"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そういえば……さっきから電話に出てくれないけど、お姉ちゃんなにやって\nるんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060020" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「何か、大変なことに巻き込まれてなければいいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103060021" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
