        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待って！　つきみから電話が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103060001" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あとにして。今はまず、カツマを追うのが先」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103060001" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それでは、まいりますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103060002" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あああ、待って待って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103060002" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ごめんね、つきみ！　あとで折り返し電話するからね～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103060003" ]},
