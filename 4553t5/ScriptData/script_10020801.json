		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……ひっく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「陛下ぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ううぅぅぅ……陛下ぁ。どこへ行ってしまわれたんですかあ、陛下ぁぁぁ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今日はまた一段とぶっ壊れてるねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「エファ殿がここまで悪酔いするとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ルナルバース殿の行方不明が、相当堪えているとみえる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ういー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ルナルバースの代わりに、あれやこれと仕事と責任も増えてるみたいだしさ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「とはいえさすがにこれ以上は、明日の任務にも差し障ろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840003" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「エファ殿。今日はもうそのぐらいにしておいてはどうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「呑まなきゃやってられないっての！　今日は今日でさあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「昔馴染みから、『来月結婚します☆』なんて幸せそうな報告が届いちゃった\nのよ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あー、そいつはまた、タイミングが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こちとら男と遊ぶ暇だってないってのに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「心中、お察しする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840005" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「同情するなら酒をくれ！　お代わり、じゃんっじゃん持ってきて！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「注文ならば致し方ないが……前後不覚になるまで呑むのはどうかと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840006" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「見知らぬ男にお持ち帰りされても知らないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「望むところよ！　持ち帰れるものならね！　むしろ持ち帰っていたぶれる相\n手が欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840009" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「カツマ殿では駄目なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840007" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カツマぁ？　あれは反抗的過ぎて、鬱憤を晴らすにはちょっとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840010" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「酔って絡まれちゃあ、隊長さんの方も気の毒に思えるねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あたしは！　気持ち良く酔って！　気持ち良くなりたいだけなの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840011" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……そういえば。酩酊した人間を騙して、書類にサインをさせる、などとい\nうあくどい話も耳にした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840008" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「心が弱ってる時は、そういうのにも嵌まりやすいからねえ。妙な教えにころ\nっと洗脳されちゃってさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「普段のエファ殿であれば、むしろころっと言うことを聞かせる側に思えるが\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840009" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うぃー……婚活は戦い……最前線中の最前線……地獄の婚活バトル……ひっ\nく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840012" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ホントにちゃんと帰れるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「へーきへーき♪　愚痴を聞いてもらったお陰で、もうご機嫌なぐらいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840013" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「気晴らしの役に立ったのであれば良いが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010113840010" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んじゃま、ありがとやっしたー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020113840008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「…………ふう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840014" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「強がってはみたものの……うぇっぷ。さすがに飲み過ぎたかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いっそ、カツマ辺りを叩き起こして、迎えに来させる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いやいや。こんな姿、誰かに見られるわけにも……それこそ幹部の名折れ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「とはいえ……うっぷ。……はあ。どうしたものか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840019" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「！？　……囲まれた？　それも複数の気配……何者？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……答える気はなし？　あたしに用があるのは、間違いなさそうだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840021" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「酔っ払っていても、そう簡単に不覚はとらないわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……って、あ、あれ？　目が、廻る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840023" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……何を……う……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060113840024" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}