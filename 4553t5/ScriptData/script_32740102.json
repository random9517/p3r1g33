{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ……？　あら、どうしたんですか？　いきなり私の後ろに回って……。 \nえっ？　ムラムラしてきたから中に……おまんこに入れたくなった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「こ……こんな森の中で、大胆ですね……？　そんなに私が好きなんですか？ \n　んぅ……♪　私は木の精霊だから、森でするのが一番いいはず、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「それはもちろん、そうですけど……うふふふ♪　そんなに貴方ががっついて \n、私を求めてくれるとは思っていませんでしたから……嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そんなにしたいですか？　本当に？　えぇ～？　どうしましょうか……なん \nて、あまり焦らすと怒られてしまいそうですね。はい。いいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私が嫌だなんて言ったところで、強引にしちゃうつもり……でしたよね？　 \nうふふふ、そういう強引なプレイ……嫌いじゃありませんよ。どうぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ん、は……ぁ、あぁああああ……っ♪　前戯も無しの生挿入……いいですね \n……っ♪　んっ？　前戯はこれから？　一体何をするつもりですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ♪　おっぱい？　私の胸を揉みしだくんですね……♪　もちろん、かま \nいませんけど……んっ、あっ♪　あっ……こ、これは効きますね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「おまんこに太いチンポを入れられながら、おっぱい、も揉まれると……あっ \n♪　さすがの私も感じないわけにはいきま、せん……。んっんっんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「貴方の指……あったかくて気持ち、いい……っ。あっ……♪　おっぱいにめ \nりこんで、食いこんでいる……？　そんなに強く揉むからですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……んふぅっ♪　いやだ♪　おっぱいを揉み揉みするたびに私の中で……あ \nんっ、チンポがピクピク震えて喜んでいますよ、本当にスケベですねぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あッ……？　おっぱいを揉み、ながらっ、こ、腰も動かしていくつもり、で \nすか……？　あっ♪　容赦ないです、ねっ……んぁっ♪　やっ、太いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　わ、私ぃ……貴方のチンポ、す、好きかもしれません……っ！ \n　あぁっ……！　一番奥にまで届いてる、あっ、おまんこにねじこまれてるっ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「胸を揉む手の大きさも、指の形も最高ぉお……！　……ンンンッ！？　ご、 \nごめんなさい……、あっ、だめっ、乳首刺激されたら……あっ！　あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「母乳ぅうううっ♪　母乳溢れちゃいました、噴き出しちゃいましたぁあああ \n……ッ♪　あひぃっ、ひぃいんっ！　おまんこされてると止まりません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ぶしゃっ、ぶしゃああって……あぁあっ♪　私の花の蜜が……あっ♪　母乳 \nが……！　あっ、ぁっ、だめ、だめぇ、どんどん出ちゃうぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……んんんっ！　ぼ、母乳を出している時におまんこを突き上げる、なんて \n……あっ！　その強引さ、嫌いではありませんよっ……あぁっ、いいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「おっぱいも……、あっ、んっ♪　乳首ももっといじってください……！　母 \n乳はまだまだ残っていますし……はぁっ、どんどん新しく溜まりますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「だか、らぁっ♪　あああっ♪　おまんこ突いて、おっぱい揉んで、腰、を私 \nのお尻に叩きつけて……！　あぁんっ、そうです、中をえぐってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んんん～っ♪　あぁんっ♪　あんっ、あんっ、あぁんんっ！　だめっ、だめ \nぇ♪　おっぱいとおまんこ、同時に攻められるのだめ、トロけちゃうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「やぁあああっ、貴方におっぱい揉まれるたびに、母乳が……母乳がほとばし \nってしまいます！　指でおっぱいミルク……蜜を絞り出しているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ッあああああっ♪　は、恥ずかしい……！　なのに、勝手に腰も動い、ちゃ \nうぅう……！　あっ♪　あっ、見ないでください、淫らな私を……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「いやぁ♪　やぁんっ、あぁんっ、あんっ……♪　自分から、チンポにおまん \nこをぶつけるのがやめられ、ないぃ♪　お尻を揺らすのが止まらないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁんっ、はぁんんっ♪　パンパンって音が、してる……！　あっ、だめっ \n、ま、待ってください……！　あぅっ、ちょっと待って……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……やぁあっ♪　ぜ、全然待ってくれないじゃないですかぁああ……っ♪　 \nひぃっ♪　こんなの、気持ち良くなりすぎてしまい、ますっ、あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「わた、しぃいい……っ♪　こんな場所で……！　お外で、光合成しながら… \n…っ、貴方のチンポでおまんこぐちゅぐちゅ貫かれて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「おっぱいっ♪　形が変わるくらい強く握られて、揉まれて、めちゃくちゃに \nされて……！　気持ちいいっ、気持ちいいんですっ、あっ、おかしくなるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ん～っあっあっあぁっ♪　あぁああんっ、いやぁ……♪　い、嫌じゃないぃ \nい……♪　は、ぁっ♪　あっぁっ、私のお肉、ユサユサ揺れて、るぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「なんてはしたない身体なの……！　あっ、んぁああっ……♪　ね、ねえ…… \nわかり、ますか？　おまんこの中……感じ過ぎてうねってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「愛液でヌルヌルで、びちゃびちゃなのに……さらにチンポを求めて、うねっ \nて、波打って……あっあっあっあっ♪　チンポにまとわりついてます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ、うぅうっ♪　はぁんっ、あぁ……あぁっ、あぁあんんっ……♪　え… \n…？　母乳と私の身体から……甘いいやらしい匂いがする、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ……嗅いじゃだめ、です……っ。あ、あぁああっ……！　仕方ないんで \nす、私、木の精霊……ですから、植物怪人ですからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「感じると甘い匂いになって……！　あっぁっあっあっ、男の人を誘ってしま \nう、んです、特殊なフェロモンが出て……！　すごく恥ずかしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ♪　そう、です……私、貴方に激しく愛されてっ……孕みたくなってい \nるんですっ、ねえっ……このまま中に、中に精液出してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁああっ……！　今、トロットロにとろけているこのおまんこの一番奥… \n…ここを狙って射精してほしいんです！　お願い、します……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私、もうイキますから……！　ですから一緒に、イッて……イッてください \nっ……！　あぁっ！　あっぁっ、イクぅっ、イクイクイクぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んひぃいいいいいいっ……♪　ああああああぁあ、あっ！？　あぁああッ♪ \n　あぁっ、あっあぁああああ～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「嬉しいっ……♪　嬉しいですっ、中出し……ぃっ♪　おまんこの奥の奥にた \nくさん出てる……！　あぁあっ、ドクドクチンポが脈打って……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「うふふふふっ♪　そんなに私のおまんこの中……気持ち良かったですかっ… \n…？　あっ！？　急に締まって、チンポを絞りあげてきた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ♪　それは……！　どうしても、貴方の蜜が……精液が欲しくて！　私 \nのおまんこが暴走してしまっただけですっ……！　あっ、熱い……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「た～っぷり精子を……おまんこに注いでくれて、ありがとうございますっ… \n…♪　でも、まだ……まだですよ、最後の一滴まで……あぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……んんっ……。ふぅううう……♪　あぁ……すっごく気持ち良かったです \n……♪　貴方も精液を……白い蜜を出しきることができましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あ、あの……さっき、……その……。イキながらはしたないことをたくさん \n口走ってしまいましたけど、あ、あれは盛り上がったからであって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「本当は私はそんなに卑猥な女ではなくて……、って、あっ！？　な、なんで \nすか？　お話の途中で……あっ、ま、また胸を揉みしだいたりして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ッんっ……！？　そ、それに……はぅっ！？　あっ、ううっ、んんっ……！ \n？　精液と愛液にまみれた中出し直後のおまんこを……あぁんっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「く、くちゅくちゅっ……！　ぐちゅぐちゅ掻き回して……！　っひぅうっ♪ \n　だめ……だめよ、私、ようやく我に返れたのにぃ……！　っあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「またはしたなくなっちゃう、淫らに貴方のチンポ求めちゃうぅうっ……！　 \nあぁっ……！　え？　じゃあやめてほしいのか、ですか？　……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「そ……それは……。あっ！　んんっ♪　か、考えている時にチンポ動かすな \nんて反則です！　こんなの、抗えるはず、ないぃ……！　あぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「わ、わかりました……！　認めます、認めますぅうっ！　あっ♪　したいっ \n……、私、貴方のチンポとエッチしたい！　まだ続けたい、やめたくない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「深く突き刺してくださいぃっ！　チンポっ、貴方のチンポ……！　抜いて欲 \nしくなんてありませんっ……。ずっと入れてて、動かしてくださぁいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ッあぁああああっ♪　も、もうおっぱいが制御できませんんっ……！　花の \n蜜っ……！　母乳溢れちゃう、噴き出して、撒き散らしちゃうぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あーっ♪　それが、乳首から母乳出すのが気持ち良くてたまらないんですぅ \nううっ♪　あっ、出るっ、出ます、出てるぅう、出るぅううう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ビュルビュル出ちゃってますぅううっ！　っんぅううっ♪　今です、チンポ \n、チンポも動かして……！　あ～っ♪　そこぉっ、そこ、イイですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「好きぃ……！　そこをチンポでこすられるの、好きっ……好きぃっ♪　気持 \nちいいいいっ……！　んっ、あぁっ、おっぱい、おっぱい壊れちゃうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んふぅううううっ……♪　また出ちゃいましたぁああっ♪　も、もうだめぇ \n♪　気持ち良すぎて、私も腰、止められない……蜜が飛び散っちゃうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あぁっ……あぁあっ！　はいっ♪　おっぱいっ、おっぱいの中の蜜っ……母 \n乳が空になるまで搾ってください、あっ♪　搾り出して……あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「しゅごいぃいっ♪　おまんこもおっぱいも感じ過ぎて、疼きが止まらないぃ \n……！　あぁあっ、あぁっ！　めちゃくちゃに犯してくださいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「蜜だくのおっぱいもっ♪　汁だくのおまんこもっ……全部、ぜんぶ貴方に捧 \nげます……！　私を貴方のモノにしてっ……激しく突いてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……♪　さ、さっきあんなに注いでもらったのに……っ、もうま \nた、貴方の白い蜜が欲しくなってきました……！　あっぁっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「お願いします……！　ください！　私の中に……あああっ♪　母乳が外に出 \nていった分、その分中に新しい蜜を……っ、あっ、イキますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「イクッ……♪　おまんこ強く締めますからっ、チンポからびゅーって♪　び \nゅーって精液放出してください！　あっ、欲しい、欲しいんですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んんんっ♪　んぁああああっ♪　あぁあああ……！　これですっ、あっ♪　 \nこれが欲しかったんですっ……ありがとうございますぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あああああ……！　どぴゅっ、びゅくっと貴方の白い蜜っ……。貴重な精液 \nが出ているのがわかります、奥に……流れこんでくる、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ、んんんんっ……！　あはっ……♪　精液の勢いで腰が浮いてしまいま \nす、なんて量……！　んっ、あぁ、逆流して溢れ出してしまいそう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「一滴もこぼしたくない、のに……！　んんぁあっ♪　だめっ、イクとおまん \nこがゆるんじゃうぅ……！　あっ♪　中出しされてイクッ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あッ、あああああぁああっ……♪　ふぁああああ……っ♪　あぁああんっ、 \nあっ、あぁ……っ！　んぁあああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「貴方のぬくもり……きちんとおまんこの奥で受け止め、ました……♪　あぁ \nああ……♪　うふふふ、イキすぎて腰が抜けてしまいましたよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……ん……。あ、ありがとうございます……♪　ようやく私の身体も落ち着 \nきました。ふふふふ、イキすぎて腰が砕けるなんて初めての経験です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「貴方が色々な人から誘われる理由が……私にもわかった気がします。そうで \nすよね、こんなに心地いいセックスをする人、放っておけませんよね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……ふふふふ♪　貴方も……私の身体、特におっぱいのことは結構気に入っ \nてくれたんじゃないですか？　であれば、できれば一定周期ごとに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「いいえ。気が向いたらいつでも、私と蜜の交換をしに来てくださいね♪　他 \nには何も望みませんから……どうか、どうかお願いします……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んぁああっ……♪　あっ！？　あらっ……！　私の身体に、白い蜜を……精 \n液をかけてくれるんですかっ……♪　あぁっ、あったかい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「んっ♪　中に……おまんこに注いでもらえなかったのは残念、ですけど…… \n！　こういうのも好き、ですよ……蜜を肌で感じられる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ♪　遠慮なんかしないで全部くださいっ……！　ヌルヌルの特 \n別な蜜……！　貴方の精液で白く染められるなら悔いはありませんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「っきゃっ……♪　すごい勢い……！　こんなっ……あぁんっ♪　私の肌にへ \nばりつく白い蜜……。貴方の臭いに包まれて、とっても幸せです……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「あっ、胸にも……もっとかけてください！　貴方の蜜を塗り込んで……！　 \nはぁんんっ♪　びゅるびゅるっ、びゅるびゅるって……激しいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「ああ……そうなんですね、貴方の蜜はドロドロで粘り気が強くて……♪　ま \nさに最高の白い蜜……♪　私の理想の精液です……っ、嬉しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「……ふふふふ……♪　もう少しだけ、このまま……貴方の蜜をまとって休ん \nでいたいところです……。ぬぐい取るだなんてもったいない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027401_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「木の精霊の花の蜜も、貴方の白いネバネバの蜜も……生命力のかたまりであ \nることにはかわりはありません。爆発したエネルギーそのもの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「だからそれを浴びたことは、私にとってはとっても良いことなんですよ。人 \n間の女の人だってそうでしょう？　肌がツヤツヤになったりするんだとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フライア" ]},
		{"command":[ "SETTEXT", "「私は……ものすごく元気になってしまうんです。ですから……、中に出すの \nも、外に出すのも、いいことばかりなんです。素敵でしょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_274_0104410" ]},
		{"command":[ "WAITINPUT" ]},
