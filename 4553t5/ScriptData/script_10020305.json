{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ごめん……カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「謝る必要ないわよ！　女性の部屋に、いきなり飛び込んでくる変態が悪いん\nですからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、カツマ先生は私たちを心配してくれたんですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいんだ。もう、いいんだ。同じネタを繰り返した俺がバカだったんだ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「で、こちらの皆様も、やはり戦車のプラモデルを作っておられたと。ほほう\n、こちらはＫＶ―２ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113310001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい。ソビエトの重戦車ですね。この巨大な砲塔と絶大な火力で、『巨人』\nとか『怪物』と呼ばれたそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんか、あっちと似たような流れだが、こっちは流々那が解説係か。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いいでしょ！　強そうな形が気に入ったのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうですかそうですか。それでこのプラモを使って、ミス・パープルのとこ\nろのマシンで遊ぼうってわけですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あら。あなた、あのマシンを知ってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええ。今日ちょっと遊んでみました。なかなか面白いですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「へえ、そうだったのね。……そうね、チームにひとり、経験者がいるとなに\nかと便利ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……へ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「決めたわ。カツマ、私のチームに入りなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「カツマが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマ先生が……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あの、お嬢様？　ちょっと待ってください？　俺はいちおう、放課後も\nいろいろ仕事とかありましてね！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「カツマ！　やろう！　模型シミュレーション！　いっしょに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113310003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「先生！　乗ってください！　私たちの戦車に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　なんだ！　なんなんだよ、おまえたちまで！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いいじゃないの。はい、決まりね。それじゃ、このプラモデルは明日までに\n作っておいて。おやすみ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　なんでいきなり俺が作ることになってんですか！　姫様！？　おー\nい！　姫様っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「いつまでここに居座る気！？　ここはレディの部屋なんですからね！　さっ\nさとそれ持って、自分の部屋に帰りなさいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そりゃ帰ります！　帰りますけど！　せめてプラモを完成させるの、\nあと３日ほど待ってーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "結局、待ってもらえなかった。プラモを徹夜で組み上げるハメになった……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　しっかりしなさいよ！　対戦相手が来たわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう言われましてもね、こっちは寝てないもんで……ふぁああああ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「皆さん、お待たせしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113310001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お、みんとが来た。チームメイトはハルカプトラの部下たちだが、この前対戦\nした連中とは違う子たちのようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「来たわね！　それじゃ、さっそく始めましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310009" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「ええ！　正々堂々勝負です！　いいですか、皆さん、私が勝ったら、Ｇ・ル\nナリアム幹部の座は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113310002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そんな話はあと！　それじゃミス・パープル！　はじめてちょうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310010" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あ！　ちょ、ちょっと待ってください！　幹部の座は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113310003" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「模型シミュレーション、ゴー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310011" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あー！　もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113310004" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "と、いうわけでここはシミュレーション空間。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那はさっそく双眼鏡で、あちこちを真剣に見回している。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「皆さんも、偵察をお願いします。みんとさんたちの戦車を、なんとしても先\nに見つけないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　そんなにみんとたちの戦車は強いのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ええ。あちらの戦車は『タイガーⅠ型』。とても強力な戦車です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310007" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なるほどなるほど。ティーガーといえば、今も昔もモデラ―人気はダントツ\nですからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113310002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「タイガー戦車なら、俺も聞いたことあるぞ。手ごわそうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「動きの鈍いこちらは、とにかく相手を先に見つけないと勝ち目がありません\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113310008" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「みんと殿は、なかなか車種選びにそつがないようですな。これは侮れません\nぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113310003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「いた！　３時方向！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113310004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほんと？　あ！　いた！　よーし、見てなさい！　先に一発お見舞いしてや\nるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113310012" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}