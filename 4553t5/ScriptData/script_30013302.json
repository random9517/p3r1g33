		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ……また……奥っ、入ってぇ……！　あっ、あぁっ、ダメだっ……ア \nナル緩んじゃうっ……また、出てきちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、チンポっ……激しくぅっ……！　すごいっ、オマンコでっ、アナル \nでもっ、どっちもイキたくなってるっ、くぅっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000133_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ……ち、近いんだな？　このままっ、一気に出してっ……また、あ \nぁっ……熱いザーメンっ、ビュクビュクさせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私も一緒にイクからっ！　ヴァルキリールナテミスがっ、チンポに分からさ \nれてオマンコッ……ケツ穴でもイクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、あっ、あぁぁぁっ、イクッ……あひぃっ、バイブ激しくなって \nっ……ひぃぃぃぃんっ、イグぅぅぅぅぅっ！」", "NORMAL" ]},
