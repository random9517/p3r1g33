		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっふっ、あぁっ、こんなちょっとだけのことで……こんなにも、変わるの \nか……は、ふっ、んぐっ、あっ、うんっ……！」", "NORMAL" ]},
