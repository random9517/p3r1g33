		{"command":[ "SETIMAGE", "0", "still_00000133_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私も……もっとオマンコを締め付けるように……？　だ、だが……バイ \nブが、あっ、ふ、震えて……いや、や、やってみる……」", "NORMAL" ]},
