		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……いつもと違う感じでと頼んだが……ここまで乱れさせられるとは思 \nわなかったぞ……はぁ、んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ヴァルキリーとしての感度が……ここまで高くなるとは思わなかったからな \n……あいつらも、かなり大変なのかも知れないな……」", "NORMAL" ]},
