		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ……まぁ、私も……ヴァルキリーの姿になってはいるが、これがいつま \nで続けられるかは分からないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304102" ]},
