		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、んふっ……はぁぁ……熱いのが……いっぱい浴びせられてぇ……鎧 \nがザーメンまみれにされていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_3304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んくぅ……もっとだ……もっと浴びせてくれ……ザーメンマーキングで、私 \nを完全なメスにしてくれぇ……はひぃ……」", "NORMAL" ]},
