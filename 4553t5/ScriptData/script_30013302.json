		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……こ、ここからもっと速くする……のか？　くっ、ふっ…… \nあぁ……だ、大丈夫だ……多少激しくなっても……あっ、ぉっ！」", "NORMAL" ]},
