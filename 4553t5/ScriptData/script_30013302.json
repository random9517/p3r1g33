		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ、んぁっ、くふぁぁっ！　抉れてくるっ……あぁぉっ、チンポ \nっ……ズリズリっ……オマンコの壁、こすれるぅっ！」", "NORMAL" ]},
