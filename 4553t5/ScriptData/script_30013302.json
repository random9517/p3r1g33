		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はふぁ……お、終わった……？　んんっ……全部出しきったのか……そう、 \nなんだな……？」", "NORMAL" ]},
