{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "俺たちはビルの中に乗り込んだ！", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あっ、あそこにいるのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「うふふ～、よしよ～し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020001" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あら？　かわいいお客さんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえ、この前チラシを配っていた保育士だな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そういうあなたは……も、もしかしてカツマくん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020003" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「な、なんてこと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "目を見開いた保育士が、俺に近づいてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ……おい、こいつの様子がおかしいぞ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、次の瞬間。俺は抱きしめられていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁあああぁぁぁんっ！　なんてこと、なんてことなのぉおおおぉぉぉっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020005" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「こんなだぼだぼの軍服きちゃって、しかもおめかしなんかしちゃってぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「かわいいっ、かわいすぎっ、もうたまんないわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「これから迎えにいくところだったのよ。でも、カツマくんのほうから来てく\nれてマキママ嬉しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「さあ、これからマキママが思いっきりお世話してあげるわね。ご飯のときも\n、お昼寝のときも、おトイレだってマキママが一緒よぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおっ、おいっ、苦しいって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマから離れな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020002" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「きゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020010" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「た、助かったぜエファナティカ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく。あんたも少しは抵抗したらどうなんだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020003" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「できるわけないだろ。この対格差なんだから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「一緒にいる子は、とてもお転婆さんなのね……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020011" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あっ、青肌幼女！？　青肌幼女よ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020012" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょっ、なにするんだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020004" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今度はエファナティカがハグされる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ、いつの間に術をかけたのかしら。まさか青肌幼女に会えるなん\nて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020013" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「しかも、強気なツンツン系なのね。素晴らしいわ。そういうのもいいわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あなたのことも、マキママがしっかりお世話してあげるからねぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うるさいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020005" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エファナティカが自力で保育士の抱擁から抜け出す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんた、さっき術とか言ったね？　あたちらをこんな姿にしたのは、やっぱ\nりあんたなんだね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「気づかれちゃった？　そうよ、あなた達をキュートな姿にしたのは私よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020016" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「術を使った相手とこんなにすぐ出会えるなんて。なら、話ははやいね。さっ\nさとあたちらを元の姿に戻しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020007" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さもないと、痛い目をみるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ！　なあ、鳳雛！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……と、鳳雛の姿が見当たらない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつ、またどこかに消えやがった！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「鳳雛殿なら、ここに乗り込むときに別ルートで犯人を捜してみると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010023020001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あいつ、肝心なときに……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあいいよ、こんなやつ、あたちらだけで十分だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020009" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あらあら、お姉ちゃんと戦うつもりなのかしら？　そんなイタズラをする子\nは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020017" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんも、ちょっと本気で相手をしてあげるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "保育士が変身した！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんた、いったい何者だい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020010" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「操年魔術師、マキ・アーリスターよ。ふふ、よろしくね。カツマくんたち♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020019" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの名前には興味ないね。さあ、いくよ。あたちの魔法で……えっと…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020011" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、どうしたんだエファナティカ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うるさいねぇ！　ちょっと術の使い方をド忘れしただけだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010023020012" ]},
		{"command":[ "SETCHARA", "0", "char_00000316_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それ、本当にド忘れかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020020" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エファナティカが言っていたことを思いだした。こどもの姿にひっぱられ、記\n憶が消えかけているのだ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "このままでは、俺もやばい。こんなときに鳳雛は頼れないし、いったいどうす\nれば……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「おまたせふたりとも！　この保育園にあった研究室っぽいところで、こんな\nのを見つけたよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023020001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこへ、鳳雛がやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、あれは研究中の成長化薬……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_010023020021" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「成長化薬だって！？　でかした鳳雛！　そいつを使えば、元の姿に戻れる！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「わかった！　これを飲むんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010023020002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鳳雛が投げた薬を、俺は飲みこんだ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……これは……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}