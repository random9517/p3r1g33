{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0187" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「待っていたぞ、旦那様よ。待ち焦がれた結婚初夜、最高のものにしようでは\nないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほれほれ、何をボサッと突っ立っておる。そこのベッドに寝そべるがよい。\nもう、すっかりその気なんじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ……ムードに欠けるか？　予とお主の間は、これくらいの感じがよいと\n思ってな。じゃが、今日は特別じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「旦那様特権として、特等席で余のご奉仕を見せてやるからな。ふふ……どれ\n、上に乗るぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほうら……どうじゃ、これが旦那様だけが見ることができる特等席の眺めじ\nゃ。この景色……どう思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000703_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふふ……生唾を飲む音が聞こえたぞ？　全く分かりやすい奴め……おぉー\n、オチンポもムクムクと起き上がって……これが答えか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どれ、つんつんと……ほほう、感度も良好……これからされることに期待し\nて、分かりやすく震えているようじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「分かっておる、今日は初夜なのじゃからな……回りくどいことはせず、特別\nなご奉仕を味わうがよいぞ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、んちゅぷ……れろ、ちゅぽっ、くぷっ、んふっ、はぷっ、んりゅっ\n、れろ……えろぉ……れろ、れろんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、口の中で更に大きくなってきておる……んぷぁっ……相変わら\nずヤンチャなオチンポじゃ……可愛い奴め……れろ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「えろ……んりゅっ、今日は……オチンポがふやけてフニャフニャになるまで\n、れりゅっ、舐めて舐めて、舐め尽くしてやろうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、ちゅぷぅぅっ……亀頭はもちろん、この皮の隙間……れる、少\nしカスが残っておるな……れる、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふ、よいよい……こうして綺麗にするのも新妻たる余の務めじゃ。旦那様\nは、もっと悠然と身を任せておればよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、んちゅっ、あぁ……この小便臭さの残るオチンポの味……れろ、り\nゅぱっ……余が独占しておるのじゃ……じゅるっ、ちゅぶっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅ……くぽっ、舐めれば舐めるほど、愛しさが増して……ちゅぽっ、も\nっと……尽くしたくなる魔性のオチンポじゃ……ぴちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……れろ……んむっ！？　んんっ……オマンコ……待ちきれなく\nなってきたか……？　んっ、指が届く……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふんっ……面白い……ならば、どちらが先にイッてしまうか……一勝負し\nてみるか？　じゅるっ、くぽっ、んふっ、りゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「先にズルい……？　くくっ、真剣勝負にズルいも何もないわ。んっ、じゅぽ\nっ、余は旦那様のオチンポを愛でる……それだけよ……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んちゅっ、、ちゅぷぅぅ……ほれほれ……カリ首へのキス……気持ちいいじ\nゃろう？　んっちゅ……ぴちゃ、ちゅぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ここにキスマークを付けるのは難しいが……その代わり、たっぷりと唾液を\n塗り込んで、この感触を忘れんようにさせてやるぞ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ！　あふっ、んちゅぷっ……反撃が始まったな……余の割れ目を……\n指でくぱっと開いて……んっ、汁が……垂れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「岩清水のように……飲むつもりか？　んんっ、あぁ……いいぞ……もっと直\n接粘膜を触ってくれて構わん……ふ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「オマンコ汁が溢れて来る……当然じゃ……んっ、旦那様のオチンポを舐めて\n、中が疼かん筈がなかろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　あぁっ、ペロペロされるぅ……んっ、くぅぅぅっ……スジを\n……舌が這い回っておるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぽっ、んふっ、なんの……余も、れろ……んりゅっ、ペロペロするぞ…\n…れろ、はぁんむっ、オチンポ……汁まみれにするからの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、りゅぱっ……はぁんむっ、夫婦の共同作業じゃなっ……オチンポ\nと……オマンコをペロペロしあって……気分を高めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「溢れ出す……汁を吸いあう……あぁ……んちゅぷっ、りゅぱっ、ゾクゾクす\nる……快感じゃ……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぁっ、ちゅぷっ、旦那様のオチンポの先からも……エッチな汁がじわじわ\n浮いてきたぞ……早速いただかなくてはな……ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふっ、りゅぷっ、くぷっ、んちゅぷっ……もご……んりゅっ、れろぉ……\nあぁ……クリトリスにも……ツンツン……刺激が届いて来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁ、そこがいい……余の、好きなところじゃ……もっと、いっぱ\nいイジメてくれ……はっ、ひぁっ、あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふっ、んっく……この遠慮のなさ……これこそ、余が求めていた快感よ…\n…はぁんむっ、先走り汁……美味いぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あふっ、オマンコ汁も……美味いか……？　ふふ……好き嫌いのない旦那様\nで何よりじゃ……あっ、んちゅぷっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んちゅぷっ……はぁ……あぁ……一段と震えが大きくなってきた\nぞ……れろ、えろぉ……んぱっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「このまま行けば……この勝負は余の勝ち……んんっ！？　あっ、オマンコッ\n……激しく吸い付いてっ……！　あくぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ、分かったっ……引き分けでよいっ！　一緒じゃっ……一緒にイこう\nっ、りゅぷっ、このまま……一緒にっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「うむっ、飲むぞっ……全部飲むっ！　出された精液はっ、全部飲むからっ…\n…出せっ、じゅぽっ、りゅぷっ、射精……早くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんんんっ……！　ふぐっ、んんっ、んんっ……こくっ、んくんっ……あぁ\nっ……溢れておる……んんっ、甘露じゃ……じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はふぁ……余の……オマンコ汁も飲んでくれている……あぁ……気持ちいい\nのじゃ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、はぁ……うむ……全部飲んだぞ。流石は我が旦那様……この濃厚\nさはそうそう他では味わうことはできまいて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ともあれ……何とも密度の濃い引き分けじゃったな。この勝負……なかなか\n楽しめたぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おっと……そんなことを言っておったら、またオチンポがいい具合に震えて\nきたではないか。やはり、きっちり決着をつけないといかんとな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふむ、任せておくがよい。一発出した程度では収まりのつかぬオチンポ……\nもっともっと蕩けさせてやるぞ……ちゅぽんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぽっ、りゅぷっ、んじゅぷっ、んふっ……オチンポにザーメンの味がたっ\nぷり残っておる……んりゅっ、えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ぴちゃ……あぁ……自然に舌が出て……止まらぬわ……美味よ\n……美味……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ……む！　旦那様の方も……ただ身を任せるだけというつもりはなさそ\nうじゃな……んっ、余のオマンコが……広げられていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はあぁ……ん、一度……イッた後だからな……汁が……あっ、出やすくなっ\nて……また……溢れてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あふっ……遠慮はいらぬぞ……舐めたければ、存分に舐めるがよい……余も\n、じゅぽっ、遠慮するつもりはないからな……りゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぐぽっ、ちゅぶっ、んぶっ、ちゅばっ、じゅぱっ……んふぅっ……やはりオ\nチンポは、品なく、貪るようにしゃぶるのが一番じゃの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぶっ、口の周りをよだれまみれにさせて……生々しい音をさせて……亀頭\nを啜るっ……んじゅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、口の中に広がる、この雑味……んりゅっ、余の……唾液と絡ませ\nて……最高の滋味となるのじゃ……んじゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぷっ、オチンポもよう震えておる……ふふっ、この裏筋のところがいいの\nか？　全く可愛い奴め……んちゅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「れろぉ……んっふ、ちゅぷっ、んぁっ……くぅぅ……味の濃いところが……\n特にピクピク震えておるわ……んちゅぷっ、れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれ……んんっ、この正直なオチンポはまたそろそろイキそうなので\nはないか？　んっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんぅっ……！　あぁ……余のオマンコも正直か……違いない……んっ、今\nのスジを舐められただけで……勝手に腰が跳ねてしまったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よいぞ……もっとしてくれ……はぁうっ！　そうじゃっ……あぁっ、旦那様\nの柔らかい舌の湿り加減が絶妙じゃ……く、はぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅぷっ……れろ、えろぉっ……余も……はぁ……んっ、もっと舐\nめるぅ……オチンポぉ……ペロペロするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、りゅぶっ、んふぅっ……あぁっ……またイキそうじゃ……くぅっ\n、こんなにも早く次が来るとは……んんっ、くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まだじゃ……んちゅっ、もっとオチンポの弱いところ……んりゅっ、責めて\n……余も……負けぬっ、じゅるっ、んちゅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「先にイカぬっ……オチンポ……我慢するでないぞっ、イクのじゃっ、じゅぷ\nっ、早くっ……イケっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、あぁっ、も、もうっ……来るっ……！　オマンコっ……良すぎ\nてっ……飛ぶっ！　ほぉぅっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「むふぅぅぅんっ！　むっ、ぐぅぅぅっ……おぶっ、あっ、ぷっ、じゅぷっ…\n…んぐぅぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ、前より……多い……！　んぐっ、こくっ……んんっ、あぁ……んっ\nく……こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぷぁ……全部飲むのも……はふっ、一苦労じゃ……んんっ、じゃが……この\n味なら……いくらでもいける……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んちゅぷ……んっ、こくっ……んっ、ふぁぁぁ……はふっ……はぁ、はぁ…\n…んっ、はぁぁぁ……ん、飲んだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……最高の味わいじゃ……はぁ……この間に何回イッたことか……\n今回は、余の負けかも知らんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なに……？　同じタイミングでイッたから……引き分けだと？　ふふ……そ\nういうところは旦那様の優しさだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「待っておれ……余にオチンポのお掃除をさせてもらう……ちゅぷっ……ぴち\nゃ……んちゅっ……れる……れろ……えろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余を満たしてくれるオチンポ……誠心誠意、舐めて綺麗にしてやらんとな…\n…ちゅぱ……ぴちゃ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んんっ、こら……まだオマンコを悪戯するでない……んんっ、しょうがない\n奴め……んんっ、うむ……これでよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「礼には及ばぬ。余の気持ちじゃ。これからも末永く一緒なのじゃからな……\nオチンポ……いや、旦那様の方もな。くふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁっ！　あぷっ、顔にっ……あっ、直接掛かって……はぁぁぅん\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぷっ……ふぁぁ……ドロドロザーメンが……どんどん出てくる……んっぷ\n……はぁぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ、オスの強烈なフェロモンが余を浸していくぅ……余が、チンポ汁…\n…精液にメロメロにされていくのじゃ……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000703_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁぁ……粘っこい……指でいくらでも広げられそうな、精の塊じゃ……あ\nぁ……終わってしもうた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んむっ……うむ、美味い……あふ……こうして直接飲まず、指で\n何度も掬いながら味わうのも乙なものじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「とは言え、思い切りイカされて……勝負としては、いささか不本意な結果に\nなってしまったな。もっと余が一方的にできると思ったが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、それだけ頼もしい旦那様ということか……ふふ、どれ後始末をさせて\nくれ。オチンポ……丁寧に清めてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ちゅぷ……さすがに少し疲れたろう……れろ、優しく癒やしてやる\nからの……れろ、んりゅ……れる……んちゅうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……んふっ……後始末の間もオマンコを弄ってくるとは……\n本当に根っからのスケベじゃの……お主も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まあ、それでこそ余の永遠の伴侶よ。これからも、末永く愛し合おうではな\nいか……んちゅっ、なぁ……オチンポもな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_0303410" ]},
		{"command":[ "WAITINPUT" ]},
