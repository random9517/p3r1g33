		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「別に、二人でいることもあるし……やっぱり、これからすること考えて……\nドキドキしちゃうのかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、今日は……ご奉仕したいなって……色々してあげたいこと……いっぱ\nいあるけど、何かリクエストとか……ある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……おっぱいで……？　そういう……うん、うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403104" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱりエッチだよね……ううん、いいの、別に分かってたことだし……そ\nれでも、ちょっと思っちゃっただけ。いいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403105" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゃあ……はだけて……そこに寝たらいいかな……？　んっ……ちょっとだ\nけ、あっち見てて……脱いでるとこ、恥ずかしいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403106" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、もういいよ……こっち……見て、大丈夫……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000214_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……あは……や、やっぱり、これ……恥ずかしい……見せるの初めてじゃな\nいけど……ドキドキする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いいよ……触って……あっ、うんっ……んふっ……ぎゅっと力入れて……揉\nんでも大丈夫だから……うんっ、むにゅって……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……強くていいのに……何だか、すごく優しくされてる……それだ\nけで、あぁ……顔がにやけちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね……オチンチン……もう、待ちきれないんじゃない？　いつでもいいよ…\n…私のおっぱいも、オチンチン感じたがってるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぅ……んんっ、あぁ……熱いの……ずぶって入って来た……ふぁ……谷\n間の中……汗かいちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふふ……言い方がオマンコみたい……？　だって、今日の私のおっぱいは\n……オマンコと同じだから……ほら、こうやって絡みつく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、んふっ……むにゅうってすると……オチンチンに響くでしょ\n？　もっと、おっぱい感じて欲しい……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、んくっ……はぁっ、んっ……どうかな……？　柔らかい……\n？　んふ……いっぱい挟んだげるね……んっ、あっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……こうして見上げると……オチンチン……すごい迫力……目\nの前で、亀頭がすぐそこに来てるの……ドキドキする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん……いいよ、腰……振って……。私もおっぱい寄せて……一緒に動かし\nていくね……これ位の速さ……かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、オチンチンとおっぱい……揉みくちゃになってる……とく\nんって脈打ってるところに……押し付けるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　んっ、あぁっ……乳首……かなり敏感になっちゃってる……\nんぁっ、くっ……あっ、コリコリされてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ……うんっ、私も……感じてるの……オチンチンと同じよ\nうに……勃起しちゃってる……んっ、あふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うぁ……先っぽから……むわっと濃い匂いしてる……んっ、はぁ……ねぇ…\n…もっと近づけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、すぅぅぅっ……ふぁぁっ……もう我慢出来ない……させて、オチンチ\nン……おしゃぶりさせてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁんむっ、ちゅぷっ……れろ、えろ……れろ、れろぉ……れろっ、れろん\nっ……んっ……えろぉ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んぁっ……少しおしっこの匂いする……んっ、オチンチン……ち\nゃんと綺麗にしてる……？　んっ、男の人って拭かないんだっけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「しょうがない……私が綺麗にしてあげるから……れろ、ぴちゃ……んっ、あ\nぁんむっ、くぽっ、んっ、ちゅぷ……りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はふぁ……むぐぅっ……んふっ、じゅぽっ、くぷっ…ダメだよ……清潔にし\nてないと……カスが溜まったりなんてダメなんだから……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、私が……お世話してあげないと……ダメかも……りゅぱっ……ん\nふっ、あぁっ……んちゅっ、ぴちゃ……あむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふ……お口のらか……感じる……？　んっ、今日は……口もオマンコらか\nらね……ちゅぷ……あぷ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコに……お口マンコ……全部使って、オチンチンしてあげるか\nら……いっぱいご奉仕楽しんでね……れる、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、んぱっ……カウパー出てきたね……んっ、ちゅぷっ、ふふ……こぼ\nしちゃうの勿体ない……れろ……れりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「大分……いい感じ……？　じゃあ、咥えたまま……おっぱい……ふるね……\nんっ、んふっ、んりゅっ、んっ、ぁっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……んちゅぷっ、あぁ……んっ、ビクビクひてるっ……んっ、オチン\nチンっ……喜んでくれてる感じ……っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……もう出ちゃいそう……？　んりゅっ、飲みたい……貴方の\n新鮮な精液っ……ごっくんしたいのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、りゅぷっ、らひてっ……このまま……貴方の搾りたてオチンチン\nミルクぅっ……いっぱいっ、いっぱい、のまへてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ……！　んぐっ、こくっ……んんっ、んふっ……ぁっ……れ\nて……るぅんっ……ぷぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁ……れて来た……んっ、いっぱい……ザーメン……こくっ、じゅぷっ、\nんぷっ、あくんっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……おいひぃ……んっ、あなたの味がするの……んちゅぷぅ……喉に\nいっぱいまとわり付いて……濃すぎるのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、ぷぁっ……ふぁ……はふっ……はぁ……はぁ……ぺろ、ぴちゃ……口\nの周り……ついちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、掬って……そのまま舐めさせて……んふっ、ちゅぱっ、れろ……ぺ\nろ……ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はふ……んんっ、何だか催淫効果がありそうな……そんな感じ……まだ、頭\nがボーッとしちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あふっ……オチンチン……どう……？　まだ、続きできそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふ、愚問だったみたいね。ビクビクって反り返ったまま……今も、元気い\nっぱいって感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、させて……このまま２回戦……まだまだ、射精出来るんだから……頑\n張ってもらわないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱい寄せるね……ぎゅうって……あふっ……あぁ……また、ちょ\nっと精液垂れて来た……このまま、おっぱいにまぶしちゃうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、そしたら……とろって絡ませて……おっぱい……前後に、寄\nせて……戻すっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どう……？　こういうのも……気持ちいい？　ビクって浮いてる血管……こ\nちょこちょって……くすぐっちゃおうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひゃっ……！　オチンチン、ビクって……んふっ……やっぱり弱いところだ\nった？　ふふ……この反応、すっごく可愛い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん……また、食べちゃいたくなっちゃったから……お口……もう一回咥え\nるね……んぁむ……くぽっ、んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んんっ、れろ……えろ……んちゅぷっ……あぁ……精液の味が濃\nくなってる……んちゅぷ、美味しい……オチンチンの味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、あふっ、舌が止まらないの……れる、える……れろ……れりゅ\n……んりゅっ、れろ、れらぁ、んえるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、貴方も……遠慮なく動いていいから……私のおっぱいマンコ……犯\nしたくなってるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……ふっ、そう……オチンチンとおっぱいが……擦れあって…\n…乳首が、どんどん硬くなっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひぅっ！　あっ、指で転がされるの気持ちいいっ……あぁ……んちゅぷっ…\n…先っぽの敏感な場所……お互いにするの……すごくいいのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、ちゅぷっ……はぁ……んっ、一緒に高めあっていくの……夫\n婦の共同作業って感じがして……すごく嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、貴方も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「また……んっ、先走り……出てきた……ちゅぷっ、後少しだね……私のおっ\nぱいで……もっともっと気持ちよくなってっ……はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、れろ……じゅぷっ……もう、出ちゃう……？　んっ、いつでも……い\nいからね……２発目……いっぱい出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ……お口マンコの中出しがいい……？　それとも、お顔と……おっ\nぱいマンコにぶっ掛けする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私は……どっちでも嬉しいから……じゅぷっ、貴方の……りゅぷっ、したい\nようにっ……ひてっ、いいからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「気持ちいいのっ……どぴゅって……またっ、いっぱい来てっ……りゅぷっ、\nじゅぷっ、濃厚ザーメンっ……ドピュドピュしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んむぅぅぅっ……！　ふぐっ……んんっ、ごくっ……んくっ、んくっ……こ\nくっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁ……また、いっぱいっ……ドピュッとしてる……んちゅぷっ……この勢\nい……んちゅぱっ……飲みきれない位……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こくっ……んくんっ、んはぁぁ……やっぱり催淫効果がある……この精液…\n…んちゅぷぅぅ……頭……トロトロになるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、んっ……ふぁっ……ちゅぷ……ぁっ……んっ、後もう少し出そう\n……？　うん、吸い上げるね……んじゅるるるるるーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じゅるっ……んっ、お行儀悪い音させちゃってるね……んちゅぷっ……でも\n、止められないの……んじゅるっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だって……まだ残ってるし……んちゅぅっ……奥の奥まで吸い上げないと…\n…オチンチンから漏れちゃうもの……んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふはっ……はぁ、はぁっ……んっ、やっと止まった……んっ、後は鈴口の割\nれてるところ……綺麗にするね……れろ、ぺろ……えろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、はい……ちゅぱっ……ちゃんと元通り……いっぱい出してくれて、あ\nりがとう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふ……どういたしまして。オチンチンのご奉仕をするのは、花嫁の特権だ\nもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「これからも、浮気が出来ないように……徹底的に搾り取っちゃうから……そ\nのつもりでね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「きゃぁうっ！　んぁっ……あっ、飲まなくて……いいのっ……はっ、んんっ\n……あぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ぶっ掛けたいのね……もう……しょうがないんだから……んっ、あぁ、顔に\nも……おっぱいにも……ネバネバがいっぱい出てるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……この匂い……吸い込んじゃったらもう……私……完全に支配され\nちゃうからぁ……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……おっぱいに掛かってる方も凄い……んっ、オチンチンの先で\n……塗りつけて……ヌルヌルにさせてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んちゅぷ……汁が亀頭から垂れて来てる……んちゅっ……ぴちゃ……ちゃん\nと味わわせてぇ……れろ、ぴちゃ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もうすぐ出し切っちゃう……？　うん……スッキリしましょう……後は、舌\nの上に直接……来て……んぁっ……ぷ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅるっ……んっ、ありがと……じゃあ、最後に……お掃除しちゃ\nうから……れろ……ぺろ、んちゅぷ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、これでいい感じ。んふ……身体中精液まみれにされちゃった……でも\n、このマーキングで、私は貴方のモノにされた感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ、もちろん逆の意味もあるけど……そう、このオチンチンはもう私の\nモノだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「射精したい時はいつでも言ってね。オナニーの必要がないように、ちゃんと\n処理してあげるから……ね」", "NORMAL" ]},
