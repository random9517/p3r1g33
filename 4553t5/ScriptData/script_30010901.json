{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "001_0903101" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……おい、来たぞ。こんな部屋にまで呼び出して……一体、何の用事だ？　 \n早く鍛錬に戻りたいのだが……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903102" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……奉仕？　まさか、貴様……私に女中のような格好をさせて、甲斐甲斐し \nく身の回りの世話をしてほしいと……そんなことを言っているのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903103" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや……べつに怒ってはいないのだが……まぁ、いいだろう。貴様には \n世話になっているしな。それで……どうすればいいのだ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903104" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと……？　Ｈなご奉仕……？　貴様の男性器を私が口に咥えて、気持 \nちよくする、だと……き、貴様……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903105" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや……だから、怒ってはいないのだが……私はそんなに、怖そうに見 \nえるだろうか……そんなに怯えられると、少し傷つくぞ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903106" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ごほん……まぁ、それはいい。しかしだな……その……私がそんなことをし \nたところで、貴様は嬉しいのか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903107" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……まったく、相変わらず破廉恥な奴め……いいだろう。貴様が \n喜ぶのであれば、私が……え、Ｈなご奉仕とやらをしてやろうではないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903108" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ただ、その……私も、そういうことは初めてだから、やり方がわからなくて \nだな…………どうすればいいか、教えてくれるか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0903109" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「おぉ……これが男性器か……初めて見たが、ずいぶんと大きいのだな……思 \nったよりも固くて、熱くて……なかなかに雄々しいではないか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903110" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それに……すん、すん……あぁ……すごい匂いがするな……これが男の…… \n雄の匂いか……ふふっ、貴様のモノだからか……存外、嫌いではないぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903111" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それで……これを舐めればいいのか……？　す、少し恥ずかしいが……偉大 \nなる月の民の末裔たる私に二言はない……ええい、ままよ……あむっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903112" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……先っぽのところは、思ったよりつるつるしているのだな… \n…れろ、れろっ……亀頭、だったか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903113" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「このところを、舌を動かして……ぺろ、ぺろっ……アイスのように……ぴち \nゃ、ぴちゃ、れろぉっ……舐めればいいのだな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903114" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あとは亀頭の裏側の……裏筋？　ここにも舌を押し当てて……れるれるっ、 \nれるっ……小刻みに、擦るようにして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903115" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「れるっ、ちゅるっ……このでっぱった段差のところは……雁首というのか… \n…？　ここに舌を巻きつけながら、れりゅ、れりゅりゅっ……擦って……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903116" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「おぉ……オチンポがびくびく暴れているぞ……れりゅれりゅっ……気持ちい \nいのか……ふふっ、そうか……ならば、もっとしてやろう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903117" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「れりゅ、ちゅるるっ……オチンポがヌルヌルになったら、唇を締めつけなが \nら……あむっ、ぐぷ、ぐぷぷっ……奥まで咥え込んでいくんだろう……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903118" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐぷっ、じゅぷぷっ……咥えながら、裏筋に舌を広く押し当てて……れりゅ \nれりゅ、ぢゅるっ……包み込むように擦って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903119" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぷぷっ、れりゅれりゅっ……奥まで咥えたら、軽く吸い込みながら…… \nじゅずずずっ、じゅぢゅっ……口を密着させて、前後に動かす……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903120" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぷっ、じゅぷっ……どうだ、気持ちいいか……？　じゅぷぷ \nっ、じゅるっ……私のフェラチオはうまくできているか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903121" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふっ、いいぞ……私の口で、じゅぷっじゅぷっじゅぷっ、もっとオチン \nポを気持ちよくしてやるからな……じゅぷぷっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903122" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「口の中でオチンポをシゴきながら……れりゅりゅ、れりゅっ……舌も動かし \nて裏筋も、れりゅりゅ、ぢゅりゅっ、舐めてやろう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903123" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぷっじゅぷっじゅぷっ、亀頭の先っぽのここも……れろれろれろ……ふ \nふっ、弱いのだろう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903124" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「雁首のところも、れりゅれりゅ、れりゅっ、舌で舐めながら、ちゅぱちゅぱ \nちゅぱ、オチンポをしゃぶってやるからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903125" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ、れろれろれろっ……むっ？　匂いが強くなって……れろれろ \nっ……先っぽの割れ目から、何か出てきているな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903126" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「味も、濃くって、れろ、れろぉっ……先走り汁？　オチンポが気持ちよくな \nると出てくるのか……ふふっ、そうか……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903127" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ならばもっと激しくオチンポをしゃぶってやろう……じゅっぷじゅっぷじゅ \nっぷ、もっと先走り汁を出すがいい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903128" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅっぽじゅっぽじゅっぽ、オチンポを口でシゴきながら、じゅるるっ、れ \nりゅれりゅっ！　たくさん舐めてやるからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903129" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽっじゅぽっじゅぽっ……んむっ？　亀頭がパンパンにふくらんできて \n……じゅるるっ、オチンポがどくどくと脈打っているぞ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903130" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「イく……出る……？　じゅぷっじゅぷっじゅぷっ、じゅるるるっ、よくわか \nらんが、またさっきの汁が出るのか……？」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903131" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと濃くて美味しいミルクが出るのか？　じゅるるっ、じゅぽじゅぽじゅ \nぽっ、それを飲めば良いんだな……じゅぷっ、れりゅりゅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903132" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「たっぷりと出すがいい、じゅぽっじゅぽっ、れりゅりゅっ、私にフェラチオ \nをされて、気持ちいいミルクとやらをたくさん出せ、じゅちちゅううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_08" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0903133" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぶっ！　んんっ、んぐうっ……！　なんだ、これは……んうぅぅぅっ！　 \nんっ、んんっ、んぐぅううううっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903134" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「熱くて、濃いものが、んぐっ、んうぅっ、こんなにたくさん……！　口の中 \nにおさまりきらない、んぶぅっ、あふれてしまうっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903135" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぐっ、んんぅっ、んぐぅっ、どろどろしていて、飲みにくいぞ……！　ん \nぐっ、んぐぐっ……ごくっ、ごくっ、ごくっ……ぷはぁっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903136" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……今のが美味しいミルクとやらなのか……？　まだ口の中がべ \nたべたするぞ……それに、青臭くて、イカ臭くて……すごい匂いだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903137" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「精液……？　まさか貴様……この私の口に大量の精子を出して、それを飲み \n込ませたというのか……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903138" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや……怒っているわけではないのだが……その……は、恥ずかしいで \nはないか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903139" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様のオチンポを咥えて……濃くてドロドロとした精液を口の中に大量に出 \nされてしまい……それをごくごくと音を立てながら飲み干したなどと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903140" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「今もまだ口の中に味と匂いが残っている……熱くて粘っこくてイヤらしいザ \nーメンが私の身体の中に入ってしまったなどと……はぁぁ……破廉恥だ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903201" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「む……飲みきれなかった精液がオチンポに垂れてしまっているな……仕方が \nない、キレイにしてやろう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903202" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、じゅるるっ、れる、れろっ、ぴちゃっ、あぁ、やはりすごい匂いだ… \n…味も濃くて、んふぅ……頭がくらくらしてくる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903203" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ぴちゃ、ちゅるっ、んっ……ネバネバして、飲みにくい……んぐっ \n、こくっ……はぁ、精液が喉にはりついて、ぺたぺたする……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903204" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「れろぉっ、ちゅるっ、じゅるるっ、ちゅぽちゅぽっ、んっ、ぐっ……こくっ \n、ごくっ……ぷはっ……うむ、キレイになったぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903205" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……心なしか、またペニスが固くなっているような……もしや貴様、まだし \nたりないのか……？　まったく、破廉恥な奴め……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903206" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかたがないな……いいだろう、ならばもう一度、貴様のオチンポにＨな奉 \n仕とやらをして、精液を出させてやろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903207" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……べ、べつに私がしたいと思っているわけではないぞ？　オチンポが大き \nくなってしまったのでしかたがなく……本当だぞ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903208" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それに、貴様の良いところはだいぶわかったからな……今度はさっきよりも \nもっと、オチンポを気持ちよくしてやろう」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903209" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから貴様は、私の口で好きなだけオチンポを気持ちよくして、好きなだけ \n出すがいい……貴様が満足するまで、何度でもご奉仕してやろう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903210" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぷっ、んちゅっ、こうやって亀頭を舌で包まれながら、れろれろれろぉっ \n、べろべろと激しく舐められるのが好きなのだろう……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903211" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「裏筋も舌でくるんで、れりゅれりゅれりゅっ、小刻みに動かしたり、れろぉ \n～～～っ、れろぉ～～～っ、こうやって、おっきく舐められたり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903212" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「唇を引き締めて吸いこみながら、じゅるるっ、ぢゅちゅううっ、じゅぷっ、 \nじゅぷぷぷぷっ、奥までねっとりと咥えられるのも、好きなんだな……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903213" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「口の中全体で、オチンポにぴったりと吸い付きながら、じゅちゅううっ、じ \nゅっぽじゅっぽじゅっぽじゅっぽ、前後に激しくしごいて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903214" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぽぽっじゅぽっじゅぽっ、れりゅれりゅれりゅっ、しゃぶられながら舌 \nでオチンポのあちこちを舐め回されると……ふふっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903215" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「また匂いが濃くなってきたぞ、じゅちゅうううっ、れろれろれろっ、先っぽ \nから、匂いの強い先走りの汁が、たっぷりと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903216" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「先っぽの割れ目を舌でほじくられたり、れろれろれろれろっ、唇で強く吸わ \nれたりすると、ちゅうううっ、ほら、また出てきたぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903217" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「なに……？　イッたばかりで敏感すぎる……？　それはつまり、気持ち良い \nということだろう？　ならばもっと激しくしてやろう、ぢゅちゅうううっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903218" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「どうだ、気持ちいいか……？　貴様の切なそうな顔をみていると、胸がキュ \nウっと苦しくなって……んふぅっ……身体が熱くなってくるのだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903219" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「またオチンポの先っぽが大きくなってきたぞ、じゅちゅるるるっ、じゅっぷ \nじゅっぷ、びくびくと震えて、じゅうううっ、また出そうなのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903220" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いいぞ、ぢゅううっ、じゅるるっ、たくさん出してくれ、じゅっぷじゅっぷ \n、濃くてドロドロの精子を私にいっぱい出してくれ……ぢゅううううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "001_0903301" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぶうっ！　んぶっ、んむっ、んむうっ、ザーメンがまた、口の中にいっぱ \nい……んぶっ、んぶぅっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903302" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ、こってりと濃くて、どろどろしていて、んふっ、んふうう \nっ、舌にからみつく……んっ、んぐぅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903303" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、じゅるっ、じゅるるっ……んぐっ、喉にへばりついて、やは \nり飲みにくい……んぐぐっ、んぐっ、ごくっ、ごくっ、んぐくっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903304" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぷはっ……あぁっ、また貴様のオチンポから吐き出された大量のザーメンを \n、飲み干してしまった……口の中がすっかり、精液の匂いでいっぱいだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903305" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「お腹の中が精液がたぷたぷになって……げふっ……あぁぁっ、ひどい匂いだ \n……身体の中まで、貴様の精液の匂いが染み付いてしまった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903306" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……またオチンポが精液で汚れてしまったな……あ、鈴口から精液が垂れ \nてきているぞ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903307" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅううっ……竿の方の精液も舌で舐め取って……れろれろっ、じ \nゅるるっ……またオチンポを、キレイにしてやる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903308" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃぴちゃっ、ちゅううっ、ふむ、キレイになったな。ふふっ、なんだか \n貴様のオチンポが可愛く見えてきたぞ。Ｈなご奉仕とやらにハマりそうだ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903309" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……む、またオチンポが固くなってきたな。勃つということはまだしたりな \nいということなのだろう？　絶倫というやつか、さすがだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903310" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ならば、またしてやろう。貴様が満足してオチンポが勃たなくなるまで、何 \n度でもしてやるからな。なに、遠慮はするな。さぁ、いくぞ……じゅぷぷっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "001_0903401" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあっ……何だ、急にチンポが抜けて……わぷっ！　んむっ、んんっ！　顔 \nに、精液が……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_14" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903402" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んむっ、んむうっ、んううっ……熱いザーメンが、びゅうびゅうと……んぶ \nっ、んむぅっ、勢いよく飛んできて……わぷっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903403" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあぁっ……濃くてどろどろとした精液が、顔中にかかって……あぁっ、な \nんだこれは……肌にべったりとはりついてとれないぞ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903404" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「口に出されるのとはまた違って……んふぅぅっ、精液の匂いに包まれている \nような……あぁ、肌に染み付いてとれなくなってしまいそうだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903405" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様……なんだ、その顔は……ずいぶんと満足そうにして……精液まみれの \n私の顔が、そんなに楽しいのか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903406" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「まさか貴様……狙って私の顔に精液をかけたのか……！　ザーメンで匂い付 \nけをして……犬のように私の顔にマーキングをしたというわけか……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903407" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや、怒っているわけではないのだが……お、おい、オチンポまでしお \nしおにさせて、そんなにしょげるな……私まで落ち込むだろう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903408" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私はべつに、貴様の匂いは嫌いではない……むしろ、少し安心するかも \nしれないな……それに貴様のことも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903409" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……ふふっ、そうだな。貴様のモノにされるというのも、存外悪くないかも \nしれないな……ふふふっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0903410" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかたがないな。またしてほしくなったら、いつでも私に言うがよい。貴様 \nのチンポにたっぷりとＨな奉仕をして……また匂い付けをされてやろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}