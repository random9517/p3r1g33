		{"command":[ "PLAYVOICE", "043_0103101" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……従僕。貴方が私をここに呼んだ理由……。既にわかっているんですのよ\n？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103102" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「くすくす、驚いた顔をしているけれど……。この部屋にこびりついた卑猥な\n臭い、染みついた雌の気配……隠せるものでもないでしょうに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103103" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「それで？　今日は私を手籠めにしようというのかしら。随分と舐められたも\nのですわね……私を誰だと思っていますの？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103104" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「名家ドラクレシュティ家が育みし妖姫……。人の血を啜る、選ばれし上位種\nのこの私に触れて良いのは、一族にふさわしい強者だけ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103105" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「貴方も筋は悪くありませんけれど、まだ……一族として迎え入れるには物足\nりない……。でも、そうですわね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103106" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「今この時、私の試練を受けて耐えられれば、一族の資格を与えてさしあげて\nもよろしくてよ？　ただし、一方的にこちらがするのですけれど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103107" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「くすくすくす、怯えて声も出ないでしょう？　って……えっ？　最初からそ\nのつもり？　わ、私に一方的に苛められたい！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103108" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あ……あ、あ……そ、そうなんですの？　貴方、そういう……。あら……。\nで、でしたら何も問題はありませんわね。それで、どうして欲しいのです」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103109" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……ええ。手コキ。……指が汚れるのは嫌なのですけれど……。んっ？　そ\nれも予想して、使う道具は揃えてある？　まぁっ、用意周到な！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103110" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「これを使ってしてくれ？　……これはオナホール……ですわね。これなら、\nまあ……いいでしょう。確かに一方的、良い選択です」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103111" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「これで貴方を責めたてる……。くすくす、なんて楽しそうな催しかしら。さ\n、そうと決まれば早くお脱ぎなさい。すごく、すごく良くしてあげます」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103112" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……今宵ばかりは……生ぬるい血ではなく、貴方の精を搾り取ってさしあげ\nましょう。存分に、歓喜し私を崇めるのよ？　……いらっしゃい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103113" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あらあらあらっ……！　これが従属の……貴方の男性器？　想像よりもずっ\nと、逞しくて立派だわ……フフフッ♪」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103114" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「オナホールの中にちゃんとおさまってくれるかしら？　ともすれば、ぶちゅ\nりと突き抜けてしまいそうなくらい大きいわ……搾りがいがありそう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103115" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……え？　今までにこういう経験があるか、ですって？　あるわけないでし\nょう。死んで、それからずっと棺の中にいたのですから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103116" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「で、も……私は外に出て学んだの。いずれ従僕を……貴方を完全に支配下に\n置くために、貴方のして欲しいことは、何でも……最高でしょう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103117" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「くすくす……こぉら。じっとなさい？　先っちょがプルプルって逃げてます\nわ。なんとまあ、猛々しくも可愛らしい牡突起なの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103118" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「心配しなくとも、私がたーっぷり可愛がってあげますわ。ですから……おと\nなしく、ホールを装着されてしまいなさい……。それそれそれ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103119" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あは……！　凄い！　なんてみっともない格好なの！　股間を丸出しにして\n、勃起したものを透けるオナホールでがっちり捕まえられて♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103120" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「情けないわね、私の小さな手に一番大切な場所を握られて……悔しいでしょ\nう？　辛いでしょう？　なのに、どんどんはちきれんばかりになって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103121" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「中で血管が浮き出しているのまで見えるわ。ああ……はしたない従僕！　い\nつからこうして硬くしていたの？　早く言ってくれれば良かったのに♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103122" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「私にこうして……男性器を愛撫して欲しかったのよね？　従僕らしく性処理\nしてもらいたかったのね？　よくってよ、よくってよ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103123" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ほら……ほら、少しずつ上下に動かしてあげる……。やぁだぁ……♪　中で\n皮も一緒に動いているわよ。めくれたり……戻ったり、めくれたり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103124" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「くすくすくす……。いいのよ、従僕。貴方の恥ずかしいところは、私がぜぇ\nんぶ見ていてあげる。だから安心して感じてしまいなさい♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103125" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「最初はゆっくり……ぬぽ、ぬぽ、ぬぽ、ぬぽ……。ふふふっ、弱くして緩め\nたり……ぎゅうってして強くしたり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103126" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「単純にヌプヌプさせてるだけでも気持ちいいの？　感じやすくて良い肉体ね\n……。それとも、私にしてもらっているからなのかしら？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103127" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ぬっぷっ、ぬっぷっ、ぬっぷっ、ぬっぷっ……。ぬぽっ！　ぬぽっ、ぬぷぷ\nぷ……ぬっぽっ……ああ……このリズム、クセになるでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103128" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「もどかしいくらいに焦らして、焦らして……性感だけをジワジワと高めて貴\n方を追い詰める……。私の手は魔法の手……甘い毒、永遠の呪い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103129" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「タマタマがきゅううって上がりきるまでゆーっくりプチュプチュもてあそん\nであげる……。ほぉら……。ぬっぷっ……♪　ぬっぷっ、ぬぷっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103130" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「腰を上げて、少しでも気持ちよくなりたい貴方を……私の手とオナホールが\nイジワルしてさしあげるの。ぬっぷっ、ぬっぷっ……ぬぷぷぷっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103131" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ぬちゅ、ぬちゅ、ぬちゅ、ぬちゅ……。やぁだ……もぉ♪　ちょっとずつ、\nホールが濡れてきているわよ？　貴方、鈴口から透明な液体が♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103132" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「これ……気持ちいいとにじみ出るのでしょう？　素直ね……。それ、それ…\n…ぬっぷっぬっぷっぬっぷっ……ぷっちゅっぷちゅ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103133" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あぁん楽しいぃ♪　やらしいお水の音たてながら、私の手で自由自在に感じ\nさせられる♪　こんなに楽しいことって他にないわ！　もっと、もっと！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103134" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ぬっぽっぬっぽっぬっぽっぬっぽっ……。あは……頑張って♪　まだイッち\nゃダメよ、我慢なさい♪　ぬっぽっぬっぽっぬっぽっぬっぽっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103135" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「先走りのお汁がホールから溢れてきちゃってる♪　そんなにいいの？　信じ\nられないですわ……♪　こん、な、単純な動きで感じる、なんて♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103136" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「まるで女の子みたいに敏感……♪　あぁ……赤黒くなっていく亀頭、太さを\n増していく肉茎……まだダメよ、まだイくのは許しませんわ。って！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103137" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あらっ！？　あらあらあらっ！？　こんな拙い言葉責めでイッてしまったの\n！？　なんて躾のなっていない！　はしたない従僕ね！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103138" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「いやだ……。ドクドクとほとばしる粘液が、真っ白な精液がホールに注がれ\nているのが丸見えではないの……。恥ずかしくないの？　貴方！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103139" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……言いつけを守らない従僕にはお仕置きが必要ですわ。……ええ、そう。\nまだ終わらせてなんてあげませんわよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103140" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「すぐに勃たせなさい。私の責めはこの程度では終わりません。……フフフ、\nいいことを考えました。勃起させるところからしてあげましょう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103201" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「そう……そう、そうよ……。私の手の動きに合わせて……。男根を再び熱く\n隆起させるの……。そう……いい子ね。そのまま硬くして……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103202" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あああ……♪　良くできました♪　イくのは我慢できないのに、勃起させる\nのだけは上手ねぇ……。お汁が増えて気持ち良くなっちゃうのかしら♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103203" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「丁寧に、丁寧に……でも、さっきより強めにしごいてさしあげましょうか。\n今度こそ、私の命なく出さないように。いいわね？　再開しますわよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103204" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「んっ……。ずっぷっずっぷっずっぷっずっぷっ！　ああ～！　なんて音！　\nさっきの比じゃなくいやらしい音が響き渡ってますわ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103205" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「だらしなく垂れ流した精液と、我慢汁が奏でる恥ずかしい音！　貴方にも聞\nこえるでしょう？　私の手の中からするひどい雑音っ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103206" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「初めて手コキをする、オナホール初心者の女の子にゴシゴシされて大量に射\n精したあげく……すぐに二度目を要求している♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103207" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「とんでもなく淫らな男性器ね♪　このパツパツに張りつめた肉筒の中は、い\nやらしい海綿体ではちきれそう♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103208" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ねえ……？　いつもこんなことばかり考えているんでしょう？　私に苛めら\nれて、好きなだけ精液を搾り取られるの。羞恥にまみれながら……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103209" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「自由にできない男性器をいじられて、尿道から噴水のように精液を噴き出す\nその様を……私の目で見て欲しいと願っていたのでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103210" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「くすくすくす……。本物の変態ね。貴方、自分の変態嗜好を、私に知っても\nらいたかったのね。いいわ、それくらい受け止めてあげる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103211" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「見ていてあげるから……何度でもおイキなさい。オナホールが破れて、私の\n手に、腕に、精子がかかるくらい射精なさい♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103212" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ほぉーら……ぐっちゅぐっちゅぐっちゅっ！　ずっぽずっぽずっぽずっぽっ\n♪　少しずつ、強く速くしていきましてよ？　じゅっぷじゅっぷじゅぷ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103213" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ずぽずぽずぽずぽずぽずぽずぽずぽ！　ぐっちゅぐっちゅぐっちゅぐっちゅ\nっ！　あーははははっ、あははははっ♪　すごい、凄い♪」", "NORMAL" ]},
