		{"command":[ "PLAYVOICE", "043_0103214" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「私に立派な男性器を操縦されて喜んでいる♪　せっかく雄々しくそそり勃た\nせた勃起を……オナホールなんかで刺激されて興奮しているなんて♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103215" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「そうですわよね、偽物のおまんこに……透明な女性器に精を注ぐのは気持ち\nがいいのでしょう？　屈辱的で、倒錯的で……変態の所業」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103216" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「おまんこの断面図みたいなオナホールに、びゅっびゅするところ見て欲しい\nのでしょう？　ええ、見ています。あますところなく！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103217" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「っ……はぁ、はぁはぁ♪　見せなさい。オナホでビュルビュルするところ…\n…ぬぽぬぽズプズプされてイクところを見せなさい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103218" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ほら、ほら、ほら、ほら！　変態さん♪　私が射精の許可を出してさしあげ\nたの。わかるでしょう？　全てぶちまけておしまいなさい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103219" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ぬっぷっぬっぷっぬぷっぬぷっ！　ヌッポヌッポヌッポヌッポヌッポヌポっ\n……！　あぁあ～～～♪　そうそうそう、その顔、その顔のまま！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103220" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「溜めに溜めた精子吐き出しなさい！　イクのっ、貴方はイクのよっ！　私の\n指で大量に射精するの！　出しなさい！　従僕っ！　早くっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "043_0103301" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「きゃーっ♪　あはははははっ、出たっ、出ましたわ♪　本当に射精するだな\nんて馬鹿みたいっ、なんて愚かっ……愛おしいですわぁっ♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103302" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「馬鹿ね、ばかねっ、こんなに出しちゃって……。二度目なのにこんなにも…\n…♪　でも、恥じることはありません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103303" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「貴方は私の命令で射精したの。主の、姫の言うことを聞いた貴方はとても良\nい子♪　私の従僕に……一族にふさわしい逸材ですわ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103304" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ああ……ああ、ああ……。見て？　私の手がずっしりと重くなるくらい……\nおびただしい量が出て……。凄まじいわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103305" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「少し揺らすだけで、たぽったぽって精液が波打つよう……♪　くすくす、私\nの膣内に射精できなくて残念ね。でも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103306" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「こんな量を出されたら、さすがの私も孕んでしまいますから。ここに出して\nくださって良かった……ということにしておきましょう♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103307" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ふふふ……。そう……そうなのね。私が、貴方をイかせることが出来た……\n。こんなにも気持ちよくしてさしあげられた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103308" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「なんだか、妙に自信がついてしまいましたわ。貴方を世界一気持ちよく出来\nるのは、きっと私なのだと……。違わないでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103309" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「初めてでこれだけ搾れたのですから……次は？　その次は？　くすくす、枯\nれてもう一滴も出ないくらいにしてしまえるかも……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103310" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「せいぜい、次の機会までに溜め込んでおくことね。ま、いくら溜めても……\n私が全て射精させてしまいますけれど……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "043_0103401" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「っきゃっ！？　きゅ、急に腰を動かさないでっ……あっ！？　あああああっ\n！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103402" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「もう！　もうもうもうっ！　ホールがズレてしまったではありませんのっ！\n　やっ……！　こらっ！　今射精なんかしたら……きゃああああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103403" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ……！　んもう……っ、従僕ぅ……！　ばか、ばか、ばかば\nかばか～～～～！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103404" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「あああああー……。私の腕も、服もドロドロ……。でも、驚いて指の力を緩\nめた私も悪いのですわ……。気になさらないで……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103405" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「気高き姫たるもの……従僕の……。一族の者の不始末をかぶるのも、また上\nに立つ者の役割……。で・す・け・れ・どっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103406" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「これが、本番の性行為であれば許しませんことよ！　次はきちんと……ホー\nルでもおまんこでも、狙いを定めて中にきちんとお出しなさい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103407" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「っ……て、べ、別に、従僕に……貴方にＨなことをさせてあげるという意味\nではありませんからね！　こ、心構えの話です！　良いですわね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103408" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……ん？　出した場所のことばかりで、汚したことは怒らないのか、ですっ\nて？　くすくす、それは当たり前でしょう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004301_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103409" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「ネバネバするのは困るけれど……。貴方は私のたった一人の大事な従僕。そ\nの体液くらい、いくらでも浴びてさしあげますわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "043_0103410" ]},
		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「……そう。姫として、高貴なるものとして……。貴方の主として、私は志（\nこころざし）高く、貴方のことを想っているのですわ」", "NORMAL" ]},
