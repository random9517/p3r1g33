{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「良いか貴様ら！！　苦しくったって、悲しくったって、恋をしている最中は\n幸せなんだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「はい！　塾長！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それは同志カツマが探し出した、劇場版『１万年と２０００年前からのプロ\nポーズ』でも明らかになった！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「イエス！　イエス！　セイエス！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にか同志にさせられている……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやまあ、一瞬とはいえエファの勢いに呑まれちまったからなあ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "攫われた立場としては、身の安全を図れたと思うべきなんだろうが……はあ。\n早く帰りたい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まさか人に教えを請う時に一番適切な態度が、壁ドンだったとは知りません\nでしたなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……奴等がますますヒートアップしているのは、そのお願いを聞いてしまっ\nた俺のせいみたいに言うな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0050" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「もう……もうっ、辛抱堪らん！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……え。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「私も、もう、この、身体の内から溢れる力を抑えられません！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ええっ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「自分も……んんんんっ！　時代を先取るニューパワー！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ウっソだろ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんとっ……！？　塾生は皆、襲来者（インベーダー）が変身した姿でした\nか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "道理で一般教養に疎いわけだ……。普通に義務教育でも受けていれば、まず嵌\nまりそうにないノリだものなあ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「まさかこの作戦で、こんな感動を味わうことになるとは……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「まったく。女幹部を攫い、洗脳してイベントをぶち壊すだけのはずだったの\nに……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「仲間としての絆に亀裂を入れ、内部から徐々に崩壊させるはずが……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「ああ……まさか洗脳したエファナティカ……いや、エファナティカ塾長が…\n…」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「こんなに立派な方だったなんて……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうして、そうなるんだ……そうはならんやろ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ははあ。なかなか手の込んだ、それでいて迂遠な作戦ですなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ってか、エファナティカは洗脳されてああなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それならばあの言動も納得出来るような……出来ないような？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「恋のひとつも理解出来なかった怪物（クリーチャー）だった頃に比べたら、\n貴様らもすごい進歩だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920003" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「ありがとうございます、塾長！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの通りですからなあ……まさか、エファナティカ様が洗脳されていたとは\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「このジュンジローの鼻をもってしても、嗅ぎ分けられませんでしたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "気づけよ駄犬、見抜けよ節穴。いや俺もだが。妙だ妙だとは感じていたがなあ\n……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「これまであたしは、強さだけを求めてきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかし花嫁になるために必要なのは、強さだけではない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「弱き者を守る正義の心！　男を優しく抱きとめ、受け入れる思い遣りの心！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そう……愛に溢れた優しさと正しさも必要なんだと、気づかされたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「はい、塾長！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「我々に足りなかったのも、それです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「愛！　愛こそがすべて！！　そうなんですね塾長！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「塾長！　エファナティカ先生！　私たち、目が覚めました！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「塾長や先生だなんて、他人行儀だ。愛に溢れた呼び方がいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そう、『ママ』と呼んでくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「ママぁー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……涙を流してエファを囲み、抱き付く襲来者（インベーダー）って。なんか\n、すごいものを見せられてるな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0050" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なあ。これが、バブミってやつか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「かもしれませんなあ。襲来者（インベーダー）も連戦に次ぐ連戦で、疲れ果\nてていたのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「現代社会で荒んだ心は、母胎への回帰を求めるものだと、古事記にも書いて\nあるとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "また古事記かよ。森羅万象を担当しているな古事記。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「戦いと社畜みたいな生活に疲れてるってのは、まあ同情を覚えなくもないが\n」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人も結構な奴隷根性ですからなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「黙れ駄犬。それよりもだな、悪の女幹部が正義の心ってなぁ……いいのか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「むしろ心配なのは、この光景を学園長率いるブラックメルヘンの皆様が目の\n当たりにした時、ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "愛と正義に目覚めた悪の女幹部と、悪の組織としての誇りはそのままに襲来者\n（インベーダー）と戦い続ける組織……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うん。相性は良くなさそうだな！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はい。このまま大団円！　とはいかない予感がぷんぷんしますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920010" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お？　おう、なんだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いきなり名前を呼ばれて、抱き寄せられたぞ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "壁ドン以来距離が近いから、ドキマギしてしまうじゃないか。ぽっ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「明日はお前のために闘う。だから応援していてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……え。明日？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "イケメンボイスで囁かれたから、つい聞き逃しそうになってしまったが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "明日？　闘う？　なんの話だ？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「うむ、これだ。不遜にも果たし状が送り付けられてきてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、エファの手に、確かに果たし状らしい物が握られているな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「見てみろ。諦めこそ悪いが、勝負を捨てないその根性、あたしは嫌いじゃな\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920013" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どれどれ……はあ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは、学園長の手による文字ですなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それで『明日、１２時、校庭にて待つ』って……おい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これがここに届いているとは、つまり、我々の居場所はとっくに判明してい\nたと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113920013" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だったら助けに来てくれよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なぜ乗り込んでこない？　こんな果たし状とか、向こうもあれか、頭湧いてる\nのか？？？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「明日の試合は花嫁シップに則り、正々堂々とやるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113920014" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「そうと決まれば特訓ですね！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

