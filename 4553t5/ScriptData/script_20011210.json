{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「長官からオオガラスへ。応答せよ。東風、聞こえるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021450001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「こちらオオガラス！　聞こえます、長官！　みんな無事です！　データも回\n収しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうか！　よくやった！　いま、ヘリがそちらに向かっている。まもなくそ\nちらに着くはずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021450002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「了解！　合流地点の、ビルの屋上で待機しています。ヘリが見えたら、信号\n弾を上げればいいんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021450002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、見えてきた！　あれが迎えのヘリだな。信号弾を上げてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アーニーが信号弾を打ち上げるとヘリはこちらに気づいて、ゆっくりと降りて\nくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「きたきたー！　待ってたっスよー！　うほほっ！　着陸マークにドンピシャ\n！　パイロットさん、いい腕っスね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ふぅ……危ないところでしたね。弾はほとんど、使い切っちゃいましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな。だけど、ここまでくればもう安心だろ。さあみんな、急いでヘリ\nに乗り込んでくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「安心……？　はたして、そうですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「またおまえは妙なこと言い出しやがって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こういう油断しきったときが、一番危ないのですぞ。たとえば、そこの床を\nぶち抜いて襲来者（インベーダー）が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021450002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、言ったとたん！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「きゃあああああああっ！　ホントに出たぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ジュンジローの言った通りのシチュエーションで、襲来者（インベーダー）の\n巨大兵器が現れた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからよけいなこと言うなって言ってんだよ、この駄犬！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なにをおっしゃる！　わたくしは注意を喚起しただけですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021450003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、みんな早くヘリに乗れ！　撃てるバズーカはあるか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「バズ太郎きゅんなら、一発だけ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そいつを貸せ！　おまえはヘリに乗れ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長はどうするんです！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021450002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はここで、あいつを片付ける！　みんな急げ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「そうは行かないんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エフュサスがそう叫んで俺の襟首をつかむと、他の連中もいっせいに俺をつか\nんでヘリの中に引きずり込む。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉっと！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「全員乗ったわ！　パイロットさん、急いで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021450001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおいおいおい！？　ちょっと待てって！　このままじゃ、あいつに狙い\n撃ちされちまうぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「だったら、早く撃ちなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021450002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんなに揺れるヘリの中から、狙いなんかつけられねえよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「いちいちうるさい隊長だ。おい、みんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021450002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はいっ！　むぎゅ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021450003" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「まかせるっス！　むぎゅ～～～っス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021450002" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エフュサスの号令で、みんなが俺にしがみつく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「こうすれば照準が安定するはずです！　隊長、早く！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021450002" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わ、わかった！　よーし……見てろよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はバズーカの照準を巨大兵器に合わせ――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、来い……こっちへ来い……吹っ飛ばしてやる……くたばれ！　この野\n郎ーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は狙いすまして、バズーカをぶっ放した！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "隊員たち" ]},
		{"command":[ "SETTEXT", "「やったーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021450004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00005802_01", "8", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00006102_01", "8", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00006402_01", "8", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バズ太郎くんの最後の一発が見事に命中！　敵は吹っ飛んだ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「わーっはっはっはっは！　やった！　やったぜ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「やりましたね、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021450005" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「さすがバズ太郎きゅん！　えらいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021450003" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「これで本当に、任務完了ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021450004" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "炎上する巨大兵器を見下ろしながら、俺はほっと胸をなでおろす。と、同時に\n……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ……！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺を支えていたみんなの柔らかい胸が！　ボディが！　素肌が！　俺に押し付\nけられていたことに、ようやく気付いた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、みんな？　ちょっと、その……離れてくれねえかな……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "離れてくれないと、俺のバズーカがけしからんことになってしまいそうで……\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「えー！？　なに言ってんスか、隊長！　みんなでハグして、喜びを分かち合\nうっスよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021450004" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ハグって、その……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「あんたはハグが嫌なのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021450004" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「嫌、ってわけじゃねえよ、むしろ気持ちい――げふんげふん！　っていうか\n、みんな気にならねえのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「なにがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021450004" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんていうか、その……俺だって男だし。そんな露出の多いカッコで、男に\n抱きつくっていうのが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ふふふっ！　なーんだ、そんなこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010021450005" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「この格好でずっと一緒だったわけですし、すっかり慣れてしまいました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021450003" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「意外と快適ですしね、ビキニって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021450006" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、そ、そうですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「そうですよ。それに、ビキニを着てるのは私たちだけじゃありませんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010021450004" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そう！　見るからに似合わない、恥ずかしいビキニ姿で自分らにつきあって\nくれた隊長も、立派なＢＢ嬢っす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010021450005" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから！　それを言わないでくれぇ～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "忘れようとしてた！　任務中、ずっと自分がビキニを着てることは、忘れよう\nとしていたのにっ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「あえて自分もその格好をする勇気、尊敬します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010021450004" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
