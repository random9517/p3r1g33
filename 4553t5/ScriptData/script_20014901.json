{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "朝から汗だくになるほどの猛暑日が続いていたある日。俺は長官に呼び出され\nていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「よし、全員揃ったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "いつもの会議室には、先にディアナとアン＝クァーがいた。なんだか珍しい取\nり合わせだ。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00022101_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「もう、遅いわよカツマちゃん。これから大事な作戦会議だって言うのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……。やけにテンション高いな。というか、お前がこんなにやる気\nだなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あたしはいつだってマジメよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「やる気があるのはけっこう。お前もすこしシャキっとしたらどうなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「この暑さにバテている場合じゃないぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "この人も、なんだかやけに元気だ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……はい……。それで、今回はいったいどんな任務なんですか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「それについては、アンちゃんの話を聞いて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アンの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい、それでは、説明させていただきますの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250001" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「まず、わたくしの能力についてなのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250002" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "とある国の姫であり、巫女として暮らしていたアン＝クァーは、神託を聞く能\n力をもっている。", "NORMAL" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "FADEINIMAGE", "1", "VERYFAST" ] },
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "今回の任務は、アンが受けた神託の内容が発端のようだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どうやらこの地球のある時間、ある場所に、スタークリスタルが出現するら\nしいんですの」", "NORMAL" ]},
		{"command":[ "FADEOUTIMAGE", "1", "VERYFAST" ] },
		{"command":[ "PLAYVOICE", "v2_221_010023250003" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「スタークリスタル？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こちらでも調べてみたが、どうやら所持者の願いを叶えることができるとい\nう伝説がある幻の宝石らしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか、ふわっふわしてますね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんせ、幻だからな。だが、その存在の信憑性はある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。実は、スタークリスタルはわたくしの星にあったものなんですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250004" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの星では、願いを叶える宝石、スタークリスタルをめぐり絶えず争\nっていた時代がありました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250005" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そこで、わたくしよりずっと前の巫女が、クリスタルに願ったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この星からなくなれ、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250007" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「その願いの通り、わたくしの星からスタークリスタルは消えました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250008" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そして、クリスタル本体は様々な次元や宇宙をさまよい続けるようになった\nのですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250009" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだか、おとぎ話みたいな内容だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そうですね。実際、おとぎ話かのように伝わるほど昔の話ですの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だが、実在する宝石であることはわかっただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「願いを叶えるという効果まで本当だったら、誰かに悪用される危険もある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そんなものを放置するわけにはいかないからな。我々が確保し、管理するこ\nとになったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「管理……ですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "大丈夫だろうか。この組織には、悪用しそうなやつらしかいないような気がす\nるんだが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ところで、スタークリスタルってどんな宝石なのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どんなって言われても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「クリスタルっていうくらいだから、きっとキラキラしてるのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「スターってつくくらいだから、星の形をしていたりもするのかしらぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「スタークリスタルちゃん、はやく見てみたいわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ディアナが朝からハイテンションなのは、任務が宝石がらみだったからみたい\nだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でも、そいつの現れる時間も場所もはっきりしてないんじゃ、見つけようが\nないだろう」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「心当たりはあるわ。ずばり、これよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250008" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ディアナがみせたのは、市街で開かれるマルチバース・コスプレ・サミットの\nチラシだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なんでも、様々な次元のコスプレイヤーが一同に会するイベントだとか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そこで行われるコスプレコンテストの優勝賞品として、スタークリスタルが贈\n呈されると書かれている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どんな願いも叶う幻の宝石……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "新聞や雑誌にある、パワーストーンの広告のような書かれ方をしていて、かな\nり胡散臭い。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というか、なんでそんな次元を越えた超すごいイベントが九重市で開かれる\nんだよ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかも賞品がとんでもない危険物だし。話ができすぎだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあ、近所でよかったじゃないか。交通費もかからないしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010023250009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},	
		{"command":[ "DISPCHARA", "0", "TRUE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういう問題かよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「コスプレなら、あたしたちの普段の格好で潜りこめるし、それにあたしの美\n貌にかかれば優勝は確実よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250009" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「待っててね、スタークリスタルちゃん。あたしが迎えに行ってあげるからぁ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "こんなに任務に前向きなディアナは珍しい。天変地異の前触れか？　明日から\nいきなり氷河期に突入するんじゃないだろうか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうそう、今回はもうひとり任務に参加するみたいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250011" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰がくるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……にゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "1000" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "750", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ディアナの背後から、グレーテルが現れた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ、グレーテル！？　……いたのか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ずっといたよ……？　はぁ……なんで私が招集されたんだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「コスプレサミットなんて、陽キャの集まるところじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そんなところに行ったら……死にそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250004" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、その程度で死にはしないだろう！？　というか、なんでこの人選\nなんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「神託によると、今回の任務はわたくしとディアナさま、そしてグレーテルさ\nまで向かうといいみたいなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250011" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "肝心のスタークリスタルの出現場所は曖昧だったのに、そこははっきりしてい\nるのか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「つまり、あたしたちが揃っていれば優勝間違いナシって、アンちゃんの神様\nが言ったってことね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250012" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、そう言うことになります……の？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250012" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そうなの……？　私がいるのに……？　私がいない方が、優勝できるんじゃ\nない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250005" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「大丈夫よぅ。グレーテルちゃんのコスプレも需要があるから、アンちゃんの\n神託で選ばれたんだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250013" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「自信もっていきましょっ、ねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250014" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そ……そうなの……かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250006" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そうですよ。それに、グレーテルさまもスタイルがいいですし、どんなコス\nプレも似合うと思いますの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250013" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「そ……そうかな……。でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250007" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「この間、魔法少女になってたじゃない。あの格好すれば、そうね、準優勝に\nはなれるでしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023250015" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「あ、あの格好させられるの！？　それは……ちょっと……。やっぱり遠慮し\nたい……かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250008" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「神託によれば、今回グレーテルさまはマストだって言ってましたの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_010023250014" ]},
		{"command":[ "SETCHARA", "0", "char_00022101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ホントに……？　物好きな神様もいたものだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020023250009" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "任務に後ろ向きなグレーテルを、ディアナとアンがふたりがかりでおだててい\nる。", "NORMAL" ]},
