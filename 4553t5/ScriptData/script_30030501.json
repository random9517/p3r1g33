{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "003_0503101" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私をこんなところに呼び出して、何の用事かしら？　もしかして、お仕置き\nが癖になっちゃった？　ふぅ、あなたと違って、私は忙しいのだけれど……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503102" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あら、違うの？　それなら、私に用事というのは……は？　今、この私に、\nあなたの粗末なモノを口で咥えて、奉仕をしろと……そう言ったのかしら？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503103" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どうやらあなた、だいぶ調子に乗っているみたいね。いい加減にしないと、\n私のこの目が開くわよ？　その意味はもちろん……分かってんだろうねぇ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503104" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……なんだって？　ちっ……はぁ、わかってるわ。陛下のご意向だもの、仕\n方ないわね。いいでしょう、あなたの言うことを聞いてあげます」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503105" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「でも……あまり勘違いはしないことね。陛下のはからいとはいえ、あくまで\nも私が上司で、あなたは単なる、下っ端なのだから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503106" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「陛下が認められたのは、その特別な能力だけで、あとは人品も卑しく、下劣\nで下等な下働きでしかないの。そのことを……よぉく覚えておくんだね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503107" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んっ、れるっ、ちゅ……くっ、まさかこの私が、あなたのような男の足元に\nひざまづいて……れるっ、そのチ〇ポを舐めさせられるとは……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000305_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503108" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……わかっています。いちいち命令しないで……れちゅ、れりゅりゅっ、も\nっと激しく、れるれる、れるぅっ、舐めれば、いいんでしょ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503109" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「れろれろっ、れるぅっ、こんなにガチガチに勃起させて……ぴちゃ、ぴちゃ\nっ、れりゅるっ、まったく、節操がなくて、みっともないったら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503110" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「太くて、固くて、ぴちゅるっ、れる、れるっ、こんなとこばっかり男らしく\nて、ちゅぱっ、ちゅぷっ、あなたのようなヘタレ男には、もったいないわね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503111" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「れるっ、れろっ、れろぉっ、竿もこんなに長くて……れろぉ～～～っ、れる\nっ、ぴちゃっ、ちゅぷっ、はぁ……こんなに、反り返っていて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503112" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「亀頭も大きくて、ちゅぱっ、ぴちゃ、ぴちゃっ、カリ首も、鋭くせり出して\nいて、れるれるっ、れるぅ～～～っ、んっはぁっ、凶悪なオチ〇ポだわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503113" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅぅっ、こんなモノを入れられて、ちゅばっちゅばっ、ナカをごり\nごりとかき回されたら、んちゅうぅっ、さぞかし気持ちいでしょうね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503114" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「れろれろっ、れろぉっ、オンナなら、たとえ処女でも、たちまちによがり狂\nって、れりゅりゅっ、悦んで股を開くメスに成り下がってしまうわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503115" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅぅ…………は？　私が、興奮しているですって？　ふんっ、バカ\nも休み休み言いなさい。私がこんなモノを、れるっ、欲しがるだなんて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000305_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503116" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そうね、確かにこんなオチ〇ポを突っ込まれてめちゃくちゃにされたら、さ\nぞかしキモチイイでしょうね……ただし、あなたのモノでなければ、ね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503117" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「命令しないとオンナにチ〇ポも舐めさせられない、情けないクズ男のチ〇ポ\nなんて、ゴメンだわ。オンナを性欲のはけ口にする気分はどうかしら？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503118" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あら？　図星を突かれて怒ったの？　それでもまた命令するのね。オチ〇ポ\nを奥まで咥えろだなんて……いいわ。ただし……後悔しても知らないわよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503119" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぐぷっ、じゅるっ、じゅるるっ、ほら、あなたのオチ〇ポが、わたしの口\nの奥に、ぐぷっ、ぐぷぷっ、どんどん飲み込まれていくわよ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000305_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503120" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「吸い込みながら、口全体をオチ〇ポに密着させて、ぢゅちゅうううっ、ぢゅ\nずっ、じゅぷっ、じゅぷっ、根本から先っぽまで、シゴいてあげるわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503121" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「舌が別の生き物みたいに、オチ〇ポに絡みついて、れちゅるぅっ、れろぉぉ\nっ、裏筋を撫でたり、カリ首に絡んだり、じゅりゅりゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503122" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「喉の奥までオチ〇ポを咥え込んで、ぐぷっ、ぐぷぷっ、喉を締めると、んっ\nぐ、えんぐっ、んぐぷっ、亀頭が甘噛みされて、気持ち良いでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503123" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「先っぽが弱いのかしら？　それなら、ずぢゅるるるっ、ぢゅぼっ……れるっ\n、れりゅりゅっ、れるるっ、舌先で鈴口をほじくられるのは、どう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503124" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「オチ〇ポがビクビクして、一段と大きくなって来たわね、れるっ、れるるっ\n、もうイキそうなの？　情けないわね。まあ、しょせんそんなものかしら」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503125" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もちろん、わかるわよ、ずぢゅるるっ、私がこれまで何本のオチ〇ポを咥え\nて、じゅぷっ、じゅぷっ、イかせて来たと思っているの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503126" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「どんな男でも、私にチ〇ポをしゃぶられたら、じゅっぷ、じゅっぷ、じゅっ\nぷ、すぐにオチ〇ポをふるわせて、精液をお漏らししてしまうのよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503127" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まあ、その中でもあなたはとびきり早いけれどねぇ、じゅるるっ、じゅっぽ\nじゅっぽじゅっぽ、ほら、もういいから、さっさとイってしまいなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503128" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ずじゅるるっ、じゅぷっじゅぷっじゅぷっ、白くてドロドロした精液を、ぐ\nっぽぐっぽぐっぽ、みっともなくぴゅっぴゅと、漏らせばいいわ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503129" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「オチ〇ポを舐められて、れりゅりゅりゅっ、先っぽから根本までしゃぶられ\nて、ずじゅるるっ、ぐぼっぐぼっぐぼっ、さっさと精液を出しなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503130" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私の口で、オチ〇ポをキツく吸われながら、ぢゅるるっ、あっけなく射精な\nさい、ほら、イきなさいっ！　ずっぢゅううううううううっ！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503131" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぶうっ！？　んぶっ、ぐくっ、ぷあっ、なに、これっ、すごい勢いっ、ん\nぶっ、熱くて、ドロドロの精液が、こんなに、たくさんっ、あぶぅっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000305_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503132" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ、んぐぷっ！　ちょっと、口の中に、出しすぎっ……ぐぶぅっ、んぐ\nぶっ！　ぶあっ、くっ、このっ……んぐっ、くっ、ごくっ、ごくっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503133" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ぐくっ、精液、濃すぎて、んくっ、口の中に、はりつく……んぐくっ、ごく\nっ、んくっ、ぷぁっ、くふぅ、臭いもすごくて、頭がおかしくなりそう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503134" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぶっ！？　ぶあっ、まって、まだ出るのっ……ぐっ、人の口に、好き勝手\nに、精液を、吐き出して、んぐっ、くっ、無理やり、飲ませるなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503135" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んぐくっ、んくっ、ごくっ、ごくっ、ごくっ……ぷぁっ……げえっぷっ！　\nくぁっ……胃の中から、精液の臭いが立ち上って、くっ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000305_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503136" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「んくぅぅっ、身体の中に、オスくさい精液のニオイが染み付いて……んふぁ\nっ、んくっ……舌の上にもべったりとへばりついて、ネバネバする……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503137" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「くっ、こんなに濃くて、臭い、精液を飲まされるなんて、ふぅ、ふぅっ……\nあっ、また精液が出て……れるぅっ、んくっ……ぷぁっ、はぁ、はぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503138" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「しかも、あんなに出したのに、んちゅっ、れるぅぅっ、まだ、こんなに固い\nままだなんて、れりゅりゅっ、オチ〇ポ、まだ出し足りないというの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503139" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅっ、ちゅっ、まったく、しかたないわね……部下のオチ〇ポを\n躾けて……ずちゅるるっ、射精管理をするのも、上司の勤めよね……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000305_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0503140" ]},
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「いいわよ、ほら、れるぅっ、もっと出しなさい、この太くて固いオチ〇ポか\nら、れろぉっ、濃くて臭い精液を、もっといっぱい、射精しなさい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}