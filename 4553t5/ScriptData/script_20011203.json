		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「できない部下ってのは誰のことだゴラァ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はいはい、お静かに。未来を担うお子様が、純粋な目でこちらを見つめてお\nります」", "NORMAL" ]},
