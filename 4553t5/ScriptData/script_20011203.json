		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「やはりできない部下を持つと、日ごろのストレスが激しいのでしょうなあ。\n同情すべき点もありますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021380001" ]},
