		{"command":[ "PLAYVOICE", "v2_081_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んんっ、ぎゅって締めるからっ、いつ……お漏らししてもいいからっ、はぁ\nっ、んんっ、出したがってるでしょっ……ほらっ、ほらぁっ……」", "NORMAL" ]},
