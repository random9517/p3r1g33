		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……水着で隠れてるって……だ、大事な所は……見えてるから…\n…同じ……！」", "NORMAL" ]},
