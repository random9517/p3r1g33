		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あぁっ、音もしちゃう……はぁっ、溢れて……ぐちゅぐちゅっ……恥ずかし\nいのにっ、止まらないのっ……お汁……漏れちゃう……！」", "NORMAL" ]},
