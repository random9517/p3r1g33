		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、出し切っちゃって……全部、残さないで……私だけ……今日\nだけは、私が……隊長さんのこと……独り占めぇ……♪」", "NORMAL" ]},
