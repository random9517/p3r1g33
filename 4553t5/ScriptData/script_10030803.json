{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「今度は古時計か！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今回の時空管理統制局からの依頼は、伝説の古時計というものを見つけ、持っ\nてきてほしいというものだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「伝説って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で……今回も俺も同行っすか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい下僕、またサボろうとしたな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「滅相もない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やっぱり、任務はカツマが一緒がいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかしまた大層な名前のモノだね。そんなもの、いったいどこにあるってい\nうんだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「大戸岐学園のどこか、としか教えてくれなかったわねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そこまでわかってるなら、どうして自分たちで探しに行かないんだ、まった\nく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「たしかに、我々を差し向ける理由はないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、とにかく大戸岐学園に行ってみましょうよ。案外、あっさり見つかる\nかもしれませんし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だな！　そしたら依頼も即終了だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0148" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "と、私たちはさっそく大戸岐学園へと向かったのだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「伝説の古時計……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、そういうものがこの学園にあるらしいんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「聞いたことがないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなものがあったら、我々が先に見つけている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「それもそうだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「この学園にあるいわくつきのものについては、ブラックメルヘンの皆さんの\n方が詳しいですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「伝説といわれるほどかはありませんが、古時計ならありますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当か！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ぜひ見せていただきたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ブラックメルヘンの協力もあり、私たちはあっさりと古時計のある場所へと行\nくことができた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やったぜ、今回はマジで楽勝だ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ここは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、見覚えのあるところだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「かつて、我々がカードバトルに興じていたころに使用していた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「『カードバトルをするための闘技場（アリーナ）』、略して『カヲスアリー\nナ』である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115670004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな名前じゃなかっただろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「いまではすっかり物置になってるんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「うちでは、授業やクラブ活動の一環として、さまざまなものを購入すること\nが多いですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「ねえ、グリムロックさん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020115670003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「えっ、ああ……そうですね……フフフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、このごちゃっとした中から、伝説の古時計を見つけないといけない\nのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115670005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「問題ないですよ。それらしい古時計は、とても大きいのですぐに見つかると\n思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020115670004" ]},
		{"command":[ "SETCHARA", "0", "char_00002602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「持ち運ぶにも、あちらの方々のように三人がかりでないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_020115670005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "学園長の視線の先をみると、時間帝国の幹部たちが、古時計を持ち出そうとし\nているところだった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、とっとと運んでずらかるのじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おい、お前も手伝ったらどうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチはそういう力仕事は向いてないんです。脳筋のあなたにこそふさわしい\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなところで仲間割れするでない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「待ちな！　その時計は渡さないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちっ、見つかってしまったか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あれはここの学園長！　これは少々まずいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なに、ちょっと相手の方が多いくらいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そういう意味ではなく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……お前たち、私の学園でなに好き勝手してくれてるんだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020115670001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間帝国を撃退しなければ、と私が思ったときには、学園長が変身していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うおっ、なんだこいつ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115670004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「い、いきなり全力で……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「本気で怒ってるね……フフフ、こんな学園長、久しぶりに見たよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115670003" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「うちも舐められたもんだね、こんなに簡単にコソ泥に入り込まれちまうなん\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020115670002" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「でも、見つけたからには無事じゃ帰さないから。そこんとこ、覚悟できてる\nんだろうね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020115670003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前たち、久しぶりに私らの実力を見せつけてやりな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020115670004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}