		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、だから我慢しないで……じゅぷっ、オチンチンから、またたっく\nさん精液だしちゃいましょうね……♪」", "NORMAL" ]},
