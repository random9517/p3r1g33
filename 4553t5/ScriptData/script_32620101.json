		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「よかった、ちゃんと来てくれたわね。えっと……私、実は隊長くんのことが\n前から気になっていたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「こう、隊長くんの顔を見ていると、私のセンサーがビンビン反応しちゃうの\nよね。だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「今日は私のわがままを聞いてもらうわ。えいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふふ～♪　思ったとおり、若返らせたらすっごく私のタイプ！　ストライ\nクゾーンど真ん中だわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00026201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くん……いや、このかわいさは『隊長ちゃん』ね。隊長ちゃ～ん。マキ\nママと、イイコトしましょうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ほらほら、逃がさないわよ。これから隊長ちゃんの、オチンチンのお世話を\nしてあげるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「さ～て、ズボンを脱いじゃいましょうね～……っと、ふふっ、可愛いミニミ\nニオチンチンがこんにちは～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのオチンチンはこうなっているのね～……。普段は経験豊富なオ\nチンチンで女の子を泣かせてるって聞いてるわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「でも……いまのオチンチンは、そんなことしらないピュアピュア皮被りオチ\nンチン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。この匂いたまらないわ……。ちっちゃくてもしっかり男\nの子の匂いがして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「このギャップがたまらないのよね……♪　すぅ～……はぁ～……♪　ああ、\nいつまでも嗅いでいたいわ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ん……？　どうしちゃったのかしら、隊長ちゃん？　私の息がオチンチンに\nかかってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ、マキママの息がかかって、オチンチンがムズムズしてきちゃってい\nるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああん、とってもかわいい反応♪　隊長ちゃん、それ無意識でやってるなら\nそうとうヤバいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「もう、私も我慢できなくなってきちゃった。いただきま～す♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ん……あむぅ……♪　んっ、んちゅっ、オチンチン……ぱくって食べちゃっ\nたわ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ちゅぶぅ、ちゅるる……ちゅ、れろぉ……。隊長ちゃんのオチンチン……ん\nちゅっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「しっかり、硬くなっているわね……ちゅるるっ、ンッ、ちゅぱっ、とっても\n素敵よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるっ、マキママ……よだれがどんどん溢れちゃってる……\n隊長ちゃんのオチンチンが美味しすぎるからよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふっ、もっと吸っちゃおうかしら……じゅるっ、じゅるじゅるぅ……っ！\n　じゅぶっ、じゅぶっ、じゅじゅじゅぅ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長ちゃん、腰がビクビクしちゃっているわね。そうよね、フェラ\nチオ経験もリセットされちゃった敏感オチンチンだもの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「刺激が強烈でたまんないでしょ……？　んじゅるっ、じゅぶっ、じゅるるぅ\nっ♪　ふふっ、ちゅぱっ、ちゅぱぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、んじゅるるっ！　オチンチン……口の中で暴れてるわ\n……じゅるっ、じゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「どう……マキママのお口……気持ちいい……？　んじゅるるっ♪　オチンチ\nンが溶けちゃいそうなくらいあったかいでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるるっ、中で……舌もいっぱい動かしちゃうのよ……。オ\nチンチンを……たっぷりかわいがるの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、んじゅるっ、じゅぶっ、じゅちゅちゅ……っ！　ふふっ、隊長ちゃ\nんのオチンチン美味しいわ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「思いっきり吸いついて、隊長ちゃんのことこのままイかせちゃうわね。オチ\nンチンから精液吸いだしちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるっ、じゅるるるる～～～～……っ♪　んっ、じゅるっ、\nじゅるるるる～～～～……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンが膨らんで……んっ、我慢できなくなってきたでしょ？　んじゅ\nるっ、じゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「いいのよ……我慢しないで、マキママのお口にだしちゃいましょうね～……\nんっ、んん……んじゅるる……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、んんぅ……っ♪　んっ、んっ、で……でてるぅ……♪　じゅるっ、じ\nゅるる……んっ、じゅる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「口いっぱいに……隊長ちゃんの精液が、いっぱい……ふぅ……ンッ、すっご\nく濃いのが……でたわねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ん、じゅるる……っ♪　んっ、オチンチンの中に……まだ、残って\nいるんじゃないかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「それもみ～んな、マキママが吸いだしてあげる……じゅるっ、じゅるる……\nっ♪　じゅるじゅる～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ん……ふはぁ……♪　隊長ちゃんが、マキママのお口にだした精液……みん\nな飲んじゃった……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「うふふ……ぷりっぷりの精液、とっても美味しかったわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんはどうだったかしら？　マキママのお口、気持ちよかった？　ふ\nふっ、照れなくてもいいのよ？　照れているのもかわいいけど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん……もっとマキママのお口で、オチンチン気持ちよくなりたくな\nい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのオチンチンは、まだまだこんなに大きいままよ？　もっと射精\nしたいでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ、今日はわたしが満足するまで、付き合ってもらうんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「……んちゅっ♪　まだまだガッチガチのオチンチン……キスしただけでビク\nンって反応して……かわいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「連続で射精させられちゃう気持ちよさも、マキママが教えてあげるわね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あ～……むっ。勃起オチンチン、またぱっくんってして……。んっ、じゅる\nっ、また……たっくさん舌で……刺激してぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んじゅるる……じゅぶ、じゅぶ……ンッ、じゅるるぅ……っ♪　んふっ、オ\nチンチンの感度、あがっちゃってるでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、逃げられないように、じゅぶっ、しっかりオチンチンに吸いついち\nゃうんだから……じゅるっ、じゅちゅちゅぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぶっ、じゅぶっ、んふふっ♪　オチンチン、マキママのお口から\n逃げられないわよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅぶぶっ、んちゅぶっ、ちゅばっ♪　オチンチン、どんどん気\n持ちよくなってきてるみたいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「口の中のオチンチンから、ンッ、先走りのお汁が、溢れてきちゃっているわ\n……じゅるっ、じゅるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、これ吸われるのも、気持ちいいでしょ……？　ちゅぶっ、口の中で先\nっぽ……舐めまわしながらね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ、じゅぶっ、じゅぶっ、んちゅぶっ、ちゅぶっ、じゅるるぅっ♪\n　また……オチンチンがビクついてきたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゅぶっ、じゅるっ、んふぅっ♪　隊長ちゃんの声を聞きながら、\nオチンチンしゃぶるの興奮するぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「お口に収まっちゃう、お手頃サイズになったオチンチン……♪　ちゅっ、ち\nゅぶっ、もっともっと……気持ちよくなってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、じゅぶっ。ほらぁ……オチンチンがまた、口の中で膨らんで\nきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「また、マキママのお口の中にぃ、精液ぴゅ～ってだしたくなってきてるの…\n…伝わってきてるわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、じゅるるぅっ、もう少し激しくかしら……？　んふっ、我慢なん\nかさせないわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンから、またいっぱい精液をださせてあげるんだから♪　じゅるっ\n、じゅるるぅっ、じゅぶっ、じゅぶっ、じゅぶっ、じゅぶぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「マキママのお口っ、んっ、隊長ちゃんの精液を受け止める準備できているか\nらね」", "NORMAL" ]},
