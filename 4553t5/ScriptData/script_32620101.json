		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「じゅるるっ、じゅぶっ、じゅぶっ、んっ、んっ、じゅるるっ、じゅぶっ♪　\nいっぱい……吸って……っ♪」", "NORMAL" ]},
