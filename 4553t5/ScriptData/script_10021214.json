{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「な、なんですって……！？　この私が……偽者なんかに……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「覚醒したルナテミス……まさか、ここまで強くなるとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……そんなことはいい。問題はカツマ！　貴様だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……え？　お、俺！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いままで会ったこともない女に『母親だ』と言われたぐらいで、なにをうろ\nたえている！　本物である証拠など、なにもないのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114600002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたい、母親だかなんだか知らんが、貴様のいるべき場所はそいつのそば\nなどではない！　違うか、下僕！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114600003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………っ！　そうだったそうだった……！　そんなことで動揺してる場合\nじゃねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺は手のかかる姫様や、バカみてえにトラブルばっかり持ち込んでくる仲間\nたちの、世話をしてやらなきゃならねえんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふっ。まあ、そうだね！　担任という名の雑用係がいなくなると、こっち\nも困っちゃうし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「隊長とは名ばかりのパシリのこと、オレたちけっこう頼りにしてんだぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そういうわけでカツマ！　号令を頼む！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう！　なんか納得のいかねえ発言もちらほら聞こえてきたが、それはこの\nさい脇に置いとくぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「インクレディブル・スクワッド！　刻の女王を攻撃しろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「困った子だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわあああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はははははは！　どうした！　そこまでか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ははは！　地球の連中はこの程度か。まったく歯ごたえがないのう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くそっ……まだまだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほほう？　まだ向かってくるのか？　それなら、じっくり時間をかけて楽し\nませてもらおうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なにを油断しているですか。こいつら、実力はありませんが妙なツキだけは\n一流です。うっかり手を緩めたら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "とオボロが言った瞬間、周囲に轟音が響き、壁の一部が爆発する。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちっ……！　言ったそばから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114600002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あれは……スケバンサンダーとやらの悪趣味な戦艦？　それに、もう一隻は\n味方の艦ではないか！？　どういうことじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114600003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0131" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「よし、命中！　なかなかやるねえ、スケバンサンダー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114600001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0131" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おう！　オレさまの腕なら、ざっとこんなもんだ！　はははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010114600001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「長官！　そっちもいいぜ！　撃ちまくれ！　ただし、こっちの艦には当てる\nなよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114600002" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「わかってる！　ルミナス、よーく狙え！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114600001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「了解！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114600001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「全火力を時間城に集中！　カツマ隊長たちを援護する！　撃てーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114600002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETTEXT", "砲撃を受けた時間城は、たちまち混乱に陥った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ごほっ！　ごほごほっ！　くそっ……！　奴ら、煙に紛れてどこかに逃げた\nか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114600003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「城内は大混乱です。この状況では、見つけ出すのも一苦労でしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114600003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく……！　運のいい奴らめ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114600004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「言ったはずです。妙なツキだけは一流だと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114600004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「仕方ない……いったん引き揚げるぞ！　地球の女幹部どもめ、次こそは、こ\nの手でなぶり殺しにしてくれる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114600005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}