{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「え……私、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「そうだ。私の神性が君がそうだと告げている！！　が、一応質疑応答をして\nみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070001" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「君、子供のころから運動会や遠足など、行事で雨になったことは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070002" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「……そういえば、ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「洗濯物を干すときに雨になったりは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070003" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023070003" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「外に出かける用事があるときに、雨に降られたりは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070004" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「……ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023070004" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「決まりだ！！　君に決めた！！　私の力を受け取ってくれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070005" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「え？　へ？　そんな急に、わああああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023070005" ]},
		{"command":[ "SETCHARA", "0", "char_00000809_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「え……？　え、なに、この力は……身体の中からなにかが湧き上がってくる\n……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023070006" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「確かに託した……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070006" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……確かに、なんだか凄い力を感じる……それこそ太陽のような温かさ\nと力強さだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「うむ。これならヴァルナを止められるだろう。ピースムーンの中に生まれた\n太陽――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「名付けて、ピースムーン・ソレイユだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ピースムーン・ソレイユ……それが私」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「今の私は力が枯渇して同行できないから、カツマ、君が彼女と一緒に行って\nくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070009" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、俺もか？　俺は日輪の力を持ってないぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夏服" ]},
		{"command":[ "SETTEXT", "「いいから行ってください。隊長、女性の扱いは得意分野でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_090023070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000810_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ配下" ]},
		{"command":[ "SETTEXT", "「行くのなら、先ほどのセクハラは見逃してあげましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040023070001" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそ、しょうがねえな……分かったよ。でも俺、空を飛べないんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「では、私が抱えていきましょう。今の私なら、空も飛べます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070002" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「よし、それでは早速行ってくれ！！　私はここからサポートしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070010" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それでは、行きます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070003" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0194" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「雨雲を抜けたか……当たり前だけど上は晴れてるな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あーあー、聞こえるか二人とも。今、権能を使ってソレイユを通して会話し\nている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「本部のレーダーから雨雲の中心地はその東側になっているのが見えた。そっ\nちに向かってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「了解」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070004" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかし、この格好はなんというか……なんとかならないのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「お姫様抱っこは嫌いですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070005" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「嫌いじゃないが、俺がやられる方なのは違うような」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「我慢してください。お尻や胸を揉まれるよりはいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う……ぐ……わ、悪かったよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私たちじゃなければ訴訟ものですよ、本気で。まあ、私なら構いませんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070007" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか言ったか？　風の音で聞こえないぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「いえ、なにも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アグニが指定したのはこの辺のはずだが……あ、おい、あそこ！！　雨雲が\n固まって立てるようになってるぞ。降ろしてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「う……ううっ、うううううう～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070001" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「なんか……泣きながら怒ってる人がいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070009" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、お前、ヴァルナか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「うううう……誰なのです……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070002" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと、俺たちはＥＤＯの者なんだが……アグニに頼まれてここに来たんだ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お姉が……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前が雨を降らせてるんだよな？　そのせいで地上がヤバいんだ。ひとまず\n降り止ませてくれないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ううっ、ぐすっ……私だって降らせ続けたくないのですけど……ううっ、涙\nが止まらないのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「一体何があったのですか？　私たちで協力できることなら解決しますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070010" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「ううう……お姉が……お姉が、私に最近また太ってきたんじゃないかって…\n…ううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070005" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070011" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、確実にお前のせいじゃねえか！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「いや、その、なんだ。そう見えてしまったものだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だからってノータイムで口にしてんじゃねえよ。俺が言うのもなんだが、デ\nリカシーを持て！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「本当に隊長が言えたことじゃないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「うううっ、ううっ、私、太ってないのです……！！　引きこもっても、エナ\nドリ飲んでも太らない体質なのです……うううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070006" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうそう。お前は太ってないし、可愛らしい顔立ちしてるじゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「！！　ほ、本当なのです……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070007" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当本当！！　泣き顔じゃなければ、愛嬌もありそうだし。可愛いよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「えへ、えへへへへへ、褒めてくれるお兄さん、好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070008" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「女の私から見てもヴァルナさんは可愛いですよ。泣き顔じゃなくて、笑顔と\nか見てみたいな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070013" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お姉さんからも……えへへ、やっぱり私は魅力的なのです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070009" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「充分魅力的だよ。お前が可愛くないなんて言う奴がいたらぶっとばしてやる\nさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「お兄さん……なんだか、涙も引っ込んできたのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「チョロい……じゃねえ、良かった。ほらほら、笑って可愛い顔を見せてくれ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「そうそう。ヴァルナは可愛いよ。痩せればもっと可愛くなる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_010023070015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あーあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023070014" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_263_010023070011" ]},
		{"command":[ "SETCHARA", "0", "char_00026301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァルナ" ]},
