		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「数が増えたところで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「ざこざこなのは変わんないよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くそっ、やはり強い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「怯むな！　攻撃を続けていれば勝機はある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「うつべし！　うつべし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ああもう！　あの子たちもだけど、宇宙船からの援護も厄介よ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、どうやらあの宇宙船が暴走電波の発信源らしいですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれってどれだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほれ、いま襲来者リーダーが乗り移っているところです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114150002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいっ！　それを早く言えっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「激しい弾幕の中、伝えるタイミングを見計らっておりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114150003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんな聞いたか！　妨害電波の発信源はあの小型の宇宙船だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わかったけど、どうやって攻撃するんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114150001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「たしかに、あんな高度を飛ばれたら、誰も攻撃が届かないじゃないか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ！　ドラグソードならどうだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すまない、ドラグソードはいま車検にだしているんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114150002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「車検ってなんだよ！　あれ車じゃないだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「特殊車両ということになっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114150003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃあ、どうすれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0153" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「私にいい考えがあるわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114150001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なによ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅちゃん、車に変形して欲しいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114150002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「なんでよ。それに、車に変形したところで宇宙船をどうにかできないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「武器も使えなくなるんだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「そうだけど、お願い。Ｍ．Ａ．Ｍ．Ａに協力して～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114150003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「誰が貴方の言うことを聞くもんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａ、その作戦は本当に大丈夫なのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「自信あるわ。Ｍ．Ｏ．Ｅちゃんが協力してくれればだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114150004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「ふんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅ殿にとってはＭ．Ａ．Ｍ．Ａ殿は恋敵のようなもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114150004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「恋敵からの頼みは、やすやすと受け入れられるものではないでしょうなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114150005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅの気持ちはわからないでもないが、ここは頼む！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ｏ．Ｅ！　いまこそお前の力が必要なんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「か、カツマちゃん……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "PLAYVOICE", "v2_111_010114150006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「そ、そうね……カツマちゃんがそこまで言うなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150007" ]},
		{"command":[ "SETCHARA", "0", "char_00011102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「こ、今回だけは、Ｍ．Ａ．Ｍ．Ａの作戦に乗ってあげてもいいんだからね！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010114150008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、隊長さん相手には素直なのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010114150005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「車に変形したＭ．Ｏ．ＥとＭ．Ａ．Ｍ．Ａが、宇宙船からの砲撃をかわしな\nがら走る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_010114150002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うわっ、轢かれるとこだったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114150002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おいっ、そっちは崖だぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114150002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「いったい、なにをしようというのか！」", "NORMAL" ]},
