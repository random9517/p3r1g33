{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「青い空。青い海。白い砂浜……これぞ南国リゾートって感じだね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「こんなにも綺麗な海、はじめて見たよ。どんな生物がいるんだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530008" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「シャラ、ゲン。遊びたい気持ちはわかるけど、まずは先生と合流するのが先\nだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530011" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「合流って言っても、先生がいつ来るかなんてわからなくな～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530009" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それはそうだけど……これはミッションなんだし、遊ぶのはあとにしないと\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530012" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んなこと言ってるクセに、ホクの耳、ピンッて持ち上がってるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530007" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あっ、ほんとだ……ビーチを前にして、嬉しくなっちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530009" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ち、ちがっ……！　これはウサギのサガで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530013" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「本当はホク姉も遊びたくてたまらないんでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530010" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いい子ちゃんぶってないで、素直になったらいいじゃねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530008" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うぐっ……！　そ、そういうウタだって、耳が持ち上がってるじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530014" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そりゃリゾートなんて言われたらイヤでも気になっちまうし、遊びたくなる\nのがウサギのサガってもんだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530009" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうだよ～。それに先生が来るまでまだ時間ありそうだし、喧嘩してないで\n着替えて遊ばな～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530011" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「海だと水着の方が動きやすいもんね。本当はホク姉も遊んだり、泳いだりし\nたいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530010" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「でもこのあとの予定が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530015" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あー、もう！　お前は細かいことを気にしすぎなんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530010" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ゲン、シャラ。ホクなんてほっといて遊ぼうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530011" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "二人" ]},
		{"command":[ "SETTEXT", "「ラビットビーチ！　イェーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530011" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00009901_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、ちょっと……！　みんな、待ってよぉー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530016" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ウタ姉、そっちにボール行ったよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530013" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オーケー！　一撃で決めてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530012" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ごめん、ホク姉。ブロックお願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530012" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「任せて頂戴！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530017" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はっ！　オレのアタックが、ブロック１枚で止められるわけねぇだろうが！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530013" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「くっ……！　中々やるね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530018" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「遊びとはいえ、ホクに負けてられねぇからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530014" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「さっすがウタ姉。頼りになる～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530014" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「まだまだこれからだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530013" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いいぜ。かかってきな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530015" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「おーい、お前たち。遅れてすまん――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530007" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「って、なにを遊んでおるんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530008" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「あっ、先生！　お待ちしてました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530019" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「いや、どう見ても待っていたように見えないのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530009" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お前たち、ここに遊び来たワケではないとわかっておるのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530010" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そんなこと言ってる割に、先生もしっかり水着を着てるじゃないですか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530015" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「い、いや……！　これはカンゲイコ（寒稽古）という冬の時期に行うブドウ\nの衣装であって、決して水着というワケでは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530011" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ブドウの衣装なら、私たちが着てる水着も問題ないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530014" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そうそう。このビキニってのは、ニンジャがたどり着く境地……ビキニンジ\nャの衣装なんだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530016" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「それはそうだが……！　そもそも、私が問題にしているのは服装のことでは\nなく、ビーチで遊んでいたということであってだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530012" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「まあまあ。無事に合流できたことですし、先生の言う本拠地とやらに向かい\nましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530020" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「あ、ああ……そうだな……では、案内しよう。ついてこい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530013" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}