		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、お帰りなさー……あれ？　どうしたの、すっごくすっごくおつ\nかれね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おしごとでたいへんなことがあったの？　もういやになっちゃった？　おと\nーさん、いつもがんばってるのにね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ね、おとーさん、ちょっとしゃがんでくれる？　そうそう……えいっ、ぎゅ\nー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、いつもがんばってるの、イルル知ってるよ？　だから、いいこ\nいいこしてあげるね？　いいこ、いいこ……なでなで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひゃんっ、お、おとーさん？　イルルにぎゅーってしたいの？　ふふっ、じ\nゃあねえ、イルル、おとーさんをなぐさめてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えへへ、今日はおとーさんがあかちゃんね？　イルルのしっぽ、うちがわ\nはやわらかいから、いたくないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いつもがんばってるおとーさん、えらいえらい。あたまなでなでしてあげ\nるねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんもいいこいいこしてあげる。しっぽで、しゅっしゅ　イルルの\nしっぽ、きもちいーい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふっ、おとーさん、きもちよさそう……　もっとつよい方がいいの？　\nええと……こう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わわっ、ぴくぴくってしてる♪　おとーさん、いきがあらいよ？　もっとも\nっとする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「え？　おっぱいすいたいの？　イルル、おっぱい出ないよ？　それでもいい\nからすいたい？　ふふっ、いいよー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あはっ、おとーさん、ちゅうちゅうーって、あかちゃんみたい　くすぐっ\nたいよう、もう、さきっぽベロでつんつんってしちゃダメ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、今日はおとーさんをなぐさめるってイルル言ったもんね？　あたまな\nでなで～、おっぱいのめて、いいこいいこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんわすれちゃってたね、こっちもいいこいいこ　ひやってしてて\nきもちいい？　よかったあ、もっとするね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「しーこしこ、しーこしこ　ぴくんぴくんしてきもちいいね？　ぁんっ、お\nとーさん、おむねつよくすいすぎ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、イルルのおっぱいひっしにすっててかわいい……　もっとも\nーっと甘えていいからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふっ、くすぐったい　ちゅーちゅーって、音立てて、ぁんっ、イルル、\nなんだかせなかぞくぞくってしちゃうよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ、ごめんね、おちんちんもいいこいいこしなきゃね？　さきっぽもくりく\nりーってしてほしいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんくりくりー　おとーさん、きもちよさそう　あれ、さきっぽ\nから何か出てきたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「とろーっとしてる……んー、ちゅ、れろ……ぷぁ、おもしろい味……。あ、\nすべりがよくなったから、もっとしこしこできるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あはっ、ぬちゃぬちゃって音がしてる……♪　おとーさん、こしがはねちゃ\nってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃんっ、もぉ、おっぱいそんなにつよくすって、ふぁっ、さきっぽ、はむ\nはむってしたらやぁなの……、イルル、きもちよくなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だめだよおとーさん、イルルのおっぱいたべちゃだめえ　ちっちゃいから\nって、全部ほおばったら、べたべたになっちゃうからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「もう、イルルのおっぱい、おとーさんのよだれでべたべた……。てらてらひ\nかってる……それに、さきっぽ……ジンジンするの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ねえおとーさん、もっとすって？　イルルのおっぱい、つよくてもいいから\n、ね？　おっきなあかちゃんだもんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁはっ、んふっ、ふぁ……っ、おとーさんっ、もっと、もっとつよくすって\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちん、もっとぬちゅぬちゅしてあげるからっ、んふっ、ぁっ、おっぱ\nいきもちいよう……っ！　もっと、もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル、きもちよくなってごめんなさいっ　おとーさんいいこに　してる\nのにっ　イルルばっかりきもちよくなってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁはっ、おちんちんびくびくしてるっ　おとーさんもきもちいい？　もっ\nとしこしこしてあげるっ　しこしこしこっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃあっ！？　な、なになに！？　おとーさんのおちんちんから、白いのび\nゅーって、たくさん出てきたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのこし、びくびくってはねてる……！？　平気なの？　苦しくな\nいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「よかったぁ、きもちいいと出るのね？　せーし……っていうの？　わあ……\nまだ出てる……すごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「え？　やさしくしこしこするの？　えっと、こう……かな？　しっぽでやわ\nやわーってつつんで……しーこしーこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わあ、まだびゅーびゅーって出てくる……　ふしぎなにおい……イルル、\nドキドキしてきちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちゅ……んむ……じゅる……んくっ、ん……おとーさんのあじ……　なん\nでだろ、すっごくドキドキする……ちゅるっ、じゅちゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのきもちよさそうなかお、かわいい……　もっとぴゅっぴゅし\nていいんだよ　しーこしこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「え？　ちゅーしながら、おちんちんいいこいいこしてほしいの？　いいよお\n、んー、ちゅっ、ちゅぷ……ちゅぅ、れろ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁは……、おとーさんのちゅー、ベロでくちゅくちゅってするのね？　んー\n、これ好きぃ……　ちゅっ、れろ……じゅぷっ、ちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんもきもちよくしてあげるね？　しこしこ、しーこしこ……　わ\nわっ、びくびくってして、まだ白いの出てくる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「もうおしまい？　白いの出てこなくなっちゃったね？　おとーさん、つかれ\nたのなおった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「そっか、まだつかれてるのね？　いいよ、今日のイルルはあかちゃんの　お\nとーさんの、おかーさんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんの白いの、しっぽにくっついちゃったから、すごくぬちゅぬちゅ\nして、すべっちゃうから……つよくするね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふっ、びくびくしてる……つよいのがいいんだ？　ぐちゅぐちゅってえっ\nちな音してる　さきっぽもつんつんするね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁっ、もう、いきなりおっぱいすっちゃだめだよー……？　びっくりしち\nゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おっぱいはにげないから、ゆっくりすってね？　ちゅぱちゅぱおいしい？　\nミルク出なくてごめんね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃふっ、さきっぽひっぱっちゃだぁめ　取れちゃうからあ　おとーさ\nんのはないき当たってくすぐったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぎゃくのおっぱいさわりたいの？　いいよぉ、おっぱいすきにして？　イル\nルおかーさんのおっぱい、おとーさんのものだからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「くぅんっ、おっぱいのさきっぽ、ゆびでおしこんだりっ、かりかりってする\nのきもちいいよう……おとーさん、おとーさぁん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おっぱいもぉっ、もっとすって……っ　ちゅうちゅうって、いっぱいきも\nちよくしてぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのこともきもちよくしてあげるからね　おちんちんいーっぱい\nこすってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「もっとつよくていいの？　おちんちん苦しくない？　んー、おとーさんが言\nうなら……ええと……これくらい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんいいこ、いいこ……　わあ、まだおっきくなるの？　すっごく\nかたくなって、どんどんあつくなるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル、おとーさんのおちんちん好きかも？　なんだかこうしてしっぽでつ\nつんであげてると、むねがきゅーってする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「しこしこ、しーこしこ　おとーさんのおちんちん、いいこね？　毎日がん\nばってるおとーさんも、いいこいいこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あたまもなーでなで……　んふっ、ぁん……っ、おっぱいのさきっぽ、じ\nんじんしてきもちいいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃふっ、さきっぽかんじゃだめだよ、おとーさん　でも、もうちょっと\nやさしくなら……いいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁっ、やさしくかまれるのきもちいい……びりびりってして、\nせなかぞくぞくってするの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、おとーさんのおちんちんも、もうそろそろ白いの出ちゃう？　びくん\nびくんってして、さきっぽふくらんできたものね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほぉら、イルルのしっぽでびゅーって出していいよ？　しこしこで、びゅー\nってしちゃえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁんっ、おっぱいぎゅーってすっちゃだめぇ　んふっ、ぁあっ、おまた\nのところぎゅーってする……くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁはっ、おとーさん、きもちよさそうなかおしてる……　白いのびゅーび\nゅーって出してね、しーこしこ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「もお、おとーさん、ずっとおっぱいすったままなんだから……。そんなにイ\nルルのおっぱいすき？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「そっか、すきなんだあ……えへへえ、じゃあねえ、おとーさんがつかれたと\nき、いつでもイルルのおっぱいすっていいからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いつもはおとーさんがやさしくしてくれるから、おとーさんがつらいときは\n、イルルがたっくさんあまやかすの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いつでもおちんちんしっぽでしこしこして、きもちよくして、白いのびゅー\nびゅーって出させてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふっ、もお、おとーさん、まだおっぱいすってる……　え？　今日はこ\nのままねむりたいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほんとうに今日のおとーさんはあまえんぼうさんね　そのままおっぱいす\nってていいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんも、まだ白いの出てるから、のこりぜえんぶ出しちゃお？　しこ\nしこぴゅっぴゅ、きもちいいねえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁあ……何だかイルルもねむくなってきちゃった……。おとーさん、こっ\nちきて？　あたまぎゅーって抱いてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「それじゃあ、おやすみなさい……　おっぱいすったまま、ねむっちゃって\nいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃあっ！？　もうおとーさん、いきなりおちんちんつきだしてどうしたの\n！？　白いのすっごくとんじゃってるよお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「わわっ、イルルの顔までとんできた……びっくり……。ま、まだ出てる……\nだいじょうぶ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「白いの、口の中にちょっと入っちゃった……。んくっ、ちゅ……んむ、んん\nんん～、へんなあじ……にがなまぐさい？　おいしくない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「じゅる……ちゅ、む、ちゅる……おいしくないのに……あたまがぼーっとす\nる……からだの中からおとーさんのにおいする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんもつかれとれた？　イルルべたべたになっちゃったから、おふろ\n入りたいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ね、いっしょに入ろ、おとーさん　おとーさんのこと、あらってあげる！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「え？　おっぱいであらうの？　よくわからないけど、おとーさんが　してほ\nしいなら、ぜえんぶしてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おふろの中でもだっこしてほしい？　おっぱいすいながら？　ふふっ、もう\nおとーさん、今日はほんとうにあまえんぼう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、今日のイルルはおかーさんだから、してあげる　だから、明日には\nいつものやさしくてかっこいいおとーさんになってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「じゃあ、おふろ行こう？　ふふっ、たのしみね♪」", "NORMAL" ]},
