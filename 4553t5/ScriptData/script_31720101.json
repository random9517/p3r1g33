		{"command":[ "SETIMAGE", "0", "still_00017201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「首を振って……んじゅるるっ、生殖器の先端を、頬の裏に擦りつけるように\n……？　んじゅるるぅっ！　んふっ、んふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こうするとイイのですか？　んんぅっ！　んじゅるるっ！　生殖器が……ん\nぅっ！　口の中で、跳ねて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「出そう？　で、出るとは？　んじゅるるっ、んっ、んんぅ……っ！　じゅぶ\nっ、じゅぼっ、んじゅぼぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んはぁああぁぁああぁぁっ！　なっ、ンッ、ああぁっ！　生殖器から……ン\nンッ、ドロドロした……これは……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103129" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「せ……精液……なんですか……？　これがニンゲンの精液……んぅ……なん\nていやらしい匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「メガネのレンズにべったりと張り付くほどの粘り気で……ああ……目の前が\n真っ白になっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　んんっ、んぁあっ！　そんな……ンッ、レンズに生殖器を押し\nあてないで……んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「レンズに……んぁあっ！　生殖器が……はぁんっ、レンズの精液が……生殖\n器で塗り広げられて……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。メガネをこんなふうに汚されているのに……なぜだか…\n…ああ……ドキドキして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「レンズ越しの生殖器から目が離せない……。え……ちんぽ……？　生殖器の\nこと……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「生殖器のことを、ちんぽと呼べと……？　ちんぽ……ちんぽですか……。ち\nんぽ……ちんぽ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「なんだか……胸がざわざわするような響きですね……。ふふっ、ちんぽ……\n。私のメガネをドロドロにした、あなたのち、ん、ぽ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そして私がこれまでしてきたことは、ふぇらちお、と言うのですね……なる\nほど……それで、私のふぇらちおはいかがだったのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「獲物が笛なだけあって気持ちよかった？　それは……私が使用する楽器と関\n係があるのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ですが、あなたに悦んでいただけたのなら嬉しいです。私も、ニンゲンのち\nんぽについて知ることができましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それで、まだまだちんぽがこんなに硬いのは……ああ、勃起状態というので\nすか？　勃起、しているのは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私に、もっとふぇらちおをしてほしいからなのですか？　わかりました。ま\nたちんぽを咥えればいいのですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぁ……んむっ、んっ、んふぅ……。先ほど射精した精液が……んじゅる、\n口の中に……んんぅ……じゅるっ、じゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽ……んじゅぷっ、パンパンに膨れて……んじゅるっ、んふぅ……ちゅ\nっ、ちゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「まだまだ精液をだすことができるということなのでしょうか？　んちゅるっ\n、ちゅぶっ、ちゅぶっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽ……んぅ、んちゅぶっ、もっと気持ちよくしますね……んちゅぷっ、\nえ……胸も……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふぇらちおをしながら……んちゅぶっ、胸を、ちんぽをしごくように動かす\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こうでしょうか……？　んっ、んちゅぶぅ、んんぅ……ヌルヌルしたちんぽ\nが……胸に……擦れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んふぅっ、んっ、んんっ、じゅるるっ、んふっ、ちゅぶっ、ちゅぶぅ、ンッ\n、ちゅぱぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「このように……んちゅぱっ、胸と、口をつかって……んじゅるっ、ちんぽを\n刺激されると……気持ちいいのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちゅるっ、ンッ、とっても気持ちよさそうで……ちゅるるっ、私も、なんだ\nか身体が熱くなってきています……ちゅっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「匂いと味に夢中になって……んちゅぱっ、この熱を肌で感じ……ちゅるるっ\n、たまらなく身体が疼くようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽが美味しい……？　そうですね……んちゅるっ、あなたのちんぽを…\n…美味しいと感じています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「苦くて……しょっぱくて……んちゅっ。決して美味しいと思えるところはな\nいはずなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「でも……んじゅるるっ、私の視線は……あなたのちんぽにくぎ付けになって\nしまっています……んっ、ちゅっ、ちゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「このままもう一度、んちゅるっ、射精して……くださいね……。ちゅっ、ち\nゅぶっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたのちんぽから出る精液を、んちゅるるっ、また私に……味わわせてく\nださいませ……んっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「れろれろれろぉ……ンッ！　ちゅるるっ、んふっ、ちゅっ、ちゅぱっ、んん\nぅ……ちゅるるっ、んふぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽ……ちんぽちんぽ……んじゅるるるぅっ！　私の胸と……口で……ち\nゅぱっ、気持ちよくなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぶっ、じゅぶじゅぶっ、じゅぶじゅぶぅっ！　いっぱい……いっぱい精液\nを……じゅちゅちゅぅっ！　んっ、じゅるるるるぅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　ああっ、ああ～～～っ！　んっ、んふぅううっ！　んっくぅう\nううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あはぁっ、はぁ……はぁ……んんぅ……またぁ……。ちんぽから白いドロド\nロが……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の顔に……メガネに……。んはぁ……ふぅ……はふぅ……。またネバネバ\nが……たくさんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こんなに……はぁ、はぁ……、二回目だというのに、ニンゲンのちんぽは射\n精できるのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「しかも濃度も、一度目と変わらないほどに高く……。はぁ……ちんぽって…\n…すごいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それは私のおかげなのですか？　私の顔が……いやらしかったから……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そ、それは……恥ずかしいですね……。ああ……ふぇらちおをしているとき\nの姿を全部見られていたのですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「か、考えてみれば当然ですよね。隠すものもなく、こうしてちんぽを咥えて\nいたのですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……私はこんなに恥ずかしい思いをしているというのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたの顔は、精液でドロドロにされたレンズのせいでまったく見えません\n。不公平ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んんぅううっ！　んふっ、んふぅううっ！　んん……んっくぅ……んんぅう\nううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぐっ、んっ、んんぅ……っ！　精液……精液なのですか……んぶっ、口の\n中に……たくさん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んんぅっ、の、飲めと？　んぐっ、んんぅ……こんなに……たくさんの……\nんぐっ、んぐ……んぐぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んはぁっ！　はぁっ、はぁ……っ！　の……飲めました……。んはぁ……精\n液……全部飲んでしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「喉が詰まるかと思うほど、濃厚で……。これが先ほど、私のメガネにかけら\nれていたのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしてもニンゲンの精液というのは、二度目でも大量に出るの\nですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「これと同じくらいの量で、同じくらいの濃さの精液が、私のメガネにかけら\nれていたのですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ところで、あなたのちんぽはまだ私の胸の間でビクビクとしていますね？　\nこれは……まだできるということなのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「人間のちんぽというのは興味深いですね……もっともっと、私にちんぽを教\nえてくださいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふふっ。それではもっと学ばせていただきます。あなたのちんぽについて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103410" ]},
		{"command":[ "WAITINPUT" ]},
