		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「これから一緒に戦うことになるあなた方ニンゲンのことを、もっとよく知り\nたいと思いまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「もし、あなたがよろしければ……。え？　いいのですか？　ありがとうござ\nいます！　ではさっそく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……って、なっ、なにをしているのですか！　急に生殖器を露出するだなん\nて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それは……ニンゲンの……ましてやオスの生殖器なんて……。見る機会など\nありませんでしたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「胸で挟んでみろ……？　そ、そんなこと……ああ、でも……少しくらいなら\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103106" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……んぅ……。これがニンゲンの生殖器……。なんだか不思議な感じで\nす……胸で挟むだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017201_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「乳房に熱を感じます……こんなに熱く……。あんっ、それに胸の間でビクビ\nクとして……んっ、暴れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「えっとこの場合どうすれば……。口を使ってこれをおさえるのですか！？　\nつまり……こう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ん……んむ……ちゅぶぅ……。こんなふうに……？　んちゅぶっ、生殖器を\n口に含み……？　ん……ちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ちゅぱ……。まさかこのような……んちゅっ、口でニンゲンの生\n殖器を……ちゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「しかもこうしていると……ンッ、生殖器が舌にあたり……んれろっ、しょっ\nぱい味が……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ですが……ちゅぶっ、不思議と嫌な気分がする味ではなく……ちゅるるっ、\nなんでしょうか……この気持ちは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んはぁ……。ちゅぶっ、ちゅるる……なんですか……？　気持ちいいのです\nか……？　んっ、ちゅばっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「その調子でもっと、ですか？　はい、わかりました。えっと……こうでしょ\nうか？　んっ、ちゅるるっ、んぶちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「舌を？　ちゅるっ、んちゅぶっ、動かして……んれろっ、れろっ、んじゅぷ\nぅ……こう……でしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぶっ、んふぅ……。ちゅ、ちゅ……んれろっ、れろんっ、れ\nろれろ……ンッ、べろろぉ～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「舌が痺れるような味……ちゅるっ、なのに……病みつきになりそうな……。\nはぁ……んっ、ちゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「口が……あなたの生殖器で……んちゅっ、いっぱいになっています……ちゅ\nるるぅ……んっ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「鼻を抜ける……んじゅるるっ、ニンゲンのオスの香り……ちゅぶっ、ちゅぱ\nぁ……なぜでしょう……胸が高鳴ってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はむぅ……ちゅぶっ、ちゅぶぅ……ンッ、ちゅるる……んふぅ……ちゅぶっ\n、ンッ、ちゅぱっ、ちゅぱっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「どんどん口の中から唾液が湧き出て……んふぅ……あなたの生殖器をぬるぬ\nるにして……んちゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こんなに熱く……硬く、大きく膨らんで……んじゅるるるるぅっ！　はぁ…\n…はぁ……これがニンゲンの生殖器……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「咥えて……もっと吸うように、ですか……？　わかりました……んじゅるっ\n、ンッ、じゅるるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00017201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅぶっ、んっ、んっ、じゅるるっ！　んふぅっ、じゅぶじゅぶ\nっ！　ンンッ！　んふぅ……じゅるっ、んぶっ、んぶぅっ！」", "NORMAL" ]},
