		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「このようなところに呼び出してすみません。その……仲間のエルフには聞か\nれたくない相談なんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0103101" ]},
