{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……と、いうわけでＢＢ隊のＢＢ嬢たちが命がけで、貴重なデータを入手し\nてくれた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「一番命がけだったのは、スケバンサンダーさんの宇宙船に乗ったときでした\nけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00006502_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「思いっきり安全運転だったろ～？　大げさだなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはともかく、貴重なデータってなんなんです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「惑星・アイザモフで、時間帝国が建設している大規模拠点の設計図です。彼\n女たちはこれを『ファウンデーション』と呼んでいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ファウンデーション……？　なんで時間帝国が化粧品を作ってるの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「誰かがボケるとは思っていましたが……実はなかなか鋭いボケです。ダイヤ\nナさん、ファウンデーションとはなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ファウンデーションって言うのはお化粧の基礎……下地を作るものよねえ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「その通り。ファウンデーションとは、基礎、基盤、土台を意味します。つま\nり時間帝国はここを侵略のための基盤――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090116000003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いわば『恒久前線基地』とするつもりなのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090116000004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなことになったら、ますます奴らの攻勢は強まるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんとかして、建設前にスキンケアをぶっ壊す方法はないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ファウンデーションです。建設中とはいえ敵の守りは硬く、普通の手段では\n破壊不可能です。しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090116000005" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そこで、わたしたちの手に入れたデータが役に立つわけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「弱点か！？　なんとかいう基地の弱点がわかったんだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「はい。『ファウンデーション』内部には、『工房』と呼ばれる超兵器製造プ\nラントが設置される予定です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ここには研究のため、大量の危険な物質が貯蔵されており、基地全体のエネ\nルギープラントとも直結しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010116000002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「設計データを解析した結果、完成前ならばこの『工房』に侵入できるルート\nがあることがわかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010116000003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「つまり、ここに潜入して吹っ飛ばせと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116000001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。それをカツマ隊長とＧ・ルナリアムのメンバーにやってもらいたい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれ……また貧乏くじか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「弱音を吐くな！　基地とやらを放っておくわけにもいかんだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうした、ハルノブ？　気になることでも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「いえ……確かにこの設計図を見ると、潜入も爆破も可能です。可能ですが…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116000003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ですが？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なんだかちょっと、変な感じがしますね……都合が良すぎるというか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116000004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「忍者の勘ってヤツか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そんなところです。ですが……ここまで見え見えな罠を仕掛けるおバカもい\nないでしょう。気にし過ぎかもしれません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116000005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ま、なんでもいいからがんばってくれや～。んじゃ、オレはこれで……あ！\n　そうだ！　長官さんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116000002" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ん？　なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116000003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「このへんに、いい飲み屋ないか？　せっかく懐もあったまったことだし、一\n杯ひっかけて帰ろうかと思うんだけどよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010116000003" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おお！　そうかそうか！　それならいい店があるぞ。よしよし、私が案内し\nよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116000004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、長官まで一緒になって飲まないで、ちゃんと帰ってきてくださいよ！\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}