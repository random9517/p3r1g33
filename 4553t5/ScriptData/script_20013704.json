{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0191" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ふむ……ここが遺跡の入り口ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、この遺跡は幾つか入り口があって、そのうちの一つがここらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「入り口が幾つか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「中がどうなっているかは分かんねぇけどよ、外側にはいくつかの入り口が用\n意されてるらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580001" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「インクレディブルスクワッドの連中も、もう中に入っているかも知れんが、\nここから入ったとは限らないということだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「なるほど。まぁいずれ中で相まみえることもあるでしょう。行きましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あー、それなんだがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580002" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「なんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……これを禁ず……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……なんです？　今、何かどこかから声が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580005" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……これを禁ず……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……？　何を言ってるんですか、これは……むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580006" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なるほど、確かに何か壁のようなものに遮られて通れない……聞いていた通\nりだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580003" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「どういうことですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580007" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ジェスタが言ってたのさ。この遺跡は、条件を満たしたやつしか入れないっ\nてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580004" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「で、この入り口が、そいつを判別する検問みたいな役割を果たしてるんだと\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580002" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……確かに、今のままだと誰も入れそうにないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「……そこまで分かっているなら、当然条件も分かってるということですよね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580008" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「当然だ。と言うか、今、聞こえてきた声が教えてくれただろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580005" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「声……？　先程の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580009" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……これを禁ず、だったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そういうことだ。だから、ジェスタから預かったこいつに着替える」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580006" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「着替え……って……なっ……ちょっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580010" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580007" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「どうしたって……な、なんですかっ、この布地……ペラペラじゃないですか\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580011" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だからビキニだよ。しかも、ただのビキニじゃない。戦闘用に特化したビキ\nニンジャ装束だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580008" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ビ、ビキニンジャ装束……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580012" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「なんかさ、ただのビキニだけだとダメなんだって。おい、そうなんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580003" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「鎧は通す……水着は通さない」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「なっ、ただビキニ着けてりゃいけるかって言ったら、違うんだとよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580004" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「何をさらっと、よくわからない声と意思疎通してやがるですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580013" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どうやら、戦闘に特化したビキニアーマーでないとダメらしい。だから、戦\n闘に適した機能性を持たせたこいつだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580009" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「うぅ、けど、これはいくら何でもって……あ、貴方達っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580014" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「何だよ、モタモタするなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580010" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「要するに、こいつに着替えないと中に入れないってことだろう？　さっさと\nした方がいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「だからって、こんな所で着替える奴がどこにいるですっ、最低限の慎みをっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580015" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「別に誰も見てねぇし、お前さんの貧相なカラダに大した興味はねぇよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580011" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「んぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580016" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「ははっ、私はそういうスレンダーって奴も嫌いじゃねぇよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580005" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「何をニヤニヤしてるですっ！　くっ……まさか、ウチが……こんな頭の悪い\n格好を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580017" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おい、どこに行くんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580012" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「物陰に行くだけですっ！　そんな誰でも堂々と恥知らずなことが出来るなん\nて思うなですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580018" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「やれやれ、神経質なことだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580006" ]},
		{"command":[ "SETCHARA", "0", "char_00009703_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0191" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「う……うくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580019" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっと来たかか。ビキニに着替えるのにどれだけ待たせるんだか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580013" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「案外似合ってるじゃんか。そんな縮こまってないで、堂々としてりゃいいの\nにさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580007" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「何のフォローにもなってないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580020" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「とにかく、これで通れるようになるんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022580005" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「試してみればいい。おっ……押し返す感触がなくなってるってことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022580014" ]},
		{"command":[ "SETCHARA", "0", "char_00010007_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「おー、マジで通れた通れた。へぇ、どういう仕組みなんだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580008" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「仕組みに興味はない。さっさと行こう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080022580006" ]},
		{"command":[ "SETCHARA", "0", "char_00000412_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａウタマロ" ]},
		{"command":[ "SETTEXT", "「やれやれ、遊び心のない連中だねぇ。ほれ、オボロもさっさと来いよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_030022580009" ]},
		{"command":[ "SETCHARA", "0", "char_00009704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「分かっています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580021" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「くぅ……まさか、ジェスタのやつ……最初からこのことを知っていてウチに\n任務を……覚えてやがれです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090022580022" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}