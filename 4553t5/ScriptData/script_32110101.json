{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「はーい、大丈夫よ、リラックスしてね。んふぅっ……んくんっ……あぁ……\nいい具合に収まっちゃうわね……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「何を驚いた顔をしているの？　ちゃんと協力してくれるって言ったじゃない\n。だから、精液採取させてもらうの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「貴方の視線……ずっと私のおっぱいに向けられていたでしょう？　だから、\nパイズリで搾り出してあげるのが一番かなと思って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ……貴方、そこそこ絶倫なんでしょう？　楽しみだわ……どれだけ濃\nいのが出てくるのか、期待しちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「でもまあ、そう難しいことは考えないで、シンプルにおっぱいのこと楽しん\nでくれればいいのよ。それじゃ、動かすわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ……ほら……こうして……んっ、チンポをしっかりと重ねてあげるの\n……んんっ、どうかしら……柔らかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ぎゅっと埋め込んであげると、体温が直接伝わっていいわよね。ふふ、私も\n貴方のチンポの脈動……しっかりと感じてるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ、は……んっ……縦にスライドさせて……くびれの所を、何回も……刺\n激してあげて……あっ、ふっ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あらあら、もう顔つきが変わっちゃったわね。パイズリ慣れしてるかと思っ\nたけど……そんなことなかったかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ああ、でも心配しなくてもいいのよ。別に、すぐ出しちゃっても困ることは\n何もないから。出したくなったら、すぐに射精していいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ほら、ゴムの予備はいっぱい用意してあるから、どれだけ出してもいいの。\nんっ、待ってね……もっと強くされたいわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ……あぁ……んっ、汗で……くちゅって音がしちゃうわね……\nんふっ、おっぱいの中で、オチンポが色々な方向を向いて……可愛いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「なんて……言ってるうちに、余裕がなくなってるわね。ふふ、先走りが滲ん\nで来たみたいだし、そろそろね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、いいわ……まず、最初の一発出しちゃいましょう。ほら……遠\n慮なんかしないで、気持ちよくドピュッと行きましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ、はっ、うんっ……んっ、さあ、出しなさいっ……一発目よ……あっ\n、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ、出てきたわね……ふふっ、いいわよ……ゴムがあるん\nだから、思いっきり出しなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103116" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「へぇ……非常識な量を出すかと思ったけど、そこまででもないわね……どれ\nお味は……ちゅぷっ……んふっ、あら……これはよさそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「濃さも申し分ないけれど、何より成分かしら……ちゅぷっ、これは搾りがい\nがありそうね……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、さあゴムを替えましょう。そうしたら、改めて、んっ……おっぱい\nを楽しんでもらおうかしら……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「精液で滑りやすくさせてあげれば、もっと効率がいいかも知れないけど……\n今は、まだ……ゴム越しで我慢して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「そのかわり……んふっ、さっきよりも、敏感になっているオチンポに天国を\n見せてあげる……ほら、沈めちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ここから、ずりゅずりゅって……あんっ、継ぎ目の所を刺激してあげる……\nふふっ、ね、気持ちいいでしょう、私のおっぱいも……感じてるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ね、乳首がツンと上向いてるでしょう？　いいのよ、ちゃんと見て……ここ\nも、くにくにしてあげる……んふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ……亀頭と乳首の連続キス……痺れるわ……キンタマにもギュッと力が\n入って……今も新しい精液を準備しているのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ、その調子でもっと踏ん張って……気持ちいい射精……どんどんして\nいきましょう？　あぁ……また脈打ってるの……逞しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ！　ここ……好きなのね？　分かったわ……もっとしてあげる……おっ\nぱいプレスよ……あふっ、いい気持ちでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ほぉら、またオチンポから、せり上がってきているの……分かっちゃうもの\n。さあ……続けて出しちゃいましょう、ほら、ぴゅぴゅって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ……！　はい、２発目ね。そうそう、腰を突き出して……振り絞りま\nしょう。ふふっ、いいじゃない。勢いが全然変わってない……頼もしいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103128" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「さあ……またゴムを交換して……あら、ちょっと休みたいの？　もう、まだ\nまだこれからじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「いいわ、ゆっくり着けてあげるから……その間リラックスしていて。んっし\nょ……と……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい、笑っちゃって。だって、休みたいなんて言う割には、ずっと\n私のおっぱいを見ているんですもの。ああ、いいのよ、もちろん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「でも、結局好きなのよね。そういう正直なオチンポ……本当に好きよ。さあ\n、心機一転……またおっぱい感じましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ほら、このシリンダーが一杯になる所まで頑張って。オチンポ……もっとも\nっとよくなりましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁっ、うんっ……んふっ……いいわぁ……やっぱり男はこうでな\nくちゃ……ずっと固いオチンポ……素敵よぉ……あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「私も調子が出てきたわっ……んっ、もっと激しく擦ってあげるっ、続けてど\nんどん出しちゃいましょうっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ほらっ、んっ、擦られたままだと……ジンジン痺れて堪らないでしょう？　\n連続射精……見せてちょうだいっ……はんっ、あっ、んふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あんっ！　これで３発目っ……んふっ！　あぁ……全然衰えないわ……これ\nは私の期待値を上回ってくれそうね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ、ゴムがもういっぱい……これは、いちいち用意してたら効率が悪いか\nもしれないわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「待ってね……んちゅ……せっかく出してくれた分、無駄には出来ないもの。\nしっかり入れて……と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふ……今のペースなら、本当にすぐに溜まっちゃいそう……貴方、本当に\n素敵よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「さあ、調子も出てきたみたいだし……ここから、またもうひと頑張りしても\nらいましょうか。ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「まだたった３発じゃない。貴方のオチンポのポテンシャルは、こんなものじ\nゃない筈よ？　もちろん、私ももっと本気を出していくわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ええ、ここから先はゴムなんて野暮はなし。ナマで直接おっぱいを堪能して\n……ほら……直接肌が触れ合うと……全然違うでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あんっ……私も、ずっと肌がピリピリしてるわ……やっぱり精液まみれのオ\nチンポを直接感じられるのは興奮するわよね……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ほら、貴方の腰もビクビクしてる……可愛いわね、射精が続いてハイになっ\nてるのかしら。でも、しっかり芯は残ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ、はふっ、後は……キンタマの方も忘れずマッサージしてあげましょう\nね。ナマ出しは勢いが大切だもの……しっかり準備しておかないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「うんっ、はんっ、んふっ……はぁ……あぁ……扱けば扱くほど……気分が高\nまって……あぁ、私も……蕩けて来ちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、あっ、はんっ、あんっ、はぁんっ……あっと……今度はすぐ\nに出さないようにしてね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「今度の射精は、ずっと溜めて溜めて、一気にドピュッと出す方向にしてみま\nしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「だから、もうちょっとお腹に力を込めて、そうそう……うっかり漏らしてし\nまわないようにね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ……ふふっ、だからと言って、手加減する訳じゃないから。また、乳首\nと亀頭……キスさせましょうか……はんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ……いいわ、どんどん盛り上がって来ちゃう……んっ、んふっ……もっ\nともっと、オチンポを感じたくなっちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「密着状態で……んっ、すぅぅぅぅぅっ……はぁぁっ、このオスの匂いを嗅い\nで……おっぱいの中にオチンポを埋めて……ぐりぐりしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んぁんっ、カリの固いところっ……いっぱい擦れるぅっ！　んくっ、もっと\nがいいわよねっ、ふんっ、あんっ、んくうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ……感じるわっ……んっ、オチンポもビクビク来てるっ、まだよっ……\nもうちょっと我慢して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ、余裕がないのは分かってるわ。我慢汁も、ぴゅるって出てきてるも\nの……だから、後少しだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「根元をしっかり抑え込んで……シコシコさせて……ふふっ、また可愛い顔さ\nせちゃって……さあ、ラストスパートよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ずっと溜めて、溜めて……待ちに待った状態でドピュッと出すのは最高でし\nょう？　あぁっ、来るわねっ、オチンポが前のめりになって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「どこに出したいのっ……ふふっ、おっぱいに中出しがいい？　それとも……\n私の顔にぶっ掛けたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「どこでもいいわっ、貴方の好きなところに、自分自身の欲望を思い切りぶち\n撒けなさいっ！　ビュクビュク射精する所を見せるのよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふ……おっぱいマンコに中出ししたいのね？　いいわっ……ほらっ、出し\nなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　いいわっ……あふっ！　んぁっ……新鮮なナマ精液っ……溢れ\nて来てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んんっ、もっとよ……一気に出しちゃいなさい……おっぱいの中をドロドロ\nにさせて……はぁん、肌の奥にまで全部染み込ませてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっふ……敏感な今だからこそ、こうして搾り出すの……気持ちいいでしょ\nう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ほら……ぎゅうっと……あんっ！　いいわ……残さず谷間を浸してちょうだ\nい……んふっ、ずりずりしてあげる……んんっ、そうそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「出し切ったかしら……ちょっと失礼……んちゅぷっ、ちゅぱっ……んーっ、\n素晴らしいわ。濃さが全然変わってない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ふふ、ほんの味見のつもりだったのに、ついつい舌が伸びちゃ\nうわね。勿体ないけど、クセになっちゃう味……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ……どうやら、全部出せたみたいね。本当に頑張ってくれたわ……どう\nも、ありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「流石に疲れたかしら？　ふふ、そうね……ずっとオチンポには頑張ってもら\nったものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「じっくり休んで……そうしたら、また再開しましょう。ほら、ここも、もう\n少しで一杯になるから……それまで頑張りましょう、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「そう……顔にぶっ掛けたいのね？　もちろんいいわよ、遠慮せずに、思いっ\nきり出しなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　そうよっ……んんっ！　濃厚ナマザーメンっ！　顔にいっぱいぶ\nち撒けてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「はぷっ……んふっ、いいわ……浴びてるだけで若返るような気分……いいの\nよ、直接オチンポを押し付けて……あんっ、そう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「ええ……出しながら頬に塗りつけて……ふふ……気持ちいい……？　私もよ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ……まだ残ってる？　この際だから、全部出しちゃいましょう。最後の\nもうひと踏ん張りよ、ね、頑張って……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ……もう一回、いいのが飛んだわね……れろ……ちゅぷっ、んんっ……\n本当に濃さが変わらない……素晴らしい素質の持ち主だわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「頬に塗り拡げて……すぅぅ……んふっ、あぁ……匂いも好みね。これは、本\n当に研究の価値がありそうだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「最後にもう少しだけ搾って……んっ、はい、これでよし……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「流石に疲れたかしら？　ふふ、そうね……ずっとオチンポには頑張ってもら\nったものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ.マジョウ" ]},
		{"command":[ "SETTEXT", "「じっくり休んで……そうしたら、また再開しましょう。ほら、ここも、もう\n少しで一杯になるから……それまで頑張りましょう、ね」", "NORMAL" ]},
