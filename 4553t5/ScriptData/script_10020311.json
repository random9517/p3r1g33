{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして、また時間は飛んで翌日の放課後……。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふふふふふふ……勝てる！　この作戦なら勝てる！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「超重戦車マウス……。プラモデルを探すのに苦労しましたけど、その甲斐は\nありそうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「見てなさいよ、怪獣戦車のボケナスビ！　今度こそあいつを壊してやるんだ\nから！　みんと！　グレーテル先生！　そっちはどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……マシンの前で待機中」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113370001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「モニターで、そちらの様子を確認しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113370001" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こっちが合図したら、すぐに動くのよ！　いいわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「わかってるわよ！　そっちもしっかりやんなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113370001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "シミュレーションマシンの外で、ほかのチームも準備万端だ。あとは、こっち\nで怪獣戦車をやっつければ……！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「……来ました！　１２時方向！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113370001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「やるわよ！　いいわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「了解です！　いつでもどうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「せーの……撃てぇええーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナの号令で、マウスが砲撃を始める。さすが巨大戦車、すっげえ轟音と\n振動だな。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はずれ！　ちょい左！　あ、まって！　光線が――きゃああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわああああっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「正面から食らった……！？　でも、まだ行ける！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113370002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ほ、本当に大丈夫なんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫……なはずだ！　なんとか、もう少しあいつに近づけば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「光線、もう一発来るわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「きゃあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113370003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ゃあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫、まだいける！　もう少しいける！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これ以上食らったら、もうもたないかも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もうすこし……もうすこし！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "のぞき窓から見える怪獣戦車の姿が、だんだん大きくなってくる。もうすぐだ\n、もうすぐ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「カツマ！　怪獣がまた、口を開いてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113370004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「光線、きます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370006" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんと" ]},
		{"command":[ "SETTEXT", "「あああっ！　マウスの車体が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_015_020113370002" ]},
		{"command":[ "SETCHARA", "0", "char_00001502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「……大丈夫。カツマの作戦通りなら、きっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113370002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ああああ！　パテで固めたところにヒビが！　カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そろそろだな！　みんな、行くぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0124" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ドラグソーーーード！　発進！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "PLAYVOICE", "v2_001_070113370008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちが叫ぶと、マウスの車体が吹き飛び、中からドラグソードが姿を表す！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ははははは！　マウスのでっかい車体なら、中にドラグソードのガレージキ\nットを隠せると思ったんだ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「苦労して改造した甲斐がありましたね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113370008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それはいいけど、動けそう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待ってください……？　思った通りだ！　いけます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「まさか、足の裏にキャタピラを貼り付けただけで『戦車』って判定されるな\nんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113370001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「ホント、判定がザル……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113370003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「いいじゃない！　いけいけー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020113370002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はははははは！　見たかボケナスビ野郎！　これが俺の『桃からドンブラコ\n作戦』だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「しかしこれは、いわゆる魔改造というヤツですな。最近の用法ではなく、原\n作で使われた『反則スレスレ、マナー違反』的な意味において」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113370001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「原作ってなんだよ、わけわかんねえこと言ってんじゃねえ！　とにかく、怪\n獣戦車をやっつけるぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうよ！　覚悟しなさい、このボケナスビっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113370010" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}