{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「騒がしい依頼主に手を引かれ、僕はまた正義の前へとやってきたのだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「一見すると、数時間前となにも変わっていない。しかし名探偵の僕は些細な\n変化も見逃さない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115170002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「これは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あのタヌキ像が、宝箱を持つタヌキ像に変わっている……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、切り札は常に僕の前に現れるようだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115170003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんだお前ら、また来たのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほむら！　この像をくれ！　すぐに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　どうしたんだ急に……って、ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「このタヌキ像……顔がルナテミスたちにそっくりじゃねぇか。前はこうじゃ\nなかったぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いつの間にこんなんなっちゃったんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それは僕から説明しよう。僕の推理では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115170004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「局地的な時空変動が原因かもしれないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ここにあったタヌキ像と、私たちが探していた『宝箱を持つタヌキ像』が入\nれ替わったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115170003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「時空変動は特定周期で起きる。時間帝国の奴らが時間を気にしていたのは、\n時空変動が起きるタイミングを待っていたからだったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115170004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……そ、それを言おうとしたんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115170005" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、よくわかんねぇけど、欲しいんだったらやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「店の前に知り合いの顔にそっくりな像があるってのは、なんだかキモいしな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか！　……って、いまキモいと言ったか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「感謝する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115170005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、いいっていいって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115170007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おいっ、無視するな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「これで、この事件も一件落着かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115170006" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「そこまでじゃよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115170001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……その声は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あやしいところに、ふごふご、張り込んでいて、もぐもぐ、正解だったぜ…\n…。うま味ーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、そのタヌキ像をこっちによこしてもらおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「断る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115170006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「誰が貴様らなんぞに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なら、しかたないのう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115170003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「力づくだな？　腹ごなしの運動にはちょうどいいぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115170002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ったー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「姫様、援軍だよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115170001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よーし、お前たち！　絶対にこのタヌキ像を渡すんじゃないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115170008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
