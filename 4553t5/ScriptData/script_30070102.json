		{"command":[ "PLAYVOICE", "007_0104409" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余はもう、お主のオチンポの虜になってしまった……余の全部を、あなたの\nオチンポで征服されてしまった……」", "NORMAL" ]},
