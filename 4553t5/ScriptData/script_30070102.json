{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "007_0104101" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くっ、はぁ、はぁっ……一体、どういうつもりじゃ……！　女王たる余にこ\nのようなことを……覚悟はできておるのだろうな！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104102" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「女を動けぬように縛り付けて、ふくぅぅっ、その身体を好きにしようなどと\n……男の腐ったような奴め！　恥を知れっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104103" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はくぅぅっ……！　貴様はもっと、気骨のある男だと思っておったが……ぐ\nぅぅっ、見損なったぞ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104104" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あまつさえ、このようなものを……あくぅぅっ！　はぁっ、はぁっ……ま、\n待てっ！　そんなところにまで……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104105" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっひぃぃぃっ！　ローターっ、ビリビリぃっ、強すぎるぅっ……！　くっ\n……このような生ぬるい責めで、んぁっ、余が、屈するとは思うな……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104106" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……ん？　ちょ、ちょっとタンマ！　お主、ドコへ行く気じゃ……？　まさ\nか余をこのまま放置するなんてことは……ないよな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104107" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……ちょちょちょ！　いくらなんでも、それはヤりすぎじゃろっ！？　さす\nがの余も、そんなことをされたら、おかしくなってしまうのじゃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104108" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「せめてもう少し弱めて……んおぉぉっ！？　なぜ強くしたぁっ、あひぃぃっ\n、ま、待つのじゃ、ほ、本当に置いていくなどと……ぉひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104109" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃっ！　イグッ、またイぐっ、イグっ！！！　もう、ずっとイって\nるのじゃっ、もう本当に、おかしくなってしまうっ、のほっ、イぐっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104110" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ……ば、バカモノっ！　本気であのまま置いていくやつがあ\nるか！　しかも、遅いのじゃ！　アホ、ノロマ、アンポンタんっほぉぉっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104111" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あひぃぃっ！　わかったのじゃ！　もう逆らわぬから、止めるのじゃ！　も\nうブルブルはイヤなのじゃあっ！　あっあっあっ、またイクっ、イグっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104112" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「っぁ、はぁっ、ひぃ、ひぃっ……くぅぅ、お主のような男に好きにされると\nは……屈辱じゃ……だが、くぅぅっ、もう、ガマンの限界なのじゃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104113" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ、ずっと乳首やクリトリスばかりで……奥がジンジンと疼いて\nおる……切なくて、おかしくなりそうじゃ……だから、頼む……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104114" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……なっ！？　こ、ここまで余を辱めておいて……さらにそのようなことを\n言わせようと言うのか……！？　ぬぅぅ、この鬼畜めぇぇ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104115" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……そういうところがまた、あやつにそっくりで……くぅぅっ……余の女が\n余計に疼いてしまうではないかぁ……くっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104116" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……い、挿れて欲しいのじゃ……お主のその大きくて立派なチンポで、余の\nオマンコを……奥までハメて、激しくズポズポ、してほしいのじゃあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104117" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おっほぉおおおおんっ！！　おっ、おぉっ、オチンポぉっ！　やっと入って\n来たのじゃあっ、んひぃぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104118" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「大きくて、固くてぇ、立派なオチンポがぁ、あぉおんっ、あっ、あひぃぃっ\n、キツキツのロリオマンコをかき分けて、奥まで入ってくるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104119" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「反り返って、ゴツゴツしててぇっ、ぉおぉんっ、奥まで、届いてるぅっ！　\nあひぃぃっ、ひぃっ！　子宮口、ゴリゴリっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104120" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「久しぶりの、オチンポなのにっ、余のオマンコ、奥までぐじゅぐじゅっ、あ\nふぅぅんっ！　放置されて、トロトロにとろけてるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104121" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぅぅっ、屈辱なのじゃ、このような男に、あひぃんっ、ずっと守ってきた\n貞操を、奪われてしもうたぁっ、あぁんっ、ごめんなさい、なのじゃぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104122" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、そこ、そこダメなのじゃっ、カリ首でほじほじされたら、あひ\nぃいいんっ、ひぃいんっ、ソコぉ、弱いのじゃぁっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104123" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひぃ、ひぃんっ、バレてしまったぁ、んひぃぃっ、あやつしか知らない、余\nの弱点を、あふぅんっ、見抜かれてしまったぁ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104124" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、このままでは、負けてしまうっ、余のオマンコが、このオ\nチンポの形に変えられてっ、あふぅんっ、オチンポを好きになってしまうっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104125" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ！？　あっ、あっ、オチンポ、大きくなって……んぉぉっ！？　\nあひっ、あひっ、カリ首も鋭いっ、ふきゅうぅっ、ナカを引っ掻いてるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104126" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「亀頭、固いぃっ！　おぉんっ！　おほぉんっ！　奥っ、子宮口ぉっ、ドチュ\nドチュっ！　ソコばっかりイジメないでほしいのじゃぁ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104127" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んぉっ！？　おっ、おっ、オチンポっ、奥ばっかり、小突いてっ、ぉおぉん\nっ！　オマンコ、仕留めに来てるっ、トドメを刺しにきてるぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104128" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余のトロトロ、ロリオマンコでぇ、オチンポしごいてっ、あひぃんっ、あっ\n、あひっ！　オマンコの奥に、射精する気マンマンなのじゃあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104129" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、ダメぇ……ダメなのぉ……おぉんっ！　ナカは、あやつだけの場\n所だから……あひぃぃんっ！　ゆるしてぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104130" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んおっほおおおっ！　おっ！　おぉおっ！　いきなりっ、はげしいっ！　オ\nチンポっ、ドチュドチュっ！　強すぎるぅっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104131" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひぃっ！　ひぃっ！　オチンポ、気持ちよすぎるっ！　放置された、トロト\nロオマンコっ、かき回されてっ、何も考えられなくなってしまうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104132" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「イぐっ、イってしまうっ！　オマンコ、上書きされるっ！　んあぁぁ～～～\n～っ、ゆるしてぇっ！　イグっ、イグイグイグッ……イッグっ！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104133" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひゅぉおおおおんっ！！　おぉおっ、おっ、おほぉっ……！　入ってきてる\nっ、オマンコのナカ……精液、いっぱい……っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104134" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁうっ……！　熱くて、ドロドロの孕ませ汁がぁ……んぉおぉっ…\n…余の、浮気オマンコにぃ……んひぃぃっ、注がれておるぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104135" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひぁっ、あっ、あぁっ……！　子宮口に、当たってるぅ……どぷっ、どぷっ\n……注ぎ込まれて……オマンコ、塗り替えられてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104136" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ああぁ～～っ……熱いぃっ……中出し、気持ちいいっ……！　ダメじゃ……\nまた、イく……イってしまうぅっ、浮気ザーメンで、また……んイグっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104137" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「っ、はぁっ、はぁっ、はぁっ……くぅぅぅ～～～っ、イかされて、しもうた\nぁ……あぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104138" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「放置されて、焦らされて……んくぅぅっ、トロトロにトロけたオマンコに、\nオチンポ挿入のおねだりまでさせられて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104139" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あやつのではないオチンポを、奥まで、ズッポリ……はくぅぅ\nぅっ、いっぱいハメハメされて、中出しまでされてしまった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104140" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余は、こやつに……このオチンポに、負けてしもうたのじゃ……すまぬ……\n心の弱い、余を許して欲しいのじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104201" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁうぅっ……！　あっ、あっ、余のナカにまだ入ったままの、オチンポが\n……くふぅぅっ、固くて、大っきくて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104202" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「まだ身体が熱くて……はぁ、はぁぁっ、火照ったままで……お願いじゃ……\nもっとオマンコ、して欲しいのじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104203" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……な、なんじゃと……？　そんなことまで、余に言わせる気か……それは\n、さすがに……くぅぅっ、でも、余は、お主のチンポには逆らえぬ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104204" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「くぬぬぬぅ……お主は一体、どこまで余を辱めれば気がすむのじゃ……この\n悪魔め、人でなしめ、ヘタレ変態サディストめ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104205" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あ、あ、オチンポ、抜けて……！？　ま、待ってくれ、言う、言うのじゃ！\n　今、放置などされたら、余はホントに狂ってしまう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104206" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よ、余は、ルナルバース１３世は、このオチンポに負けてあっさりと負けて\nしまった、弱小で、はしたない、淫乱ロリ妻なのじゃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104207" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「国民の、みなさま……あっ、あひっ……オチンポに弱くて、だらしない、女\n王で……んあぁっ、ごめんなさいぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104208" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あ、あっ、あっ、あなたぁ……っ！　他の男のオチンポでぇ……んあぁっ！\n　気持ちよくなる、不貞妻で、ごめんなさいぃっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104209" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅ、今からまた、このオチンポでぇ、んあぁっ、あなたより大っき\nくて、立派なモノで、奥までズポズポ、ハメてもらいますぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104210" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あなたの形だったオマンコを……おっ、おっ……このオチンポに作り変えて\nもらいますっ、淫乱ではしたない余を、どうか許してください……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104211" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひゅぉおおおおおんっ！　おひっ、おほぉっ！　激しいぃっ！　オチンポ、\nじゅぽじゅぽっ！　あぁぁあんっ！　気持ちいいぃぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104212" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「大っきなおちんぽっ、ズコズコ、ぬりゅぬりゅっ！　中出し精液っ、オマン\nコのカベに、擦り込んでるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104213" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぉっ、おっ、おっ！　しゅごいっ、ガチガチの先っぽ、奥っ、ズンズン、\nあっ、おっ、おっ、ま、待って、ソコは……あっ、あっ、あっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104214" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あほぉぉんっ！？　んおっ……おっ……はい、っちゃ、った……んぉぉっ！\n　ユルんだ子宮口からぁっ、ナカまで、オチンポ入っちゃったのぉっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104215" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぉおおんっ！　おほぉぉっ！　パンパンの亀頭が、子宮のナカずりゅずり\nゅうっ、ほぉっ！？　カリ首、引っかかって……おっ、おっ、おっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104216" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おひぃぃっ！　ひぃっ、んひぃぃっ！　もう、ダメぇっ！　余のオマンコぉ\n、隅から隅まで、負けちゃいましたっ！　オチンポに完全敗北しまちたっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104217" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぉおおんっ！　オチンポっ、子宮のナカで、また大っきくなってりゅぅっ\n！　んぉぉっ！　ジャーメンっ、しゃせーの準備してるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104218" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「オマンコもっ、またイぐっ、イかされちゃうっ！　オチンポにっ、てってー\nてきに負けて、しゅごいのクるっ、アクメしちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104219" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あひっ、あひっ、ごめんなさいっ、雑魚オマンコ女でっ、オチンポ大好きの\n淫乱オマンコ妻でっ、ごめんなしゃいぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104220" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んあぁぁっ～～～！！　イグっ、またイグっ、子宮のナカまで犯されて、イ\nっちゃうっ、オチンポに負けて、敗北アクメっ、キメりゅうぅぅっ～～！！」", "NORMAL" ]},
