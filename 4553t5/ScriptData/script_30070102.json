		{"command":[ "PLAYVOICE", "007_0104302" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おぐっ、しきゅうの、おぐっ、あたってるっ、ざーめんっ、びゅーびゅーっ\n、そそがれちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104303" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ひぃっ、ひぃぃっ……あちゅいっ！　せーえき、あちゅいのっ！　ヤケちゃ\nうっ！　オマンコ、ヤけちゃうっ！　しきゅー、ヤけちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104304" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あへぇっ！？　あっ、あへっ、あっ、あひゅっ！？　まだ、でてるっ、せー\nえき、また……んへぇぇっ！　もうしきゅう、はいらないぃぃっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104305" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はへっ、はへっ、ザーメン、たぷたぷっ、じゅせーしちゃう、よのらんしが\n、せーしにぷちゅぷちゅオカされて、あかちゃんデキちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104306" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁっ……はふぅぅぅっ……種付けされてしまったのじゃ\n……奥の奥まで、たっぷりと精液を注がれて……んふぅぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104307" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「これでもう……余の身体は、すっかりお主のものにされてしまったのじゃな\n……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_23" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104308" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「よもや、こんなヘタレ男に手ゴメにされてしまうとはな……くふふっ、だが\n悪くはない……これもまた、余が望んだことじゃからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104309" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「……そうじゃな、次にヤるときには、余の本当の姿を見せよう……これから\nは、お主に操を捧げるのじゃからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104310" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余の、身も、心も……もう、お主の……あなたのものじゃ……だから、どう\nか……末永く、よろしく頼む……」", "NORMAL" ]},
