		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あひっ、あちゅいっ！　せーえき、どぴゅどぴゅっ、ざーめん\nしゃわー、あちゅいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104403" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「せーえきいっぱいかかってる……あふぅっ、エッチなニオイで、マーキング\nされて……ニオイづけ、されちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104404" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「んああぁっ……あっ、あっ……！　また、どぷどぷって……ひぅぅっ、から\nだじゅう、せーえきまみれになって、ザーメンパックされてるのじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104405" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「あぁっ……あっ、あっ……あちゅあちゅの、せーえきで……んふぅぅっ、か\nらだじゅう、こーてぃんぐされて……ザーメンでおぼれちゃうぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104406" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふぅっ、ふぅぅっ……はぁぁっ、すごいニオイじゃ……頭からつま先まで、\nザーメンまみれにされて、んふぅぅっ、お主のニオイに包まれておる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000701_02_26" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104407" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ネバネバのザーメンが、べったりと肌にへばりついて……はぁぁっ……お主\nのニオイが、身体のナカまで染み込んでくるようじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "007_0104408" ]},
		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「でも、足りぬ……まだ……もっと、してほしいのじゃ……余のナカにも、外\nにも……いっぱい、お主の精液をかけてほしいのじゃ……」", "NORMAL" ]},
