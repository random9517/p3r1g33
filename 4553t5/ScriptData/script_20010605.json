{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「待て！　逃がしはしないぞ！　よくもみんなを――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140001" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「みんなを――ってあれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140002" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「どうしまし――ってあれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140001" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ゲンナイ君、僕の見間違いでなければ、みんな生きてるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140003" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「私も眠たさで幻覚を見たんじゃないかと思いましたけど……間違いじゃない\nですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140002" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「何かみんな楽しそうにしていません？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「してるよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140004" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "思わず顔を見合わせた二人は、皆の会話に耳を傾けた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふむふむ……なるほどね……まさか全て長官の仕組んだ事だったとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140005" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「さすがの僕も茶番の推理はできなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……あれ？　そうなると、さっき倒したのは一体？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140004" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「きっと雇われていたインストラクター達だろうね。彼等には悪い事をしたね\n。後で謝っておこうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140007" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここから出してくれぇえええええええ～っ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……ん？　何か声が聞こえた気がするんですけど……気のせいかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140005" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「気のせいじゃないかな。多分寝不足が原因だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140008" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「誰のせいでこうなったと思っているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140006" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「今度お寿司を奢るから、許してくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140009" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……仕方ないですね。お寿司と言われれば、許してあげます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140007" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃあ最後に締めるので、鳳雛さんも手伝って下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140008" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「分かったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140010" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「では……本日はこれまで！　事件はこれにて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021140009" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛＆ゲンナイ" ]},
		{"command":[ "SETTEXT", "「一件落着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021140011" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "-300" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "8", "CENTER", "300" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
