{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0084" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「隊長、せっかくビーチで二人っきりなんだし、今日はここでヤらないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「なにをって、テメーなぁ。そんなもん交尾に決まってんだろうが。へへっ、\n最近テメーとシてなかったからな、こっちも溜まってんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00009502_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「テメーだって……ほら、チンポはすっかり勃起してんじゃねーか。ンッ、そ\nうそう……アタイのマンコに擦りつけて……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204103" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00009502_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……なんだよ、チンポを擦りつけるだけか？　はぁ、おねだりしてほしいだ\nぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、誘ったのはアタイからだけど……って、チンポをしまおうとする\nな！　わぁったよ！　やりゃいいんだろ、やりゃぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……チッ、調子に乗りやがって。あー、あー。テメーのチンポを、アタイの\nマンコに……って、もっといやらしく？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「注文の多いやつだなぁ。……じゃあ、テメーの勃起チンポを、アタイのヌレ\nマンコにぶち込んでくださ……んぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「て、テメー！！　いきなりぶち込むやつがあるか！　んなっ、濡れまくりで\nすんなり入ったって、言うなそんな恥ずかしいこと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……って、ンッ、待てよそんなにっ、んぁっ！　いきなり激しくチンポ突き\n入れてっ、んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「待てっ、待てって！　あくっ、ンッ、はぁあっ！　なんだか身体がっ、やけ\nに感じやすく……んんっ、はぁあんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「イッ、イッた！？　アタイ、こんな簡単に……んっ、んっ、んはぁあっ！　\n隊長のチンポにっ、イッ、イカされて……あっ、あはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「おいっ！　イッたからちょっとは手加減しろっ、ンッ、ああっ！　なっ、自\n分はイッてないから、イクまでは腰振るって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204112" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああぁっ！　マジでっ、ああっ！　隊長のチンポがっ、ンッ\n、マンコをめちゃくちゃ、擦ってっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイのマンコっ、ぐちゃぐちゃに……んひっ、はぁっ、はぁ……ああっ、\nんぁっ、あっ、ひぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああっ、な、なんだよっ、悪ぃかよぉっ！　んぃっ、イッてるっ！　さっき\nからっ、アタイのマンコ勝手にっ、ンッ、イキまくってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「なんでこんなっ、感じやすく……んひぃっ！　ああっ、ああっ、んっ、んっ\n、んくぅ……っ！　はぁっ、はひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「く……くっそぉ……。こんな、情けない顔ばっかり、見せられるかよぉ……\nンッ、おおっ！　テメーのチンポ……さっさとイかせてやる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「イキまくりのっ、ミュータントマンコでっ！　んぁっ、チンポ……思いっき\nり締め付けてやるからなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅううっ！　ど、どうだっ、どうだぁっ！　アタイの本気締めっ、\nンッ、効くだろぉ……っ！　んっ、あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「へへ……っ、だんだん、腰の動きが早くなってきてるじゃねーか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「テメーのチンポも、アタイに射精したくてビクンビクンしてきたみてーだな\n……ンッ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「クソッ、油断するとこのチンポに簡単にイカされちまいそうだ……ンッ、気\n持ちよくて、腰まで勝手に動きやがる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、チンポが膨らんでっ、んくぅ……っ！　ぶってぇので、ナカ\nが、思いっきり擦られる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、く……っ、ふぅ……っ、あっ、ああ……っ！　チンポがっ、おお\nっ、思いっきり、奥に……ンッ、くぅうう……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああっ、テメーのチンポっ、ンッ、いいっ、いい……っ！　突\nかれるたびにっ、アアッ、全身っ、痺れるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁ……っ、はぁ……っ！　本当っ、こんなにっ、アタイが隊長のチンポで\nイカされまくるなんて……んぁあっ、あはぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はぁっ、はぁ……っ！　んっくぅ……っ！　んふっ、ふはぁっ！\n　はぁっ、はぁ……ンッ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「チンポっ、んっ、んっ、チンポっ、んひっ、いっ、イイ……ッ！　んっ、は\nぁんっ！　ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、テメーもっ、もう……イキそうに、なってるみてーだな……\n！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイの、マンコに……んぁっ、このまま、射精して……ンッ、精液……注\nいじまえっ、んっ、あっ、射精っ、しちまえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああっ、アタイばっかり、イかされまくるなんてっ、悔しくて耐えられねぇ\nからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「そらっ、アタイだって、腰振って……ンッ、くぅうっ！　マンコでっ、テメ\nーのチンポっ、しごいてっ、んっ、しごきまくって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、搾り取ってやるっ！　テメーのっ、ンッ、チンポからっ、\nせ、精液……んぁっ！　あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ドロドロしたっ、テメーの精液っ！　んっ、だ、出せっ、出しちまえ……！\n　はぁっ、はぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃチンポっ、早くっ、んくっ、ああっ、ヤベッ、ああっ、アタイ\nこれっ、た、耐えられな……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、イッ、イッくぅうううぅぅぅううぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああ……くぅ……。マンコに……流れ込んできてる……。テメーの\n……熱い、精液……ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。思いっきり……中に、出しやがって……。ふぅ……ふぅ\n……腹いっぱいに……テメーの精液が泳いでるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「へへ……。だが、これだけじゃ終わらねぇみてーだな……？　アタイの中で\n、まだまだチンポおっ勃ててよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイだって、イカされまくりのままじゃ終われねぇって。まだまだ時間は\nあるんだし、このビーチでヤりまくろうぜ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　ま、また思いっきり、チンポでアタイの子宮をっ、ズンッて突\nきやがったなぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「くそっ、気に入らねぇっ！　いつも隊長にっ、アタイの弱いところを簡単に\n見つけられるっ、ンッ、くぅううっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「い、イッてないぞっ！　イッたあとだから、マンコがもっと敏感になってる\nだろうって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はっ！　そんなわけねーよ！　むしろ、一回イッたから、ちょっと余裕が出\nたくらいだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「……なら激しくしてもいいな、って。ま、待て。激しくするのは……んひぃ\nっ！　あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、またっ、ああ……っ！　思いっきりっ、ンッ、チンポがっ、\nマンコ……ぉおっ、奥っ、んんぅうううっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「中出しされた精液かきだしながらっ！　ンッ、アタイのマンコっ、めちゃく\nちゃにっ、隊長のチンポでっ、おっ、犯されて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　ンッ、はぁっ、はぁ……っ！　んっくぅ……！　ん\nひぃっ、はっ、はっ、はっ、ひひぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「感じるっ、隊長のチンポっ、チンポ……ぉ……っ！　まだっ、アタイのマン\nコ、パンッパンにするくらいっ、ぶっといぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「こんなのでっ、ンッ、めちゃくちゃ突かれてっ！　ああっ、頭の中っ、おか\nしくなりそうなくらいっ、感じる……イッくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ああっ、感じるっ！　感じてるしっ、イッてる！　もう、イキまくってる…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「テメーのチンポ……テメーとのセックス……ッ！　ああっ、アタイ、本当に\nどうかしちまってる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「この『シャークガール』様がっ、チンポを前にっ、自分から腰振ってっ、イ\nキまくってるなんて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……だめっ、だっ、もう……っ！　イキまくって、本当に、お\nかしくなってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイの身体っ、イッてるのが当たり前になって、アアッ、気持ちいいのが\nっ、止まらなくっ、なってきた……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009502_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「ンッ、テメーのっ、精液っ！　また思いっきり注いでほしくて……ああっ、\nイキマンコッ、ヒクつかせながら、チンポに食いつくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、テメーも、もう限界みてーだな……っ！　ああっ、射精…\n…また、ドロドロしたのを、思いっきり……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_095_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マリッサ" ]},
		{"command":[ "SETTEXT", "「アタイに……テメーのを、たっぷり食らわせて、くれ……っ！　んっ、ああ\nっ、ああ……っ！　あっ、くぅううう……っ！」", "NORMAL" ]},
