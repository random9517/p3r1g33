		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「話はわかったが……実はシャムとフィルは、もう陽動作戦に出てもらってる\nんだ。いま、君たちのほうに向かっている敵艦は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「シャムちゃんたちの陽動にひっかからなかった、賢い人たちってことですか\n？　あちゃ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116180001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だが、なんとか戦力をかき集めて援軍は送る。それまでなんとかしのいでく\nれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「わかりました！　逃げ回って、なんとか時間を稼ぎます。だから長官……援\n軍、ホントによろしくお願いしますね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116180002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「本気と書いてマジでヤバくなってきたので！　期待して待ってますから～！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010116180003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「通信、終了しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ダイアンサスへの援軍か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さて、困ったぞ……自力で宇宙空間を移動できる連中は、みんな陽動作戦に\n参加してしまっているし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「陽動部隊も戦闘中です。すんなり撤退はさせてもらえないでしょうし、なん\nとか別の船を探すしか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116180002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こんなときに限ってミス・パープルも出張中……タイミングが悪いわね……\nとっても不運……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「Ｄｒ.サイレーン、なにか持ってないの？　原付免許で乗れる宇宙船とか、\nハエ取り紙付き転送装置とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そうよ！　地下に宇宙船が隠してある、とかぐらい言いなさいよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「二人の言うとおりだ！　なにか出せＤｒ.サイレーン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010116180002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．サイレーン" ]},
		{"command":[ "SETTEXT", "「おいおい、ボクは未来からきた人魚型ロボットじゃないぞ……あ、いや、待\nてよ？　宇宙船なら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．サイレーン" ]},
		{"command":[ "SETTEXT", "「あの『スケバンサンダー』って人、もう帰っちゃった？　まだ地球にいるん\nじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010116180002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「宇宙港に連絡してみます！　地球にいるのなら、まだあそこに船があるはず\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116180003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「頼むぞ……あいつの宇宙船なら、戦闘力もあるしそこそこの人数を運べるし\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「長官！　彼女の船はまだ係留中です！　しかも料金未払い！　早く本人に連\n絡してくれとのことです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116180004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうか！　よしよし！　係留料金ぐらい、こっちで立て替えてやる！　もち\nろん報酬から天引きでな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ7世" ]},
		{"command":[ "SETTEXT", "「相変わらず無駄にしっかりしているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010116180001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「というわけで、手分けしてあいつを探してきてくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116180008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「わかったわ、まっかせなさ～い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010116180002" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "8", "CENTER", "0" ]},
