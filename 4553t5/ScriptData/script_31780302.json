{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……今日は随分と優しく絡みついてくるのね。本能より理性の方が勝\nってるのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「でもいやらしい動きなのは相変わらずね。私の感じるところをしっかりと刺\n激してきて……あっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ、はあぁっ……！　このおっぱいに触手が這う感覚……たまらないわっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「触手のヌルヌルした感触と程よい弾力でいっぱい感じさせられて……乳首も\n少しずつ大きくなってきてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふっ、ぐっ……！　あっ、んっ、ひぅ……！　オマンコの周りもいっぱい刺\n激されてるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「そんなにいやらしく撫でられたら……乳首だけじゃなくて、クリトリスも大\nきくなっちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「くっ、あっ、んっ、あああぁんっ……！　オマンコの奥から、エッチな汁が\nどんどん溢れてくるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「こんな優しく全身愛撫されたら、オマンコが切なくなって……あっ、あっ！\n　腰が勝手に浮き上がってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「触手たちにおねだりするみたいに身体が動いて……ひっ、ぐっ、ああっ……\n！　乳首もクリトリスも痛いくらいに勃起してるわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「もうオマンコの準備が出来てるのに、まだ挿れてくれないのね……！　本当\nに焦らすのが得意なんだからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　オマンコとアナルの間にも触手が這ってくるぅ……！　そ\nこを弄られたら、どっちの穴も感じちゃうからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あああっ！　だ、ダメっ……！　敏感なところを何度も刺激されてるせいで\n、気持ちいいのがすぐそこまで来ちゃってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「この状態でオマンコに触手を挿れられたら、すぐにイッちゃう……！　触手\nたちより先に絶頂しちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふっ、あっ、ひああぁっ……！？　太い触手がオマンコに近づいてきてるわ\n……！　そのぶっといのを、挿れられちゃうのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「いいわよ……その太くてヌルヌルした触手を、思いっきりオマンコの奥まで\n突き入れて頂戴っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あはああああぁぁぁんっ！　ヌルヌルの極太触手がオマンコに入ってきてる\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ところどころにあるデコボコした感触が、ヒダに絡みついて……！　こんな\nの味わったら、感じすぎてイッちゃうううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イクッ！　軽いアクメがすぐそこまで来てるっ……！　ひ\nぐっ、んっ、あっ、んくううぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あはぁ……まだ触手たちが本気でピストンしてないのに、挿\nれられただけでイッちゃうなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ……！　そうよね……私だけ気持ちよくなってちゃダメよね\n……いいわよ……ちゃんと貴方たちも気持ちよくしてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「いっぱい動いて、私のエッチなオマンコをたくさん犯して頂戴っ……！　子\n宮の奥の奥まで、触手汁でいっぱいにしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、ふっ、あっ！　あああっ！　ぶっとい触手がオマンコを出た\nり、入ったりしてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「この触手たちの本能的な動き……気持ちよすぎるぅ！　拘束もどんどん強く\nなって、私を絶対に離さないって意思を強く感じるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「捕縛され、無理やり犯され、強制的に孕まされる……！　こうやって触手た\nちに弄ばされるなんて、最高としか言えないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あああっ！　もっと犯してっ！　私の触手専用オマンコ、もっとズポズポし\nてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んひいぃ！？　触手の先端がうねって、子宮口をこじ開けようとしてるぅ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「私の大事なところに触手をねじ込んで、触手汁を直接子宮に流し込もうとし\nてるのねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「そんなことされたら、確実に触手の赤ちゃん孕んじゃうっ！　触手たちの苗\n床になっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「うぐっ、あっ！　んふっ、はひぃ！？　触手たちの動きがさらに激しくっ…\n…！　ズポズポされる速度が上がってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「私が貴方たちの苗床になった姿を想像して、興奮してくれたのねっ！　凄く\n嬉しいわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「触手たちの母親になれるだなんて、これ以上の悦びはないわっ！　このまま\n子宮に触手をねじ込んで、触手汁を注ぎ込んでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁんっ！　触手が子宮口を通って、子宮の中に入り込んで来てるぅ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの部屋を内側から撫でられながらズポズポされたら……！　ま、ま\nたイクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、うぐぅ！？　あ、貴方たちも出したいのねっ！　触手\n汁を子宮にびゅーびゅーしたいのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「いいわよっ！　このまま出してっ！　子宮の中、貴方たちのエッチなミルク\nでいっぱいにしてぇぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んはあああぁぁぁっ！　触手汁が子宮にびゅるびゅる出てるの感じるぅぅぅ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「こんなに熱いのを注ぎ込まれたら、イッちゃうっ！　気持ちいいのが溢れて\n、潮吹きしながら排卵しちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イッ、イクッ！　イッてるのに、またイッちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「身体が勝手に強張って、子宮口だけじゃなくてオマンコ全体が締まって……\n！　んひぃぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「本当にイクの止まらないのぉ！　こんなの、何回だってイッちゃうっ！　触\n手汁が出され続ける限り、イキ続けちゃうううぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「はぁ……ぐっ、んんっ……！　お腹の中が触手汁でいっぱいになってるわ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「これだけ出されてたら、本当に苗床になっちゃいそうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　オマンコの中で触手たちがまたうごめいて……んんっ！　\nいやらしくうねりながら、子宮口を刺激してきてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……やっぱりこの程度じゃ終わらないのね……いいわ。このまま続け\nて相手をしてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ほらっ……さっきよりも激しく動いて、私を思いっきりイカせて頂戴っ……\n！　出したばっかりの触手汁を、オマンコに塗り込んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　んひっ、あああっ！　触手がオマンコのヒダに絡みついて……！　\nヌルヌルのエッチな汁が、身体の中で広がってるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「出し挿れされるたびに触手汁が子宮の奥にまで流れ込んできてるっ！　もう\nお腹いっぱいなのに、まだ奥まで注ごうとするなんてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ……！　くっ、んふぅ……！　凄く苦しいけど、貴方たちの濃厚\nミルクで子宮が満たされるって思うと、幸せな気持ちになるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「だからこのままもっと犯してっ……！　私の身体、貴方たちのいやらしい汁\nでメチャクチャにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んふっ、くううぅ！　オマンコだけじゃなくて、おっぱい\nも強く搾り上げられてるわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、んんっ！　ち、乳首をホジホジしながらオマンコズポズポす\nるのダメぇ！　それ、さっきより感じちゃうわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「また腰が勝手に浮いて、いやらしくヘコヘコしちゃうぅ！　オマンコも勝手\nに締まって、触手を強く締め付けて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あはあぁっ！？　強く締め付けてるのに、そんな激しく動かされたら、また\n気持ちいいのが溢れてきちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「私のエッチな蜜がオマンコに広がって、触手汁と絡み合っていやらしく音を\n立てちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふっ、ひぐっ！？　あっ、あっ！　んっ、あひぃんっ！？　また触手が子宮\nの中でグニグニ暴れてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ダメっ！　ダメぇ！　こんなのもうイッちゃうっ！　またお潮吹きながら、\n果たしたなくイッちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「おっ、おおおぉ！？　オマンコに入ってるぶっとい触手がビクビク震えてっ\n……！？　貴方もイキそうなのねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！　そのまま出してっ！　私のこと、触手汁でドロドロにし\nてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「膣内でも膣外でも、好きなところにびゅーびゅーしてっ！　貴方が出したい\nところに、触手汁をぶちまけてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ！　イクッ！　イクぅ！　触手に嬲られながら、イッちゃうう\nうぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んんんんんっ～～～～～！　で、出てるぅ！　また触手汁がオマンコの奥に\nびゅるびゅる出てるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ！　触手汁が流し込まれるタイミングに合わせて、オマンコ\nからお潮出ちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　あっ、やああぁっ！　そ、そんなっ！　出してる最中にオマンコ\nズポズポするのは反則よっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「子宮に触手汁を流し込まれながら動かれたら、イクの止まらないわっ！　何\n回だってお潮吹いちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あああっ！　またイクぅ！　触手たちに無理やりイカされ続けちゃうううぅ\nぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、んんっ……！　あっ、あふっ……やっと止まってくれたのね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「それにしても、出しながら突くだなんていやらしい子ね……やっぱり本能に\nは逆らえないのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……こうやって激しく犯されるのも嫌いじゃないわよ……むしろ貴方\nたちの本質を強く感じられて嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「でもこれだけ出されたら、本当に貴方たちの苗床になりそうね……お腹が大\nきくなったら、歌手が続けられなくなっちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「まあ、そうなったらそうなったときに考えるとしましょうか。それより今は\n、貴方たちをもっと感じていたいもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んひぃ！？　しょ、触手が一気にオマンコから抜けてっ……！？　あはぁぁ\nぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「熱い触手汁が全身にかかってるぅ！？　ドロドロの臭いミルクが肌に染み込\nんで……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あっ！　だ、ダメっ！　これ、臭いと感触でイッちゃうっ！　お潮吹き出る\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃ！？　もっとかけてぇ！　子宮の中だけじゃなくて、全身を触手\n汁まみれにしてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「貴方たちのいやらしい汁で私のことマーキングしてっ！　私は貴方たち触手\nのモノだって、しっかりと身体に覚え込ませて頂戴っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……すごいわ……全身触手汁まみれで、ベトベトのドロドロ\nよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00017803_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「こんなにも臭いが肌に染み込んだら、洗っても取れそうにないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「でも別にいいわ……こうやった触手汁に塗れていると、貴方たちと心も身体\nも一つになっているように感じられるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「ふふっ……このまま触手と一体化するのも悪くないかもしれないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "あゆむ" ]},
		{"command":[ "SETTEXT", "「触手と一緒に歌う歌手ってフレーズで売り出すのもいいわね。一般受けはし\nないかもしれないけど、一部では大うけしそうだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_178_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}