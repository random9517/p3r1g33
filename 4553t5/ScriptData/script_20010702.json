{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_006" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「くっ……！　私が負けるだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090004" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「一人だったらヤバかったけどな……おっさんが居てよかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090025" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いい加減そのおっさんってのやめろ。俺にはカツマって名前があるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「わかった、わかった。次からはカツマって呼ぶよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「ところで、この不審者はどうするんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090027" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いくら学園の生徒とはいえ、夜に忍び込んでる時点で、お前も十分不審者だ\nからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この際、処分は置いといて……とりあえず、お前の名前と目的を教えてもら\nおうか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「……南野サキよ。ここに来た目的はさっきも言ったけど、私も願いを叶える\n力を探してるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090005" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は力を手に入れて、なにをする気なんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「……ちょっとした復讐よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090006" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前も復讐が目的なのか。詳しい理由を聞いてもいいか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「……私の家は貧しかったけど、それなりに平穏な暮らしをしていたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090007" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「でもある時、お父さんが医者から大腸がんを宣告されて、すぐに入院して治\n療しないと命に関わると言われて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090008" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「すぐに入院しようと思っても、家にお金なんてない。でもあの医者は、金が\n払えないなら検査も手術も出来ないと言って来たわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「なんとかお金を用意して、詳しい検査をお願いしたのだけど……お父さんの\n容態は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090010" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほどな……もう少し早く検査が出来ていれば、親父さんは亡くならずに\nすんだ。だから、その医者に復讐したいと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「違うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090011" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ！？　違うのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「再検査で分かったのだけど、お父さんは大腸がんじゃなくて、小さな大腸ポ\nリープが出来ただけだったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090012" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「つまり、あの医者はただのヤブで、私たちの平穏を乱したのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090013" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「誤診ということでお金は病院が返してくれたし、示談金も貰ったけど、私の\n怒りはおさまらなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090014" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「あのヤブ医者をボコボコにしてやろうと思ったけど、既にその医者は居なく\nなってたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「そんな時、この学園に願いを叶える『秘密の力』があるという噂を聞いて、\n居ても立ってもいられなくなって、こうして忍び込んできたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「つまりお前は、ヤブ医者の居場所を知るために、力を求めてると……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「そういうことよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090017" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか……お前の復讐も随分軽いというか、なんというか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誤診はないとは言い切れないし、返金されて示談金も貰ってるなら、別にい\nいんじゃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそも、医療制度を使えば、金がなくても検査や手術ができるだろ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「あたしもこいつも、理由があって力を求めてるんだ。だから頼む……！　こ\nのことは内緒にしてくれないか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090028" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「理由って言われても、そんな深刻な理由じゃないと思うんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……まあいいや。とりあえず、学園長には黙っておいてやるよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「マジか！　話が分かるじゃねぇか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090029" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ただし、俺もその力を探す手伝いをさせてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーっと、サキ……だっけ？　お前も一緒に探してくれると助かるんだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「……私も協力していいのなら、是非とも手伝わせて欲しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090018" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「よっしゃ！　それじゃ、改めて秘密の力を探そうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090030" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「……って、意気込んではみたけど、何処にあるのかわかんねぇんだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090031" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「あなたって、見た目相応にバカなのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090019" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「あぁん！？　じゃあお前は何処にあるのか知ってんのかよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090032" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「知らないから、こうして誰も居ない時間帯を狙って探しに来たのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090020" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「喧嘩したばっかりなのに、また喧嘩するなよ……とりあえず、しらみつぶし\nに探すしか――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「とりあえず、音がした方へ行ってみようぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090033" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0128" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「やっばっ……！　めっちゃいい音させちゃったし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090001" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「まー、でも誰も居なさそうだから、大丈夫かな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090002" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！　そこに居るのは誰だ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うわっ！　誰か居たし！　しかも秒で見つかるとかウケるんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090003" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「……ん？　お前、環じゃねぇか！　なんでこんなとこに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090034" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サキ" ]},
		{"command":[ "SETTEXT", "「あの子……最近この近辺で噂になってる、辻斬りギャルの岩下環ね。知り合\nいなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_139_010021090021" ]},
	{"command":[ "SETCHARA", "0", "char_00013901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「何度か喧嘩したことあってな。今じゃちょっとした顔見知りみたいなもんだ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090035" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「あー！　泉じゃん！　ってか、なんでこんな時間にこんなトコ居んの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090004" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それはこっちのセリフだ。一体なんの用だ？　まさかお前も、秘密の力を探\nしてるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「うちの目的知ってるとか、エスパーみたいじゃん！　あっ、もしかして、あ\nんたたちが力を守ってる感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "環" ]},
		{"command":[ "SETTEXT", "「まー、なんでもいいけどね！　力はうちのモノだし！　邪魔するなら、ちょ\nっと眠っててもらおうかな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_140_010021090006" ]},
	{"command":[ "SETCHARA", "0", "char_00014001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "泉" ]},
		{"command":[ "SETTEXT", "「へぇ……やろうってのか。いいぜ！　かかって来な！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_138_010021090036" ]},
	{"command":[ "SETCHARA", "0", "char_00013801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}