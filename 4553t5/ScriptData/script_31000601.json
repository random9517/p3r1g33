{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……今日のペニスもいいカタさをしているな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「胸に挟むだけでこんなに暴れて……んっ、こんなの、すぐに舐めたくなって\nしまうじゃないか……んっ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅちゅ……れろっ、んちゅ……ん？　人が気持ちいいことをしてや\nっているというのに、なんだその顔は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなことをされる理由がないだと？　ふふっ。別に理由なんてなんでもい\nいだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603104" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだな……普段頑張っているおまえへのご褒美とでも思っておけ。それな\nら、気も楽になるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まあ、ご褒美というのはあくまで建前で、ペニスが欲しくなっただけだがな\n……！　んちゅ……ちゅぱっ、れろっ……ちゅ、ずちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずちゅ……ちゅ、ぐちゅ……ふふっ。そんなに腰を引かずともいいだろう？\n　それとも、気持ちよくないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「気持ちいいけど、こんなの間違っているか……あははっ！　なにが間違って\nいると言うんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえも気持ちいいし、私も気持ちいい。なにも間違っていないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいから、素直に快楽に身を委ねておけ……ぐちゅ、れろっ、ぷちゅ……！\n　逃げたりしなければ、悪いようにはしない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603110" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずちゅ、にちゅ……んっ、くふっ……ぺろっ、ちゅちゅ……んっ、んんっ…\n…！　この裏側を舐められるの、好きだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……それにこの段になっているカリの部分……ここも弱いんだったな\n……んちゅ……ぐちゅ……ぺろっ、れろっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスが震えているぞ……あははっ……！　おまえの弱点は全部知っている\nからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「先端だけじゃなくて……こうして、胸で圧迫してズリズリしても……んっ、\nぐちゅ……！　ほら。簡単にペニスが反応してくるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603114" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぐりゅ……ぢゅ、じゅぷっ……！　どんどんだらしない顔になっているな…\n…！　実に私好みの顔だ……！　もっと見せてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603115" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、ちゅぴっ……れろっ、ぐちゅるっ……にちゅ、ずぽっ、ぐぷぷっ\n……！　はああぁ……ペニスからエッチな汁が溢れてくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「先走りなのに濃厚で……んっ、じゅ、ぐずりゅっ……！　すごくトロトロだ\n……最高の甘味だな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いっぱい舌でペロペロして、おっぱいでシゴいてやるから……もっと我慢汁\nを搾り出せ……！　んっ、ぷぷっ、ぢゅるるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷ、ちゅぴっ……！　ウラ筋をおっぱいで刺激すると、滝のよう\nに汁が出て来るな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ひょっとして、この筋の部分も好きなのか……？　んっ……れろぉ……！　\nぴちゃ、ぷちゃ……ぐちゅ、くちゅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おい……！　気持ちいいからって、腰を引こうとするんじゃない……！　ペ\nニスを引きちぎられたいのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……そうそう。人間、素直が一番だ……あむっ……じゅぷっ、ぢゅぽ\nっ……ぐちゅ、にりゅるっ……ぐぽっ、ぐぽぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はああぁ……ペニスのニオイもどんどん濃くなっているぞ……！　私の唾液\nのニオイと混ざって、とてもいやらしいな……ちゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら……ペニスの先端から、濃いニオイがするのを感じるだろう……？　も\nっとも、おまえからすれば、クサイだけかもしれんが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603124" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私くらいのオンナになると、このニオイがヤミツキになるんだ……ぐぐっ、\nじゅるっ……ずぷっ、ずぐっ、じゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「常にこの味とニオイを味わっていたい……ペニスをいっぱいイジメて、汁を\n噴き出させ続けたい……そんなふうに思ってしまうんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぺろっ、ちゅちゅ……にちゅ、ぐちゅ……！　だから、もっと出せ……！　\nエッチな汁が尽きるまで出しまくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえの汁……全部私が味わってやるから……！　ぐちゅ……ちゅ、じゅる\nっ……！　ちゅぱっ、ぢゅぷっ……にりゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603128" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅ……！　おっと……ペニスがビクビクしまくっているな……そろ\nそろ我慢汁以外のモノが出そうだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「なら……こうやって、谷間をさらに寄せて、ズリズリと激しくシゴけば……\nんんっ！　案の定、激しく脈打ってきたな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「舐めながら擦れば擦るほど……ペニスの振動が大きくなって……！　んっ、\nちゅぱっ、にちゅるっ……ずっ、ずずずっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「出したくてたまらないといった様子だな……！　ふふっ……！　そんなに精\n子を出したいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゅ、ずっ、ちゅぱっ……！　出したいなら、出したいと言え……！　先生\n、ボクの精子出させてくださいと情けなく言ってみろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはははははっ！　まさか本当に言うとはな！　いいだろう……！　その情\nけなさに免じて、精子を出させてやるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずぽっ、じゅぽっ……！　ぐちゅ、ずちゅ……！　ほらっ、イケッ！　情け\nない声を出しながら、イキまくれっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　あっ、くはああぁ……！　胸にいっぱい出て……くううぅ\n！　やはりこの熱さはいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「毎日味わっていたくなるほどだ……！　んんっ……！　はああぁ……心が満\nたされていくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603137" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと出るように、射精中もシコシコしてやる……！　これで、もっと吐き\n出せるだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふううぅ……！　シゴくたびに、びゅるびゅるザーメンが溢れ出て……！\n　やはり射精中に擦ると勢いが増すな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、あっ……！　最後までしっかり出すんだぞ……！　少しでも\n残したら……どうなるかわかるな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……情けなく射精させられた気分はどうだ？　嬉しかったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなのはご褒美じゃない……？　ほう……妙なことを言う奴だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603202" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この私がパイズリをして、フェラチオまでしてやったというのに……ひょっ\nとして、満足できなかったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いや、みなまで言わなくていい。おまえはもっとおっぱいでシコシコして、\nペニスを舐めて欲しい……そう言いたいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603204" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。なにが違うというんだ？　私がしたいことは、おまえのして欲しい\nこと……それがこの世の道理というモノだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぐちゅ……れろっ、じゅぽっ、ちゅちゅ……！　んっ、んっ……！　あっ、\nんふっ……！　じゅぷっ、じゅるっ……ちゅ、ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603206" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぢゅ、ぢゅぢゅ……！　あははっ！　やはりこうやって、ペニスをイジメて\n欲しかったみたいだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603207" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「違うことなどない。現にこうしてさっきよりも強く反応して……！　んっ、\nあっ……！　ビクビクと暴れ回っているじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「先端を舌先でグリグリしながらおっぱいを擦るだけで……んちゅ、ちゅ……\n！　エッチな汁がびゅるびゅる出て来るぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おまえは私に犯されたい……イジメられたい……酷いことをされたい……！\n　心の奥底では、そう思っているんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そもそも、本当にイヤなら最初から私の誘いに乗らないし、逃げるのが普通\nだ……だが、おまえはそうしなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ペニスを気持ちよくして欲しいから……んっ、ちゅちゅ……ぺろっ、れりゅ\n……！　私の言葉につられてここに来たんだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……無理やり連れてこられた？　逃げようとしたらもっと酷い目に合\nう？　あははっ！　なんのことやら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くだらないことを言ってないで、もっとペニスに集中しろ……！　じゃない\nと、気持ちいいのが痛いのに変わっていくぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゅちゅ、ぢゅ……！　じゅるるっ、ちゅぱっ、ちゅぷっ……！　そうだ、\nそれでいい……！　もっとペニスで快感を味わえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603215" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「この大きなおっぱいの感触と……んぅ、ちゅるっ……舌のねっとりとした快\n感で……気持ちよくなるといい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んぶっ、じゅるるっ！　ぐちゅ、ちゅ……れろっ、ちゅぴっ、ちゅぷぷっ！\n　ペニスも射精したくて、ビクビク震えまくっているぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「精子を出したいなら……んっ、んっ……ちゅ、じゅるっ……！　またさっき\n見たいに情けなく私に媚びろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ちゅ、れろっれりゅ……！　何処に出したいのかはっきり言っ\nて……！　情けなく私に懇願しろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「限界なんだろう……！　ほら、言え……！　先生、射精させてください……\n！　精子出させてくださいと言いながらイケッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あははっ！　いい声を出しながら射精するじゃないかっ！　ああっ……いい\nぞ……！　おまえの情けない声が、アソコに響く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、んはああぁ……！　そんな声を出されたら、私もイッてしま\nう……あっ、あっあっあっ！　あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　おまえを屈服させるこの感じ……！　これこそ、私にとって\n最高の快楽だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと私のモノになれ……！　心も、身体も……なにもかも、私に委ねてい\nけ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あの祭りのように、解放的になって……！　情けなく全てを曝け出せっ……\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ああぁ……２回目なのに、かなり量が出たな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにニオイも……んっ、味もいい……良質な精子がたくさん溜まっていた\nみたいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなにも射精させてもらえるなんて、最高のご褒美だとは思わないか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603308" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんな無理やりなのは好きじゃない……？　ほう……あんなにも無様な声と\n顔をしていたのに、まだ反抗するのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いいだろう……！　ならばおまえが私のモノになるまで、もっともっと犯し\nてやるとしよう……！」", "NORMAL" ]},
