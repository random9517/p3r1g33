		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ……！　顔にかけたいと言い出すとは……くっ、あふっ……\n！　んんんっ……熱いのがべったり付いて……はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603401" ]},
