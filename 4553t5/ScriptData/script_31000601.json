		{"command":[ "SETIMAGE", "0", "still_00010006_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅるっ……ちゅ、くちゅ……！　あんんっ……！　この甘美な味わ\nい……！　やはり精子は搾りたてが一番だな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んくっ……んっ、ごくっ……！　この味わいだけで、子宮が満たされていく\nっ……！　あっ、あっ……！　イクッ……！　イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あはああああぁん……！　すごいのがアソコからゾクゾク溢れて……あっ、\nんふっ……！　射精に合わせて、またイクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「もっと出せ……！　顔中が精子塗れになるくらい……濃くてクサイのを出し\nまくれっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……はふっ……胸も顔も、おまえの精子塗れだ……どうだ？　\n自分の汁でオンナを汚した感想は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603406" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「支配欲みたいなのが満たされて、背徳的でとっても心地いいか……ふふっ。\nおまえもよくわかっているじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだ……人を支配する……自分のモノにするというのは、とても心地いい\nことなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603408" ]},
		{"command":[ "SETIMAGE", "0", "still_00010006_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だからこそ、私はおまえが欲しい……！　支配欲と背徳感を満たすためだけ\nに、おまえの全てを手に入れたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0603409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……そのために、もっと気持ちよくしてやる……！　ドロドロのグチ\nャグチャにして、私から離れられないようにしてやろう……！」", "NORMAL" ]},
