{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あーのー……隊長……。今夜は私、多忙なのですがー……？　デカパイ艦長\nが派手にやらかしてくださいまして、その後処理を……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104101" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ぷっ、ふふふっ……。なんですか？　その真剣な顔……。そのわりにー……\nほぼ素っ裸で、キメキメな表情されてもー……ぷ、ふふふ、ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……夜のお勤めをご所望……ということでしょうか？　そーですねー……。\nもう、雑務を増やされるのはお断りですがー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長が。私の日々の苦労をねぎらってー……その身体でご奉仕してくださる\nというのならー……この身を委ねても構いませんが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……そうです。私が攻めて、攻めまくって、隊長のボディでストレスをスッ\nキリ解消させてもらえたりするならー……って、んっ！？　んむ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「こんな素早い動きをしたの初めてですよね！？　隊長……！　いつものぼへ\nらーっとした姿は昼だけの偽りの姿だったのですか！？　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019101_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「い、いやですよ！　私が攻めるならまだしも……！　こ、こんな、小さな子\nどもが父親にだっこされるみたいな格好……恥ずかしいです、やっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んっ……んん……！　本当にっ……！　わ、私主導にはさせてくれないので\nすね……。あっ！　ちょっ……ちょっと！　胸を揉まないでくださ、あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んふぅうう……ッ、あ……あぁ、あっ……あ、も、もう……！　なんという\nワガママですか……。我儘な人は艦長だけで充分なのですが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ん……？　『足の間をよく見てみろ』……？　私の脚ですか？　……下には\n隊長の脚しか……。……あ！！　さ、三本目の脚……ペ、ペニス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「や、やる気もやる気なんですね……？　私を呼んだ瞬間から……こうやって\n、い、いやらしいことをするつもりだったんですね……わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「す、好きにしてくださ……い……。でも、スッキリさせてくれないと……イ\nヤですからね？　私もうんと気持ち良くしてくださいねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「それならー……。はぁ……。まずは私の胸に指を這わせて……ん、乳揉みで\nすか？　って、あっ！？　ど、同時に男根を股間に添わせて……やっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「乳房をいじくりながら、か、花弁で素股……！？　ど、どこでそんな高等テ\nクニックを！？　……ぁ……！　い、いや……！　反応し、ちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ズルいですよぉ……隊長ぉおー……！　二点攻めなんて、ぁっ……！　意識\nが分散して……あっ、乳首をこねまわされたり、胸を揉まれたり……ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「乳輪、優しくなぞられたりしてる間にも……。んんっ、にゅる、にゅる、に\nゅるって……カウパーまみれのペニスでアソコこすられて……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「どっちも無防備なまま、時間差でなぶられて……あっ♪　はぁ、くぅっ、く\nぅう……！　無理やり、整わされる……エッチＯＫにされてくう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ……んっ……んんっ……んんー……！　私の周りにいる人は、なんでこ\nうも自由奔放でー……やりたい放題なんでしょうかぁあ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「もう、どうなっても知りません、から……あっ！　私を攻められるだけの女\nだと、思わない方がいいですよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「こっちからも腰を動かして攻めちゃいますからー……！　あっ！　あ、ほら\n……ほら、どうですか……！　おっぱい揺らして、腰、振って……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長なんかいくらでも誘惑して、煽って、たまらなくさせてやるんですから\nー……！　あッ……えぇ？　『協力ありがとう』？　んもぉお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「協力、なんかしてません、一方的にされるのが気に食わないだけ、で……！\n　『挿入の準備手伝ってくれてる』？　ばっ……そ、挿入！？　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「だめですよ……あっ！　挿入なん、て……あっあっ！　こ、これ前戯なんで\nすか！？　って……ああ……！　押しつけないでくださ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「愛液と先走りで、アソコ濡れてきてますから間違って入っちゃいます……！\n　あっ！　胸、胸揉むから、感度あがって……濡れて……って、あ、あ、あ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「だ、め……！！！　あひぃいっ！　あああああっ！　あああーっ！　入っち\nゃったー……！　ペニス、ペニスぬるんって入れられちゃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ん、んんんんんー！！　こんなのっ、どう抗えっていうんですかー！！　あ\nっ……！　『濡れすぎてたから奥まで入った』？　う、うるさぁい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長の手つきと腰つきがやらしすぎたから、し、自然に潤っちゃっただけで\nすうー……！　あっ！　あっ、やだ、ま、待ってください、動かさないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ちょっ……あっ！？　あぁ！？　いきなりっ！　いきなりそんな全力全開で\n動かさないでぇえ……！　あーっ、だめっ、だめ、すごい動いてるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私の中、中っ……膣内！　まったくペニスを拒めてないぃ……！　受け入れ\n、ちゃってる……！　歓迎しちゃってる、絡みついてる……ぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　パンパンって！　パンパンってお尻に腰っ、打ち付けられ\nて……！　すぐ気持ち良くなってきちゃってる、恥ずかしい、やぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「わけわかんない部屋に連れ込まれて、ご、五秒で愛撫されて……即ハメされ\nちゃってる……！　は、はじめて、はじめて、なの、に快感強すぎぃい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ずどぉんん！　ずどぉおおんって……あっ！　ちんぽ、ちんぽが私の中……\nで、おまんこの中で花火打ち上げてるみたいに……あっ！　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「太い快感の衝撃ぃ……がっ！　ドッチュンドッチュン突き上がってきてぇえ\nー……ひいぃいっ！　んひぃっ！　これ、これ、これ、ヤバいぃい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ストレス解消どころか……あひぃいいっ！　今まで感じた気持ち良さっ、人\n生全部分乗算してもかなわいくら、い……すごい、すごい、すごいぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「知能指数下がって……あーっ！　おまんこでおちんぽすることしか考えられ\nないですっ……おちんぽ、あっ、おちんぽでおまんこ！　おまんこぉお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「おちんぽがっ、隊長のおちんぽが私のおまんこをずっこずっこずっこずっこ\nしてます、あっ……あああっ、悔しいぃ、反撃なんかできませんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「されるがまま……！　あああっ……私、私ぃ……！　攻め好きのつもりでい\nた、のにぃ……おちんぽ一本でおまんこ好き勝手されちゃって……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　気持ちいい！　気持ちいい、気持ち……いい！　もうわけ\nわかんないっ、ですっ！　この突き上げられるの好きっ、好きぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「おまんこかきまぜてくださ、いぃ……隊長っ！　隊長のちんぽ強すぎて……\nぇ、おまんこイッちゃいます、イっちゃいます……んーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んっ……えっ？　あっ？　あっあっあっ？　何っ……？　なん、ですか？　\nなんか急に、おまんこの奥あっつくなって……あっ？　あっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「もし……かして今、私射精されてます、か？　……あっ！　どぴゅ、どぴゅ\nって……一番奥で……奥で何か……。……あ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「熱い……熱いのがほとばしっててー……身体がカーッて熱くなって……あっ\n……。中出し……中出しされちゃってますか、赤ちゃん作られて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ッんんんんっ……！　これ、が……これが膣内射精……。気持ち、いい……\n！　ぁ……すぐ、おちんぽ抜かないとなのに、避妊しないとなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「抜いて欲しくない……です……。隊長……！　あとで、後で私がなんとかし\nますからぁ……ご迷惑おかけしませんから、お願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「このままっ……このまま、中出しされたばっかりのおまんこでエッチ、エッ\nチ続けてください……あっ！　私も協力……協力します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「さっき、前戯……愛撫の時にしてたみたいに……あっ♪　おっぱいっ……な\nまめかしく揺すって、くねらせて……腰も使います、だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「もう一度、抜く前に……抜かずにぃ！　ずっぽずっぽしてくださいっ、あっ\n！　いいか悪いかは聞いてません……勝手に私しちゃいます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長の凶悪な、極太おちんぽ咥えこんで……勝手に一人で気持ち良くなりま\nすっ……！　隊長の指と手で、胸も極限まで感じまくって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長で豪華なオナニー、させていただきます……！　っあああああっ！　あ\nあああ……！　ハンパないです、隊長のっ、もう大きさ取り戻して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私に攻めて欲しいって言ってるみたいぃい……あんっ！　あんっ、んっ、ん\nんんんっ……！　すごい……すごい、すご、い……気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「腰を振るのも大変なくらい……！　ずっぷり奥まで突き刺さってる、それを\n……それをおまんこでぐっちゅぐちゅするのがイイ……いいのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「隊長も……隊長も気持ちいい、ですかー……？　私のっ、半分……あっ♪　\n１０分の１……１００分の１でも、相当……クるでしょう……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「無我夢中になってー……♪　あっ♪　あっ♪　コレに全集中しちゃうくらい\nぃ……あっ！　気持ち良くて……気持ち良くて……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私の胸、ちゃんと捕まえていてくださ……いっ！　も、腰振りすぎて、腰振\nりた過ぎて、上半身っ……制御できないのでっ……すみませ……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　あっ、あっ♪　あぁああ……♪　たい、ちょ……隊長、隊\n長ぉおお……♪　なんか、なんかぁ……中でおちんぽ急成長してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ビクビクしてるんですけどー……これっ♪　あっ、私の……ロシアおまんこ\nがよすぎてまた……また中出し狙ってるんですか、射精ですかぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「のっ……望むところで、す……。はぁああ♪　受けてたちます、から……！\n　やわらか濡れ濡れおまんこ、で、限界ギリギリまで溜めて、溜めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「もうダメぇってところで出し、てくださ……いね♪　はぁっ♪　はぁ、あぁ\n、はぁっ……はぁあっ♪　あははは……太くなりすぎー……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「こんなん、女喜ばせるための最終兵器じゃないですかぁー……♪　ああああ\nっ！　ストレスもっ、意識もフッ飛ぶくらい……気持ち……イイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「っああああああ……♪　中出し、中出し……中出しぃいい……♪　キてる、\nキて……ます、はいっ、はい……♪　絞り上げ、ます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「んッ……んんんんー……！！　す、ごい……大量……！　はい、一滴残らず\n中に……ぃい♪　避妊？　さあ、そんなの知らないです、聞いたことない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「とにかく♪　今は隊長のおちんぽが射精してっ♪　その汁で私がっ……私が\nキマっちゃうくらいイッてることが全て、すべてですから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あ、ああああ……！　一回目より、どくっ、どくっ、どびゅ、どびゅって出\nされているのがくっきり……♪　これが中出し……幸せ、ですー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あは……♪　私が座ってる格好だからでしょうか、おちんぽ真上に向けたま\nま出してもらっているからー……打ち上がり感とてつもないですよー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　出ました……か？　出しきれましたか……？　はああああ\nあ……♪　満ち満ちて……これが満足というものなのですねー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「これが、隊長とのセックス……♪　身体も心もスッキリしすぎて、今まで詰\nめ込んできた知識のほとんどが消滅したような爽快な気分ですー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ふふ、むふふ、ふふふー……♪　ぴーすしたいくらい気分がいいです……。\n隊長……。すごくいいことを教えてくださってありがとうございました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「私っ……どうやら、艦の運営以上にこちらの才能もありそうですのでー……\n。練習にこれからもお付き合いくださいねー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「え？　本番は誰とするんだって？　それも隊長一択でしょう。隊長で練習を\n積んで、隊長で本番して……いつの間にか、とりこんでいきますねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ああああああっ……んあああああっ、んふーーーー！　ふぅううううーーー\nーっ、んふぅうーーーーー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あっあっ♪　今度は外に……外に出すんですか♪　やだぁ……\n♪　おまんこきっちり締めておかないと、さっきの精子出ちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あふっ……ふぅっ、ふぅううう♪　これって……いわゆる外出し……ですよ\nね♪　男が女を完全支配、征服した証にしちゃう白濁マーキング♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「これでぇー……あっ♪　私は隊長のものだってぇ、はっきり示されちゃった\n形になるんでしょうかー……♪　だってエロさがすごいですもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ついさっきまでズコズコ犯してた女体に、仕上げの白濁まき散らし……。や\nりたい放題してくれちゃって、うらやましいくらいです……。はぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「お尻も、脚も、アソコも身体も……隊長ので染められてしまいました……。\nにちゃにちゃで、トロトロで変な感触ですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「不思議と誇らしいといいますか、……今までにない満足感といいますか……\n。ただ……あの、ですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「次にする時には二回連続で膣内射精……キメてほしいという気持ちもありま\nす。やはり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「選ぶのは隊長さんですけどねー……。あ、そうだ♪　次こそは、私に攻めさ\nせてくださいよ。そうしたら……むふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00019101_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「最後に抜くか抜かないか、どこで出すかも私が決めちゃいます。私の気分で\n。そういうのも、いいと思いませんかー……？」", "NORMAL" ]},
