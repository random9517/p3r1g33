{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……う……。こ、ここはどこだ……？　お、おい……おまえ、なんでわたし\nの足を縛ってる？　なにぃ？　ナマイキなメスガキの捕獲ぅ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「も、もしかして海賊団全員をひっつかまえてるんじゃないだろうな！　違う\n？　わ、わたしだけ？　そ、それもどうなんだ……うう、離せ離せ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「キッチリお仕置きをするまで離さない？　ふ、ふぅーん……。じゃ、じゃあ\nこういう交換条件はどうだ？　わたしをすぐに解放するかわりに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「少しくらいならエッチなこと……をしてもいいぞ？　ん？　どうせしたいん\nだろ？　スケベ目的で捕まえたんだろ？　どーだ？　ほらほらほら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「こーやってさぁ？　わたしのおっぱいでおまえのチンポ……気持ち良くして\nほしかったんだろ？　そのくらいなら、別にしてやってもいーし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020901_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「こんなのてきっとーにおっぱいでチンポをグリグリー、ムニュムニューって\nすればいいだけじゃん。簡単すぎるし。余裕でできる。戦いより楽……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……ん？　なんか不満でもあるのか？　わざわざわたしがおまえのチンポを\n触って、刺激してやってるんだぞ？　したくもないのに……。そうだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「まー、イヤイヤやってるかどうかって言われたらそうだし。おまえがいつも\nわたしのおっぱいジッと見てるからこうしてあげてるって感じだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「しょーじき、そんなことしてほしがるオトナって意味わからんし。でも、そ\nうしないと逃がしてくんないし。……はー……面倒くさい。だる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ふぁーい、ずりずりずりー……。しこしこしこー……。お？　胸を揺らした\n方がいいみたいだな。ほーれ、たっぷんたっぷんたっぷんたっぷん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……はー……。腕も胸も疲れてきた。やる気ない……。もうやめていいか？\n　一応エッチなことはしたし……はいはい、終わり。おつかれさーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「って、うあああああっ！？　痛い！　イタイイタイイタイっ！　急に乳首を\nひっぱるなぁああっ！　おいっ、痛いから！　伸ばすなつまむなぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　なにやってんの！？　おまえっ……！　わたしがちょーっと優し\nくしてあげたら調子のってんのか！？　っあっ！　痛い、痛いからそれぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「手、を、は、な、せぇえええ……！　んん！　伸びるからっ！　乳首元に戻\nらなくなったら怒るぞ！　っいたたたた……やめろってぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「や、め……！　ううう……！　ひっぱったまんまでクリクリす、んなぁ……\nっ！　ヘンなクセがつくぅ！　ほ、ホント痛いんだって……！　っうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「一体なんなんだよぉお……っ！　……はぁ！？　こ、このままもう一度、素\n直におっぱいを動かしてみろぉ！？　や、やだよっ、なんでそんな命令！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……んぃいいっ！？　イタっ……！　わ……わ、わかった、わかったぁ……\nっ！　わかったからそれ以上伸ばすなぁああ！　乳……胸だよなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「む、胸……胸でチンポ……。デッカいチンポぐにゅぐにゅしてやる！　か、\n感謝しろよ……っ！　ん、ぅ……！　動かしにくい……、ふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ん、く……っ。はぁっ、はぁっ、はぁっ！　くふぅっ……ふぅうっ！　ふぅ\nっ、ふぅううっ……あぅううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「く、くそぉ……！　乳首がジンジンするぅ……！　それに、な、なんか、チ\nンポがますますデカくなってきて……やりづらい、も、揉みこめないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「な、なぁ、チンポ、チンポこれ以上デカくすんのやめろよっ……！　必死で\nやってるのがバカみたいだろ！　ぅっ、あっ、デカすぎてやりにくい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わ、わたしのおっぱいからハミ出てんだけど！？　っんっ……！　な、なぁ\n……！　あっ！　て、手加減してくれよ少しくらいぃ……！　はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「頑張ってるだろ！　わ、わたし……！　おっぱい叩きつけて、チンポ押し潰\nして……めちゃくちゃグニュグニュしてやってるじゃん……！　はぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「な、のになんか不満そうだし……！　あっ、き、気持ちよくないわけないだ\nろっ……！　海賊団の中ではわたしの胸が一番おっきいん、だからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「その胸でぐりゅぐりゅいじってて、感じないわけ……！　っぅううっ！？　\nち、乳首持ったまま、わたしの胸を弾ませるな、乳首で操るなぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ホントやだ、こんなのやだ……！　っうっ！　い、いや、イヤ……なのに…\n…。っぅっ♪　勝手におっぱい、使われて嫌なハズ……なのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なん、か……？　んん？　なんだコレ？　なん、か、ちょっと気持ちいい？\n　……うぁっ？　おっぱいが熱い、……乳首がキュンキュンってなるぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あひっ？　ひっ……あっ、あっ？　あっ♪　ヤ、ヤバいぃ？　これっ……な\nんか、チンポがこすれるところ、火照って……ビリビリするぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「き、気持ちイイかも……っ！　うぁっ♪　おっぱい、おっぱい感じちゃう、\nかも……っ♪　んあああっ！　谷間にズポズポ出し入れ、されてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ゾクゾクしちゃってるか、も……！　ふぁああっ♪　知らないっ、こん、な\n……感覚知らない！　おっぱいどんどんおかしくなってくぅっ、うううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっうっ♪　ううっあっ♪　んあああっ♪　あっふっ♪　ふぅっ、ふぅうっ\n……！　んんんっ、んん……！　あっんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「た、頼むよぉ……！　それ以上おっぱいっ……おっぱいひっぱんないでくれ\nよぉ……！　あうっ！　気持ち良くなってきた……あうっ、なんだこれぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ、うぅっ……！　くぅうっ……！　く、ふ……！　な、なあ！　わたし\nいっぱいチンポ気持ち良くするから、だから……許してくれよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「う……うっ、うっ！　はぁっ、はぁ、ああっ……！　こうか！？　こうする\nといいか？　……っんぁああっ！　もっとか？　力をこめて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「チンポ包み込んで、シゴいて……。んぁっ！　チンポビクッてなったぞ！？\n　なんだ！？　どうなるんだ！？　ふぇっ、しゃ、射精ぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「うふぁああああっ♪　ああああっ♪　ドッピュドピュかかってるっ……なに\nなになにっ！？　やっ、ぁっ、あああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んぅっ！　んんう……！　これっ、ど、どうにかして止められないのかっ…\n…！　うぁあっ、ビュルッビュル飛んでくる、すっごい量だ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「うぁあぁっ……。ムワァァって……キッツいオスのニオイ……。顔にまで湯\n気がかかるくらい、くっさいぃ……。それにドロドロで、粘ってて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「こ、こんなのチンポの中に詰まってるなんて、おまえって一体何者なんだよ\nぉ……！　ふぇっ？　男はみんなそう……？　そ、そんなワケないだろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「びゅるびゅる無限に湧き出てきてるしっ！　あっ！　またチンポビクッてし\nた！　やっ……♪　あっついっ、わたしの胸ヌルヌルだぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「う、ううう～～～……！　おまえの射精……思ってたのと全然違ったぁ！　\n精液なんか、ちょっとピュピュッて出るくらいで……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「楽勝で、カンタンで……！　そんで、射精させちゃえばおまえはわたしにメ\nロメロになって、言う事全部聞く都合のいいどれーになると思ってたのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……っふ……♪　こうして喋ってるだけで、精液の濃いニオイでクラクラす\nる……。あ……♪　あ、あ……♪　精子なんてばっちいはずなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なんか、目が離せなくて……このトロトロが好きになってきて……っ。なん\nだ？　おまえの精子、わたしに洗脳でもかけてるのか？　こ、こわすぎる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「か、勘違いするな！　わたしは精液なんか好きじゃないし、乳首ひっぱられ\nるのも痛くてキライだ！　わかったらその手を離して……。はぅうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「や……だ♪　なんで乳首っ、乳首また引っ張るんだぁっ♪　あっ♪　チンポ\n……全然ちっちゃくなってないし、むしろデカさが増してるしぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ！？　精液で濡れたおっぱいに、どちゅどちゅチンポが出入りして……\nあふっ！　さっきより気持ちいいぞ！？　んぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルして……ああああっ♪　そ、そっか……！　精液で、わたしのおっ\nぱいのすべりが良くなって……チンポがスムーズに動くようになったから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「だからわたしのおっぱいが、たくさん刺激されて……！　くぅうううんっ♪\n　やぁっ♪　痛いのに感じるようになっちゃってるっ♪　あうっあうあうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「乳首っ！　グリグリつねられるのもヤなのに！　ニュルニュルのおっぱいと\nジンジンする乳首と、二種類の快感がずーっとほとばしってて……、あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「き、気持ちいい……！？　も、もうこれ以上突かないでくれぇ……！　おっ\nぱいっ、おっぱい確実におかしくなっちゃってるぅ……！　あうっううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「お、おまえが喜ぶような、エロエロなおっぱいに改造されてしまったぁ……\n！　はうっ！　うっ♪　突かれたところが燃えるぅ、あついぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「え？　んんっ！？　うぅっ！？　む……胸と乳首だけでイキ、そうかも……\n！？　あっ♪　マンコに全然触られてないのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おっぱい、だけでイカされてしまうぅ……！　マズいぃっ、それはヘンタイ\nだぁっ……！　マ、マトモなおっぱいに戻れなくなってしまうぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　イクっ！　乳首でイクッ……♪　んぁ～～～っああああっ♪　お\nっぱいに熱がこもって、乳首がビリビリして……うぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「イッちゃうよぉお……！　あ～～～っ♪　あんっ♪　あふっ♪　ん～～～っ\n！　んんっ、ん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あひぃいっ♪　ひぃんっ、ひぃいっ……♪　凶悪なチンポに突かれて、胸ぇ\n犯されてっ、むちゃくちゃイかされてるぅっ！　うぁあ、イクぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ん……んんっ、ま、また射精したくなってきたのか……！？　あっ……だ、\nダメだなんてもう言えないぃ……！　だって、だってぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わたしがたくさんイッてる、から……っ♪　ああっ！　だからおまえも、イ\nッて、いいぞっ♪　あうっ！　わたしに、わたしにかけてくれっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「メスガキ乳首をぎゅうぎゅう伸ばされて♪　何度もイッてるエロいわたしに\n、精液かけてぇっ♪　欲しいっ……びゅるびゅる欲しい！　おねがいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んふぅうううっ♪　おっぱいぃっ♪　おっぱいに真っ白な精子っ♪　精液び\nゅっびゅっ！　びゅっびゅっきたぁあ♪　嬉しいっ、うれしいぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あるだけかけてっ♪　出せるだけ出して、全部おっぱいにかけてぇ\nえ……っ♪　あーっ、当たってる、精子が胸に流れてくぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「あぅう……♪　敏感になったおっぱいに当たる精液の感触……っ。一度目よ\nりずっとはっきりわかる、んっ……ゾクゾクしちゃうよぉお……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「見てぇ……。ベタベタしたのがおっぱいにはりついて、模様みたいになって\nる……♪　くっさいくっさい模様……。はぁ、はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱい、一度目の射精でカピカピになってるのに……二回目はブ\nリュブリュで変な感じ……♪　思いっきりマーキングされちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「んへぇえ……♪　すっごいいっぱい精液……♪　あは……♪　もうこのニオ\nイ、一生とれないよ……♪　だってこんな量なんだもん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「乳首グリグリされて、ぎゅーって伸ばされて……たぷんたぷんのおっぱいに\n、何度も精液ぶっかけられて……それがあんなに気持ちイイなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わたし、どうにかなっちゃったみたいだ……♪　あああ♪　ずーっとずっと\n、余韻で軽くイッたままで……♪　あひ……♪　はぁっ、はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「イケナイ遊び、教えられちゃった……♪　えへへへ……♪　このまま、おっ\nぱい伸びちゃって元に戻らなくなったらどーしよ～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「そん時はおまえ、責任とってわたしを……。って、い、今のはナシ……。も\nしそうなったら、続きを言う……。はぁっ♪　はぁっ、はぁっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「きゃぁっ！？　わぁあっ……！？　顔に……精液がかかって息ができないぃ\n……っ！　はーっ♪　はーっ、はーっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「やっ……！　頭っ……髪にも首にもいっぱいっ……！　精子飛んできたぁ…\n…！　んぐっ……！　強烈なニオイぃ……すごすぎるぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえっ……♪　そんなにわたしの顔にかけたかったのか……っ♪　んぷっ\n、すっごい量がドクドクしたたり落ちてくる……♪　んっ、ぅっうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「わたしが悪い子だったからっ……こうやってお仕置きしてくれたんだろっ♪\n　あぁあ……♪　そんなの、興奮しちゃうよぉお……♪　っあっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ンッうぁああ♪　さ、最後にもう一回イッちゃった……♪　だって、顔に出\nされるなんて想像もしてなかったから……っ♪　ん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「ん……♪　なぁ……？　おまえの精液まみれになったわたしの顔、好きか…\n…？　こんな顔、誰にも見せられない。恥ずかしくてドキドキする♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00020901_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「え？　これだけおっぱいを好きにイジられて感じるなんて、マゾ……？　あ\nはは……♪　そう言われれば、そーなのかも……。んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「おまえがわたしの予想を超えてイジワルなことをしてくるたびに、……うん\n……。アソコも……マンコもじゅわって濡れちゃってた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「もっといじめられたいって思うたびに感じちゃって……あぁ……♪　思い出\nすだけでまた、イッちゃいそうになって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「……今度おまえにナマイキなこと言ったら何されちゃうのか、た、楽しみに\nしてるから……。その時はいっぱいイジメてくれよな……♪　へへへ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_0103410" ]},
