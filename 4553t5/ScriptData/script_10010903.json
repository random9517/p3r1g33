{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0140" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……やってくれるやないけ、ほむら。ウチの事務所で子分たちをぶちのめし\nくさって、タダで済むとは思っとらんやろなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109050001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おお、怖ぇ怖ぇ！　悪の首領はおっかねぇなぁ？　ハハハハハッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ナメくさって……！　こん借りは、近いうちに熨斗つけて返させてもらうか\nらのぉ！　吐いたツバ飲まんどけよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109050002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へっ！　いつでも来いよ、待ってんぜ！　そんときがおめぇらの年貢の納め\nどきってやつだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「さてと、これから忙しくなりそうだぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「アネキ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＢ" ]},
		{"command":[ "SETTEXT", "「アネキ、お待ちしてました！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うわっ！？　なんだなんだおめぇら、こんなとこで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＣ" ]},
		{"command":[ "SETTEXT", "「噂は聞きましたよ。社長……いや、組長とやり合ったって！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんでぇ、お前ら。知ってたのか。まあ、そういうことだ。あたしはもう、\n現場には行かねえよ。いろいろ世話になったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「俺たちも、バイトやめてきたんすよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なにぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＢ" ]},
		{"command":[ "SETTEXT", "「俺たち、これまでバイト先を転々としてましてね。居酒屋の経験もあるんす\n！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「Ω組の現場は、労働基準法厳守で待遇もよかったっすけど……それより、こ\nれまで世話になったアネキに、恩返しをしたいと思ったんす！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、おまえら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「かくしてほむらは、数名の構成員とともに『居酒屋・正義（まさよし）』を\n悪の組織として独立させると宣言」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109050001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「九姉妹（ナインシスターズ）執行部の承認と、互助組合への加入を要求した\nのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「それからのほむらの動きは迅速であった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へぇ！　こりゃいい酒じゃないか！　この店に、こんな酒があったなんてね\nえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へへへ、そいつはマスターの秘蔵の一品でな。こんなときでもないと、出し\nてこれねえんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もぐもぐ……この……アジフライに……煮込みに……明太ポテトサラダもい\nけるではないか……マスターの味に負けていないぞ……もぐもぐ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109050001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「新しく入ったヤツに、他の居酒屋で修行してたのがいてな。そいつに厨房を\n任せてるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほどなるほど……これなら充分、マスターの不在を埋めることができる\nな……むぐむぐ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109050002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「で、だ。ものは相談なんだが……その酒と料理。しばらくの間、タダで飲み\n食いできるチャンスだって言ったら……興味あるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………話を聞こう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109050003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「かくしてほむらは、親睦会問題への態度を保留していたグレート・ルナリア\nム内部に、二名の協力者を確保。意気揚々と活動を開始した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109050004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「一方、Ω（オメガ）組も手をこまねいていたわけではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109050005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「おい！　ほむらがくるぞ！　買い物かごに食材がいっぱいだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ｂ" ]},
		{"command":[ "SETTEXT", "「あれをぶんどりゃ、今夜はろくな料理が出せめえ！　ほむらぁ！　往生せい\nやー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「威勢のいいのが突っ込んでくるが、どうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109050004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いっちょ軽～く揉んでやろうじゃねえか。軽～くな。へへへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109050011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}