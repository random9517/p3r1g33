		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ……。今日は母に付き合ってもらうぞ。久しぶりの休暇だからな。お前\nと一夜を共にしたいのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もう、準備はできているのだぞ？　勃起したチンポに、母の濡れたマンコが\nはっきり感じられるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母は、仕事をしながら、今日のこの時間を楽しみにしていたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「早く息子チンポとセックスしたくて……ンッ、だから、仕事もいつもより早\nく片付けたのだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、お前の準備も、しっかりとできているようだな？　チンポはガチガ\nチに勃起しているし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「それに、乳首まで硬くなっているではないか……。お前も、興奮しているの\nだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、先にこっちを刺激してやろう。ほら、乳首をつまんで、コリコリとい\nじって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、こっちの乳首は、母のキスだ……ンッ、ちゅ、ちゅぱっ、んふぅ…\n…ちゅ、ちゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あんっ、チンポがふるえて、マンコにこすれる……。んちゅっ、母に乳首を\n責められて、感じているようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふふっ、これはまだ前菜であろうに。メインディッシュはこれからだぞ？\n　ほら、母のマンコ……こんなに汁を滴らせている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「乳首で感じているお前を見て、母も昂ってしまったようだ……。お前のその\n切ない表情……母は、たまらないのだぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、それじゃあ、そろそろ……はぁ、はぁ、このチンポを、ハメるとす\nるかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、んんぅ……っ！　やはり、大きい……！　それに、母の一番奥にまで\n届いている……たくましい、チンポ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、これから、母が動くからな？　お前のチンポを、母のマンコでいっぱ\nいしごいてやるから……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ああっ、んふぅっ！　この体位だと、自分で、気持ちいいと\nころにチンポを当てられて……ああっ、いい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、どうだ？　母のマンコ、どうだ……？　んんっ、よく締まって、お\n前のチンポに、絡みついてくるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いい、いい……！　やはり、息子チンポはいい……！　ああんっ、腰が勝手\nに、動いてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、マンコの中で、お前のチンポがビクビクと震えているぞ…\n…んふっ、もっと、もっと私のマンコを感じるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ほら、乳首も責めてやるぞ……。ちゅぅっ、乳首舐められて……\nンッ、チンポ、ビクってしたな……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「気持ちいいか？　母に、乳首を舐められながら、腰を振られて……んっ、セ\nックス、気持ちいいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、ああんっ！　お前が感じているのは、伝わってくるぞ……\n！　んっ、んんぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「大きいチンポが、ますます膨らんで……！　んっ、んくっ、母の、母のマン\nコを……いっぱい、ひろげてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、先っぽがパンパンになってるっ。あぁんっ！　お前のチンポで、マ\nンコがいっぱいになってる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あんっ、ああっ、あはぁんっ！　チンポ、チンポがいいところ\nにあたるっ、ああっ、ああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母は、感じてしまっているぞっ！　マンコから、いやらしい汁をいっぱい溢\nれさせてしまってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「見えるだろう？　お前のチンポを頬張っている、母のスケベマンコ……！　\nんぁっ、お前のチンポ……母の汁まみれに、してる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、腰がとまらないっ！　いやらしい音、じゅぶじゅぶって響\nかせながら、腰を振ってしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、もっと、もっとこすって！　母のマンコを、ごりごりって\n、そのたくましいチンポで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、いいっ、いいぞ……たまらない……！　こうして、すぐ近くでみる\nお前の感じている顔も、最高だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「その、気持ちよさそうな……切なそうな顔……。それを見たら、私はますま\nす昂ってしまうからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「マンコから、ますますスケベな汁を溢れさせて……んっ、ああっ、さらに激\nしく、腰を振ってしまうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んっ、はぁあんっ！　ああっ、ああっ、どうした？　もう限界なのか？　射\n精、してしまいそうなのか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「チンポが、中で震えて、ンッ、そうか、そうか……射精してしまいそうなの\nだな……ああっ、んんぅう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいぞ、もちろんかまわない。私のマンコに、このまま射精してしまうがい\nい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私は、受け止めるから。お前の射精なら、私は、すべて……この子宮で、受\nけ止めてやるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁああっ！！　ああっ、ああぁあああぁぁぁんっ！！　きたっ、きた……\nっ！！　はぁっ、ああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「チンポが、ビクンビクンって跳ねてっ！　んっくっ、でてるっ、でてる……\n！　お前のチンポから、精液……ああっ、熱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、すごいまだっ、まだでてる……！　チンポが、何回も、精液の塊\nを母の子宮に放ってくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……すごい……。こんなに濃厚な精液を、さっそく放ってもらえるなん\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前は、なんて親孝行な息子なんだ……。ふふっ、母は、とっても鼻が高い\nぞ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、それにしても、まだまだお前のチンポは硬いままだな……。もっと\n、母に搾られたいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「私は、一度だけで終わらせるつもりはないぞ？　ほら、このまま続けようで\nはないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、ああっ、さっきよりも、お前のチンポを感じる……！　あぁんっ！\n　母も、さっきの中出しでイッたからな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「マンコの感度が上がって……んっ、ああっ、お前のチンポを、より感じられ\nるようになってる……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、お前はどうだ……？　私のマンコは、気持ちいいだろう……？\n　汁だくで、トロトロで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前から精液を搾るように……んんっ、いやらしく、動いてしまっているの\nだから……はぁんっ、あっ、んんぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「だから、また母が……腰を振るぞ……んっ、ああっ、ぐりぐりって、腰を押\nし付けるように……んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、お前の大きいチンポが、はぁんっ、私の、マンコの一番奥にまで達\nしてしまっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いや、違うな……。さっき、あまりにも気持ちよかったから、私の子宮が降\nりてきてしまっているんだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んふっ、んふふっ、どうやら、私の身体は本気でお前から精液を搾り取ろう\nとしているらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、だから、こうして……んっ、気持ちよくて、頭がおかしくなりそ\nうなのに……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「自分から、いやらしく、お前に見せつけるように腰を振って……ああっ、お\n前のことを、興奮させようとしているのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、もう……とまらない……！　もっと、もっと射精して欲\nしくて……ンッ、腰が止まらないぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、お前のチンポも、また、ビクビクしてる……！　んくっ、\nマンコの中で、また、膨らんで……はぁんっ、あっ、ああ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020102_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「イキそうになってるな……んっ、私も、私もだから……！　私もお前と同じ\nだ、イキそうになってるんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「また、息子の精液を浴びて、イキたい……！　ああっ、ああっ、もう身体が\n、昂ってしょうがない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ほら、お前も我慢せず、一緒に……！　んっ、イキそうになってる、そのチ\nンポから、精液を放つのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「先ほどのような、濃厚精液を、ああっ、このいやらしい母に、いっぱい、い\nっぱいだして……だして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、もうだめ……イクッ、イク、イク……ッ！　あっ、あっ、\nああ……ああ……っ！！」", "NORMAL" ]},
