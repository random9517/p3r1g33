		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「来たわね。さあ、さっさと下を脱ぎなさいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00025301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「どうしたのよ、ほら、遠慮することはないわ？　エリザが直々にご奉仕をし\nてあげようっていうのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「エリザはグズグズされるのはキライなの。気が変わらないうちに、さっさと\n脱ぎなさいよ。ほら、早く！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぇっ……！？　あっ……え……あ……えっ……お、大きい……あ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025301_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「な、何でもないわっ……ふぅん、ま、まぁまぁね。それが、あんたの……オ\n、オチンチンってワケ……へぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「その、違うわ、思ったよりはマシなモノを持ってるのねって……思っただけ\nよ。あんたにしては、まぁまぁね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「す、するわよ。待ってなさい……えっと、これを……んぷっ！　ちょっ、オ\n、オチンチンで頬を叩かないでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「これは、その、そうっ！　ちょっと焦らしてあげてるのよっ、そんなことも\n分からないっての？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「こんなの心の準備が……じゃ、なくて……！　どうしてあげようかなって…\n…あっ、んぶっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぐっ……！　んふぅぅぅっ！　まっ、んぶっ、おっ……むぐぅっ、ふっ、\nんぐっ、んんんんんんんーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「やっ、めっ、まひなひゃっ……むぐぅっ、あぷっ、じゅぽっ、んぐっ、ふっ\n……んぐぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ぷぁっ、はぁ、はぁっ……な、何するのっ……んっ、て、手伝うって……ふ\nぐぅっ、むふっ、じゅぽっ、りゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「やめっ……んじゅぷっ、ふぉんらにっ……奥まれっ、突いひゃっ、んじゅぷ\nっ、らめっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、はぁっ、んっ、むふぅっ、んぱっ、はぁっ、はぁっ、んっ……\nふぐっ、んぱっ、はぁっ、はぁっ……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ま、待ちなさいよ……んっ……んふぁ……ちゃんとするって言ってるんだか\nらぁ……れろ……んじゅぷっ、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「エリザが自分で……りゅぷっ、おしゃぶりするの……んりゅっ、くぽっ、じ\nゅぱっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「もごぉ……大きい……んふっ、何よこれ……口にやっと入るかどうかじゃら\nいの……んむぅ……息が……くるひぃ……んじゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「鼻で息を……んっ、ふっ、あんたに言われなくてもっ……わかっへるわっ…\n…！　んりゅっ、じゅぽっ、ちゃんと……ふるわよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んふぅっ、じゅぽっ、ちゅぱっ、んちゅぷっ……こう……れひょっ、んじゅ\nぷっ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んんっ、おふぅっ……くぱっ、あぁ……んぐっ、臭いわ……ヘンな味……ん\nんっ、オチンチン……こんなだったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んむっ、くぱっ……はむぅ……れりゅっ……れも……んっ、ちゅぷっ……口\nの中が……んぐぅ……いっぱいれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んふっ……んはぁ……りゅぷっ、くるひい……けど……んじゅる\nっ、なんだか……変なの……じゅぱ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぐぅ……ほ、奉仕……そうらわ……んっ、エリザが……したいの\nは……んじゅぷっ、このオチンチン……よくするのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「えろっ、れろ……れろぉ……どう……？　んっ、オチンチンの先……んじゅ\nぷっ、舌でレロレロされるの……いいんれひょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ぴちゃっ、むぐぅ……んふっ……じゅぷっ……この濡れてるとこ\nれ……んじゅぷっ……舐めてあげるのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んふぁっ、りゅぱっ……んちゅぷっ……はぁ……んふっ、ふぐっ……はぁ、\nはぁっ、んぱっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「別に……苦しくなんかないわよ……それより、どうなの？　あんたはちゃん\nとオチンチン出そうなの？　気持ちいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「まぁまぁ……っ……ふぅん、余裕じゃない……いつまでそんな余裕が続くか\n見ものよね……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んふっ、腰を抜かしても……知らないわよ……？　りゅぷっ、エリザの本気\n……みへてあげるわっ、じゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「むぐっ、むぐぅ……もごっ、ほぷっ……んっ、けふっ、けふっ！　へ、平気\nよっ……ちょっとむせたくらい、普通にあるでしょっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ちゃんと……しっかり、ご奉仕に……集中してなひゃいっ、むぐぅっ、むふ\nっ、んぷっ、くぷぅ……りゅぷっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、口からよだれ……う、うるひゃいわね……ひょっと漏れるこ\nともあるわよっ……じゅぱっ、んちゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「そんらことより……んっ、もう……出したいんじゃらいろっ？　ヤセ我慢な\nんか……してらいれっ……イッたらろうなのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ほら、何とか言ってみ……んぐぅっ！　ふぐっ、頭っ……抑えてっ、むぐっ\n、りゅぷっ、んぶっ、ふぐぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「むぐぅっ、まっ……こんらっ、激しくっ……ふぐっ、んっ、んぶっ！　むぅ\nっ……んぐっ……んんんーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あぶっ！　れてっ……るっ……！　むぐぅっ……せっ……えきっ……んぐっ\n、んふぅっ……こくっ、んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んっ、んふっ、んぐっ……の、飲むわ……飲むからぁ……んっ、んぐっ……\nまってぇ……んっ、んくん……んはっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あふ……はぁ……んっ、全部……飲んじゃった……はぁ、\nあたし……オチンチンの精液……飲んじゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「今の……何だったの……？　すごい力で押さえつけられて……夢中でオチン\nチン……口いっぱいにして……めちゃくちゃにされて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「なのに……あたし……んふぅ……ドキドキして……こんなの……初めてかも\n……はぁ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あ……ま、待って……待ちなさいっ！　その、オチンチン……し、しまうの\n待って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「その……さっきの、ちょっと……よ、よかったわ……だから、その……ら、\n乱暴にする感じのやつ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あっ、そ、そう……そのオチンチンで……エリザのほっぺをぺ\nちってするのも……モノ扱いされてるみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「だから……また、さっきみたいに……エリザの口……して、欲しいの……ま\nだ、オチンチンおっきいままだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あぷっ！？　ふぐっ、んんんんんっ！　ふぉ、ふぐぅっ……んっ！　むぐぅ\nっ、おぷっ、んっ、ふんぐぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぉ、ふぉうっ、ふぉれぇっ……！　んぱっ、りゅぶっ、んちゅぷっ……エ\nリザのっ、く、口マンコっ……じゅぶっへひへぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「むぐっ、んふっ、ふるわっ……ひゃんと……きもひよくっ……んじゅぷっ、\nするのっ、オヒンチンっ……ご奉仕ふるのよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「れろっ、んりゅぷっ……この辺は……ろぉっ？　んっ、あっ……ビクってひ\nてる……んふぅ……ここ、いいのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「少し分かった気がふるわ……んじゅっ、あぷっ……んむぅ……んふっ、オチ\nンチンの……れるっ、気持ちよさそうなとこ……んっちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「この割れてるトコ……ふぉれに……んっ、んりゅっ、この皮が……ズリズリ\nって……捲れると……いいんれひょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「分かるわ……んじゅぷっ、らって……んっ、ビクってオチンチンが跳ねて…\n…むぐっ、んっ！　ノドに……届くりょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぐぅぅっ……むっ、んぐっ……んぱっ、はぁっ、はぷっ、んちゅぷっ……\n！　息……くるひいのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んじゅぷっ……はぁっ、んぐっ、なんらかっ……体が……ゾクゾクふるのぉ\nっ、んふっ、ぐぷっ、んじゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「こんら風にっ……激しく……されるのっ、んじゅぷっ、好きっ……らのかも\nぉっ……んっ、じゅぷぅ、んじゅぱっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「また……んっ、よくなってきたんれひょっ？　ならっ、んじゅぷっ……んっ\n、また……オチンチンれっ、口マンコひてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぶぅっ！　んぐっ、あぶっ、んふぅぅぅっ！　はげひぃのっ……おぶっ！\n　ふごいっ、じゅぷじゅぷっ、ひてふぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んぷっ、ふぐっ、エリザの角っ……押さえちゅけられてへぇっ！　オチンチ\nンっ……じゅぼじゅぼっへぇっ、むぐぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あぷっ、あぁっ、らひたくっ……なっへるのっ！？　おひんひんっ、いっぱ\nいっ、れるのぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んぶっ、ふぐぅっ、あぷっ……ひてっ、らひてっ！　れんぶっ……いっぱい\nっ、らひきってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「むぐぅぅぅっ！　んじゅぷっ、おぶっ、わらひもっ、ふぐぅんっ、イグっ…\n…んくぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んぐぅっ……！　はぷっ、んんっ！　んりゅっ、むぐっふぅぅぅっ！　んっ\n、んぐぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……いっぱいれてる……んんっ、んぐっ、こくっ、んくんっ……おぷ\nっ……はぁっ、んふっ、むぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ま、まっへぇ……ちゃんと……飲むからぁ……んぐっ、勢い……止まっへぇ\n……んじゅるるっ、ちゅぱっ、んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んはっ、はぁっ、はぁっ……あふっ、んくんっ……はぁ……はへぁぁ……全\n部……出た……？　んっ、飲んだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……はぁ、こんなに沢山……んっ、出すなんて……思わないし……け\nふっ、でも……ちゃんと飲んだわよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、んっ、はぁ……オチンチン……気持ちよかったから射精した\nのよね？　エリザのご奉仕、上手だったでしょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「悪くない……ふんっ、そーいう時は、空気読んで上手だったって言うのよっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「全く、そーいうところは全然気が利かないわよね。だから、冴えない男なん\nて言われたりするのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ま、まぁ？　ちょっと強引なところは、結構ワイルドで……エリザとしては\n悪くなかった気はする……けど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ほ、ほめてるのよ！　だから、ちゃんとありがたく思って……ま、また……\n強めに、し、しなさいよねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁっ！　あぶっ……顔にっ……んふぅっ、いっぱいっ……出てっ、\nんくぅぅっ、あっ、んぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んぁぁ……ねとねとのが……シャワーみたいに……エリザの顔に、んぷぁ…\n…べっとりついてるの……はふぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……あぁ、エリザの顔にぶっかけぇ……出して……もっと、掛けて\nぇ……んふぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はぷっ……はぁ、はぁ……終わった……？　んんっ、ふっ……やっと……オ\nチンチン全部出し切ったのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「すごい……ねとねと……あぁ……むわっとするニオイ……エリザ……あんた\nにマーキングされちゃったんだ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「こんなに出すなんて……んふぅ……よっぽど、エリザのご奉仕が気持ちよか\nったのね。そうなんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「まぁまぁ……こんだけ、エリザの顔を汚しといて、よくもそんな偉そうなこ\nと言えたわねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「フン……そーいうところがダメダメだってのよ……全く、何だってエリザは\nこんなのを……何でもないわよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ま、まぁ？　ちょっと強引なところは、結構ワイルドで……エリザとしては\n悪くなかった気はする……けど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ほ、ほめてるのよ！　だから、ちゃんとありがたく思って……ま、また……\n強めに、し、しなさいよねっ！」", "NORMAL" ]},
