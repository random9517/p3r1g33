{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0101" ]},
        {"command":[ "DISPIMAGE", "0", "true" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_018" ]},
        {"command":[ "SPOTCHARA", "0" ] },
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だから！　わざとじゃないって言ってんだろう！　しつこいねえ！」", "NORMAL" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "003_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あのことだけを言っているのではありません！　あなたたちの戦術に問題が\nあると言っているのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いちいちうっせえなぁ！　勝ったんだからどうでもいいだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「勝てばいいという問題ではありません！　だいたい、あなたたち悪の組織に\nは協調性が欠けているんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ヒーロー同士で内輪もめして、崩壊したチーム出身の方に言われたくありま\nせんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「な！　あ、あれは私のせいではありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「めんどくさいなあ、もう……こんなことならホク姉たちとパトロールに行っ\nてればよかったよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前たち、いいかげんにしないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んなこと言ったって、言いがかりつけてくるのはアイツなんですよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「何が言いがかりですか！　私は、戦術上の問題点を指摘しているだけです！\n　そもそも今日は隊長がですね――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030004" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「……隊長？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030005" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぇっ！？　な、なんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「隊長から見てどうなのですか！　今日の彼女たちの不始末は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030006" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「不始末……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「何が不始末だい！　お前が自分勝手に動くのが悪いんじゃないか！　カツマ\n、オマエからも言ってやんな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分勝手に……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "おいおい、二人とも何言ってんだ？　戦闘中にいったい何が……？　まったく\n記憶にないぞ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだい、はっきりしないねえ！　隊長だろう！　ズバッと言ってやんな！\n　ヘマをしたのはどっちか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103030003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうです！　隊長として、キッチリと指導をお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030007" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そう言われても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "何なんだ？　そもそもなんで揉めてるんだよ、みんな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ああ、もう！　はっきりしてください、隊長！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030008" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……はっきりできるはずがない。隊長は寝ていて、現場を見ていないのだか\nらな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030009" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「どういうことだい、そりゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103030004" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　え？　え！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そ、そうか……道理で記憶がないわけだ。俺、寝落ちしてたのか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ったく……なにやってんだ、このアホは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103030005" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくだ。こんなことで、よく隊長だなどと大きな顔をしていられたもの\nだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待てよ！　俺は何もわざと――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYBGM", "BGM_016" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……カツマ。少し黙れ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええええっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ひでえな！　こっちの事情も聞かねえつもりかよ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「今日と言う今日は、さすがに私からも苦言を呈さなければならないようだ。\n……カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このままではお前は、隊長失格だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにぃ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "勝手に隊長に祭り上げといて、何もかも仕事を押し付けといて、いきなりの\n失格宣言！？　どういうことだよ、そりゃ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おまえが隊長として指揮をとらないのはまだいい。いつものことだ。その程\n度は、私がフォローできる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030005" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「指揮するのは、私だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どちらでもいい。とにかく、戦術の欠如は我々メンバー個々の能力で補うこ\nともできる。だが問題は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030006" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お前がせっかくの『エンブレム・シンテシス』を、まるで使いこなせていな\nいことだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030007" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「『はぁ？』ではない！　これでは、お前が隊長に就任した意味がないではな\nいか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030008" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、お前……！　あのな……！　だいたいだな……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "『エンブレム・シンテシス』ってなんなんだよ！　全然説明してもらってねえ\nじゃねえか！　と文句を言おうとしたが――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そもそも～、下僕ちゃんが隊長ってなんだか変だと思ってたのよね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあ、コイツには荷が重すぎると思ってはいたがねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103030006" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひでえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「焼きそばパン買ってこいって言ったらコロッケパン買ってくるし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそも隊長にパシリさせんなよ！　買いに行く俺も俺だけど！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「言わせてもらえれば、状況の把握力、分析力にも不安があります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030010" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おーい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「やはり人選ミスだったか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00004901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから！　そもそも隊長職を押し付けてきたのはあんたらじゃねーか！　っ\nていうか、いつからそこにいたんだ長官！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ホク姉のほうが、隊長に向いてるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00009901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでそこでホクサイが出てくんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「要するに、カツマじゃ全体的にダメのダメダメです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこまでストレートに言うか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「みんなひどいよ！　カツマさんだって、ダメなりにがんばってるんだよ！？\n　知恵と力が足りてないからって、責めるのはよくないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一番ひでえ言いぐさだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ、あの、カツマ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あーもう、わかった！　いいよ！　もういいよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「要するにみんな、俺が隊長なのが不満だってことだよな！？　いいよ！　だ\nったら辞めてやる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待て、カツマ！　いきなり何を言い出すのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030009" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今さら何を言っても遅えぞ！　もう決めたんだ！　辞めてやる！　こっから\n出てってやる！　俺はもう――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「グレてやるぅ～～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「待ってください、カツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「な、なんということだ……これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090103030010" ]},
        {"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく……アイツと来たら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030004" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様、放っておきましょう。本人が辞めると言っているのですから\n、辞めさせてあげたらいいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そうそう。あんなのいなくたって、立派に仕事は務まるって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103030004" ]},
        {"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103030004" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「とはいえ、隊長なしでは部隊を維持することはできませんね。新しい隊長が\n必要だと思うのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030011" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「新しい隊長？　そんなの決まってるじゃないか。ウチのルナテミス様だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010103030007" ]},
        {"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ。皆がそう言ってくれるのなら私が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030005" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「は？　誰が、いつそんなことを決めたのですか！？　だいたい、悪の組織か\nらＥＤＯ所属部隊の隊長を出すこと自体がおかしいのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030012" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030006" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、誰がやるってんだよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010103030005" ]},
        {"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「とにかく、正義の味方側から隊長を出すべきです、適任者がいなければひと\nまず私が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030013" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ホク姉でいいじゃ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010103030003" ]},
        {"command":[ "SETCHARA", "0", "char_00009901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「え？　わ、わたし？　でも、シャラクがそう言うなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "096_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「横からいきなり口を挟まないで！　だいたい、ホクサイさんはいつ戻ってき\nたんですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030014" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「つーかさぁ？　あなた、自分が隊長やってみたいだけなんじゃないの～？　\n戦隊にいたころは、リーダーになれなかったから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「なんてことを言うのよ、あなた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010103030015" ]},
        {"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "昆虫型女怪人" ]},
		{"command":[ "SETTEXT", "「ちょーっと待ったあ！　新しい隊長を選ぶのなら、ウチの組織の首領を推さ\nせてもらおうかぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "黒スーツの女極道" ]},
		{"command":[ "SETTEXT", "「ウチの姐さんを差し置いて何言ってやがんでぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "装甲強化服の女" ]},
		{"command":[ "SETTEXT", "「いーや！　アタシがやる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "アンドロイド女" ]},
		{"command":[ "SETTEXT", "「私が隊長を務めるべきだと、マザーコンピューターが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「って、貴様らどこから出てきたぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010103030007" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はははは！　騒ぎを聞きつけて、非番のメンバーまで集まってきたようだね\n。面白いことになってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010103030001" ]},
        {"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「っていうか、こうしてみるとウチの隊って、すごい大所帯だったんだねえ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010103030002" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「のんきなこと言ってる場合じゃありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010103030004" ]},
        {"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETNAME", "イカ型女幹部" ]},
