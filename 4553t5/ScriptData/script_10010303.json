		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "変身魔法少女" ]},
		{"command":[ "SETTEXT", "「ちがーう！　正義の味方から出すの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "狼女" ]},
		{"command":[ "SETTEXT", "「やんのか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッチョ女" ]},
		{"command":[ "SETTEXT", "「やったろうじゃねえか！」", "NORMAL" ]},
