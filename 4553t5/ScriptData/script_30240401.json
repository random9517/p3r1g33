		{"command":[ "PLAYVOICE", "v2_024_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ほら、まだ……出てくる……んっ、直接オチンポ顔にくっつ\nけちゃうの……あぁ、精液……ヌルヌルぅ……」", "NORMAL" ]},
