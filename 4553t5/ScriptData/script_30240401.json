		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぷぁっ……２発目なのに、まだこんな勢いで……ホントご主人さ\nまってば、ムッツリなんだから……んっ、あぷ……」", "NORMAL" ]},
