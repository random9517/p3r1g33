{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「来たわね、ご主人さま！　さあ、そこに座りなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「もう座ってる？　細かいことはいいのっ。今日はあなた……ご主人さまに、\n特別なプレゼントを用意してあるのよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ、察しは悪くないみたいね！　このマーガレットちゃんが、メイド姿\nでバレンタインにあげるプレゼントなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00002404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さ、という訳で……はい、ズボンを下ろすわよ！　えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002404_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「何をビックリしているの？　ふふっ、ほら……オチンポ出しちゃうわ。あら\n……もう半分大きくなってるじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えっ、チョコレートはどうしたのかって？　バレンタインだったら普通はチ\nョコ？　ふふっ、もちろんそんなことは分かってるわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「チョコならほら、ちゃーんとここに、ほらボウルの中にクリームがあるでし\nょう？　たっぷりのチョコが入ってる特製のやつよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えっ、まだどういうことか分からないの？　全く、やっぱり察しは悪いわね\n！　ほら……こういうことよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほぉら……ふふっ、たっぷりオチンポにチョコがコーティングされちゃった\nわ。茶色くなったオチンポの形も中々ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「それじゃ……あぁん……れろっ、ぺろっ、んちゅ……れろ……えろっ、んん\nんーーっ、あまぁぁぁいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ、私が味わうのかって？　いいじゃない、ご主人さまはチョコよりも\nっとあまーい、マーガレットちゃんのご奉仕を味わえるのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら……れろ、ちゅぱ……オチンポはとっても正直にビクビクしてるじゃな\nい。いっぱい舐め回して欲しいって震えてるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、えろ……れろぉ……どうなの？　それとも、こんなご奉仕は受けたく\nない？　もうやめちゃった方がいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふふっ、そんなに首をぶんぶん振っちゃって。やっぱりオチンポは正直で\nいいわね！　そんなに言うならしょうがないわ……んれろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えろ……れろ、ぴちゃ……んちゅぱ……ちゅぷぅ……れろ……んっ、あぁ…\n…れろ……また、チョコ……足してあげようかしら……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ、れろ……ちゅぱっ……んふっ……チョコの甘さに……オチンポのし\nょっぱさが混じって……結構行けるわこれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「よかったらご主人さまも味わってみる？　ふふ……遠慮するの？　結構美味\nしいのに……ぴちゃ……れろぉ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「まぁ、代わりにご主人さまはマーガレットちゃんの舌をたーっぷり味わって\nね。この割れてるところ……ぐっと押し込んでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「えろっ……れろぉんっ……くびれとカリのトコ……くすぐるように舐め回し\nてぇ……んっ、ぴちゃ……んちゅ……れる、える……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふ……気持ちよさそうに目を細めちゃって。それに、目つきもやらしくな\nってる……じーっとおっぱいばっかり見て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「そんなにマーガレットちゃんのおっぱいが気になる？　触りたい？　モミモ\nミしたい？　んふふーっ、どうしよっかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、今日はダーメ。今日のここは見せてあげるだけ……ご主人さまはおっ\nぱいじゃなくて、オチンポに集中するの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んちゅっ……ふふっ、ほら……この辺弱いのよね？　舌でくりく\nりってつっついてあげると……あはっ、ピクって跳ねるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほぉら、可愛いー。気持ちよくて、ぷるぷるーって震えちゃうんだ。んちゅ\nっ……ぴちゃ……とっても敏感で正直なオチンポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぷっ……そろそろ舐めてるだけじゃ物足りない？　なら……\nぱくってしちゃおうかなー、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぁんむ、りゅぷっ、じゅぽっ、じゅぱっ……んじゅっ、りゅぷっ、んりゅ\nぷっ……じゅぷっ……んふっ、じゅぽっ、くぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403126" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷ……いっぱい、頬張っひゃうっ……口の中れぇ……んむっ\n、オチンポ……膨らむぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くぷっ、んぱっ、んりゅぷっ……はぷぅっ……んじゅるるぅっ……あぁ、よ\nだれ、れてきちゃう……チョコの味も残って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んんっ、後は……オチンポと汗と……んちゅぅぅっ、中から出て\nきてる汁ぅ……んじゅるるっ、んちゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ、オチンポ吸われるのきもひぃぃ？　いいわよ……ご主人さまの為に\n、もっともーっとしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、くぷうっ、んじゅぽっ、じゅぷっ、んじゅぷぅぅっ、りゅぷっ、\nんじゅるるっ……んちゅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、どんどんお汁……溢れてくるわ……くぽっ、りゅぷっ\n……唇でシコシコされるの……好きらのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぶっ、りゅぷっ……ほぉら……どんどん我慢できなくなってきてる……鼻\nがぷくって膨らんで……我慢できないの？　ご主人さま？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、いいのよ……んりゅぷっ、ムダなやせ我慢なんてしちゃわないで\n……出したくなったら、そのまま……お漏らししちゃいなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んんっ、ふぉらっ……もうビクビクさせへるんらからっ……じゅ\nぷっ、らひなさいっ……りゅぷっ、んじゅうぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぶぅっ！　んんっ……んぐっ、こくっ……んんっ、沢山……出てる……ん\nくっ、こくっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んはぁっ……あぷっ、ちゅぷっ……美味しいわ……ご主人さまの新鮮なミル\nク……んちゅぷっ……とっても濃くて……こってりしてるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「れろ……ふふっ、チョコも綺麗に舐めちゃった。先っぽがツルンってしてる\n……れろ……まだ舌が伸びちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どう？　気持ちよかったでしょ？　ふふっ、ご主人さまのオチンポ……喜ん\nでくれたみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……バレンタインの時の特別ご奉仕、楽しんだなら何よりだわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あららー？　ご主人さまのオチンポ……まーたムクムクしちゃってる？　一\n体、どうしたのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ、もしかしてぇ……まだ全部出せてないから、ムラムラしたのが残っ\nてる？　そうなんだ……ご主人さまはどうして欲しいのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「メイドさんにお願いしたら～、もしかしたら叶えてくれるかもしれないよぉ\n～？　ほらほら～、どうなのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふふーっ、そうなんだー。そんなにオチンポナメナメして欲しいんだ。も\nう、しょうがないご主人さまなんだから……えろぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ、ちょうどチョコも、もう少し残ってるし。ヌリヌリしたげる……そ\nれで、これをぉ……れろっ、えろっ、ぴちゃ……んれるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ、ペロペロされると……またオチンポ気持ちいい感じになってるでし\nょ？　ちゅぱ……ぴちゃ……精液の味も混ざってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「甘いチョコ……しょっぱいオチンポ……それに、ドロッとした精液……んっ\n、れろ……色々な味が重なってぇ……れろ、ぴちゃ……美味しい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ、オチンポも気持ちいいみたいね。れろ……ぴちゃっ……こうして舐\nめてあげる度に、ピクってするの分かっちゃうもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、一回イッた後だから、すごく敏感になってるんでしょ……？　可愛ら\nしく震えて……れろっ、えろ……ぺろ……れろぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「まだまだ……メイドさんのご奉仕はもっと凄いのよ……？　はむっ、くぽっ\n、んちゅぷっ、深く……咥えなおひてぇ……こぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んりゅっ、ずりゅっ、んじゅぷっ……ふぐっ、お口の裏のとこれ……オチン\nポ、りゅぷって……ひごいてあげる……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くぽっ……んふぅっ、口の中……いっぱいになるぅ……喉のとこまれ……と\nろいて来ちゃう……んふっ、くぽっ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「腰が動きそう……わらひのお口……犯したいって思ってるの……？　んふっ\n、いいわよ……？　ご主人さまなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんっ！　ふぐっ、あぶっ……！　んっ、あぁっ、んぷっ、本気ろっ……ピ\nストン……ひてるぅっ……んぐっ、りゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ、わらひもっ……ちゃんと……吸い上げてっ……オチンポ……よくひ\nてあげるっ……じゅるっ、んじゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んぱっ、りゅぷっ、じゅぱっ……んふぁっ……はぁん……また、お汁浮いて\n来た……じゅぷっ……ふぉーら、腰引いちゃらめ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゃんと、舌を感じるのよ……れる……れりゅっ……そう、気持ちいいのか\nら逃げちゃらめ……しっかり気持ちよくなるのぉ……じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、ご主人さまのオチンポ、ビクビクしてる……これ……もうイ\nキたくて仕方ないんでしょ……？　ちゅぷっ、んりゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ……ほらほら……やせ我慢しちゃダメって言ったでしょ？　メイドさ\nんの言う通りに、オチンポびゅくってしちゃいなさいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403219" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さあ……らすのっ……奥に残ってる濃いのっ……思いっきりびゅーびゅーし\nちゃいらさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んんーーっ！　ふぐっ……んくっ、こくっ……んんっ……んくっ、んっく…\n…こくっ、んっ……んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふぁっ……んぷっ……まだ、こんなに残してたんじゃない……ホントご主人\nさまってば、ムッツリなんだから……んちゅ……ちゅうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふぉら、今度は全部出しきっちゃうのよ……残したりしてたら、承知しない\nんらから……んちゅぷぅ……んっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んふっ……！　ふぉら……残ってた……んちゅっ、ちゅぅぅっ……こくんっ\n、れろ……これで、やっといいみたいね……ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「れろ……んふふっ……はい、おしまい。後は、最後のお掃除だけしちゃうわ\n……れろ、ぺろ……んっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほーら、オチンポちゃんと綺麗になったわ。んふふっ、どういたしまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002404_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どうだった？　やっぱりメイドさんのご奉仕は普段より気持ちよかった？　\nえっ……おんなじ位？　むぅー、何よイマイチだったってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「逆？　普段も同じくらいいいから比べられない……？　ふふーん、何よ、そ\nーいうことなのね。それなら仕方ないわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「じゃあ、そんなご主人さまにいいものあげる。ほら、口を開けて、あーんっ\nて……そうそう、はいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ、甘い？　さっきのクリームが入ったチョコレート。一応ご主人さま\nも味わっておかないと、ね♪」", "NORMAL" ]},
