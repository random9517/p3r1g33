		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁっ……今度こそちゃんと出たわね……ちゅぷっ、んっ……今度も\n濃厚で……美味し……♪　さ……後はお掃除ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
