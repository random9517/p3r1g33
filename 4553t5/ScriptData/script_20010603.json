{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「鳳雛さん、追いましょう！　死体を取り戻さないと！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120001" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「駄目だ！　ゲンナイくん、落ち着くんだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120001" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕たちは、まだ他のみんなにバレてしまってはいけない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なんでなんですか？　もうここまで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120002" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ここまできたからこそだ。冷静になって考えるんだ。敵の手際はかなり良い\n。僕も含めて全員を翻弄している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120003" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「こんなに翻弄されるのは、情報が漏れているから――それはつまり内部協力\n者がいる事を示している！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「た、確かにそうですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120003" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃあ、えっと……どうしますか？　この周辺を探しますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いえ……一旦他の人の様子を見に行こう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120005" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0123" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_021" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「皆さんも固まっているみたいですね。こうなると内部犯行の線はないんじゃ\nないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120005" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ちっちっちっ……逆さ。間違いなくあの三人の中にいるはず。今は動かず、\nじっとタイミングを見計らっているんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120006" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃあ鳳雛さんは、誰が犯人か目星はついているんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120006" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「残念ながらついてない。三人共、大いに可能性がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120007" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「オボロは、普段から落ち着いていて連絡係としては適任」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ダイアナは、自分から推理を行った事が怪しい。捜査を攪乱している可能性\nがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「セレーナは……こんな回りくどい事はできないだろうが、だからこそ情報を\n制限して自由に動かしているのかもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なるほど……言われてみると三人共怪しく感じますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120007" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……だから動きがあるまで、ここからは見張りだ。かなりの持久戦になるか\nもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120011" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「おおっ！　私、見張りって結構憧れてたんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120008" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0123" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_021" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ううっ……寒いし、何もできないし、暇だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120009" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「だから言ったじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120013" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「お腹空いたな……お寿司食べたい……今頃みんなはお寿司食べてるんだろう\nな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120010" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「我慢も仕事だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120014" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0123" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_021" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ううっ……結局朝に……全然動きないし……これなら研究してればよかった\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120011" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「鳳雛さん、これからどうします……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120015" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「鳳雛さん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120013" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ぐぅ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120016" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ね、寝てる！？　いつの間に！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120014" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「鳳雛さん、ほら起きて下さい！　ズルいですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120015" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「う～ん……お前が犯人だ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120017" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「寝ぼけてないで、起きて下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120016" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いやぁ～っ！　ダイヤナちゃん、もうゾンビちゃんいやぁ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010106140001" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「今の声は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120017" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ん、んん～お父さんの名に懸けて～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021120018" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「鳳雛さん、寝ぼけてガス化しないで！　起きて！　起きてぇぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021120018" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}