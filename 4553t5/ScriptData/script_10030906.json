{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0028" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「塾に時間帝国の兵士が入ろうとしたってことは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「この塾、時間帝国がかかわっているのは間違いないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間帝国の兵士を蹴散らしたふたりが、塾の中へと飛び込んでいく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえら待て！　そんなに先行するな！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺も急いであとを追った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETTEXT", "塾の中、教室がもぬけの殻だと思ったら、地下へと続く通路を発見した。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこを通った先で俺たちが見たものは……！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ルルーナさん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「マーガレットに……つきみも！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "塾に通っている生徒たちが、怪しい機械につながれている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……って、あの機械見たことあるぞ。あれってたしか、サイレーンの作った『\n不眠学習装置』じゃないか！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「カツマさん、あの機械のことを知ってるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え、ああ……まあな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だが、あの装置をどうして時間帝国の連中がもっているんだ？　装置の周りに\nいる連中に秘密がありそうだが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "｢やはり洗脳装置の効果にはまだ限界があるようだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「洗脳魔法もそう……時間が経てば書きこんだ記憶が消えてしまう……。ウヒ\nヒ、不運」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「洗脳ですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっぱり、この塾で行われていたのは勉強じゃなかったんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不眠学習装置そっくりな機械で行われていたのは、学習よりもはるかに迷惑な\n行為だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ところで、侵入者である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なんだって！？　なぁんで教えないの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「聞かれてないからである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「侵入者に気づけないなんて……不運」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「言ってる場合！？　とにかく、ボクたちの邪魔はさせないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860003" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ハルカプトラ、侵入者の居場所は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「さっきからそこの入り口で覗いているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115860003" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そんなに近づかれてたの！？　なぁんで教えないのさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860005" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「教える理由がないからである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115860004" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「十分あるでしょうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860006" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……こんなときに仲間割れ。なんて不運」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ちょっと、もうバレちゃってるじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115860003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「仕方ありません……強行突破です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115860004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「夜日楽ってそんなキャラだっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115860004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「だって、ルルーナさんたちを助けないと！　あの人たちが言い争っている隙\nに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115860005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「……そうだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115860005" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっとまて！　いったん本部に連絡を……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふたりを止めようとしたが、俺の言葉を聞かずに飛びだしてしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あの機械を操作している３人組、絶対に時間帝国の一般兵士じゃないだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……でも俺だけここに隠れてるわけにいかないか！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふたりを放っておけず、俺も飛びだす。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そ、そこまでです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「むむっ、侵入者であるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115860005" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いかにも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115860002" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「生徒のみんなを、開放してもらいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もちろんルルーナたちもだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それはできないね……いけ、ボクらの塾生たち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115860007" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナたちに取り付けられていた装置が外れる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

