{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……私の衣装、ずっとジーッと見てるけど……。やっぱりおかしい？　似合\nわない？　そうじゃなくて、目を惹くから？　……そ……そうなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そうだね。この衣装、結構目立つよね。でも私はあんまり着たくなかったか\nも。露出度も高いし、……ちょっと恥ずかしい記憶もあって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え？　どんな記憶かって？　そ……それは……。って、い、いきなり近づい\nてこないでっ、わ、わかったから、教えるから！　えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あれは、私がこの服に変身しようとしてた時の話。今の君みたいに、急にあ\nの人が後ろから迫ってきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404104" ]},
		{"command":[ "SETCHARA", "0", "char_00001804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「う、ううううぁあああ！？　な、何っ、突然っ……！　こ、こんな恥ずかし\nいポーズとらせないでよ……って、ひぇっ！　い、衣装が、消えてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001804_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……変身中に驚かせたりするから、中途半端に衣装が生成されて……ほとん\nど全裸状態になってる！　……い、一度下ろして！　こんなのだめぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「なんでって……見てわかるでしょ、さ、寒いし、恥ずかしいし、顔が赤くな\nるし、もうさんざんだよ！　態勢を立て直したい、だから早く……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ッひっ……！　な、なんでおチンポを取り出しているんだい……？　だ、だ\nめだってば、そんなの、私のおマンコに押し当てちゃ……。んぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ま、まさか今ここで……するつもりじゃないよね？　あっ……い、嫌とかじ\nゃ、なくて……。心の準備もできてないし……あっあっ待ってよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ！？　うっ♪　う、ウソぉおお……っ！　容赦なく一突きで挿入され、\nちゃった……。あっ、ぅう……！　下ろしてって言った、のに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……んん？　腰を下ろした？　そ、それは私の腰をぉお……君のおチンポに\n下ろしただけ、で……！　っあっ♪　こ、これは……ま、マズいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「中でおチンポ、太くなってる……大きさも、硬さも、長さも限界まで増幅さ\nれてくるっ！　な……なんで？　なんでぇ？　……うぁううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「は……恥ずかしい、って言っているのにぃ……！　っあっ！　ちょっ……ち\nょっと待って！　私を上げ下げして、おチンポを出し入れしないでよお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ん、んくぅううっ！？　んぁっ、あっ……んんぁっ！？　無理っ……むりぃ\n！　揺さぶられる、と、おマンコが勝手におチンポ咥えこむぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……奥っ、一番奥に突き刺さる、から、休ませて、せめて気持ちが整うまで\n……って、んぁあああああ！　だ、だから、まずいからっ……！　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こ、ここ、校門前……だよ？　ねえっ、い、今は誰もいないけど……い、い\nつ人が来たっておかしくない……本当にこのままするの？　っあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私っ、つ、通行人に見られながらしたいとか、そういう趣味はないんだけど\nな……？　っあうっ！　んんっ、ん～っ、やめる気はない、みたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っあっ……！　ああっ、ああ、あっ！　あっ、あっ……！　ね、ねえ、この\n格好、本当に何もかも丸見えだし、お、オマンコ、とか……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おマンコにおチンポ入ってるのとか、な、中で動いてるのとか、全部……隠\nせてないし！　きょ、教育に良くないって……。っんん！　は、ぁ、う♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ほ……ほら！　何人か人が近づいてきてる！　……え？　人の気配がすると\n、私のおマンコが締まる？　そ、そんな……違う、……はぁっ、はぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「愛液の、音、響いて……それで人が不審がって集まってくるんだって？　わ\n、私のせい……？　あ、うっ、た、確かにおマンコはすごく濡れてるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポでっ、突き上げられて、掻き回されると……うううっ♪　雫がポタ\nポタ、地面に落ちるくらい濡れてる……。で、でも……恥ずかしいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「人に見られちゃうよ……！　っぁっ♪　見られるっ……ううっ♪　困る……\n、本気で下ろしてもらいたい、のに……そのはずなのに……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ズンッ、ズンッ、って突かれると……頭がボーッとし、て……あっあっあっ\n♪　いつもそんないやらしい腰の振り方、しない、のに……ふぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そんっなに外で、するとイイの……？　あぅっ、このグチュグチュって音…\n…私の音だけじゃない、絶対先走りの汁も混ざってるぅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ♪　うぁあっ、ああっ……あああっ！　な、中で、完全に勃起したおチ\nンポがおマンコをずりゅずりゅえぐってる……！　うううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「快感で気が遠く、なりそう……っ！　トんじゃうよ、これ以上されたらぁ…\n…！　あっあっあっあっ！　ヘンなところで度胸発揮しないでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んっ、んぅ、ね、ねえっ！　本当に人が、来てる……あっあっ！　っていう\nか見てる、よ……！　だめ……っ、らめ、らよ、不道徳すぎぃい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「え？　み、見せつけてるの？　……うぁあああっ♪　よくない、いけないこ\nと、なのにぃ……なんか身体が悦んじゃう……感じちゃうぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あッうぅっ♪　私なんか、どうせマゾだけどぉお……っ！　は、ハッピート\nリガーとして頑張ろうとしてりゅ、のに♪　台無しになっちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だめ……だめだ、よ！　このまま続けられたら……普通にイッちゃう、んぁ\nっ、そんなのだめ、下ろして……下ろし、てぇ……！　……んくぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「おチンポの上に、下ろすんじゃなくてぇ！　あっ！　地面っ、地面に下ろし\nっ……！　あ～っ♪　抵抗すればするほどおチンポ活発になって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わ、わかった……！　もうこうなったら、……あっ♪　イ、イカせるしかな\nい！　おチンポに射精して落ち着いてもらうしか……！　っんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「は、早くイッてぇ……！　精子出しちゃってよぉ！　っあああっ、でもっ、\nあんまり激しくしない、でぇっ♪　あっ、見られてるからあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っんんんっ……！　ますます私のおマンコのうねりが強く、なった？　あっ\n、い、言わないで、黙ってイッて……出して、お願い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「う！？　あっ♪　あうぅううっ♪　ふぅうううっ♪　んぅううっ！？　出、\nた……出てるぅっ、精液……どぴゅっどぴゅって爆発して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「い、いきなり襲って更に中出し、するなんて……あっ！　あっ、恥ずかしい\n、種付けされてるところ、みんなに、見られてるっ……うううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「よ、悦んでなんかいないよ……ぉ♪　だけど……妙に精液、おチンポに残っ\nても困るから……最後まで出していい、よ……もっとちょうだい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私のおマンコが、真っ白になるまで出して……！　っはぁううっ♪　す、す\nごい量……！　君も見られて興奮するタイプ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ♪　いつもより量……多いっ！　は、入りきらない……っ！　あっ♪　\n漏れちゃうよ……垂れるぅ……！　あっあっあっあっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はぁああっ、ふぅうう……♪　ふーっ、ふぅうう……♪　衆人環視の中、で\n……これだけ好き勝手できるのってす、ごい……お腹重たいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ね……ねえ？　これだけ大量に精液出したら、もう満足だよね……？　あっ\n、わ、私がまだイッてない？　イ……イッたよ？　軽く、だけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404202" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「い、いきなり襲って更に中出し、するなんて……あっ！　あっ、恥ずかしい\n、種付けされてるところ、みんなに、見られてるっ……うううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それじゃダメ……？　ふにゃふにゃにろれつが回らなくなるまで犯す？　…\n…わっ！　も、もしかして、まだ勃起、おさまってない感じ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っあ……ああ、あああ……！　わ……私も普段ならしたいと思う、けど……\n。ここ、本当に……外だし、まだ人がいるから……だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ッあっ！？　あっ！？　きゅ、急に腰の動きっ、再開しないれぇっ……！　\nど、どうしていつも心の準備ぃっ、さ、させてくれにゃいのぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っあ～～～～っ♪　ああっ、あっ！　あっあっあぁうううっ！　不幸ぅうう\nっ♪　不幸だぁああっ♪　なのに、……うくぅううっ♪　き、気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「精液出されたばっかりの、ほかほかおマンコ……っ！　ゴッチゴチの全然萎\nえないおチンポで突かれて、る！　こんなのどうかなっちゃう、よぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　は、恥ずかしい格好でおマンコ突かれてる私を……みんな\n見ないで……！　っあぅううっ！　本心を言え？　い、言ってるけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「み……見られて嬉しい、もっと見てくださいって言えって……？　ぅっ……\n♪　うううっ、そ、それはさすがに……！　んっ！？　あっぁっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404210" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「や、やめてよぉお……！　激しく突いて、い、言わせようとするのやめてぇ\nええっ♪　い、言う……言うからぁ！　あっあっ、深く突き上げ、ないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……そ、そうだよ……っ、私……すごく感じてる、身震いして、全身で悶え\nて、快感に打ちのめされるくらい……いい、ぐちゃぐちゃにされるの好き！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だ、から本当は嬉しがって、る……♪　おマンコもずぅっとヒクヒクしてて\n、君のおチンポ完全に受け入れて……離したくないって咥え、てるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あああ……そうなの、私っ……幸せ、目指してみても、やっぱり……っ！　\n犯されたり、不幸にされたりするのも好きぃ……だからもっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404214" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「もっ、と、激しく、して……厳しくして、無茶苦茶に犯して……！　あっ！\n　あっ、あっ！　不幸なところを見られるの……気持ちいいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「っんっはっ♪　はっ、あっ♪　んあああっ♪　ああっ……！　不幸気持ちい\nい……！　惨めになればなるほど、辱められると……感じるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ああ、んぁああっ！　太いおチンポで、ワケがわからなくなるくらい犯して\nぇ……！　あっ！　あっ！　情けない声で喘ぐ私を見てほしいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んんんッ♪　おね、がい……！　私の一番恥ずかしいところ、一番不幸で幸\nせなところに出して……！　精液欲しい、我慢できないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ッああっ……！　おマンコに力を入れろって……っ、こ、こんな状態で力な\nんか入らないぃ……♪　で、も、やらなきゃずっと犯されたまま……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「ふ、ンっ……！　こ、こう？　もっと？　んっ、ンンンッ♪　おチンポから\n精子、絞り上げるから……出して！　出し、てぇ……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「んひぃいいいっ♪　ひゅごっ……ひゅごしゅぎ……ぃっ！　凄すぎるよぉお\nおっ！　あっ！　膣内射精されながらみっともなくイクっ、イクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　んあああっ♪　赤ちゃんできるくらい、出てる、君の精液……あ\nあああっ！　さっきも同じところに出したのに、また出てるぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「いいよ、このまま妊娠させて……！　ううぅうっ♪　赤ちゃんできるの、幸\nせで、しゅごい……！　イクのが止まらない、あっぁっうっうっうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「わかるよ……私のおマンコの奥で、おチンポがビックンビックン脈打ってる\n……♪　あは、あはは、そんなに良かったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「公開種付けで興奮して、生イキしてる私と……大量射精してる君と……♪　\nあああっ♪　アブノーマルすぎて、すごい……こんなの初めてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「だから記念にっ、いっぱい出して……！　あ～～～～っ♪　見て、見てぇ、\n赤ちゃん受精するところ、みんな見てぇ……！　あっ、来るっ、来るぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はひぃいいい……♪　ひぃっ、んひぃいいい……♪　あ、頭がまだフワフワ\nする、混乱の極みだよ……♪　大事なものを失ってしまったような……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「アブナい快感を教えられてしまった、ような……？　はぁ、はぁ、はぁ……\n♪　絶対良くない、悪い快感を覚えてしまったのだけはわかるぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「って、わ、わああ……！　うっとりしている場合じゃ、ない……！　あ、あ\nのっ、これ……見世物じゃないからっ！　も、もう終わったから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……お、下ろして……！　れ……冷静になって考えてみると、衣装も汚され\nて、人前でエッチして……。わ、私、不幸に逆戻りかもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「はひィッ！？　あ、あれっ……！　おチンポがずるぅって抜けて……！　う\nぁっ、う、ウソ、かかってる……ヘンなところにかかってるよぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「あふっ！？　ひぅっ！　熱いっ……！　な、なんでぇ……！　膣内射精お願\nいしたのに、あんな恥ずかしいおねだりしたのにぃ……外ぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「外に出して、しかもぶっかけなんて……あうううっ！　おマンコに精液っ、\n注がれて幸せになるつもりだったのに……ひどいよぉ……あっ♪　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「トローって流れてる、垂れてくるぅ……！　も、もういいからぁ、そこに出\nしちゃだめ……！　あっ♪　おチンポ戻してよぉ、中に出してぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……うっ♪　こ、この衣装にかけたかったの？　それとも私を驚かせたくて\n……？　あっ！？　まだ出てる、びゅっびゅって……粘ってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001804_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「うっあっあっあっ♪　も、もうわけがわからないよぉ……。私を辱めて、恥\nずかしがらせて何が楽しいのぉお……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「う、うう……。どこもかしこも、精液まみれでヌトヌトに……。こんな姿じ\nゃどこにも帰れないよぉ……。臭いだって取れない……くさい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「こんなことするなんて、もしかして君……私のことを嫌いになったんじゃ…\n…？　え？　興奮しすぎて照準を誤った？　私が可愛かったから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「……う、嘘だぁ……。で、でも、万が一本当なんだったら、ガンマンの私が\n今度はちゃんと中でイケるように、照準を合わせてあげるよ……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「そ、そ、そんなことを呑気に話している場合じゃないっ！　は、早く下ろし\nて……！　せ、せめて裸だけでも隠させてよ、恥ずかしすぎるよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}