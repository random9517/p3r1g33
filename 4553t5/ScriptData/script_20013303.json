{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「う……ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270001" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「あれ……私は……確か流れ弾を受けて……そうだ、それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270002" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「傷がない……えっと……ていうことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「目が覚めたか、頼母木」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「あ、長官」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270004" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いい、いい。楽にしていろ。お前は撤退する敵の攻撃に巻き込まれた。それ\nは覚えているか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「え、ええ。でも怪我がないみたいですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270005" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな。制服に損傷はあったし、血痕もあったがお前の身体は無傷\nだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だれかが手当したのか……心当たりはあるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「ええ……えっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270006" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『できれば私のことはしばらく伏せていてくれるとありがたいです』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270007" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ど、どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「い、いえ。えっと……わからないです。攻撃を受けたあとは気絶していまし\nたので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270008" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだな……誰か、姿を隠した協力者がいるのか……？　だが、なんのため\nだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『なかなか勘が鋭いですね、この指揮官は』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあいい。初陣で見事に任務を果たしてくれた。よくやった。怪我はないよ\nうだが、しばらく休んでいてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私は事後処理にあたる。後でまた医務官をよこすから、それまでここにいる\nんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「はっ、ありがとうございます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270009" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「えっと……夢じゃないんですよね、これ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270010" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『ええ、現実ですよ。私はあなたの中にいます』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「ん……これからどうすれば？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『基本的には普段どおりに生活をしてもらって構いません』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『私はあなたのプライバシーは覗きませんし、望むならそれこそ普段は休眠の\nような状態になることもできます』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『そうすれば、戦闘の時以外は私はあなたに一切干渉できなくなります』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「私は……命の恩人にそんなことは言いません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270012" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『……優しい人ですね、あなたは。ただ、一つだけ』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『戦いに際して危険だと思ったら、あなたの了承を得ずに私が表に出ることが\nあります』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『それだけは認識しておいてください』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「わかりました……って、よく考えたら、普段の切り替えはどうすればいいん\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270013" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『ああ、これは説明を忘れていましたね。あなたが着けているその素敵なメガ\nネ、それに奇跡の星の力を付与しました』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『それがあなたと私をつなげるキーアイテムとなります』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「メガネ……って言われても、いつもと変わりないように思えるんですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『付与した以外は特にいじっていません』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『マミが不便になるでしょうし、そもそもそんな素敵なメガネに余分なものは\n付け加えられません』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「……なるほど、たしかに私たちの価値観は似ているかも知れませんね。この\nメガネ、店で熟慮して選んだデザインなんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270015" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『そうでしょうそうでしょう。コホン。ともあれ、私に切り替えたいときはそ\nのメガネに手を添えて、念じてください』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「念じる、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270016" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『ええ。なんでもいいですが、そうですね……私の名を、マムと』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『そう呼んでくれればなにかの事態で休眠していても必ず応えます』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「わかりました……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270017" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「この音は、警報音！！　あいつら、また攻めて来たの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270018" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『敵の襲来ですね。マミ、どうします？』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「どう……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『あくまで私はあなたの意思に従います。ここで身体を休めておくのも、戦い\nに赴くのも、あなた次第です』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「そんなの、決まっています。行きましょう、マム！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270020" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『了解っ！！』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くおおっ、なんだって今日はこいつら、こんなしつこいんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せっかく防衛戦を整えなおしたというのに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022270001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「先ほどよりも数が多いぞ！！　じわじわ食い破られている……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022270001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まずいな……相手に対して一手足りん……このままではジリ貧で撤退するし\nかなくなる……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうにかならないのかよ！？　援軍は来ないのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「要請はしている。だが、他の地点も襲撃されており、望みは薄い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうする、長官？　こちらの防衛戦はこれ以上下げられない。かといってこ\nのままでは押し込まれる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090022270002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきみたいに別働隊を組んで横から攻撃するとかはできないのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「先ほどの戦闘はまだこちらの数に余裕があった。今回は敵が増えてここを守\nるのが精一杯になっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270011" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「せめて、相手の気が一瞬でも削がれれば全軍で押し返せるんだが……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022270012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「……来たのはいいですが、かなりの劣勢ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270021" ]},
		{"command":[ "SETCHARA", "0", "char_00020501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『そのようですね。こういう言い方はよくありませんが、都合がいい』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「というと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『劣勢のときに颯爽と現れて味方する』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『それで勝利できれば、私……ひいては奇跡の星への印象はよいものになるで\nしょう？』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「そう言われれば、そうですね……ですが、危険な状況でもあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_205_010022270023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "『だからこそ、私がいるのです。早速ですが、私の出番です』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_010022270023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マミ" ]},
		{"command":[ "SETTEXT", "「お願いできますか、マム？」", "NORMAL" ]},
