{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おっと……へへ、主……お目覚めかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「何してるかって……んふふっ、そうだなぁ……まあ見ての通りってことで…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふふっ、夜這いだよ、よ、ば、い。ここのトコ、ずっと主にアタシのカラダ\n……じっくり開発されたじゃんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「当然、そいつが満タンになったら、するコトは一つって訳で……なぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「っとぉ……まあ、そう慌てない。ふふ……ほら、アタシも主に随分と焦らし\nプレイをさせられたしさ、その良さはよーく分かってるつもりなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「だから、それを主にもたーっぷりと味わって欲しくてさ。ふふっ、こうして\n……かる～く素股でチンポを刺激してやってるワケ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、ほら……マン汁がじゅるって溢れ始めてるの……分かるだろ……？　\nこの中にチンポがズッポリハマったら……最高だと思わないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おっとと、だからってすぐハメられる訳じゃないぜ？　主も、このもどかし\nい感じ……じっくり堪能したいだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あっ……ふっ……！　んんっ……このピクピク脈打ってるチンポと……アタ\nシのオマンコ……んくっ……こんなにくっついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへ……我慢出来ないって顔してるな。別にアタシも鬼じゃない、ちゃんと\nおねだり出来たら、ハメていいぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「そうそう……この勃起チンポを、ズッポリオマンコにハメさせて下さいって\nさ……ほら、どうするぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふふっ……言っちゃったなぁ。そうかそうか、主はアタシのオマンコにハメ\nたくて仕方なかったかぁ。さて、どうするかなぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「なんて……そんな心配そうな顔すんなって。元々アタシだって我慢なんか出\n来ないんだから……さっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁぁぁ……ほぉら……入ったぁ……んくぅぅ、これが主のチン\nポッ！　くぅんっ、ヤバい……いきなり奥までハマっちまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「どうだ？　もうジュクジュクのヌルヌルだろ？　おねだりさせといてなんだ\nけど、アタシも……全然我慢なんか無理だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「主がおねだりしてくれたから……やっと、オマンコ……いっぱいに出来たぁ\n……んくぅ……気持ち、いいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んふっ……けど、もちろんここからが本番だよな。はっ、んふっ……あぁ、\n主のチンポ……トロトロにさせてやるからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「うんっ、んっ、ふっ、あっ、おぉっ、んくっ、うんっ、はっ、おぉっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁっ、やっべぇ……めちゃくちゃ硬いのが……中で、擦れてくるぅ……あ\nぁ……チンポ熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「これを……もっと扱いてやらなきゃな……んくぅっ、あっ、おっ、ほっ、お\nぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「くぅんっ、あぁ……ひっ、んくうっ……これ……いいっ、ビクつくチンポっ\n……オマンコ突き上げてくるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んんっ、もっと締め付けてやらないと……はぁぁっ、アタシの方が、先に…\n…おかしくなるっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んふっ……突き上げたい？　まだ、もう少し待ってくれよ、主。しっかりご\n奉仕してみせるからさ……んっ、んふんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……主の目がギラギラしてるぞ……んっ、やっぱり揺れるオッパイに食\nいついて来るんだよな……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「まぁ、こうして……腰を振ってりゃ、自然に……あっ、おっ、跳ねちまうか\nらな……あっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシも……主に見られてるって思うと……はぁっ、中からジュンとして…\n…また、オマンコ……ヌルヌルになってくんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あぁっ、こーら、足をバタつかせない。射精まで、きっちり\n面倒見てやるんだから、少し恥ずかしい位のカッコは我慢だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふふっ、こんな風に足をおっ広げて、アタシにチンポを委ねて……ぱっくり\nオマンコに頂かれちまってる気持ちはどうだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……脈打ってるやんちゃなチンポ……すごく感じるっ……んんっ\n、ホントに腰……止まらないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おっ、あっ、うんっ……おぉっ、こ、このカッコで突き上げるのかっ？　分\nかった……んっ、いいよ……主も動いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んひぁっ！　あっ、くぅぅんっ、ヤバっ……主のチンポピストンっ……ズン\nズン響くうっ！　んぅっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいっ……アタシの腰振りとっ……一緒に合わせてっ、リズミカル\nにっ、おぅっ、おぉぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「な、中でチンポがっ、あぁっ、ビクビクって！　はぁっ、んんっ、これっ、\nもう……近いっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「出そうかっ……？　あぁっ……ならっ、このまま……全部中出しで頼むっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシもっ……主とイクからっ、んくぅっ、あぁっ、このチンポと一緒にっ\n、オマンコッ、思いっきりイクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁーっ！　来たっ、中出し来たぁっ……イクっ、おぉぉっ、オマ\nンコッ……ガチアクメするぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おほぉぉぉ……すごっ……んっ、あぉぉ……こんなにぃ……なるなんてぇ…\n…あ、はぁぁぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……いい中出しだったぁ……あぁ……まだオマンコがジンジンす\nる……やっぱり、変な道具より生チンポが一番だよな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「元気いっぱいの精子が、今……アタシの中で泳いでる……着床しちゃったら\n妊娠するかもな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んふぅ……どうだ、主もセックス堪能したか？　アタシのオマンコは主専用\nだからな、これからも遠慮なく使ってくれていいんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おっと、まだチンポを抜くのは早いよなぁ。オマンコの中で、ビクビクして\nるの……バレてるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「こうして……んんっ！　締め付けてやれば……ふふっ、疼くだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「一発出して、あったまったチンポ……改めて扱きまくってやるからな……ふ\nっ、んっ、んぅっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あぁ……一発出しても、全然萎えてないな……流石の絶倫\nチンポ……んぅっ、オマンコの中で大きいままだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「出された精液と……溢れるマン汁で……はぁっ、さっきよりいい音しちまっ\nてる……んくぅっ、はっ、あぁっ、ひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ほらっ、ぐちゅっ……ぐちゅって……なんて、やらしい音させてるんだよ…\n…主のドスケベ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「お互い様だって……？　あはっ、違いねぇな。でも、それも主が仕込んだせ\nいだぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシが主とじゃないとイケないのを知ってて、さんざんエロい開発させて\n……きっちり責任取ってもらうからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、もちろん……ちゃんと、気持ちよくさせてやるよ。このチンポ\nのカリと……アタシのＧスポット……くっつけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ、おぉぉぉっ！　そうっ、ぐりぐりっ……擦るっ……あひっ\n！　こ、ここぉっ、チンポ効くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁっ……んはっ、オマンコ痺れるっ……あぁっ、そこっ、もっと……続け\nてぇっ、おっ、ふぁっ、くぅんっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシばっかり楽しんでる？　そんなことないだろぉ、主ぃ……オマンコの\n中で、これだけチンポ跳ねさせといてさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「しっかりアタシの感じる場所……んっ、狙ってきてるじゃんか……はっ、ふ\nっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「主のチンポもビクビクして……また出そうになってる……でも、まだ少し気\nが早いぜ……よっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうだ？　こうして根っこを押さえてやれば……出したくても出せ\nなくなるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「この状態で……腰をゆっくり回してやれば……あははっ、チンポめっちゃビ\nクビクしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、ダメだぞぉ、ガマンガマン。ここでじっくり熟成して、気持\nちよく出したいだろぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んくっ、あっ、ふっ……それどころじゃないって顔だな……んんっ、それに\n……アタシのオマンコも……ヤバい……かもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「どうする……主？　んっ、また先走りの汁が滲んでるんだろ？　後もう少し\n……んっ、ふっ、はぁっ、おっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「さあ……そろそろ、だな……出したがりのチンポ……どうしたいんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「また中出ししたいって……？　なら……またおねだりだな♪　溜まったチン\nポミルクっ……アタシのオマンコにドピュドピュさせて下さいって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「言わなきゃ、この手は離さないぜ？　溜まり過ぎてチンポがどうにかなって\nも責任持てないぞぉ？　ほら、どうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あははっ、あっさり言っちまうんだな。いい大人がドピュドピュって……ふ\nふっ、いいよ、いい子で言えた主にはちゃんとご褒美を上げなきゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「さあ……これでもうイケるだろ？　後は思いっきり、チンポ出しちまえっ…\n…ほらっ、イケっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぁひぃぃぃぃぃんっ！　おぉぉぉっ、出たっ……チンポミルクッ、オマン\nコにビュクってぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104305" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おひっ！　イグッ、あらひもイグッ！　んひぃぃぃぃぃんっ！　オマンゴッ\n、いぐぅぅぅぅぅぅーーーーんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ、んっ、はぁぁ……あっ、ふっ、はぁっ……あぁっ、直接精液\n当たるの……ヤバ過ぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「せっかく、主のこと……よがらせてやったのにぃ……やっぱり、チンポに負\nけちまったぁ……あ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あ、ふ……あぁ……汁が漏れて来る……んんっ、どんだけ出すつもりなんだ\nよぉ……主ぃ……分かった、分かったからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「やっぱり、アタシは……主のチンポに絶対服従だ……これがなくちゃ……ダ\nメなんだぁ……あ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふふっ、アタシの身体にぶっ掛けたいのか？　なら、ちゃんとそう言わない\nとな。チンポミルクシャワー、ドピュッとさせて下さいってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ほら、黙ってちゃこのままだぜ？　それとも、主はこの生殺しが好きなドマ\nゾなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ははっ、ちゃんと言えるじゃねぇか。そうだよなぁ、射精したいのにプライ\nドもクソも何もないよなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「いいぜ……ほら、楽になったからもう出せるだろ？　さあ、遠慮しないでい\nやらしいシャワー浴びせてみせろっ、ほらっ、イケっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁぁんっ！　出たっ！　ビュクビュク出たぁっ！　チンポミル\nクシャワーっ……溢れてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104405" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　あらひもイクッ！　きもひいいのっ……おぉっ、オマンコイッ\nクぅぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……んんっ、カラダ中……ドロドロだぁ……主の匂いで全身マーキング\nされちまったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「せっかく、主のこと……よがらせてやったのにぃ……やっぱり、チンポに負\nけちまったぁ……あ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、まだビュクって出てる……さっきよりずっと多いじゃねぇか……分か\nった……降参だよ、降参するぅ……」", "NORMAL" ]},
