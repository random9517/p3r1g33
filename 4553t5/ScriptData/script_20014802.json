{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},	
		{"command":[ "SETTEXT", "俺は今回の件について、ほむらに相談した。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ったくあいつは、ヒーローショーのことをなんにもわかっちゃいねぇ！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いつも通り戦っていいからって、その通りにやるやつがいるか？　ちったぁ \nサービスしろっての」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「氷華はそういうことができないだろうって予感はあったけど、まさかここま \nでとは思わなかったな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、次までに、なにか手を考えないといけないんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いつだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「次の週末だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しかし、ショーを盛り上げるためにどうするか、ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_020023210001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「というか、台本に殺陣をすることを明記すればいいのでは？　多少は手加減 \nもしてくれるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_020023210002" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかもしれないが、今回のショーでは、手加減している様子を見せるわけ \nにもいかないんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうのは普通のヒーローショーで見飽きてる客を相手にしているからな \n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「本物のマスカレードが出演しているショーだしな。本物の戦い方を見せなき \nゃいけないってことかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なんだなんだぁ。長官である私をのぞいて作戦会議だなんて、さみしいじゃ \nないかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺のところに、すでに出来上がった状態の長官がやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げっ、長官！？　ていうか酒臭っ！　そのビール何杯目ですか！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「みっちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……５杯目だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私にいい考えがある！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まだなにも聞いてないだろうが！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まだってことは、これからひとり飲んでる私に相談する予定があったってこ \nとだなぁ、カツマく～ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、近い近い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "このまま酔っぱらいに絡まれたら、相談どころじゃなくなってしまうぞ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「長官、いい考えというのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_020023210003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやぁ、この酔っぱらいがロクなこと思いつくはずが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ショーを盛り上げるポイントが欲しいんだろぉ？　だったら、氷華を危機的 \nな状況に追い込めばいいじゃないかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……なるほど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_020023210004" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "思ったよりもまともな内容で、俺は少し拍子抜けしてしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あの氷華を、危機的な状況にねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「できるか……俺たちの戦力で……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しかし、俺とほむらは顔を見合わせた。長官のアイデアは採用したい。だがそ \nんなピンチを作り出すには、こちらにもブルーと同等の戦力が必要だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほむら……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「断る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210007" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まだなにも言ってねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「どうせ俺にステージを手伝えとか言いたかったんだろ？　あいにく予定があ \nるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イグニスは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「すみません、私もほむらと一緒に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_020023210005" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだよなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「人望がないなぁカツマくんはぁ。じゃ、長官が人脈みせちゃおうかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いったいなにを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それから、長官はどこかへ連絡を取り始めた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おーい、長官。来てやったぞー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「またお呼ばれするとは思いませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210001" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "よりにもよって、現れたのはオーヴァーハング四天王の奈羅苦とアルスラだっ \nた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00020001_01", "6", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、長官！？　なんでこいつらを……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「前に飲んでたらばったり会ってなぁ。こんなこともあろうかと連絡先を交換 \nしておいたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいのかよ、マスカレードの上官がその敵と飲み仲間になってて」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「この店は中立地帯ですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_020023210006" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「正義のヒーローがその敵とつるんでることは、いまさらつっこむことでもな \nいだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そう言われたら、そうかもしれないが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ブルーのことを知りたいなら適任じゃないか。マスカレードに詳しいのは、 \n私らをのぞいたら、敵だった彼女らだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「たしかにそうですね。マスカレードは宿敵でしたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210002" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ああ。ブルーとの因縁は、まだ片付いちゃいないがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210002" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「私だって。はぁ……愛しのブラックはどこに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210003" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まあまあ、駆けつけ三杯ってことで、飲みながらうちの隊長の相談を受けて \nやってくれないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210009" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ほむらたーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「その呼び方するなって。はぁ……。他の客もいるんだから、あんまり騒ぐん \nじゃねーぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いやぁ、さっすがマスカレードの宿敵！　いい飲みっぷりだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「いやぁ、それほどでもあるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210003" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ここのお酒が美味しいから、つい飲み過ぎてしまいますわ。あとは……ここ \nにブラックがいてくれれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210004" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「悪いね、元レッドで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020023210011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……それでだなぁ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "すっかり酔いのまわったふたりに、ヒーローショーとブルーのことを話した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「わかってねぇなぁ！　いいんだよ、雑魚なら一瞬で片付けるのがブルーだろ \nうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「それを活躍が見れないだの、一方的過ぎてつまらないだの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「お客様気取りも大概にしろってぇの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、相手は客なんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「い～な～。隊長よぉ～、お前の権限で次の公演にアタシを出演させてくれよ \n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210007" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ブルーとやりあえるんだろ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……そうだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "戦力のバランスをとるために、奈羅苦にも参加してもらうのはありかもしれな \nいが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はっきり答えろ！　アタシとブルーを戦わせろよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210009" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「こっちはイベントで登場して以来、まともにブルーと絡めなくてストレスが \n溜まってるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210010" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んぐっ！　わ、わかったわかった！　首っ、首が締まってる……やばい…… \n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「よーし、見たかアルスラぁ、アタシだって巧みな話術で交渉できんだぞぉ？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210011" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あれは……話術……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210005" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。ところで、なにか知らないのか？　ブルーの弱点とか。 \n宿敵なら相手の弱点を突いたこととかあるだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁ……あったかなぁ……？　アタシはいつも真っ向からブルーと戦ってた \nし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210012" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そうだったわねぇ……。あ、そうだ。弱点じゃなくても、隙をつくれればい \nいんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210006" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「隙？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そう、あの冷静なブルーも思わず動揺してしまうような……たとえば、恥ず \nかしい格好をさせるとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ブルーの……恥ずかしい格好……。見たい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210013" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「いかにブルーといえど、恥ずかしい格好をさせられて、平気なはずないわよ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210008" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかもしれないが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「なんだったら、私たちも恥ずかしい格好をしてあげてもいいわよ？　ヒーロ \nーものにはエッチな女幹部が定番だし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023210009" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そうだな。アタシはブルーと同じ条件で戦いたいし。恥ずかしい格好になっ \nてやってもいいぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210014" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふたりがそこまで言うなら、ブルーに恥ずかしい格好をさせるって作戦でい \nいんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_040023210012" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まあ、他に策はないか。酔っぱらい達からこれ以上いいアイデアを聞きだせそ \nうにないし。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んじゃ、俺はこれで……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「なに帰ろうとしてんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210015" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「アタシがみっちりブルー対策を教えてやるから。隊長、その場に残ってつき \nあいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023210016" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "正義から抜けだそうとした俺は奈羅苦にがっしりと肩をつかまれてしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},	
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そして店が閉まるまで、ブルー対策と称した奈羅苦の自慢話に付き合わされた \nのだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}