{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「待つのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850001" ]},
		{"command":[ "SETCHARA", "0", "char_00002003_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……王……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850001" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ピラミドンと言ったか。そいつを抱えていても、特にお主の足しになること\nはないぞ。返してもらえるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850002" ]},
		{"command":[ "SETCHARA", "0", "char_00002003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「王ノ命令デモ承服シカネマス。我ガ形状ヘノ疑念ハ晴ラシテオカナケレバナ\nリマセン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850002" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「やれやれ、口は災いの元とはよく言ったもんだね。それにしても……思った\n以上に細かい動きが出来るんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「確かに……動きが自在に変化して、中々読みきれないのである……中々捕ら\nえ切れないのであるっ……ふんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850003" ]},
		{"command":[ "SETCHARA", "0", "char_00002003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「恐レナガラ、私ノ動力機構ハ、王国内デモ最高ノ物ヲ備エテイマス。生半可\nナモノデ、遅レヲトル事ハアリエマセン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850003" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いいねぇ、いいねぇ。一度じっくり中を見せて欲しいトコだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……ッ！　拒否シマスッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850004" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぉわぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「変に刺激するのはやめるである、ドクター！　動きが一層鋭くなったのであ\nる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850004" ]},
		{"command":[ "SETCHARA", "0", "char_00002003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「おっとと……てことは、身の危険を感じると、性能が更にブーストされるの\nかな？　そいつも興味深いね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「警戒レベル上昇。防衛システム発動シマス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850005" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁー、何かバチバチ火花が飛んでますね。小競り合いかと思ったけど、結\n構本気でやりあってる感じっすねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「みんなの変身……カッコいい……ハルカプトラのは特に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850001" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あれは確か、アヌビス様のイメージなんですけど……自画自賛っすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「私のイメージなの？　じゃあ、私もやってみたら出来るかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850002" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「えぇ……どういう発想なんすか、それ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「えっと……アーマーンって確か、あの辺がああで……この辺がこういう感じ\nだったかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850003" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「な、何すか。あーしのカッコですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「んっと、大体こんな感じだったから……どういうといいのかな……モード・\nアーマーン……みたいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850004" ]},
		{"command":[ "SETCHARA", "0", "char_00008101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「えっと……出来ちゃった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850005" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そんな軽く変身しちゃうんすか……アヌビス様、ホント空気よめないっスね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「身体に色々くっついてる……いざって時に力が出せるようにしたんだっけ…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850006" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「や、疑問形で言われても……自分のコト、分かんないすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あんまり覚えてない……けど、何となく気持ちが大きくなった気がする……\n顔が隠れてるからかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850007" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「顔は隠れてますけど、身体の方はより全開って感じがするっすね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850007" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ……何だか……力が溜まってきた……結構、凄いの出ちゃいそう……撃っ\nていい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850008" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「え？　凄いのって……ちょ、あの、まさか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850008" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「モードアーマーン……エネルギーチャージ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021850009" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いや、ちょぉっ！　アヌビス様っ！？　ダメっす、ハルカさーん逃げてーっ\n！！　何かヤバいのそっち行くっすー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850009" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うん？　何かアーマーンが言ってるようであるが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850005" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「って、何か凄いエネルギー集まってない！？　アレが来るってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「高エネルギー反応確認！　強力ナ熱源ガコチラニ向カオウトシテイマス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850006" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ヤバいよっ、退避って……間に合わないっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「サイレーン、捕まるのである！　モードスフィンクスッ！　回避っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850006" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "7", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「熱源来るぅっ！　うわわわわわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850006" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご、ご主人～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「けほっ、けほけほっ、何か……ヤバい爆発起こったし……ハルカさんは……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850010" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我は大丈夫である。サイレーンも一緒である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021850007" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ハルカさん！　よかった……でも、隊長は……？　それに、ピラミドンの姿\nもない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021850011" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まさか、お二人揃って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021850002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「う……む……あ、あれ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……お怪我はありませんでしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850007" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……大丈夫みたいだ。えぇと……あんたは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「危険な目に遭わせて申し訳ありません。私はピラミドン、モードＤ（ドール\n）。貴方を衝撃から守るための変化形態です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっきのピラミッドの中が……こんな風に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「はい。緊急性を要する事態と判断し、より高度な行動が取れる状態に変形し\nました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「元はと言えば、私が取り乱したことにより招いた事態。改めて、貴方にはお\n詫びしなければいけません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「おぉぉぉっ、少女型多脚ロボへの変形キター！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850008" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なるほど、外装の奥にこの展開は当然アリですぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021850003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「アリもアリ、大アリでしょ！　いやー、昔の人も分かってるぅー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021850009" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「あれは……何を話されているのでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850011" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よく分からんが、とにかく譲れないこだわりがあるらしい。あぁ、だが、俺\nも一つお前さんに言っておくことがある」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「何でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021850012" ]},
		{"command":[ "WAITINPUT" ]},

