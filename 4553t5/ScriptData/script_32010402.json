		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ふふ……。どうだろうか？　このように、自分の身体を自分で縛り……っと\n、ますますプレゼントのようになっただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404102" ]},
