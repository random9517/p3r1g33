		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ。こうやって、身を捩らせて……ンッ、胸やふとももに、食い込むリ\nボンを見せてやれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404104" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「獣のような視線が、母の全身に突き刺さる……。母のオマンコに、そのチン\nポを挿れたくてたまらなそうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母も、息子の視線で身体が昂ってしまっている……。はやく……お前のチン\nポを挿れてほしいぞ……♥」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「息子の視線だけで、濡れてしまっているこのオマンコ……。今宵はお前が好\nきなように犯していいのだから……♥」", "NORMAL" ]},
