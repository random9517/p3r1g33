		{"command":[ "SETIMAGE", "0", "still_00020104_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「勃起チンポが、イキマンコこすって、ガチガチの亀頭が子宮口を押し上げて\nくるぅっ！！　くひぃっ、いいっ、んひぃいい～～っ！！」", "NORMAL" ]},
