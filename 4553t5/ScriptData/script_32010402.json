		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こ、これは……。さっき激しく動いたから、リボンが絡まって……んんっ、\nほ、ほどけなくなって、しまっている……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「なあ、息子よ。母のリボンをほどいてくれないか？　このままでは、お前を\n抱きしめることができない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃんっ！？　ま、待て。急に奥まで突いたら、オマンコが\n、びっくりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「くひっ、いっ、んふぅうっ！！　お前、この状態の母に、さらにピストン…\n…おぉっ、おっ、んぉおおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そんなっ、んぉっ、おおっ！　また思いきり、ピストン……！　んぉおんっ\n！　イッたばかりの、マンコにぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「か、感じすぎるっ、おおっ、お前のチンポ、すごく感じるぅっ！　息子チン\nポっ、いいっ、よすぎるぅっ！！」", "NORMAL" ]},
