		{"command":[ "SETIMAGE", "0", "still_00020104_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の子宮も……お前の亀頭を迎えに行くように降りてしまっている……ンッ\n、お前のチンポと、子宮が……キスしているようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、チンポが暴れている……っ！　ピストン激しくなって、母のオマン\nコをめちゃくちゃにしている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいっ、いいぞ……。母も、感じている……。お前のチンポを、すごく感じ\nて……こ、腰が……動いてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……じっとしていられないのだ……。お前の情熱的なピストンが気持ち\nよすぎて、身体が反応してしまう……！」", "NORMAL" ]},
