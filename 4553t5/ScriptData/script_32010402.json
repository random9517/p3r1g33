		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こんな無防備な状態で、息子に身体を委ねるというのもたまにはいいだろう\n。お前もこの母の姿に興奮してくれているようだな」", "NORMAL" ]},
