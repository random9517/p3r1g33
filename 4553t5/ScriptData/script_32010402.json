		{"command":[ "SETIMAGE", "0", "still_00020104_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「また、オマンコが反応しまくるっ！　チンポをぎゅっと締めつけているのが\nわかるだろう、ああっ、母は気持ちいいんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぉっ、おほぉっ、身体が反応するぅっ！　チンポが出入りするたびに、ビ\nクビク跳ねてしまうぅっ！！」", "NORMAL" ]},
