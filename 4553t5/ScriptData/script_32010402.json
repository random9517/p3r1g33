		{"command":[ "SETIMAGE", "0", "still_00020104_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「愛液も溢れて止まらない……！　お前の腰がぶつかるたびに、ばちゅばちゅ\nといやらしい音を響かせてしまっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、そうだぞ。母のオマンコは愛液を溢れさせ、チンポを締めつけ、息子\nチンポを甘やかしてしまっているのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「だからもっと、もっと、母のオマンコに甘えていいのだぞ？　ああぁっ、そ\nう……そうやって、もっと激しく突いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、じゅぶじゅぶと音を立てながらのピストン……ッ！　たまら\nない……母も、とても感じてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「奥へっ、奥へ……っ！　母の子宮の中へ亀頭が入ってしまいそうだっ、ああ\nぁっ、子宮っ、揺さぶられている……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「このまま、イッてしまいそうか？　母のオマンコに中出ししてしまうか？　\nいいのだぞ、遠慮などするな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404129" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「今宵はお前が、好きにしていいのだから……。思いっきり射精しても、誰も\n咎めはしない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前とともに腰を振り、オマンコの中を蠢かせてやろう。母がお前の射精を\n手伝ってやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、こうすると、母のイイところにチンポが当たって、母も……イッ\nてしまいそうだ……！」", "NORMAL" ]},
