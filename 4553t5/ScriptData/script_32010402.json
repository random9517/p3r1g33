		{"command":[ "SETIMAGE", "0", "still_00020104_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ゆっくり、母のオマンコをぶっといチンポが押しひろげながらはいってくる\n……っ！　ああっ、なんて熱さ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前のチンポが、母のオマンコをいっぱいにしているのが、わかる……！　\n前より太くなったのではないか？　ふふっ、ここもまだ成長中か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母のオマンコは、どうだ？　そうだ、愛液でこれ以上ないほどに潤っている\nだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「奥まで入ったお前のたくましいチンポを、しっかりと締めつけ、そしてうね\nっているのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「この母のオマンコは、お前へのプレゼント……ごほうびなのだから。存分に\n堪能してくれ。母も、お前のことをいっぱい気持ちよくするぞ♥」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、さっそくピストン……ッ！　んぁっ、あっ、息子チンポが…\n…お、オマンコに……こすれる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404114" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「カリが、母の肉襞を……あっ、ああっ、ごりごりと、削るように……んっ、\nあぁあっ、どんどん激しく……なるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、母のオマンコ、気持ちいいか？　ンッ、腰が止まらなくなっている\nようだな……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そのように、悦んでもらえると……母も、あんっ、嬉しいぞ……。ああっ、\n母の身体も……熱くなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁっ、んくっ、んふぅっ、息子チンポ、奥に……くる……っ！　んぁっ\n、オマンコの奥に……ゴツゴツ当たる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0404118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
