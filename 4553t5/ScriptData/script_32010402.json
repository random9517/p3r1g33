		{"command":[ "SETIMAGE", "0", "still_00020104_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……っ！　あっ、ああ……っ、あはぁあああぁぁぁ～～っ！　\nき……きた……息子チンポ……きたぁ……っ！」", "NORMAL" ]},
