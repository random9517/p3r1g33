		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「くうっ……んんっ、わ、私か……？　それは……あっ、んくぅっ……もう、 \n分かっているだろう……私も……またイキそうになっているっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あぁっ、もう誰かに見せてしまっても構わないっ……このま \nま最後までイカせて……お前も……イッてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁっ、激しいっ……！　チンポが……オマンコっ……グリグリ擦ってぇっ \n……んぁっ、あひぁぁっ、も、もうっ……ダメだっ……！」", "NORMAL" ]},
