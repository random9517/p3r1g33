		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぉっ……子宮が熱い……ザーメンでいっぱいにさせられて……も \nう、何も考えられない……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁ、はふ……んんっ、出し切ったのか……あぁ……これは、本当に受精し \nてしまったかも知れないな……んっ、ふっ……」", "NORMAL" ]},
