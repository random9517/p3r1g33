		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、い、イヤじゃない……むしろ、もっとして欲しいくらいだ…… \n私のオマンコを……グッと……突きこんで欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104111" ]},
