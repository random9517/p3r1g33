		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……そう、だな……愛されているという……実感がある……あ \nふっ、本気チンポが気持ちいい……」", "NORMAL" ]},
