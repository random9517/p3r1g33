		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「大丈夫だ……続けてくれ。んっ、もっとオマンコかき回してくれ……あっ、 \nあぁんっ！　そうだっ、あっ、チンポっ……またいいっ！」", "NORMAL" ]},
