		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、もう……淫乱でもいいっ、お前のメスとして……あぁっ、も \nっと……オマンコ可愛がってくれっ……あぁぉっ、そこぉっ！」", "NORMAL" ]},
