		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、分かっている……下手な遠慮などせず、さっきの分に上乗せしてくれ \n……お前の精液はどれだけあっても嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁぅっ……！　んっ、あぁ……まだ腰を振って……射精しながらチンポを \n出し入れするなんてぇ……」", "NORMAL" ]},
