		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あっ、あぁっ……今日は、最初から……すごいな……んっ、 \nまるで獣みたいに……貪ってくるじゃないか……」", "NORMAL" ]},
