		{"command":[ "SETIMAGE", "0", "still_00028401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「オマンコがジンジン痺れている……ふわふわ、気持ちいい感覚が全身を支配 \nして……頭がぼやけてしまってる……」", "NORMAL" ]},
