		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、こんなにも甘えたがりだったか……？　本当に私がいないとダメなや \nつになってないだろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そ、そうだな……少し休憩してからなら……も、もう一回くらいは……して \nも、いいぞ……」", "NORMAL" ]},
