		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「そうか……もう、お前の好きなようにすればいい……その代わり、残さず全 \n部出すんだ……分かっているな……？」", "NORMAL" ]},
