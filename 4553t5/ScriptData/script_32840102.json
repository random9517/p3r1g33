		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁぁ……う、うぅ……イッた……あっという間にイカされてしまっ \nた……」", "NORMAL" ]},
