		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はふ……全く、ここまで貪り尽くされるとは思わなかったぞ……お前の欲望 \nを全部受け止めるというのは大変なことなんだな……」", "NORMAL" ]},
