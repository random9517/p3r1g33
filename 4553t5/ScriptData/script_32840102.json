		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「とは言え、こんな窓越しに……外から全部見える状態でするのは……色々、 \nまずいだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104103" ]},
