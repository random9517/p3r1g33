		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あふっ、そうだ……んんっ、チンポから出ている分を、しっかりお腹にも塗 \nりつけろ……徹底的にやってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぁ……チンポが擦れている……お腹のところで……あぁ……そこをくすぐ \nられると、ぞわりとした気分になってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……全部……出し切ったのか……？　射精……もう、収まったと \nいうことでいいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104406" ]},
