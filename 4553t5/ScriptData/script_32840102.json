		{"command":[ "SETIMAGE", "0", "still_00028401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あぁんっ、締め付けが……よくなったなんて……ち、違う…… \n別に、わざとしてる訳じゃないんだ……これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「恥ずかしいことをさせるとオマンコがヒクつくなんて……そんなことは…… \nあ、あぁっ、ダメだ……勝手にしてしまうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、あぁ……今日は、本当に激しい……んっ、あぁ……チンポ… \n…長くて……オマンコ、入り切らない……あふ、んくんっ！」", "NORMAL" ]},
