		{"command":[ "PLAYVOICE", "v2_284_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、はぁぁっ、大きな身体に抑え込まれて……メスの本能が……疼 \nいてしまう……はっ、ふっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「こんなこと……お前だから許すんだぞ……？　あっ、ふっ、他の奴らになど \n絶対にさせないんだからな……わ、分かっているか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「私が弱みを見せるのも……お前だけだ……あぁっ、そ、そうだっ……こんな \n風にオマンコを許すのもお前だけなんだっ……はひっ！」", "NORMAL" ]},
