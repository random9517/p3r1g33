		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「わ、分かっている……お前は、まだイッてないんだからな……当然、こんな \nところで終わらせる訳にはいくまい。んっ……ふっっ……！」", "NORMAL" ]},
