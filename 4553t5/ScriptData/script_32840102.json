		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……！　奥がいっぱいになる……も、もうあれだけ種付けしたの \nに……まだ、出し足りなかったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104302" ]},
