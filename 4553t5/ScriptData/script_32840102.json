		{"command":[ "SETIMAGE", "0", "still_00028401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あひっ、はっ、ひっ……んんっ！　あぁっ、か、身体を支えるだけで精一杯 \nだ……し、しっかり捕まえていてくれ……はっ、ひっ！」", "NORMAL" ]},
