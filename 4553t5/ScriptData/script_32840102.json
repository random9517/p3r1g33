		{"command":[ "SETTEXT", "「私のオ、オマンコがよすぎるから……もっとしたい……うぅっ、そんなにも \n直球で言われたら……拒める筈がないだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「私も、お前のチンポがもっと欲しい……私がお前のメスだということを、オ \nマンコに染み込ませて……もっとチンポで分からせて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あぉっ、ほぉぉぉぅっ……！　くぅっ……また、太いチンポっ……擦れて来 \nるっ……あっ、おおぉっ、おっ、ふっ……！」", "NORMAL" ]},
