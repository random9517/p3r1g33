		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ど、どうしたんだ……また種付けするんじゃ……私を……白く染め上げたか \nった……そ、それは……」", "NORMAL" ]},
