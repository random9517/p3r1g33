		{"command":[ "SETIMAGE", "0", "still_00028401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、あぁっ……すごい……は、ふぁっ、オマンコ……すごいっ… \n…あぁ、チンポが……激しすぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、ヒクヒク蠢くのが……止まらないんだ……んっ、お前に…… \n身体……全体を支配されている感じがするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ、んんっ……！　し、して欲しい……あぁ、このまま、もっとチ \nンポ……激しくしてぇ……イカせて欲しい……」", "NORMAL" ]},
