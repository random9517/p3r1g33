		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ところで……いつまでくっついたままでいるんだ？　流石に、もう３回目な \nんて言い出さないだろうな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「もう少し、こうしていたい……？　む……ま、まぁ、私としてもダメだとい \nう気はないが……分かった、分かった……後少しだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_0104308" ]},
