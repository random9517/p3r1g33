		{"command":[ "SETIMAGE", "0", "still_00028401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「イクッ……またイクぅっ！　出してっ……射精してっ……立ちバックのまま \nっ、全部……出し切ってくれぇぇぇっ！」", "NORMAL" ]},
