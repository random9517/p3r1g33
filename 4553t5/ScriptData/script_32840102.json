		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はひっ、ダメだっ……こんなすごいのっ、耐えられるわけっ、あっ、イクっ \n……はぁんっ、も、もうイカされっ、るぅんっ！」", "NORMAL" ]},
