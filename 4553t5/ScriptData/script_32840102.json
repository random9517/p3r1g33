		{"command":[ "PLAYVOICE", "v2_284_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00028401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
