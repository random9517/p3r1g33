		{"command":[ "PLAYVOICE", "v2_284_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、あぁっ……硬い……はぁぅ……私の粘膜が……いっぱいかき回 \nされていく……ズンズン……響いてくるぅ……」", "NORMAL" ]},
