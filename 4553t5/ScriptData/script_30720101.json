{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_01" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "072_0103101" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……貴方！　これはどういうことなの……っ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103102" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「お仕置き……とはなんです？　そんなことをされるような失態……この私が\n犯すとお思いなの？　まずは拘束を解きなさい、苦しいの、すごく！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103103" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「こんな殺風景な場所に磔（はりつけ）にして……怖がらせようとでもいうの\n？　愚かね……私は脅しには屈しないわ。私はミス・パープル……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103104" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いえ、あの崇高なるクリスタル・コンツェルンの技術主任……パープル・ハ\nンプシャーですのよ？　……はぁ？　何です？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103105" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「私は何もしなくていい……？　チンポをサポートしてくれれば……って、き\nゃああっ！　おやめなさい、やめなさいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103106" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「そんな醜いものを私の顔に近づけないで……！　あっ！　やめっ……やめて\nっ、肉棒で顔をぺちぺちするのはやめて……いやああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103107" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「汚いでしょう！？　それに……うっ、く、臭い……ひどい臭い……貴方っ、\nきちんと毎日洗っているの！？　生臭いのよっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103108" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「……あっ！　あっ、いやっ！　いやっ……私の美貌を、男根なんかではたい\nたりして……信じられないっ！　止めて！　止めて……ぇえっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103109" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「……へ？　『やめてほしければやめてやる』……？　よ、よかった……なら\n今すぐやめなさい。なんですって？『やめるかわりに』……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103110" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ペニスを私の口に入れて、喉を勝手に使う……？　そ、そんな……そんな…\n…っ、こんな体勢でそんなことされたら、息が……もごっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103111" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「んーっ！？　んんんーっ！　んむーっ！！　んーーーーッ！！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103112" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「んむぐっ！？　んむーーっ！　んッ……んっぐっ、んっ……！　や、やめ…\n…やめれ……んんんんー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103113" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ぐっちゅっ！　ぐちゅっ！　ぐっぷっ……ぐっぷっぐっぷっぐちゅっ！　ぐ\nちゅっ！　ぐっちゅっ……！　おえっ……！　ぐっちゅっぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103114" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「や、やら……やらぁ、やめなひゃ……ぐっちゅっ！　ぐちゅっ！　こ、こん\nなことひて……後でどうなりゅか……んんー！　ぐっちゅっぐちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103115" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「あぐっ……んんぶっ……どうひて……どうひてこんなころ、わ、わたくひに\n……！　んーっ……んんんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103116" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ！　ぐちゅっ、ぐっちゅっぐちゅっ……ぐっぷっ！　ぐちゅっ……\nぐちゅっぐっちゅっぐちゅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103117" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「も、もうそんなに奥に入りゃにゃ……い、嫌……！　んぢゅぷっ！　ぢゅっ\nぷっ！　ぢゅぷっ！　ぢゅぷっ！　げほっ、けほっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103118" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「こ、これ……イラマチオ……、わらくひ……イラマチオ、しゃれて……んぐ\nっ……！　ぢゅるっ……ぢゅるるっ！　ぢゅぽっ！　ぢゅっぽっぢゅぽ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103119" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「あぐ、んぐ……喉につかえて……ぐちゅっ！　く、くるひ……い、大きすぎ\n……っ！　ぢゅぷっ！　ぢゅっぷっ！　ぢゅぷっ！　ぢゅっぷっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103120" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「んーっ！　ん゛ーっ！　んー！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103121" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ぐぷっ、ぐっぷっぐちゅっぐちゅっ！　ずりゅっ！！　ずっちゅっ、ずちゅ\nっぐちゅっ……！　えぅっ……！　んんぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103122" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「わたくひの高貴なおくひっ……お口っ、唇ごと……ぉっ、チンポに蹂躙しゃ\nれて……んんんむぅううっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103123" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「道具みひゃいに……使われひゃってる……犯されひゃってりゅぅうう……！\n　んぶっ！？　ぐちゅっ……ぐっちゅっ、ぐちゅ……やああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103124" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「抵抗ひたいのにぃ……逃げたい、のに……ぃ……動けにゃいぃい……！　や\nだ、や、やら……！　ぐちゅっ！　ずちゅっ！　ずっちゅっずちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103125" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「やらっ、やらぁあっ！　チンポやら、やら……やらぁああっ！　いらにゃい\n、にゅ、にゅいて……っ！　ずちゅっ！　ずっちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103126" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「おちんちん……おいひくないぃ、気持ちわりゅい……！　あ、ぅ、ううう…\n…っ！　ぐっちゅっ！　ぐちゅっ、ぐっちゅっぐちゅっ！　ぢゅるぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103127" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「……でも……っ、れも、コレをイかせにゃいと終わらない、なら……。いっ\nそこっちから舐めた方が……！　いや、嫌、だけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103128" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ！　ぢゅるるるっ……ぢゅるっ！　ちゅるるるっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_15" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103129" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「早く……ぅ、はやく、はや、きゅ……イッて……！　出ひて……出ひてぇえ\nえ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103130" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いっぱいぃ……いっぴゃい、舐めりゅから……吸って、舌でレロレロすりゅ\nから……っ、早くイッて……出して……出してぇええ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103131" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ぢゅぽっ……ぢゅろっ！　ずろろろろっ……ずろろろっ！　ぢゅぷっ！　ぢ\nゅぷっ、じゅっぷっ、ぢゅるるるっ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103132" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「頑張っれ……頑張っれ舐めて、りゅのに……その上喉にチンポ……チンポど\nちゅどちゅ突っ込んでくりゅぅ……！　んんんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103133" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「最低……さいていぃ……！　でも、負けな……んんんっ！　ぢゅるるるるっ\n、ぢゅりゅりゅりゅりゅっ……！　ぐっぽっ！　ぐぽっ、ぐっぽっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103134" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「おえっ！　ぐちゅっ！　ぐちゅっ！　ぐちゅっぐっちゅっ！　あっ！　出り\nゅっ？　出まひゅの？　んーっ！　ぢゅるるるるっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103135" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あ、あ、あ……もご……もぐ……んんんっ……んん゛……んむ\n……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103136" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「んーっ……！　んんんんんーっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_18" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103137" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「げほっ……！　げほっごほっ！　かっはッ……おえっ……おえええっ……！\n　あ、あは……あははは……精液、出た……出ましたわ……ごっほっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_21" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103138" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ん……？　『飲まないとお仕置きにならない』……ですって……？　だ、誰\nがこんなもの……ごほっ、飲み干すものですか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103139" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「用は済んだれひょう……！　わたくひをすぐに解放なひゃい……！　んっ！\n　……精液が喉に絡んで喋りにくい……っ！　んもうっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007201_01_19" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "072_0103140" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「とにかくっ……お仕置きとやらを受けてやったのですからっ……んぷ……っ\n、私は無罪ですわ！　帰らせていただきますっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
