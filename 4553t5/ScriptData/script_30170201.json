{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は、はい……そうです。男の人のオチンチンを見るのは、初めてじゃありま\nせん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「その……フェラチオをしたことも、あります……オチンチンを手でシゴきな\nがら、口で咥えこみました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「せ、精液を飲んだ経験ですか……！？　そ、それは、その……そういうこと\nも、しました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ううぅ……！　も、もう十分でしょう！？　これぐらいで許してください！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「もっと具体的に、フェラチオをした時のことを話せって……わ、わかりまし\nた……お話します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……あっ、あふっ……こうして触れるの、気持ちいいですか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「気持ちいいなら、よかったです……それと私、オチンチンを咥えるのは初め\nてで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「もっとこうして欲しいとか、いろいろ言ってくれたら……できる限り頑張り\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、はい……まずはオチンチンの先端を、舌でペロペロすればいいんですね\n……わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「痛かったりしたら、遠慮なく言ってくださいね……んっ、あむっ……ちゅ…\n…ちゅちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、れろっ……ぷちゅ、れろれろっ……んっ、じゅるっ、くぷっ……こ\nんにゃ感じれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は、はひっ……全体を舐めるようにしゅればいいんれふね……れろっ、ちゅ\nぷっ、くちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ……！　けほっ、けほっ……！　はぁ、はぁ……す、すみません\n……粘っこいお汁が喉に引っかかって……けほっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……舐めてたら、オチンチンの先端からドクドク出てきました…\n…これ、なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「我慢汁って言うんですね……舐めても問題ないなら、このまま舐めさせても\nらいます……んっ、ちゅっ……ちゅ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くぷっ、ちゅぷっ……ちゅ、ちゅるるっ……！　んっ、ずちゅ、れりゅ、れ\nりょっ……！　ずぷっ、ちゅ……ちゅぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んむっ、うむぅ……！　舐めりぇば舐めりゅほど……我慢汁がオチンチンか\nりゃ出てきまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ずっ、ずりゅるっ……ちゅ、じゅぞっ……！　んんっ……ちょっと、しょっ\nぱいです……んっ、ずちゅ、ちゅくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、ぐぷっ……ぷはっ……！　は、はい……先端だけじゃなくて、カリも\n舐めればいいんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと、カリっていうのは、この段になってるところですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わかりました……オチンチンの皮の隙間も、いっぱいペロペロします……ず\nちゅ、くじゅっ……ずぽっ、くちゅちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ぐっ、んむうぅ……！　カリのとこりょを舐めたりゃ……オチンチンがビク\nビク跳ねて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そんなに動かしゃれりゅと……オチンチン、舐めにくくなっちゃいまふっ…\n…くぽっ、ちゅ、ぐぽっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ふぇ……？　オチンチンしゃぶりながら……手も動かすんれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203124" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「オチンチンをシコシコしながら……ペロペロして……んっ、ちゅ……！　ち\nゅぷ、くちゅ……じゅぞっ、じゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、うぐうぅ……！　シコシコすりゅと、我慢汁がもっと出てきまひたっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「じゅちゅ……くちゅ、くぽっ……！　ずじゅじゅっ……ぐっ、うぐっ、くり\nゅ、ぢゅぱぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あぐうぅ……！　ぷはっ……！　はぁ、ああっ……私の唾液と我慢汁のニオ\nイで……頭がクラクラします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「とってもクサイんですけど、クセになるというか……オマンコが疼いちゃう\nニオイです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「これに精液が混じったら、どんなニオイになるんでしょうか……んぅ、ちゅ\nぷっ……！　ぐちゅ、ずちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ぐちゅ……ちゅ、れろれろっ……！　ぐぷっ、ずゅぽっ、くじゅ\nっ……！　あぐっ、んっ、んぐむぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、、あんんっ……！　い、イキそうなんれふか……！？　でひたら、も\nっと強くペロペロしまふね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ちゅぷっ……！　ずぷっ、ぐぽっ、ぐちゅるっ……！　ちゅ、ちゅ\nぴっ、ぺろっ、くちゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、ぐっ……！　はひっ……出してくらはいっ……！　私の口に……いっ\nぱい、精液らしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、ずりゅ……！　ちゅ、ちゅちゅっ……！　んっ、くぷっ……ちゅ\nぱっ、ちゅ……！　くぷっ、んぐっ、あむううぅぅぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！？　ぐううぅぅぅ～～～～～……っ！？　あっ、熱いの\n出てまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「オチンチンが跳ねながりゃ……口の中に、びゅるびゅる出て……！　ぐぶっ\n、んむっ、じゅるるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ぐっ……！　あぐっ……！　せ、精液を飲めばいいんれふね……！？　ぐっ\n、ぢゅるっ……ごくっ、こくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「うぐっ……あぶっ、じゅぱっ……！　んぐっ、んぐっ……！　我慢汁より、\n喉に絡んでくりゅっ……ごくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「うううぅ……それに苦くて、クサくてっ……！　あひっ、ぢゅぶっ……！　\n本当にクセになっちゃいまふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……はぁ、ああっ……ちゅ、くぽっ……！　はぁ、はぁ……いっぱ\nい出ましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「私の口の中……精液でいっぱいです……あんなに飲み込んだのに、まだ残っ\nてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、ごくっ……こくんっ……！　はああぁ……精液って、苦いんですね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっ……？　もっと出したいんですか……？　はい。大丈夫です……頑張っ\nておしゃぶりします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ですから、また好きなだけ出してください……んっ、ちゅ……ちゅぢゅ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ずちゅ、ちゅるるっ……！　ぐぽっ、ちゅぱっ、じゅじゅっ……！　ぐっ、\nぴちゃ、くちゅ……ちゅぱっ、ずにゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「うぐっ、あぐっ……！　オチンチンから、また我慢汁が溢りぇてきれまふ…\n…！　ちゅ、ちゅるっ……ずぷっ、くちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと……今度はオチンチンを舐めりゅだけりゃなくて、吸えばいいんれふ\nね……ずっ、じゅぞぞっ……ちゅ、ずちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ずちゅ、じゅぞっ、ぢゅるるっ……！　んっ、んんっ……！　我慢汁だけり\nゃなくて、精液の残りが……また口の中に……んぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こくっ……んっ、んぐっ……！　ごくんっ……！　ううぅ……吸えば吸うほ\nど、オチンチンからエッチなお汁が出てきまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅぱっ……！　ちゅ、ちゅうぅ……！　ぐぷっ、ずぞぞっ……\n！　ぴちゃ、ぷちゅ……くちゅ、れりゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んむっ、あむうぅ……！　ぷはっ……！　はぁ、あはぁ……！　もっと奥ま\nで咥えて、ペロペロ、シコシコしないと……んふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ちゅぽぽっ……！　ずちゅ、れろっ……！　咥えるだけりゃなく\nて、カリや皮も舐めて……んっ、ちゅぱっ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅ、んちゅっ……！　じゅるっ、ぐむっ、ぢゅくちゅ……！　ちゅぱっ、\nちゅぴっ……！　んぷっ、れりゅりゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……！　んっ、あはぁぁぁ……！　精液と我慢汁にょ混ざったニ\nオイ……たまりましぇんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「口でオチンチンを感じてりゅのにっ……鼻の奥も、オチンチンでいっぱいに\nなってりゅみたいでふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「こんにゃの……イッちゃいまふっ……！　オマンコの奥かりゃ、すごいのき\nちゃいまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅるるっ！　んっ、あふっ！？　またオチンチンがビクンって\n動ひて……！　イクんでしゅね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はひっ……！　私もイキまふから……！　一緒に、イッて……っ！　ぐちゅ\n、じゅるるっ！　ちゅぱっ、じゅぱっ、ぢちゅうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、ちゅぽっ！　れろれろっ、ぴちゅ、ぴちゅるっ！　出して、くら\nはいっ！　精液どぴゅどぴゅひてっ……！　ちゅ、じゅるうううぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ぐぶっ！？　んっ、んむううううぅぅぅ～～～～～！？　さ、さっきよりも\n量が……あぐっ、うぐっ！　じゅぷっ、ちゅぷうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅるるっ！　全部飲みましゅかりゃ……！　もっと精液らして\nくらはいっ……！　ちゅぱっ、じゅぞぞっ……ぐちゅ、ちゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んくっ、んぐっ……！　じゅるっ、ごくんっ……！　はぁ、はぁ……！　や\nっ、あぶっ……！？　熱いの、止まりませんっ……んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「じゅぞっ、ぢゅぷっ、くちゅるうぅ！　あっ、あんんっ！　こんにゃに出さ\nれたりゃ、またイッちゃいまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んぐっ……！　ちゅぱっ、ちゅぷっ……！　せ、精液飲みながら感じ\nて……！　ちゅ、じゅじゅっ！　イクっ……イクぅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちゅ……ちゅぱっ、じゅるっ……！　はあっ、はあぁぁぁ……本当に、たく\nさん出ましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ……オチンチンの奥に残ってりゅ精液も……吸い出しまふね\n……ちゅ、ちゅうううぅ……ぐちゅ、くりゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「れろっ……ちゅ、ずりゅるっ……ごくっ、んくっ……！　はぁ……あふっ…\n…オチンチンの中……綺麗にお掃除できまひた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっと……オチンチンの中だけじゃなくて、外も綺麗にして欲しいんれふか\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はい……わかりました……それでは、お掃除させていたらきます……んっ、\nちゅ……ぺろっ、ちゅぷ……ちゅ、ちゅぱっ……ちゅるうぅぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「んっ、あぶぅぅぅっ！？　お、オチンチンが抜けて……きゃあああああぁぁ\nぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「精液が飛び出てるっ……！　あぅぅぅ！　あっ、熱いのいっぱいかかってま\nすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「はあっ、ああっ、うぐっ……！　だ、ダメっ……！　おしゃぶりしてたとき\nより、精液のニオイ感じちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　はぁ、あああっ！　びゅるびゅる止まりませんっ……！　\n精液かけられるの、気持ちいいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「やっ、あああっ……！　イクッ！　精液びゅーびゅー出されながら、イッち\nゃいますうううぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「くっ……あっ、はああぁぁぁ……いろんなところが、精液でベトベトになっ\nちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「このままだと、ニオイが取れなくなりそうですね……それはさすがに困ると\nいうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ですが、マーキングされてるみたいで、ちょっと嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「えっ……発想が変態みたい……？　別に私は思ったことを言っただけです…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00001702_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それと変態なんかじゃありません！　私は、その……ちょっとエッチなこと\nに、興味があるだけですから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0203410" ]},
