{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "敵の警備兵を追い散らし、俺たちはついに――", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "DISPNAME", "TRUE" ]}, 
		{"command":[ "SETTEXT", "「よし、着いたぞ！　ここが工房だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ここを吹っ飛ばせばいいんだな？　よし、爆弾を――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「あらあら～？　ダメよ、そんなおイタしちゃ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「え！？　な、なに？　この人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうやらあいつが、報告にあった別次元のダイヤナらしいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「ええ～？　そっちの子もダイヤナちゃんなの～？　あらあら、とってもかわ\nいい子じゃな～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110116080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あら～！　さっすがダイヤナちゃん！　ダイヤナちゃんの美しさがわかるの\nねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「ええ～、もう、とっても素敵～！　なんかもう、見てるだけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110116080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「バラバラにちぎってヒイヒイ泣かしてあげたくなる感じよねぇ～！　ゾクゾ\nクしてきちゃう～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110116080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひっ！？　ちょっとカツマちゃん！　あの人ヤバいわよ！　なんとかして！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なんとかするけどさぁ……お前も戦えよ。別次元のお前なんだから…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まあとにかく、あいつを片付けないと爆弾を仕掛けられないってことだね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふふふ……そのようなこと、我らが許すとでも思うておるのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おまえは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ここがお前たちの墓場となるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたたちはここで、宇宙の塵となりやがるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だーっ！　おまえらまで！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「そちらに勝ち目はありませんわ。おとなしく観念なさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190116080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0216" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "敵幹部たち" ]},
		{"command":[ "SETTEXT", "「ふふふふふふふふふふ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190116080002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「敵側のアナザー大集合、ってことですか。準備万端で待ち構えていたようで\nすね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116080001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待ち構えてた……？　ってことはまさか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「おバカの仕掛けた見え見えな罠に、思いっきり引っかかりました。ウチが賢\nすぎたのが敗因です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116080002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}