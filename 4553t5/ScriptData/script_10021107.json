		{"command":[ "SETCHARA", "0", "char_00001501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まあまあ、そう言わないで自己紹介ぐらいさせてよ。まず、こちらはセレー\nナくん。お察しの通り、キミらとは別の世界の……だけどね」", "NORMAL" ]},
