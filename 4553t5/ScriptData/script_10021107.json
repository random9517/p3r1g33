		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うっそだー！　あいつが私のアナザーなはずないじゃん！　私だったら、\nもっと賢そうな顔してるってー！」", "NORMAL" ]},
