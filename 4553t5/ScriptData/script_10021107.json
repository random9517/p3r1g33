		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おう！　あっちの筋肉バカっぽいほうか！　あいつがどうした？」", "NORMAL" ]},
