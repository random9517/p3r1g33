		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そしてボクはジェスタ。刻の女王陛下に仕える道化師さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114400007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
