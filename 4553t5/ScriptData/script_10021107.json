		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんにもわかってなかったのかい、あんたはーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114400003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あははははは！　面白い！　キミたち面白いなー！　ジェスタちゃん、本職\nの道化師なのに笑わされちゃったー！　だよねえ、カツマくん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114400002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っ！？　カツマを知ってるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんー？　あれ？　あれれれ？　そういえばカツマくんと他数名、姿が見え\nないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114400003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ、そうだったそうだった！　ボクが分断したんだったねー！　こりゃ\nまた失敬！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114400004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ジェスタ。つまらん芝居はやめろ。そんなことより、先にやることがあるは\nずだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
