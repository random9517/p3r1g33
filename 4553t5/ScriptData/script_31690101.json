		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「こっ……このまま、おっぱいに中出しっ！？　あぁっ、はいっ、もう……ど\nうにでもなさって下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
