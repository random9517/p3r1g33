		{"command":[ "PLAYVOICE", "v2_169_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ご主人のオチンポが、目の前でわたくしのおっぱいを犯して……あぁっ、こ\nれでは性処理の……道具のような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
