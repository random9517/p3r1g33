		{"command":[ "PLAYVOICE", "v2_169_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ん、ふっ……！　あぁ……終わりましたか……？　あぁ……乳首ぃ……こん\nなの初めてです……」", "NORMAL" ]},
