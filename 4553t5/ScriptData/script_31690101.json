		{"command":[ "SETIMAGE", "0", "still_00016901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ、勃起した乳首と擦り合わせてっ……んんっ、わたくしのお\nっぱいも感じさせて下さいませぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
