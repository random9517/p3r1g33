		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「パ、パイズリ？　それは、あの……はい……知識としては。胸で……男の方\nの、ペニスを……挟んで、気持ちよくなるよう扱くのですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「それは理解しましたが、どうしてわたくしは手の自由を奪われているのでし\nょうか……これでは、動かすことが出来ないと思うのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「え……？　あ……ご主人が……全部なさると……？　わたくしは……身を任\nせているだけで……それは、ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「い、いえっ、決して逆らうとかそのようなつもりはっ！　分かりました……\nそれでは、お、お願い……致します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んっ……ふぁっ……そんな、あっ、いきなり……ち、乳首はっ……あっ、ひ\nぁんっ！　いけませんっ、わ、わたくしのそこは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「だって……こんな、陥没したもの……ご不快ではありませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あひっ！　あっ、指ぃ……そこっ、あっ、擦られてぇっ……み、魅力的なん\nてっ……そんなことっ、だって……わたくしはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……！　こんな不格好なものっ……好きになんて……あっ、び\n、敏感なのはっ、か、関係なくてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あひっ！　あぁんっ、あぁっ……何で、先端が……ムズムズして……あぁっ\n、乳首が……出てきてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「こ、これで準備が……えっ……あっ、ご主人っ……は、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あぁっ……そんな……わたくしのおっぱいの中に……ご主人のペニスが……\nあぁ……凄い……」", "NORMAL" ]},
