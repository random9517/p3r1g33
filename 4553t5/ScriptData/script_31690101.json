		{"command":[ "PLAYVOICE", "v2_169_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「そう、ですか……良かった……ですが、今度は手を自由にして頂けると嬉し\nいです」", "NORMAL" ]},
