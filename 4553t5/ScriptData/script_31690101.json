		{"command":[ "PLAYVOICE", "v2_169_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ……これが……パイズリ……ご主人のペニスが、ビクビク脈打\nって……凄い……です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
