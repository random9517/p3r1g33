		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あっ……何をっ？　ま、また……顔にっ！？　あぁっ、は、はいっ……おっ\nぱい……お使い下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
