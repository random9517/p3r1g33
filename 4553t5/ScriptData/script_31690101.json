		{"command":[ "PLAYVOICE", "v2_169_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「んちゅぷ……んぁ……あぁ、全部出して下さい……ご主人の精液を……今だ\nけは、私が独り占め出来るなんて……んふぅ……」", "NORMAL" ]},
