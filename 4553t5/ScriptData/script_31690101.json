		{"command":[ "PLAYVOICE", "v2_169_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
