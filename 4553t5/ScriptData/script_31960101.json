{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ♪　いたいたぁ～！　探したよぉ？　おにーさん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんのことがぁ～。好きで好きでたまらないおにーさんのために、今\n日はイイものを持ってきてあげたよ？　こ・れ。なんだかわかる～？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ボニューデマクール、だって♪　すっごいフザけた名前だよねぇ。でも……\n効果はホンモノらしいよぉ？　試してみたいでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だって想像してみて？　アーちゃんのちっぱいから母乳がさ～？　ぴゅるぴ\nゅる出ちゃうんだよ？　見たいでしょ～？　……見たいって言え～！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えいっ……♪　これだけゆーわくしてもわかんないダメダメおにーさんには\n……アーちゃんが直接教えてあげる♪　感謝してよねぇ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019601_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぷぷぷっ♪　な～に～？　あたしの裸見てきんちょーしてるんだぁ？　どー\nして？　ねぇねぇ、ど～して～？　ぷぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「力比べしたら絶対勝てちゃうちびっこの、ちっちゃなおててとおっぱい見な\nがら興奮してるんだ？　やっぱりおにーさんって……変態♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んん？　べっつにぃ、ヘンタイだからって嫌いじゃないよ？　嫌いなら\nこんなことしないし……。って、きゃ～！　やだ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おちんちんがピクピクしてきたんですけどぉ！　え？　え？　これって勃起\n？　ボッキしちゃってるの？　か～わいい～♪　触っちゃえ～♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えいっ……えい、えい……あはははっ。どんどん硬くなってくる～。がっち\nがちのビッキビキ♪　やっぱりちっちゃなおっぱいが好きなんだ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それなら～……見てるだけじゃ満足できないでしょ？　ト・ク・ベ・ツに今\n日はアーちゃんの女神おっぱいをちゅーちゅー吸わせてあげるね……ほら」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ちゅーちゅー♪　ちゅーちゅー♪　んふふふっ、くすぐったぁい♪　ほーら\n変態おにーさん♪　おっぱいちゅーちゅー♪　ちゅーちゅー頑張って♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっ……違うってぇ。もっと強く吸うの！　ぢゅうううって、ホンキで赤ち\nゃんになったつもりで……。はぁ、はぁ、そう……そう、そのまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぅっ……♪　ねっ……？　ぼにゅー……。甘くて美味しい母乳が染み出し\nてきたでしょお？　おいちいよねぇ、トロトロしてていいにおい♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ♪　あたしの母乳が飲めるひとなんて、おにーさんくらい\nなんだから……感謝して吸ってよね？　もっと♪　もっとペロペロして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……っふぅうっ……♪　すっごい……。これ、本当にぴゅッ、ぴゅって出て\nるぅう……。コレ……おにーさんに飲まれちゃってると思うと……。ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なんか、ヘンな感じ……♪　あっ……。こらぁ、エッチな感じで吸うなぁ…\n…っ！　はぁっ……あっ……。ぁっ……ンン……♪　んぅうう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「な……なんっか恥ずかしくなってきた……！　こっちだけ舐められてるとか\nありえない……。あたしもおにーさんのことイジめちゃうんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふふふっ♪　おちんちん、すっごいね？　ビ～ンって勃ってて怖いくらい\n……。これ……アーちゃんに楽にしてほしーよね？　んぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おちんちんの先っちょ～♪　亀頭？　ここをおててでぐりぐりしたげる～♪\n　あんっ、思ってたよりプニプニでなんか気持ち悪い♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でも……指が離せない……。すっごく気になる感触ぅ……。んっ……んっ…\n…！　お、おにーさんのくせにかっこいいおちんちんでナマイキ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほぉら！　気持ちよくても口止めないで！　おにーさんは母乳をぺろぺろし\nて……。あっ♪　アーちゃんはおちんちんをいじる、の……ぉっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふ……♪　ふふふ……。おっぱいチュパチュパしながら、モロ出しのおち\nんぽいじいじされてるおにーさんって、なんか赤ちゃんみた～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「かんっぜんに～♪　あたしの手のうちって感じ～。おっもしろ～い♪　ど～\nお～？　ちびっこに手のひらで転がされてるき・ぶ・ん・は～♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あれ～？　お返事が聞こえないな～？　それじゃ、もーっともっとおちんち\nんをイジメて教えてあげなきゃかな～？　さーて、どこから攻めよっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「やっぱりここかな～？　おちんちん本体……肉竿？　っていうんだっけ？　\nここをさわさわ、ぐにぐにされると感じちゃう？　教えてよぉ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「強めにギュッて握るのがいいわけ～？　あっ♪　へ～、上下にこすられると\nいいんだぁ？　おにーさんのくせに、おちんちんはおっきくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんの手じゃあ一度に全部握れないんですけど？　反省して？　……\nうん♪　反省するならいっぱいしごいてあげる……。こう？　こう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ん～……それともこっち？　タマタマ……♪　あははっ、ぷにゃぷにゃして\nてヘンな感触ぅ～。何これ～、ぴとぴと汗でくっついてくる～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ここでぇ……せーしを作ってるんでしょ～？　せ・ぇ・し♪　おちんぽミル\nク♪　ザーメン♪　いいな～？　見たいな～。見せてよ～、見た～い！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「む……！　あたしの手とおっぱいじゃしゃせー出来ないっていうわけぇ？　\nばーかばーか、おにーさんのばぁ～か。そんなこと言ったら逆効果だし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぜーったいしゃせーさせてやるって思っちゃった♪　ね～ね～いいでしょ～\n？　情けない顔で、なさけな～い声出してしゃせーするとこ見せてよぉ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほらぁ、ぴゅっぴゅっ♪　じょーずに出来るかな～？　ぴゅっぴゅっ……。\nぜぇんぶ見ててあげるから解放しちゃえ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おっぱい飲みながら、ぴゅーぴゅー出来たら褒めてあげてもいーよ？　よち\nよちよち、おにーさんえら～いって……だから出して？　３、２、１……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぜ～ろっ♪　あはぁっ♪　えっ？　本気～？　本気でしゃせーしちゃってる\nの～？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはっ、すっごいヤバ～い♪　えっ？　えっえっ？　ありえない量が出てる\nよ？　おにーさんのおちんちん壊れちゃったんじゃない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「わっ……あっ♪　ありえない……っ♪　アーちゃんの母乳なんて目じゃない\nくらいせーえきビュルビュルだし……変態♪　へーんたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほんっとおにーさんって面白い♪　……あーあ♪　アーちゃんのかわいいお\nててがせーえきでベタベタになっちゃった～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっつくてヌルヌルしてて全然とれないし……。ふぅ～ん♪　こんなにたっ\nくさん出ちゃうんだ～♪　赤ちゃん作りたくって必死じゃん、可愛い～♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「で、も～♪　いくらおててにピュッピュしても赤ちゃんなんかできませーん\n♪　残念でした～。大事な大事な精子が無駄になっちゃったね～。悔しい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「悔しくてもやめてなんてあげないよ～。だって、アーちゃん……。おにーさ\nんの情けない射精を見てたらワクワクしてきちゃったんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「何回も射精するとこ見てみた～い♪　おにーさんもさぁ？　もう一度気持ち\nよくなってぴゅーしたいなら、もっとちゃんとおっぱい吸ってね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そしたら女の子みたいにイかせてあげる……。潮吹きみたいにびゅーってせ\nーし出るようにしてあげる♪　びゅーっびゅーって……うぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんの女王様はアーちゃんなの♪　女王様の命令は～♪　ぜった～い\n♪　早く母乳をぺろぺろして！　夢中で吸って！　味わって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぁっ……ふぅうっ♪　そ、そう……。今の、ちょっとよかったから……そ\nのまま……。んぁっ♪　はぁっ……そう、ベロでおっきく舐めて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁあっ……♪　はぁうう……！　い、いい感じ……っ。み……認めてあげ\nてもいーかも……。あんっ♪　そう、乳首転がして……吸って……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お、おにーさん、やれば出来る子じゃん……！　あっ♪　あっぁっ、ちくび\nっ……乳首甘噛みはちょっとズルい♪　はぁ、はぁ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あふんっ♪　ンンッ……♪　こ……こらぁ♪　おにーさんのお口……なんか\n生意気！　それなら……こっちも本気出しちゃうから……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んぅうっ♪　母乳をぷしゅ、ぷちゅ、って出しながら……っ。うう♪　\nおててで……おててでおちんちんをいじりまくって……。はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぜったい、ぜったい負けないっ……。アーちゃんは勝つ、もん……！　じゃ\nないとおにーさん、アーちゃんに見向きもしてくれなくなる、から……ぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だから早くアーちゃんのエッチさにメロメロになっちゃえぇ……！　他の子\nなんて見られなくなるくらいおちんぽ夢中にさせたげるんだからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっ……ん……。ね～え……？　アーちゃんのおっぱいミルク、おいし～い\n？　母乳ってぇ、男の人が飲むと幸せになるんでしょお……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぷぷぷ……♪　アーちゃんのぉ、ロリロリミルクをちゅぱちゅぱしてるおに\nーさんって、ほんっとだらしない顔してるよぉ。チンチンだってガッチガチ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あたしみたいなちびっこにタマタマとおちんぽをいじくりまわされて……。\nんっ、ぷぷ……♪　ちっぱいミルクにむしゃぶりついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そんな情けないお顔は他の人には見せられないよねぇ？　だから、アーちゃ\nんだけに見せてよ。ほら♪　ほらほら♪　いい感じに仕上がってきたじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ♪　この動き？　これが一番効くんだぁ～。へ～ぇ。ヘンなのぉ～♪　\n反応見てたらわかるよ、こうでしょ？　こう♪　こう、こう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「裏筋にちょっかいかけられるのも好きみたいだね～♪　っていうか、どこも\nかしこもおちんぽぜーんぶ敏感すぎて見てらんない♪　えい、えいえい♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「え！？　嘘でしょ？　あははっ、また出しちゃうの？　またしゃせーしちゃ\nうの？　……あっ♪　ちょっとぉ、乳首吸うの強いぃ……ばか♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほんっとキモいおにーさんだね♪　でも……うんうん、出しちゃっていーよ\n？　そのために、おててベタベタにしながら頑張ってあげてるんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんの乳首から飲んだミルク、ぜーんぶおちんぽから出してよね♪　\nちょっとでも少なかったらゆるさないから……。えいっ、出しちゃえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んんっ……！　ふぁあああっ……♪　ちょーっとぉ！　出しすぎ、出しすぎ\nぃ……！　むぷぅう……っ♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ざこざこよわよわおにーさんのくせにぃ……！　アーちゃんの顔にくさくさ\nマーキングするなんて……っ♪　大人って卑怯すぎ～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっぷぅ……っ♪　ほんっと～におにーさんの精液ってくっさぁい……♪　\n粘り気強すぎだし、やたら存在を主張してくるし……あっついし……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_13" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ホント最低だけど……。むぷぷぷ♪　許してあげてもいーよ……？　これか\nらぁ……アーちゃんだけの遊び道具……奴隷ちゃんになるならね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……あっ、本気にした？　怒らないでってぇ……♪　まー、結構面白かった\nから、またおにーさんのおちんぽいじってあげてもいーよ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ボニューデマクールだって、あと何回か分は残ってるし……。今度は母乳を\nおちんちんに塗りつけたりしてもいいかも……。ぷぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_12" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……おにーさんなんかに主導権はあげないよ？　アーちゃんがしたいときに\n、したい事をおにーさんにするの！　いいよね？　それで嬉しいよね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふふっ、もしかしてこわ～いの～？　でも、もうやめてなんかあげないよぉ\n～だ。おにーさんはアーちゃんのモノなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんが出してって言ったら、こうやってくっさいせーえきをぴゅっぴ\nゅしてね？　屈服のしょーこに♪　びゅるびゅる精子……よわよわちんちん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのしゃせーはこれから、アーちゃん様が管理しまぁ～す♪　他の\n人で出しちゃだめだよ？　抜き打ちチェックするんだからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んもぉおおっ……♪　おにーさんったらはしゃいじゃってぇ～♪　んっ……\nんんっ♪　アーちゃんのおっぱいがデロデロぉ～！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「きゃっ、やだぁ♪　アーちゃんの母乳にせーしがかかっちゃってるじゃん…\n…っ！　そんなにミルクとミルクを混ぜ混ぜしたかったのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふっ♪　んふふふっ♪　おっぱいめがけてビュルビュルしゃせーしちゃっ\nてさぁ♪　やっぱりおにーさんはあたしのちっぱいじゃなきゃダメなんだ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_14" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ミニミニおっぱい、ちびっぱい好きのへんた～い♪　見てぇ、変態さんのえ\nっちミルクが胸にいーっぱいかかっちゃった～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ……♪　待って待って♪　まだ出してるの～？　おにーさんの精子って\n、おにーさんと一緒でしつこすぎ～♪　必死すぎ～♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_16" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのざこざこミルクなんかに、アーちゃんの母乳おっぱいは負けな\nいもぉ～ん。って……、あっ♪　ほ、ほんとにしつこくて……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こ……こんなの、せーしの匂いがこびりついちゃうでしょ！　も……もうい\nいってば……！　おにーさんのミルクの匂い、記憶しちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019601_01_15" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ、アーちゃんにだったら好きなだけかけていいと思ってるでしょぉ！　ち\n……ちっちゃな女の子に包容力とか母性求めてくるとかありえないぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ああ……ぐちゃぐちゃになっちゃった……。で、でも特別に許してあげる…\n…。す、好きだからじゃなくて！　おっぱい吸うのが上手だったから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こ……今度はもーっときもちくしてよね！　いい子にしてたらぁ……おにー\nさんにも、ご褒美あげるかも～？　ぷぷぷっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0103410" ]},
