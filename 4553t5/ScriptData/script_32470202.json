		{"command":[ "PLAYVOICE", "v2_247_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひぐっ！？　あっ、ふっ、んはぁ！？　カツマさんの動きもさらに速くなっ\nてきてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ズンズンって、激しくオチンチンを打ち付けてきてますっ……！　私のオマ\nンコプラグを求めて、必死に腰を振ってくれてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひああぁ！？　あっ、んんっ！　あひっ、あああっ！　プラグの圧がさらに\n強まって、ギュってオチンチンを締め付けて……あはあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんのオチンチンが、オマンコでしっかり包みこまれてるのを感じま\nすぅ！　こんなに感じさせられたら、私……もうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ！　んんっ！　カツマさんのオチンチンがビクビク震えてますっ……！\n　か、カツマさんもイキそうなんですねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「でしたら、一緒にイッてくださいっ！　私のオマンコプラグで感じて、精液\nびゅるびゅる出してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「そのまま膣内に出していいですからっ！　いっぱい子種を奥まで注ぎ込んで\n、種付けしてくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　来るっ！　来ちゃうぅ！　オマンコの奥から凄いのが来てっ……！\n　あああぁんっ！　イクッ！　イキますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁぁぁ……っ！　オマンコプラグの奥に精子が注ぎこまれてるの\n感じますぅ！」", "NORMAL" ]},
