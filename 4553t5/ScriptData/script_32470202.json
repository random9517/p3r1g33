		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「わ、私と……その……！　せ、セックスをしていただけないでしょうか……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「私……カツマさんのことが大好きで……！　普通の人みたいに、一つになり\nたいという欲求が抑えきれなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それで、あの……！　開発部の方にお願いして、セックスができるように接\n続プラグも取り付けていただきました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ですから……私のことがお嫌いでなければ……ど、どうか……カツマさんの\nオチンチンを、私のオマンコに挿れてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あんんっ……！　熱くて硬いモノがオマンコに入ってきてるっ……！　これ\nって、カツマさんのオチンチン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
