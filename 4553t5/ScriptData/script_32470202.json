		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あっ！　イクッ！　イクッ！　カツマさんっ！　私、もう……\n！　ひああぁっ！　イクッ！　イッちゃいますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あはぁぁぁんっ！　カツマさんの熱いザーメンが、またオ\nマンコに注がれてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「子宮口とオチンチンがキスしてるみたいに、ぴったりとくっついて……！　\n奥の奥まで精子が流れ込んでるのがわかりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら、本当のオマンコだったら絶対に妊娠してますっ！　カ\nツマさんの子種で、妊娠しちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「これは接続プラグだから妊娠なんてしないのにっ……！　でも、カツマさん\nとの赤ちゃんを想像したら……また幸せな気持ちが溢れてきてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　幸福感が止まりませんっ！　私の超人工知能、本当に壊れ\nちゃいますぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、んんっ……！　私の接続プラグ、カツマさんの精子\nで真っ白になっちゃいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふふっ……大丈夫ですよ。さっきも言いましたが、これはあくまでも接続プ\nラグ……疑似オマンコですので、妊娠はしません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ですが、カツマさんとの赤ちゃんを想像したのは本当ですよ……可能なら、\n妊娠したかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「って……こ、こんなこと言うと、カツマさんにご迷惑をおかけしちゃいます\nよね……！　すいません、忘れてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ですが……いつか本当にその夢が叶う時がきたら、それはとっても嬉しいこ\nとだなって思っちゃいますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁっ！？　オチンチンが一気にオマンコプラグから抜けてっ……！\n　あああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「私の身体にカツマさんの精液が飛び散ってるぅ！　熱くて臭い白濁液がこん\nなに……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「オマンコプラグに注がれたときよりも、濃い臭いがしますっ……！　ああっ\n、ダメですっ！　この臭いを嗅ぐだけで、またイッちゃいそうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、くるっ……！　オマンコの奥から気持ちいいのきてますっ……！　あ\nっ、イクッ！　イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ドロドロのザーメンを浴びながら、またイッちゃいますぅぅぅ～～～～～！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あふっ……はふぅ……こんなに出るなんて……さすがはカツマさんですね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「オマンコにも身体にも、たくさん精子を注いでもらえるなんて……私、凄く\n嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふふっ……カツマさんも満足されたみたいでよかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あの……もしよろしければ、また今後もこうしてセックスしていただけない\nでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「い、いいんですかっ……！？　で、では……今後とも、よろしくお願いしま\nすねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
