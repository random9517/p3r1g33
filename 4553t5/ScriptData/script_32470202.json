		{"command":[ "PLAYVOICE", "v2_247_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ……！　カツマさんのオチンチンがさらに奥まで来てっ……！\n　んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ……！　ど、どうですか……！　私の接続プラグは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「人間の女性器を模して造られていますので、気持ちいいとは思いますが……\nもし不都合があったら、すぐに言ってくださいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それと、何か私にして欲しいことがあったら遠慮なく言ってください……カ\nツマさんのためなら、何でもしますので……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっと……気持ちいいから、動いていいかって……？　もちろんですっ！　\nカツマさんのお好きなように動いてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「いっぱい接続プラグを締めて、オチンチンを気持ちよくしますので……！　\nんっ、くっ……あっ、はあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　プラグを圧迫すると、カツマさんのオチンチンの形がよくわ\nかりますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなの我慢できませんっ……！　カツマさん……いっぱい動いてください\n……！　私のオマンコプラグ、じゅぽじゅぽしてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、ああっ！　凄いですっ！　奥の方までカツマさんのオチンチ\nンが届いて……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「幸せな気持ちが、接続プラグを通じてメモリーに流れ込んできますっ……！\n　これが好きな人とのセックスで感じる快感なんですねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あふっ……！　あっ、んはあぁ……！　オチンチンのカリの部分が\n、プラグの膣内でゴリゴリこすれてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふっ、んくっ……！　ど、どうですか……私のオマンコは……？　ち\nゃんと気持ちよくなっていただけてますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　凄く気持ちいいだなんて……！　悦んでもらえて嬉しいです\nっ……！　では、もっと気持ちよくさせていただきますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こうして、カツマさんの動きに合わせて腰を動かして……あっ、はっ！　ん\nっ、あっ！　あはぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「これ、いいですっ！　オチンチンが出し入れされる感覚がさらに強くなって\n、オマンコのヒダに亀頭が擦れてるのが、ダイレクトに伝わってきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「愛液のオイルがたくさん滴ってきて……！　ぐちゅぐちゅって、いやらしい\n音が響いてきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こんなエッチな音を響かせるなんてっ……！　あんんっ！　ダメっ！　余計\nに興奮してきちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あっ、ふぐっ、んふっ、ああっ！　くっ、んっ、あはぁっ！　気持ちよすぎ\nて、いろんなところからエラーが出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「エラーを止めないといけないのに、勝手に身体が動いて……やっ、あふっ、\nんはぁっ！　と、止まるどころかエラーが増え続けてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
