		{"command":[ "PLAYVOICE", "v2_247_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひっ、ああぁっ！　まだ出てるっ……！　カツマさんのザーメンが、オマン\nコプラグいっぱいに広がってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もっと出してくださいっ！　カツマさんの気が済むまで精子出してっ！　私\nのオマンコに、全部注ぎ込んでくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ……凄いです……出されたザーメンが、結合部の隙間\nから溢れ出てきますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それに私のエッチなお汁と混ざって、さらにドロドロになって……あんっ…\n…！　臭いも凄くいやらしいですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「精液と愛液オイルの混ざった臭いを嗅いでると、いやらしい気持ちがさらに\n強くなってきますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あ、あの……カツマさん……よかったらもう一度、私のオマンコにオチンチ\nンを突き挿れてくれませんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「……ほ、本当にいいんですかっ……！？　ああっ、凄く嬉しいですっ……！\n　では、よろしくお願いしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「くっ、あっ……んっ、んんっ！　ズブズブってエッチな音をさせながら、ま\nた奥までオチンチンが入ってきてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「愛液オイルと精液のおかげで、さっきよりもスムーズに最奥まで届いてるっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああっ！　んぐっ、ひっ、あっ！　カツマさんのオチンチンの先端が、子宮\n口に当たって……あっ！　これ、一番好きかもしれませんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「人間の女性で言えば、ポルチオとでもいえばいいんでしょうか……子宮口の\n周りをグリグリされるの、本当に気持ちよくてっ……あああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「そっ、そうですっ！　そうやって、奥をトントンってされながらオチンチン\nの先端で押されるのが、凄く感じますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「か、カツマさんっ！　それ、もっとしてくださいっ！　私もオマンコプラグ\nに圧をかけて、いっぱい締め付けますのでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　オマンコプラグを締め付けると、子宮口の快感がさらに強く\nなってきてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「オマンコプラグがカツマさんのオチンチンの形なってるから、カリの擦れ具\n合や子宮口への当たり方がさっきとは段違いですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ！　これダメぇ！　さっきよりも多くのエラーが出て、私の超人\n工知能が壊れちゃいそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゃんと規律を守るようにシステムが命令してきてるのに、全然身体が反応\nしてくれなくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「心と身体がまったく別物になってるみたいな感じがしますぅ！　こんな感覚\n、今まで感じたことありませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んっ、あはぁぁぁっ！　これ、またイッちゃうっ！　オマンコの奥\nから気持ちいいの溢れ出ちゃいますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あああっ！　ダメっ！　イッ、イクッ！　イッちゃいますぅ！　か、カツマ\nさん、また私と一緒にイッてくださいっ！」", "NORMAL" ]},
