{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下僕！　グレーテルチームが来るわよ！　弾を装填しなさいよ早く早く早く\n早くーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いまやってますって！　ちょっと待って――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "Ｈｅｒｅ　Ｃｏｍｅｓ　Ａ　Ｎｅｗ　Ｃｈａｌｌｅｎｇｅｒ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「むむ？　いまのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113330001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「なんか、視界にテロップが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113330001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「誰か、バトルに参加してきたんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113330001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そうみたいね、１１時方向に戦車が……って、なによあれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「見て！？　変な戦車！　あんなのありなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナの大声に驚いて、みんなハッチを開けてそっちを見る。すると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0123" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「戦車の車体に……怪獣が乗ってる……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113330002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「なに、あれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113330001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グレーテルたちもあの戦車を見ているようだ。呆れた声が無線から聞こえてく\nる。それにしても……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「怪獣だぁ！？　おい！？　このマシン、第二次世界大戦中の戦車しかデータ\nが入ってないはずだよな！？　そのころはホントに怪獣がいたのか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「そんなはずはないであります！　怪獣戦車など存在しません！　考証がいい\nかげんでありまーすっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113330002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那もかなり慌てているせいか、口調が変だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「危ない！　怪獣の口から光線が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050113330003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「逃げて！　急いで後退よーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナの悲鳴で、全員戦車の中に引っ込んで慌ててバックさせようとするが\n――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「間に合わねえ！　うわっ！　わっ！　わわわわわわわーっ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ルルーナさんチーム、グレーテルさんチーム、撃破！　大丈夫ですか！？　\n皆さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113330001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ミス・パープルが、慌ててブースを開けて俺たちを外に出す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「大丈夫もなにもないわよ！　なんなの、アレ！？　怪獣戦車なんてアリ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わけがわかりませんぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113330002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ルルーナさんたちもやられたんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113330001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「いったい、あれはどこのチームなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020113330002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「それが……ログインしていたのはあなたたち２チームだけのはずだったんで\nす。それに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113330002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そう言ってミス・パープルはプラモデルがおさめられたボックスを開ける。す\nると――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひいいいいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひどいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113330002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちのプラモデルが、メチャメチャに壊されていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ど、どういうことですか？　どうしてこんなことに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130113330003" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「わ、わかりません……こんなことは、起こるはずがないんです。システム上\n、ありえないんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113330003" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さすがのミス・パープルも動揺している。しかし、それ以上にうろたえている\nのが――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ど、どうして……！？　どうして私のプラモデルが、こんなことになっちゃ\nうの！？　苦労して作ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったくです……苦労して作ったのは俺ですが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「返して！　私が作ったＫＶ－２を返しなさいよ！　ボケナスビぃーーーーー\nーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113330008" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから作ったのは俺ですーーーーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「と、とにかく、いったんマシンは閉鎖します。原因を突き止めなければ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010113330004" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}