		{"command":[ "PLAYVOICE", "008_0603101" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はぁ……本当に最悪です……なぜ私がこんなことを……わかっています、わ\nかていますが……だからって、納得はできません」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000806_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603102" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「とりあえず、そのクサいものをしまってください。先ほどから鼻がまがりそ\nうです……なんですか、この不快な匂いは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603103" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はあ……？　これを……舐める……？　私が……？　い、嫌に決まっている\nでしょう！　もっと他に方法はないのですか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000806_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603104" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「くっ、なんということを……ウソですよね……こんなものを舐めさせるなん\nて……ふざけるのもいい加減にしてほしいです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603105" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「……な、なに……本気で、言っているのですか……あ、あぁ……奉仕といっ\nても、なぜこんなことを……ぐっ、わ、わかりました！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603106" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「舐めればいいんでしょう……簡単です……ええ、こんな粗末なもの……すぐ\nにイかせてあげますからっ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603107" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「んっ、んぐっ……ンンっ……わ、わかってますっ……腰を動かさないでくだ\nさい……やりにくいでしょう……ンっ、むっ、ぐっううっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603108" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「んぶっ……ンぅっ……ちゃんと舐めます、から……ジッとしていてください\n……お願い、ですから……はぁ、んっ……ンちゅっ、ちゅうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603109" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はぁ、むっ……んむっ、ンちゅっ……美味しいわけ、ないでしょ……クサい\nし、不味いに決まってます……あむっ、んっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603110" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「もっと美味しそうに舐めろって……無理です……こんな、もの……舐めさせ\nておいて……はぁっ……なにを言ってるんですか……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603111" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「このままだといつまでも射精できない……それはそっちでどうにかしてくだ\nさいっ……こっちは、ちゃんと舐めてるでしょうに……れろっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603112" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ああっ、もうっ！　わかりましたっ……わかったから……言われた通りにし\nますから……さっさと終わらせてくださいよっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603113" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぶっ……れろ、れろぉ……お、おいひぃ、です……隊長の、ちん\n、ぽぉ……ガチガチで、熱くて……ちゅ、ちゅくっ……ンぁっ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603114" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「なぜこんな屈辱的なことを……言わされるんですか……んちゅっ……ちゅく\n……れろっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603115" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「まったくっ……なんて情けない顔……それに気持ち悪い声を出して……最低\nですよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603116" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「パワーアップのためじゃなかったら、こんなこと……んっ……絶対に、やり\nませんから……ね……わかってますか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603117" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「あー、はいはい……申し訳ございません、ちゃんとやりますっ！　はむっ…\n…ん、ちゅぷっ……れろ、ちゅくっ……ちぴゅ、ちゅうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603118" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「こんな感じで、よろしいですか……はっんんっ……んふっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603119" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「もっと先っぽ……ここを重点的に舐めればよろしいんですね……んぁ、ちゅ\nぶっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603120" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ちゅっ、くちゅっ……ンっ、んはっ……い、いちいち、言わなくてもいいで\nす……感じてるのは、なんとなくわかりますから……あんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603121" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はぁ、ちゅくっ……それより……き、気持ちいい、なら……さっさと終わら\nせてください……ちゅ、くちゅっ……ほら……早くっ……ンンっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603122" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ン、あぁ……なんか……滲んできてますし……うぅ、苦い……こんなものを\n舐めさせて……隊長の変態っ……あむっ、ん、ンふぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603123" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はっ、はっ……んんっ……が、我慢汁、ですか……これ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603124" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ということは、もうすぐ射精しそうなんでしょう……いいですよ……ンっ、\nちゅうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603125" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「が、我慢しないでください……無駄に、長引かせようとしないで……んっ、\nはあぁっ……れろっ、んちゅっ……ちゅぶっ、ぢゅ、ぢゅるっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603126" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「だって気持ちいいから……じゃないです……これはパワーアップのためのご\n奉仕で……隊長の息抜きではありませんよっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603127" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「早く、出して……射精してください……ですから、先ほどからこうやって…\n…先っぽから根元まで……舐めて、いるでしょうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603128" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ええ、はい……美味しい、ですっ……隊長のちんぽ、美味しいですから……\nはむっ……んっ、ぶっ、ちゅうっ……おいひぃ、れすっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603129" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ぢゅっ！　ぢゅうっ、ぢゅるるっ！　はっ、はぁっ……やってるでしょ、こ\nうやって……しゃぶって、吸って、舐めてぇ……んぢゅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603130" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「いいから、早く出してっ……お願いですから……は、早くっ……ンンっ……\nはっ、ちゅっ、ちゅうぅっ……ンっ、ンンっ、んぶぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603131" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「んぐぅぅぅぅっ！　ぶっ、ンぶっ……はっ、はぁぁぁっ！　あっ、はひっ…\n…ンン、んはぁぁぁっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603132" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと何これ……出しすぎっ……ンっ、んぶっ……ちゅぶっ……ん\n、んふぅっ……ううぅっ、んうぅぅうぅぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603133" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「ん、んぷっ……く、口の中がいっぱい、で……すごい匂い……んっ、はぁっ\n、はっあぁぁっ……くうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603134" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁ、はぁ……これで……満足しましたか……こんな不味い\nものを、飲ませて……うっ、ぐぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603135" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「こんなことを褒められても嬉しくない！　パワーアップのためじゃなければ\n……八つ裂きにしてやりたいくらいですよっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603136" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はあ？　どこがっ……ノリノリなわけないでしょう！　あ、あれは……隊長\nがそうしろって言ったからっ……そう、命令に従っただけです！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603137" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「な、なんですか……そんな残念そうな顔をしても無駄ですよ……え？　嫌な\nらやめるって……それじゃあ今後パワーアップは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603138" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「くっ……ひ、卑怯な……隊長にご奉仕するしかないって……わかってて……\nもうっ、本当に最低な人ですね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603139" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「はぁ～……わかりました……今後とも、ご奉仕させていただきます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "008_0603140" ]},
		{"command":[ "SETNAME", "ピースムーン オボロ配下" ]},
		{"command":[ "SETTEXT", "「な、なにって……隊長のちんぽです！　わざわざ言わせないでくださいっ…\n…！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000806_01_09" ]},
