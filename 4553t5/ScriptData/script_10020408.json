		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「私たちに必要なのは、仲間を信じる心！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_028_010113630001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それらを糧として熱く燃える心！　滾る血潮！」", "NORMAL" ]},
