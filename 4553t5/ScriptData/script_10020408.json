		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「教育とは、時には黙って見守るもの。耐えるのです。試練は教師と生徒、双\n方を成長させるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_020113630002" ]},
