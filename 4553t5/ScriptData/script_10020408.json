		{"command":[ "SETCHARA", "0", "char_00001501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "な、なんだ。熱血なのか。", "NORMAL" ]},
