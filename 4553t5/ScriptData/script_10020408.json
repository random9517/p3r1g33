		{"command":[ "SETCHARA", "0", "char_00001701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ボールは友達だっ！　怖くないっ！」", "NORMAL" ]},
