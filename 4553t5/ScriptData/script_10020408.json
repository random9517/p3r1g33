		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そんなこと、言われたってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113630003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「目を背けてはだめっ！　いま、あんたに必要なのは自分自身を乗り越える勇\n気！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010113630001" ]},
