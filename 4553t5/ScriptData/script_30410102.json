		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「もうっ、まぁ、真っ白ですぅ……んぅっ、臭いも凄い……はふっ、はぁ、は\nぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「全身、隊長さんのものだってぇ、客観的に誰が見てもわかるくらい、マーキ\nングされちゃいましたぁ……あふっ、あぁ……」", "NORMAL" ]},
