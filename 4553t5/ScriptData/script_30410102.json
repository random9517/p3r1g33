		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ぷるぷる、ゼリーみたいに濃い精液ぃ……んぅっ、あぁ、とても熱くて、気\n持ちいい……はふっ、はぁ……んんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「いつまでもこのままでいたいくらい、気持ちよくて、幸せ……論理的に説明\nできない、不思議な感覚ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんは、私に新しいこと、たくさん教えてくれます。気持ちよくて、幸\nせなこと……」", "NORMAL" ]},
