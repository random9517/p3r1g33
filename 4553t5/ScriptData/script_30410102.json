		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ひゃっ、どうしてオマンコからオチンポ抜いちゃう……んんぅっ、あぁっ、\nくりゅっ、熱いの……ひううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ふぁあああああああああっ、あぁうっ、あぁっ、びゅるびゅるっ、精液、出\nてますっ、わ、私の身体にぃっ！」", "NORMAL" ]},
