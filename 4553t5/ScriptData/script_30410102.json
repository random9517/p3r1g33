{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「な、なななな、なんですか？　……緊張？　つ、常に氷のごとく冷静沈着な\n私が、動揺するなどありえません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104101" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんのせいで、知識も身につきましたし……いまさら、こんなことで緊\n張するなど、客観的に考えてありえませんから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……で、でも、その……じっと見つめられると、さすがに意識してしまいま\nすので、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104103" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……後ろからなら、いいだろう？　……そ、そうですね。顔を合わせないほ\nうが……あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「いいでしょう。こ、こういう場合、経験豊富な方にお任せするのが、論理的\nに考えて適切ですし！　ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104105" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんのお好きなように、命じてください。私は、それに従って……し、\n従いたい……気分ですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104106" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ベッドに上がって、隊長さんのほうにお尻を……は、はい……んっ、こうし\nて……どうぞ……」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ひぅっ、くうううううう！　はぁ、はんぅっ、あぁっ、は、入ってきて……\nはひっ、ふぁあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ぎっちりっ、た、隊長さんのオチンポが……私の中、いっぱいに入ってきて\nますっ、くはぁ、はぁ、はふぅっ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁっ、はい……んっ、大丈夫です。あ、あんなに太くて大きなオチンポが\n、私の中に全部入って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ろ、論理的に不思議ですけどっ、ちゃんと、全部入ってます……中がいっぱ\nいに……はふっ、はぁ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「お腹の奥まで隊長さんでいっぱいになって……んぅっ、何だか、凄く熱いで\nす。熱くて……気持ち……いい……はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「動く……ですか？　んぅっ、だ、大丈夫だと思います。わ、私も……本能的\nに、動いてほしいと感じてるような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「中……オマンコの中、勝手に動いてしまってるの、自分でもわかります。う\nねうね……オチンポに甘えるみたいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はひっ、どうぞ……突いて……ひぃっ、はぁ、はんぅ、くふぁああっ、はぁ\n、そこ……突いてぇ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「凄いっ、ですっ、私の中っ、ズンズンって、はぁ、激しく……オチンポが出\n入りしてぇっ、いいっ、ひぐぅっ、くふぁあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「中っ、いっぱいにっ、はぁ、はんんぅっ、ふぁああっ、はぁっ、ひいいいい\nいいっ、イイッ、んくううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んぅっ、はぁ、はぁ、小さなお尻に、こ、腰を叩きつけるの……興奮する…\n…ですか？　はぅっ、くぅっ、そんな……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「やぁ、やっぱり、隊長さんは、倫理的によろしくないですっ、けどっ、そ、\nそういうところ……私……あふぅっ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「好き……かもっ、ですっ。いっぱい、小さなオマンコ、激しく突いてくれる\n隊長さんっ、エッチな隊長さん……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「あぁ、一番深いところっ、し、子宮、ズンズン突かれるたびに、何だか嬉し\nくなって……気持ちよくなって……ふぁあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「蕩けちゃいます、私、オマンコがぁ、頭の中が、蕩けて……はへぇっ、はぁ\n、ひうぅっ、あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんのことで、いっぱいに……なっちゃう、んくっ、はぁ、あんんんん\nっ、ダメっ、ひぐぅっ、あひいいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、オマンコ、き、きつく締まりすぎ？　んぅっ、そんなこと言われ\nても、加減なんて、無理ですぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「奥にオチンポの先っ、もう、オチンポ汁でヌルヌルの先っぽが当たるたびに\n、もうっ、あふぁあっ、身体、痺れてぇ、はひぃぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「もっともっといっぱいほしくて、感じたくてぇ、オマンコが勝手に締まっち\nゃいますっ、はひっ、はぁ、ふぁあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私がこんなに流されちゃうなんてぇ、ろ、論理的に理解できないですけどぉ\n、でもっ、でもっ、もう、イィッ、はひいいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「突いてください、もっともっとっ、窮屈なオマンコ、ゴリゴリ、削るみたい\nに広げてぇ、はぁ、はぁっ、ひいいいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「いっぱい突いてぇ、くふぁああっ、はぁ、んんんんんっ！　いぃっ、そこっ\n、子宮っ、コンコン、ノックするみたいに突かれるのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「好きっ、私……しゅきぃっ、あへぇっ、はぁ、ひいいいっ、もう、頭真っ白\nになって……くりゅっ、なにか、くううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「もう、頭の中ぁ、隊長さんのオチンポでいっぱいになってぇ、んんふぅっ、\n凄いの……きちゃうっ、くぅっ、くふぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「あはっっ、んんぅっ、隊長さんのオチンポもっ、いっぱいっ、いっぱい震え\nてぇ、はぁはぁ、で、出るんですね、精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「オチンポ汁っ、私の子宮、パンパンにふくらませちゃうくらい、出してくだ\nさい……いっぱい、いっぱいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「この疼き、満たすにはぁ、隊長さんの精液を子宮にもらうしかないっ、たぁ\n、種付けぇ、してもらうしかないですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「本能的にっ、子宮でそう感じてますっ、だからぁ、きてぇ、精液っ、オチン\nポ汁っ、びゅーびゅーきてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ひくうううううううっ、あぁ、中でオチンポがふくらむぅっ、くりゅっ、熱\nいのっ、きますっ、ひぐぅっ、いぃっ、ンくぅううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「あふぁああああっ、はぁ、きたぁっ、でぇ、出てますっ、奥に熱いのぉっ、\nびゅーびゅー出てりゅっ、くりゅっ、ひぐぅっ、くううう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私の子宮、い、いっぱいになってるのに、まだまだ出てますっ。精液、たく\nさん出て……ふぁああああっ、くりゅっ、もっとくりゅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、、はふっ、んんぅ……中……も、もう、パンパンですぅ……隊長\nさんの精液で……ふくらんでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「こんな感覚、初めて……です。不思議な……幸福感……はふっ、クセになっ\nてしまいそうなぁ……ふぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「でも、オチンポ、ま、まだ元気ですね……んぅっ、私は一回で、こんなにぐ\nったりしてしまっているのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ベッドの上での隊長さんは、誰よりも強い……です。んっ、そ、その強さ…\n…魔術的に、とても興味あります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……い、いいえ……正直……一番は性的に興味があるので……だから、もっ\nと、もっとこのまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「くふぅっ、はぁ、はひっ、そうですぅっ！　隊長さんの精液でいっぱいのオ\nマンコ、もっともっと突いてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「出してもらったばかりの精液、グチュグチュ、エッチな音を鳴らしてかき混\nぜてぇ、すり込むみたいにっ、ふぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「動いてっ、もっともっと……くぅふぁああっ、はぁ、いぃっ、そこっ、ひふ\nぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んぅっ、じゅぼじゅぼっ、突かれてぇ、精液、子宮の奥に押し込まれるみた\nいな感じっ、いいっ、はんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁ、ああっ、もっと激しくしてください。お尻っ、隊長さんの腰に叩かれ\nて、あ、赤く腫れてしまうくらい強く、思い切りっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「凄いですっ、んうっ、はぁ、あああっ、身体が震えてしまうくらい、激しく\n突かれてっ、はんんっ、くふぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「窮屈なオマンコ、隊長さんのオチンポの形に作りかえられていくみたいでぇ\n、嬉しい……幸せ……あふっ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「恥ずかしい声っ、と、止まりません、もうっ、勝手にっ、声が出ちゃいます\nっ、はんぅ、はっ、ひぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ろぉ、論理的にぃ、理解できないですっ、こんなっ、自分の身体、言うこと\n聞かなくなっちゃうなんてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんのオチンポで支配されてぇ、もうっ、らめぇ、あひぃっ、ひぃっ、\nしゅごぃっ、オチンポぉ、しゅごぉっ、おほぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、ひふぁあっ、あぁっ、らめぇ、いぃっ、んくぅっ、またイ\nク、わらひぃっ、はぁ、ひううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「イッ、イッちゃいますっ、オマンコ……気持ちよくて、熱くてぇ、はへぇ、\nふぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「きて、ください、隊長さんもっ、一緒っ、い、一緒がいいですっ。一緒にイ\nキたいですぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「トロトロのオマンコで、オチンポ、遠慮なくしごいて、また濃い精液、オチ\nンポ汁出してくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ドクドク、うんと熱くて粘っこいお汁で、私のこと、隊長さん色に染め上げ\nてぇ、はぁっ、くううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「イィッ、くりゅっ、しゅごいのっ、くりゅっ、もうっ、イィッ、はぁ、ひく\nううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「きてぇ、隊長さんっ、一緒にっ、イク、イッくっ、あはぁ、オチンポ、ビク\nビクしてるの感じるっ、はぁっ、くふぁあああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んふううううううううっ、きてますっ、おっほぉっ、あぁっ、また熱い精液\nっ、オチンポ汁、子宮にきてりゅううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104301" ]},
