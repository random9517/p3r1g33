		{"command":[ "SETIMAGE", "0", "still_00004101_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「イク、おぉぉっ、んふうううっ、子宮ぅ、精液でぇ、もっともっといっぱい\nにされてイクぅっ、イッちゃいまひゅうううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「精液、やけどしそうなくらい熱くて、ドロドロでぇ、あひっ、あぁ、も、も\nう、何も考えられませんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「オチンポ汁、もっとほしくて、オマンコが勝手に締まっちゃいますぅっ、オ\nチンポにおねだりしてりゅぅ……はぁはぁ、あひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んぅっ、まだ出て……と、止まらない……嬉しいですっ、いっぱい射精して\nもらえるのっ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「もう、オマンコの隅々まで隊長さんの臭いでいっぱい……んぅっ、隊長さん\nのオチンポ専用にされてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、客観的に見てもぉ、私のオマンコ、隊長さんのものだってわ\nかるようになって……嬉しい……ですぅ……はふぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「論理的に考えて、こんなに子宮を精液でいっぱいにされたら、絶対に孕んじ\nゃってますぅ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私の知性を引き継いだ優秀な赤ちゃん……隊長さんと私の赤ちゃん、できて\nます……きっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ふふっ、母娘で魔術の研究を進めるのも楽しみ……もちろん、隊長さんも強\n力してくださいね……ふふふっ」", "NORMAL" ]},
