		{"command":[ "SETIMAGE", "0", "still_00004101_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「濃い精液、いっぱいかかってぇ……んぅっ、身体中、隊長さんの精液塗れに\n……なってぇ、ひぐぅっ、くううううっ！！」", "NORMAL" ]},
