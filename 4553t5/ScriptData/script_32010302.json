		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前とともにこの部屋へと足を踏み入れた時から、胸の高鳴りがおさまらな\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いよいよなのだと思うと、子宮まできゅんと唸りをあげてしまう。……ふふ\nっ、どうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304103" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の浅ましく発情した身体を、お前に晒せというのか？　……そうだな、少\nし恥ずかしいが、お前の頼みなら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304104" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「これでよく見えるだろう。母の胸も、マンコも……。ああ……お前の視線が\n、母に向けられている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020103_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「全身を、舐めるように見られている……。勃起した乳首にも……蜜を溢れさ\nせるマンコにも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふ。お前も母に欲情しているようだな……。勃起したチンポが、ヘソまで\n届くほどに反りかえっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母のマンコはこんなに蕩け、もう準備ができている。早くそのチンポを、母\nの膣へと挿れてくれないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「……どうした？　もっと卑猥に求めて欲しい、か……。プライドを捨て、一\n人のメスとして、夫のチンポを求める……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こうだろうか……。マンコを、思い切りひろげ……。ンッ、濡れた穴を、お\n前によく見せて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……チンポ……チンポをハメてほしい……。愛しいお前のチン\nポを、この淫らな汁にまみれた、母のいやらしいメス穴にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、お、押しあてるだけでなく、中に……！　チンポをぶちこんで、\nお前の欲情を、母にぶつけてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　ああぁ～～っ！！　き……きた……っ！　お前のチンポが、母\nのマンコの奥まで……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母のマンコ……どうだ？　熱く、蕩けているだろう……？　お前のチンポを\n待ちわびていたのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、このまま、動いてくれ……。好きなように動いて、チンポの形を刻み\n込んでくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、ああっ！　激しいっ、チンポっ、んっくぅっ、ずぼずぼ\nとかき回してっ、あっ、ああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「熱く、硬い勃起チンポが……母の膣を、満たしている……！　んふっ、くは\nぁっ、いいっ、すごく……感じてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「亀頭が、一番奥に届いてっ、ああっ、子宮を押し上げてくるっ！　何度も、\n子宮口小突かれてっ、ああっ、頭が真っ白になりそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こんなにも母を求めて……。お前も、気持ちよくなってくれているようだな\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「たっぷりの蜜で満たされながらも、しっかりとお前のチンポを包み、締めつ\nけている、母のマンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、今日は特別に濡れてしまっている……。いつにもまして、お前のこ\nとが愛おしくてたまらないのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「妻として抱かれ、お前の男らしいところを全身で感じている……。そのせい\nかもしれないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んくぅっ！　なんだ、先ほどより激しく腰を……あぁっ！　もっと母に……\n男らしいところを見せてくれるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　すごいっ、マンコの奥っ！　子宮口責め……！　ゴツゴツ\nきてっ、んぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「蜜がっ、溢れてとまらないっ！　突かれるたびに、ぶちゅっ、ぶちゅっとい\nやらしい音をたてて噴いてしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、感じているっ！　母のマンコは、悦んでいるっ！　んぁっ、ああっ、\n母の腰も、踊ってしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前の動きにあわせ、腰をくねらせ……んぁっ、ああぁっ！　勝手に動いて\nしまう、腰が……とまらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、んっ、んぁあっ！　中でチンポが膨らんでっ、ああっ、暴\nれまわっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前のチンポがっ、あたるっ、こすれるっ！　んくっ、ピストンのたびに、\n愛液がかきだされるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、母も感じている！　お前の腰遣いに、夢中になっている！　力強く突\nかれ、チンポが頭まで届いているようだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「身体が、お前の与える快楽でいっぱいになって、破裂してしまいそうだ……\n！　ああっ、だが、もっと求めてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前が母に抱いてくれた想いを、すべて受けとめる！　マンコをしっかり締\nめ、子宮で……この身体全てを使って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ピストンが、ますます速く……！　イキそうなのか？　中\n出し……ああ、もちろんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の子宮は、お前の精液欲しさにすでに降りてきている。ここに注いでくれ\n、愛しいお前の精液で、母の子宮を満たしてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……ああ……母も……！　私ももう、イク……イッてしまう……ああっ\n、イク、イク、イク……ッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁ～～～～っ！！　あっ、ああっ、精液きたっ！　射精っ、びゅ\nくびゅくとチンポがっ、ああぁぁあぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「精液でいっぱいになるっ！　子宮がっ、ああっ、膨れるぅううぅぅっ！！　\nんはぁっ、ああっ、イッくぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……すごい……。お前の想いのこもった精液が……母を満たす……。こ\nんなに、嬉しいことはない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。イッたあとのマンコを……ンッ、かきまぜるように、腰\nを動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「精液が、肉襞に染み込むように……。んっ、ああ……念入りに塗り込むよう\nな腰遣い……。ん……はぁ……たまらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、わかっている……。初夜はまだはじまったばかり。お前のチンポがま\nだ滾っているように、母の火照りもまったくおさまらない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「さあ、続きをしよう。お互いの身体が蕩けてしまうくらいに、この快楽に溺\nれてしまおうではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああぁっ、う、動いて……っ！　んはぁっ、あっ、ああぁ……っ！　チンポ\nが、ゆっくり……中をかきまわす……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああ、お前にイかされたマンコが……。ますます、貪欲にお前のこ\nとを求めてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「トロトロに解れた膣肉で……んんっ、チンポを、ぎゅうぎゅうと……熱く、\n抱きしめて……はぁっ、ああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どうした？　お前も腰が動いてしまうか？　ふふっ、それでいい。思うがま\nまに母のマンコを味わってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁっ、また激しい……っ！　チンポが、んっ、ああっ、じゅぼじ\nゅぼマンコを、かきまぜっ、て……ああぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「中出し精液っ、かきだすような腰遣い……っ！　んくぅっ、カリが、ゴリゴ\nリひっかいて……はぁっ、あっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ、母のマンコは、お前のチンポを悦ばせるためにうねって、締めつけ、\nしごくように蠢いている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前のことが愛おしくてたまらない。さらに愛液を溢れさせ、お前の腰をび\nしょびしょにしてしまっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んむっ、どうした？　そんなに母を見つめて……ンッ、顔までエロくなって\nいる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうだな……お前に責めたてられ、すっかり母の顔は蕩けてしまっている…\n…。ンッ！　チンポがビクンと跳ねた……んはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ますます激しくっ、チンポがっ、んっ、んぁっ、あはぁっ！　マンコをほじ\nるっ、んくっ、ううぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00020103_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母の顔を見て、さらに興奮させてしまったか？　んぁっ、チンポが暴れて、\n先っぽも子宮に突き刺ささる、んっ、くはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「も、もっと感じまくり、情けない顔を晒せと……んぁあっ、お前のチンポに\n夢中になった、浅ましいメスの表情を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そんなこと言われずとも、母はもうお前の妻だ。お前のメスだ。だからお前\nにイかされれば、自然とその表情を見せるだろう」", "NORMAL" ]},
