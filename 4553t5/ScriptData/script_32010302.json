		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「今宵はお前の妻として初めて抱かれる夜……。ふふっ、母は柄にもなく緊張\nしているようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00020103_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
