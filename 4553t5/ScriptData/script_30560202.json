		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁあっ……すごい、です……オチンポが脈打ってて……ザーメンが\n噴水みたいに……んっ……飛び散ってぇ……あぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁあっ……私のからだ……隊長のザーメンまみれになってますぅ……んっ\n、あったかい……せーし、あったかぁい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ンっ……ふぅ、うぅん……はぁ、に、匂いも……すごい……生臭くて、濃厚\nで……あぁっ、頭がクラクラしてくるぅ……んはぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひうっ……はっ、ああっ……ま、まだ出てる……さっき射精したばっかりな\nのにぃ……こんなにたくさん……たくさん……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204406" ]},
