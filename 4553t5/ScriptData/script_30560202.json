{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「お疲れ様です、隊長。清水紅羽、参りました。今日も呼んでいただいて、と\nても嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「この格好ですか？　ふふっ……はい、水着です。隊長に喜んでもらお\nうと思って……どうですか、似合ってますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「とてもエロい、ですか……興奮しますか？　ああ、嬉しいです……大好きな\n隊長にそう言ってもらえて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「きゃっ！　も、もうっ……なんでもうそんなに大きくなってるんですか……\n水着に興奮してる証拠？　べつに疑ってませんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「で、でも……それほど興奮してくれてるなら……こうやって水着を着てきた\nかいがあります……ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「もう我慢できない……？　私はどうか……？　そ、そんなの……私だって隊\n長に抱かれたくて溜まらないに決まってるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……水着だから、すぐ大事なとこが……全部見えちゃう……ンンっ…\n…は、恥ずかしい……恥ずかしいに決まってるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　乳首は勃起してるし、アソコはぐちょぐちょ……？　わざわざ言わな\nくてもいいじゃないですかぁ……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「それだけ期待してるんです……早く隊長とエッチなこと、したいんです……\nだからもう焦らさないでください……お願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「えぇ、おねだりですか？　また私を恥ずかしがらせて……うぅぅぅ……わか\nりました、言います……言えばいいんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長の……ください……その勃起したオチンポ……私のぐちょぐちょに濡れ\nたオマンコを、いっぱい犯してください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……言いましたよ？　ちゃんとおねだりしたじゃないですか……だ\nから、早く挿入れてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁ……熱いっ……隊長のオチンポが……先っぽが……アソコに当\nたって……んんっ！　そこ、そこぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……入口のとこ、くちゅくちゅしないでくださいぃ……は、早く\nぅ……奥まで、きて……んっ、はぁあっ……あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そう、そこです……そのまま……あっ、あっ、ああっ！　くるっ……隊長の\nオチンポが中に、挿入ってくるっ……うぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はあぁぁぁぁっ！　んっ、ひぃあぁっ……な、中が擦れてぇ……んっ、エッ\nチな音してるっ……はっ、んんっ……んっひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んひっぃぃぃいぃっ！　お、おくぅ……ズブズブってきたぁ……隊長\nのバキバキに勃起したオチンポぉ……はっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「くっ、ひぃうっ……あ、熱い……それに硬い、ですっ……んんっ……すごい\n、中でビクビク震えてる……あっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、あはぁ……隊長のオチンポ、すごい……熱くて、私のオマンコとろけち\nゃいますぅ……んんっ、あぁっ……気持ちいい、ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁっ……は、はい……感じてます……すごく感じてますぅ……挿入\nれられただけで、オマンコ濡らしちゃってますぅ……はぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そう言う隊長だって……いつもより、オチンポ大きくなってませんか……？\n　中が、すごくキツくて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「これも水着のおかげ、ですか……？　それならよかった……です……んっ、\nあぁっ！　お、奥、グリグリしないでくださいぃ……くひぃっ、いぃンっ……\n！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……嬉しいです……隊長に喜んでもらえて……興奮してくれて\n……最高に幸せですぅ……んっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ……！　んんっ！　いいですよ……隊長の好きなように動いて\nください……私のオマンコは隊長のものですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ！　そ、そうっ、ですっ……私のオマンコで、いっぱい気持ちよく\nなってください……！　あっ、あんっ……はぁあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひぃっ！　ひぃんっ……！　な、中がゴリゴリ擦れてるぅ……オチンポでか\nき回されてぇっ……んっ、ンっはぁっ！　感じちゃうぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ！　あっ、あひっ！　すご、いぃぃっ！　硬くて、ぶっといオチ\nンポが……中で暴れまわってぇっ……オマンコおかしくなっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひゃうっ、うぅんっ……はぁ、はっ、はいぃ……好きぃ……激しくされるの\n好きです……隊長のオチンポぉ、大好きですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あひぃいっ！　また大きくなったぁ……奥に当たって……くひぃっ！\n　ひぃんっ！　はっ、あぁあっ……激しいぃっ……いぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はひぃ、気持ちいぃれす……はっ、んはぁっ……オマンコ気持ちいいっ！　\nすぐイッちゃいそうです……んっ、ンはぁっ！　あぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んはぁ……た、隊長も……ですか？　隊長も、気持ちいいですか……？　あ\nぁ、はい、わかります……オチンポが喜んでるのわかりますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁんっ……い、いいですよ……出してください……私のオマンコに、隊長\nのザーメン……たっぷり中出ししてくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ……お、奥です……一番奥で、出してほしいですっ……そうです、\n子宮に大好きな隊長の精液を注ぎ込んでくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃっ！　ひっ、ひぃいいっ！　はぁ、は、激しいっ……オマンコ\n痙攣してるっ……あぁ、このままじゃ私が先にイッちゃいますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ンっ、んんっ……！　イ、イク……もうダメっ！　イッちゃう……あっあっ\nあっ……イ、イクイクイクぅぅぅうぅうぅぅうぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっあぁぁぁぁぁっ！　んっ、あぁぁぁっ！　で、出てるぅぅっ！　隊長の\nザーメンがぁぁ……オマンコに流れ込んでくるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひぃっ、あぁぁっ……中出しぃ……ザーメン中出しされながら、イクぅっ！\n　中出しアクメしちゃってますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、ひぃうっ……んんっ……あぁ、好きぃ……隊長に中出しされるの好き\nぃ……んっ、まだいっぱい、出てるぅ……はぁ、あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ……嬉しい……隊長……いっぱい興奮して、いっぱい精液出してくれ\nて……オマンコすっごく幸せぇ……んっ、んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ……隊長のオチンポ……射精したばっかなのに……まだ全然硬い…\n…んっ、そうですよね……一回出したくらいじゃ満足しませんよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、あんっ……抜かずに、そのまま二回戦だなんて……さすが隊長、です\n……あっ、あぁあっ……んんっ、オチンポぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あれだけ射精したのに……ガチガチに勃起したままで……あぁっ、とっても\n素敵です……んっ、はぁ……隊長ぉ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「い、いい、です……気持ちいい、ですぅ……はぁあっ……オチンポで突きま\nくって、くださいぃ……あっ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「私のオマンコでぇ……オチンポしごきまくって、隊長も気持ちよくなってく\nださい……あ、あんっ……そうです、その調子で……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁっ！　カリが擦れてっ……んっ、子宮にも当たってぇ……！　\nはっ、はひぃ……イッたばかりだから、感じちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長も……またすぐイキそうなんですか？　あぁ、嬉しいです……私も\n同じです……んっ……一緒に感じまくってくださいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ！　あっ、あふぅぅっ……んっ、ンンっ……お、奥ぅ……いい、気持\nちいいっ……はぁ、あぁっ……あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「こ、声出ちゃいますよぉ……こんなの……気持ちよすぎてぇ……はっ、あぁ\nっ……隊長だって、息荒くなってますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっあぁん！　ま、待ってください……生意気って……ひゃうっ！　くっ、\nくひぃ……いきなりそんな乱暴に動かれたら……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「オチンポすごい！　お、おぉ……オマンコが気持ちよくなりすぎて……頭が\n真っ白になっちゃう……はっ、はあぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はっあぁっ！　あっんっ、あぁんっ！　感じちゃうっ……！　隊長の\nオチンポで敏感なオマンコずぽずぽされてぇ……んっ、ンぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひぃいっ、はひっ……！　おっ、おおっ……おくぅっ、すごっ、いいっ……\n！　はっ、はぁあっ……んおおっ……おほっ、んほぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ら、らめっ……イ、イクぅっ！　イッちゃうっ……またイカされちゃいます\nぅぅぅっ！　ひぃ、はひぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はひっ、ひっ、ひぃいいっ！　しゅごいっ……オチンポしゅごいぃぃっ！　\nお、おくぅ……がつがつ当たって、子宮が揺れちゃってるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、あぁあんっ！　た、隊長も……イキそう、ですか？　は、はいっ\n……いつでも出してください！　あっ、あひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んほぉぉっ！　おっ、おっおおっ……だ、出してぇ！　私のオマンコ\nぉ……隊長のザーメンでまた満たしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ぜ、絶対にイっちゃうっ……！　中出しアクメしちゃいますっ！　はぁ、あ\nはぁあぁっ……気持ちよすぎて、今出されたらぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ！　イキたいぃっ……隊長と一緒にイキたいですぅっ！　お願\nいですから、は、早く……！　も、もう限界っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁぁぁっ！　あっあぁぁぁぁっ！　すごぃっ、すごっ……んっ、\nおぉ……隊長のオチンポぉ……！　オチンポでイかせてぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ザーメン、ザーメンっ！　隊長のオチンポミルク欲しいっ！　私のオマンコ\nに出してくださいぃぃぃっ！　あぁっ、あぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204220" ]},
		{"command":[ "WAITINPUT" ]},

