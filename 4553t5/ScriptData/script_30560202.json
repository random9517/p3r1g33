		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひゃぁあぁぁぁっ！　あっ、あぅぅっ！　どうして、オチンポ抜けて……あ\nっあっ……ひぃあっ、あぁぁぁぁんっ……！」", "NORMAL" ]},
