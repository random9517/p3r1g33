		{"command":[ "PLAYVOICE", "v2_056_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ふふっ……見てください……精液まみれで、ベトベトになってますぅ……ほ\nら、白い糸引いて……んふぅっ……あぁ、気持ちいい……」", "NORMAL" ]},
