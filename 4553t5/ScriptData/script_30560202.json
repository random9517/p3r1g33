		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっはぁぁぁぁぁぁっ！　はっ、あぁっ……あぁんっ！　な、中にっ……中\nに出てるぅっ……！　隊長のザーメン出てるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひぃいっ、いぃんっ！　オマンコの、奥ぅっ……子宮に精液が……ドクドク\nって、ぶちまけられてるぅっ！　んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はっ、ひぃああっ……あふっ、うぅんっ……あ、熱いっ……中出しザーメン\n熱くてぇ……ヤケドしちゃいそうですぅ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁっ……は、はひっ……すごいっ……またいっぱい……出てるぅ\n……ザーメンがドクドクいってるぅ……あ、はぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あっあんっ……さっき中出しされた精液が押し出されて……んんっ！　あぁ\nっ……二回目なのに……こ、こんなたくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長……はぁあっ……絶対、妊娠しちゃいます……んっ……ひぃあっ、\nあっ、あふっ……絶対に孕んじゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ……だって、本当に幸せなんです……大好きな隊長に、こんなに愛\nしてもらって……嬉しくて顔がとろけちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んっ……隊長、満足していただけましたか？　私のオマンコ……楽しんでい\nただけましたか？　はぁ……はぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204308" ]},
		{"command":[ "SETIMAGE", "0", "still_00005602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「このザーメンの量が答え……ですか。ふふっ……嬉しいです……全部受け取\nりました……隊長の気持ちも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、隊長……お慕いしてます。私をずっと側においてください……いつで\nもご奉仕します……もちろん心を込めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_0204310" ]},
