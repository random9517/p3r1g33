		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　ひっ、はひぃぃっ！　ザーメンかかちゃうっ……んんっ、はぁ\nっ……あぁっ……あ、あつ、い……んぁっ……」", "NORMAL" ]},
