		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「へへぇー、センパイ……来ちゃいましたねぇ？　男と女の愛の巣……ラ・ブ\n・ホ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00016503_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「今日はもう、ずーっと楽しみにしてたんですよ？　誰にも邪魔されずにぃ、\nいーっぱい可愛がってもらうんだーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「楽しみすぎて……そのことをずーっと考えてるだけでぇ、もう……ジュース\n……じゅわじゅわ出まくりでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ……口で言うより、見てもらうのが一発っスよねぇ？　てことでぇ…\n…はぁい……失礼しまーす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、ほらぁ……センパイ……こーいう大股開き……やっぱりグッと来るん\nじゃないですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016503_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふふっ……視線がど真ん中に集中してるっスねぇ？　中身……気になります\nよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「それじゃあ……こうしてぇ……ぴらっ……んふふっ、ほぉら……センパイの\n大好きな、オマンコ……くぱぁっ……ですよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「どうですか……割れ目のとこから、やらしぃ汁が……じゅわぁって……滲ん\nでるの見えるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「もう、あーしのオマンコはぁ……センパイのチンポをずぶってして欲しくて\nぇ……ずーっと発情しっぱなしなんですよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「こうして開いてたら……ヨダレのマン汁……どんどん溢れてくるの分かるっ\nスよね……？　ねぇ、センパイ……チンポ欲しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「早く……あーしの、ドスケベ発情オマンコにぃ……センパイのぶっといチン\nポっ、ずぶってハメて……奥までかき回して下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そのビンビンに勃起した……絶倫チンポで……あーしの子宮にドピュドピュ\n中出ししてっ、いっぱい種付けして下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁんっ！　あぁっ、太いチンポっ……ズブって来たぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んくぁぁ……はぁぁ……あふっ、ヤバいっス……センパイ……最初の一ハメ\nだけで、今……軽くイっちゃったっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほら……見て下さい……お腹のトコ……サキュバスが気持ちいいと浮かぶ淫\n紋……光ってるでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「みっちり埋まってるセンパイのチンポが良すぎて……んっ、もう……反応し\nまくりになってるんスよぉ……あふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふぅ……この奥まで届いてる感じ……んくぅっ、じっとしてるだけでもヤ\nバいっスねぇ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でも、そろそろ動きたいんじゃないですか？　んふふっ……いーですよぉ？\n　あーしに遠慮しないで、チンポ……かき回して下さい……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あぉっ、はぁんっ！　あぁっ、来てるっ……！　センパイの\nチンポピストンッ！　あぁっ、始まったぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぅっ、んくんっ、あぁっ、めっちゃ……グリグリされるのいいっ！　オマ\nンコッ……じゅくって……かき混ぜられるっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、いいっス……もっと本気でチンポッ……突きまくって下さ\nいっ……んぁぁっ、ズンって子宮に……響くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこっ……いいですぅっ……！　あはぁっ、パンパンってっ……エ\nロい音っ、しまくってますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あくぅっ……深くめり込んでぇっ……！　ヒダヒダ……一つ一つがっ、いっ\nぱい擦れてぇっ……んふっ、くぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あーしもっ、負けてらんないっスっ……んぅっ……！　ほら……こうして、\nんぁっ、オマンコ……キュンって絞り込むのっ……どうスかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぁふっ……あぁっ、チンポの出し入れに合わせてっ、しっかり締め付ける\nとっ……はぁんっ、淫紋が疼きますっ、あくうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ひっ、あひっ……！　あぁっ、声……出ちゃうっ、オマンコ\n気持ちいいっ、センパイのチンポっ……気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「今のトコっ……ヤバいっス。続けてグリグリして下さいっ……あひぃっ！　\nそれっ、あぁっ、あぉぅっ！　チンポ効くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、はぁんっ、あぁぁんっ、そっちがそうなら……あーしも……ん\nっ、くっ、んふんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふっ、声……出ちゃいましたねぇ？　センパイの……喘ぎ……結構色っ\nぽいっスよ？　んぁふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「もっと入り口のトコ……カリ引っかかるようにさせて……あっ、それですっ\n、そ、それぇ……あっ、ぱちゅんってさせてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「しっかりチンポっ、絡みつかせて……激しくっ……中……刳りこむようにっ\n、あっ、あぁっ、ぐちゅぐちゅっ……するっスぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁっ、はぁぁんっ……この角度じゃないとっ……届かない場所っ\n……これがっ、たまらないんっス……くぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、また……マン汁溢れちゃうっ……こんな続けてされたらっ\n……あっ、また潮吹きもすぐっ……しそうっ……はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あんっ、んくぁっ……センパイもっ、そろそろ……ヤバいっスか？　んっ、\nあぁっ、んふっ、じゃあ……このままスパート掛けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あひぁっ！　そうっ、あぁんっ……もち……このまま……中に出してっ……\nセンパイとの赤ちゃん作っちゃいましょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あんっ！　ズコズコ来てるっ！　センパイのチンポっ……本気でか\nき混ぜてぇっ……あーしもっ、もうっイキますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あくぅぅぅんっ！　出てっ……はぁぁ……中出しぃっ……！　オマンコっ…\n…どぷんってっ……受精してますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅぅんっ……はぁぁ……チンポ……脈打って……流れ込んでくる\n感じ……すごくイイ……オマンコ……熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……止まっちゃった……んっ、たっぷり中出しし\nてもらっちゃった……えへへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「めっちゃ良かったっス、センパイ……やっぱり生チンポの種付けセックス、\nサイコーっスね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ……はぁ……んふっ、センパイ……どうしました？　なんでって顔して\nますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「とりあえず、一発出して休憩……とか思ってます？　いやいやー、それはま\nだまだ先の話っスよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふふぅ……がっちりホールドして……離しませんよぉ？　抜かずの連戦…\n…始めちゃいましょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほら……むちゅって……オマンコの肉が……しっかりチンポにへばりついて\nます……この状態のまま、ずーっと平気でいられます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「無理ぃ？　ですよねぇ……じゃあ、もうすることは一つ……また、チンポ…\n…動かしちゃいましょ……はぁんっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、そうっス……はぁ……ほら、また……淫紋が……テラテラ…\n…光ってます……んっく、はふっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほらほら、チンポ頑張ってっ……フレー、フレー、センパイのチンポッ！　\nもっと、オマンコッ……ぐちゅぐちゅしちゃえっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふぁっ、いいっスよぉ……おっぱいも触ってぇ……このプルプルの膨らみ\nっ……遠慮なく揉みまくって下さい……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁむ……んちゅぷっ、キスも……いいれふっ……んちゅぅ……舌ぁ……れ\nろれろ、させひゃいまひょ……んれる、れりゅ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そしたらぁ……また、オマンコ……ずぶって……はぅっ、んんっ、気持ちい\nいとこっ……繰り返されてぇっ……はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あぁっ、ぐちょぐちょっ、ズコズコっ……！　やらしい音っ、鳴りまくって\nますぅっ！　オマンコいいっ、突きまくられるのすごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふぁっ、んちゅぷぅっ……あーしも……センパイの乳首……イタズラしち\nゃいますよ……んっ、コリコリになってるの……くすぐってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「れろ……ぺろ……んちゅぷっ、ねちっこいキスもぉ……唾液……いっぱい交\n換してぇ……あーしの乳首も寄せて……ツンツンしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、あぁっ、一つに溶けてくみたいな感じぃ……ぽーっとして\nぇ……何も、考えられなくなるぅぅ……んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁぁ……チンポぉ……もっとチンポくらひゃい……あぁぁ……またイキそ\n……オマンコ……我慢れきなくなってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこっ、ずっと弱いとこぉっ……！　あぁ……はぁんっ、もっとし\nてっ、あっ、センパイのチンポっ、上手すぎますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
