		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ここは……確かに、大きな空洞がありそうだな……！　よし、メンバーを集\nめろ、一気に掘り起こすぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
