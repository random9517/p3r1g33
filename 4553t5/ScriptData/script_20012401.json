		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「…………異分子反応ヲ検知……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021820001" ]},
		{"command":[ "SETCHARA", "0", "char_00021801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うん？　今、何か言ったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820023" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
