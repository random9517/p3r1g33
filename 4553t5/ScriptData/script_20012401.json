	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おい、そっちはどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820001" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「もうすぐ終わりそうですが……多分空振りですね」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チッ……ここも駄目か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820002" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｂ" ]},
		{"command":[ "SETTEXT", "「せめて、もう少し範囲が狭まれば、効率もよくなるんでしょうけど……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「全くだ、そっくりそのまま上に聞かせてやりたいぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820003" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｃ" ]},
		{"command":[ "SETTEXT", "「一体、どのような指示だったんですか？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「どうもこうも……『この辺に大きな力が埋まっているから掘り出してこい』\n……それだけだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820004" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「この辺って……この一面の遺跡全体ですか……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「まだ、この遺跡の全容もどうなってるか分からんというのに、とにかく掘れ\nだぞ！？　私の爪は、こんなことの為にあるんじゃないんだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820005" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｂ" ]},
		{"command":[ "SETTEXT", "「一応、最深部に近い所には来てると思いますが……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そうであって欲しいがな……正直これだけ手探りだと、効率も何もあったも\nのじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820006" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｄ" ]},
		{"command":[ "SETTEXT", "「隊長っ！　上層部からの連絡が入りました。お繋ぎしても……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「連絡？　何か、具体的な指示が出たのか？　聞かせろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820007" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｄ" ]},
		{"command":[ "SETTEXT", "「は、はいっ、こちらで……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「やっほー、何か見つかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010021820001" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「は……いえ、今のところはまだ何も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820008" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「えぇぇー、遅い～。そこは、パーッと掘って、ガーッと見つけて、いい報告\nしてくれないと～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010021820002" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「は、はぁ……しかし、遺跡は広大で、もう少し何か目星のようなものがない\nと中々……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820009" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だからー、その辺をぐわーっと掘り起こしたら、大体何か出るでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010021820003" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ぐわー……い、いえ、ですから、より具体的な箇所を絞って頂ければ我々と\nしても、もう少し作業がやりやすく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820010" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だから、その辺だってば！　何かあるのは分かってるんだから、それっぽい\nのを見つけてドーンだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010021820004" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「あっ、ねーねー聞こえる？　それ終わったらさ、帰りプリン買ってきて！　\n安いのじゃなくて、ちゃんとクリーム乗ってるやつね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010021820001" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「えーズルいー！　じゃあ、あたしもー！　とりあえず２つ確保絶対ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010021820005" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「プリン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820011" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゴルドノーバ" ]},
		{"command":[ "SETTEXT", "「とにかく、ちゃっちゃーっといい報告シクヨロー♪　それじゃねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010021820002" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ……ちょっ……あのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820012" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｄ" ]},
		{"command":[ "SETTEXT", "「通話……終了しました……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「くっ……！　何なんだ今のはっ！　現場の状況も知らないで適当な命令ばか\nりしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820013" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｂ" ]},
		{"command":[ "SETTEXT", "「お察しします……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「しかもプリンて！　コンビニにお使いに行ってるのとは訳が違うんだぞっ、\n訳がっ、あー全くもうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820014" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｅ" ]},
		{"command":[ "SETTEXT", "「隊長ーーっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「今度は何だっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820015" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｅ" ]},
		{"command":[ "SETTEXT", "「遺跡の奥の方に、岩盤の脆い所がっ、中に何かありそうですっ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「何っ！？　すぐに行くっ！」", "NORMAL" ]},
