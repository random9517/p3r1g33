		{"command":[ "SETNAME", "部下Ａ" ]},
		{"command":[ "SETTEXT", "「た、隊長っ……これはっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「出た……これが……求めていた……黄金のピラミッド……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820020" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｂ" ]},
		{"command":[ "SETTEXT", "「素晴らしい光沢です……とても古代の遺跡とは思えない位……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それだけ、当時の技術の粋を集めて作られたものなんだろう。よし……とり\nあえずは連絡だ。この成果があれば大手を振って戻れるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820021" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｃ" ]},
		{"command":[ "SETTEXT", "「プリンも買って帰れますね！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ああ、奮発して一番高いやつでも買ってやろうじゃないか！　お前たちにも\n１つずつだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820022" ]},
