		{"command":[ "PLAYVOICE", "v2_156_010021820019" ]},
		{"command":[ "SETCHARA", "0", "char_00090101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "部下Ｅ" ]},
		{"command":[ "SETTEXT", "「はいっ……！」", "NORMAL" ]},
