		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「何だ、どうした、妙な声を出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010021820025" ]},
