		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、行くのだ！　タヌキ像を手に入れるのはこの時間帝国なのだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115190002" ]},
