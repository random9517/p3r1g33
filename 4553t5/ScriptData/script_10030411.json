		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵" ]},
		{"command":[ "SETTEXT", "「ち、違います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115190004" ]},
		{"command":[ "SETCHARA", "0", "char_00092401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵" ]},
		{"command":[ "SETTEXT", "「自分じゃないです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115190005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、仲間割れか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なんじゃ！？　余に向かって攻撃をした愚か者がいるな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵" ]},
		{"command":[ "SETTEXT", "「そ、そんなことは！」", "NORMAL" ]},
