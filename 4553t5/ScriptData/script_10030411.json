		{"command":[ "SETCHARA", "0", "char_00092501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵" ]},
		{"command":[ "SETTEXT", "「あいたっ！　だ、誰だ私を攻撃したのは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115190007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだ？　なにが起きているんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「味方同士でケンカを始めちゃったみたいだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「統率が乱れた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだっていい、チャンスだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「時間帝国側の陣形が崩れた隙に、ルナテミスたちが攻撃を仕掛ける」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……って、ちょっと待って、全力すぎ！　僕も巻き込まれないうちに退散し\nないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ！　待ってまって、適当な岩陰へ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああもう、こうなったら撤退するぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くそっ、次はこうはいかないからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おう！　またぶっとばしてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115190005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「急に仲間割れなんかはじめて、いったいどうなっているのか、こっちが聞き\nたいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも、これでタヌキ像をもらえるんでしょ？　よかったじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ところで鳳雛のやつはいったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0191" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「やあやあ、ここだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様……って、服はどうした！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いやあ、たまにはガス化能力を使わないと、設定を忘れられそうでねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「はっはっは。どうだった？　兵士たちに変装して内部からひっかきまわした\n僕の作戦」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「大成功だったでしょ？　いやあ、さすが名探偵」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それ、名探偵と関係あるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「無事に時間帝国を撃退した僕たちは、三度正義へとやってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190011" ]},
		{"command":[ "DISPCHARA", "0", "true" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほむら！　宝箱を持つタヌキ像を譲ってくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん？　ああそうだな。それじゃあ約束通り、ほら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115190001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ありがとう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それにしても、なんでこんなのを欲しがるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115190002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「前はもっと普通のタヌキ像だったのに、急にこんなにキモいタヌキになるな\nんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115190003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うーん、キモい。見れば見るほどキモい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020115190004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そんなにキモいキモい連呼しなくてもいいだろう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まあまあ。とにかく、目的のものは手に入ったんだ。これでカツマを迎えに\n行ける！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115190004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな。急がなければ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115190009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そして、受け取ったタヌキ像を抱えて、大急ぎで次元管理統制局へと向かっ\nたのだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190012" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「この事件も、いよいよ解決に向かおうとしている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190013" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}