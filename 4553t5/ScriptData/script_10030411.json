		{"command":[ "SETCHARA", "0", "char_00092501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「戦況は圧倒的時間帝国の有利。僕たちにはカツマ隊長がいない分、そのバフ\nがないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「となれば、僕もそろそろ次の手を打たないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115190003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
