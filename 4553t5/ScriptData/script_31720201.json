		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「えっ？　このメイド服でご奉仕をしてほしい、ですか？　はぁ……そうです \nね。メイドさんは、ご主人様に奉仕するのがお仕事……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「でしたら今は私もメイドですから……。あなたの希望を叶えるべきだと思い \nます。でも……ご奉仕といっても何からすればいいのか……。んっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「む……胸でパイズリをしてほしい、と？　あ……、わ、わかりました……。 \nですが私はパイズリという言葉を聞いたことがはじめてで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……ひとつひとつ、教えていただけますか？　であれば、メイドエルフとし \nて、誠心誠意お尽くしします。パイズリ？　でご奉仕させてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ええ、と……。まず、ご主人様によく見えるように、胸を露出……。服をは \nだけさせるのですね。はい。その後、ちんぽを挟みこむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……乳房は柔らかさ、温かさが長所だと思うのですが……。谷間に挟んでい \nいのですか？　膨らみに直接ちんぽを置いた方がいいのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ、なるほどです。そういうことなのですね。谷間には、ちんぽを置くだ \nけで……左右、両側から膨らみで圧迫する、押し潰す……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それを自分でするのではなく、メイドエルフにやらせることで……支配して \nいる感、大切に奉仕されているというイメージで興奮する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……ニンゲンの性への知識はとてもすごいですね。私には、想像もできない \nことを次々に教えてくれる……。もっと教えてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ここからはどうすれば……。……あ、胸の膨らみでこう……上下左右にちん \nぽを刺激するのですね。パイズリのズリは、擦る、という意味でしたか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「おっぱいで擦る、ゆえにパイズリ……。わかりました。自信はありませんが \n努力します。……ん……こ、こうでしょうか。んっ……こ、う……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「もっとむぎゅううっとちんぽに胸を寄せて？　はい……。かなり力を入れて \nも平気だから、ガンガンシゴいてほしい……？　だ、大丈夫でしょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「シゴく、というのは相当力をこめる印象ですが……。ニンゲンのちんぽはそ \nれにも耐えられると？　んっ……これくらいの強さですか？　もっと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んんっ！　んっ！　これくらい……？　え、もっと！？　ガチガチに勃起し \nて硬くなっている時は、柔らかな胸ではビクともしないと？　すごいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンのっ、んっ、ちんぽは強いの、ですね……っ。それならもう少し… \n…強めにこすってみましょうか。んっ……、これくらいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ♪　気持ち良かったんですね。ちんぽがピクピクって反応してくれました \n……。力加減はこれくらい、と……しっかり胸に刻みましたので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「パイズリを始めさせていただきます……。ん……んん、んんっ、んんん…… \n♪　はぁ、はぁ……左右の胸を、上下に動かす……。っん……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「え、上手……ですか？　良かった……♪　それではこのまま……、と、隊長 \nさん……？　私の乳首を触っていますか？　あっ、そ、その……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「くすぐったくて……、んぅっ。パイズリをする時に影響が……んんっ。これ \nには一体どういう意味が……？　っぁっ……、つまんじゃだめです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっ、あっ……。ご奉仕するメイド自身の性感を開発、して……メイ \nドが感じることで、その快感がちんぽにつたわる……。なるほど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そ、それではそのまま私の乳首……をお願いします……？　っんん……！　 \nは、はい……ムズムズします、乳輪も、乳首も……んぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ピリ、ピリ、と細かく電流が走るような……ああっ♪　い、いけません…… \n！　ご奉仕する側の私が隊長さんより気持ち良く、なるなんてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そんな……の、はぁんっ、そんなの、い、いやらしすぎます……！　っぁっ \n……♪　乳首が勃起してきた？　ちんぽのようにですか？　んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ほ、本当です……！　ガチガチのニンゲンちんぽと同じ、ように……ああっ \n、乳首っ……私の乳首も硬く、長くなって……はぁ、はぁはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「くりくりつままれて、ひっぱられて……あああっ、疼きます、気持ちい、い \n……っ。乳首気持ちいいです……。っんっ……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「わ、たしも……っ。もっとパイズリで、隊長さんを喜ばせないとっ。つ、つ \nり合いが、取れていません……私の快感の方が多すぎますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ♪　ぁっあっぁっあっ、気持ち、いい……気持ちいいぃ……っ！　あっ \n……あっ、隊長さんのちんぽもピクッ、ピクッてずっと震えてるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私たち……あんっ、今、快楽を……快感を共有できている、ということです \nよね……っ、あっ、では感じてください……私の胸の高鳴り、とっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「乳首の気持ち良さ……あっぁっぁっ♪　んッ……でも、隊長さんのちんぽの \n気持ち良さも、私の胸に伝わっているのなら……あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「この、もどかしい感覚がそうなのでしょうか……っ♪　あっ、ぁっ……！　 \nちんぽ、火照ってます、とっても熱くなって……反り返っていますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私、の乳首もぉ……！　あっ♪　硬く尖って……あっぁっ、はぁんんっ♪　 \nおそろい、ですねぇ……っ。パイズリってすごすぎますぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んんんっ……。胸……こねくりまわしすぎて、……あっ、どんどん柔らかく \n、なって……っ。ちんぽにぴったりくっついてます……。っぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「乳首はこんなに硬い、のにぃ……あっ、乳房はふわふわのトロトロになって \n……。っん……♪　あぁ、精液がびゅるっと飛び出してしまいそうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「気に、しないでください……っ。私も……、あんっ、私もぉ……！　さっき \nからずっと乳首、乳首がおかしくなりそうで……んぁあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぅううっ♪　あううぅうっ♪　精液っ……、ニンゲンの精液を胸に浴びな \nがらぁっ……乳首でイキます、いじられてイキますぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふぁああっ♪　あぁっ、あぁああああっ……！　びゅるっ、びゅぶるぅっ、 \nびゅぅうって胸の谷間にっ……真っ白な精液がほとばしって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ、ふ……っ。溢れちゃいます、あっ……あっぁっ、すごい量です……！　 \n私も乳首がジンジンして……！　ゾクゾクして、あ、あああああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「何も考えられません……、うぁああっ♪　ヌルヌルした精液、ニンゲンの精 \n液……！　あっぁっ、あんまり興奮するとメガネが曇っちゃう……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「メガネが、ズレ落ちそうなくらい……激しくちんぽが脈打って……！　どぴ \nゅっ、どぷってまだ……続けて精液を撃ち出しています、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そんなに私の胸……心地良いと思ってくださったんですね……っ。あっ、私 \nも……私もすごく気持ち良くて……あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はい！　はいぃっ、落ち着くまで、好きなだけどうぞ……！　……えっ？　 \n根元から精液を絞り上げてほしい？　わ、わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　んくぅうっ、ん～っ……♪　あっ♪　びゅるって最後に大き \nく精液が飛び出して……！　ふぅ、ふぅ、これで一段落……ですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あとはお互いの身体が落ち着くのを待てば……。……と、安易に考えてしま \nいましたが……。あ、あの……ちんぽがまったく落ち着いていません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「むしろ、……あっ♪　隊長さんが腰を、揺らすので……。んぁっ、精液でち \nんぽがすべって……。硬いまま、で……ですから……。そ、そのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「乳首でイッて敏感なままの私の胸も……。っぅ……♪　ソワソワして、ドキ \nドキして……。ふぅ、ふぅ、汗をかいてきました……。ん、ん、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「隊長さん……。もしかして、このままパイズリを続けてほしい……のですか \n？　やっぱり……！　そうではないかと思っていました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「かまいませんよ。メガネエルフメイドですから……。ご要望にお応えしてこ \nそです。それに……私自身、どうしてもやめるのが名残惜しくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「もう少しだけ、ちんぽをお預かりしてもいいですか？　絶対に気持ち良くし \nます。……見ていてください。いきますよ……！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あぁっ……♪　んぁっ……あっ、ぁっ、あぁうぅっ♪　パイズ \nリも……多少は上達したでしょう？　それに……精液が潤滑油になって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の未熟な技術を、補ってくれています……。んぅっ♪　ほらぁ……ほら、 \nわかりますか？　さっきよりもずっとスムーズです……！　っんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ん、はぁっ……はぁんんっ、んん……♪　あぁ、んん、んんっ、んん……♪ \n　　なんとなくコツが掴めてきた気がします……。っぁっ、ん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……あ♪　隊長さん……っ、また乳首を刺激してくださるんですね……っ。 \nあっ♪　もう一度、二人で気持ち良くなれて嬉しい、です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ッぁ……♪　あぁあっ、精液をローションがわり、にぃ、パイズリっ……。 \nあっ♪　乳首を触るあなたの手も……あっ、ヌルヌルしてすごいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あぁあっ、はぁあっ、あぁ……♪　はっ、はぁっ、ん～っ、んん \n……♪　こうして見ると、本当に……あなたのちんぽは大きいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンがみんなこうではない、と思うのですが……。んっ♪　元からこん \nなに大きい、のですか？　それとも……私の胸に興奮して？　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私のせい……だったらいいのに……♪　んっ……。ふふふ。私の胸が大きい \nのは……いつのまにかですが、この胸は、あなたのものですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……きゃっ♪　すごいです、膨らみで抑えきれないくらいにちんぽが膨らん \nで……長くなって……っ。こ、これはまた精液が溜まったということですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「もしそうなら……、出していい、ですよ……♪　あっ、違いますね。私が… \n…出して欲しい、です……♪　だって……っ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203219" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ま、また乳首でイッてしまいそうなんです……！　一緒にがいいんです、で \nすからイッてください、ちんぽから精液出して……出してくださいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……！　きゃあっ、出てます、出てますぅっ……！　ニンゲン \nの精液っ……あっ！？　二回目なのに勢いが衰えていませんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「なんでこんな、に出るんですかぁっ……？　胸で圧迫して、刺激して……こ \nすっただけなのに、びゅるぅっ、びゅるって白い噴水みたいに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっあっ……！　だ、めです……溢れちゃうっ……♪　ぎゅうって \nちんぽを押し潰さないと……！　っあ……！　ビクンビクンって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「新鮮で健康な精液が、何度も私の胸の中に……♪　っあぅっ……、ちんぽっ \nて、心臓みたいにドクンドクン震えて、不思議ですね……♪　あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ……、あたたかい……♪　んんんっ……。一度目に出した精液の上に、 \n新しい精液が重なって……。私の胸、マーキングされてしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「見えますか……？　この胸はあなたのもの、だって……はっきりくっきり刻 \nみ込まれてしまいました……♪　あぁ、むせかえるような香り……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……ニンゲンの精液に、ここまで順応してしまうなんて……。私はメガネエ \nルフとしてちょっとおかしいのかもしれません。ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたに頼まれたことをきちんとこなして、メイドとしてご奉仕できて…… \n。それに達成感を覚えているのは本当なんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203308" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の胸で、あなたが少しでも癒されてくれたら……心地よくなってくれたら \n、満足です。それは音楽を奏でている時と同じこと……なのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「他の方には絶対に見せられない秘密の行為でもあって……。はい。それに、 \nときめいてしまっている自分にも戸惑っています……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203310" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んっ？　た、隊長さんっ……！？　あッ……い、いけませんよ、そっちは顔 \nで……！　っあぁああっ！？　ひぁっ！？　あっ、んぁあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ、ぷぷっ……んぷぅっ……！　せ、精液を飛ばしすぎて……私の顔にかか \nってしまっていますっ……。あっ、熱い……それに強い臭い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ん、はぁ……♪　これがニンゲンの精液の臭い……。なんとなくは知ってい \nましたが、独特な、強烈な臭いです……。んっ！　ンッ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「っあ……♪　メガネにこってりとした精液がこびりついて……。っんん…… \nっ。ま、前が良く見えません……っ、あああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「困ります……っ。ですが、一度発射してしまったものを戻すわけにもいきま \nせんから……。わかりました、お気の済むまでどうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ……ああああっ♪　真っ白……！　私の視界が精液の色と臭いに染めら \nれていくぅ……。ドロドロの、くさぁい世界に変わっていく……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふぅううっ……♪　よ、ようやく出し終わりましたか……？　い、いえ。メ \nガネのことはいいんです。洗えば綺麗になると思いますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203407" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ただ……隊長さんが、私のメガネに精液をかけることがクセになってしまっ \nたら大変だと思いまして……。だって、すごい喜びようでしたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そんなに面白かったですか？　ええ……たまにならいいんですよ？　ただ、 \n毎回メガネにかけられたら……普段も思い出してしまいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203409" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「隊長さんへのご奉仕のこと……。ですから、たまに、で……。えっ、また次 \nもかけたい？　もぉ……本当に困った人。たまに、ですよ……！」", "NORMAL" ]},
