		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あの……私に頼み事がある、というのは一体どんなことなんでしょうか？　 \n協力出来る事でしたら、ぜひお力になりたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "0", "CENTER", "0" ]},
