{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「来ました、ですね……済みません、わざわざ呼びつけるようなことをして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00000503_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まぁ、ここに呼び出したということは、薄々どういうことか……お分かりじ\nゃないかと思いますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「その、なんです……？　ここ最近は、色々と貴方にお世話になっている機会\nも増えましたし……私の力を更に強化するという意味もありますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00000503_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「で、ですからっ……まぁ、ちょっと位は……その、ご、ご奉仕というんです\nか？　して、あげなくもないかな……なんてことをですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほ、ほら……口でするアレです！　分かるでしょうっ、だから……フェラ…\n…フェラチオですっ！　皆まで言わせるなですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00000503_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「分かったなら、ほら……ペニス……オ、オチンチンをっ……出すですよっ…\n…う、うぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303106" ]},
		{"command":[ "SETCHARA", "0", "char_00000503_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それにしても……いざ、改めて目の前に見せつけられると……流石に生々し\nいですね……ウチにはないモノ……少しグロテスクさを感じます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「しかし……最初からこれだけ勃起しているというのは、どういうつもりなん\nです？　もう、されるものだと思って反応してるんですか、変態ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まぁ……興奮しているようですし、始めることに問題はなさそうですね……\nそれじゃあ、やりますよ？　いいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、あぷ……ちゅぱっ、ぴちゃ……んちゅ……んんっ、うぅ……やっぱり\n、臭くて……微妙な味がします……ちゅぷ、れろ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これは……決して美味いものではないですよね……りゅぷっ、美味しい、美\n味しいなんて……とんだ嘘っぱちもあったものです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、何ですか。ほんの少し、動画を参考にしただけです。ウチが研究したら\n悪いですか？　ぶっつけ本番の適当にされるより、ずっといいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ん……ふっ、くぷっ、分かったなら……大人しくしていて下さい\n。ちゃんと、上手くやってみせますから……ちゅぱ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……すんっ、くんっ……すぅぅっ、んはぁ……うぅ、匂いが強すぎま\nす……こんなくさいモノ……喜んで嗅ぐなんて気が知れません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くんっ、くんくんっ……すんっ、すんっ……んぁぁ……本当に、ありえない\nです……すぅぅぅ……んっ、はぁぁっ、あふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、何ですか？　少し鼻を近づけた位で、問題ありますか？　んっ……匂い\nを嗅ぐのに必死だとか……それがどうかしましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この姿は……普段の時以上に、全体の感覚が鋭敏になっているんです。だか\nら、こんな臭いモノ……嗅ぐのは、自然なことですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「わかりましたか……んっ、りゅぷっ、分かったなら……ちゅぷ、大人しく身\nを任せてやがれです……ちゅぱ……りゅぷ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと、オチンチン……してあげるですから……りゅぽ、んくぷっ、んち\nゅるるるっ、んりゅ……くぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んはぁ……あぷっ、むぐっ……それにしても、大きすぎ……れふ……ウチは\n華奢なんですから……もうちょっと加減して欲しいものです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「分かってますよ……そんな器用なことが出来るわけないのは……じゅぷっ、\nウチが慣れれば……それでいいんでひょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んちゅぷっ、んふぅ……ひっかり咥えて……りゅっぷっ、んぶっ\n、くぽっ、じゅぷっ、んじゅるっ、じゅるっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……腰がビクンってひまひたね……んふぅ……りゅぱっ、これ……そ\nんらによかったれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「分かりまひた……なら……じゅぽっ、ちゅぷっ、もっと続けてしてあげるで\nふ……じゅぽっ、オチンチンの先を……チュウって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ちゅぷっ、ろうれふか……感じるれひょう……ウチのテクニック\nに、りゅぷっ……メロメロじゃないれふか……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……ごまかしても無駄です……オチンチンの先からも……カウパー\n汁が……りゅぷっ、滲み出して来てるじゃないれふか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それとも、全然感じてないと言い張りますか？　ここでやめちゃってもいい\nんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ほら……やっぱり困るんじゃないですか……偉そうに勃起していても、オチ\nンチンはなんとも正直ですね……ぺろ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いいれふよ……ほら、ちゅぷっ、ぴちゃ、れろっ、やせ我慢しても無駄です\nからね……ちゅぱっ、ぴちゃっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぷっ、んんっ、震えが大きくなってます……んりゅぷっ、もう出ますか？\n　出るんですね？　精液……射精しようとしてますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろっ、ぺろっ、びくって脈打って……タマも震えて……匂いも強くなって\nぇ……んはぁぁっ、あぷっ、んむっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さあ、飲ませたいれひょう……いいでふよ……飲んであげまふから……さっ\nさとらふれふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んじゅるるるるるっ、んじゅるぅっ、じゅぽっ、んちゅぅぅぅぅ\nぅぅーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぶぅっ！？　ふぐっ……れてっ、まひゅっ……んっ、くひの中にっ……濃\nいのっ……むぐぅっ、ど、どろってぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぐっ、んっく……こくっ、んんっ……んぁぁ……んぷっ、こく……んっ、\nはぁっ、んちゅぷ……んふうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……んふっ……やっと射精……止まりましたか……。全く……ご奉仕\nするとは言いましたが、ここまで遠慮なく出されるとは思いませんでしたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぅ……んっ、口の中が精液のニオイでいっぱいです……んふぅ……呼吸が\n苦しい……すぅぅ……んっ、はぁぁぁ……んふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……鼻を通り抜けて行くこの感じ……何故か知りませんが、どうにも気\nになってしかたないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「とにかく、気持ちよく出したのは間違いないですね？　ウチの技にやられた\nと……そう解釈しますからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ええ、分かればいいのです。ちゃんと、ウチは特別なんだと……そういう認\n識でいて下さい。いいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「さて……まだまだ、やりたがりなオチンチンは全然満足できてないみたいで\nすね……全く、ウチがしてあげているのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「気持ちよかったから、もっとして欲しい……ですか。ふ、ふん……モノは言\nいようですね。まぁ、そういうことにしておいてやるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それにしても……ちゅぷっ、んんっ、二回目だと言うのに……まるで、サイ\nズが変わらないです……んむぅ……はむっ、くぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぐぅ……顎が……疲れまふのに……りゅぷっ、んんっ……んちゅぅ……ま\nだ精液の味もかなり残って……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「美味しい訳ないじゃないですか……自分で飲めますか？　飲めませんよね？\n　そーいうのを飲ませてるって自覚ないれひょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、りゅぷっ、それを……こうひて……舐めてあげてるんれふら……ちゅ\nぷっ、感謝の一つ位しておきやがれです……りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、ちゅぱっ……すんっ、すんすんっ……んはぁ……あぁ……も、\nもう一回だけぇ……すん、すんすんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あ……べ、別に……匂いが気に入ってるとかじゃないですよ？　臭いものは\n、何となく嗅ぎたくなるっていう……例のやつです……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんな、顔が蕩けてるとか……言いがかりれふから……はむ、んくぷっ、り\nゅぷっ、んっ、じゅぽっ、ちゅぷぅぅぅ……んっ、はぷぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「オチンチン美味しいなんて……そんらこと……ある訳ないれふ……んちゅぷ\nぅ……ここ、んっ、もう少しだけぇ……んりゅ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、ちゅぱっ、ぴちゃ……んんっ、鈴口ぃ……んっ、あぁ……\nまた汁……出してるじゃないれふかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んっ、そうれふ……睾丸も……一緒に刺激してやりますよ……ん\nくぽっ、くぷっ、ちゅぱっ、んぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「れろ……もごっ、んふぅ……コロコロ転がされると、力……抜けちゃうんれ\nひょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「分かりやすいれふ……んちゅ、ほら……そっちこそ顔がだらしなくなってま\nふよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いい大人が、オチンチンを吸われて、ビクビク腰を震わせてぇ……恥ずかし\nくないんれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「もっと舌で押し込んで欲しいんれひょ？　じゅぷっ、あぁ……んっ、もうす\nぐ……出るんれふね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「バレバレれふよ……んんっ、またオスのにおいが……濃くなってぇ……はぁ\nぁ……ダメ、ウチ……これぇ、くんくんっ……嗅いじゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んはっ……ち、違いまふっ……と、とにかくっ……ウチのことは気にせずっ\n、また射精しちゃうんれふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「すぅぅぅっ……んはぁぁ……ちゅぷっ、においで発情なんて……してないれ\nふからっ！　りゅぷっ、イヤらしいミルクっ、出すのですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ……あんむっ、じゅぷっ、くぷぅっ、んじゅるうっ、じゅるるるっ\n、んじゅっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぐぅっ！　ふぐっ、んんんっ、くっ、くひの……中にっ……んぶっ、んん\nんんーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「まっ、待っへっ……！　量が……いくらっ、らんでもっ、んんっ、多すぎっ\n……んぶっ、むぐぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ごくっ、んくんっ……んぐっ、んっ、……んくっ、んふっ、んんんー\nーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ、あっ、ふぁ……はぁ……はぁ……あ、危ないところでした……\n本気で窒息するかと思いました……はぁ、んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はふぁ……口の中に、精液の味が……においも広がってぇ……はふぁ……粘\nっこいのが喉に残って……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……ちゅぷ、全く……この遠慮なしのオチンチンにも困ったものです…\n…いっぱい汚れてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「仕方ないから、ちゃんと掃除してあげますよ……ねる、んりゅ、れる……ち\nゅぷ……んちゅるっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁ……これでいいでしょう。全く……本人どころかオチンチンまで世話\nが焼けるんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……どうでしたか……オチンチン……満足して頂けましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そうですか……まぁ、それだけ喜んだのなら……ま、またしてあげなくも…\n…ないですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んあぷっ！　あっ……んふぅっ、か、顔にっ……あっ、んぷぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……またすごいにおい……広がってるぅ……はぁ……もっと出して……\nあぁ……掛けてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、あぷ……はぁ……はぁ……はぁ……あふ……全部ですか？　これで、\n出し切りましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ダメですよ……変に残してたら……んんっ、あっ、だからって……そんな頬\nにくっつけなくてもっ……あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……終わりましたね？　本当に出し終えましたね？　もうこれ以上はし\nませんからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……それにしても……オチンチン、ドロドロじゃないですか……こんな\nにだらしなくさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「分かりましたよ……最後まで面倒見てあげますよ……ちゅぱ……ぴちゃ、ん\nちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んりゅ……別に、味がクセになった訳じゃないですよ……においだ\nって平気ですからね……すんっ、んふぅ……はふ……」", "NORMAL" ]},
