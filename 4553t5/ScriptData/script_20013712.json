{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はーい、ビールお待ち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022660001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ、ありがとう。皆、グラスは行き渡ったな？　それでは、改めて……乾\n杯！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「かんぱーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022660001" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「どうした、何をそんな仏頂面をしている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それは下僕でなくとも、私も言っておきたいところではある。自分たちばか\nり、たっぷりとバカンスを楽しんでずるいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022660001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「一応、君たちにも一日は時間を与えたではないか。相応にリフレッシュでき\nただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「確かに、とんぼ返りではなかったが……隊員達は、もっとビキニ星を堪能し\nていた……正直うらやましいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022660002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そう言うな。我々もずっと働き詰めだったからな。何とか彼女たちにも休暇\nを出してやりたかったのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「まぁねー、そもそも行けなかったメンバーだっているわけだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022660002" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「今回休暇が取れなかった者達にも、やりくりをして、近いうちにリフレッシ\nュしてもらうつもりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まぁ長官さんもよ、毎日クッタクタになるまで働き詰めでさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022660001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お、おい……余計なことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そのストレスをウチでひたすら愚痴ってたからよ。少し位ハメを外すのは許\nしてやってくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022660002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「だから余計なことは言わなくていいっ。店長なのに、客のプライベートをべ\nらべら話すのは問題だぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「かかっ、まあそんな中で、一生懸命やりくりして取ったバカンスだってこと\nは知っておいていいと思うぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022660003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、そうだったのか……それはろくに事情も知らず失礼した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022660003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや、いいのだ。結果としては君たちの働きのおかげで、ベストな装備も手\nに入ったのだしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「古い装備だからな、ある程度耐久性に気をつけて、ここぞという場面で使っ\nて欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、心得た！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022660004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「枝豆お待ち。確かにいい休養が取れた。お陰で、またバリバリと働けそうだ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022660002" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イグニスはワーカーホリックなところがあるからな……正直、もう少し休ん\nだ方がいいと思うぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「む……しかし、こうして体を動かすのも鍛錬のうちだからな。私としては気\nに入っているのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022660003" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「休めたのはいいですけど……やはり、あの姿で戦いというのは……色々と恥\nずかしすぎて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022660001" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「むぅ……このような姿はそんなに恥ずかしいものかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022660005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あっ、ルナテミスさんみたいに、しっかりと着こなせている方ならいいんで\nす！　私は、どうしてもスタイル的に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022660002" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「気にし過ぎだと思うがな。私はルシオラのビキニ姿はとても似合っていたと\n思うぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022660006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「あ……は、はい、ありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022660003" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へぇ、ビキニかぁ。どんな感じのやつだったんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022660004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「えっ……あ、あのっ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022660004" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「うむ、それだったら皆で撮った記念写真があるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660010" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっ、どれどれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020022660005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「えっ、み、見せちゃうんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022660005" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0197" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「せっかく撮影したんだ。思い出を共有してこそだろう、ほら……こいつだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022660011" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}