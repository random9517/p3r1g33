		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んひぃいいいぃぃぃいいぃぃっ！！　ひぃっ、ひぃいいいんっ！　精液ぃい\nいいっ！　ああっ、あああぁぁぁっ！」", "NORMAL" ]},
