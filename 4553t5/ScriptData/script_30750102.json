		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「どびゅどびゅぅうううっ！　中にっ、中にぃいいっ！　子宮にぃいいいっ！\n　届いてるっ！　届いちゃってるぅううっ！」", "NORMAL" ]},
