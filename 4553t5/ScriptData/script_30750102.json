		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「いっぱい、気持ちよくなって！　いっぱい、びゅーびゅーって、射精しちゃ\nいましょう……っ！　あんっ、あんっ、ああっ、ああ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「目の前が、チカチカしてきたわ。もう、イきそう……イけそう……っ！　隊\n長くんにおま○こじゅぼじゅぼされて……イク……！」", "NORMAL" ]},
