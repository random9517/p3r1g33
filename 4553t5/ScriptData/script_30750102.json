		{"command":[ "PLAYVOICE", "v2_075_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くん、隊長くん……っ！　お姉さん、お姉さん……ああ……ああ……精\n液……欲しいの……っ！！！」", "NORMAL" ]},
