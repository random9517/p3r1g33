		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くん！　お姉さんもう我慢できなくなっちゃった。いいから、さっさと\nセックスしましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くんの方から誘ったんだから、今日は一晩……いいえ、一日中付き合っ\nてもらうわよ？　ふふ、楽しみだわ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「うふふ、すっごーい♪　隊長くんのおち○ぽ、もう準備万端って感じね。こ\nーんなにガッチガチに勃起しているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「お姉さんのおま○こも……ふふ、説明がいらないくらいびしょびしょに濡れ\nちゃっているのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「それじゃあ、さっそく隊長くんにライドしちゃおうかしら。うふふ、クロス\nホワイトが乗るのはバイクだけじゃないんだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ん……っ！　きた、きたぁ……っ！　隊長くんのおち○ぽが、おま○こに…\n…入ってきて……んぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「あつあつのおち○ぽが、お姉さんのおま○こをかきわけて……ああ……奥に\nまで届くわぁ……ンッ、すっごい……おま○こいっぱい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。隊長くんどうかしら……？　おち○ぽが、私のおま○こ\nにすっぽり収まっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「いやらしいおま○こ肉が、うねうねってして……ンッ、隊長くんのおち○ぽ\n、気持ちよくしているのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。おっきなおち○ぽ……子宮にまで届いちゃってる……。ん\nふふ、じゃあ、動いちゃうわよー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ！　んふっ、んふっ！　あっ、ああ……っ！　感じるわっ、隊長くん\nのおち○ぽの形……ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「太くて……硬いの……っ！　ンッ、ンッ！　エラも張って……おま○こ、ご\nりごり……してる……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、すごいわ……このおち○ぽすごい……っ！　んっ、腰が、\nどんどん、動いちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、欲しがっちゃう……隊長くんのおち○ぽ、もっともっとっ\nて、いやらしく、動いちゃうの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、止まらないわ……！　ああっ、隊長くん、隊長くんっ！　あん\nっ、あんっ、どんどん気持ちよくなっちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、どうしたの隊長くん？　もっとゆっくり……？　んんっ、だめよ。\nお姉さん、もう止まらないんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「こんなに気持ちいいおち○ぽを持ってる隊長くんがいけないのよ？　ああん\nっ！　お姉さんのブレーキ、どうにかなっちゃったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「だから、止まらないの！　おま○こ止まらない……っ！　はぁ、はぁ、はぁ\n……ああっ、ああ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「どんどん、おま○こからお汁が溢れてきちゃう。いやらしいお汁でおち○ぽ\nぬるぬるにしちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「大丈夫よ……ちゃんと、おま○こ締めつけて、隊長くんのことも気持ちよく\nしてあげるから……ああんつ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「だから、一緒に楽しみましょう……？　ふふ、隊長くんも、ブレーキなんて\n捨てて、アクセル全開にして……ね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　そ、そこ……ぉ……おおぉ……っ！？　隊長くんも、腰、んぁ\nあっ、突きあげて……ひゃはぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「そんな、そんな……っ！　おち○ぽが子宮に、ゴツゴツあたっちゃうわっ！\n　お姉さんの子宮、隊長くんに潰されるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　んっ、んっ、んはぁあああっ！　隊長くんのおち○ぽに\n、ずぼずぼって……あああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「いいっ、いいのっ！　気持ちいいわ隊長くん！　最高の乗り心地よ……ああ\nっ、ああ……いい……いいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「おもらししたみたいにおま○こびちょびちょ……！　ああ、ああ……じゅぶ\nじゅぶいやらしい音……出ちゃうわ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「あうぅうっ！　隊長くんのおち○ぽが、ますます大きくなって……んっ、あ\nあ……この音で、興奮したのね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「マン汁がかき混ぜられるエッチな音で……ああんっ、じゃあ、もっともっと\n聞いて……隊長くん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長くんが興奮してる……！　お姉さんも、身体が熱くなってきち\nゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「だからもっと……隊長くんの上で、いやらしく腰を弾ませちゃうの……ああ\nんっ！　じゅぽじゅぽじゅぽって、腰……上下に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「もうおち○ぽのことで頭がいっぱいになっちゃう……！　隊長くん、隊長く\nん……！　ああ……このまま……イキましょ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「おま○こで、いっぱい気持ちよくするから……！　隊長くん、このままお姉\nさんに……射精、して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、あんっ、あんっ！　イッて、イッて！　ビクビクしている\nおち○ぽから……精液……だしちゃって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、お姉さんのおま○こに……おま○こにぃ……っ！　ああっ、ああ…\n…きてきて……きてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んんぅううううぅぅぅっ！　あっ、ああ……ああ……っ！　隊長くんのおち\n○ぽから……精液でたぁああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「びゅーびゅーって、勢いよく噴き上がってる！　子宮まで届くくらい、すご\nい勢い……っ！　突き抜けてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、イッてる……！　お姉さんも、イッちゃってる……！　こ\nんなに気持ちいい絶頂、初めてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「びゅくびゅく中出し、すっごく気持ちいい……っ！　はぁ……はぁ……やっ\nぱり最高……これ……好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ふふ……まだまだ、おち○ぽが硬いまま……そうね、本番はこれからよね…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「まだまだ隊長くんの上で、おち○ぽで、気持ちよくなりたいわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「うふふ。時間は限られているんだから、休んでいる暇はないわよ、隊長くん\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「まだまだガチガチの……おち○ぽ……♪　んっ、んんっ、ああっ！　もっと\n……もっと味わわせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「んんっ！　これ、これこれぇ……。カリでおま○こゴシゴシって、ああんっ\n、こすれるの、たまんないわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、抜かずのセックスは中出しされた精液がかき出されちゃうけど、問\n題ないわよね？　んふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「だって、隊長くんがもっともっと精液だしてくれるもの。ああっ、ほら、こ\nんなに射精したがってるおち○ぽだからぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「また、さっきみたいに腰を……ああっ、ああ……っ！　隊長くんの方から、\nいっぱい動かして……きて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ドスケベヒロインを、徹底的に犯してやるだなんて、あんっ、頼もしいこと\n言うわね。んふっ、じゃあ、やってみて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　すっごい、さっきよりも激しく、おま○こずこずこって\n、突きあげ……きてっ、きて……ぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00007501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「おま○この一番奥にっ！　あはぁっ！　何度も、何度もぉつ！　亀頭をぶち\nゅぶちゅって、キス、キスぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「どんどんマン汁っ、垂れ流しちゃうわぁっ！　あんっ！　あんっ！　泡立っ\nて……白く濁って……ああ、いやらしい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くんすごいわ。こんなスピードでおま○こかき回されたら、あっという\n間にお姉さんイかされちゃうっ！　ああっ、イッちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ああっ、いいのよ止めないで……ブレーキなんていらないから……っ！　も\nっと、もっと……隊長くんを感じたいの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「私も、おま○こをいっぱい感じるように……きゅって、隊長くんのおち○ぽ\nを、締めつけるわ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「ほら……一緒に……一緒に感じて……気持ちよくなりましょう……！　ああ\nっ、ああ……おち○ぽと、おま○こ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_075_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロスホワイト" ]},
		{"command":[ "SETTEXT", "「隊長くんと、一緒に……っ！　セックスで、駆け抜けて、イクッ、イクッ、\nイクイク……イク……ッ！」", "NORMAL" ]},
