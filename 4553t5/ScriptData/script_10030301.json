{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おい、下僕。例のアレ、どこやった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「また見つからないんですか！？　いつものあそこに置いてないスか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「腹減ったー！　おやつ買ってくるー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「また食べるの？　今日５回目よ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「健康でよろしいではございませんか。ワタクシにもなにかおやつを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どさくさに紛れて図々しいこと言ってんじゃねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「私たちが、元リーダーと共に『地球』という星で暮らすことになってから数\nか月」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「この星の住民たちの生態は、とても興味深い……というわけで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「今日はその奇妙な暮らしぶりを密着取材！　動画レポートでまとめてみよう\nと思います！　題して『ＥＤＯかんさつにっき』！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「観察と言われても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この忙しいのになにやってんだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「いや、一応あたしらも止めたんだけどな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「気にしないでやって―。この子、研究とか実験とか大好きなんよねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、遊んでねえで仕事しろよ、仕事！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0183" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「私が観察対象に選んだのは、ＥＤＯという地球防衛組織に属する特殊部隊『\nインクレディブル・スクワッド』のメンバー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……話、聞いてねえな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「ここの人たちは奇妙な生態を持つ地球人の中でも、特に変わった行動を取る\nことが多いようです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「今日はそんなインクレディブル・スクワッドのメンバー、セレーナと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだ？　メシか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114950002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「いちおう群れのリーダーである、カツマの行動を追ってみたいと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺を巻き込むなよ！　っていうか、雑用がたまってんだからお前も手伝って\nくれよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「雑用は後だ。市街地に襲来者（インベーダー）が現れたとの通報があった。\n全員、ただちに出動だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114950001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「おっと？　どうやら群れの一大事！　カメラは、引き続き彼らに密着します\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいかげんにしろっつーの！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "と、いうわけで、テレビの取材班かなんかのつもりでいるらしい元・襲来者（\nインベーダー）たちを引き連れて、俺たちは出撃したのだが……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "敵の襲来者" ]},
		{"command":[ "SETTEXT", "「おっと！　またしょうこりもなく出てきたな、原住民ども！　今日こそぎゃ\nふんと言わせてやる！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「うるせー！　おまえらこそ、ヒーヒー泣かせてやるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114950003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「にらみ合い、お互いに工夫のないありがちな煽りゼリフを投げつけ合う！　\nこうして彼らは、互いの縄張りを主張するのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114950009" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「いやその……まだ撮り続けるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っていうか……お相手は、あなたたちの元お仲間ちゃんなんだけど……いい\nのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114950002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「あー、いいからいいから！　こっちは気にせずお仕事しちゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040114950001" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}