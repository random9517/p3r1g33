{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ふう……。ルナも寝てくれたし……わたしもそろそろ部屋に戻ろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「って、ひゃん！？　び、びっくりした……いつもと違う姿だったから気がつ\nかなかった……。それ、お仕事の衣装？　……そうなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ん？　べつに怖くなんかないよ。中身はあなただし。それより……えっと。\nこのあと時間、ある？　たまにはいちゃいちゃしたいなー……いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……いちゃいちゃしたいって言ったのはわたし……だけど。やっぱりこうい\nう展開になっちゃうんだ……。困ったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「だっていつもと格好がちがうし……。そういうあなたと今のわたしがくっつ\nいてたら……なんか、ちょっとアブノーマルな香りがする……かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「悪い怪人さんに襲われてる女の子……に見えるし。うん、そうだよ。いつも\nの姿だったらまだ……ヒーローショーみたいな催しに見えたかもだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「今は……背の低い女の子を、わる～い大人の男の人が襲ってる状態だと思う\n……。だからといって、離れたいとか、嫌なわけじゃない……けど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「え？　わたしの服？　これは私服。今日はお休みだったから、ルナと二人で\n出かけていて……。……んっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203108" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「い、今おっぱい触った……？　タンクトップが汗で透けてえっちだったから\n？　あ……っ、こ、これは……。外、暑かったから……。ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あんまり見ないで……。それに、べたべたするでしょ？　あんまり触ったら\n……。って、あっ！？　ま、また……いいの？　手がよごれちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「それに、変な匂いがしたらはずかしいし……。着替えてくるから待ってて？\n　……だめ？　なんで？　汗でおっぱいが濡れて、蒸れてるのが好きなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ここにおちんちんを挟みたい？　……そんなこと、考えたこともなかった。\nでも……あなたがそういうのが好きなら……うん。い、いいけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「っぅ……っ！？　ふぅううっ……！？　ほ、ほんとうにおちんぽ、おっぱい\nに挟んじゃった……。湿ってるし、ぺたぺた……しないの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「女の子の匂いがする？　や、やだ……あんまり嗅がないで。思春期の女の子\nだけの、甘酸っぱい匂い？　そ、そんなの自分じゃわからないし……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「は、ぁ……♪　んっ……あっ、あぁ……。あなたのおちんちんのニオイだっ\nて、すごいよ……。むわぁって湯気が出てるみたい……。はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「これって、ずーっとスーツの中に入れてたから……？　それとも、えっちな\nことばっかり考えてたから……？　っん……いつ見てもおっきいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱいの中からこぼれだしそう……。柔らかい胸のお肉にずぶう\nって刺さってて……先っちょが少し濡れてて……やらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「う、ん……そうだね。二人ともくさいなら、いいのかも……。おちんちん、\nゆっくり動かしていいよ……。わたしもおてつだいする……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「こうやって、手で挟んで……おっぱいの谷間がきゅうって締まるようにする\nね。それから……。ンッ……こうやって、上下に揺らして……っ、ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「だめっ……これ、思ったよりも感じちゃう……。っはぁっ、あぁあっ……♪\n　おっぱい、刺激されて……おちんちんの熱さにビリビリ反応してる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ッんんんん……！　おちんちんの先っちょが、顔に……目の前に迫ってきて\n、すごい迫力……。あっ、ぁっ……ずぼぉっ、ずぼぉって音、してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ……！　そんなに激しく動いたら……ふぁああっ♪　ち、\n乳首むずがゆくなってきちゃうよ……硬くなっちゃう……。あっ、やぁっ」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたの腰の動かし方……えっちすぎ……！　あっ……あっ♪　えっ？　真\n似するみたいに？　おっぱいを押しつけながら私も動かすの？　……うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「こ、うかな……？　んぁああっ……太すぎてつかまえきれないよ……。そん\nなに気持ちいいの？　摩擦熱で、汗……かいちゃう、……んふ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「汗でヌルヌルしてきた……。それにこれ……先走りのお汁、だよね……。前\nに教えてくれた……。おちんちんが気持ち良くなってくると出るお汁」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「だったら……ふふ、このままこうやってぐにゅぐにゅしてたら、きっとたく\nさん精液が飛び出すね……。楽しみ……♪　んぅっ……強くしていいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっ……もっと、したいようにして……あんっ。いい、から……っ。わたし\nもそっちの方が……好きだから……はぁっ、はぁ、あふ……♪　あっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203127" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「なんだかヘンな感じ……♪　いつもと違う格好で、あなたが一所懸命に腰を\n振って……あぅっ♪　わたしの胸、揺らしてて……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「乳首くすぐったいし……んっ、ピリピリする感じ……。はぁっ、おちんちん\nに乳首こすれるの……好き？　さっきからビクビク反応してる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ……んっ、もっとこすりつけるね……。っはぁっ……はぁっ、んああ…\n…♪　胸……ドキドキしてくる……。あっんっ……熱い……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたに教えてもらったこれっ……あっ♪　パイズリ……。んんっ、あなた\nが感じてるのがよくわかって、たのしい。おちんちんもよく見える、し」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「尿道口からぴゅぴゅって精液が飛び出してくる瞬間も好き……。っんっ……\n♪　えへへっ、今わたしの言葉に反応した……♪　いいよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「たーくさんおっぱいでかわいいかわいいしてあげるから……好きな時に、ん\nっ、出してね……♪　わかってるよ。あと少しで出そうなんだよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……♪　早くおっぱいで浴びたいな……。っはぁっ♪　この服は\n汚してもいい服だから……遠慮しないで。本気で出して……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱいが真っ白になるくらい、ドクドクって出して……！　っは\nぁっ！　グググって、おちんちんの力、強くなってきた……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！？　んんぁっ……！　びっくりした……あっ！？　あッ……く\nぅううんっ……♪　あれ……？　いつもよりたくさん出てるよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしがおっぱいで絞り出してる、から……？　あっ……精子のニオイ、す\nっごく濃くて……クラクラする……。胸の谷間にドロドロが溜まってく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ……あったかい……♪　うん……！　嫌じゃない、うれしい…\n…だからもっと、ちょうだい……！　んふっ……ふぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んんんん～っ……！　んぁあああっ……！　もしかして……わたしのために\nずっと精子、溜めててくれたの……？　それくらいたっぷりだね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おっぱいの上でヌラヌラしてる……♪　んっ……、なんだろ。こんなに出し\nてくれると、達成感があって……もっとしたくなる、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あのね……？　もう少しだけ、これ……。パイズリ、しててもいい？　びゅ\nるびゅるした後にされるのって……迷惑？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「もしそうじゃなかったら……まだ、続けたい……。んふ……♪　あなたがと\nっても気持ち良くなっているのを見ていたら……わたしも、って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしもパイズリで気持ち良くなりたいって思っちゃった。あなたはもう一\n度びゅるびゅるしたから……次はわたしの番」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203203" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「今度はわたしが一番気持ち良くなるように、おっぱいをおちんちんにこすり\nつけちゃうね……。いくよ？　っん……っ、ンッ……♪　ん、ぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おっぱい……縦に、谷間をズボズボってされるのも気持ちいいんだけど……\n。っぁっ……こうやって、ね？　横からぎゅむって押し潰して……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ぐりんぐりんって回して、お肌のいろんなところを刺激してもらうのもすご\nくいい……♪　んっ……。あなたも、かき混ぜるみたいにしてみて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……あっ♪　くぅうっ……くふぅっ♪　そこっ……！　今のっ！　そうやっ\nて色んなところ、わたしのおっぱいの全部を突いて……！　っあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「や……♪　あぅうっ……！　はふっ……♪　ふぅうっ……！　あぁ……二人\nで協力してするパイズリ、とっても気持ちいいよ……ありがとう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「もう少しっ……強く、乱暴にして……♪　んんぅっ♪　……白い精液がおっ\nぱいに……おちんちんに絡んでえっち……♪　にちゃにちゃ音もしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「っんっ……この音好きぃ……。ふぁ……ああっ！　わたしの汗、とあなたの\n精子……混ざって蒸れて大変なことになってるね……。で、も……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるして、すべって……感じる……っ。あっ……！　あっ、ぁっ…\n…！　あなたのニオイ、あなたの色にわたしの肌が染まってく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……ッだめっ……！　イ、きそう……。んんっ……！　は、ぁ……っ♪　イ\nク……おっぱいだけでイくぅ……っ！　ひっ……あぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ん～っ、んんっ……んん～～～～っ！　ふぁあっ……！　ごめんね……一人\nで気持ち良くなって……。でも、すごくよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたのおちんちんがおっぱいに埋まってると……それだけで興奮するのに\n、したいようにしたら……全然もたなかった。はぁっ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……え？　もっとおっぱいを押しつけてほしい？　いいよ？　……んっ！　\nあっ、腰、打ち付けるの？　あっ……わたしがイクところを見たから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたも興奮してくれたってこと？　……えへへへ……。じゃあ、最後は二\n人で……一緒にイこう。リズム、合わせるから……。んっ……んっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっ……あ、あぁ……っ！　わたし……またすぐイっちゃうと、思う……！\n　だから本気でパイズリ、するね……っ。はぁっ……はぁっ、んっんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あ……！　どうし、たの……？　すごく硬くなってる……。んんっ……。精\n液溜まってきた？　わたしのおっぱいで、ちゃんとイけそう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしは……大丈夫、ほんとにすぐイキそう……っ。んんっ……ふ、ぅ……\n♪　んふっ……ふっ、んん……♪　ん～っ……んッんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたし待ってるから……！　もう一度おっぱいにかけて……っ。はぁ、はぁ\n……一緒にイキたい……！　イこ……♪　ふぅっ、ふぅうう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あ！　ああああっ……！　んぁっ……！　ふぁあああっ、あぁあああ……っ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あははは……っ♪　二回目もすごいね……！　あなたのおちんちんって魔法\nが使えるみたい……。こんなすぐに精液作って、びゅくびゅくして……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「見て……？　わたしに甘えるみたいにビクンビクンしてるよ……♪　あっ…\n…！　そうなんだ、そんなに気持ち良かったんだ……♪　んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたし、も、気持ちいいよ……♪　精液で真っ白になったおっぱいが、誇ら\nしい……♪　あふ……♪　谷間からこぼれそうなくらい出してくれてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……んんんんんっ……♪　色、は一回目と同じくらい。ニオイはキツいかも\n……？　ドロッドロだった形は、ちょっとだけゆるくなった……かな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「でも、その分量が増えて……おっぱい全部、あなたのでいっぱいになった…\n…♪　ほら……♪　これが今日、二人で協力して作った精子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……おちんちん、毎日こんなに精液を作るとしたら……どんどん出さないと\n、危険だよね。溜め込みすぎて病気になんてなられたら、困るし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「えっと……。ルナとでかけたり、過ごしたりしてる時は無理だけど……。他\nの時だったら、いつでも……パイズリ、するから教えてね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「いつもの姿の時も、今日みたいな服の時も……どっちでもいいから。わたし\nにできることがあったら、言って。パイズリも上手になりたいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おっぱいだって、まだまだ成長しておっきくなると思う……から。そういう\nの、あなたが楽しみにしててくれると……いいなって、思ってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっ、イく……！　って、ひゃんっ！？　あっ！？　な、なんで顔に……！\n　あぷっ！？　んっ、んふ……！？　出すところ間違えちゃった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あぅっ……んんぁっ……。ベトベトが顔中に……。んぅ……。精液の味は嫌\nいじゃない、けど……こっちにかけるって思ってなかったから……。あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「不意を突かれちゃった……。んっ……ンッ、わたしもまだまだだね……♪　\nぷぁ……。出すの二回目でも、一回目より量が多くなってる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「これじゃ、発射する時に照準が合わなくってもしょうがないかも……。だっ\nてすごい勢いで出てる、し……♪　あっ……♪　熱すぎる、し……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……おっぱいじゃなくて顔でもいいから、全部出しきって……。あっ♪　ど\nこでも、いいの……わたしにかけてくれるなら……受け止める……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ん……！　……全部出しきれた？　すっきり……した？　そう……♪　わた\nしが役にたてたってことだよね。わたしと、わたしのおっぱいが……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ご奉仕……って、あなたに教えてもらうまでは知らない概念だったけど……\n。やってみると、すごく自分の性に合って……しっくり、きたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしがあなたにえっちなことをして、尽くすと……あなたとあなたのおち\nんちんがこんなに喜んでくれて。わたしもそれを見て喜んで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……これって、すてきな関係だなぁって、最近思う。ルナのことは大事だけ\nど、女の子同士だから……。えっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「男の人のあなたに、尽くせるのってやりがいが……ある。これからも……か\nわいがってくれたら、うれしいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
