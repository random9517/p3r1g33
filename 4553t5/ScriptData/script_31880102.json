	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長……さん？　この部屋は……何ですか？　こんなお部屋、存在している\nのに初めて気が付きました……。夜はいつもこちらに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00018801_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『お仕置き部屋』……おしおき……。あっ、もしかして……私がなにか戦闘\nでミスを？　え？　そうではなくて……？　っきゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00018801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あっ！　話の途中でベッドに押し倒すだなんて……。近くに誰かがいたら大\n変ですよ。私は……その、かまいませんけど……。って防音、なんですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00018801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「防音で、ベッドがあって、お仕置きの部屋……。なんだか、すごくエッチな\n感じがします。私の考えていること……あ、当たって……ますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「はい。私も……ちょっと期待して来たんです。夜中に隊長さんと二人きりだ\nなんて……エッチなことがあるのかなって。だから……いいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「お仕置き……してください。ただ……出来れば痛いのは嫌です。怖いのも…\n…。んっ……。おっぱい……？　おっぱいに触りたいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「それなら……痛くも怖くもありませんし。私が触ってほしいから……むしろ\nお願いします。触ってもらえますか？　私の胸……強く握ってもいいから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……っんッ……♪　はぁっ……はぁ……隊長さんの手……いやらしい動きで\nす……。それに、さわさわ、揉み揉みってフェザータッチで焦らし、て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018801_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んん……もどか、しいです……♪　もっと強くていいんですよ？　ん……あ\nっ、ぁっ……キツく、その指で……揉んで苛めてほしい、のに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……っ。私の胸を撫でるだけ……。わざと乳首、や乳\n輪には触ってくれなくて……あ、ぁ……いや……なんだか、んぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「全身がゾクゾクしちゃう……っ。あっ、胸っ、胸しか触られていない、のに\n……！　優しくなぞられると……あっ、アソコも……疼いて……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「どんどん、どんどん切なくなって……んふ……！　た、隊長さん……！　あ\nんまりもてあそばないでくださ、いぃ♪　私……私、もうずっと前から」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長さんに触れられると……。その目で見つめられると、身体が熱くなって\nしまうんです。欲しく……なっちゃって。強い抱擁、乱暴な愛撫、それに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「もっと深い繋がりを妄想しちゃうんです。ですから……、ふンンっ……！　\nあのっ……！　も、もっと……近くにきて……ガッと鷲掴みにして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃに扱ってもいい、ですから……。私の胸……指のあとがつくく\nらいに揉んでくださいっ……はぁっ、はぁ、このままじゃ辛いです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……んんん……！　はぁっ……はぁ、はぁ、はぁ……イジワルしないで……\nっ。もどかしくてどうにかなっちゃう……。あ、ンン、強く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『上手におねだりできたらご褒美をやる』……！　あっ……おねだり……。\nおね、だり……。わ……私の、大きいだけのダメおっぱいを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「戦いの邪魔になる、乳牛みたいな乳房を絞って……鳴かせてくださいぃ……\n！　それで、それで……ミルク出るくらいお乳搾りして、そのままっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おっぱい揉みながら！　乳牛おっぱいいじくりまわしながら……私のはじめ\nてっ、初めて強引に奪ってください！　お、おちんぽを入れてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「も、もう……アソコが期待で大洪水なんです……。おちんちん、おちんぽ入\nれてもらわないと狂っちゃいます！　お願いです、おちんちんください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……あっ……！　おっき……！　えっ……隊長さん……おちんぽスゴく腫れ\nあがって……！　ぁ……私、のせい……？　あ……大丈夫、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「どんなに硬くて太くて大きくてもいいですからっ……それっ、それください\n！　私の処女おまんこにズブズブしてほしいんです！　どうかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……ん、ぅ……ああ、ああああああああッ……！　あぁあっ！？　か、は…\n…っ、んぁああああっ！　おちんぽっ、おちんぽおちんぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽ入っ……入りました、入れられちゃいました♪　あっ♪\n　うそっ……奥の奥まで届いてる、それに……圧倒的質量、んん、重いっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あは……あ、ぁ……あぁあああ……♪　すっごい♪　すっごいです、おヘソ\nの裏まで……んぁああっ、私のお腹の奥までぎっちり入って、る……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「目で見たモノより何倍も、太いモノで貫かれている感じ、です……！　あっ\n♪　なのに嫌じゃない……初めてなのに……あぁ、い、入れられただけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んいぃいっ♪　軽く意識がトんでっ……あっ！　お尻が、腰が浮いてきちゃ\nいます、自然と男の人、おちんぽ受け入れるポーズになっちゃ、うぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ンぁっ♪　あぁっ、あぁ、あぁああ……！　気持ちいいっ、気持ちいい……\n！　私おちんぽ待ってました、ずっと待ってましたぁ♪　あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「それ、に……あっ！　さっきより力を入れておっぱいっ♪　おっぱいムニム\nニ揉んでもらって……っ、まだっ、まだ優しいけど、それでもぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「胸もアソコも、二か所が同時に気持ち良くってっ……あぁ♪　全部の神経が\n悦んでる……！　エッチ、エッチしたかったの隠せてないです……ぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んーーーーっ♪　ごめんなさいっ、ごめんなさい……！　腰が勝手にくねく\nねしちゃって……あぁっ、おちんぽ求めちゃってる、恥ずかしいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『まずは優しく、一発抜かせてもらう』……？　い……いっぱつ……？　あ\nっ……！　おちんぽから精液出したいということ……ですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「それならっ、それなら……使ってください！　私のおまんこ……あっ！　す\nっごく濡れて、熟れて……我慢できなくて、うねうねしてますから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「うねうねおまんこで一発っ、抜いてくださ……いっ！　んあっ！　あぁっ…\n…！　ゆっくり……ゆっくりおちんぽ動かすなんて……はぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「や、だぁ♪　激しく、激しくぅううっ♪　んああああ……！　優しいのやだ\nぁああ♪　あぁ……ッ、性感、高めるだけ高めて……んぅうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「最後の一押しをしてくれない、なんてぇ♪　……あ！　あっ……あぁ……！\n　気持ち……いいのに！　全身ビクビクしてるのに……んぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あと、ちょっと……なのにっ、イ、きたいのに……イけな、いぃ……！　あ\nっ♪　あっ♪　『俺は気持ちいい』？　それならいいですけどぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あはぁああ……ッ！　おかしくなっちゃい、そう……！　おかし、く……ん\nあっ、あぁっ、あぁ……！　『ぬめぬめしてて柔らかい』？　あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あり、ありがとう、ございま……す、あっ♪　あぁっ……！　ど、どうです\n……か？　一発、抜けそうで、すか……あの、あの、あのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「まずは一発っ、びゅるびゅる出しちゃってください！　いいですからっ、生\nでいいですから！　避妊なしで中に……んーっ！　まず出して……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ああああああああっ！？　あっんんんんっ！　ああああああぁっ……！　し\nゃ、せい……あああっ！　射精、んんんっ！　一発目ぇええ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ひぃっ、んひぃっ……！　奥にっ、奥に精液が当たって、る……！　あぁ…\n…！　じゅわっておまんこの中が熱くなって……わかります！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽが脈打つのが……はっきりわかる……！　んっ、『まだ甘イキでこ\nれからが本番』……！？　そんなっ、これ以上の快感が存在するなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……きゃあっ！？　あぁっ！？　射精しながら、突然おっぱいを握りつぶし\nて……？　あっ！　腰をガンガン振りたくるのですか！？　あっ、やだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「射精直後に……！　人生最初の膣内射精されたばかりの私のおまんこ、攻め\nまくるだなんて……！　あっ！　いやっ！　いやっ、いやっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『こうして欲しかったくせに』……？　そ、そう、です……！　胸を絞られ\nながらっ、握られながら乱暴に犯して欲しかったですけど……あああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「精液っ、精液をおまんこで感じたばかりの敏感な粘膜に！　おちんぽ、おち\nんぽの形刻まれると……たまらないんですっ！　あっ！　イくっ、イくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ……！？　んひぃいいいっ！？　イ……く！　イくぅっ！　ああ\nあっ！　隊長さん！　私イキました！　イッてます、イってますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「イッてるのにぃ……！　あっ！　あっ！　おちんぽが精液かき混ぜてるっ、\n私のおまんこっ、壊れるくらい突き上げて……おっぱい刺激してくるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっ！　あーっ！　そんなぁああ……だめです、だめです、だ\nめ、だめ、だめ……あああ、止まらない、止められないぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ああっ！　何かクる……！　きちゃう、きちゃうううう……あーーーーーっ\n！　あっ！？　あああっ！？　あーっああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んぅうううううーっ！　……はっ！？　す、すみません！　私今、し、潮を\n噴いてしまって……！　あぁっベッドが、ベッドが水浸し、に……ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「『お漏らししたみたい』……そうですよね、それにっ……あっ！　あっ！　\n気持ちいいの止まらなくて、絶頂してもしても終わらなくてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「潮も精液も愛液もぉ……垂れ流しになりながらイキ狂っちゃいます！　あっ\n！　あぁっ！　エッチっ、エッチ気持ちいい、好きっ、好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ずーっとずっとこうしてい、たいです……あっ！　どこまでも、限界知らず\nに二人で感じ合いたい……！　あっ！　私も腰を動かし、ます、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　あぁっ、あぁっ、あぁああ……♪　エッチ気持ちいい、エッ\nチすごいぃ……！　んあああっ、あぁっ！　一生このままでいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽにおまんこ突いてもらいながらっ、おっぱいグニグニ揉まれてイキ\n続けていたいぃ……！　あっ！　あっ！　乳首っ、おまんこ、おっぱいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「全部、全部いい……！　隊長さんが触れているところ、全部、全部エッチす\nぎて大好き……っ！　私のこと……気持ち良くしてくれてありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「隊長さん、も……気持ち良く、なって♪　なって……♪　一緒に……あっ！\n　一発目より、大きな快感を……共有しながら……イってほしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あッ♪　私……ま、たイくから♪　さっきよりいっぱいいっぱいイく、から\nぁ♪　隊長さんも私のおまんこに出して、二発目ちょうだいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～～♪　んぁふっ、あぁんん♪　二発目、二発目すっごいぃ…\n…♪　一度目よりも勢いが増して、る……奇跡みたいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んっあぁ♪　今度は……奥に、一番奥に注いでくれるんです、ね……♪　荒\n々しく……私を孕ませるために……♪　くぅううん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「男らしくて素敵ですっ……♪　はぁっ♪　あぁ、ビュルッ……びゅるっ、ビ\nュクッ……生命の種がしっかりと注がれていくのを感じます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「っんんん……♪　おまんこの中に出してもらっているのに……。精液がおい\nしいって、感じます。全身がくまなく悦んでいるのがわかって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ああ、私これがずーっと欲しかったんだって……♪　隊長さんのおちんぽで\n、隊長さんだけのオンナにしてほしかったんだって理解しちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……ん……♪　ふふ……私のお腹の中、隊長さんでいーっぱい……♪　幸せ\nで、なんだか泣けてきちゃいます……♪　んっ、気持ち良すぎたからかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「エッチの味を覚えちゃった私は……もうさっきまでの私じゃありません。だ\nって……快感が、快楽が、忘れられない身体になったんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「……これからも……私のこと、たくさん抱いてくださいね♪　隊長さんとな\nら……どんなことだってしてみたいんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「それ、に……中出し……膣内射精は、粘膜だけじゃなくって心まで満たして\n癒してくれるから……。何度でもしたくなっちゃいそうで……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「おちんぽ中毒になってしまったらごめんなさい。だけど……私がエッチ大好\nきな方が……隊長さんも、おちんぽくんも嬉しいですよね♪　ねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「やっ……！　あっ！？　どうして抜いちゃうんですか……っ！　あっ……！\n　身体に……！？　身体にかけるんですかっ……？　んーーーーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ♪　胸に……お腹に、全身に……っ♪　あぁ……私の身体\nが、白一色に染め上げられていく……隊長さんの色に染まってく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ビチビチと肌の上で跳ねる、健康な精液……♪　さっきはこれが、お腹の中\nに……おまんこの中に出されていたなんて信じられません……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「じっくり好きな場所にかけてくださいね。あんっ♪　精液って……狙い撃つ\nのは難しいですか？　どぴゅって飛び出して、色んなところに着地して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ふふふっ♪　一発目は中に出しましたもんね……♪　今度は……自分の目で\nはっきり見えるように、私に精液をかけてみたかったんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00018801_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「んんんっ……もちろんいいですよ♪　私……隊長さんのおちんぽも、精液も\n好きだから……。好きなモノに囲まれて幸せ、です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ただ、二度目の中出しも経験してみたかった気はしますけど……♪　それは\n今度の機会のお楽しみにとっておくことにしますね……。あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「ねっとりと肌にはりついて、まるで蜘蛛の巣に絡めとられたような気持ちで\nす……。隊長さんの臭い……いつもよりしっかり嗅ぎ取れてうれしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「それに、量の多さは、膣内射精ではなく実際に浴びてみないとわからないも\nのですから……。ふふふ、私もベッドも、隊長さんもドロッドロ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_188_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エージー" ]},
		{"command":[ "SETTEXT", "「森で水浴びをした時みたいに、童心に戻ってしまいますね。オトナの水浴び\n……♪　エッチなザーメンシャワー……ハマってしまうかも……♪」", "NORMAL" ]},
