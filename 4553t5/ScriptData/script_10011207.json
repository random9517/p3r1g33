{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0113" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ドラグソード！　もう少しだ！　もう少しがんばってくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とはいっても、このままじゃ脱出できないぞ。どうにかしないと――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……？　アナザー？　どうした？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「みんな、私にいい考えがある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どんな考え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「その言い方、なんだかちょっと嫌な予感がするんですが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私が、ドラグソードとここに残って時間を稼ぐ。その間に、カツマが他の全\n員を連れてコペルニクス・クレーターへ向かうんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な！？　なに言ってんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「アナザー！　無茶言わないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「無茶かもしれんが、被害を最小限に食い止めるにはこれが一番だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも……あなたを置いていくなんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112130002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんな顔をするな。しんがりは危険な役目ではあるが、死ぬと決まったわけ\nではない。できるだけ急いで、助けに戻ってくれればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「作戦としてはそうかもしれませんが、しかし、この状況ではあまりにも危険\nが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……そうだ。オボロの言う通りだ。オボロの言う通り、作戦としてはありだ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！？　ウチがいいたいのは、そういうことではありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それはわかっている。だが、私が言いたいことも、少し違う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「どういうことです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ドラグソードと残るのは、アナザーではなく私だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なんですって！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010112130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　ダメだってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010112130002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　それはいかん！　なぜお前が！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なぜ、だと？　さっき見ただろう！　ルナパレスが吹き飛ぶところを！　あ\nれは奴らの仕業だ！　奴らが、ルナパレスと母上様を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから、ここには私が残る！　母上様の仇を、ひとりでも多く倒す！　その\n間に、お前たちは援軍を連れてこい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「仇を討ちたいのは私だって同じだ！　母上を失ったのは、お前だけだと思\nっているのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ついさっき失ったばかりなのは私だ！　しかも、いま目の前にいる連中にや\nられたんだ！　おまえこそ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー！　ちょっと待ったストップ！　ふたりともいいかげんにしてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかしカツマ！　ここは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふたりとも言いたいことはわかる。仇討ちをしたいだろうし、他のみんなを\n安全に行かせたい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「でもな、ふたりのどっちも、ここに残していくわけにはいかないんだ。誰か\nが残るとしたら、それは――俺の役目だからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待て、カツマ！　それは危険すぎる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130010" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「『危険すぎる』って、残るとか最初に言いだしたのはおまえじゃねえか！　\nこんなときにツッコミ入れさせんな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、そういうことではなくてだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいんだよ、危険なのはわかってんだ。でもな、その危険は俺が引き受けな\nきゃいけないんだ。だって俺は、隊長なんだからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130012" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ、貴様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あーもう、時間がもったいねえ！　ふたりとも、みんなを連れて早く行け！\n　それから、援軍を連れて早く戻ってこい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……わかった。カツマ、しばらく持ちこたえてくれ。私たちは必ず戻るから\nな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090112130013" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「当たり前だ！　おまえらが助けにくる前提で、残るって言ってんだからな！\n　絶対戻って来い！　もし戻って来なかったら――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえら全員！　一生恨むからな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「案ずるな！　約束は守る！　行くぞ、皆の者！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010112130012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほらほら！　急げ急げ！　おい、ジュンジロー！　おまえとメカで――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご心配なく。言いたいことはわかっております。ワタクシとメカのふたりで\n、しっかり皆さんを先導いたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふたりで、じゃなく主にメカが、だろうけどな。まあいいや、とにかく頼ん\nだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112130003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「――って、カグヤ！　まりあ！　ふたりともなにボーっとしてんだよ！　み\nんなと一緒に行動しなきゃダメだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私たちも、カツマと残る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「さすがにカツマさんだけでは、戦力として心もとないですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112130004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいから行け！　早くしろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「嫌」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「『嫌』とか言うなよ。言う通りにしてくれ、頼むから！　幼なじみのおまえ\nに、紋章の力で命令はしたくないんだよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112130004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあも行ってくれ！　だいたいおまえが残って、あっちに敵がいたらつき\nみが困るだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは……そうですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112130005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから頼む！　ふたりとも早く行ってくれ！　後で戻ってくれればいいんだ\nから！　急げ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……わかりました。カグヤ、行きましょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010112130006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、待ってて。すぐ戻ってくるから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010112130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……おう、行け行け。早く行け。なるべく早く戻ってきてくれ。それまでは\n俺とドラグソードが――」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひいいいっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわぁああ！？　襲来者（インベーダー）の連中、もう来たのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010112130001" ]},
