		{"command":[ "SETIMAGE", "0", "still_00022103_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やっ……！　ぺろぺろの途中でそんなふうに触られ、たら……おむねが、お\nむねが痺れて……ますますお股が熱く、なって……んむぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「は……ぁっ♪　うぅ……♪　とろけちゃいまひゅ……ぅ、おっぱい、溶けち\nゃいます……。わ、わたくひも負けませんから……！　えいえいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……！　おちんちんさんをチロチロして……。んふっ！？　ぁっ…\n…旦那ひゃまを気持ちよくひて……！　っちゅるるっ、ちゅぷぷぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ら……らめれすぅ、おっぱい……！　おっぱいプニプニされたら……お、お\n口が留守になって……ぁっ……だめ、おしゃぶり、おしゃぶりしなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！？　んむぅううっ！？　んむぅうう……！　むぅうう……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きゃっ……旦那ひゃま！　突然、とつぜんせいえきが……んぷっ！　こほっ\n……！　の、飲みきれないくらい……あぷっ、んん、んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁああ……っ♪　こんなに……、んぅっ！？　あっ……♪　イキまひゅ…\n…！　おくちの中にしゃせいされてイキま、す……ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どろって……あったかいせいえきが……♪　ぁっ……♪　ごくっ……ごくっ\n……♪　飲んでも飲んでも……んんぅっ♪　ごきゅ……ごきゅっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああ……♪　飲みながら何度も達してしまいました……。ぴちゃ……ぴちゃ\n、せいえき……ごちそうさまでしたぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……！？　ぴゅるって……ぴゅるってせいえきが……♪　あっ……、ぁ\nっあっ……！　たくさん溢れて、顔に……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はいっ……はい、かけてください……ぴゅっぴゅしてください……♪　旦那\nさまのせいしはぜんぶ、わたくしのお顔に……あぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい……♪　あたたかくて、旦那さまの臭いがして……達して\nしまいました、……あっ♪　止まりません……またイキます、っうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……♪　だめ、です……こぼれてしまうのは……。んっ……指でせいえき\nをぬぐって、あつめて……んちゅっ♪　たべちゃいます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちゅ……ちゅ……れろっ、れろ……れろ……♪　んん……ごくっ……♪　わ\nぁ……♪　喉に絡みついて……のみにくい、です……んん……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁぁあ……♪　ぷぁ……♪　み、てください……ぜんぶ飲めました……。\nまだお口の中が、すこしベトベトしています……えへへ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのせいえきは、わたくしが飲み干すときめていましたから……ちゃ\nんと飲めてよかったです♪　え？　どんな量でもか、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……もちろんです。せいえきは、旦那さまからわたくしへのプレゼントです\nから……。無駄にするなんて、ありえません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……、そうです。お顔についたせいしだけじゃなく、おちんちんの中に残\nったせいしもちゅーちゅー吸って飲んじゃうべきですよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのせいしも、汗も……妻たる者がそのお口でぺろぺろすべきだとお\nもいませんか？　だいすきなひとの、プレゼントなんですよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303410" ]},
