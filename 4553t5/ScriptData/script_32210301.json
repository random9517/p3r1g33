	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま……お部屋におまねきいただきまして、ありがとうございます……\n！　わたくしはこの日をずっとずっとたのしみにしていましたの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00022103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「今日はほんきで子どもを作る日……二人で赤ちゃんをこの身に授かる日です\n。そのために……えへへ、たくさん勉強してきました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまの喜ぶこと……そしてわたくしも、いっぱいいっぱい感じて、最高\nの状態で受精するために。セイドラム復興のためにも全力でがんばりますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっと……より良い受精のためには、まず丁寧なご奉仕……ですよね♪　旦\n那さまに教わった知識を活かしてみせます。おまかせください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お洋服を脱がして……脱いで……。んん……、しつれいします。おちんちん\nさんをペロペロさせていただきますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん……わぁ……♪　今日もすごーくおっきくて……りっぱなおちんちんさん\nです……。もう、こんなに硬くなっているんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00022103_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あの……わたくし、一所懸命にご奉仕させていただきますので……どうかよ\nろしくおねがいいたしますね？　おちんちんさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……いただきます……。ちゅ……♪　ぁ……熱い、れひゅ……。むわむわっ\nて臭いが広がって……えへへ、舐められるの楽しみだったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ピクピクしていて……とっても元気で……たくさんキスをしたくなっちゃい\nます。ちゅっ、ちゅむ……♪　ん……、いたくないれひゅか……？　ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あなたさまのアンが……んん♪　配偶者にして妻のわたくひが……ご奉仕に\nまいりまひたよぉ……。くちゅ、ちゅ、ちゅ、ぺろ……ぺろぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んむ……くちゅ、ちゅ、ちゅぅ……ちゅむ……。は、ぁ……♪　んむ……♪\n　ちゅ……れろ……れろ、ぴちゃ、ぴちゃ……んぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……そういえば、今日のためにぃ……おふろにはいって身体をぴかぴかに\nしてきたんです……。みてください……。んちゅ、ちゅ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あまーいミルクの香りの入浴剤をちゅかって……。ぺろっ♪　すみずみまで\nおいしくなるように磨きぬいてまいりまひた……れろっ、れろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ですから、どこから食べてもおいしい奥さんになっていると……思いまひゅ\n……♪　どうぞ、お味見してください……。ん……ん、ん、ん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ぁっ！　か、身体をさわったりなでなでしたり……プニプニするのはか\nまいませんが……えっちなことはまだしなくてよいですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そういうことは、まずわたくしがぜーんぶいたします……♪　王様気分で優\n雅に寝そべっていてください。妻は……。んッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「妻は、旦那ひゃまに尽くすことがしあわせです……。そう、旦那さまがくだ\nさったご本に書いてありました。フェラチオは愛情のご奉仕だと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ですから……ゆったりと……。んっ♪　身体のちからをぬいて……そうです\n♪　ほら、見ていてください。おちんちんさんはわたくしの手で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん、しょ……ん、しょ……♪　こうしてしごきながら……先っちょをれろれ\nろさせていただきます、から……ご安心を……。ちゅ、ちゅ、ちゅちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ♪　ぴちゃ……ちゅぷ♪　くちゅ……ちゅ、ちゅ……♪　んぁ\nあ……おくちに入りきらないおちんちん……ぴちゃ、ぴちゃ、ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この逞しいおちんちんさんが……んむ♪　わたくしと旦那さまの赤ちゃんを\nさずけてくれる……大切な、たいせつなおちんちん……♪　ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさまぁ……あなたさまをたいせつに、たいせつにしますから……\nどうかわたくしに健康な赤ちゃんをおさずけください……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん、ちゅ……チュ♪　ちゅ……ぺろっ……はぁ、はぁ、はぁ……♪　くちゅ\nっ……♪　ちゅっ、ちゅぅ……ちゅぅ♪　ぴちゃっ、ぴちゃぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぅ……なんだか、身体が熱くなってきました……。それに、お顔も……ん\nっ……。おちんちんさんが、熱すぎるせいでしょうか……？　れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はやく、ぴゅっぴゅしたいですよね……でも、もう少しだけせいえきを貯め\nてください……。一番濃いのがほしいんです……ん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おててでぐにぐに……お口でちゅっちゅっ……♪　ぺろぺろしながら……は\nぁあっ……♪　愛情をこめて……れろっ、れろ、ちゅうぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おおきな音をたてながらするのがきもちいいですか……？　ぴちゃっ……く\nちゅ♪　ぺちゃ、ぴちゃ、ちゅぅ……♪　ちゅっ、ちゅぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんの先っちょの穴を……ぺろぺろ……♪　音をたてながらくち\nゅくちゅ……♪　ちゅっぷっ、ぷちゅっ、ちゅぷ、ぁ、んんん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんがおおきすぎて……ぜんぶおしゃぶりできなくてごめんなさい…\n…。どうして、こんなにわたくしのおくちは小さいのでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふむぅ……ンン……っ。んん……んむぅ……ん……んん……！　んぷ……！\n　ふぁ……やっぱり頑張っても、あ、あまりお口にふくめません……でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そのぶん、先っちょを丁寧におしゃぶりひまひゅ……。ちゅぷ、くちゅ、ち\nゅる、ちゅむっ、ぷちゅ……ちゅぅ、ちゅぅ、ちゅぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「え？　おしゃぶりを吸っているみたいでひゅか……？　わたくしは赤ちゃん\nではありまへんよ……？　ちゅる……くっちゅっ、ぷちゅちゅちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あむ……ぷちゅっ、だ、旦那ひゃま……おちんちんが太くなっれきまひた…\n…♪　これは精液があがってきた証……れふよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んッ、んむ……ふンン……♪　どうぞ、わたくひのお口に精子をぴゅっぴゅ\nなさってくだひゃい……遠慮なさらずに……♪　っちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　たまたまさんもあがってきています。出そうなんですね。嬉し\nいです……ちゅぅっ♪　ちゅっ……ちゅぅ……くちゅぅううっ、どうぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んむ！　むぅううっ……んっ、ぅっ♪　んくぅ♪　んっ……んんんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「どくどく、どくどくと……んっぅ……♪　赤ちゃんのたね……いっぱい……\n♪　うれひぃです、旦那ひゃま……♪　んんんん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「や、です。おくちは絶対に離しまひぇん……。よぉく味わって……くちゅ…\n…くちゅ……んん♪　ごくっ……♪　ごくっ、ごく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん……！　ひゅ、ひゅこひお口から垂れてひまいまひた……。大丈夫です、\nぜんぶ……いただきます。ん……れろ……ちゅ、……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ……、はぁ、はぁ……あぁ……♪　おなかがたぷたぷです。苦くて真っ\n白な赤ちゃんの種……ごちそうになりました……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、あの…ど、どうでしたか？　わたくしのご奉仕……。お勉強の成果はち\nゃんと出ていましたか……？　はぁ、はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「思ったよりもたくさん出た……ですか？　うれしいです！　わたくしは……\n旦那さまにたくさん喜んでいただくのがすきです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だから……。もう一度してもいいですか？　はい、さっきもお腹がいっぱい\nになるくらいたくさん精子を出していただきました。それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ、興奮してしまって……まだお口がうずうずしているんです。もっと、旦\n那さまのせいえきがほしいです。ゆるしてくれますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おしゃぶりしてもいいですか……？　……いいですか！　やった……！　で\nは、さっそくおしゃぶりしますね……えへへ、嬉しい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いただきます♪　はむっ……♪　ちゅ……ちゅ、んぁ……♪　すっごく味が\nついていて……ぴちゃ、残っていて、どきどき……しちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00022103_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「は、ぁ……んん……♪　おいひいれすよ……♪　ぴちゃ……ふふふ♪　また\nおっきくなってきまひた……。れろ、れろ、れろ……ちゅく……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくひ……♪　こうしておちんちんさんとお口で会話ひゅるのが好きれひ\nゅ……♪　すぐに応えてくださるから……♪　ちゅっ、ちゅぅっ、ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お役にたてているって思えて……そうすると頭がぼうっとして……♪　おち\nんちんさんを舐め舐めすることしか考えられなくなって……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「気持ち良くなってひまうんれす……♪　ンッ……！　おまたからじゅわぁっ\nて蜜が溢れ出して……あっ♪　ぁっ、せ、切なくなって……ぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんにがっついちゃいます……ぱくぱくレロレロしたくてしたく\nてたまらなくなって……♪　ふぅう♪　こうやって……夢中、で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちゅっぷちゅぷにゅるにゅる……。んっ♪　お口でいたずらしちゃうんです\n……！　っんっ……んっ、んぅ、くちゅ……ちゅくっ、くっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……旦那さま……♪　わたくしは、おちんちんさまも旦那ひゃま\nも大好き……♪　れろ……れろれろっ、ぢゅる……ちゅるっ、ぷっちゅっ」", "NORMAL" ]},
