		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……！？　だ、旦那ひゃま……なんですか……っ！？　ぷぁ……！　わ\n、わたくしの、お胸のさきっちょをつまんで……あぁっ！？」", "NORMAL" ]},
