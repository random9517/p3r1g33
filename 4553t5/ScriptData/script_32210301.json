		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぅうううっ……！　あふ……、ま、また絶頂ひてひまいました……くちゅ\nっ！　あぁ……ぺろぺろがやめられません……れろ……れろれろ……♪」", "NORMAL" ]},
