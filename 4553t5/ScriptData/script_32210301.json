		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……♪　き、気持ちいい……♪　おちんちんさんを舐めると……気持ち\nいいです……！　あっ！　ビクビクしちゃって……んぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
