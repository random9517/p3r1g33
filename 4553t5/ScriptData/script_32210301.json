		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふんん……♪　ぐちゅっ……！　ぐちゅっ、ぢゅっ……！　じゅるるっ……\nちゅっ！　くちゅっ……はぁ、はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
