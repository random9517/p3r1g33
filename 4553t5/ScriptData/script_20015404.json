		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　だ、だ、だ、誰だこいつらは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550007" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「突然何もない場所から現れたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550007" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "びっくりしている俺達だったが、出現した時間帝国側はもっと盛大にびっくり\nしていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あれっ！？　何……？　キミの周りにいる人達……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「特に、あちらのおば様……時間帝国の幹部達が束になっても勝てないレベル\nのお方では！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っていうか、それよりっ！　あのチビっ子から、女王様と同じくらいのパワ\nーを感じるんだけど！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「逆にそっちには、Ａエファナティカとかルナテミス・ダークとか、主力メン\nバーはいないのか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "3", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "3", "CENTER", "300" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「随分しょぼいメンバーだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550008" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁああああ！？　なによ！　アーちゃんたちじゃよわよわで不っ服ぅ～！\n　って言うつもり～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そこまでは言ってないけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「まぁ、でも気持ちは分かる気がするわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私たち……篭絡部ですから、戦力にはなりませんし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「むむむむ……。これはちょーっと本格的にピンチですね。と、いうことで！\n」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「こうなったら、作戦タ～～イム！！　ｗｉｔｈカツマ君！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550005" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐぇっ。なんだ、急に抱きついてきて」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「単刀直入に言うけどぉ……今日だけ味方してくれない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550006" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　出来るわけないだろ！　俺が殺される！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でーもー！　味方してくんなきゃ、あたしたちが殺されちゃう～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは……もう自業自得だろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ぶーぶー、つれなぁーい。もしアーちゃん達の味方してくれたらぁ、すっご\nいクリスマスプレゼント♥　あげるんだけどなぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クリスマス……プレゼント？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ええ、そうよ。特別なプレゼント♥」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「お正月まで、腰が抜けっぱなしになるような……最高のプレゼントですよ、\nいらないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ううううう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "唯一、ルナルバース陛下の遺産……クリスマスプレゼントを貰えていない俺の\n心が揺らぐ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのお耳にぃ、あま～い吐息をふーっ♪　ねえ、おにーさん？　ア\nーちゃんのこと、めちゃくちゃにしていいんだよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023550005" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なんなら美女と美少女てんこ盛り、夢の５人プレイもアリかも～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550007" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あなたの力が必要なんです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「頼りにしちゃっていいかな？　ご褒美はあ・と・で♪　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00018303_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉおおおおおおおお！　こんなの寝返るしかねええええ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「やった！　籠絡できました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00018403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「オレ　時間帝国　守ル　サンタ　敵　容赦シナイ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「きゃ～っ?　おにーさん、ご褒美への期待で筋骨隆々のムッキムキになって\nるんですけどぉ～っ?」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_010023550006" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いいね！　これならなんとかなるかも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550008" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「皆の者！　カツマが裏切りよったぞ！　応戦じゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550013" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……裏切者は許さない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550009" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "こうして俺は、ルナテミス、修羅姫、サンタガール、クィン・テイルというＥ\nＤＯ随一の最強メンバーに立ちはだかることを決めたのだった。", "NORMAL" ]},
