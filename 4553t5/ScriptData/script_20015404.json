{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0008" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「良いか？　今夜の仕事は簡単じゃ。グレート・ルナリアム幹部の大使館に潜\nり、ルナルバースの遺産を与えていく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「単純な任務じゃが、あくまでこれはサンタの仕事。寝ている皆を起こすこと\nのないように注意せよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんな人数で行って大丈夫か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それを考慮して、今夜の食事には睡眠薬を混ぜておいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「クリスマスパーティーということで、皆油断したらしく今はもうぐっすりだ\nそうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな……薬物に詳しいやつだって、毒に強いやつだってここにはいるだろ\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「そのへんは、こう……サンタの力でちょちょいっと、バレぬようにしておい\nたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「サンタにそんな力があったなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「普通はないと思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まずは輝夜の部屋か……。輝夜って何が欲しいんだ？　ちっともわからんな\n……？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「んん……今度、こそ……。カツマに告白……したい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040023550001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「告白……？　何か重い罪でも犯したのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「お主……余もドン引きするほどの鈍感男じゃの。じゃが、まあ良い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「今年１年良い子にしていた輝夜には……これじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550005" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんだ？　……んん？　カツマの抱き枕？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「そうじゃ。しかも、最新限定版……乙女が喜ぶタキシード姿のクリスマスバ\nージョンじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550006" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺の肖像権ってどうなってるんですかね！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなものはない。輝夜、これを抱いて幸せに眠るんだぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分の知らないところで抱き枕が作成されている……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　嘆いている間に皆様次の部屋に行ってしまいましたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023550002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うううう……。付いていくっつうの……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "とぼとぼと俺が次の部屋に入ると、エファがベッドで苦しそうにうなされてい\nた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……でも、熟睡はしてるみたいだぞ。すごいな、サンタの力って」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「寝言で何か言っているな。聞いてみるか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……うぅ……。陛下がいなくなって以来……仕事が、仕事が増えて……仕事\nが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_050023550001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「とにかく仕事に追いつめられているようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「そろそろイルルの授業参観……。でも、仕事が……しご、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_050023550002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「なにやら不憫になってきたのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550007" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人手が足りない、仕事が山積みってのはプレゼントではどうしようもないか\nらな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「とりあえず、カツマをこき使える券を１０枚綴りで置いておこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それがいい。１０枚で足りるか？　２０枚にしておこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺には肖像権どころか人権もないってことですか！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「次はセレインの部屋か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550005" ]},
		{"command":[ "SETCHARA", "0", "char_00000130_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふごぉ……。んごぉおおお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030023550001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「寝言を聞くまでもなく、食べ物だな。枕元に置いておこう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「目覚めたらきっとすごく喜ぶぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023550006" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00000130_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「で、次がディアナの部屋……。ん？　何か喋ってるな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「……んん～、むにゃむにゃむにゃ……。私ぃ、おっぱいがぁ～大きすぎて、\n肩が凝ってるのぉ……。っむにゅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023550001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「私よりぃ、おっぱいおっきい人なんていないからぁ……。こんなこと、相談\nできないしぃ……。むにゃむにゃむにゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040023550002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「……こやつ、煽っておるのか？　よしよし、世の全ての貧乳より恨みを買い\nしお主にはこれじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550008" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よく間違った使われ方をされている電マ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんだか、遺産というか……。まるで今準備したような……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550005" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「んんっ！？　お、おかしなことはないぞ。ルナルバース陛下はと、とても部\n下思いというか、先見の明があったからの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550009" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「こんなこともあろうかと、これを託してくれたのじゃろう！　それに……こ\nやつの煩悩を払うには、こんなもんで十分じゃろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550010" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ひえええ、目がすわっておりますぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023550003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「最後はピースムーンたちにプレゼント、だそうだ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ピースムーンたちには、何を贈るつもりだ？　結構な数がいたと思うが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010023550006" ]},
		{"command":[ "SETCHARA", "0", "char_00001605_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、一括で大きな袋を置いておこうと思う」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「それなら全員に、一度にプレゼントを贈れるのぉ。よく考えたものじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550011" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、俺はプレゼントを何ももらえないんですけどね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サンタガール" ]},
		{"command":[ "SETTEXT", "「……うむ、それはまた別の話じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_090023550012" ]},
		{"command":[ "SETCHARA", "0", "char_00000799_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああっ！　さらっとかわされてしまいましたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023550004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しくしくしく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺を除いた幹部全員、さらにはピースムーンまでのプレゼントを配り、ひとし\nきりの仕事が終わった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、じゃあ帰るとするか……って、うわぁ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が歩き出そうとした瞬間、ぶぉん、とワープホールが開き……中から何人も\nの見慣れた顔が転がり出てきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「転送完了……っと。あっ、いたいた！　キミを探していたんだよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023550001" ]},
		{"command":[ "SETCHARA", "0", "char_00023103_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジェスタ！？　それにアトロポス……戦闘員の２人まで！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00019603_01", "6", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00023103_01", "6", "CENTER", "650" ]},
		{"command":[ "SETCHARA", "2", "char_00018403_01", "6", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "3", "char_00018303_01", "6", "CENTER", "200" ]},
