{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　どうだ、主導権を握られた気分は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いつもオレのことをメス犬扱いしてたバツだ。今日はオレがお前のチンポを\n責めて、責めて、責めまくってやる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレがチンポなんかに負けないところを、イヤというほど見せつけてやるぜ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ……！　チンポも悔しそうにビクビク跳ねてやがる……！　早くオマン\nコに挿れて欲しくてたまらないって感じだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だけどダメだ。まずはオマンコの入口でじっくりと焦らしまくってやる……\n！　んっ、ふっ……あっ、あぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あっ……！　チンポがオマンコに擦れて……熱が伝わってくる\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのオマンコの柔らかいところに、硬い感触がして……オマンコの入口が\n押されていくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに、こうして上下にズルズル動いてると、クリトリスに亀頭が当たって\n……！　んっ、あっ、あっ……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「や、ヤバい……！　軽く擦ってるだけなのに、オマンコからエッチな汁が溢\nれてくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのオマンコ汁が入口のとこでチンポと絡み合って……くちゅくちゅって\n、いやらしい音がして……んっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ぐっ、あっ、あふっ……！　チンポの先端からもネバネバした汁が\n出て来たな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルがオマンコとチンポに広がって……こんなの、今すぐにでも挿れた\nくなっちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ……！　だ、ダメだ……！　チンポ、我慢できない……！　ゆっ\nくり、慎重に……角度を整えながら挿れて……ぐっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「えっ……？　は、早く挿れないのかって……？　う、うるさいっ！　今、挿\nれようとしてたんだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前は黙って……オレに責められてればいいんだ……！　い、いいか……挿\nれるぞ……！　んっ、んっ……んんんんんっ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「がっ、はっ……！？　ぶっといチンポがオマンコをかき分けながら、奥まで\n入ってきたぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのオマンコ、チンポを期待しすぎてヌレヌレになってる……！　こんな\nに滑りがよかったら、一気に子宮の入口まで届いちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、くふっ……！　もっとゆっくり挿れないと……気持ちよすぎ\nて、足が震えるっ……！　ひっ、あっ、あああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、はああぁ……！　ぶっといチンポ、奥まで届いた……！　赤ちゃんの\n部屋の入口と、チンポの先端がキスしてやがる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……！　ど、どうだ……オレのオマンコは……！　ギチギチのキ\nツキツで、気持ちいいだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「今からもっと気持ちよくして、悶絶させてやるからな……！　か、覚悟しろ\nよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ！　あっ、あっ！　やっぱりこのチンポ凄いっ……！　上下に動くと、\nオマンコのヒダが強く擦れるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「カリのデコボコしたところにヒダが絡んで……！　ぞりぞりって、えぐられ\nる感じが……ひっ、あっ！　あはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「腰を動かすたびに、尻や太ももがお前の身体に当たって……！　パンパンっ\nて、エッチな音がしてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに繋がってるところからもずちゅずちゅって、いやらしい水音が鳴って\n……！　こんなに濡れるなんて、おかしいのに……！　んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……！？　オレは別に、オマンコを濡らしまくってなんて……！　\nこれは……そ、そう！　お前の我慢汁のせいだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのオマンコが気持ちよすぎるせいで、お前のチンポが勝手に反応して、\n先端からびゅーびゅー我慢汁を噴き出してるんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んっ、あっ、ひうっ……！　ま、まったく……堪え性のないダメチン\nポだな……！　ざまぁないぜ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「えっ……？　もっと早く動いてくれたらイケそうだって……？　ふんっ……\n仕方ねぇな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前を無様にイカせるためにも、今より激しく腰をパンパンしてやるっ……\n！　オレの慈悲に感謝するんだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　ぐっ、おっ、おおおぉ……！？　んほっ、おっ、おふぅ……！？　\n動きを激しくすると、チンポがもっと奥に刺さるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オマンコも勝手に締まって、チンポの形を覚えていっちまう……！　ギチギ\nチすぎて、動きづらいくらいだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　だ、ダメだっ……！　奥の気持ちいいとこに当たりまくる\nせいで、イッちまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、お前も早く出せ……！　オレがイクと同時に、お前がイクことも許可し\nてやるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　イクッ、イクッ……！　オマンコイクッ……！　イッ、あ\nっ……んっ、あっ！　ぐっ、んくぅぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あはあぁぁぁっ！？　ち、チンポから精子出てるっ！　オレがイクのに合わ\nせて、射精してるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「我慢汁より熱くてドロドロした汁がオマンコいっぱいに広がって……！　し\n、子宮の中にまで入り込んでるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ヘソの下あたりから凄い幸せな感じがする……！　こんなの味わったら、メ\nス犬になっちまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だ、ダメだっ……！　オレはメス犬なんかじゃない……！　お前を食らう、\n猛犬なんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぐっ、おっ……おおおっ……！？　お、オレはこんなので……チンポなんか\nに負けたりしないんだぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……！　へっ……ど、どうだ……オレのオマンコは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こんだけ射精したってことは、相当気持ちよかったってことだろ……よかっ\nたな。無様に射精できて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これに懲りたら、オレのことをメス犬呼ばわりしたりするんじゃねぇぞ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「へっ……？　まだチンポは満足してない……？　ここでオレが退いたら、お\n前の勝ちだと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、オレに上等（じょーとー）コクなんて、１０万光年早ぇーんだよ！　い\nいぜ、もう一発カマしてやるっ！　出ッ発（でっぱつ）だぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、あっ！　ぐっ、あっ……！　精子がオマンコに広がってるせ\nいで、さっきより滑りが……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「や、ヤバい……！　さっきみたいなペースだと、イカす前にイカされそうだ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ここは一度速度を落として、オマンコを整えて……！　ひっ！？　あっ！　\nんんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、何で……！？　お、お前……今、勝手に腰を突き上げて……！？　お前\n……な、何してくれてんだっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレの動きが遅くなったから、反撃できると思って反撃しただとぉ……！？\n　ちょ、調子乗ってんじゃねぇぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレが遅いなんてことはねぇんだよ……！　い、いいぜ……！　見せてやる\nよ、オレの最速伝説ってヤツをなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ！　ぐっ、おっ、おおぉっ！？　ち、チンポがゴリゴリオマンコをえぐ\nってくるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「速く動きすぎるせいで、オレのポルチオが次々に責められて……！　チンポ\nの先端が、子宮とキスしまくってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひっ、んっ！　あっ、あああっ！　エッチな音が激しく響いてくるぅ！　チ\nンポも容赦なく跳ねて、オマンコに我慢汁をぶっかけてきてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「膝もオマンコも限界だっ！　オレの子宮に気持ちいいのが集まってきて、解\n放したくて疼きまくって……！　んっ、あっ！　あはあぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んひぃ！？　ち、チンポのビクビクもさらに激しくなってるっ！？　そんな\nに動かれたら、もっと気持ちよくなるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　んっ、あはあぁぁぁっ！？　これじゃあ、イカす前にオレ\nの方がイッちまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「俺が主導権を握ってるはずなのに、なんで……！　ぐっ、あああっ！　ダメ\nだ、もう我慢できないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オマンコ気持ちよすぎて、腰が止まらないっ！　絶頂（エクスタシー）と踊\n（ダンス）っちまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、おっ！？　イッ、イクッ！　イクッ！　オマンコから気持ちいいのが\n暴走（はし）ってくるうぅぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ひぎいいいぃ！？　ち、チンポから精子がどぴゅどぴゅ出てるうううぅ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレのオマンコに……いや、子宮に直接流れ込んできて……！　あっ！　あ\nっ！　これ、ヤバいっ！　気持ちいいところに熱いの届いてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「今この状況でこんなに出されたら、お前の赤ちゃん孕んじまうっ！　ボテ腹\nになっちまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっ、おほぉぉぉっ！？　も、もう出すなっ！　これ以上、オレの子宮を精\n子で汚すなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あああっ！　ダメなのに、勝手に腰が動いて射精を促しちまうっ！　あっ！\n　やっ！　やめっ……身体、止まってくれぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁー……はぁー……やっと、チンポが大人しくなったみたいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぐっ、ううぅ……こんなに膣内出ししやがって……！　それに子宮にも精子\nが……んっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お前……オレが妊娠したらどうする気だ……！？　責任取れるのか……！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もし子供ができたら、オレが総長を務めるレディースのメンバーが増える…\n…？　は、はぁ！？　何だよ、レディースって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレは別にレディースとやらの総長じゃねぇよ！　そもそも、オレはエファ\nナティカ様に忠誠を誓ってるんだ！　勘違いしてんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んひいぃっ！？　あ、熱いっ！　おっぱいや顔にベトベトした汁が飛んでき\nてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これ、精子っ……！？　な、何でチンポがオマンコから抜けてんだよっ……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そ、それより……！　どうして精子がここまで飛んで……！？　んっ、あっ\n！　やっ、やめっ……！　オレに精子をぶっかけるなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレを穢すんじゃないっ！　メス犬みたいにマーキングしようとするんじゃ\nないぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「やっ！　あっ！　やめろと言ってるのに……！　ひっ、ま、まだ出てるっ…\n…！？　あっ、んひっ！？　あっ、あはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、あぅ……！　オマンコも身体も、お前の精子まみれになっち\nまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000411_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「クソっ……勝手にチンポを抜くなんて卑怯だぞ……！　男なら正々堂々と勝\n負しろってんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「えっ……？　お前が抜いたんじゃなくて、オレが激しく腰を動かしすぎたか\nら抜けただけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そ、そんなことあるはずねぇだろ！　これは……そ、そう！　不運（ハード\nラック）と踊（ダンス）っちまっただけだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ならもう１度チンポを挿れて、今度は事故らないようにすればいい……？　\nそ、それは無理だな……！　今日はその……が、ガス欠だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}