{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0202" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "吹き飛ばされる俺の脳裏にこれまでの記憶が浮かんでは消えていく。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうだ。俺は何回もまりあに告白されそうになった。そのたびにどういうわけ\nか光の渦にのまれて廊下に戻されていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それは、さっきルナテミスたちがのみこまれていった光の渦、それと同じもの\nだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、大丈夫だっちゃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まりあが駆け寄ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まりあ……おまえ、本当に俺の知っているまりあなのか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「な、なにを言っているっちゃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりおかしいんだよ！　やっぱりおまえは、俺の知ってるまりあじゃね\nー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそも、口調がおかしいんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなことないっちゃ！　どこからどう見てもまりあだっちゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいや違うね！　おまえ偽物だな！　メカまりあか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「匂いを嗅がせろ。本物かどうか確かめてやる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
	
		{"command":[ "SETTEXT", "まりあの身体を抱き寄せ、大胆に開いたバニーの胸元に顔をうずめる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "さっきまでの戦闘でかいただろう汗の匂い。校庭の土埃の臭い。鼻の穴をめい\nっぱいひろげておもいっきり摂取する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうせ現実じゃないのなら、いっそめちゃくちゃなことをしてやる！　覚悟し\nやがれ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ち、違うっちゃ！　あっ、ああっ、そんな胸の谷間は、汗臭くって恥ずかし\nいっちゃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0210" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほ、本当に……恥ずかしいっちゃぁああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぎゃはぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そのとき、俺に電流が走る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ、ごめんなさいカツマさん！　つい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115750007" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くぅ……痺れたぜぇ……。だが、これではっきりした……やっぱりこの世界\nはおかしいってことがなぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0154" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「これは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どうかしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「どうやら、現実の方からまりあ時空に干渉があったようだ。おかげでその構\n造が弱まってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「もともと、まりあ時空はかなり不安定なものなんだ。向こうでまりあが『ぬ\nるま湯のような日常』を崩そうとすれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「おそらく本人の意志と関係なくループが発生しているんだろうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……つまり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「カツマくんとまりあとの関係に劇的な変化が起きようとすれば、ループが発\n生して、いまがその状況……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「……って、まって、凄い顔してる！　ヒロインがしていい顔じゃなくなって\nるよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750006" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「抜け駆けは許さない。カツマは渡さない。私に……もっと力があれば……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「落ち着いて。ここからが大事な話。カツマくんを助けられるかもしれないチ\nャンスが今だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750007" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それを早く言って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あ、はい。……えっとね、いまは次元の壁が弱まってる状態なんだ。だから\n、こっちも次元を越えられるものを使えば、まりあ時空に介入できる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750008" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「次元を越えて……そっか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「でも、そんなことができるのは……って、カグヤ？　ちょっと、どこ行った\nのさー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115750009" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……妙だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにがだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私たちが出てきた光の渦が消えていない。いつもなら、古時計のところに戻\nらないといけないのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115750002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「たしかに、どうして今回に限って消えていないんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「どうする？　また突撃するか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも、またまりあちゃんに追い出されたりしないかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そうだね。なにか対策をたてておかないと、また同じことの繰り返しだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「アナザー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どうしたカグヤ、というか、いままでどこに行っていたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「話はあと！　ドラグソードをだして！　まりあのいる次元の壁を破壊して！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750007" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ、そんなこと……たしかにドラグソードには可能だが……しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「い、い、か、ら！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750008" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、わ、わかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こいっ、ドラグソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115750004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ドラグソード、あの渦を攻撃して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115750009" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}