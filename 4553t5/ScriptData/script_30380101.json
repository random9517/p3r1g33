{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "038_0103101" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「はいな～！　隊長さん、私来たよ！　で、今日はナニ？　……ン？　私にさ\nせたいことがアル……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103102" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ン……。それはアレか？　私を自分のいいよーに利用したい、てことカ……\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103103" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「権力をかさに着る男は嫌いヨ。戦神蚩尤を舐めたらあかんアル。言うてる意\n味わかるナ……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103104" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私は確かに、今隊長さんの言うこと聞いてるヨ。でも……本気になったら、\n隊長さんを殺して、ここ、壊滅させてやってもいいんだからナ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103105" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「て、違う？　もっと仲良くなりたかっただけ？　あー……そうなノ。てっき\nり、いつものパターンかと思たヨ～」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103106" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私、めちゃ強いからナ。色んなトコから利用しようとするヤツわらわらいた\nアルの。でも……隊長さんは……えと、なんだっけ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103107" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私と仲良くしたいアルな？　んん？　しかも、パワーアップさせてくれるア\nルか？　おおー！　それならそうと早く言ってヨ、威嚇しちゃったヨ～！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103108" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ふむふむふむ～～～？　フェラチオか。それをすると、隊長さんと仲良くな\nれた上に強くなるのナ。わかたヨ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103109" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……エ？　疑わないのか？　フフフッ、疑うわけないヨ。これでもけっこー\n人を見る目あるノ。隊長さんはイイ人。だから信じル！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103110" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「それに、セックス要求されてわけでないしナ～。ちょびっとオチンポ舐める\nだけでショ？　いいヨ！　スルから早いとこオチンポ出してナ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103111" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……ってひゃわわわわわ！？　エ！？　デカすぎない！？　隊長さん、これ\n、コレッ！　私の知ってるチンチン違う……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103112" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……て、店長のお子様をお風呂に入れてあげたことあるアルが、もーっとも\nっとちびちゃいプニプニちんちんだったノ！　コ、コレ何？　ナニ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103113" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「エ、エエエ～……こんなデカイの舐めるのイヤよぉ……。ちっちゃいのペロ\nペローてして終わり、めちゃ楽～て思たのに～。ぶーぶーぶー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103114" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「めっちゃエッグイ形してるシ～！　なんかクサイし～！　ウウッ、安請け合\nいなんてするんじゃなかたヨ～！　やめていいカ～？　ダメ～！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103115" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……ダメか……。はぁ……まあ、仕方ないナ。する、出来る、言ったこと撤\n回するの、商売人のすることじゃナイ……。我慢する……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103116" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「でも、むっちゃコエ～……。オオオオ……。こんなノどやってズボンに入れ\nてたノぉ……はみ出るヨぉ……めそめそめそ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103117" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……む～～泣いてても進まない。やってやるアル……！　う……ぺちゃ……\nっ……。ぺちゃっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103118" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ンンンンン～～～！？　変な味ッ……！　いちいち予想を超えてくるアルね\nぇ～～～！　っ……チュ、チューするのも微妙アル……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103119" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「でも、でも……約束しちゃったかラ……。ううう……。ぺちょっ……ぴちょ\nっ、ちゅ、ちゅ、ちゅぅ……。ちゅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103120" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　な、なんか動いたァ……！　ヤダー！！　ちゅっ……チュ、ち\nゅ、ちゅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103121" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「も、もうイイ？　私フェラチオしたよネ？　もー帰ってイイ……？　んぐっ\n……こんなのじゃダメ？　うーーーーーイヤよォ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103122" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「隊長さんのバカぁ……！　大体ちんちんは食べ物じゃないのヨ、お口に入れ\nるモノと違うのヨぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103123" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私にこんなコト要求する隊長さんは変態アル。ヘーーンーーターーイーーー\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103124" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「うう……チロッ……。ちろ、ちろ……ぺろっ……れろ……。ぐぅ……。ちん\nたらやってたら永遠に終わらないみたいアルな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103125" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「いたしかたナシ！　嫌だけド……めっちゃ嫌だけド、がぷっといくしかない\nアルね……。うう……ごくっ……お口に入りきるか不安だけドも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103126" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「はぷっ！　ん……ん、ん、ん……。ぢゅる……うええええっ……！　しょっ\nぱみえぐみが増して……ちんちんの味ヨ……おえええ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103127" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んぐっ……んぶ、んんぅ……！　ぶちゅ……ぐちゅっ……ぬちゅ、ぬぷぷ、\nぬぷ……！　ずちゅっ……ぐちゅっ、にゅぷぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103128" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「おえっ、ううう……！　私の口の中……ちんちんの味と臭いでイッパイ……\n。げほっ……じゅぷっ！　じゅぷっ、ぢゅぷっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103129" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ぐぷっ……ずちゅっ、ずっぷっずぷっ……！　うえええ……！　おえっ……\nぢゅるっ……じゅっ、ぢゅるっ、ぢゅる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103130" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んッ……！　んっ、ん、ん……！　おえっ……や、ヤダぁ……。ほっぺの裏\n側に、チンポの先っちょくっついてぇ……うううっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103131" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「なんか、舌の上でヌルヌル動いて、喉に入ってくるノぉ……！　ふ、太いの\nで気道塞がないれヨォ……死んじゃうヨぉ……けふっ、けふ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103132" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ヤダ……ヤダ、ヤダぁ……。ぐぷっ！　ぢゅるっ……！　ずりゅっ……ぢゅ\nるっ！　ぺろっ、ぺろぺろぺろ……ぐちゅっ！　ぐっちゅっずちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103133" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んむっ……んん、んん……！　れろっ……れろっ、れろ、れろ……。ごぷっ\n……！　ンン……！　ぢゅるっ！　ぢゅるぢゅるぢゅるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103134" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ぐちゅっぐぷっ、ずりゅっ、ずりゅずりゅじゅるっ……！　ぐっちゅっ！　\nぐっちゅっ！　ぐっちゅっぐちゅっ……うううう～～～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103135" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アッ！　なんかお口の中にビュッて出たヨ！？　ナニっ！？　ナニこれっ…\n…アアアアッ！？　つ、次々飛び込んでクル、も、もーやめてェ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103136" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「嫌っ、いや、いやーーー！　うぷっ！　んううううー！　出さないでっ、出\nしたらダメぇ！　変な汁私の口に……うぷ、出すのやめれぇえ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103137" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「あああああーーーー！　きちゃないィ、きちゃないヨォ……！　ちんちんか\nらヘンな汁出すなんて信じられないヨ～～～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103138" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ぺっぺっ！　うーーー口も喉もイガイガすル～～～！　もうイヤッ！　私、\nうがいしにいくアル！　止めても無駄アルよ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103139" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「うぇええ～にがにがヨ……。知らなかったアル、ちんちんは白いネバネバ汁\n入ってル……。もー金輪際触んないヨ、何が仲良しパワーアップヨぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103140" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「人生で一番ヒドい目にあったヨ、泣いちゃいそうヨ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103201" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……って隊長さん！？　ちんちんまたデッカくなったアルけど！？　ナンデ\n！？　私、イヤて言ったのに……それで興奮したノ！？　ヘンタイ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103202" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「お、オマワリサーン！　ここに変質者いるヨぉ……！　て、エッ！？　フェ\nラチオはまだ終わってないィ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103203" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「もっと勢いよくすすって、舐めて、しゃぶって、口の中でぐっちょぐっちょ\nヌチョヌチョしないとダメ……？　あいやー本当なノそれェ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103204" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「う、疑ってないヨ、隊長さんのこと信じてるケド……！　隊長さんのちんち\nんのことは信じてナイ……！　それに見てヨ、口の中ドロドロなノ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103205" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……ドロドロのまましろテ……！？　はぅああああ……！　こんな理不尽な\n要求、飲食業でもなかなか見なイ……！　で、でも……うむ……うぅん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103206" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「確かに、まだパワーアップしてる感じしナイし……。そーなのカも……。わ\nかた、あ、あとちょとだけ……ちょっとだけヨ……えーーーん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103207" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「もーちんちん怖すぎるから、一気に全力でたたみかけさせてもらうアル……\n！　大丈夫、大丈夫……私だったら出来る、出来る……ハズ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103208" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「えーい！　はぷっ……！　にゅるっ……にゅぷぷぷっぢゅるっ！　ぢゅぷっ\n！　じゅぷっ！　じゅっぷっ、じゅぷっ、じゅぷぷぷ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103209" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ぐちゅ、ぐちゅ、ぐちゅ……はぅう……れろんっ……！　れるっ、\nれる、れろ……れろぉ……うぷ……！　んぐぅっ、んむ……ぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103210" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んぐぷっ……！　ぐぷっ、んぐ、んむぅ……！　ぢゅるっ！　じゅる、じゅ\nる、じゅるる……んんん……やっぱり、この味と大きさには慣れないガ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103211" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「フフ、隊長さんが気持ちよさそーだからサービスしてあげるアル。皆には内\n緒ヨ……んん！　ぐちゅっぷっ！　ずるるっ、じゅっぽじゅっぽっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103212" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「れろっ、レロレロレロレロ……じゅるっ！　ぢゅるるるっ！　ぷぢゅっ、ぢ\nゅっぷっ、ぢゅっぷっ……アハ……やっぱ気持ちが大事？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103213" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「隊長さん、めっちゃチンチン痙攣してきタ……。私も、マジで必死、だけど\nナ……！　それ、それそれ……レロレロレロレロ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103214" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「私がここまでしてるのヨ！　盛大にビュッビュしちゃいナっ……！　べろっ\n……べろべろっ！　れろんっ、れるんっ、れるっ……ぢゅるるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103215" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ぢゅっぷっぢゅっぷっじゅっぷっじゅぷっ！　んんぐ……っぢゅるっ！　じ\nゅるっじゅぷっ！　じゅぷっじゅっぷっじゅぷっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103216" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「いいヨ……隊長ひゃん……もいちど出したいアルよね……最後まで……最後\nまで、私導いてみせる、から……来るアル……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103217" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ずっちゅっ！　ぷちゅっ！　ぶちゅっぐっちゅっぐちゅっ……！　んんッ…\n…！　コレ、出す前のスッゴい痙攣……来るノ？　来るノネ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103218" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「早く、早く出すアル……！　っずりゅっれろんっれろんっ……！　れろっ…\n…！　ヂュルッ、ぢゅるるっ、ぢゅるんっ、ずちゅるっ……はぷっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103219" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「臭いお汁出しテ……！　そしたら……！　うっぷっ、隊長ひゃんは気持ちイ\nイ、私解放される、いいコトばかりヨ……早くぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103220" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「出しへ……出しへぇ……！　ぐっちゅっ！　ぐっちゅっぐちゅっ！　ぢゅる\nぢゅるぢゅるっんんんんーっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "038_0103301" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んんんっんぷぅううっ！　んーーーーっ！　んんんーーーっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103302" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「うっ、うう……ううう……いやぁあ……。またお口に出しっ……出したネ…\n…！　げほっ、げほごほっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103303" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「んもぉお……！　隊長さ、ん……そーゆーの好きなノ……？　マーキングみ\nたいな……ごほっ……嫌ヨぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103304" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「うぇえ……口の中がねっちゃねちゃのネバッネバぁ……。えふっ……こ、コ\nレどうしたらいいノ……飲むノぉ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103305" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……えーーん……絶対、ゼッタイ美味しくないヨ……。でも……いつまでも\n口の中にあるのもヤだシ……。うーーーーん、むぐ……ぐちゅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103306" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ごきゅっ……ごくっ、ごくんっ……。ハァ、ハァハァ……ど、どうヨ……？\n　ちゃぁんと飲んだヨ……。これでもう文句ないアルな！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103307" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「けぷ……。なんか、喉の奥で絡まってる感じスル……。ねばっこいのがいつ\nまでも残って、けぷ……。めっちゃ臭いヨぉ……どーするノコレぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103308" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「隊長さんのちんちんの味、一生消えなかったら恨むヨ……。それに、遠慮な\nしにビッチャビチャ出すからァ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103309" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「なんか、今日はもう何も食べなくてもお腹イッパイ……。胃の中でお汁がタ\nプタプいってるアル……。あまり考えたくないガ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103310" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「この汁全部消化するまで、なんも食べる気がしないヨ……。そーゆー意味で\nは、高カロリー高タンパクでいいのかもナ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "038_0103401" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ンンッ！？　む、胸っ！？　私の胸に出すのカッ！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_12" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103402" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「アッ！？　あっ、ぁっあっあっ！？　あわわわっ、わわわ……！　ヤダっ！\n　ビュル、ビュルてかかって……あーっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103403" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「わぷっ、んぷぷっ……！？　やぁあ……！　私、胸にかけていいて言ってな\nいヨぉ……！　ナニするノぉ……ひーーーん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103404" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「エ？　ずっと胸にぶっかけてみたかった……？　はわわッ、やっぱ隊長さん\n変態アル～！　私の感覚正しかっタぁ～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103405" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……あ、アア……胸のふくらみを……ぬったりしたくっさいお汁が流れてく\nヨ……。こんなのが見たかったアル？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103406" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ヌルヌルして、ドロドロして……おっぱいにねちゃねちゃまとわりついてく\nル……。あーーん、もうこれでお嫁さんに行けなくなったヨぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103407" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「だって、だってちんちん舐めて、おしゃぶりして、乙女の柔肌にブリュブリ\nュお汁垂らされたのヨぉ……おしまいヨ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103408" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ほらっ、ほら見テ！　赤ちゃんにお乳あげる大事な胸……隊長の汁でダラダ\nラ……。えーーーん、穢されてしまたアル～～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103409" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「この責任、どう取るつもり～～～！？　う、ウン、隊長さんと仲良くなりた\nいて気持ちは嘘じゃないし、パワーアップもしたかたケド……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003801_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "038_0103410" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「で～～～も～～～！　こんなに汚い汁何度もビャービャー出されたんじゃ文\n句の一つも言いたくなるのヨ！　つ、次からは気をつけてナ！！」", "NORMAL" ]},
