{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、えっと……そのままじっとしてて、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「今日はね、海につれてってくれて、とってもうれしかったの。だからね、イ\nルルもおとーさんにお礼したいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「それでね、おちんちん……ぺろぺろするから……もし、いたかったらちゃん\nと教えてね、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あふぅ……でも、おとーさんのおちんちん、すっごくおっきい。こういう時\nって、苦しいんでしょ？　だから、イルルが楽にしたげるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はむっ、んちゅぷっ、くぷっ、んぽっ、あぁん……むっ、んりゅっ、はむ、\nんふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぐ、むご……ふごい……んんっ、あぁんって、お口いっぱいにしないと、\n入らないね……ん、りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ん、でも、だいじょうぶだよ。イルル、むりしてないし、おとーさんのおち\nんちんの味……好きだから……んちゅぷっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だから、んっ、おとーさんは、そのまんまにしててね。イルル、がんばって\n……ちゃんとするから、くぽっ、りゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふぅっ、じゅぽっ、じゅぱっ、ちゅぷっ、んふぅ……えっと、まず、先っ\nぽのところ……ぺろぺろするんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「れろ、ぺろっ、えろんっ、それで……んっ、ぱくってひて……んふっ、りゅ\nぽっ、くぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「お口の中で……またぺろぺろって……んりゅっ、何度もしてあげるの……ち\nゅぱっ、じゅぱっ、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふふぅ……おとーさん、きもちいー？　んっ、イルルもね、おとーさんの\nおちんちん、ぺろぺろしてるときもちいーになるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「なんだかね、からだがぽかぽかして、ほわーんってなるのが好きなの。これ\nって、イルルだけなのかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んふっ、りゅぱっ、お口の中で、つばがいっぱい出てきてね……\nはぷ、んんっ、気をつけないとこぼれちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はぷ、んむっ、あふっ、りゅぱっ、じゅぽっ、んふぅっ……これで……いい\nのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、んりゅぷっ、イルル、ちゃんと出来てる？　おちんちん、白い\nのいっぱい出せそう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うんっ、よかった。このまま、イルルがんばって続けるね。はぁんむ、くち\nゅぷっ、ちゅぱっ、りゅぱっ、んちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのおちんちん……少しだけしょっぱいね……ちゅぱっ、んちゅっ\n、海にいっしょに入ったからかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、この前もそうだった気がする……ちゅぱっ、あっ、でもね、ちゃんと\nおいしーよ？　だから、だいじょうぶだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えっ、イルルなにかヘンなこと言った？　だってニコニコしてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルやさしいの？　んと、よく分かんないけど……おとーさんがうれしい\nのはイルルもうれしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ……だからね、もっともっとイルルがんばるから……んちゅぱっ、ぴち\nゃ、ちゅぱっ、んちゅぷっ、ちゅぷぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁ……おっきいけど……んむぐぅっ、くにくにしてて……はふう……\nやわらかいの……ちゅぱっ、んぷぁっ……あむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、こっちのぶらぶらしてるのはへーき？　ちょっとさすさすした\n方がいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふわわっ……今、おちんちんビクってした。そっか……ここは気をつけない\nといけないのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん、分かった。じゃあ、またして欲しくなったら言ってね。ちゅぱっ、イ\nルル……おちんちんの方いっしょうけんめいするから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、ちゅぽっ、んふぅ……くぽっ、りゅぱっ、んむっ、むずかしい…\n…ね……んちゅぷっ、すごく上手にできる人……いるんれひょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルのも上手？　ホント……？　あ、うん……おちんちん、ぴくぴくして\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「そっか、きもちいーと、おちんちん、ぴくぴくするんだ。じゃあ、ちゃんと\nイルル……出来てるのね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、よかった。あむっ、んちゅぷっ、イルルもっとペロペロするからぁ…\n…はぷっ、りゅぱっ、んじゅるっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぁ……なんだか、おちんちんから出てきた……んちゅるっ、これ、おとー\nさんがきもちいーから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うん、後もうちょっとなんだ……じゃあ、イルル……最後までがんばる！　\nんくぽっ、りゅぷっ、じゅぷっ、んちゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あぷっ、よられ……れひゃう……はぁんむ……おとーさんのおち\nんちん……ビクビクしれるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あむぅっ……んちゅぷっ、おとーさん、出したいの？　おちんちん、ぴゅっ\nぴゅしたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、このまま……らひてっ、イルル……おとーさんのせーえきっ、飲\nみたいからっ、ちゅぷっ、んちゅぷ、んちゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　んふっ、んんっ！　ふぁ……おひんひんっ、れたぁっ……ん\nっ、んぷぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふあぶっ、んんっ、こんら……いっぱい……あふぁ……ごめんらさい、おと\nーさん……んっ、イルル……飲みきれない……んぷぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ふぁ……せっかく出してくれたのに……こぼしひゃった……\nちゅぱ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「え……？　すっごくきもちよかったから、いっぱい出たの？　そっか……え\nへへぇ、おとーさんがよかったら、イルルもよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でもでも、えっとね……こんどはもっと、ちゃんと飲めるようにがんばるか\nら。イルル、もっともっとがんばるね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ……おとーさんのおちんちん……またピクってした……これって、まだ\nしたいってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「やった！　えへへ、じゃあイルルね、またがんばってぺろぺろするね！　あ\nむっ、んちゅぱっ、ちゅぷっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あむ、んぱっ……おちんちんの味に……さっきのせーえきの味……いっぱい\nしてる……ちゅぱ、んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルね、おとーさんのせーえきの味、好き。ドロっとして、ちょっと飲む\nの、たいへんな時あるけど……ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「でも、におい……くんくんすると、あたまがぽーっとなって、なんだかとっ\nてもきもちいー感じになるの……りゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だからね、今もね……れろ、ぺろっ……おちんちんぺろぺろしながら……し\nっぽとか……ムズムズしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だからね、おとーさんがきもちいいとね……イルルもいっしょにきもちいー\nの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、じゅるっ……せーえきとおちんちんの味でぽわぽわして……んふ\nぅ……もっと舐めたくなっちゃうの……ちゅぱ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んんんっ……はぁ、おいしい……おとーさんのおちんちん……好きぃ……ち\nゅぱ、ぴちゃ……ちゅぷ、れろ、ぺろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あったかくて……しょっぱくて……やわらかいのと、かたいのといろいろで\n……それで、えっと……えっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、イルルね……おとーさんに、いっぱいきもちよくなってほしいの\n……ちゅぱ、ちゅぽっ、んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「いま、すっごくきもちいい？　えへへぇ……やったー、イルルで……おとー\nさん、きもちよくなってくれてるんだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おちんちんの、どのへんが好き？　れろ……このかめさんのとこ？　れるっ\n……奥のふよふよのとこ……？　ちゅぱっ、ふぉれとも、こっひ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、イルル……どこでもするよ？　ちゅぱっ、おとーさんの好きな\nとこ、いっぱいいっぱいしたげるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、んぁ……またおちんちんから出てきた……はぁ、んちゅぷっ……\nおとーさん、また出ちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぷっ、りゅぱっ、また……いっぱい出るのね？　イルル……ちゃんと、じ\nゅんびするから大丈夫っ……ちゅぱっ、んりゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぁむっ、ちゅぱっ、いつれもっ、いいよぉっ……おちんちんっ……あんむ\nぅっ、んちゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふっ、じゅぷっ、ちゅぷぅっ……おちんちんプルプルしてる……おとーさ\nんっ、出して……いーからねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルもっ、じゅぽっ、もっろがんばるからっ……んあむっ、おちんちんっ\n、ぴゅっぴゅってしてっ……」", "NORMAL" ]},
