		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くん、いらっしゃい。急にこんなところに呼び出しちゃってごめんね。\nふたりっきりになるなら、この部屋が一番だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あらあら、身構えなくていいのよ。だって、私が隊長くんをお仕置きする理\n由はないでしょ？　隊長くんも、心当たりないわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「そうじゃなくって、今日はいつも頑張っている隊長くんを労ってあげようと\n思って。隊長くん、私に甘えてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00026202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「……そうね。とりあえず脱ぎ脱ぎしましょうか。ほらほら、ズボンを下ろし\nて……ふふっ、オチンチンがふっくらしているわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「私も脱いじゃうわね……んっ、どうかしら？　隊長くんは、私のおっきいお\nっぱい、好き？　うふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026202_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「こういうの……どう？　隊長くんのオチンチンを私の乳首に近づけて……。\nンッ、先っぽが乳首に当たっちゃったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンに乳首……つんつん、くりくり……って。ふふっ、だんだん私の\n乳首も勃起して……ンッ、大きく、膨らんできちゃうわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンと同じように、硬くなって……。ああ……隊長くん、わかるかし\nら……？　こんなに、興奮しちゃってるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんのオチンチンも、すっごく熱くなっているわね……。あんっ、手の\n中で、びくって震えちゃっているわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「私の乳首に……こりこりって、刺激されて……ンッ、気持ちいい……？　ふ\nふっ、オチンチンは素直に反応しているわよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「でもね、私の乳首はこれだけじゃないのよ。これから、もっともっと隊長く\nんのオチンチンを興奮させてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、んん……っ。もうちょっとだけ、強めに……あんっ、乳首をオチンチ\nンにこすりつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ああ……んふぅ……♪　アツアツのオチンチンで乳首火傷し\nそう……んっ、あふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「このまま……乳首で……んっ、私もいっぱい、きもちよくなると……ね……\n。んぁっ、見ていて、隊長くん……んっ、んん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁっ、んふぅうううぅぅぅ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ほ……ほらぁ……。乳首でたくさん気持ちよくなったから、母乳……でてき\nちゃうんですよ……んふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんのオチンチン……あんっ、私の母乳で、ヌルヌルになっちゃいます\nね……んっ、んふぅ……あっ、ああ……ン……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「……っと、私だけが気持ちよくなっちゃダメですね。隊長くんのことも、ち\nゃんと気持ちよくしますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ほら……んっ、ますます硬くなった乳首で、隊長くんのオチンチンを刺激し\nます……んっ、んふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「裏筋や……エラのとこ、も……んっ、乳首とオチンチンの先っぽ同士、ツン\nツンってするのも、どうですか……？　んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンが……ますますビクビクって、震えていますね……。んっ、ああ\nっ、隊長くんも気持ちよくなってるの……伝わってきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……私も……。滑りがよくなって、乳首がいっぱい擦れるよう\nになって……んっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「気持ちよくなって……んっ、じわぁっと、追加の母乳が溢れちゃってます…\n…。あぁ……んふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「もっと……激しくしちゃいますよ……。ズリズリって、乳首でたっくさんオ\nチンチンを刺激して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、んぁっ、乳首……んく……ふぅ……。どんどんガチガチになるオチン\nチンで……気持ちよくなっちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんも……気持ちよく、なれていますか……？　うふっ、オチンチン、\n膨らませて……ンッ、震えてます……ああんっ♪」", "NORMAL" ]},
