		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「乳首気持ちいい……んっ、甘えん坊のオチンチンを押しつけられて、ちっち\nゃい絶頂が何回もきちゃってます……」", "NORMAL" ]},
