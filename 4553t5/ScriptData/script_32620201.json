		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……でちゃってるっ、また……たくさん母乳……でちゃって…\n…んっ、ああぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんのオチンチンからも……ネバネバした、元気な精液がいっぱい……\nんっ、すっごく……エッチな匂いぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……どうだったかしら……。私の乳首と、母乳……気持ちよか\nった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ふふっ、でも……まだまだオチンチンは満足できていないみたいね。こんな\nにガッチガチのままだもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くん、今日はとことん労ってあげるんだから。もっともっと、私に甘え\nてちょうだい。私もいっぱい甘やかしてあげます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ほら……こうやって……射精したあとのオチンチンをさすってあげながら…\n…。んっ、反応して、ビクビクしてますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……さっき射精した精液で、どんどんおっぱいがヌルヌルにな\nっていきますよ……ん……ふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「私も……ンッ、乳首……さっきイッたばかりだから、敏感になって……。は\nぁ、はぁ、母乳……でてきちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くん……乳首ズリ、気持ちいいですか……？　ふふっ、もっと激しく乳\n首をこすりつけますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「まだまだ……射精したりないって言ってるオチンチン……。あんっ、いっぱ\nい、労っちゃいますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んっ、んぅっ♪　乳首っ、軽くイクたびに、ぴゅっぴゅって母乳が噴きだし\nて、オチンチンにひっかけちゃってます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026202_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んふっ、隊長くん……すっごく興奮しちゃっていますね……？　私の、いや\nらしい乳首見ながら、ますます硬くして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「私の乳首の感触で……ンッ、もっとも～っと気持ちよくなってくださいね…\n…あんっ、私ももっともっと、こすりつけちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「ミルクまみれ乳首……んっ、いっぱい、パンパンになった亀頭に……んくっ\n、ズリズリ～って……んぁっ、ああ……ン……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「腰を突きだして、私の乳首をぐりぐり～って。ンッ、そう……そうやって私\nに甘えていいですよ～♪」", "NORMAL" ]},
