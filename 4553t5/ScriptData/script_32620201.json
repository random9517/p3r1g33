		{"command":[ "SETIMAGE", "0", "still_00026202_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんも、腰が動いちゃっていますね……んっ、ああっ、いいですよ……\n私の乳首に、甘えてください……んぁっ、んっ、んん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「オチンチンと、乳首ぃ……っ♪　ぐりぐり、ズリズリって……んっ、ああっ\n、すごくっ、気持ちよくなっちゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、隊長くん……このままじゃ、私またイッちゃいそう……。\n隊長くんを、乳首でねぎらいながら、また……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんも？　んっ、それじゃあ、隊長くんもイッて……一緒に、イキまし\nょう……んっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「隊長くんがイクように、私も、乳首いっぱいこすりつけて、気持ちよくする\nから……んっ、んぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「い……イク……イッちゃう……！　乳首……んっ、また、乳首イキ、きちゃ\nう……はぁっ、はぁ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
