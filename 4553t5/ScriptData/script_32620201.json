		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んぅっ、はぁ……こすりつけ……激しく、乳首とオチンチン……んっ、ああ\n……もう……私も感じすぎて……♪」", "NORMAL" ]},
