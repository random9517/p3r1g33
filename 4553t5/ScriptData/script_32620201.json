		{"command":[ "SETIMAGE", "0", "still_00026202_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「このまま……オチンチンのこと、イかせちゃいますからね……んっ、ああ…\n…もっと、激しくこすりつけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_262_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、勃起乳首で、オチンチン……んっ、んふぅ、ズリズリって\n……んぁっ、んっ、ふぅ……っ♪」", "NORMAL" ]},
