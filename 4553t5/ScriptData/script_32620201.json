		{"command":[ "SETIMAGE", "0", "still_00026202_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マキ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、んぅ……♪　勃起オチンチン……感じて……。はぁ、ふぅ…\n…乳首……熱くなってきちゃいます……♪」", "NORMAL" ]},
