		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いくぞぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「覚悟しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガン・シスター" ]},
		{"command":[ "SETTEXT", "「やっつけてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "変身した俺たちに、ルナテミスたちがおそいかかる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「味方が相手じゃ攻撃しにくいだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115910001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「昨日のように、無様に敗北するがよいのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「悪いけど、こっちは昨日までのわたしじゃないのよね！　夜叉！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「は、はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バッケンローダーの合図に、夜叉が金棒を投げ渡す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ところで、バッケンローダーに金棒を渡したら、夜叉は丸腰になっちまうん\nじゃないか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「安心してください、金棒にはまだまだスペアがありますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910002" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう、そうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "特訓の最中に何本も壊されていたが、まだ予備が残っていたんだな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ありがとう、夜叉！　……ふんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910002" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "金棒を受け取ったバッケンローダーが、その先端で地面を突く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　金棒ぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その先端がぐにゅっと曲がった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「……あ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910003" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「大事にしてくださいって言ったじゃないですかぁっ！　なんでもうすでに筋\n力がゴリラなんですか！　ゴリラが滲み出てますよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ちょっ、夜叉までひどくない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910004" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「刀と……金棒……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115910001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そんな重たそうな金棒、かえって足手まといになるんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115910002" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そんなことありません！　桃花さんのゴリラ級の筋力なら、刀と金棒を同時\nに扱うなんて、ちょうど今の時間帯……つまり朝飯前です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910005" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ゴリラも泣いて逃げ出すほどの脳筋力（パワー）で、あっさり洗脳された赤\n点娘たちを一網打尽にしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910006" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ちょっと夜叉！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910005" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やい、パチもんトリオ！　武器を２本持った殺人ゴリラに、てめーらごとき\nが勝てると思うなよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が何度死にかけたと思ってやがる！　伊達にあの世は見てねーぜ！　さあ\n行け、ゴリラ女！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「カツマさん、もしかして怒ってる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、別に無理やり特訓に付きあわされたことを根に持ってなんかいないぞ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「夜叉も……えっと、金棒のことはごめんって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「知りません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115910007" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あー……もう！　今はとにかく……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0212" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "バッケンローダーが大桃切と金棒をカチンッと打ち合わせる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「バッケンローダー・ツインソード！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115910009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "広がる透明感のある音、そして衝撃波。すべてが止んだとき、バッケンローダ\nーの新たな姿が現れる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「バッケンローダー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115910002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ツインソード！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115910002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガン・シスター" ]},
		{"command":[ "SETTEXT", "「かっこいーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115910002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
