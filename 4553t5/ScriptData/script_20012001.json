{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やれやれ……毎度ながら、人使いの荒い長官だぜ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そういう言い方は感心しません。これも立派な任務の一つです。拝命された\nことを光栄に思うべきです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はー……相変わらず真面目なこったな。急に見つかった怪しい地下室の調査\nなんて……どう考えてもろくな話じゃねぇだろうに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何でもねぇ異常なしの報告が出来るなら、適当に時間が潰せて、いい仕事で\nしたって言えるけどな。まぁ、十中八九ろくなことにはならねぇな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「どうして、そんなことが分かるんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「正直自分でもパッと説明出来ることじゃないが、まぁイヤな予感って奴だな\n。で、これがよく当たると来てる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ……そんなものですか、ん……これは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何か見つけたのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁ、いえ、何となく窪みになっているような所が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい、迂闊に触ったりするなよ？　どんな罠が……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「ぽちっと……えっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉぉぉいっ、だから押すなって……うわぁぁぁぁぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "М・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「カツマさんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021610007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い……つつっ……たく……言ってる側からこれだよ……どこだ、ここは……\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「落とし穴みたいな所から落ちた筈なんだが……天井は何ともなってねぇな…\n…くそ、出口は……どうなってるんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「結構広いが…………お、おいおい……勘弁しろよ、閉じ込められるとかない\nぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？　これは……何だ……窪んだ場所に……スイッチ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何だよ、このいかにも胡散臭いのは……いや、待て待て……慌てるな。まず\nは、よく辺りを探して出口を確保してからだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……やっぱり何もねぇ……とりあえずこいつを押すしかないのか……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええいっ、罠でも何でも来るなら来やがれっ……そりゃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だっ！？　やっぱりヤバいヤツだったかっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「し、下から……何かせり上がって来てるっ？　ひ、棺みたいなのが……う、\nうわわわわっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な……何だこれ……妙な棺桶みたいなのが……いち、に、さん……４つ……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうなってんだ……扉は開かねぇし……こんな不気味な状態のまま……うぉ\nっ……な、何だ……動いた……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁぁぁぁー、あぁー……よく寝たぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610001" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「全くぅー、カラダ……バッキバキになってるしぃ……♪　ホーント、かった\nるいったら……あら、あららぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610002" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……お、お前は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あら、あらあら♪　我に向かってお前呼ばわりとか、マジで命知らずぅ？　\nキャハっ、ちょー生意気ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610003" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "な、何だ……このやべぇ殺気は……？　背筋が……凍りつくような…\n…身体がう、動かねぇ……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おいおい、なーに、起きた早々に物騒な気配撒き散らしてんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610001" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「全くですわぁ……朝のまどろみの時間は至高のひととき……それを邪魔する\nのは無粋の極みですのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021610001" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「残念ながら、朝って感じじゃなさそうだけど？　ま、この解放感自体は似た\nようなものだと思うけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021610001" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ま……また……次から次へと……一度に４人……だと？　しかも、ど\nいつもこいつもやべー感じがする……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あららぁ、あんたらも今、お目覚めぇ？　あははっ、めっちゃ、のんきねー\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610004" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「お互い様だろ？　それより、せっかく起こしてくれた戦闘員をいきなりビビ\nらせてどーすんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610002" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へ……せ、戦闘員……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「そうですわねぇ。この子が、ウチらノートちゃんたちの封印を解いてくれは\nったんじゃありませんの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021610002" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「へぇ……そうなのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021610002" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「なぁーんだ♪　そーだったの？　それなら、そーと、先に言ってくれたらよ\nかったのにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610005" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、いや、その……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「まぁ、ファンタズマに睨まれたらビクつくのも無理はねぇ。見た目はお子ち\nゃまでも、目ぇ見たらヤベぇのはバレるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610003" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だーれがお子ちゃまだってぇ？　先にあんたがザックリ貫かれて、トマトジ\nュースにされたいかしらぁん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610006" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「はっ、上等じゃねぇか、ちょうど体もなまってたトコだ。アタシの大鎌に血\nを吸わせてやるのも悪くねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610004" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「全く……野蛮ですわねぇ。そんな調子やと、またこの子が怯えはりますわよ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021610003" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「すぐに脱線する……四天王としての規範は守って欲しいものだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021610003" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あららぁ♪　いっけない、我としたことが、ついついテンション上がっちゃ\nうしー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610007" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「ふふ……久しぶりのことだから仕方ない。どうだい、せっかくだし、いつも\nの『アレ』をするというのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021610004" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おー、そうだな。せっかく、封印も解けたんだ。こいつにも、アタシらのこ\nとをはっきり分からせてやんねーとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610005" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……お、俺……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んふふぅー♪　他に誰がいるしー？　我ら、次元旅団……オーヴァーハング\n四天王！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610008" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「魅惑の芳香で、人を狂わせ悪夢の虜にする……オーヴァーハング四天王、東\nのラストノート！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021610004" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「怒りに満ちた鬼の力で、全てを刈り取る大鎌を振りかざす……オーヴァーハ\nング四天王、西の奈羅苦！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610006" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あらゆる嘘を断罪し、潔癖なる真実の世界を作り出す……オーヴァーハング\n四天王、南のアルスラ・マグナス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021610005" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そしてぇ、我がぁ……この、次元旅団オーヴァーハング四天王、最強にして\n最上！　北のファンタズマだし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610009" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「おいおい、ナニ勝手に最強名乗ってんだよ、名乗りはただの東西南北順で、\n関係ないだろーが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610007" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「でもでもー、事実は事実だしぃー♪　我が最強なのは黎明から決められた真\n理の中の真理♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021610010" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「上等だぁ、やっぱり決着付けなきゃ分かんねーみたいだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021610008" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「まぁた始まった……けど、確かに最強を分からせてあげる必要はありそうで\nすわねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021610005" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「面白い……どの道、避けて通れない運命だったということかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021610006" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
