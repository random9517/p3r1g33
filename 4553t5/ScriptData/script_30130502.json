		{"command":[ "PLAYVOICE", "v2_013_0504134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「こうっ、してっ……んんっ……気持ちいいですかっ？　私もっ……あぁっ、\n気持ちいいですっ、オマンコっ、ヒクヒク……させますぅっ……」", "NORMAL" ]},
