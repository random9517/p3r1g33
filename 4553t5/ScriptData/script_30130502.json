		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はいっ、オチンポ……奥に欲しいんですっ、お願いします……んぁっ……あ\nっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そこっ、そこに欲しかったんですっ……！　オチンポがっ、襞に擦れてっ…\n…はぁっ、ジンジン痺れてっ……気持ちいいですっ！」", "NORMAL" ]},
