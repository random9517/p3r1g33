		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ……もう一回お願いします……あっ、ひっ！　いいですっ……\nあぁっ、オチンポ……深いですっ……！」", "NORMAL" ]},
