		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はいっ、いっぱいお尻……振りますっ！　貴方のオチンポも感じてもらえる\nようにっ、はしたなくっ、お尻フリフリしますからっ……！」", "NORMAL" ]},
