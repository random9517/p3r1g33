		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「い、いえ、やっぱり正面からとか……そうではなくて、あの……この感じ…\n…もっと続けたいと言いますか……」", "NORMAL" ]},
