		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んくっ、あぁ……はっ、んっ、あ……お尻……ぱつんって……あぁっ、当た\nって……ます……んくぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「は、ふっ……はい、気持ち……いいです……ずっと待っていましたから……\n硬いのが……欲しい所に……ずっと当たってます……んんっ！」", "NORMAL" ]},
