		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁぉぉんっ！　どう、ですかっ……！？　オマンコっ……締め付け……で\nきてますかっ？　ちゃんとオチンポ気持ちいいですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あひぃっ！　ありがとうございますっ……！　あぁっ、オチンポピストンい\nいですっ！　私もっ、いっぱい感じますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁっ、スケベなオマンコがっ……オチンポぱっくり食べてっ、涎マン汁っ\n……いっぱい垂らしてっ……繋がってるとこっ、ヌルヌルにさせてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ダメっ……勝手にヒクヒク動いちゃいますっ！　このままされたらっ、また\nすぐオマンコイッちゃいますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「いいんですかっ？　はいっ、イキたいですっ、あぁっ、でも、また一緒にっ\n……貴方と一緒にイキたいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504217" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「気持ちいいとこ、ズリズリ……擦られてぇっ……！　はぁぁんっ！　あぁっ\n、はいっ、最後っ……腰を振ってっ、一気に搾り取りますからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁっ、鼻息が掛かって……興奮してるのっ、分かりますっ……！　もう、\n私は……いつでもいいですからっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「出してっ、また熱い精液出して下さいっ！　ドピュドピュ濃いのを出してっ\n……私もイキますっ！　はぁんっ、オマンコっ……イキますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁっ……！　また……後ろからっ……種付け……熱いの、ドピ\nュって……溢れ……ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504301" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁぁ……この熱いのが……堪らなくて……ダメ、立ってられなくなってし\nまいます……んんっ、あ……すみません……支えて頂いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あっ……！　嘘……射精されたまま……まだピストン続けて……！　あぁっ\n、ドロドロ精液……流し込まれながらオマンコされてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はふぁ……こんな、クラクラします……はぁぁ、貴方のオチンポの形に躾け\nられてぇ……オマンコ……完全に支配されてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、はぁっ、はぁっ……あぁ、止まり……ましたか？　まだ、奥\nでオチンポを突かれているような気がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい……いっぱいオマンコを躾けて下さってありがとうございました……そ\nの、お陰で……ムラムラも少しは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「えっと……じ、実は、まだ……完全には解消された感じではなくて……あっ\n、いえっ、こんなにいっぱいして頂いて満足なんですが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「え……同じ……？　あの、それはつまり……どういう意味の……貴方も……\nまだ、解消しきれていないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504308" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい……それじゃ……とりあえず、一休みだけしておきましょう……一気に\nしたら、倒れちゃいますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504309" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「それで、もしよかったら……今度は正面からも……お、お願いして……いい\nですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁんっ！　あっ……お尻にっ……！　びゅくびゅくっ……出てっ……\nますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504401" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……オチンポ抜けて……あぁう……掛けられてる……身体に……精\n液染み込ませられてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁっ、お尻の谷間にズリズリって……オチンポが……！　あぁっ、オチン\nポで直接お尻になすりつけられるなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……支配されてます……私……身体、押さえつけられて……貴方の\nオチンポに完全敗北させられましたぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はふ、はぁ……はぁ……終わり、ましたか……？　やっと、射精が落ち着い\nて……止まりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……まだ心臓がドキドキしています……私、やっぱり少\nし乱暴にされるのが好きなんでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「その、自分でも……エッチな自覚がないわけではないというか……でも、だ\nんだん、そういうのを開発されてしまってる気がして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「貴方と合体した状態だと余計に意識してムラムラしやすいと言いますか……\nあぁ、な、何言ってるんでしょう私……忘れて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「えっ……？　いくらでも相手を……エッチな方がいいから……あ……は、は\nい……ありがとうございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504409" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですね……少し気持ちが楽になりました。また、ムラっとしたら……い\nっぱい可愛がって下さいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504410" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_16" ]},
		{"command":[ "WAITINPUT" ]},
