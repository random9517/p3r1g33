		{"command":[ "SETIMAGE", "0", "still_00001305_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もっとしてもらえるって思うと……ゾクゾクして……んっ、私……本当にス\nケベなマゾなのかも知れないです……んっ、あぁっ……」", "NORMAL" ]},
