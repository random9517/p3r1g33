		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「でもっ、いやらしい音っ、もっとさせて下さいっ……パンパンしてっ、んは\nぁんっ、ドキドキしますっ……オマンコもっと欲しいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、はぁっ、あぁ……はいっ、私も……お腹に力を込めて……ん\nんっ、オチンポ……強く締め付け、ますねっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504116" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んく……んくぅっ……どう、ですかっ……オチンポっ、あっ、ます\nますサカって……下さいますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁぁぁんっ！　あぁっ……いいですっ、気持ちいいっ！　後ろからのオチ\nンポピストンっ！　トロトロにされちゃいますぅっ！」", "NORMAL" ]},
