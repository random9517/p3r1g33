		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はい……このまま、後ろからの立ちバックで……オ、オマンコ……ハメたお\nして下さい……お願いします……あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁっ……！　あぁっ……奥へっ……ゆっくり、ずぶって……入って\n、来ます……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504107" ]},
