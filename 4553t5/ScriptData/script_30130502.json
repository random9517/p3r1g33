		{"command":[ "SETIMAGE", "0", "still_00001305_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……出ました……んふっ……逞しいオチンポ……素敵で\nした……は、ふぁ……」", "NORMAL" ]},
