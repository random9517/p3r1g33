		{"command":[ "SETIMAGE", "0", "still_00001305_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁ……自分からお尻を振るなんてはしたないこと……で、でも……貴方が\n気持ちよくなってくれるなら……」", "NORMAL" ]},
