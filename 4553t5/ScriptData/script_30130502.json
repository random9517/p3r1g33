		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ、ふぅ……あ、あの……こんな時ですけど、ちょっとわがままを\n聞いてもらってもいいですか？」", "NORMAL" ]},
