		{"command":[ "PLAYVOICE", "v2_013_0504132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あひんっ！　あっ、そんなお尻っ……叩くなんてっ……！　し、締め付けが\nよくなるなんてっ、そんな、ことぉっ……！」", "NORMAL" ]},
