		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あふっ、あっ、あぁっ……！　んっ、んぁっ、あぁっ、これ……難しいです\n……上手く、動かして……あげたいのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ、あのっ……やっぱりお願いします……立ちバックだと……貴方が動いて\nくれないと……ちゃんとご奉仕……しきれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もっと激しく……後ろから貴方のオチンポで、ズコズコ……突いて下さいっ\n……！　そうしたらっ、私も……一緒に動きますからっ……」", "NORMAL" ]},
