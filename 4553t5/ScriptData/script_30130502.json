		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「今の格好で繋がったままで……もっとじっくり……色々なところを責めて…\n…欲しいんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あ……あぁっ！　んっ、だって……あっ、自分の自由があまり効かないのに\n……身体がどんどん感じてしまって……今も、膝が震えてるのに……」", "NORMAL" ]},
