		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もっとズコズコして下さいっ！　あひぃっ、オマンコ熱いですっ……あぁっ\n、どんどんお汁……溢れて来ちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
