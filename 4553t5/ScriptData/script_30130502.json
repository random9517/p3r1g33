		{"command":[ "SETIMAGE", "0", "still_00001305_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチンポまだっ、激しくぅっ……！　出すんですかっ？　あっ、こ\n、このままっ、は、はいっ！　中にっ……下さいっ……！」", "NORMAL" ]},
