		{"command":[ "SETIMAGE", "0", "still_00001305_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「もっと……あぁっ、そこもっ……！　入り口のところもっ、はいっ、あっ、\nあぁっ……どんどん開発されてしまいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁっ……あっ、ふっ、ど、どうしたんですか……？　急に止め\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「今度は……私がお尻を振って……オチンポにご奉仕を……？　は、はい……\n上手く出来るか分かりませんが、やってみます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
