		{"command":[ "SETIMAGE", "0", "still_00001305_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「本当は……向かい合わせの状態で……したかったんですけど……んっ、ふっ\n、あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「でも、こうして……後ろから少し乱暴にハメ倒されるのも……あっ、うんっ\n！　好き……かも知れませんっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「はぁんっ、そう……こんな、ケダモノみたいにっ……あっ、後ろからっ……\nサカって……オマンコっ、されてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
		{"command":[ "SETTEXT", "「うんっ、はぁっ、オチンポっ……届くぅっ……！　くぅんっ、大きいですっ\n……あぁっ、こんな格好……恥ずかしいのに……んくぁっ……！」", "NORMAL" ]},
