		{"command":[ "PLAYVOICE", "v2_013_0504206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001305_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルバスター・ブルー" ]},
