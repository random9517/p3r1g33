		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……また、私に見せて下さいませ……ご主人様のご立派なオチンポから \n、ドピュっと濃い精液が溢れ出すところを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もう……私のおっぱいはすっかりその気になって……ぷるぷるとはしたなく \n卑猥なダンスを踊っております……あぁ……もう待ちきれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「後、もう少しですね……？　心得ております……んんっ、もっと深くめり込 \nませてっ……ずりずりっ……擦りつけてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……ビクビクしてっ……後もう少しっ……！　はいっ、下さ \nいませっ……！　熱い……精液っ、お恵み下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「パイズリっ……熱いですわっ……あぁっ、私も……またおっぱいで絶頂しま \nすっ、ご主人様と一緒にっ、上り詰めますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んはっ……！　あぁっ……また出ていますわ……おっぱいマンコに……どぷ \nどぷ……新しい精液が溢れております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ふふ……気持ちよさそうなお顔です……どうぞ、このままご遠慮なく最後ま \nで出し切って下さいませ……あぁ……すごい勢い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んっ、おっぱいの中でオチンポが何度も震えて……まるでいっぱい種付けを \nして下さっているかのようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……ご主人様の精液を浴びられて……おっぱいが悦んでおります……あ \nふ……気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んっ、弱まって参りましたね……まだ、もう少し奥に残っている分……お扱 \nきして、出してしまいますね……んっ、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あふっ……！　ふふ……最後に、まだ濃いのが出てきました。疲れの元が一 \n緒に吹き飛んでくれればいいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「くすっ、余計にお疲れにさせてしまったかも知れませんね？　どうか、この \nまま楽になさっていて下さい。後始末……させていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「れろ……んちゅっ……途中でのおしゃぶりは禁止でしたから……ちょっと味 \n見させていただくだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、これでよろしいですわ。はしたないおっぱいでのパイズリ……少しで \nも楽しんで頂けたなら私も嬉しく思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もちろん……これからも、いつでもお呼び下さい。ご主人様のオチンポの為 \nなら、私はいつでもこのおっぱいを差し出して、ご奉仕させて頂きます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んぅんっ！　あぁ……顔に……ご主人様の精液が、びゅくって……掛かって \nいます……んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁん……あったかいです……あぁ……どんどん溢れて……もっと掛けて下 \nさい……濃厚ザーメン浴びせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁ……私もおっぱいが気持ちよくて……また母乳が射精している \nみたいに……びゅくって溢れてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……あぁ……んふ……今日はおしゃぶりは禁止ですけど……口の周 \nりの精液を舐め取るのはお許しください……れろ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、この精液の味が大好きなんです……れろ、ちゅぱ……ちゅぷ……ぴち \nゃ……んちゅぷぅ……美味しいですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んふっ……！　最後にドピュって……残ってた分が出てきました……れろ、 \nちゅぷっ……あぁ……ご馳走様でございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「これで出し切りましたか。はい、大変お疲れ様でございました。まだ、しば \nらくそのままじっとしていて下さい。綺麗に致しますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んちゅ……ぴちゃ……ほんの少しだけ、お清め致します……また後で、お背 \n中をお流しする時にも致しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ひとまずは、これでよろしいでしょう。ふふ……楽しんで頂けたなら私も冥 \n利に尽きる思いですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、またいつでもご奉仕させて頂きます。ご主人様のオチンポを癒やすの \nは、私の至上の役目ですから……ふふっ」", "NORMAL" ]},
