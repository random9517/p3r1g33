		{"command":[ "SETIMAGE", "0", "still_00028201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「皮の剥けかけたところを……ずりゅずりゅ押し付けて……んふっ、どんどん \n震えが大きくなっています……」", "NORMAL" ]},
