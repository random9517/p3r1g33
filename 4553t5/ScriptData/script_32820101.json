		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「今日も一日お疲れ様でした。僭越ではございますが……どうか、私のおっぱ \nい……パイズリでお楽しみ下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んっふ……あぁ、すごい……もうこんなに逞しく勃起して……谷間の中でオ \nチンポ様が更に膨らんでいきますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「こんなに熱を持って……お疲れだったでしょう？　私のおっぱいで、精一杯 \nのご奉仕をさせて頂きますから……楽になさって下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「さて……まずは、ちょっと滑りをよくしなければなりませんね……乳首をオ \nチンポの先に失礼いたします……ふっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んんっ……！　はい……私も……ご奉仕をお命じ頂いて……もう、ずっと期 \n待しておりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「このコリコリにしこった乳首は……その現れですわ……後は、もう少し擦っ \nてさしあげれば……んんっ……ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁん……母乳が滲み出して参りました……はい、こちらをオチンポに塗り \nまして……よく滑るようにしていこうかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、ローションの代わりです……私のエッチなミルクでオチンポをしっか \nりとコーティングさせて……それから……あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「十分に滑る感じが出てきましたら……本格的にオチンポをシコシコさせてい \nただきます……はっ、んふっ、あんっ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……ぶっといオチンポの感触……素敵ですわ……こうして触れていると \n、ドキドキしてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もっとしっかりと密着させて……あぁ……おっぱいの中で暴れている感じが \n致します……はぁん……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「それだけ、私のおっぱいを求めて下さっているのですね……大変光栄ですわ \n……また、興奮で新しい母乳が滲んでしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「まだまだ拙い動きがあるかも知れませんが……どうか、おっぱいを存分に感 \nじて下さいませ……んふっ、上下に揺らして参りますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁんっ……あぁ、根元の方から……亀頭までぇ……ゆっくり、ずりゅずり \nゅ扱いています……滑る感触が……気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……このビンビンに浮き上がった血管が……お肌にしっかりと絡んで… \n…ここを、何度も……動かしたら……はふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい……私のおっぱい、オチンポをお扱きするだけで、どんどん気持ちよく \nなっております……はしたないおっぱいで申し訳ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ご主人様は……いかがでしょうか？　私のパイズリで、至らぬところはござ \nいませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「よかった……ちゃんと気持ちよくできているのでしたら何よりです。まだ、 \nここからが本番ですから……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「しっかりと、お肉を食い込ませて……オチンポの脈動を感じさせていただき \nますね……はぁっ、んくっ、あっ、ふっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……とっても硬い……けれど、柔軟なところも同時に備わっていて…… \nこのへばりつく感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……動かせば動かすほどに……あぁ、オチンポと一つになってい \nくような感覚が……心地いいです……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「今日は……おしゃぶりはなしで……？　かしこまりました……この先端のに \nおいだけで我慢致しますわ……んっ、すぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……ゾクッとします……んふぅ……私のいやらしい気持ちが膨れ上がっ \nて……おっぱいがどんどん感じやすくなっております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「うんっ、んふっ、んくんっ……あぁ……はしたなく勃起した乳首を見られて \nいます……私のスケベな勃起……ご覧になって下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　んっ、ふっ……コリコリを押し潰すようにしたら……あっ、感 \nじすぎて……またミルクが……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい……はしたないローションミルク……もっとまぶしていきますから…… \nたっぷり感じて下さい……んんっ、くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……いかがですか……？　して欲しい場所がございましたら、 \nどうぞ遠慮なくお申し付け下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「完全に……お任せいただけるのですね？　はい、もちろんそれも嬉しく思い \nます……ご信頼にお応えしなくてはなりませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「それでは……縦の動きから……今度は前後に……んっ、ふっ、おっぱいを… \n…揺らしまして……あっ、んむぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「うんっ、んっ、ふっ……んくぅ……擦れ方が変わると……それだけでも、あ \nっ、おっぱいへの刺激が新鮮になりますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……乳首が一層感じやすくなってますの……これを続けているだけで… \n…んんっ、どうにも疼きが止まらなくなって……あぁ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あふっ、んんっ……オチンポも、敏感になっているみたいで \nすわ……先走りがじわりと滲んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「このまま続けたら……おっぱいの中に出そうですね……？　はい、もちろん \nご遠慮なく中出しなさって下さいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「私のおっぱいマンコはその為にあるのですから……ご主人様の精液を……浴 \nびたくてウズウズしているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「このまま、あっ、激しく擦りますからっ……オチンポっ、ドピュッと濃厚ザ \nーメンをお出し下さいませぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んふぁっ……！　あぁ……ありがとうございますっ……ご主人様の濃いザー \nメンが……おっぱいマンコを満たしておりますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はぁん……熱い……ねとねとした白濁がおっぱいを浸しております……はふ \nぅん……この精液のにおい……堪りません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んんっ、あふっ……はぁ……どうか、こちらの方にも……んっ、母乳と精液 \nが入り混じって……粘っこい汁がおっぱいから垂れてしまいますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あぁ……んふっ……いっぱい出して下さいましたね……オチンポ、気持ちよ \nかったですか？　はい……私もおっぱいでイッてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んふ……まだビクンビクンって脈打っています……逞しいオチンポ……素敵 \nですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はふ……多少はお疲れも取れたでしょうか？　あぁ、でも……まだオチンポ \nは芯がしっかり残っていらっしゃいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「これは疲れマラというものでしょうか。でしたら、もっと優しく搾り取って \n差し上げないといけませんね……お続けしてよろしいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、かしこまりました。どうぞ、身体の力を抜いて……先ほど以上に、じ \nっくりとご奉仕致しますから……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はふ……んっ、あぁ……ザーメンのぬるぬるが増えて……ゆっくり動かして \nも、擦れる感触が気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「お肌が……ずりゅっと滑る感触……より感じるようになって……あんっ、ま \nた母乳が……滲んでしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はっ、ぁっ……んんっ、あぁ……お汁まみれのオチンポがてらてら光って… \n…とってもいやらしいですわ……は、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「また乳首でキスしてしまっても……？　んんっ、くぅぅ……あんっ、敏感な \n場所同士が擦れ合うの……ゾクゾクします……あっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅ……おっぱいを寄せて……今度は下の方に……はい、キンタマ \nの方もご奉仕いたします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ずっと精液を作り続けて……ここも、しっかりと癒やしてさしあげませんと \n……ふふ、むにゅっとした感触が可愛らしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「くすっ、今……ビクってされましたね……やはり、男の方の弱点は落ち着き \nませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00028201_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「大丈夫です……痛くすることはありませんから……むにゅっと……優しく包 \nみ込んで……モミモミいたしますね……ん、ぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「シワの部分が……ヒュンと縮こまるようにして……こんなことを思うのは失 \n礼かもしれませんが……とても可愛らしくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「もっともっとおっぱいで、癒やして差し上げたいと思ってしまいますわ…… \nキンタマのマッサージ……気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「はい、もちろんオチンポ自身も忘れてはおりませんわ。こちらも、震えがま \nた大きくなって参りましたものね……」", "NORMAL" ]},
