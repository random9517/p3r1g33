{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そ、そなた……いったい、なにをするのであるか！？　　やめるのであるっ\n！　離すのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くううぅ……！　王に対してこのような辱めをするとは……今すぐ冥府に送\nってやるのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　あっ、ひあああぁ……！？　お、お尻の穴が拡げられている\nのであるぅ！　これでは、奥まで見えてしまうのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「なにをジロジロ見ているのであるっ！　排泄器官をジロジロ眺めるなど、変\n態以外の何者でもないのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……！？　やっ、ああぁ……！　か、顔を近づけるんじゃないの\nであるっ……！　やめっ……やめるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んきゃあああぁ！？　お尻のニオイを嗅ぐんじゃないのであるぅ！　離れる\nのであるっ！　息を止めるのであるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我は機械の身体であるが、そこは人間と同じなのであるっ！　汚いのである\nぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「いい香りがするとか、そんな見え透いたウソをつくんじゃないのである！　\n絶対クサイのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　そ、そなた……何故そんなにもオチンポを大きくしているの\nであるか……！？　まさか、我のアナルに興奮したとでも……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「どうしてオチンポを近づけるのであるか……！？　まさか、我のアナルに挿\nれるつもりじゃ……！？　や、やめっ……！　やめるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んはあああぁ！？　あっ、ああぁ……！　奥まで入ってくるのであるぅ……\n！　ぶっといオチンポが、お尻の肉を掻き分けて……んひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「苦しいのであるっ……！　アナルがオチンポのカタチに広がって、ギチギチ\n音を立てているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ぐっ、あぐっ……！　抜くのであるっ……！　こんな不浄の穴にオチンポを\n挿れるなど、あってはならないのであるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「抜きたくても肛門が締まって抜けない……？　そ、そんなことないのである\nっ！　我はアナルを締め付けたりしてないのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「抜けないから、もっと奥まで挿れてほぐすだと……！？　待つのであるっ…\n…！　これ以上奥に挿れられたら、お尻が壊れて……おほおぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おっ……おおおおぉ……！？　直腸までオチンポが届いているのであるぅ…\n…！？　苦しいのであるっ……！　ぐっ、うぐぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……あぐっ……！　ひっ、あっ……！？　が、我慢できないから\n動くって……！？　ひいいぃ……！？　いっ、いやああああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んひっ、おっ、おおおおぉ！？　アナルがズリズリ擦れている\nのであるぅ！　お尻の穴、感じるのであるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポが出たり入ったりするたびに、気持ちいいのが伝わってくるのであ\nるっ！　ずっと排泄行為をしているみたいであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　あっ、うぐっ、あっ、あひいいぃ！？　こんなのおかしいので\nある！　動くのを止めるのであるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひいいいぃ！？　どうしてもっと激しくズポズポするのであるかっ！？　\n我は止めろと命じたのであるぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「アナルが気持ちよすぎて止まらない……！？　くっ、うううぅ……！　これ\nだから人間は愚かなのだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「不浄の穴でのセックスがどれだけ汚らしいものか、理解していないのである\n……！　やはり人間は、我に管理されるべき存在である……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「汚いと言ってる割りに、お尻からエッチなお汁が垂れているって……ち、違\nうのであるっ！　それはエッチなお汁ではないのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これは……そう！　汗であるっ！　そなたが我のお尻の穴をズポズポしまく\nるから、擦れて汗ばんでいるだけであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「決してお尻から出てきた汁では……！　あひいいぃ！？　ピストンの速度が\n、どんどん上がっていくのであるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「アナルから漏れ出る腸液のおかげで滑りがよくなっただと……！？　だから\nこれは腸液などではなく、汗だと言って……あはああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うぐっ、がっ、おっ、おほおぉ！？　さっきよりも擦れる感覚が強くなって\nいるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「肛門の肉がカリに引っかかって、伸ばされているのであるぅ……！　ひぐっ\n、あっ、あああぁ！　アナルが焼けるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そんなにアナルをホジられたら、イッてしまうのであるっ！　イキたくない\nのに、イクのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひっ、あああぁ！　オチンポもアナルの奥でビクビク震えているのである\nっ！　まさか、お尻に出す気じゃないであろうな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「アナルに出すのはダメであるっ！　こんな状態でザーメンを受けたら、本当\nにイッてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　オチンポがどんどん膨らんで……！　ひぐっ、あふっ、んぎい\nいぃ……！　あ、アナルが拡がるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「オチンポのビクビクがさらに激しくなっているのである……！　だ、出すな\nっ！　アナルに出すんじゃないのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うああああぁ！　ダメっ！　ダメであるぅ！　アナルに出すのだけは、許し\nて欲しいのであるうううううぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひっぎいいいいいぃぃぃぃぃ！？　おっ、おおおおぉぉぉ……！？　お尻の\n中にドロドロのザーメンが出ているのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んひっ、うぐうぅ！　こんなに熱いのを注がれたら、腸の奥\nが焼けるのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「がっ……！　あっ……おおぉ……！　イッ、イクッ……！　お尻に出されな\nがら、イクッ……！　んんんんんっ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んっ、あひいぃ！？　イッてる最中なのに、まだザーメンが出てい\nるのであるぅ！　もう許して欲しいのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　射精される感覚でまたイクッ！　お尻にザーメンぶっかけられ\nながら、イクのであるうううぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……あっ……はぁ、ぐぅ……んんっ……！　お、終わったであるか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ならばさっさと我のアナルからオチンポを抜くのである……！　んっ、くっ\n……いつまでも止まってないで、早く動くのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「１回出したくらいじゃ物足りない……？　もっと我のアナルを堪能したい…\n…？　な、ななっ……なにを言っているのであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　あっ……！？　腰が引かれて、アナルが引っ張られるぅ……\n！　まさか……そのまま突き入れる気ではないであろうな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そ、そのままオチンポを抜くなら、我のアナルを犯した狼藉を許してやるの\nである……！　だから、オチンポを抜いてっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふっぎいいいいいぃぃぃ！？　がっ、あっ……あっ……！？　また、奥まで\nオチンポが入っているのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「今度は……子宮の裏側にまで届くくらい深いのであるぅ……！　アナル越し\nに、子宮を突かれて……うぐうううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もう許して欲しいのであるっ……！　これ以上アナルを責められると、本当\nに頭がおかしくなるのであるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「だから……オチンポ、抜いてっ……！　ひぎっ！？　がっ、あああああぁ！\n　おっ、おっほおおおおおぉぉぉぉんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「いあああああぁ！　ズポズポするのダメであるうううぅ！　肛門がめくれあ\nがるのであるぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　気持ちいいの、止まらないんであるぅ！　アナルを擦られる快\n感と、子宮の裏側を突かれる快感が、同時に来るのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひっ！　あぐっ、んふうううぅ！　オチンポでズリズリされるたびに、肛\n門が勝手に締まるのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「そなたのオチンポのカタチに合わせて、ぎゅーっと締め付けて……！　ああ\nあぁ！　アナルがオチンポのカタチを憶えてしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もう気持ちいいのしか感じないのであるっ！　そなたのオチンポに屈してし\nまいそうであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「このままでは、堕ちるところまで堕ちてしまうのである！　王ではなく、そ\nなたのスレーブになってしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あひっ、んっ、あっ！　だ、ダメだと思っているのに、もっとオチンポで激\nしくズポズポして欲しいと感じてしまうのであるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あああぁ！　スレーブ堕ちしてしまうのであるぅ！　オチンポの虜になって\n、そなたに尽くしたくなってしまうのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、うぐっ、んんっ！　イッ、イクのであるっ！　イッたら堕ちるのとわ\nかっているのに、イクのとめられないのであるうううぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んひっ！？　あぐっ、あっ、んふうううぅ！　そ、そなたもイクのか！？　\nまた我にザーメンを受け止めろというのであるかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　オチンポが震えているのである！　出さないで欲しいのであ\nるっ！　や、やめっ……！　やめるのであるうううぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「おおおおおおぉ……！？　またお尻の奥にびゅーびゅー出されているのであ\nるぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「しかも今度はお尻の中から、子宮の裏側にオチンポを押し当て出すなんて…\n…！　うぐっ、んくううううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あっ！　あはあああああぁ！　アナルに出されているのに、子\n宮にザーメンを出されている感じがするのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんなの気持ちよすぎて、逆らえなくなるのであるっ！　そなたが我の主だ\nと、認めたくなるのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「イクッ！　イクのであるっ！　お尻とオマンコで感じさせられながら、イク\nのであるうううううぅぅぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……！　あっ、あふっ……たっぷり肛内出しされたのである\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「アナルを責められ……お尻の奥までザーメンで染め上げられてしまったので\nあるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これでは王の威厳を保っていられないのである……我はそなたのモノになっ\nてしまったのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これからは主として……我をいっぱい可愛がって欲しいのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「えっ……もう１回アナルセックスがしたい……？　ホホホ……遠慮などせず\nに、我のお尻を好きなだけ使って欲しいのであるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んっひいいいいいぃ！？　おっ、お尻から急にオチンポが抜けていくのであ\nるうううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「んああああぁ！　肛門がひり出される快感と、ザーメンをぶっかけられる快\n感が一緒に来るのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こんなものを味わわされたら、たまらないのであるっ！　気持ちよすぎて、\nまたイクのであるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「あっあっ！　イクッ！　ザーメンの熱さとドロドロした感覚を味わいながら\n、イッてしまうのであるううううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うあああっ、あっ、あああああぁ！　イクッ！　イクであるううっ！！　ん\nああああっ、イクうううううぅぅぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、んふっ……あっ、あはあぁ……オチンポが抜けたというのに\n、まだ入っている感じがするのであるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002004_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「我のアナルがこんなに開いて……もう元のカタチに戻らないのである……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「これはもう、そなたのモノになるしかないのである……！　こんな身体にし\nた責任、取って欲しいのである……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「責任を取るから、今度はオマンコの方でもシたいだと……？　あれだけ出し\nたというのに、まだシたいのであるか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「もうこれ以上はダメであるっ！　本当におかしくなって……んひっ！？　だ\n、だからダメだと言っているのであるううううぅぅぅ……！！」", "NORMAL" ]},
