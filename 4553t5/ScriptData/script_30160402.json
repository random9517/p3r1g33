		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「むっ……そこにいるのは何奴だ！？　と……驚かすな。貴様か。突然飛び出\nしてくるから驚いたじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああ。私は今、ちょうど試合が終わったところだ。乱杰李威仏斗暴屡は面白\nいが……、うん。興奮しすぎて、後に響くな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そういえば、前にもこうして昂ってしまったことがあったな。……聞きたい\nか？　あれは、私が大活躍した試合の直後だった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……嬉しいぞ。ちょうどいいところに来てくれた……！　今日の私は、身体\nが熱くて熱くて抑えきれない。過度な運動をこなしたからかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「こんなところで押し倒して、何をするつもりか……？　ハッ、決まっている\nだろう？　スポーツの後のお片付け、というやつだ……。フフフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001604_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そうだ。私は発情している……♪　血流が良くなりすぎて、疼きと火照りが\nおさまらないんだ。もちろん、発散を手伝ってくれるんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404106" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……見てくれ……。濡れた膣口から、じゅわじゅわと新しい蜜が湧き出てく\nる……♪　フフ……充血して、入り口がぽってり赤く腫れているだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これは、オスのチンポをメスのオマンコが欲している何よりの証だ。潤んだ\n入り口が、早くチンポを奥の奥まで突き入れてくれとねだっているんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　はぁ、はぁ……あぁ……♪　貴様のオチンポを見ているだけで、\n身体の内側が燃えるようだ……ほしい、欲しい、欲しい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「逞しい、その肉の棒でめちゃくちゃに突きまくられたい……♪　何度も何度\nもタッチダウンされたい……♪　だが……すぐには入れたりしないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「極限まで、性感を高めて……一気にいただく。……ふぅううっ♪　貴様もそ\nの方がうんと気持ち良くなれるはずだ。私の下半身によく集中しろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「締まりのいい、キツい膣内で貴様の肉茎をぐちょぐちょと搾り抜いてやる…\n…♪　力強く、根元からカリ首まで、亀頭も丸ごとのみこんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……っはぁああっ……♪　ズッポズッポ腰を振りながら……。あっ♪　万力\nのような力でチンポを膣壁でシゴいてやるぞ♪　楽しみだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ほ、ら……♪　ンンッ♪　スクワットするみたいに、オマンコをチンポの先\n端になすりつけて……。ヌルヌルヌル……ニュルニュルニュル……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ♪　か、硬い……デカい……♪　最高のチンポの先っちょが、私の愛液\nで濡れて……興奮する♪　はぁっ、貴様にもわかる、だろう、んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「今日の私のオマンコは熱々で気持ちいいぞ……？　ほら……。中までたーっ\nぷりと蜜で潤んでいるんだ。早く種付けされたくて焦っている♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ここにズブズブぅっとチンポを埋めたら……。何枚もの膣ヒダにうねうねと\n大歓迎されて、二度と離してもらえないだろうな……。ンッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「精根尽き果てて、精液が枯れ……貴様が死ぬまでセックスさせられる、セッ\nクス奴隷になってしまうかもしれないぞ……それでもいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それでも……ココに入れたいか？　クク……♪　あっ、おい。そちらから入\nれるのはナシだ。我慢の限界になったら情けなくねだるといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「どうか修羅姫様の最高のオマンコを堪能させてください、俺のオチンポを好\nきにしてください、使ってくださいと涙ながらに懇願してみろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ♪　でなければずぅ～～～っとこのまま、マンコはおあずけだぞ\n？　ヌルヌル入り口をこすりつけて……あっ♪　濡らし、たまま♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「永遠に待てのまま、前戯を続けてやる……。んっ……ふぅっ、ふぅっ……ふ\nぅ……♪　ああああ……♪　ん？　なんだ？　聞こえないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「もっと大きな声で言え。修羅姫様のオマンコに入れたいです、と……。ああ\n、そうだ。もっと！　もっと、もっとだ！　……ああああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「わかった……♪　そこまでねだるのならば入れてやろう。今日の私は機嫌が\nいいんだ……。ほら。入る瞬間をよーく見ておけ……。いくぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ンッ♪　んんんんんんんん～～～～♪　んぁああああ♪　深い……！　あっ\n♪　チンポ、ぶっといチンポが……あっ♪　奥っ、奥っまっでっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「奥の奥まできたぁああ……っ♪　んあっ♪　ああっ、ああああっ……！　こ\nれ、コレだ……！　スポーツの後にはコレしかありえない……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ああっ！　ああっ、あぁあああ……！　ハハハッ♪　随分がっついてくるじ\nゃあないか……！　相当待ちきれなかったらしい、なっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そんなに私のオマンコにっ♪　チンポ入れたくて我慢ができなかったか♪　\nうっ♪　う……っ♪　わかるぞ、わかる……あっあっあっああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「か、たい……硬すぎる……っ！　絶対に私を孕ませるという、強い意志をチ\nンポが発している……！　あぅっ、ぐ、う……これっ、これ、だ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これが欲しかったんだ……！　あっ、あっ！　わ、私とてやられっぱなしと\nいうわけにはいかん……！　こちらからも攻めていくぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ♪　……あっあっあっあっ♪　どう、だ♪　修羅姫様の高速ピストンは\nぁ……っ♪　そんじょそこらの女では出来ない芸当だ、ろうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404131" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「呼吸も忘れるくらいに腰を振りたくって……！　あっ♪　あっあっあっおぉ\nっ♪　貴様のチンポを追い詰める、精液を搾り取るこの動きっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これは、鍛えた乱杰李威仏斗暴羅亜にしか出来ないセックスの動きだ……！\n　ああっ、おぼっ、覚えておけっ……ああっ、き、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あふぁあああっ♪　ああっ♪　あぁっ、ああ……！　駄目だ、腰が止められ\nない！　こんなの、後で筋肉痛になるとわかっているのに……くぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それでもしたい、やめられないぃ……！　ああっ！　ああっ、ああ……！　\n貴様もいいか？　いいんだろう？　あっ……出せっ、出せっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私の一番奥に……精液を出せっ！　あぁ……！　選択権はないっ、生で中出\nしだ、避妊無しの生中出ししかありえん……！　ほら出せ、出すんだっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ンッ♪　んふぅうううううううう～～～♪　あああああああ～～♪　いいぞ\nっ、良い子だ……ああっ、ちゃ、ちゃんと出せたな……合格だぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「特濃の、ドロッドロ精液……。汁気たっぷりの真っ白な精液が私の中に満ち\nていく……！　んぁあああ……熱い、熱い……気持ちがいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「イ……くっ、イクぅ……！　あはははっ、貴様の情けない懇願種付けでイク\nぅ……！　あっ！　まだ出せ、出せるだけ出せぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっんんんんん……！　この瞬間がたまらないんだ……！　ああ……！　子\n宮が精液でいっぱいになる、拡張されるこの瞬間んんん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ンッ♪　んんんん♪　……はぁ～～～～～♪　はぁあああ……♪　はぁ～～\n～～♪　あぁ……。簡単に絶頂してしまった……おかしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404201" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「自分で激しく腰を振って、貴様の精子を胎内に発射されて……。すぐにイっ\nてしまった……。感度がおかしくなっているみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……何？　イケたからこれで終わりなのか？　まさか……。これくらいでは\n終わらせんよ。貴様も、継続を望んでいるのはもうわかっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「射精してなお、勃起がおさまらないチンポがその証拠だろう……。いや、嫌\nだと言われても抜いてなどやらない。私がもっとしたいからだ。ほらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「根性で最大まで勃起させろ！　……ンッ♪　精液のぬめりで滑るオマンコで\n、私もたくさん感じさせてやる……。ほ、ら……ほらっ、ほらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁ……！　ああ……！　ハハハハッ♪　大きくなってきた……。\nあっ♪　マンコの中で硬さが戻って……。んっ、太く、なって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あぁっ……ああ、ああっ、あぁ……！　そうだ……。今度は挿入のお願いだ\nけじゃなく、貴様に射精のおねだりもしてもらうとしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私が腰を動かしている間に……。んっ、イキたくなったら手を上げてねだれ\n！　両手を……ああっ、あげ、て……子供のように媚びてみろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「イカせてください修羅姫様、と……。あっ♪　あっ、あっ♪　修羅姫様の極\n上オマンコの中にもっと射精がしたいです、と言え……！　いいなっ」", "NORMAL" ]},
