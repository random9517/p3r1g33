		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、はぁ、あっ、あっ……♪　そら……また腰を動かすぞ。\nどんどんスピードをあげて……。あっ♪　くぅっ、こ、これは……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「い、イイところに当たる……こすれる……♪　んうっ♪　ンン……ん～～～\n～♪　ここっ、ここ、ここがこすれると……気持ち、いい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そう♪　そこだ……。あっ、そこぉ♪　奥っ……奥のあたりっ……！　あふ\nっ♪　そこをこすりあげられると……電流が走ったように、んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「快感でおかしくなる♪　ああ……ああっ！　セックススクワット♪　やめら\nれない……あっ！　き、貴様も早くねだれ……もっと乱れろ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んぁっ……ああ♪　はぁ♪　はぁっ、はあぁあっ……ああ♪　出したいだろ\nう！？　もう一度……私に孕ませチャンスを与えたいはず、だ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ドピュドピュ、ビュクビュクと……ああああっ♪　精液を、種を、一番奥に\n撒き散らかして……スッキリさっぱりしたいだろうっ、なあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……っくぅうう……！　くふぅううっ、うう……んぅううう……♪　うぅ…\n…♪　そうだ、何度も言え、私のオマンコが最高だと、……あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「修羅姫様に種付けしたいと、そのまま言い続けろ……ねだれっ、ねだれ……\n！　あっ♪　そうだ、そうっ……あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「良い子にしていれば、……ああっ、私はいくらでも射精させてやるぞ♪　特\n別だ……！　あっ♪　貴様は特別だ、特別に膣内射精してもいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あ、……くぅううっ♪　出したいのか♪　また射精するんだな♪　いいぞ…\n…全力で種付けするがいい！　来いっ……来い来い来いぃいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あうぁあああああああ♪　あふぁあああああ……♪♪　のぼってきたぁ♪　\n貴様の精液……ああっ、私の中をのぼってくるぅううう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404301" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「あっ♪　アッ♪　あっ、あぁあああ♪　ま、マンコがキツい？　我慢しろっ\n……！　こっちも今イッているんだ、調節なんかできないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404302" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「イクと勝手に締まってしまう、んだ……！　あぁ……っ♪　イクイクイクっ\n……！　イ、ク……種付けされてイク♪　イクぅう……イクっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……っふぅううっ♪　んふぅううううう～～～～～♪　……ンン♪　んぅ！\n　んん……。どっぴゅどぴゅっ……ドックドク……ああああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404304" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「っはぁああ……♪　ものすごい射精だった……。精液の威力で腰が浮き上が\nるような……、身体がガクガク震えるような強力な射精……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ハハ……♪　貴様もやるじゃないか。いつまでもひ弱だと思っていたが……\n私をここまでおかしくさせるチンポに鍛え上げていたなんてな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ほんの少しだが、見直したぞ。……ふぅ……♪　……ん？　私もスッキリサ\nッパリできたか、だと？　そ、そうだな……その点は気にするな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……目的通りに……。いや、目的異常に身体がすがすがしくスッキリした。\n……まあ、それが貴様のおかげだといえばそうかもしれない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……調子に乗られてしまうのは嫌だが。助かったよ。……というか、今度、\nまた試合がある時には……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私をこうして助けてくれないか？　そうしたら……私は試合に全力で取り組\nめる。貴様に協力してほしい……。かまわないだろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……と、油断させたところで……それっ♪　ハハッ……射精寸前で腰を引い\nて……。チンポにおあずけさせてやったぞ。悔しいか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様はマンズリで果てさせてやる……。んっ……ンン……♪　中には一度精\n液をもらったから、な……次は身体に浴びせてもらおう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「んっ……あっ、あぁ……ああっ、はぁっ♪　見え、るか……？　さっき貴様\nがドクドク注いだ精液が、愛液に混じって溢れ出しているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ヌメりが増したオマンコに、チンポの先を押し当てて……。くぅっ……。出\nしたいか……？　出したいだろう……！　んんっ、ンッ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「貴様のチンポに詰まった膿を、私が身体で受け止めてやる……さあ！　ぶち\nまけてみろっ……準備は出来ている……！　ほら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ハハッ……！　あはははっ、はははは……出たっ！　出た、……あっ！　あ\nぁっ……！　私の汗を洗い流すように、精子が、精液が……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404406" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「精液のシャワーだ……っ♪　んんぁあ……！　熱くてヌルヌルして……！　\n私の肌にはりつく精液……。んっ、外に出したからよかったものの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これを膣内で……子宮の中で爆発させられていたら、卵子に逃げ場などなか\nったはずだ……♪　ククッ、オマンコだけでは受け止められない量」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404408" ]},
		{"command":[ "SETIMAGE", "0", "still_00001604_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これほどの量を浴びられてとても嬉しいぞ……。褒めてやる！　っあ……♪\n　疲労した肉体に注がれる、白濁の雨……心地いい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「これからも、試合の日にはこのシャワーを浴びたい……。浴びなければ満足\nできない♪　次も頼んだぞ……絶対に来るがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_0404410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}