		{"command":[ "SETIMAGE", "0", "still_00001604_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「でなければ……。あっ♪　な、生殺しのまま……。射精寸前でキツく締めつ\nけて、尿道口を解放してやらないぞ。それは地獄の苦しみだろう……？」", "NORMAL" ]},
