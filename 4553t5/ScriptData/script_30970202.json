{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなところで一人寂しくなにしてんだ？　ホクシィたちはどうした？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「全員海に行ったから、強制的に荷物番をさせられてるのか……なるほどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「荷物番してるってことは、暇ってことだよな。それならオレに日焼け止めを\n塗ってくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「どうせ暫くここから動けないんだろ？　だったら、丁度いいじゃねぇか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ぶつくさ言ってないで、さっさと塗ってくれ。オレも早く海で泳ぎたいから\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ちょ……！？　オマエ、何処に手を入れて……！？　あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「手が滑っただぁ……！？　アソコ丸出しにしながら胸揉んでるのに、そんな\nイイワケが通るとでも思ってんのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やっ……あっ！　やめっ、おっぱい弄るなっ……！　オレのアソコに粗末な\nモン擦りつけるなぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「アソコが濡れてきてるって……そんなワケあるか！　これは……そ、そう！\n　お前が塗ってた日焼け止めだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、んんっ！　腰を動かすたびに、ぐちゅぐちゅ音が強くなってる\nって……！？　そんなの気のせいに決まってるだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やああっ！　乳首を強く摘まむなっ！　ちゃんと正直に言うから、そんなに\n激しくするんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そ、そうだよ……これはオレのエッチな汁で……隊長ので擦られて、アソコ\nから溢れてきてんだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くっ……！　お、オマエが悪いんだからな！　オレをその気にさせたこと、\n後悔させてやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「えっ……んっ！　ま、待て……なに挿れようとしてやがる……！　後悔って\n、そういう意味で言ったワケじゃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んぐっ、んはあぁ……！　入って、くる……！　隊長のガチ\nガチに勃起したモンが、オレの膣内に……くはあああぁん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぐっ……！　オレの膣内が隊長のでいっぱいに……！　んっ、あっ\n……これ、大きすぎる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぅ……どうした？　オレのアソコが気持ちよすぎて、声も出ないっ\nてか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だったら、オレを襲おうとしたバツを受けてもらわないとな……！　んおお\nおおぉっ！　ラビットパワー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ！　ふっ、んぐうぅ！　どうだ……！　この飛び跳ねるような\n動き……！　根本から先端まで、ずりゅずりゅ擦られて気持ちいいだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　言葉にしなくてもわかるぜ。こうして上下に動くだけで、隊\n長のがビクビクうごめいてるからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「アソコを締め付けながら、傘の部分をアソコのヒダに引っ掛けて一気に下ろ\nせば……！　はああぁ……！　あっ、ふあああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ……！　これ、ヤバい……！　勢いよく動いたせいで、子宮口\nに隊長のが当たってすげぇ気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ここを重点的に突かれたら、意識が飛んじまう……！　あっ、あっ！？　ち\nょ、なんでオマエが腰を動かしてんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やああっ！　んっ、んぎゅっ……！　奥、気持ちいいっ！　小刻みにトント\nンされると、アソコから汁が溢れて止まらなくなっちまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オー！　ノー！　ノーーー！　はぁ、あああっ！　クソ……！　調子に乗っ\nてんじゃねぇぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「好き勝手されるのは性に合わねぇんだ！　オレの実力を見せてやるっ！　覚\n悟しやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オマエの動きに合わせてこっちも腰を振れば……！　んっ、あっ！　ふああ\nぁ！？　余計にアソコの肉が擦れて気持ちいいっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「パンパンって打ち付けるたびに、傘の部分が膣内をゴリゴリって削ってる…\n…！　オー！　イエス！　ベリーグッド！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんなにも感じるなんて……さすが隊長。中々やるじゃねぇか……！　オレ\nの動きについてこれるなんて、いいセンスしてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「もしかしたら、オレたち相性がいいのかもな……！　アソコのフィット感も\n丁度いいし……オマエもそう思うだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はうっ、んんっ！　隊長のが大きく震えて……！　アソコじゃなくて、口で\n返事をしろよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「イキそうで、そんな余裕がない……？　そういうことなら……オレもリミッ\nトが近いし、たっぷりとイカせてやるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おらっ！　イケっ！　オレの腰振りで感じまくって、くっさい精子をアソコ\nにブチまけろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふああぁっ！　急に隊長の腰振りも激しく……！？　あっ、あっ！　\nイクッ！　オレもイッちまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、ああぁっ！　はあああぁんっ！　オー！　カミング！　カミン\nグ！　ザーメンカミーーーング！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オーーーゥ！　膣内に精子がっ！　隊長の子種がどぴゅどぴゅ出てるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「子宮の奥まで流れ込んで、オレを孕まそうとしてやがるっ！　あっ、あああ\nっ！　この膣内が満たされる感じ、たまらねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　気持ちいいっ！　ヤバいっ！　イクッ！　イクッ！　オレも\nイッちまうううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああああっ！　アソコを締め付けると、隊長の形がはっきりわかるっ！　ザ\nーメン吐き出してる姿が鮮明に感じとれるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「グッド！　ベリーグッド！　さすがは隊長だっ！　あっ、んはあっ！　ぐっ\n、あっ……ふあああああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……子宮に入りきらなかった精子が、ワレメから溢れてきてるぜ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ったく……こんなに出して、子供が出来たらどうするつもりなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「別にオマエとの子供なら、産んでもいいかなって思うけどさ……ニンジャの\n修行もあったりするからな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「えっ……なっ、また膣内で大きくなってやがる……！？　いま出したばっか\nりだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレを孕ませたいから、もっと膣内で出したい……？　ば、バカ野郎！　そ\nんなことはっきり言うんじゃ……あああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204205" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あっ！　んぐううぅ！？　容赦なくオレの奥に突き入れられてる…\n…！　クソっ、いきなりフルスロットルかよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「少しは手加減ってもんを……ノォオオオーーー！？　子宮の入り口をグリグ\nリすんじゃねぇ！　それ、感じすぎるから……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ！　やっ、はああぁ！　調子に乗るなよ……！　やられたら倍にして\nやり返すのが、ニンジャってもんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「子宮を弄ぶ悪いヤツには、こうして思いっきりアソコを締め付けて……！　\nへへっ。傘の部分がヒダと重なって、相当気持ちいいみたいだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「このままオレの膣内で、思いっきりシゴいてズポズポしてやるっ！　圧迫さ\nれながらゴリゴリ抉られるの、すげぇ気持ちいいだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ほらっ！　遠慮しないで情けない声出しながら、思いっきり感じやがれっ！\n　オレの虜になっちまえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くううぅっ！　あっ、あはああっ！　こんだけ締め付けてんのに、まだ動け\nるのかっ！？　さすが隊長だぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ、ふあっ、ああっ！　浅いところと深いところが、交互に擦れて……！\n　圧迫してるせいで、すごく感じる……んぐううぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へへっ……！　こんな快感を得られるのはオレだけだ……！　ホクシィのヤ\nツには絶対に渡さねぇ……！　隊長はオレのモノだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ちょ、おまっ……！？　ノオオオゥ！？　なんでそんなに激しく\n動いて……！？　あっ、ああっ！　奥っ、潰れちまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、ふあああっ！？　お、おい……！　オレ、なにかしたか！？\n　もしかして、締め付けすぎて痛かったのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204216" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「隊長がオレのモノじゃなくて、オレが隊長のモノ……？　んなっ！？　バカ\n言ってんじゃねぇ！　オレの方が上なんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んひいいぃ！？　またそうやって奥をグリグリしながら小突いて……！？　\nあっ、ダメだ……それされると、すぐにイッちまうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はひっ！？　オマエのもビクビクってうごめいてやがる……！？　あっ、あ\nっ！　イクんだな！？　また精液出すんだな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あ、あっ、あぁっ！　好きなだけ出せっ！　んっ、あっ、んぐうぅ！　イッ\n……イッ、イッピカイエエエェーーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おほおおぉ！？　また子宮の奥にびゅるびゅる出てるっ！？　オレの大事な\nところ、精子で染められてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ！　身体の芯が焼けるぐらい熱いのに、すげぇハッピーな気持ちにな\nりやがるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「こんな感覚知ったら、もう戻れねぇ！　オマエから離れられなくなって……\nあっ、はああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204303" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！？　まだ射精されてるっ！？　さっきよりも多いぐらいのザー\nメンが、オレの膣内に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　出るっ！　オレもアソコから潮が噴き出て……んんんんっ\n～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「はああぁ……さすがにヤバすぎだろ……感じすぎて、足が震えてきやがるぜ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「それにしても、なんであんなにムキになったんだよ……オレが上で問題ねぇ\nだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「女を守るのは男の役目だから、オレが隊長のモノじゃないとイヤだ……？　\nな、なに言ってんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だいたい、オマエよりオレの方が強いんだ。だからオマエを守るのはオレの\n役目なんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「でもまあ……オレのことを大事に思ってくれてるのは、嬉しいけどな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んはああっ！？　急にアソコから隊長のが抜けて……はひいいいぃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ガッデムッ！　なに身体にぶっかけてんだ！？　こんな日差しの中で熱い精\n液浴びたら、余計に熱く感じるだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204402" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ああっ、んんっ！　キツいニオイが充満して……あっ、ああっ！　こんなの\n嗅いでたら、頭がおかしくなりそうだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ！　ダメだ……ニオイでイクッ！　身体についたネバネバの精子\nでイッちまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ふああっ、あっ！　くあああっ！？　イクっ！　イクうううううぅ～～～～\n～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ふああぁ……こんなに身体に精子を付けるなんて……まるでマーキングだな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ウサギも縄張りを主張するためにマーキングするが……こいつはちょっとニ\nオイがキツすぎるぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「これだけマーキングしたら、オレが隊長のモノだって言い張れる……？　ん\nなっ！？　お、オマエ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「マーキングするのはオレの方だ！　さっきもアソコから出た潮を、オマエの\n身体にたくさんぶっかけてるし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204409" ]},
		{"command":[ "SETIMAGE", "0", "still_00009702_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「いいかっ！　隊長はオレのモノ！　つまりオレが上だ！　そのことを忘れん\nじゃねぇぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
