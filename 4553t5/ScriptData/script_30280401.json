{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「おっ……来たわね。とりあえず、そこのベッド寝ちゃいなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いきなり話が見えない？　鈍いわね……察しなさいよ、この部屋に呼びださ\nれてすることなんて……そんなにあるもんじゃないでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ほら……一応さ、この前の戦闘……あんたにしては頑張ってたじゃない。ま\nぁ、そのちょっとしたあたしなりのご褒美、みたいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっと……！　けど、あんたがあたしに手出しするってのはナシ。あくまで\nも、あたしがするご褒美なんだから。オーケー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403104" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふん、よろしい。それじゃ、そこに寝て。もちろん、余計なものは全部脱\nいじゃってね。ほら、さっさとする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふん……じゃあ、あたしも準備しよっかな……んっ、しょっ……と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「これでよし……っと……あーあ、もうオチンチンバッキバキじゃん。気が早\nいにも程があるでしょ、スケベ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002804_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「もっかい言っとくけど、今日はお触りも厳禁だからね。ま……目を閉じろと\nは言わないから？　せいぜいあたしの姿を焼き付けときなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっしょ……それじゃ、こうして……んっ、ぎゅっと……ふふっ、もうビク\nってなってるし……ホントサイズだけは一人前なんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「どれどれ……んっ、ふっ、んしょ……んっ、く……落ち着きのないオチンチ\nン、しっかり捕まえておかないとね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ……まずは、根本の方から軽く扱いてみよっか。こうして……ズリズリ\nって……どう、いい感じ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふふっ、しっかり気持ちいいみたいね。じゃあ、少しずつ上の方……いっ\nてみよっか。よっと……んっしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「この辺は、さっきより敏感でしょ？　まだぎゅってされても平気だろうけど\n……足の指……ぐって食い込ませたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あはっ、今の痛かった？　ちょーっと、力加減が難しいかもね。でも、結構\nそれくらいの方がよかったり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ほら、ムッとしない。心配しなくても、最後はちゃーんと気持ちよくしたげ\nるし。オチンチン……てっぺんのとこ……行くよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふっ……やっぱり、ここが一番感じる場所ってコトよねぇ？　露骨に腰が\n浮きかけてるし……ちょっと緊張してるじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「だーいじょうぶ、今度はゆっくりするからさ……んっ、ぎゅうって……やさ\nしーく、やわらかーく……ほら、いい感じでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ぐにぐに……くにくにって……ちょっとずつ圧を掛けてくのがいい感じみた\nい……ね、気持ちいいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ダメよ、じっとしてる。今日のあんたは見てるだけ……んっ、それだって…\n…結構サービスしてるんだから……いいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふっ……ここぞとばかりにじぃっと見ちゃって……何よ、やっぱり男って\nおっぱいが大好きなのね。まずは、それって感じじゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「別にそこだけじゃない？　へぇ……だったら、あんたはどの辺が好きなワケ\n？　ちょっとフェチっぽいトコとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「足先とか……うなじとか……腋とか……結構、パーツ単位で気にしてる人も\nいるよね……あたしはよく分かんないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「てか、このバレバレな視線……もっとストレートに……オ、オマンコ……見\nたいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「脱いでたら目に入るのは当然……？　うーわ、完全な開き直りだし、キモい\n視線がじっとオマンコ見てくるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ……しかも、このオチンチンの反応の仕方……何だか随分盛り上がって\nらっしゃるみたいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「足を動かすと……微妙にビラビラが動く……本気で、少し引いてるんだけど\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ま……今日はご褒美なんだし……いいよ、見ても……んっ、はっ、んふっ…\n…あっ、んんっ……は……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしも興奮してるって……？　バカ……そんなの、するに決まってるじゃ\nないの……こんなシチュ……冷静に出来るかっての……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも、楽しーよ？　あたしの足の加減一つで、ビクビクってオチンチン震わ\nせちゃってさ……何か表情もコロコロ変わるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そーいうの観察しながら、ズリズリって……擦ってくの……楽しいし……興\n奮するよね……んっ、はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うわ……お汁……出てきたね……何か、クチュクチュ……言いはじめてたの\n、これかぁ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ここまで来たらもうひと押しだよね……どう？　足の先でシコシコされるオ\nチンチン……どれ位で出そう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふーん、もう少し強いのがいいんだ。いーよ、じゃあ……そろそろ出しちゃ\nおっかっ……んっ、ふっ……はっ、あっ……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あふっ……ビクビクしてる……指先に……オチンチンのヤバいの伝わってき\nてる……ほら、もう我慢無理でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いいから……びゅびゅって……出してるトコ見せてっ……ほらっ、思いっき\nり……射精しちゃえっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ひぁっ……！　出たっ……って……めちゃくちゃ出てるしっ……んぁっ、お\n腹っ……おっぱいにも届いてきてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ウソ……こんな勢いすごかったっけ……んっ、あぁ……どんどん出てくるじ\nゃないの……んくぅ……これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、あ……止まったぁ……はぁ、はぁ……こんなに射精して…\n…あたしの足コキ、そんなに気持ちよかったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「えへへ……まぁ、上手く出来てたんならそれでいいんだけどさ。はぁ……ヌ\nルヌルしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ホントいっぱい出したよね……こんなに興奮するなんて、やっぱスケベなん\nだから……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「って……んなこと言ってる間に、またオチンチンムクムクさせてない……？\n　今出したばっかでしょうに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あー、そーいうこと。要するにまだまだ全然物足りなくて、して欲しがりの\nままだって……そーいうことなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「……まぁ、ね。いーけど……続きしても。どうせ、その気になって、このま\nまだと収まりつかないんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「こんなにさせちゃったのは、あたしの責任でもあるし……きっちり面倒みて\n、また射精させたげるわよ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うわ……先っぽから、ドロって出てきた……奥に残ってる分も出し切れてな\nかったってことね。んっ……押し出しちゃう感じにする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ほぉら……こうして……ぎゅーーって……搾り出すみたいなの……ふっ、ん\nっ、はっ……すぐには出ないって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「もう、ヘンなとこでめんどくさいのね。じゃあ、またオチンチンシコシコし\nて、いっぱいドピュってさせてやればいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふ……ほら、こうして……んっ、今度はあまり強くしなくても、敏感だか\nら気持ちいいよねー、んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「分かるよ……まーた、視線もギンギンに感じるし。なーに、精液のついたお\nっぱい……余計にエロく感じちゃってる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あんたがぶっ掛けたんだからね……すっごいにおいしちゃってるし、こんな\nの身体に染み込ませて……変態よね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも……それで、発情してるあたしも同類かも……何か、いつの間にか……\nオマンコ……濡れて来ちゃってるし……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふっ、突っ込みたいの……？　でも、ダーメ……今日は、あたしの足がオ\nチンチンを気持ちよくする役目なんだから……見てるだけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも、ちょっとだけ……くぱって見せたげよっか……んふふ……濡れてるの\n分かるでしょ？　すっごいドキドキしてるから……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、また……オチンチンビクビクってしたね。エッチなところ見ながらシ\nコシコされるの堪らないんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふっ、はっ……んんっ……新しいカウパー出ちゃってる……むき出しのトコ\n……ツヤツヤして、やらしー感じになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「また……出そう？　んふふっ……まーた派手な射精しちゃうのかなー？　今\n度は顔まで飛ばす？　それとも、またおっぱいにぶっ掛ける？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いいよぉ……あたしの足コキで、いっぱい気持ちよくなって……思いっきり\nビュビュッって出しちゃお？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ここから、ラストスパート……んっ、あっ……オチンチン……ぐりぐりっ、\nシコシコっ……あと、少しぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁっ……すごい音っ、ぐちゅぐちゅしてるっ……足コキオ\nチンチンっ……限界に来てるよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いいよぉ、必死に我慢してる顔……でも、もう無理だよね？　プルプルして\nるオチンチン……諦めて……イッちゃえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んぁぁんっ……！　また……出てきたっ、おっぱい狙いの精液っ……溢れて\nくるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁぁん……最初っから……ずっと狙いブレてないし……あたしのおっぱい\n、真っ白にすることしか考えてなかったんでしょ……スケベ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んんっ……でも２回目なのに、これだけいっぱい出せるのは、それだけ良か\nったってことだもんね……なら、許す」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それにしても、んっ……足先もおっぱいもベトベトだし……うぅわー、糸引\nいてる……この中で精子いっぱい泳いでるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「まだ先っぽ震えてるし、後ちょっと出る感じ？　んしょ……あっ、擦ったら\n溢れてくるの、なんか面白ーい。ふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「びゅるびゅるって……今ので最後？　間違いないね？　もう、後から言って\nもしてあげないからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はーい、じゃ、お疲れ。ちゅぱっ……うわ、にが……これが美味しいとかっ\nて感覚はよく分かんないわ……れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「まぁ、絶対無理じゃないし、どうしてもって言うなら、そのうち飲むのもア\nリかもだけど……そのうち、ね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ……それより、ヌルヌルすごすぎでしょ……もう、さっさとシャワー浴\nびる。はぁっ、一緒に……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「調子に乗ってる感じするけど……まぁ、今日は特別ってことでいっか。ほら\n、行こ。あたしの気が変わらないうちにね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「きゃうっ……！　ホントに……顔の方まで飛ばしてきてるし……冗談通じな\nいんだから……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「てか、２回目で、こんな勢い出せるの、本気で性欲魔神過ぎでしょ……んぁ\nぁ……ベトベトするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それだけ、気持ちよかったから……あたしの足コキが良すぎたってこと……\nまぁ、それなら仕方ないかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ていうか、まだオチンチン、ビクビクしてるじゃん……これ、出し切れてな\nいの？　もうちょいコスコスする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、んっ、あっ……びゅるって漏れてきた……流石に、もう勢いは\n弱いわね……ふふっ、続けては無理か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「じゃあ、今度こそ終わりかな？　はい、あたしのご褒美タイム……これでお\nしまい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002804_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「れろ……んっ、うぅ……やっぱ微妙な味ぃ……精液……やっぱクセあり過ぎ\nるし、足でするのがちょうどよかったかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「まぁ気が向いたら、もっと活躍した時に……もうちょっとサービスしてあげ\nてもいいけど。それは、もっと頑張った時だかんね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「とりま、シャワー浴びたいわー。何か少しカピカピになって来てるし。汗も\nかいたからさっぱりしたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「何、一緒に入りたい？　今日のヘンなことはもう終わり……それでもいいな\nら、まぁ……いいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}