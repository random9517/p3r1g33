		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「隊長さま……いらっしゃますか？葉金です。今日、わたくしを呼び出したの\nは……ええ。プライベートなご用事ですわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ええ。わたくし、そういうの……自然と感じ取ってしまうんです。近頃のわ\nたくしを見る、隊長さまの目……卑猥なことを考えているお顔……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わかっていて来たのですから、遠慮はいりませんわよ。ただ、一つお約束し\nていただきたいことが。わたくしは構いませんから、鈴にはこのような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「と、こ、これは……！？部屋が唐突に、聖ダイカスト学園の教室に……！？\nこ、これは一体……。ヴァーチャルシミュレーション……そうですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「それで、この状況でわたくしに何を……。えっ。『鈴を想うその気持ちを証\n明しろ』……？『鈴を誰の毒牙にもかけたくないのなら』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしに、こ、ここでオナニーをしろ、と……？鈴の代わりに？……え？\n代わりにではなく、鈴を想いながら……！そ、それは……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……ここまで強気におっしゃっるということは……証拠を掴んでいるのです\nね。そ、その、わたくしが……時折鈴でしている、こと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104107" ]},
		{"command":[ "SETCHARA", "0", "char_00011501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ですがそれは、強い友情からくるものですし、変身した際に身体に残る、鈴\nの感触に惑わされているだけで……。っ……わ、わかりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「いいでしょう。オ、オナニーくらいなら……。……ですが、見ていて面白い\nかどうかは保証できませんよ。んっ……その……わたくしは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「自らの指で慰めるのが、どうにもうまく出来なくて……。こう、して……机\nの角などに陰部をおしつけて、た、達することが……多いですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「これなら、いつ、でも……どこでも、スカートをめくりあげ、たくしあげる\nだけで素早く行えますし……。自分の指の感触に邪魔されることもなく、て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「た、ただ悦楽に没頭できるのです。……隊長さまならお気づきかもしれませ\nんが。じ、自分の机や……鈴の机で……んっ、んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ちょうどいい角度をさがし、て……んっ、速度を調整すれば……すぐっ♪ふ\nぅっ♪ふぅうっ……うう♪ぁっ……あぁ……！軽い絶頂をおぼえっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「一度スイッチが入れば、あとは気が済むま、で、続けるだけです……。こん\nな、ふう、に♪あっ、あぁっ、あぁっあっあっ♪んー……ッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「疲労がたまってしまうことが欠点ですが……気分はスッキリします。でも…\n…肝心なところは埋まらなくて……。むなしくもなる……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……やっ！隊長さま？したくなったのですか？あっ……だ、だめ……性交は\n、あぁ……！恋人でもない方とだなんて……あっ、い、いやぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「オナニーで濡れているから、そ、挿入を止められない……っ、あああっ！あ\nぁ、入ってしまう！す、鈴、鈴、ごめんなさ……あああああーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「あっ、た、隊長さま……あぁっ！こんなに簡単に……ヌルンと入ってしまう\nなんて……！わたくし、どこかでこうされることを望んでいたの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ん、ぅう……！轟琴の娘とし、て……ぇっ、鈴のライバルとして、友達とし\nて……！立派であろうとし続けたわたくしの本当の望み……のぞ、み……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……隊長さま……！あそこが、わ、わたくしのアソコが熱い……っ\n！とても硬いものでかきまわされて……あぁああんっ、いやぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「感じてはいけないのにっ、あっ！う、動かれると疼いて疼いて止められな…\n…いですわっ、あぁっ、本能がっ、ペニスの侵入を喜んでいますぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ん、ぁ、あ、あぁ……！わたくしっ、わたくし初めてなのですっ……そんな\nにズブズブと動かれて、は……あぁっ、あっあっあぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「い、や……っ！学園長ともあろうわたくし、が！生徒の模範となるべき生徒\n会長のわたくし、が……教室で、教室で性交だなんて……あぐっ、んぐぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「許されることではないのに……あっ！教室でしていると想像するだけ、で、\nアソコがキュンとしてしまって……あぁ、恥ずかしい！恥ずかしいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「鈴ぅ……っ！貴方の信じてくれているわたくし、は……あっあっ！机で浅ま\nしく腰を振りっ……あぁ、教室で抱かれることに興奮する痴女……ぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「あっ、あぁ、ごめん、なさい、清廉潔白な、高潔な生徒でなくて申し訳っ…\n…ありませんんっ……！ごめんなさ、い、あっ、いいの、すごくいいのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「貴方のことを思ってぇ♪一人でしていた時の寂しさが消え、て……んあああ\nっ！頭の中が、アソコの中が、身体の奥がペニスでいっぱいぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「あぁっ、あぁイくぅっ！達します、達してしま……うぅ♪ああああっ♪いや\nぁ……いやぁ、いやぁ……！わたくしがどんどん淫らになっていくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ペニスの力で変えられてしまうぅうっ……！あぅんんっ！それくらいっ、そ\nれくらいスゴいのですっ……女はっ、ペニスを入れるための肉穴ぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「わたくしはっ、隊長さまの男性器を！生殖器を入れられるために、オナニー\nでアソコを濡らしている変態女っです、あっ、あぁ、イク、またイクぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「ふ、ぅううううっ……！うぅ……ッ♪貴方にだけは見られたく、ない……っ\n！隊長、さま……あっ、隊長さまが悪いのですよっ、あぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「隊長さまのペニスが大きすぎるからぁ……っ！わたくしがどうにかしてしま\nいましたのぉおおっ！あっ！あっ！気持ちいいっ、気持ちいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……んッ！？い、今、子宮の近くでペニスがブルブルして……？あっ！？う\n、嘘……だめですっ！中に出すのはだめ！だめ、ですぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「赤ちゃんできてしまいますわっ、隊長さま……！膣内射精はだめっ！できち\nゃう！赤ちゃんできてしまいますからっ……あ、あ、あ、いや、いやぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「あーーーーーーーーっ！出て、る……ッ！いやぁあっ、出てますわ、わたく\nしの奥に……赤ちゃんのお部屋にビュルビュル精液が注がれているううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「んんーーーっ！んーっ、んんんんーーーーーッ！長い、長いですぅっ！射精\nが長いのですっ……妊娠確率がどんどん、どんどんあがって……いやっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「いや、なのに……どうして！？わたくし、今までで一番感じている……ッ！\nああああああ！イキますわ、イかされますっ！膣内射精で絶頂します！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「っんーーーーーーーーーーッ！んぁああああっ、あああああああああーっ！\nペニス、精液、精液、ペニス……ああああ、だ、大好きぃいい……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「……っあぁああ♪　はっ……、い、今、わたくし、とんでもないことを口走\nっていたような……。すみません、意識がトんでしまいまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00011501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "葉金" ]},
		{"command":[ "SETTEXT", "「太腿につたいおちる精液……あぁ……。わたくし、隊長の膣内射精で……。\n淫らな女に変身してしまいましたわ……。どう責任をとるおつもりなの」", "NORMAL" ]},
