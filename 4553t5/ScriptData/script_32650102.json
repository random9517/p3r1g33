{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0094" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様、今日はありがとうございました。隊長様といろんな場所を回れて、\n楽しかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ご飯も美味しかったですし、外界には本当にいろんなものがあるのですね！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「それで、社会勉強としてこんな……ホ、ホテルにまで……。ああ、えっと…\n…その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様……。シャナは、隊長様のこと……す、好き……みたいなんです\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナは、恋愛というものをよくしりません。でも、隊長様といるときに感\nじる胸のせつなさは、きっと恋だと思うのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「……って、いきなりすみません。隊長様は素敵な方ですから、きっとシャナ\nより相応しい方がいらっしゃいますよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「……ひゃっ！？　隊長様っ、急に……。隊長様、シャナの気持ちに……応え\nてくれるのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「う、嬉しいです……！　このままシャナのこと抱いてもいいか、だなんて。\nそんなこと聞かないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナだって……隊長様の気持ちにちゃんと応えたいです。不束者ですが、\nどうかよろしくお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「えっと……こう、でしょうか……？　隊長様に、お尻の穴を見せるような格\n好になればいいんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「い、いよいよ隊長様とエッチしてしまう……シャナは、なんだか緊張してし\nまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「力を抜いたほうがいい……そうですよね。ですが胸の高まりが……ひぅっ！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た、隊長様……そこは……！　んんっ、隊長様が、シャナのお尻の穴に触れ\nて……んぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ぐりぐりって、入り口を……んっ、んんぅ……！　恥ずかしくて、でも、力\nが抜けてしまいます……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「た……隊長様のおちんちんが、シャナの中に入ってしまうんですよね……？\n　どうか、やさしくお願いします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んんぅ……っ！　あっ、ああ……っ！　お、お尻……ぃ……っ！　お尻の穴\nっ、ひろげられ、て……ぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様のが、入ってくる……んくっ、ふぅっ、ふぅ……っ！　んひぃっ、い\nっ、はっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長……様……ぁ……。シャナ……こんな感覚、はじめてです……。お尻の\n中……いっぱい、隊長様が詰まって……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、動いて……おちんちんが、シャナのお尻の中でっ、んぐ\nっ、ゆっくり……動いて……ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、熱いのが……シャナの、お腹いっぱい……こすれているの\nが、わかる……んっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「す、すごくっ、不思議な感じで……。でも、こうして隊長様と繋がっている\nことに、なんだか、安心感を覚えてしまって、ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ああ……。シャナ、せつなくなって、シャナのおちんちんも、硬\nくなってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様、シャナ……おちんちんを、発散させないと……って、その必要はな\nいって、いったいどういう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んひぃんっ！　た、隊長様っ、そこぉっ！　あっ、ああっ、お尻っ、破裂し\nたかのような……刺激がぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、さっきよりも激しく、おちんちんが動いてっ！　シャナの\nお尻の……んひぃっ、同じところっ、おっ、ごつごつって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、隊長様っ、隊長様っ！　シャナ、おかしいっ、おちんちんに触\nれていないのに、先走り汁まであふれて……きてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「くひぃいいいぃぃぃっ！！　でてっ、るぅっ！？　精液がっ、おおっ、でて\nっ、おひだされへ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んはぁあっ、あっ、ああっ、あひぃっ！！　でるっ、んはっ、でてりゅぅっ\n！？　おっ、おぉっ、おおぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様っ、シャナのおちんちんどうなって……ひぃいっ！　隊長様に動かれ\nると、精液がっ、とまらなっ、んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、でりゅっ、なんでぇっ！　おちんちんおかしいっ、シャナの\nおちんちん、おかしくなってっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「なんども射精っ、させられちゃってますっ！　ああっ、こんなにっ、気持ち\nいいの、知らない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様っ、んくっ、シャナのお尻も、気持ちいいですかっ！　気持ちいいか\nら、こんなに腰をふって、しまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、嬉しいですっ！　シャナのお尻で、隊長様も気持ちよくなってもら\nえるなんて……んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「嬉しくてっ、ますますおちんちんが……せつなくぅ……！　ああぁっ、また\nっ、びゅって、精液がっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様もっ、イキそうですか！？　はいっ、そのまま、シャナの中にっ！　\nシャナに、中出ししてくださいっ！　中出し……ああっ、して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁ～～～～っ！！　んひっ、ひいいっ、おひりっ、おひ\nりのなかっ、やけりゅぅうううぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、隊長様のっ、いっぱい……注がれて……！　シャナもっ、シ\nャナもイッてますっ、おひりでぇ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んはぁ……っ、はぁ……こんなにぃ……。満たされた気持ちになるの……い\nままで、経験したことない、感覚です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様……シャナは……シャナは、ちょっと欲張ってしまいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「もっともっと……隊長様に愛していただきたいと、思ってしまいます……。\nどうか……シャナともう一度……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　た、隊長様……また動いてっ、おっ、おちんちん……ああぁん\nっ、まだ、硬い……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様も、同じ気持ちだったんですか？　嬉しいです。シャナに……もっと\n隊長様を感じさせてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んくっ、んふぅっ！　ああっ、はぁあっ！　隊長様、なんだかシャナ……さ\nっきよりも気持ちいい……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんが動くの……いっぱい感じて……ンッ、はぁんっ！　お尻が、動\nいてしまいます……んふぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああっ、おちんちん、感じるぅ……！　隊長様の、太くて立派なお\nちんちん、お尻で、はっきりぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「熱くて、脈打って……んくっ、シャナは、そんなおちんちんに、いっぱい愛\nしてもらってるって、感じてしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、隊長様ぁ、さっきのような、激しいの、ください……。シ\nャナに、隊長様を感じさせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああぁぁあっ！　んひっ、ひぃっ、いいっ、そこっ、おっ、おおぉおっ！　\nくひぃいいいぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「いっぱいでるっ！　また、おちんちんから精液が、とまらなくなってしまい\nます！　くひっ、ひぃいいぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おお、お尻、すごく締まって気持ちいいですか？　ああ、隊長様が気持ちよ\nくなってくれて、嬉しいですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナも……シャナも気持ちいいです……！　隊長様に、後ろからおちんち\nんで、ずんずんってされまくって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちんに、精液をつぎつぎに押しだされているような感じで……んぁあ\nっ、ああぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「なんどもっ、なんどもイクッ！　おちんちんイクぅっ！　おっ、おっ、おち\nんちんおかしくっ、なるぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナのおちんちん、壊れてしまいますっ！　ああっ、おちんちんだけじゃ\nなく、お尻も壊れて……ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様の、どんどん大きくなるおちんちんにっ！　シャナのお尻っ、ひろげ\nられて、元に戻らなくなるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「お尻っ、おひりぃっ！！　隊長様専用になるっ！　隊長様に愛してもらうた\nめの穴になってしまいますぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……隊長様っ、また、イキそうになってますか？　おちんちん\n、びくびくさせて……んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナもまた、お尻でイキますっ！　隊長様にいっぱいイかせてもらいたい\nです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナは、シャナはもう……頭が真っ白になるっ、何も考えられなくなって\nしまいます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ただ、隊長様のことだけを考えて、お尻イクッ、イク、いい……イッ、イク\nッ、イッくぅうううぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ひゃはぁああああぁぁぁぁ～～～～っ！！　あっ、ああっ、精液ぃっ、また\nたくさんお尻にぃっ、きてますぅうううぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あっ、熱いっ、熱いのいっぱいぃっ！　おひり火傷しゅるっ！　シャナのお\nひりっ、焼け焦げりゅぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ひはっ、はっ、はぁっ、んひぃ～～～～っ！！　お、おお……おひりぃ……\n隊長……しゃまぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「おちんちん、しゅごいっ、まだびくびくして……っ！　でてる……精液まだ\n、止まらない……ふひぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナのお腹がいっぱいになっても、射精……射精ぇ……っ！　はぁ、はぁ\n……ああ……はひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ひぃ……ひぃ……んっ、ひぃ……。隊長……様ぁ……。こんなに、お腹いっ\nぱいに隊長様を感じられるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナは……シャナは今日、隊長様に告白をして、よかったって思います…\n…すごく、嬉しい……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「これが恋愛……そしてセックスというものなのですね……。こんなに、心が\n満たされるだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「隊長様……これからもシャナのこと、いっぱい愛してくださいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そしてこれからも、シャナにいろんなことを教えてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「んひゃぁあああぁぁぁ～～～～っ！？　ああっ、おちんちんが抜けてっ、精\n液っ、んっ、あああぁぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「シャナにっ、いっぱい……！　せ、精液がぁ……隊長様の、精液がかかって\n……んぁっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「精液をかけられているだけなのにイクッ！　イッくぅっ！　身体が、ビクン\nビクンってしてしまいますっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こんなに……いっぱいぃ……っ！　はぁ……はぁ……隊長様の精液……ドロ\nドロがぁ……お尻にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00026501_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ああ……隊長様の精液の匂い……漂ってきて……。んふぅ……シャナは、身\n体が……むずむずとして、しまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はぁ……ンッ、ああ……。お尻も、力が入らなくてぇ……。んんぅっ！　だ\n、ダメです隊長様、あんまり、見てはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「先ほど中出しされた精液が、お尻から、出てきてしまいますから……！　ん\nっ、ああ、だめぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、お尻に力が入らない……精液、トロトロ垂れてきてしまい\nます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「でも隊長様は、こうして溢れでてしまうほどシャナに精液を注いでくださっ\nたのですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そんな隊長様とこうして愛しあうことができて、シャナはいま、とっても嬉\nしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}