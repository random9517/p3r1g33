{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「皆さん、お待たせしました！　次の競技です！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「次はこのビーチの名物、高飛び込み！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「高飛び込みか。さっきのビーチフラッグと比べたら、あんまりポロリ要素は\nないな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ポロリのためにやっているコンテストではないと思いますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520048" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「高飛び込みに参加される選手ですが、紅組はホクサイさん、ゲンナイさん。\nそしてサチ・ハマダさん！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「さっきは紅組が負けちゃったから、今度こそ勝つよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「高飛び込みってはじめてやるから、楽しみだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふむ、飛び込みか。これも立派な修行になるだろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そして白組はウタマロさん、シャラクさん、序さんです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「頑張ろうぜ、シャラ！　序！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「ちょっとぐらいの高さなら、いつも修行で飛んでるからね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「先ほどは妹たちが負けてしまいましたからね。仇はとらせてもらうですよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さあ、高飛び込みのルールは超簡単！　ジャンプ台から飛び込んで、その飛\n距離を競う！　これだけです！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「高いところから飛ぶほど、当然飛距離が出ます！　すごく単純明快です！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「飛距離……？　高飛び込みって、飛んだ時の演技を競い合うものじゃないの\nか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「普通はそうですな。ですがコンテストに参加する人は基本的に素人ですし、\n演技よりも飛距離の方が分かりやすいということでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520049" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「飛距離を競うのであれば、これほど楽なことはない。お前たち、修行の成果\nを見せてみろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "２人" ]},
		{"command":[ "SETTEXT", "「ラビットパワー！　イェーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00009802_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「飛び込み台の高さですが、昨年は２．５メートル、５メートル、７．５メー\nトル、そして１０メートルでした」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ですが今年は違います！　皆さんからのご要望にお応えし、なんと１００メ\nートルの飛び込み台を用意させていただきました！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ワァッツ！？　ひゃ、１００メートル！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「１００メートルって、なん尺になるの～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「ふっふっふ、知ってるですよ。１尺は約３０．３０３センチ！！　昨日たま\nたまクイズ番組で見て憶えてたです。つまり……大体３３０尺です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「聞き間違いか……？　今、１００メートルという単語が聞こえたような……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ねえ、ゲンナイ……１００メートルって、ビルとかマンションで言うと、ど\nれぐらいかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうだね……多分だけど、３０階とかそれぐらいだと思うよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ついでに言うと、２５メートルや５０メートルといった、中途半端な高さは\n一切ありません！　１００メートル一本勝負です！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "４人" ]},
		{"command":[ "SETTEXT", "「絶対死ぬって！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520017" ]},
		{"command":[ "SETCHARA", "2", "char_00009802_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "3", "char_00009902_01", "3", "CENTER", "-200" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「当然ですが、普通に飛び降りたら間違いなくイッてしまうので、水に特殊な\n薬液を混ぜています！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これにより着水時の衝撃を吸収し、身体にダメージがないよう安全に配慮し\nてあります！　こちらは私の身体で実験、検証もしてあります！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「ただ薬液の副作用なのか、水がローションのような状態になっており、着水\nすればヌルヌルべちょべちょのローション塗れになることは必須！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「勿論、かなりの高さなので怖いと思ったら辞退していただいて構いません！\n　さあ、我こそはと思うツワモノよ！　かかってこいやぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ローション塗れか……これはなんとしても飛んでもらわないと！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「高さという恐怖がない分、ポロリの方がまだまともに思えてきますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520050" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「安全とはいえ、１００メートルはさすがに無理だ……みんな、この競技は辞\n退しよう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えっと、ニャンコ先生はここに居るホクサイさんたちのお師匠様なんですよ\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そうだが、それがどうかしたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「お師匠様が飛ばないなら、お弟子さんは絶対に誰も飛ばないと思うです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「なので、ここは私が一番最初に飛んで白組に貢献……ひいては、優勝と最優\n秀賞をいただくですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それはダメだよ！　優勝するのはボクたち紅組なんだから！　序くんが飛ぶ\nなら、ボクが最初に飛ぶ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「ダメだよホク姉！　序とホク姉が飛んで、他のみんなが辞退したらポイント\nは１対１……ならここは、私も飛ばないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それだと紅組２点、白組１点になっちゃうね～……なら、あーしも飛ばない\nとダメだよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「オレはホクが飛ぶなら飛ぶぜ！　それに、これで２対３で白組の勝ちになる\nしな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お、お前たち……！　わかった……なら私も覚悟を決めて、最初に飛ぶとし\nよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "４人" ]},
		{"command":[ "SETTEXT", "「どうぞどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520019" ]},
		{"command":[ "SETCHARA", "2", "char_00009802_01", "3", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "3", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "3", "char_00009902_01", "3", "CENTER", "-200" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そこはどうぞじゃないだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520014" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「話もまとまったようなので、皆さんを飛び込み台へご案内します！　観客の\n皆さま、少々お待ちください！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいぞーーー！　みんな頑張って飛び込めーーーーー！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。また不純な応援になっていますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520051" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「さあ、それではトップバッターのサチ・ハマダ選手！　お願いします！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ひっ……！？　こ、ここ……この高さは……さすがの私でも、足が震えてし\nまうぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520015" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お、おい……！　本当に飛び込んでも大丈夫なんだろうな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「当たり前です！　じゃないと、こんな狂気じみた競技にしませんよ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「安全とはいえ、十分狂気じみておるぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そう言われましても……おっと、すいません。主催者からの伝言が……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「あー……サチ・ハマダさん。なんか時間が押してるみたいなんで、巻きでお\n願いします」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「本能による恐怖が、そんな理由で抑えられるわけないだろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520018" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「先生……やはりここは、僕が一番最初に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「待って、ホク姉。ここは私が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ホクにばっかいい恰好させられるか！　オレが最初だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「え～、あーし一番がいいな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人曰く、精神一到飛び降りも成らざらん（せいしんいっとうとびおりもな\nらざらん）……精神を集中して努力すれば、飛び降りれるということです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520016" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「私はもう準備万端です。やはり一番最初に飛ぶのは、お亥様の寵愛を受けし\n『愛と正義の美少女サムライ』たる私しかいないということですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520017" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「お前たち、そこまでの覚悟を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520019" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふっ……これでは師匠である私が一番に飛ばなければ、立つ瀬がないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "４人" ]},
		{"command":[ "SETTEXT", "「どうぞどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520021" ]},
		{"command":[ "SETCHARA", "2", "char_00009802_01", "6", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "6", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "3", "char_00009902_01", "6", "CENTER", "-200" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「だからそこは、どうぞじゃないだろう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520021" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「コントはいいんで、飛ぶなら早く飛んでください」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_002" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「くっ……！　わかった！　飛べばいいんだろう、飛べば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「い、いいいいい……行くぞ……！　いち、にの……さんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「うあああぁぁぁあああぁあああぁあああぁぁぁあああぁーーーーーーーーー\nーーーーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520024" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ぷはっ……！　はぁ、はぁ……見たか、私の勇姿を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520025" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおおおおぉ！　あの全身ローション塗れでヌルヌルのぐちょぐちょな感じ\n……最高だな！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「容姿ではなく、勇姿を見てあげてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520052" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「サチ・ハマダ選手の豪快な飛び降りでした！　さて、記録の方は……！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「……出ました！　記録は５メートル！　５メートルです！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「あんなにも怖い思いをして、ローション塗れになったというのに、たったの\n５メートルだと！？　なにかの間違いじゃないのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520026" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「これはあくまでも飛距離を競い合うものですので、単純に飛び降りただけで\nは飛距離は出ません」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「なっ、なんだそれは！？　そういうのは先に言え！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520027" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「一番最初のルール説明で言いましたよ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そんなの、飛び降りる時の恐怖で全部忘れておるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520028" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「まあいい……ホクサイたちが私の記録を抜いてさえくれれば、なにも問題は\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520029" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「先生！　お疲れ様です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520022" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「先生の飛び降りる姿……私、感動しちゃったよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「さすがはオレたちの先生だぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「本当にすごかったよ。あーしじゃ絶対に真似できないもん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「まさか本当に飛び降りるとは……ニャンコ先生。お見それしたですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520019" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「えっ……どうしてお前たちが下に居るんだ？　まさか、もう全員飛び降りた\nのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520030" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「先生の叫び声を聞いたら、飛び降りるの無理だなーって思って、辞退しまし\nた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520023" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「さすがに、無理はよくないと思うんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520013" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お、オレは別に飛び込んでもよかったけどな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「先生が飛び降りた姿を見て、真っ先にやめようって言ったの、ウタ姉だった\nじゃ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520012" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「妹たちの仇は取れなかったのは悔しいけど、ニャンコ先生の活躍で得点は１\n対１……まだまだこれからです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520020" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "司会" ]},
		{"command":[ "SETTEXT", "「そういうわけで、他の皆さんは辞退されました！　では、勝利した紅組には\n１ポイントを進呈します！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「な、なんだそれはーーーーー！？　納得いかんぞーーーーー！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520031" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだ、そうだーーーーー！　もっと見せろーーーーー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「本当に酷い競技でしたな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520053" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}