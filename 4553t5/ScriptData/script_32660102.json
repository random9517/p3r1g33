{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んふっふっふっふ……♪　いくらバステトおねーさんのこと、信頼して信用\nしているからって……二人っきりになんてなっちゃって良かったのぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「真夜中♪　年頃の男女が二人きり……♪　しかもおねーさんは、扉の側に立\nっているわけで……。部屋のカギを閉めて、君をもう逃がさない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……なぁんて、私の目論見も、わかっていてきみはノってきたんだね♪　ス\nゴい自信……。これから何をさせられるかわかっているくせに……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00026601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……ふふ♪　そうだよ。おねーさん、きみとエッチしにきたの。だから脱が\nして。……そう、少しずつでいいよ……。はぁ、はぁ、じゃあはじめよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ♪　もうおねーさん、全然我慢できないの……♪　ほらぁ、見て？　お\nまんこが充血して、たらたらおツユを垂れ流してる……。クリも勃起中♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「今日はずーっとこんな感じだった。発情してたの。オトナの女のいやらしい\n匂い……。ケダモノの、メス猫の発情期の匂いをぷんぷんさせて誘ってた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「なのにきみったら、わかってて私の出方を待っているんだもん。そりゃ、辛\n抱できなくなって誘惑しちゃうよね♪　ねえ……おちんちんちょーだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「もう、なーんにも前戯しなくても、愛撫しなくてもすぐにおちんちん入れら\nれると思うよ。奥の奥まで濡れてるの。子宮がキュンキュン疼いてる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「だから……。あっ♪　ンンッ、じ、焦らさないでぇ……♪　ねーえ、きみの\nおちんちんが立派で、めちゃくちゃ美味しそうなのはもうよくわかってるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「なのに見せつけて、私のまんこの入口にこすりつけるだけで……！　はぁっ\n♪　おあずけするなんてズルすぎるよぉ、こんなに欲しがってるのにぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……ね？　ヒク、ヒクってワレメがヒクついてる♪　中だってすごいんだよ\n？　濡れたヒダヒダがうねっておちんちんをすっごく待ってるの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「きみのが入ってきたら、どれだけ気持ちいいんだろうって……そんな妄想だ\nけでクリトリスもビンビンになって、もどかしくって頭ヘンになっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「おねがいぃ……♪　バステトおねーさん、どうしてもきみのおちんちんが欲\nしい～♪　入れてぇ♪　挿入して♪　もちろん、避妊なんていらないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んっ♪　この、長くてふとーいおちんちん、おねーさんのおまんこで食べた\nぁい……♪　ねーえ♪　脳みそ溶けちゃうよぉ、欲しくて狂っちゃうぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「絶対絶対気持ち良くするから、おちんちん貸してぇ♪　乱暴にしてもいいよ\n、……ううん、乱暴にして？　強引に犯して、お願い、お願い～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「えっ？　い、入れてくれるの！？　やぁああったぁあああ～～～♪　ん、こ\nこだよっ♪　この穴ぁっ、一番ぐちょぐちょのところに刺して！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んッお……っ♪　おぉおおおおっ♪　んぁあ！？　でっか……っ！　あっ！\n？　ああっ、おちんちん、おちんちんでっかすぎぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「はひぃいいっ♪　ああああっ♪　ゴメッ……♪　ゴメンンッ♪　入れてもら\nっただけでガチイキしちゃっ、た……んあああ♪　絶頂止まんないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「な、にこれ、なにこれぇええ♪　エッチ、こんなに気持ちよくて大丈夫！？\n　赤ちゃん作る大事な儀式、なのに快楽強すぎない！？　アヘアヘになるぅっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「あっ♪　あああああっ、あああああああ～っ♪　や、やばいよぉ！　なんで\nぇ！？　挿入だけでもう、何度も何度もおまんこと脳がイッてりゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……んぁああああ♪　目の前がチカチカすりゅっ……！　ま、まだ動いちゃ\nだめだよ！　今動かれたらおねーさん馬鹿になるから……。っんっ！？　ぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「こ、こらぁあああっ♪　前フリじゃないからっ、ホントに！　ホントに今っ\n！　今ピストンはまずいのぉっ♪　あひっ！？　ひぃっ、なにこれぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「イグイグイグイグっ……！？　んふぁあああ♪　う、うん？　うんっ、も、\nもちろんイヤとかじゃないよ、うれしーよ、うれしい、大好き、だいしゅき」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「好きだけど！　なんか、気持ち良すぎるの！　きみのおちんちん、私のおま\nんこに入れるために存在してるみたいにすーっごく相性良くて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んあっ！　入ってるだけでしゅごい、少し動かされるだけでひゅごい、……\nんぅうう！？　らめぇっ、おっきく動かれたら超ひゅごいいいいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「うあっ♪　ああっ♪　か、カワイイ喘ぎ声出せなくなりゅっ♪　えええっ？\n　私、女神なのに！？　こんっな一方的にイカされまくっちゃうのぉおっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「っあ～～～♪　ああっ、んあああああ～っ、ああああ～ッ♪　ひぇえっ♪　\nんひぃいっ！　ひぃんんんっ♪　も、悶絶ぅ、悶えちゃう、こんなのぉお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「焦らされてから一気に入ってきたから？　おまんこずーっとトロトロのまま\nで、入れてもらうの待ってたから？　それともきみがエッチの天才！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「わ、わかんないよぉ、なのにむっちゃくちゃ気持ちイイの……っ！　あっ！\n　あっ！　やば、いよぉ、これ以上快感、快楽、味わったら気絶する、のに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「私ぃ、自分でも腰をヘコヘコさせちゃってるぅう、勝手に身体が動くのっ…\n…♪　あっ♪　あっ、腰、揺らしておちんぽ貪りはじめてるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「んんんんっ♪　ごめんんっ、ごめんねええっ♪　綺麗で清楚なバステトおね\nーさんでいたいのにぃっ♪　もう頭も体もアッヘアヘだよぉおおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「気持ちイイ♪　気持ちいいいっ！　……えっ？　きみもやばいの！？　あっ\n！　そ、そっか私ずっとイッてるから……おまんこがうごめいて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「きみのおちんちん、容赦なく絞り取ろうとしちゃってるんだ！　ごめんっ…\n…でも止められない、本当にイクのやめられないぃっ、んああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ねえ♪　一回私を落ち着かせてぇ♪　そうっ、このまま射精して、精液を注\nいで……満たしてみてっ！　お願い♪　お願い♪　精液ちょうだいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「絶対絶対おまんこの中に出して♪　っぁっ♪　奥っ、そこ！　一番奥っ、子\n宮めがけて精液くださぁい！　精液ぃっ、精液ぃ……あああ、イクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ♪　きたぁああ♪　中出しぃっ♪　膣内射精、生射精ぃいい\nっ……♪　うん！　これだよ、これでいいの、だからやめないで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「わた、ひのおまんこの奥に精液ちゃんと出てるぅ……！　あっあっあっ！　\n燃えてるみたいに熱い……♪　生命の奔流を感じりゅううう♪　素敵♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「全身にエネルギーが満ちていくみたい♪　んぁあああ♪　乾きが癒える、私\nの肉体に訪れていた乾季が……雨季に変わってく、潤ってくぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ああっ、あああああっ……ふぁあああああ……！！　イクイクイクぅううっ\n！　限界までイ、く……♪　あ～～～～っ♪　んあああああ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ひぃいいんんっ♪　んひぃいっ、びゅうびゅうきてるぅうう♪　精液気持ち\nいい、大好き、大好きぃいい……♪　あああああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……ん……、ぅ……♪　い、今一瞬、気を失っちゃってたかもしれない。う\n、うん、ちょっとだけ落ち着いた……。でもまだイクのは終わらないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「楽にはなったかも……。余韻はすごいし、頭もぽーっとしてるけどね……。\nはぁ、はぁ、はぁ……ふぁ……♪　……あ、ああ、そ、そういえば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「私ばっかりずっと絶頂させてもらってて、きみの方はどうなってる？　無理\nやり射精させちゃったけど、強引だったよね？　いやじゃなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……え？　まずは落ち着かせるために出したけど？　……う、うん。次はき\nみのペースでしたい？　……次？　あっ、も、もしかしてこのまま！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「２回戦……するの？　あ、あ、絶倫～……♪　で、でも……そうだ、ね？　\n確かにおちんちん、まったく萎えてない。むしろギンギンで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「わ……わかったぁ。それじゃあ２回目は、きみの好きなスピードで動いて…\n…♪　……っ、ぁ♪　わ、私も腰、揺らしちゃうけどそれは秘密、ね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「……っん……♪　んんっ♪　ンンッ……♪　んん……。うんうん？　最初は\nゆーっくり？　出したばっかりの精液と私の愛液を中で混ぜ合わせて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「たっぷり潤滑油をおちんちんに塗ったら……。うあっ！？　あっ！　激しめ\nに、股間を打ちつけて……あっ？　速度を急加速ぅ！？　……んぁんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「ああんんっ♪　あんっ！？　あんっ♪　あんあんっ！？　んんんっ！？　け\n、結局これじゃ、わ、私主導の時と同じ……！　ん！？　ち、ちがう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_266_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バステト" ]},
		{"command":[ "SETTEXT", "「さっき私に絞り取られたから？　今度は自分が攻めてる？　そ、そうなんだ\n……♪　おまんこのうねうねで精液絞り上げられちゃったから？　あっ♪」", "NORMAL" ]},
