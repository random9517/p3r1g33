{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "147_0103101" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「た、確かにあなたの部屋でゲーム配信しよう……？　って言ったけどさ。こ\n、こんなことになるなんて……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103102" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「つ……つまり、その、アレだよね。あたしに隊長のオチンポを舐めろって\n言ってるんだよね？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103103" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「イヤっていうか……そ、そうじゃなくってさ。あたし経験ないから。男と付\nき合ったこともないし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103104" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「うぅ、恥ずかしい、こんなこと告白する日が来るなんて……っ。だから人並\nみの知識しかないし」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103105" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ちゃんと出来るかどうか分からないよ。それでもいーい？　い……いいんだ\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103106" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「じゃあ、うまく出来たらあたしの頭よしよししてね。あ……ま、まだ早いっ\nてば」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103107" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「それじゃ……こ、こうかな？　ちゅる、ちゅっ、ちゅぱ……咥えるの？　頬\n張っちゃうんだ……はうううぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103108" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「すっごいエッチ……！　自分の姿を想像しただけで、興奮してきちゃったよ\nぉ……うぅ、う……うん。大丈夫」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103109" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「はぁ……はあぁ、あむっ。ちゅる、ちゅば……んんぅ、こんなの絶対に配信\nできないよぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103110" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ふぇ……！？　ば、バカっ！　配信したらアカウントＢＡＮされちゃうって\nば……ちゅるりゅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103111" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「初めてにしては舌の使い方が上手い？　ほんと？　良かったぁ……それじゃ\nあ、こう……かなあ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103112" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ちゅむむ、ちゅる、んんぅ、ちゅばっ、ちゅっ、ちゅるる……！　んっ、ん\nっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103113" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ちゅぷぷ、ちゅむっ、ふあぁ……隊長のオチンチンこんなにおっきかったん\nだね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103114" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「あたしのお口の中で暴れ回ってるよ……？　ちゅむむ、んふぅ、裏筋……っ\nて何？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103115" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「こっち？　こっちしゃぶればいいの？　ちゅるるる……！　ちゅぷ！　ちゅ\nぷっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103116" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ちゅっぽ、ちゅぽ！　んふぅ……頬をすぼませて、こうすればいいんだ……\nの、飲み込みが早い？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103117" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「……うん。昔っから、忍術の師匠にもそう言われたっけ。お手々も使うの？\n」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103118" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「いいよ、隊長を満足させたいから……あたし頑張っちゃう！　タマタマは\n　優しくだよね……きっと」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103119" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「撫でて、さすって……んふふ、んあぁ……赤くて黒くて、すっごいたくまし\nい……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103120" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「って、あたしってば何を言ってるんだろ、すごく恥ずかしいよぉ……！　フ\nェラチオ、だなんて……すごい絵面……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103121" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「えっ……ええええ！？　さっきからスマホで撮ってる！？　配信はしてない\nから安全、って……ダメだってばぁ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103122" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「隊長の個人観賞用？　あたしがオチンポしゃぶってくれない時に観ながら\n……お、オナニーする……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103123" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「う、ううう……っ！　もぅ！　ちゃんとしゃぶるから。オチンポしゃぶって\n、満足させるもん、断らないからっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103124" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「だから許可も得ずに撮っちゃダメっ。いーい？　うっ……じ、自分ですごい\nこと言っちゃった気がする……もぅぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103125" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「あなたのせいなんだからね！　はあぁ、ほら……これ、きっと好きでしょ？\n　タマタマを撫でて、オチンポしごかれながら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103126" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「先っぽを、こう……だもん！　ちゅるりゅ！　ちゅるるる！　んふふ♪　オ\nチンポがビクってしたぁ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103127" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「えっ？　もっとして欲しいの？　根元まで咥える……！？　そ、そうだね。\nあたしなら出来るかも……上達早いし」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103128" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「じゃあ、やるよ？　あむっ、ちゅるる、ちゅむ……んんんぅ！？　じゅむむ\n……じゅるりゅ！　じゅぽ！　じゅぽっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103129" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「けふぉ！　だ、大丈夫、コツ分かってきたからぁ、じゅぷぷ、じゅっぷ！　\nんあぁ……じゅぷ！　じゅぷ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103130" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「んあぁ……オチンポの先から変な汁が溢れてきて、不味いよぉ……？　気持\nちイイ証拠、なの？　イキそうになってる？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103131" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「うん……じゃあ、イッて？　あたしの初フェラで満足しちゃって……隊長」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103132" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ちゅむむ、ちゅぷ！　ちゅっぽ、ちゅぷぷ、裏筋を責めて……ちゅるる、ち\nゅるりゅ、んふああぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103133" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「尿道を責めて……りゅぷっ、りゅぷっ、んふぅ……喉まで咥えちゃうもん、\nんむぅ、じゅぷぷ！　じゅっぽ！　じゅぽ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103134" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「んふううぅ！　あたし今ぁ……○○さんのオチンポで喉まで犯されちゃって\nるぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103135" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅぷぷ！　んんぅ、来る……！？　来るの！？　じゅぷ！　じゅ\nぷっ！　来てっ……んっ、んんぅ、じゅむむ、ん～～～っ！！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103136" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「んああぁぁ……！！！！　じゅむみゅっ、ごきゅっ……！　んあぁ、やっぱ\nり精液って美味しくない……ね」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103137" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「熱くて、ネバネバで、んあぁ……す、すっごくエッチな匂いで、変な味ぃ…\n…んんぅ、もぅ、全部飲めっていうの？　バカぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103138" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「ちゅるりゅ、ちゅる、ごくっ……ごきゅ、あぁ、ネバネバして飲み込めない\n……ちゅる、ちゅうぅ、んふぅ、ごきゅ……ごっ……くん」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103139" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「どーお？　満足してくれた……？　って、ま、またオチンポ大きくなってる\nし！　どうなってるの？　えっ……一回ぐらいじゃ満足しない？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00014701_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "147_0103140" ]},
		{"command":[ "SETNAME", "ツバメ" ]},
		{"command":[ "SETTEXT", "「んもぅ、分かった。じゃあ満足するまでオチンポしゃぶったげる♪　えへへ\n、本番は……まだ、その、恥ずかしいから、フェラで我慢してね♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}